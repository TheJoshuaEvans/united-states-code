{"tag":"section","attrib":{"id":"ida1d22a2b-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s328a"},"text":null,"children":[{"tag":"num","attrib":{"value":"328a"},"text":"§ 328a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Active Guard and Reserve duty: State disaster response duty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida1d22a2c-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s328a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The chief executive of a State who has declared an emergency in such State due to a disaster, may, with the consent of the Secretary of Defense, order a member of the National Guard of such State, who is performing Active Guard and Reserve duty pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s328"},"text":"section 328 of this title","children":[],"tail":", to perform duties in response to, or in preparation for, such disaster. Duty performed under this section shall be referred to as “State disaster response duty”."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1d22a2d-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s328a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"State disaster response duty performed pursuant to this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida1d22a2e-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s328a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be on a reimbursable basis, in accordance with subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1d22a2f-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s328a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be performed to the extent that the performance of such duty does not interfere with the performance of the member’s primary Active Guard and Reserve duties of organizing, administering, recruiting, instructing, and training the reserve components; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1d22a30-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s328a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall not exceed a total of 14 days per member per calendar year, except that the Secretary of Defense may, if the chief executive so requests before the end of the 14th such day, authorize an extension of the duration of such duty, not to exceed an additional—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida1d22a31-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s328a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 7 days, if the Secretary determines that such extension is appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida1d22a32-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s328a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 46 days if the Secretary determines that such duty is in support of the response to a catastrophic incident, as that term is defined in section 501 of the Homeland Security Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s311"},"text":"6 U.S.C. 311","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1d22a33-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s328a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida1d22a34-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s328a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the military department concerned shall charge a State for the fully burdened costs of manpower for each day of State disaster response duty performed pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1d22a35-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s328a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such charges shall be paid from the funds of the State of the requesting chief executive or from any other non-Federal funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1d22a36-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s328a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any amounts received by a Secretary of a military department under this section shall be credited, at the discretion of the Secretary of Defense, to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida1d22a37-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s328a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriation, fund, or account used to pay such costs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida1d22a38-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s328a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an appropriation, fund, or account available for the purposes for which such costs were incurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1d22a39-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s328a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the State of the requesting chief executive is more than 90 days in arrears in reimbursing the Secretary of the military department concerned for State disaster response duty performed pursuant to this section, such duty may not be performed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida1d22a3a-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s328a/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless authorized by the Secretary of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida1d22a3b-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s328a/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the requesting chief executive obligates funds for the amount in arrears.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1d22a3c-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s328a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation of Liability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"While performing State disaster response duty under this section, a member of the National Guard is not an instrumentality of the United States with respect to any act or omission in carrying out such duty. The United States shall not be responsible for any claim or judgment arising from the use of a member of the National Guard under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1d22a3d-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s328a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida1d22a3e-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s328a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Active Guard and Reserve duty” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1d22a3f-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s328a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s901"},"text":"section 901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida1d22a40-2930-11f1-9ed5-c078b45cfa95"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tV/s512/a"},"text":"Pub. L. 119–60, div. A, title V, § 512(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/860"},"text":"139 Stat. 860","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida1d22a41-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida1d22a42-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida1d22a43-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tV/s512/b"},"text":"Pub. L. 119–60, div. A, title V, § 512(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/861"},"text":"139 Stat. 861","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tV/s512/b"},"text":"“Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"], the Secretary of Defense shall prescribe regulations under section 328a of such title, as added by subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
