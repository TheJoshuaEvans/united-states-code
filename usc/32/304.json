:"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “or affirmation” are omitted as covered by the definition of the word “oath” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t1/s1"},"text":"section 1 of title 1","children":[],"tail":". The words “Each person” are substituted for the word “Men”. The words “______ National Guard” are substituted for the words “National Guard (Air National Guard)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida1cafe4c-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida1cafe4d-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" struck out “the Canal Zone,” after “Puerto Rico,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/751"},"text":"Pub. L. 87–751","children":[],"tail":" substituted “support and defend the Constitution of the United States and of the State of ______ against all enemies, foreign and domestic; that I will bear true faith and allegiance to them” for “bear true faith and allegiance to the United States of America and to the State of ______: That I will serve them honestly and faithfully against all their enemies whomsoever” and inserted “So help me God.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida1cafe4e-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related S