},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1954-09-03/ch1257/s319"},"text":"Sept. 3, 1954, ch. 1257, § 319","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/68/1160"},"text":"68 Stat. 1160","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s1227/a"},"text":"section 1227(a) of this title","children":[],"tail":"” are omitted as surplusage."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida1cd6f87-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida1cd6f88-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" substituted “National Guard officers: officers” for “officers: Army National Guard; officers” in section catchline and amended text generally. Prior to amendment, text read as follows: “Each officer of the Army National Guard who is promoted to fill a vacancy in a federally recognized unit thereof, and who is eligible for promotion under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3363/b"},"text":"section 3363(b) of title 10","children":[],"tail":", shall be examined for Federal recognition in the grade to which he is promoted. However, a second lieutenant or first lieutenant of the Army National Guard who has served creditably for at least one year in a position prescribed to be filled by a captain, and who has not previously been federally recognized under this section, may be examined for Federal recognition in the next higher grade without regard to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3363/b"},"text":"section 3363(b) of title 10","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida1cd6f89-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida1cd6f8a-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691"},"text":"section 1691 of Pub. L. 103–337","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida1cd6f8b-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Suspension of This Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For authority of the President to suspend this section in time of war or emergency declared by Congress, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s111"},"text":"section 111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
