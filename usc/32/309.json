{"tag":"section","attrib":{"id":"ida1cd6f82-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s309"},"text":null,"children":[{"tag":"num","attrib":{"value":"309"},"text":"§ 309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal recognition of National Guard officers: officers promoted to fill vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each officer of the National Guard who is promoted to fill a vacancy in a federally recognized unit of the National Guard, and who has been on the reserve active-status list or the active-duty list of the Army or the Air Force for at least one year and has completed the minimum years of service in grade specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14303"},"text":"section 14303 of title 10","children":[],"tail":", shall be examined for Federal recognition in the grade to which the officer is promoted."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida1cd6f83-2930-11f1-9ed5-c078b45cfa95"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s2/7"},"text":"Pub. L. 85–861, § 2(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1543"},"text":"72 Stat. 1543","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1630/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1630(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2963"},"text":"108 Stat. 2963","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida1cd6f84-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida1cd6f85-2930-11f1-9ed5-c078b45cfa95"}