html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"323(b)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"323(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"32:154 (last 26 words of last par.).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"32:115 (1st sentence, and 1st 24 words of 2d sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50:1116 (last 15 words of 1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-06-03/ch134/s76"},"text":"June 3, 1916, ch. 134, § 76","children":[],"tail":" (1st sentence, and 1st 24 words of 2d sentence); restated "},{"tag":"html:a","attrib":{"href":"/us/act/1933-06-15/ch87/s13"},"text":"June 15, 1933, ch. 87, § 13","children":[],"tail":" (1st sentence, and 1st 24 words of 2d sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/48/158"},"text":"48 Stat. 158","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-06-03/ch134/s110"},"text":"June 3, 1916, ch. 134, § 110","children":[],"tail":" (last 25 words of last par.); restated "},{"tag":"html:a","attrib":{"href":"/us/act/1922-09-22/ch423/s6"},"text":"Sept. 22, 1922, ch. 423, § 6","children":[],"tail":" (last 137 words of last par.); restated "},{"tag":"html:a","attrib":{"href":"/us/act/1928-05-12/ch529"},"text":"May 12, 1928, ch. 529","children":[],"tail":" (last 25 words), "},{"tag":"html:a","attrib":{"href":"/us/stat/45/501"},"text":"45 Stat. 501","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1952-07-09/ch608/s706"},"text":"July 9, 1952, ch. 608, § 706","children":[],"tail":" (last 15 words of 1st sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/66/503"},"text":"66 Stat. 503","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the words “ceases to have the qualifications prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s300"},"text":"section 300 of this title","children":[],"tail":"” are substituted for 32:154 (last 26 words of last par.), since it is implicit that a member who could not be paid would lose his federally recognized status (see JAGA 1953/9033, 3 Dec. 1953). The last 23 words of subsection (a) are inserted as a necessary implication of the rule stated in "},{"tag":"ref","attrib":{"href":"/us/usc/t32/s309/c"},"text":"section 309(c) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “or warrant officer” are omitted, since ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s101/9"},"text":"section 101(9) of this title","children":[],"tail":" defines “officer” to include warrant officers. The word “detailed” is substituted for the word “appointed”, since the filling of the positions involved is not appointment to an office in the constitutional sense. The word “commissioned” is inserted after the words “composed of”, since the word “officer” alone, in 32:115, referred to a commissioned officer only (see opinion of the Judge Advocate General of the Army (JAGA 1953/4078, 6 May 1953)). The words “who outrank him” are substituted for the words “senior in rank to the officer under investigation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the opening clause is substituted for the words “such transfer”. The words “his Federal recognition is withdrawn” are substituted for the words “shall terminate his federally recognized National Guard or Air National Guard status”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida1cfb8dd-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida1cfb8de-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1958 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section of title 32","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"323(d)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"323(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:1261 (as applicable to Federal recognition).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50:1352(e)(1) (56th through 63d words).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50:1352(e)(2) (78th through 85th words).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1954-09-03/ch1257"},"text":"Sept. 3, 1954, ch. 1257","children":[],"tail":", §§ 324 (as applicable to Federal recognition), 522(e)(1) (56th through 63d words). (e)(2) (78th through 85th words), "},{"tag":"html:a","attrib":{"href":"/us/stat/68/1161"},"text":"68 Stat. 1161","children":[],"tail":", 1181."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The change [in subsec. (b)(1) and (2)] is necessary to exclude from the efficiency board commissioned officers of the Army Reserve or Air Force Reserve, in accordance with the source law, the first sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-06-03/s76"},"text":"section 76 of the Act of June 3, 1916","children":[],"tail":", chapter 134 (formerly "},{"tag":"ref","attrib":{"href":"/us/usc/t32/s115"},"text":"32 U.S.C. 115","children":[],"tail":" (1st sentence))."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s115"},"text":"section 115 of title 32","children":[],"tail":"” are omitted as surplusage."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “if appropriate” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida1cfb8df-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida1cfb8e0-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1676/a/3"},"text":"Pub. L. 103–337, § 1676(a)(3)","children":[],"tail":", substituted “12105, 12213(a), or 12214(a)” for “3259, 3352(a), 8259, or 8352(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1630/2"},"text":"Pub. L. 103–337, § 1630(2)","children":[],"tail":", added subsec. (d) and struck out former subsecs. (d) and (e) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(d) Except as provided in sections 1005 and 1006 of title 10, the Federal recognition of a second lieutenant of the Army National Guard who is discharged under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3820/c"},"text":"section 3820(c) of title 10","children":[],"tail":" for failure of promotion shall be withdrawn on the date of that discharge."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(e) Except as provided in sections 1005 and 1006 of title 10, the Federal recognition of a reserve officer of the Air Force who is not recommended for promotion under section 8368(c)(1) or (2) of title 10, or who is found to be not qualified for Federal recognition under section 8368(d) or (e) of title 10, shall be withdrawn.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s33/c/2"},"text":"Pub. L. 85–861, § 33(c)(2)","children":[],"tail":", substituted “the Regular Army or the Army National Guard of the United States, or both” for “a regular or reserve component of the Army”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s33/c/2"},"text":"Pub. L. 85–861, § 33(c)(2)","children":[],"tail":", substituted “the Regular Air Force or the Air National Guard of the United States, or both” for “a regular or reserve component of the Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s2/11"},"text":"Pub. L. 85–861, § 2(11)","children":[],"tail":", added subsecs. (d) and (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida1cfb8e1-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida1cfb8e2-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1676/a/3"},"text":"section 1676(a)(3) of Pub. L. 103–337","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-12-01"},"text":"Dec. 1, 1994","children":[],"tail":", except as otherwise provided, and amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1630/2"},"text":"section 1630(2) of Pub. L. 103–337","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691"},"text":"section 1691 of Pub. L. 103–337","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida1cfb8e3-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1958 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s33/c/2"},"text":"section 33(c)(2) of Pub. L. 85–861","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1956-08-10"},"text":"Aug. 10, 1956","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s33/g"},"text":"section 33(g) of Pub. L. 85–861","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida1cfb8e4-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Suspension of Subsection (d) of This Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For authority of the President to suspend subsec. (d) of this section in time of war or emergency declared by Congress, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s111"},"text":"section 111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
