{"tag":"section","attrib":{"id":"ida1d49a9a-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s504"},"text":null,"children":[{"tag":"num","attrib":{"value":"504"},"text":"§ 504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Guard schools and small arms competitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida1d49a9b-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under regulations to be prescribed by the Secretary of the Army or Secretary of the Air Force, as the case may be, members of the National Guard may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida1d49a9c-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s504/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attend schools conducted by the Army or the Air Force, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1d49a9d-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s504/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct or attend schools conducted by the National Guard; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1d49a9e-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s504/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in small arms competitions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1d49a9f-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Activities authorized under subsection (a) for members of the National Guard of a State or territory, Puerto Rico, or the District of Columbia may be held inside or outside its boundaries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida1d49aa0-2930-11f1-9ed5-c078b45cfa95"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/611"},"text":"70A Stat. 611","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/621/s1/2"},"text":"Pub. L. 88–621, § 1(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-03"},"text":"Oct. 3, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/999"},"text":"78 Stat. 999","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tXII/s1234/b/1"},"text":"Pub. L. 100–456, div. A, title XII, § 1234(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2059"},"text":"102 Stat. 2059","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida1d49aa1-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida1d49aa2-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida1d49aa3-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"504(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"504(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"32:64 (1st sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"32:64 (less 1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-06-03/ch134/s97"},"text":"June 3, 1916, ch. 134, § 97","children":[],"tail":" (less last sentence); restated "},{"tag":"html:a","attrib":{"href":"/us/act/1926-05-28/ch417/s2"},"text":"May 28, 1926, ch. 417, § 2","children":[],"tail":" (less last sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/44/674"},"text":"44 Stat. 674","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “members” is substituted for the words “officers, warrant officers, and enlisted men”. The words “for the purpose” and “for that purpose” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “Assemblies under subsection (a)” are substituted for the words “such assemblages”. The words “for members of the National Guard of a State or Territory, Puerto Rico, the Canal Zone, or the District of Columbia * * * inside or outside of its boundaries” are substituted for the words “either within or without the State, Territory, or District of Columbia, to which the members of the National Guard designated to attend them shall belong”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida1d49aa4-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida1d49aa5-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" struck out “the Canal Zone,” after “Puerto Rico,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/621"},"text":"Pub. L. 88–621","children":[],"tail":" substituted provisions authorizing the Secretaries of the Army and of the Air Force to issue regulations, for provisions authorizing the President to issue regulations, and provided that members of the National Guard may conduct or attend schools conducted by the National Guard."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
