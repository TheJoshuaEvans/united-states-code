ldren":[],"tail":" (39th through 56th words); restated "},{"tag":"html:a","attrib":{"href":"/us/act/1920-06-04/ch227"},"text":"June 4, 1920, ch. 227","children":[],"tail":", subch. I, § 41 (39th through 56th words), "},{"tag":"html:a","attrib":{"href":"/us/stat/41/781"},"text":"41 Stat. 781","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-06-03/ch134/s75"},"text":"June 3, 1916, ch. 134, § 75","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/act/1933-06-15/ch87/s12"},"text":"June 15, 1933, ch. 87, § 12","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/48/158"},"text":"48 Stat. 158","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1952-07-09/ch608/s803"},"text":"July 9, 1952, ch. 608, § 803","children":[],"tail":" (10th par.), "},{"tag":"html:a","attrib":{"href":"/us/stat/66/505"},"text":"66 Stat. 505","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1952-07-09/ch608"},"text":"July 9, 1952, ch. 608","children":[],"tail":", §§ 703(a) (as applicable to officers), 705(a) (less last 39 words), "},{"tag":"html:a","attrib":{"href":"/us/stat/66/502"},"text":"66 Stat. 502","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “prescribed by subsection (a)” are substituted for the words “to determine such qualifications for appointment”. The word “designated” is substituted for the word “appointed”, since the filling of the positions involved is not an appointment to office in the constitutional sense. The words “of an individual as an officer or warrant officer” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the word “originally” is inserted for clarity. The words “If such a board finds a person” are substituted for the words “if the applicant has been found”. The words “for individual Federal recognition for the office for which he was found qualified” are inserted for clarity. The words “that office” are substituted for the words “the office for which he was found qualified”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “Notwithstanding the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s113"},"text":"section 113 of Title 32","children":[],"tail":"” are omitted as covered by the words of exception in revised subsection (a). The words “Subject to subsection (a)(1) and (2)” are inserted, since 50:1115(a) (less last 39 words) was not an exception to that part of 50:1113 relating to qualifications prescribed by the Secretary, or to the requirement that only members of federally recognized units can be federally recognized. The words “in his reserve grade” are substituted for the words “in the same grade in which he is appointed as a Reserve officer of the appropriate Armed Force of the United States”. The last sentence is inserted for clarity."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida1cd6f72-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida1cd6f73-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1958 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section of title 32","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"307(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"307(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:1349(b) (1st sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50:1349(b) (less 1st sentence, and less 36th through 58th words of 2d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1954-09-03/ch1257/s519/b"},"text":"Sept. 3, 1954, ch. 1257, § 519(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/68/1179"},"text":"68 Stat. 1179","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"307(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:1349(b) (36th through 58th words of 2d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “to subsection (a)(1) and (2)” are inserted, since 50:1349(b) was not an exception to that part of 50:1113 relating to qualifications prescribed by the Secretary, or to the requirement that only members of federally recognized units can be federally recognized. The words “without the examination prescribed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s113"},"text":"section 113 of Title 32","children":[],"tail":"” are omitted as covered by the words of exception in revised subsection (a). The last 37 words are substituted for 50:1349(b) (last 29 words of 2d sentence; and last sentence)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida1cd6f74-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida1cd6f75-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" struck out “and sections 8365 and 8366 of title 10” after “of this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/535"},"text":"Pub. L. 96–535","children":[],"tail":" struck out subsec. (g) which prohibited extension of Federal recognition to members of the Virgin Islands National Guard in any grade above colonel."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/492"},"text":"Pub. L. 92–492","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s2/6/A"},"text":"Pub. L. 85–861, § 2(6)(A)","children":[],"tail":", substituted “subsections (d) and (e) of this section and sections 8365 and 8366 of title 10” for “subsection (d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s2/6/B"},"text":"Pub. L. 85–861, § 2(6)(B)","children":[],"tail":", added subsecs. (e) and (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida1cd6f76-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida1cd6f77-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-12-01"},"text":"Dec. 1, 1994","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691"},"text":"section 1691 of Pub. L. 103–337","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida1cd6f78-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Suspension of Subsection (e) of This Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For authority of the President to suspend subsec. (e) of this section in time of war or emergency declared by Congress, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s111"},"text":"section 111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
