{"tag":"section","attrib":{"id":"ida1de112b-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s907"},"text":null,"children":[{"tag":"num","attrib":{"value":"907"},"text":"§ 907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to State duty","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed as a limitation on the authority of any unit of the National Guard of a State, when such unit is not in Federal service, to perform functions authorized to be performed by the National Guard by the laws of the State concerned.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida1de112c-2930-11f1-9ed5-c078b45cfa95"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s512/a/1"},"text":"Pub. L. 108–375, div. A, title V, § 512(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1879"},"text":"118 Stat. 1879","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
