{"tag":"section","attrib":{"id":"ida1de112d-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s908"},"text":null,"children":[{"tag":"num","attrib":{"value":"908"},"text":"§ 908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida1de112e-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s908/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement for Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After the end of any fiscal year during which any assistance was provided or activities were carried out under this chapter, the Secretary of Defense shall submit to the congressional defense committees a report regarding any assistance provided and activities carried out under this chapter during that fiscal year. The report for a fiscal year shall be submitted not later than March 31 of the year following the year in which such fiscal year ended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1de112f-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s908/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report for a fiscal year shall include the following matters:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida1de1130-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s908/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The numbers of members of the National Guard excluded under subsection (i)(13) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s115"},"text":"section 115 of title 10","children":[],"tail":" from being counted for the purpose of end-strengths authorized pursuant to subsection (a)(1) of such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1de1131-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s908/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the homeland defense activities conducted with funds provided under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1de1132-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s908/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An accounting of the amount of the funds provided to each State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1de1133-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s908/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the effect on military training and readiness of using units and personnel of the National Guard to perform homeland defense activities under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1de1134-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s908/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the effect of any equipment shortfall on the ability of the National Guard of a State to perform a homeland defense activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida1de1135-2930-11f1-9ed5-c078b45cfa95"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s512/a/1"},"text":"Pub. L. 108–375, div. A, title V, § 512(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1879"},"text":"118 Stat. 1879","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tX/s1071/b/2"},"text":"Pub. L. 109–364, div. A, title X, § 1071(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2400"},"text":"120 Stat. 2400","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tX/s1065/a"},"text":"Pub. L. 112–81, div. A, title X, § 1065(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1588"},"text":"125 Stat. 1588","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tV/s513"},"text":"Pub. L. 119–60, div. A, title V, § 513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/862"},"text":"139 Stat. 862","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida1de1136-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida1de1137-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida1de1138-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" substituted “After the end of any fiscal year during which any assistance was provided or activities were carried out under this chapter,” for “After the end of each fiscal year,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" substituted “(i)(13)” for “(i)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
