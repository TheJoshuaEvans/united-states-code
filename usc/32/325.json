{"tag":"section","attrib":{"id":"ida1cfb8f3-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s325"},"text":null,"children":[{"tag":"num","attrib":{"value":"325"},"text":"§ 325.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relief from National Guard duty when ordered to active duty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida1cfb8f4-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s325/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relief Required","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida1cfb8f5-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s325/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), each member of the Army National Guard of the United States or the Air National Guard of the United States who is ordered to active duty is relieved from duty in the National Guard of his State, or of the Commonwealth of Puerto Rico, Guam, or the Virgin Islands or the District of Columbia, as the case may be, from the effective date of his order to active duty until he is relieved from that duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1cfb8f6-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s325/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An officer of the Army National Guard of the United States or the Air National Guard of the United States is not relieved from duty in the National Guard of his State, or of the Commonwealth of Puerto Rico, Guam, or the Virgin Islands or the District of Columbia, under paragraph (1) while serving on active duty if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida1cfb8f7-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s325/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President authorizes such service in both duty statuses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida1cfb8f8-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s325/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Governor of his State, or of the Commonwealth of Puerto Rico, Guam, or the Virgin Islands, or the commanding general of the District of Columbia National Guard, as the case may be, consents to such service in both duty statuses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1cfb8f9-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s325/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advance Authorization and Consent","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President and the Governor of a State or Territory, or of the Commonwealth of Puerto Rico, or the commanding general of the District of Columbia National Guard, as applicable, may give the authorization or consent required by subsection (a)(2) with respect to an officer in advance for the purpose of establishing the succession of command of a unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1cfb8fa-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s325/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Return to State Status","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"So far as practicable, members, organizations, and units of the Army National Guard of the United States or the Air National Guard of the United States ordered to active duty shall be returned to their National Guard status upon relief from that duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida1cfb8fb-2930-11f1-9ed5-c078b45cfa95"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/607"},"text":"70A Stat. 607","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tXII/s1234/b/6"},"text":"Pub. L. 100–456, div. A, title XII, § 1234(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2059"},"text":"102 Stat. 2059","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tV/s516"},"text":"Pub. L. 108–136, div. A, title V, § 516","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1461"},"text":"117 Stat. 1461","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tX/s1057/b/6"},"text":"Pub. L. 109–163, div. A, title X, § 1057(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3442"},"text":"119 Stat. 3442","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title V, § 517, "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4442"},"text":"122 Stat. 4442","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida1cfb8fc-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida1cfb8fd-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida1cfb8fe-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"325(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"325(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:1120.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50:1122(b) (less last 17 words).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1952-07-09/ch608"},"text":"July 9, 1952, ch. 608","children":[],"tail":", §§ 710, 712(b) (less last 17 words), "},{"tag":"html:a","attrib":{"href":"/us/stat/66/503"},"text":"66 Stat. 503","children":[],"tail":", 504."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “in the service of the United States” are omitted as surplusage. The words “effective date of his order to active duty until he is relieved from that duty” are substituted for the words “active-duty date of the orders and for as long as they remain on active duty in the service of the United States”. 50:1120 (last sentence) is omitted as surplusage, since the persons involved are members of the Army or the Air Force.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “upon relief from that duty” are substituted for the words “upon being relieved from active duty”. The words “their National Guard status” are substituted for the words “to the National Guard and Air National Guard in their respective States, Territories, and the District of Columbia”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida1cfb8ff-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida1cfb900-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/s517/a"},"text":"Pub. L. 110–417, § 517(a)","children":[],"tail":", struck out “in command of a National Guard unit” after “active duty” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/s517/b"},"text":"Pub. L. 110–417, § 517(b)","children":[],"tail":", added subsec. (b) and redesignated former subsec. (b) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" substituted “State, or of the Commonwealth of Puerto Rico, Guam, or the Virgin Islands” for “State or Territory, or of Puerto Rico” in par. (1) and introductory provisions of par. (2) and “State or Territory or Puerto Rico” in par. (2)(B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s516/a"},"text":"Pub. L. 108–136, § 516(a)","children":[],"tail":", substituted “(a) "},{"tag":"inline","attrib":{},"text":"Relief Required","children":[],"tail":".—(1) Except as provided in paragraph (2), each” for “(a) Each” and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s516/b"},"text":"Pub. L. 108–136, § 516(b)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" struck out “, the Canal Zone,” after “Puerto Rico”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"ida1cfb901-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"ida1cfb902-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions and authority of President under this section delegated to the Secretary of Defense, see Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2011-04-14"},"text":"Apr. 14, 2011","children":[],"tail":", 76 F.R. 22003, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t32/s315"},"text":"section 315 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida1cfb903-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"National Guard Support for 2004 Democratic and Republican National Conventions and Other Appropriate Events","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2004-07-23"},"text":"July 23, 2004","children":[],"tail":", 69 F.R. 46397, which delegated to the Secretary of Defense the functions and authority of the President under this section, was superseded by Memorandum of President of the United States, "},{"tag":"date","attrib":{"date":"2011-04-14"},"text":"Apr. 14, 2011","children":[],"tail":", 69 F.R. 22003, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t32/s315"},"text":"section 315 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
