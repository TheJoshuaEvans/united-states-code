{"tag":"section","attrib":{"id":"ida1d22a5f-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s501"},"text":null,"children":[{"tag":"num","attrib":{"value":"501"},"text":"§ 501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training generally","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida1d22a60-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The discipline, including training, of the Army National Guard shall conform to that of the Army. The discipline, including training, of the Air National Guard shall conform to that of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1d22a61-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The training of the National Guard shall be conducted by the several States, the Commonwealth of Puerto Rico, the District of Columbia, Guam, and the Virgin Islands in conformity with this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida1d22a62-2930-11f1-9ed5-c078b45cfa95"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/609"},"text":"70A Stat. 609","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tXII/s1234/b/1"},"text":"Pub. L. 100–456, div. A, title XII, § 1234(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2059"},"text":"102 Stat. 2059","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tX/s1057/b/7"},"text":"Pub. L. 109–163, div. A, title X, § 1057(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3442"},"text":"119 Stat. 3442","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida1d22a63-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida1d22a64-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida1d22a65-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"501(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"501(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"32:61 (1st 24 words).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"32:61 (less 1st 24 words).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-06-03/ch134/s91"},"text":"June 3, 1916, ch. 134, § 91","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/39/206"},"text":"39 Stat. 206","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “that of” are substituted for the words “the system which is or may be prescribed for”. The word “Army” is substituted for the words “Regular Army”, since the Army is the category for which the discipline and training is prescribed and the Regular Army is a personnel category for which no discipline and training is prescribed. Similarly, the words “Air Force” are used instead of the words “Regular Air Force”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida1d22a66-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida1d22a67-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" substituted “States, the Commonwealth of Puerto Rico, the District of Columbia, Guam, and the Virgin Islands” for “States and Territories, Puerto Rico, and the District of Columbia”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" struck out “the Canal Zone,” after “Puerto Rico,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida1d22a68-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida1d22a69-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Accreditation of National Guard Marksmanship Training Center","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tV/s549"},"text":"Pub. L. 119–60, div. A, title V, § 549","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/876"},"text":"139 Stat. 876","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tV/s549"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accreditation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army may accredit the National Guard Marksmanship Training Center (hereinafter, ‘NGMTC’), located at Robinson Maneuver Training Center, Arkansas, as a U.S. Army Training and Doctrine Command institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Validation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon accreditation, the Secretary may designate the Small Arms Weapons Expert and Squad Designated Marksman programs of instruction taught at NGMTC as Training Operations Management Activity validated, National Guard-centric courses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Skill Identifier","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may award the Master Marksman Training additional skill identifier to members of the Army National Guard who successfully complete both programs specified in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Briefing","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2026-04-01"},"text":"April 1, 2026","children":[],"tail":", the Secretary shall submit to the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and House of Representatives] a briefing regarding—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the determination of the Secretary whether to use the authorities under subsections (a) through (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any progress of the Secretary in integrating such programs into the Army Program Objective Memorandum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the determination of the Secretary whether to establish a Modified Table of Organization and Equipment requirement associated with the additional skill identifier described in subsection (c) to ensure enduring demand and sustainment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to transfer operational control, administrative authority, or ownership of the facility of the National Guard Marksmanship Training Center from the Army National Guard to the Department of Defense, the Department of the Army, or the National Guard Bureau.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida1d22a6a-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Pilot Program on Regional Cybersecurity Training Center for the Army National Guard","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVI/s1651"},"text":"Pub. L. 115–232, div. A, title XVI, § 1651","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2139"},"text":"132 Stat. 2139","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVII/s1743"},"text":"Pub. L. 116–283, div. A, title XVII, § 1743","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4135"},"text":"134 Stat. 4135","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXV/s1502"},"text":"Pub. L. 117–81, div. A, title XV, § 1502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2021"},"text":"135 Stat. 2021","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/81/dA/tXV/s1502"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pilot Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army may carry out a pilot program under which the Secretary establishes a National Guard training center to provide collaborative interagency education and training for members of the Army National Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Center.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training and cooperation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary carries out the pilot program under subsection (a), the Secretary should ensure that the training center established under such subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" educates and trains members of the Army National Guard quickly and efficiently by concurrently training cyber protection teams and cyber network defense teams on a common standard in order to defend—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information network of the Department of Defense in a State environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while acting under title 10, United States Code, the information networks of State governments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" critical infrastructure;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" fosters interagency cooperation by—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" co-locating members of the Army National Guard with personnel of departments and agencies of the Federal Government and State governments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing an environment to develop interagency relationship to coordinate responses and recovery efforts during and following a cyber attack;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborates with academic institutions to develop and implement curriculum for interagency education and training within the classroom; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinates with the Persistent Cyber Training Environment of the Army Cyber Command in devising and implementing interagency education and training using physical and information technology infrastructure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Locations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary carries out the pilot program under subsection (a), the Secretary may select one National Guard facility at which to carry out the pilot program. The Secretary may select a facility that is located in an area that meets the following criteria:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The location has a need for cyber training, as measured by both the number of members of the Army National Guard that would apply for such training and the number of units of the Army National Guard that verify the unit would apply for such training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The location has high capacity information and telecommunications infrastructure, including high speed fiber optic networks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The location has personnel, technology, laboratories, and facilities to support proposed activities and has the opportunity for ongoing training, education, and research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary carries out the pilot program under subsection (a), the Secretary should ensure that the pilot program includes the following activities:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing joint education and training and accelerating training certifications for working in a cyber range.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Integrating education and training between the National Guard, law enforcement, and emergency medical and fire first responders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing a program to continuously train the cyber network defense teams to not only defend the information network of the Department of Defense, but to also provide education and training on how to use defense capabilities of the team in a State environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing curriculum and educating the National Guard on the different missions carried out under titles 10 and 32, United States Code, in order to enhance interagency coordination and create a common operating picture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary carries out the pilot program under subsection (a), the Secretary shall provide immediate notification to the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives] that includes information relating to the resources required to carry out such pilot program, identification of units to be trained, the location of such training, and a description of agreements with Federal, State, local, and private sector entities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority provided under this section shall expire on ","children":[{"tag":"date","attrib":{"date":"2024-08-31"},"text":"August 31, 2024","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida1d22a6b-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"National Guard Support on Wildfire Response","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tV/s515"},"text":"Pub. L. 117–81, div. A, title V, § 515","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1683"},"text":"135 Stat. 1683","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tV/s516"},"text":"Pub. L. 117–263, div. A, title V, § 516","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2566"},"text":"136 Stat. 2566","children":[],"tail":", related to National Guard support on wildfire response, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tV/s515/c"},"text":"Pub. L. 118–31, div. A, title V, § 515(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/249"},"text":"137 Stat. 249","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tIII/s351"},"text":"Pub. L. 115–91, div. A, title III, § 351","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1367"},"text":"131 Stat. 1367","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tIII/s385"},"text":"Pub. L. 117–263, div. A, title III, § 385","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2544"},"text":"136 Stat. 2544","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tIII/s314"},"text":"Pub. L. 119–60, div. A, title III, § 314","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/804"},"text":"139 Stat. 804","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tIII/s314"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Secretary of the Army and the Secretary of the Air Force, in consultation with the Chief of the National Guard Bureau, shall provide support for the training of appropriate personnel of the National Guard on wildfire prevention and response. In carrying out this section, the Secretaries—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall give a preference to personnel assigned to military installations with the highest wildfire suppression needs, as determined by the Secretaries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may consult with the Executive Board of the National Interagency Fire Center.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida1d22a6c-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Demonstration Project To Increase Reserve Component Internet Access and Services in Rural Communities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title III, § 390], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–90, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/398/s1/dA"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization and Purpose of Project","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army, acting through the Chief of the National Guard Bureau, may carry out a demonstration project in rural communities that are unserved or underserved by the telecommunications medium known as the Internet to provide or increase Internet access and services to units and members of the National Guard and other reserve components located in these communities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Project Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the demonstration project, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and operate distance learning classrooms in communities described in subsection (a), including any support systems required for such classrooms; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide Internet access and services in such classrooms through GuardNet, the telecommunications infrastructure of the National Guard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2005-02-01"},"text":"February 1, 2005","children":[],"tail":", the Secretary shall submit to Congress a report on the demonstration project. The report shall describe the activities conducted under the demonstration project and include any recommendations for the improvement or expansion of the demonstration project that the Secretary considers appropriate.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida1d22a6d-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Pilot Program To Use National Guard Personnel in Medically Underserved Communities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tIII/s376"},"text":"Pub. L. 102–484, div. A, title III, § 376","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2385"},"text":"106 Stat. 2385","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tIII/s365"},"text":"Pub. L. 103–160, div. A, title III, § 365","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1629"},"text":"107 Stat. 1629","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tIII/s384"},"text":"Pub. L. 103–337, div. A, title III, § 384","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2741"},"text":"108 Stat. 2741","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/337/dA/tIII/s384"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pilot Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief of the National Guard Bureau shall enter into an agreement, approved by the Secretary of Defense, with each of the Governors of one or more States to carry out a pilot program during fiscal years 1993, 1994, and 1995 to provide training and professional development opportunities for members of the National Guard through the provision of health care to residents of medically underserved communities in those States with the use of personnel and equipment of the National Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts made available from Department of Defense accounts for operation and maintenance and for pay and allowances to carry out the pilot program shall be apportioned by the Chief of the National Guard Bureau among those States with which the Chief has entered into approved agreements. In addition to such amounts, the Chief of the National Guard Bureau may authorize any such State, in order to carry out the pilot program during a fiscal year, to use funds received as part of the operation and maintenance allotments and the pay and allowances allotments for the National Guard of the State for that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Supplies and Equipment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds made available from Department of Defense operation and maintenance accounts to carry out the pilot program may be used for the purchase of supplies and equipment necessary for the provision of health care under the pilot program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to supplies and equipment provided through the use of funds under paragraph (1), supplies and equipment described in such paragraph that are furnished by a State, a Federal agency, a private agency, or an individual may be used to carry out the pilot program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maintenance of Effort","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief of the National Guard Bureau shall ensure that each agreement under subsection (a) provides that the provision of services under the pilot program will supplement and increase the level of services that would be provided with non-Federal funds in the absence of such services, and will in no event supplant services provided with non-Federal funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination Among Programs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out the pilot program under subsection (a), the Chief of the National Guard Bureau shall consult with the Secretary of Health and Human Services for the purpose of ensuring that the provision of services under the pilot program are not redundant with the services of programs of such Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service of Participants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Service in the pilot program by a member of the National Guard shall be considered training in the member’s Federal status as a member of the National Guard of a State under section 270 [see 10147] of title 10, United States Code, and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s502"},"text":"section 502 of title 32","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"“(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall, not later than ","children":[{"tag":"date","attrib":{"date":"1995-01-01"},"text":"January 1, 1995","children":[],"tail":", submit to the Congress a report on the effectiveness of the pilot program and any recommendations with respect to the pilot program."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"“(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term ‘health care’ includes the following services:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Medical care services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Dental care services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation, by air ambulance or other means, for medical reasons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘Governor’, with respect to the District of Columbia, means the commanding general of the District of Columbia National Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘State’ includes the District of Columbia, the Commonwealth of Puerto Rico, Guam, and the Virgin Islands.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida1d22a6e-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"National Guard Civilian Youth Opportunities Pilot Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tV/s573"},"text":"Pub. L. 104–106, div. A, title V, § 573","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/355"},"text":"110 Stat. 355","children":[],"tail":", continued the authority to carry out the pilot program under "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/s1091"},"text":"section 1091 of Pub. L. 102–484","children":[],"tail":" for 18 months beyond "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", and limited the number of programs authorized to be carried out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1091"},"text":"Pub. L. 102–484, div. A, title X, § 1091","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2519"},"text":"106 Stat. 2519","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s104/e/1/A"},"text":"Pub. L. 103–82, title I, § 104(e)(1)(A)","children":[],"tail":", (C), "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/846"},"text":"107 Stat. 846","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tXI/s1174"},"text":"Pub. L. 103–160, div. A, title XI, § 1174","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1767"},"text":"107 Stat. 1767","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s391"},"text":"Pub. L. 103–382, title III, § 391","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4024"},"text":"108 Stat. 4024","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1073/d/2/B"},"text":"Pub. L. 105–85, div. A, title X, § 1073(d)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1905"},"text":"111 Stat. 1905","children":[],"tail":", authorized a pilot program known as the National Guard Civilian Youth Opportunities Program during fiscal years 1993 through 1995 to provide help to selected secondary school dropouts through military-based training. See "},{"tag":"ref","attrib":{"href":"/us/usc/t32/s509"},"text":"section 509 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
