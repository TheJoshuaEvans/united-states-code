,"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1955-08-11/ch802"},"text":"Aug. 11, 1955, ch. 802","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/69/686"},"text":"69 Stat. 686","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"109(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"32 App.:194(b) (4th sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"109(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"32 App.:194(b) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “heretofore authorized by this Act [sic]”, “as such”, and “in any manner” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “under any Federal law” are omitted since only Federal law could require service in the armed forces. The word “military” is omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “defense force” are substituted for the words “organized militia” for accuracy and to conform to subsection (c). The words “reserve component of the armed forces” are substituted for the words “Reserve Forces as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s901"},"text":"section 901 of Title 50","children":[],"tail":"”, since that term is not defined in the Armed Forces Reserve Act of 1952."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida1c642b6-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida1c642b7-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsecs. (a) to (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s1057/b/3"},"text":"Pub. L. 109–163, § 1057(b)(3)","children":[],"tail":". See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsecs. (a) to (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s1057/b/3"},"text":"Pub. L. 109–163, § 1057(b)(3)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":", substituted “State, the Commonwealth of Puerto Rico, the District of Columbia, Guam, or the Virgin Islands” for “State or Territory, Puerto Rico, the Virgin Islands, or the District of Columbia”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsecs. (a) to (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" struck out “the Canal Zone,” after “Virgin Islands,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s2/2/A"},"text":"Pub. L. 85–861, § 2(2)(A)","children":[],"tail":", substituted “defense forces authorized by subsection (c)” for “State defense forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s2/2/B"},"text":"Pub. L. 85–861, § 2(2)(B)","children":[],"tail":", added subsecs. (c) to (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida1c642b8-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida1c642b9-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/h"},"text":"Pub. L. 111–383, div. A, title X, § 1075(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4377"},"text":"124 Stat. 4377","children":[],"tail":", provided that the amendment made by section 1075(h)(4)(B) is effective as of "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" as enacted."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
