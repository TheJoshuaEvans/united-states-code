ll},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"314(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"314(b)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"314(c)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"314(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"32:11.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"32:12.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:998.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"32:13.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"32:14.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1903-01-21/ch196/s12"},"text":"Jan. 21, 1903, ch. 196, § 12","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/32/776"},"text":"32 Stat. 776","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1900-06-06/ch811"},"text":"June 6, 1900, ch. 811","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/31/671"},"text":"31 Stat. 671","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-06-03/ch134/s66"},"text":"June 3, 1916, ch. 134, § 66","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/39/199"},"text":"39 Stat. 199","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “appointed” is omitted, since the position is not filled by appointment in some cases. The ","children":[{"tag":"ref","attrib":{"href":"/us/act/1903-01-21/ch196/s12"},"text":"Act of January 21, 1903, ch. 196, § 12","children":[],"tail":" (last 48 words of 1st sentence) are not contained in 32:11. They are also omitted from the revised section as covered by subsection (d) of this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “grade” is substituted for the word “rank”. The words “To be eligible for appointment as * * * a person must be” are substituted for the words “each * * * shall be”. The words “of that jurisdiction” are substituted for the words “of the Territory for which he is appointed”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the word “Regular” is inserted as an implication of 10:998 (last 2 words). The words “commanding general” are substituted for the words “brigadier general commanding”, since the commanding general might hold another grade.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “basic pay” are substituted for the words “active service pay” to conform to section 201 of the Career Compensation Act of 1949, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/63/805"},"text":"63 Stat. 805","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t37/s232"},"text":"37 U.S.C. 232","children":[],"tail":"). The word “grade” is substituted for the word “rank”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “at such times and in such form” are omitted as covered by the words “such returns and reports as the Secretary * * * may prescribe”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida1cd6fb5-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida1cd6fb6-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsecs. (a), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" substituted “State, the Commonwealth of Puerto Rico, the District of Columbia, Guam, and the Virgin Islands” for “State and Territory, Puerto Rico, and the District of Columbia”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" struck out “each Territory and” before “the District of Columbia” in first sentence, and struck out at end “To be eligible for appointment as adjutant general of a Territory, a person must be a citizen of that jurisdiction.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" struck out at end “Each Secretary shall send with his annual report to Congress an abstract of the returns and reports of the adjutants general and such comments as he considers necessary for the information of Congress.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456/s1234/b/1"},"text":"Pub. L. 100–456, § 1234(b)(1)","children":[],"tail":", struck out “the Canal Zone,” after “Puerto Rico,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456/s1234/b/5"},"text":"Pub. L. 100–456, § 1234(b)(5)","children":[],"tail":", struck out “, the Canal Zone,” after “each Territory” and “or the Canal Zone” after “a Territory”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456/s1234/b/1"},"text":"Pub. L. 100–456, § 1234(b)(1)","children":[],"tail":", struck out “the Canal Zone,” after “Puerto Rico,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/894"},"text":"Pub. L. 85–894","children":[],"tail":" struck out “Puerto Rico” in two places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
