{"tag":"section","attrib":{"id":"ida1cd6fac-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s314"},"text":null,"children":[{"tag":"num","attrib":{"value":"314"},"text":"§ 314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjutants general","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida1cd6fad-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be an adjutant general in each State, the Commonwealth of Puerto Rico, the District of Columbia, Guam, and the Virgin Islands. He shall perform the duties prescribed by the laws of that jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1cd6fae-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall appoint the adjutant general of the District of Columbia and prescribe his grade and qualifications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1cd6faf-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s314/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may detail as adjutant general of the District of Columbia any retired commissioned officer of the Regular Army or the Regular Air Force recommended for that detail by the commanding general of the District of Columbia National Guard. An officer detailed under this subsection is entitled to the basic pay and allowances of his grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1cd6fb0-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s314/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The adjutant general of each State, the Commonwealth of Puerto Rico, the District of Columbia, Guam, and the Virgin Islands, and officers of the National Guard, shall make such returns and reports as the Secretary of the Army or the Secretary of the Air Force may prescribe, and shall make those returns and reports to the Secretary concerned or to any officer designated by him.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida1cd6fb1-2930-11f1-9ed5-c078b45cfa95"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/604"},"text":"70A Stat. 604","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/894"},"text":"Pub. L. 85–894","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1713"},"text":"72 Stat. 1713","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tXII/s1234/b/1"},"text":"Pub. L. 100–456, div. A, title XII, § 1234(b)(1)","children":[],"tail":", (5), "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2059"},"text":"102 Stat. 2059","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXIII/s1322/b"},"text":"Pub. L. 101–510, div. A, title XIII, § 1322(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1672"},"text":"104 Stat. 1672","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tV/s553"},"text":"Pub. L. 102–190, div. A, title V, § 553","children":[],"tail":", "},{"tag":"date","attrib":{"date":"