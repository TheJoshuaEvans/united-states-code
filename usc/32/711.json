{"tag":"section","attrib":{"id":"ida1db9fab-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s711"},"text":null,"children":[{"tag":"num","attrib":{"value":"711"},"text":"§ 711.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of obsolete or condemned property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each State, the Commonwealth of Puerto Rico, the District of Columbia, Guam, and the Virgin Islands shall, upon receiving new property issued to its National Guard to replace obsolete or condemned issues of property, return the replaced property to the Department of the Army or the Department of the Air Force, as the case may be, or otherwise dispose of it, as the Secretary concerned directs. No money credit may be allowed for property disposed of under this section.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida1db9fac-2930-11f1-9ed5-c078b45cfa95"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/616"},"text":"70A Stat. 616","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tXII/s1234/b/1"},"text":"Pub. L. 100–456, div. A, title XII, § 1234(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2059"},"text":"102 Stat. 2059","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tX/s1057/b/2"},"text":"Pub. L. 109–163, div. A, title X, § 1057(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3441"},"text":"119 Stat. 3441","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida1db9fad-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida1db9fae-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida1db9faf-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"711","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"32:46.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-06-03/ch134/s85"},"text":"June 3, 1916, ch. 134, § 85","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/39/204"},"text":"39 Stat. 204","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “to its National Guard” are inserted for clarity. The word “it” is substituted for the words “all property so replaced or condemned”. The last sentence is substituted for 32:46 (last 8 words).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida1db9fb0-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida1db9fb1-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" substituted “State, the Commonwealth of Puerto Rico, the District of Columbia, Guam, and the Virgin Islands” for “State and Territory, Puerto Rico, and the District of Columbia”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" struck out “the Canal Zone,” after “Puerto Rico,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
