{"tag":"section","attrib":{"id":"ida1cd6f9f-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s313"},"text":null,"children":[{"tag":"num","attrib":{"value":"313"},"text":"§ 313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointments and enlistments: age limitations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida1cd6fa0-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s313/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To be eligible for original enlistment in the National Guard, a person must be at least 17 years of age and under 45, or under 64 years of age and a former member of the Regular Army, Regular Navy, Regular Air Force, or Regular Marine Corps. To be eligible for reenlistment, a person must be under 64 years of age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1cd6fa1-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s313/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To be eligible for appointment as an officer of the National Guard, a person must—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida1cd6fa2-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s313/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a citizen of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1cd6fa3-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s313/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be at least 18 years of age and under 64.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida1cd6fa4-2930-11f1-9ed5-c078b45cfa95"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/604"},"text":"70A Stat. 604","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s2/9"},"text":"Pub. L. 85–861, § 2(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1544"},"text":"72 Stat. 1544","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/130/s2/2"},"text":"Pub. L. 90–130, § 2(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-11-08"},"text":"Nov. 8, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/383"},"text":"81 Stat. 383","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida1cd6fa5-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida1cd6fa6-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida1cd6fa7-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspa