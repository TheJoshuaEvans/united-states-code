:"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “does not comply” are substituted for the words “shall * * * have failed or refused to comply”. The words “a requirement of, or regulation prescribed under, this title” are substituted for the words “any requirement of this title, or any regulation promulgated thereunder and in aid thereof by the President or the Secretary of the Army”. The words “money or any other aid” are substituted for the words “pecuniary or other aid”. The words “or provided by this title or any other” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida1c642a6-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida1c642a7-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “If, within a time to be fixed by the President, a State does not comply with or enforce a requirement of, or regulation prescribed under, this title its National Guard is barred, wholly or partly as the President may prescribe, from receiving money or any other aid, benefit, or privilege authorized by law.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida1c642a8-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","at