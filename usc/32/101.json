{"tag":"section","attrib":{"id":"ida1bf1735-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s101"},"text":null,"children":[{"tag":"num","attrib":{"value":"101"},"text":"§ 101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In addition to the definitions in sections 1–5 of title 1, the following definitions apply in this title:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida1bf1736-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of other laws relating to the militia, the National Guard, the Army National Guard of the United States, and the Air National Guard of the United States, the term “Territory” includes Guam and the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1bf1737-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Armed forces” means the Army, Navy, Air Force, Marine Corps, and Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1bf1738-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s101/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “National Guard” means the Army National Guard and the Air National Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1bf1739-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s101/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “Army National Guard” means that part of the organized militia of the several States and Territories, Puerto Rico, and the District of Columbia, active and inactive, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida1bf173a-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s101/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a land force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida1bf173b-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s101/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is trained, and has its officers appointed, under the sixteenth clause of section 8, article I, of the Constitution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida1bf173c-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s101/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is organized, armed, and equipped wholly or partly at Federal expense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida1bf173d-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s101/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is federally recognized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1bf173e-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s101/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Army National Guard of the United States” means the reserve component of the Army all of whose members are members of the Army National Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1bf173f-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s101/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “Air National Guard” means that part of the organized militia of the several States and Territories, Puerto Rico, and the District of Columbia, active and inactive, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida1bf1740-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s101/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an air force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida1bf1741-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s101/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is trained, and has its officers appointed, under the sixteenth clause of section 8, article I of the Constitution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida1bf1742-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s101/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is organized, armed, and equipped wholly or partly at Federal expense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida1bf1743-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s101/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is federally recognized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1bf1744-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s101/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Air National Guard of the United States” means the reserve component of the Air Force all of whose members are members of the Air National Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1bf1745-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s101/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Officer” means commissioned or warrant officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1bf1746-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s101/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Enlisted member” means a person enlisted in, or inducted, called, or conscripted into, an armed force in an enlisted grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1bf1747-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s101/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Grade” means a step or degree, in a graduated scale of office or military rank, that is established and designated as a grade by law or regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1bf1748-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s101/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Rank” means the order of precedence among members of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1bf1749-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s101/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Active duty” means full-time duty in the active military service of the United States. It includes such Federal duty as full-time training duty, annual training duty, and attendance, while in the active military service, at a school designated as a service school by law or by the Secretary of the military department concerned. It does not include full-time National Guard duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1bf174a-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s101/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Supplies” includes material, equipment, and stores of all kinds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1bf174b-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s101/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Shall” is used in an imperative sense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1bf174c-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s101/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “May” is used in a permissive sense. The words “no person may * * *” mean that no person is required, authorized, or permitted to do the act prescribed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1bf174d-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s101/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Includes” means “includes but is not limited to”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1bf174e-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s101/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Pay” includes basic pay, special pay, incentive pay, retired pay, and equivalent pay, but does not include allowances.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1bf174f-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s101/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Spouse” means husband or wife, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1bf1750-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s101/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Full-time National Guard duty” means training or other duty, other than inactive duty, performed by a member of the Army National Guard of the United States or the Air National Guard of the United States in the member’s status as a member of the National Guard of a State or territory, the Commonwealth of Puerto Rico, or the District of Columbia under section 316, 502, 503, 504, or 505 of this title for which the member is entitled to pay from the United States or for which the member has waived pay from the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida1bf1751-2930-11f1-9ed5-c078b45cfa95"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/596"},"text":"70A Stat. 596","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s2/1"}