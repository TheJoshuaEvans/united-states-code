dren":[{"tag":"html:span","attrib":{},"text":"101(9)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"101(10)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"101(11)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"101(12)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"101(13)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"101(14)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"101(15)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"101(16)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1835 (less last 16 words).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"32:2.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"32:4b.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50:1112(b) (for definition purposes).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-06-03/ch134/s71"},"text":"June 3, 1916, ch. 134, § 71","children":[],"tail":"; added "},{"tag":"html:a","attrib":{"href":"/us/act/1933-06-15/ch87/s9"},"text":"June 15, 1933, ch. 87, § 9","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/48/157"},"text":"48 Stat. 157","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1949-10-12/ch681/s530"},"text":"Oct. 12, 1949, ch. 681, § 530","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/837"},"text":"63 Stat. 837","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1952-07-09/ch608/s803"},"text":"July 9, 1952, ch. 608, § 803","children":[],"tail":" (9th par.), "},{"tag":"html:a","attrib":{"href":"/us/stat/66/505"},"text":"66 Stat. 505","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1952-07-09/ch608/s702"},"text":"July 9, 1952, ch. 608, § 702","children":[],"tail":" (for definition purposes), "},{"tag":"html:a","attrib":{"href":"/us/stat/66/501"},"text":"66 Stat. 501","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1951-09-19/ch407/s305"},"text":"Sept. 19, 1951, ch. 407, § 305","children":[],"tail":" (less last 16 words), "},{"tag":"html:a","attrib":{"href":"/us/stat/65/330"},"text":"65 Stat. 330","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definitions in clauses (2) and (9)–(17) reflect the adoption of terminology which, though undefined in the source statutes restated in this title, represent the closest practicable approximation of the ways in which the terms defined have been most commonly used. Where established uses conflict, a choice has been made.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (1), the definition of “Territory” in 32:4c is executed throughout this revised title by specific reference, where applicable, to the Territories, Puerto Rico, and the Canal Zone.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (2), a definition of “National Guard” is inserted for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (3)(A), the words “a land force” are substituted for 32:2. The National Defense Act of 1916, § 117 (last 66 words), ","children":[{"tag":"ref","attrib":{"href":"/us/stat/39/212"},"text":"39 Stat. 212","children":[],"tail":", is not contained in 32:2. It is also omitted from the revised section as repealed by the "},{"tag":"ref","attrib":{"href":"/us/act/1925-02-28/ch374/s3"},"text":"act of February 28, 1925, ch. 374, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/1081"},"text":"43 Stat. 1081","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clauses (3) and (4), the word “Army” is inserted to distinguish the organizations defined from their Air Force counterparts.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clauses (3) and (5), the words “unless the context or subject matter otherwise requires—” and “as provided in this title”, in 32:4b, are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clauses (3)(B) and (5)(B), the words “has its officers appointed” are substituted for the word “officered”, in 32:4b.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clauses (4) and (6), only that much of the description of the composition of the Army National Guard of the United States and the Air National Guard of the United States is used as is necessary to distinguish these reserve components, respectively, from the other reserve components.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (5)(A), the words “an air force” are substituted for the words “for which Federal responsibility has been vested in the Secretary of the Air Force or the Department of the Air Force pursuant to law”, in 10:1835, and for 32:2 (less applicability to Army National Guard), to make the definition of “Air National Guard” parallel with the definition of “Army National Guard”, and to make explicit the intent of Congress in creating the Air National Guard, that the organized militia henceforth should consist of three mutually exhaustive classes comprising the Army, Air, and Naval militia.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (8), words showing how enlisted members became such are inserted to make clear that enlistment is not the only method of becoming a member in an enlisted grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida1c18855-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida1c18856-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1958 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section of title 32","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"101(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"101(18)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (2), the term “armed forces” is defined for legislative convenience and is defined the same as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/4"},"text":"section 101(4) of title 10","children":[],"tail":", United States Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definition in clause (18) reflects the adoption of terminology which, though undefined in the source statutes restated in this title, represents the closest practicable approximation of the ways in which the term has been commonly used.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida1c18857-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida1c18858-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Cl. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" amended cl. (1) generally. Prior to amendment, cl. (1) read as follows: “ ‘Territory’ means any Territory organized after this title is enacted, so long as it remains a Territory. However, for purposes of this title and other laws relating to the militia, the National Guard, the Army National Guard of the United States, and the Air National Guard of the United States, ‘Territory’ includes Guam and the Virgin Islands.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Cls. (4), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" struck out “the Canal Zone,” after “Puerto Rico,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Cl. (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/s414/b/1/A"},"text":"Pub. L. 98–525, § 414(b)(1)(A)","children":[],"tail":", inserted at end “It does not include full-time National Guard duty.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Cl. (19). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/s414/b/1/B"},"text":"Pub. L. 98–525, § 414(b)(1)(B)","children":[],"tail":", added cl. (19)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Cl. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/600"},"text":"Pub. L. 96–600","children":[],"tail":" inserted reference to Guam."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Cl. (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" struck out “duty on the active list,” after “Federal duty as”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Cl. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/492"},"text":"Pub. L. 92–492","children":[],"tail":" inserted provision including within term “Territory” for purposes of this title and other laws relating to the militia, the National Guard, the Army National Guard of the United States, and the Air National Guard of the United States, the Virgin Islands."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—Cl. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/624"},"text":"Pub. L. 86–624","children":[],"tail":" struck out reference to Hawaii."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1959—Cl. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/70"},"text":"Pub. L. 86–70","children":[],"tail":" struck out reference to Alaska."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Cls. (2) to (18). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861"},"text":"Pub. L. 85–861","children":[],"tail":" added cls. (2) and (18) and renumbered former cls. (2) to (16) as (3) to (17), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida1c18859-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida1c1885a-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701/a"},"text":"section 701(a) of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"ida1c1885b-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida1c1885c-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Official Designation of Salem, Massachusetts, as Birthplace of the National Guard of the United States","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/241/s1"},"text":"Pub. L. 112–241, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-10"},"text":"Jan. 10, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2372"},"text":"126 Stat. 2372","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/241/s1"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress makes the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In 1629, Captain John Endicott organized the first militia in the Massachusetts Bay Colony in Salem.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The colonists had adopted the English militia system, which required all males between the ages of 16 and 60 to possess arms and participate in the defense of the community.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In 1636, the Massachusetts General Court ordered the organization of three militia regiments, designated as the North, South, and East regiments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" These regiments drilled once a week and provided guard details each evening to sound the alarm in case of attack.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The East Regiment, the predecessor of the 101st Engineer Battalion, assembled as a regiment for the first time in 1637 on the Salem Common, marking the beginning of the Massachusetts National Guard and the National Guard of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Since 1785, Salem’s own Second Corps of Cadets (101st and 102nd Field Artillery) has celebrated the anniversary of that first muster.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As the policy contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s102"},"text":"section 102 of title 32","children":[],"tail":", United States Code, clearly expresses, the National Guard continues its historic mission of providing units for the first line defense of the United States and current missions throughout the world."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The designation of the City of Salem, Massachusetts, as the Birthplace of the National Guard of the United States will contribute positively to tourism and economic development in the city, create jobs, and instill pride in both the local and State communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of Salem, Massachusetts, as National Guard Birthplace","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In light of the findings made in subsection (a), the City of Salem, Massachusetts, is hereby designated as the Birthplace of the National Guard of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Military ceremonial support","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief of the National Guard Bureau, in conjunction with the Secretary of the Army, the Secretary of the Air Force, the Council of Governors, and the Adjutant General of the State of Massachusetts, shall provide military ceremonial support at the dedication of any monument, plaque, or other form of official recognition placed in Salem, Massachusetts, celebrating the designation of Salem, Massachusetts, as the Birthplace of the National Guard of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding source","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Federal funds may not be used to design, procure, prepare, install, or maintain any monument, plaque, or other form of official recognition placed in Salem, Massachusetts, celebrating the designation of Salem, Massachusetts, as the Birthplace of the National Guard of the United States, but the Adjutant General of the State of Massachusetts may accept and expend contributions of non-Federal funds for this purpose.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
