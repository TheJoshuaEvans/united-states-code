{"tag":"section","attrib":{"id":"ida1db9fc1-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s714"},"text":null,"children":[{"tag":"num","attrib":{"value":"714"},"text":"§ 714.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final settlement of accounts: deceased members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida1db9fc2-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s714/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the settlement of the accounts of a member of the National Guard who dies after ","children":[{"tag":"date","attrib":{"date":"1955-12-31"},"text":"December 31, 1955","children":[],"tail":", an amount due from the armed force of which he was a member shall be paid to the person highest on the following list living on the date of death:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida1db9fc3-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s714/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Beneficiary designated by him in writing to receive such an amount, if the designation is received, before the deceased member’s death, at the place named in regulations to be prescribed by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1db9fc4-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s714/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Surviving spouse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1db9fc5-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s714/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Children and their descendants, by representation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1db9fc6-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s714/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Father and mother in equal parts or, if either is dead, the survivor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1db9fc7-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s714/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Legal representative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1db9fc8-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s714/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Person entitled under the law of the domicile of the deceased member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1db9fc9-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s714/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Designations and changes of designation of beneficiaries under subsection (a)(1) are subject to regulations to be prescribed by the Secretary concerned. So far as practicable, these regulations shall be uniform with those prescribed for the armed forces under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2771/b"},"text":"section 2771(b) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1db9fca-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s714/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under such regulations as the Secretary concerned may prescribe, payments under subsection (a) shall be made by the Department of the Army or the Department of the Air Force, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1db9fcb-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s714/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A payment under this section bars recovery by any other person of the amount paid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida1db9fcc-2930-11f1-9ed5-c078b45cfa95"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s2/12"},"text":"Pub. L. 85–861, § 2(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1546"},"text":"72 Stat. 1546","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/87/46"},"text":"Pub. L. 87–46","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-06-16"},"text":"June 16, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/92"},"text":"75 Stat. 92","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/316/tII/s202/q"},"text":"Pub. L. 104–316, title II, § 202(q)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3844"},"text":"110 Stat. 3844","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida1db9fcd-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida1db9fce-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida1db9fcf-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"714(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"714(b)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"714(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:361.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"37:362.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"37:365.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"37:364 (less proviso).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"37:363 (less last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1955-07-12/ch328"},"text":"July 12, 1955, ch. 328","children":[],"tail":", §§ 1–3, 4 (less proviso), 5 (1st sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/69/295"},"text":"69 Stat. 295","children":[],"tail":", 296."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"714(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:363 (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the definition of the term “Department”, in 37:361, is omitted as unnecessary, since the particular departments referred to are spelled out in the revised text. The definition of the term “uniformed services”, in 37:361, is omitted as covered by the word “member” in this revised section. Clauses (1)–(6) are substituted for the last 5 clauses of 37:362. The words “regulations to be prescribed by the Secretary concerned” are substituted for the words “regulations of the Department concerned”, since the “Department”, as such, cannot issue regulations.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “Surviving spouse” are substituted for the words “widow or widower”. As defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s101/18"},"text":"section 101(18) of this title","children":[],"tail":", “spouse” includes a widower."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “are subject to” are substituted for the words “shall be made under”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the word “Under” is substituted for the words “Subject to”. The words “rules and” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida1db9fd0-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida1db9fd1-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316"},"text":"Pub. L. 104–316","children":[],"tail":", in first sentence, substituted “Secretary concerned” for “Comptroller General” and struck out at end “Payment under clause (6) of subsection (a) shall be made—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) upon settlement by the General Accounting Office; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) as otherwise authorized by the Comptroller General.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1961—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/46"},"text":"Pub. L. 87–46","children":[],"tail":" substituted “Payment under clause (6) of subsection (a) shall be made—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) upon settlement by the General Accounting Office; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) as otherwise authorized by the Comptroller General.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"for “Payments under clauses (2)–(6) of subsection (a) may be paid only after settlement by the General Accounting Office.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida1db9fd2-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida1db9fd3-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Designation of Beneficiary Made Before January 1, 1956","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Designation of beneficiary made before ","children":[{"tag":"date","attrib":{"date":"1956-01-01"},"text":"Jan. 1, 1956","children":[],"tail":", considered as the designation of a beneficiary for the purposes of this section, see note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2771"},"text":"section 2771 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
