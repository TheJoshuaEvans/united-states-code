{"tag":"section","attrib":{"id":"ida1d49abd-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s508"},"text":null,"children":[{"tag":"num","attrib":{"value":"508"},"text":"§ 508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for certain youth and charitable organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida1d49abe-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Provide Services","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Members and units of the National Guard may provide the services described in subsection (b) to an eligible organization in conjunction with training required under this chapter in any case in which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida1d49abf-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s508/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of such services does not adversely affect the quality of that training or otherwise interfere with the ability of a member or unit of the National Guard to perform the military functions of the member or unit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1d49ac0-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s508/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the services to be provided are not commercially available, or any commercial entity that would otherwise provide such services has approved, in writing, the provision of such services by the National Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1d49ac1-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s508/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National Guard personnel will enhance their military skills as a result of providing such services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1d49ac2-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s508/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of the services will not result in a significant increase in the cost of the training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1d49ac3-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Services","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The services authorized to be provided under subsection (a) are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida1d49ac4-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s508/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ground transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1d49ac5-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s508/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Air transportation in support of Special Olympics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1d49ac6-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s508/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Administrative support services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1d49ac7-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s508/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Technical training services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1d49ac8-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s508/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Emergency medical assistance and services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1d49ac9-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s508/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Communications services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1d49aca-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s508/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Authorized Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Facilities and equipment of the National Guard, including military property of the United States issued to the National Guard and General Services Administration vehicles leased to the National Guard, and General Services Administration vehicles leased to the Department of Defense, may be used in connection with providing services to any eligible organization under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1d49acb-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s508/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Organizations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The organizations eligible to receive services under this section are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida1d49acc-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s508/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Boy Scouts of America.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1d49acd-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s508/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Girl Scouts of America.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1d49ace-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s508/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Boys Clubs of America.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1d49acf-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s508/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Girls Clubs of America.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1d49ad0-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s508/d/5"},"text"