{"tag":"section","attrib":{"id":"ida1cfb8c6-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s322"},"text":null,"children":[{"tag":"num","attrib":{"value":"322"},"text":"§ 322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discharge of enlisted members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida1cfb8c7-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s322/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An enlisted member of the National Guard shall be discharged when—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida1cfb8c8-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s322/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" he becomes 64 years of age; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1cfb8c9-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s322/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" his Federal recognition is withdrawn.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1cfb8ca-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s322/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An enlisted member who is discharged from the National Guard is entitled to a discharge certificate similar in form and classification to the corresponding certificate prescribed for members of the Regular Army or the Regular Air Force, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1cfb8cb-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s322/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In time of peace, an enlisted member of the National Guard may be discharged before his enlistment expires, under such regulations as may be prescribed by the Secretary of the Army or the Secretary of the Air Force, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida1cfb8cc-2930-11f1-9ed5-c078b45cfa95"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/606"},"text":"70A Stat. 606","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida1cfb8cd-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida1cfb8ce-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida1cfb8cf-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"322(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"322(b)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"322(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"32:154 (last par., less 1st 26, and last 26, words).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"32:125 (less last 27 words).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"32:125 (last 27 words).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-06-03/ch134/s72"},"text":"June 3, 1916, ch. 134, § 72","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/act/1920-06-04/ch227"},"text":"June 4, 1920, ch. 227","children":[],"tail":", subch. I, § 40; restated "},{"tag":"html:a","attrib":{"href":"/us/act/1933-06-15/ch87/s10"},"text":"June 15, 1933, ch. 87, § 10","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/48/157"},"text":"48 Stat. 157","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1952-07-09/ch608/s806/d"},"text":"July 9, 1952, ch. 608, § 806(d)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/66/507"},"text":"66 Stat. 507","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-06-03/ch134/s110"},"text":"June 3, 1916, ch. 134, § 110","children":[],"tail":" (last par., less 1st 30, and last 25, words); restated "},{"tag":"html:a","attrib":{"href":"/us/act/1922-09-22/ch423/s6"},"text":"Sept. 22, 1922, ch. 423, § 6","children":[],"tail":" (last par., less 1st 30, and last 137, words); restated "},{"tag":"html:a","attrib":{"href":"/us/act/1928-05-12/ch529"},"text":"May 12, 1928, ch. 529","children":[],"tail":" (less 1st 30, and last 25, words), "},{"tag":"html:a","attrib":{"href":"/us/stat/45/500"},"text":"45 Stat. 500","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a) is substituted for 32:154 (last par., less 1st 26, and last 26, words) to reflect an opinion of the Judge Advocate General of the Army (JAGA 1953/9033, 3 Dec. 1953).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “is entitled to a discharge certificate similar in form and classification to the corresponding certificate” are substituted for the words “shall receive a discharge in writing in such form and with such classification as is or shall be”. The words “service in” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “his enlistment expires” are substituted for the words “the expiration of terms of enlistment”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
