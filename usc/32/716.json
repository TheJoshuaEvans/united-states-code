{"tag":"section","attrib":{"id":"ida1db9fed-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s716"},"text":null,"children":[{"tag":"num","attrib":{"value":"716"},"text":"§ 716.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claims for overpayment of pay and allowances, and travel and transportation allowances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida1db9fee-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s716/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A claim of the United States against a person arising out of an erroneous payment of any pay or allowances made before, on, or after ","children":[{"tag":"date","attrib":{"date":"1972-10-02"},"text":"October 2, 1972","children":[],"tail":", or arising out of an erroneous payment of travel and transportation allowances, to or on behalf of a member or former member of the National Guard, the collection of which would be against equity and good conscience and not in the best interest of the United States, may be waived in whole or in part by—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida1db9fef-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s716/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Office of Management and Budget; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1db9ff0-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s716/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary concerned, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s101/5"},"text":"section 101(5) of title 37","children":[],"tail":", when—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida1db9ff1-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s716/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the claim is in an amount aggregating not more than $10,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida1db9ff2-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s716/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the waiver is made in accordance with standards which the Director of the Office of Management and Budget shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1db9ff3-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s716/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director of the Office of Management and Budget or the Secretary concerned, as the case may be, may not exercise his authority under this section to waive any claim—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida1db9ff4-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s716/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if, in his opinion, there exists, in connection with the claim, an indication of fraud, misrepresentation, fault, or lack of good faith on the part of the member or any other person having an interest in obtaining a waiver of the claim; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1db9ff5-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s716/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if application for waiver is received in his office after the expiration of five years immediately following the date on which the erroneous payment was discovered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1db9ff6-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s716/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who has repaid to the United States all or part of the amount of a claim, with respect to which a waiver is granted under this section, is entitled, to the extent of the waiver, to refund, by the department concerned at the time of the erroneous payment, of the amount repaid to the United States, if he applies to that department for that refund within two years following the effective date of the waiver. The Secretary concerned shall pay from current applicable appropriations that refund in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1db9ff7-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s716/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the audit and settlement of accounts of any accountable officer or official, full credit shall be given for any amounts with respect to which collection by the United States is waived under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1db9ff8-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s716/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An erroneous payment, the collection of which is waived under this section, is considered a valid payment for all purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1db9ff9-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s716/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not affect any authority under any other law to litigate, settle, compromise, or waive any claim of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida1db9ffa-2930-11f1-9ed5-c078b45cfa95"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/453/s2/1"},"text":"Pub. L. 92–453, § 2(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-02"},"text":"Oct. 2, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/759"},"text":"86 Stat. 759","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s515/9"},"text":"Pub. L. 96–513, title V, § 515(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2937"},"text":"94 Stat. 2937","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/224/s3/a"},"text":"Pub. L. 99–224, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-28"},"text":"Dec. 28, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1742"},"text":"99 Stat. 1742","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tVI/s657/c"},"text":"Pub. L. 102–190, div. A, title VI, § 657(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1393"},"text":"105 Stat. 1393","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/316/tI/s116"},"text":"Pub. L. 104–316, title I, § 116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3835"},"text":"110 Stat. 3835","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tVI/s671/b"},"text":"Pub. L. 109–364, div. A, title VI, § 671(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2270"},"text":"120 Stat. 2270","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida1db9ffb-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida1db9ffc-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida1db9ffd-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s671/b/1"},"text":"Pub. L. 109–364, § 671(b)(1)","children":[],"tail":", substituted “$10,000” for “$1,500”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s671/b/2"},"text":"Pub. L. 109–364, § 671(b)(2)","children":[],"tail":", substituted “five” for “three”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316/s116/1/A"},"text":"Pub. L. 104–316, § 116(1)(A)","children":[],"tail":", substituted “Director of the Office of Management and Budget” for “Comptroller General”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316/s116/1/B"},"text":"Pub. L. 104–316, § 116(1)(B)","children":[],"tail":", inserted “and” at end of subpar. (A), redesignated subpar. (C) as (B) and substituted “Director of the Office of Management and Budget” for “Comptroller General”, and struck out former subpar. (B) which read as follows: “the claim is not the subject of an exception made by the Comptroller General in the account of any accountable officer or official; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316/s116/2"},"text":"Pub. L. 104–316, § 116(2)","children":[],"tail":", substituted “The Director of the Office of Management and Budget” for “Comptroller General” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" substituted “$1,500” for “$500”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/224/s3/a/1"},"text":"Pub. L. 99–224, § 3(a)(1)","children":[],"tail":", substituted “and travel” for “other than travel” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/224/s3/a/2"},"text":"Pub. L. 99–224, § 3(a)(2)","children":[],"tail":", substituted “made before, on, or after "},{"tag":"date","attrib":{"date":"1972-10-02"},"text":"October 2, 1972","children":[],"tail":", or arising out of an erroneous payment of travel and transportation allowances” for “, other than travel and transportation allowances, made before or after "},{"tag":"date","attrib":{"date":"1972-10-02"},"text":"October 2, 1972","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/224/s3/a/3"},"text":"Pub. L. 99–224, § 3(a)(3)","children":[],"tail":", struck out “of pay or allowances, other than travel and transportation allowances,” before “was discovered”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1972-10-02"},"text":"October 2, 1972","children":[],"tail":"” for “the effective date of this section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida1db9ffe-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida1db9fff-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2007-03-01"},"text":"Mar. 1, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/s671/c"},"text":"section 671(c) of Pub. L. 109–364","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2774"},"text":"section 2774 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida1dba000-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316"},"text":"Pub. L. 104–316","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/316/s101/e"},"text":"section 101(e) of Pub. L. 104–316","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4593"},"text":"section 4593 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida1dba001-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/224"},"text":"Pub. L. 99–224","children":[],"tail":" applicable to any claim arising out of an erroneous payment of travel and transportation allowances made on or after "},{"tag":"date","attrib":{"date":"1985-12-28"},"text":"Dec. 28, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/224/s4"},"text":"section 4 of Pub. L. 99–224","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5584"},"text":"section 5584 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida1dba002-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701/b/3"},"text":"section 701(b)(3) of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"