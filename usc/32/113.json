{"tag":"section","attrib":{"id":"ida1c8b401-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s113"},"text":null,"children":[{"tag":"num","attrib":{"value":"113"},"text":"§ 113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal financial assistance for support of additional duties assigned to the Army National Guard","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida1c8b402-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army may provide financial assistance to a State to support activities carried out by the Army National Guard of the State in the performance of duties that the Secretary has assigned, with the consent of the Chief of the National Guard Bureau, to the Army National Guard of the State. The Secretary shall determine the amount of the assistance that is appropriate for the purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1c8b403-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Activities","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida1c8b404-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s113/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (2), financial assistance may be provided for the performance of an activity by the Army National Guard under subsection (a) only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida1c8b405-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s113/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activity is carried out in the performance of a responsibility of the Secretary of the Army under paragraph (6), (10), or (11) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7013/b"},"text":"section 7013(b) of title 10","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida1c8b406-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s113/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Army National Guard was selected to perform the activity under competitive procedures that permit all qualified public-sector and private-sector sources to submit offers and be considered for selection to perform the activity on the basis of the offers, subject to the exceptions provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3204/a"},"text":"section 3204(a) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1c8b407-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s113/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1)(B) does not apply to an activity that, on ","children":[{"tag":"date","attrib":{"date":"1998-10-17"},"text":"October 17, 1998","children":[],"tail":", was performed for the Federal Government by employees of the Federal Government or employees of a State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1c8b408-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s113/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disbursement Through National Guard Bureau","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army shall disburse any contribution under this section through the Chief of the National Guard Bureau.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1c8b409-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s113/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds appropriated for the Army for a fiscal year are available for providing financial assistance under this section in support of activities carried out by the Army National Guard during that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida1c8b40a-2930-11f1-9ed5-c078b45cfa95"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tIII/s386/a"},"text":"Pub. L. 105–85, div. A, title III, § 386(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1712"},"text":"111 Stat. 1712","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tIII/s375/a"},"text":"Pub. L. 105–261, div. A, title III, § 375(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1992"},"text":"112 Stat. 1992","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1066/d/4"},"text":"Pub. L. 106–65, div. A, title X, § 1066(d)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/773"},"text":"113 Stat. 773","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tVIII/s806"},"text":"Pub. L. 108–375, div. A, title VIII, § 806","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2010"},"text":"118 Stat. 2010","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s809/j"},"text":"Pub. L. 115–232, div. A, title VIII, § 809(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1843"},"text":"132 Stat. 1843","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1702/f/1"},"text":"Pub. L. 117–81, div. A, title XVII, § 1702(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2157"},"text":"135 Stat. 2157","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida1c8b40b-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida1c8b40c-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida1c8b40d-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 