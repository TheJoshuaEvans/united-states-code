{"tag":"section","attrib":{"id":"ida1c8b416-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s115"},"text":null,"children":[{"tag":"num","attrib":{"value":"115"},"text":"§ 115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funeral honors duty performed as a Federal function","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida1c8b417-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s115/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Order to Duty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of the Army National Guard of the United States or the Air National Guard of the United States may be ordered to funeral honors duty, with the consent of the member, to prepare for or perform funeral honors functions at the funeral of a veteran under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1491"},"text":"section 1491 of title 10","children":[],"tail":". However, a member of the Army National Guard of the United States or the Air National Guard of the United States may not be ordered to perform funeral honors functions under this section without the consent of the Governor or other appropriate authority of the State concerned. Performance of funeral honors duty by such a member not on active duty or full-time National Guard duty shall be treated as inactive-duty training (including with respect to travel to and from such duty) for purposes of any provision of law other than sections 206 and 435 of title 37."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1c8b418-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s115/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service Credit","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member ordered to funeral honors duty under this section shall be required to perform a minimum of two hours of such duty in order to receive—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida1c8b419-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s115/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" service credit under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12732/a/2/E"},"text":"section 12732(a)(2)(E) of title 10","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1c8b41a-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s115/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as directed by the Secretary concerned, either—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida1c8b41b-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s115/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the allowance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s435"},"text":"section 435 of title 37","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida1c8b41c-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s115/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compensation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s206"},"text":"section 206 of title 37","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1c8b41d-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s115/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursable Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member who performs funeral honors duty under this section may be reimbursed for travel and transportation expenses incurred in conjunction with such duty as authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s452"},"text":"section 452 of title 37","children":[],"tail":" if such duty is performed at a location 50 miles or more from the member’s residence."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1c8b41e-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s115/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The exercise of authority under subsection (a) is subject to regulations prescribed by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida1cafe0f-2930-11f1-9ed5-c078b45cfa95"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s578/g/2"},"text":"Pub. L. 106–65, div. A, title V, § 578(g)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/627"},"text":"113 Stat. 627","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 575(a)(1)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/u