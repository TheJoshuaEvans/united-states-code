{"tag":"section","attrib":{"id":"ida1cfb8e5-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s324"},"text":null,"children":[{"tag":"num","attrib":{"value":"324"},"text":"§ 324.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discharge of officers; termination of appointment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida1cfb8e6-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s324/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An officer of the National Guard shall be discharged when—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida1cfb8e7-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s324/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" he becomes 64 years of age; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1cfb8e8-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s324/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" his Federal recognition is withdrawn.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The official who would be authorized to appoint him shall give him a discharge certificate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1cfb8e9-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s324/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subsection (a), the appointment of an officer of the National Guard may be terminated or vacated as provided by the laws of the State of whose National Guard he is a member, or by the laws of the Commonwealth of Puerto Rico, or the District of Columbia, Guam, or the Virgin Islands, of whose National Guard he is a member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1cfb8ea-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s324/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding subsection (a)(1), an officer of the National Guard serving as a chaplain, medical officer, dental officer, nurse, veterinarian, Medical Service Corps officer, or biomedical sciences officer may be retained, with the officer’s consent, until the date on which the officer becomes 68 years of age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida1cfb8eb-2930-11f1-9ed5-c078b45cfa95"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/607"},"text":"70A Stat. 607","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tXII/s1234/b/6"},"text":"Pub. L. 100–456, div. A, title XII, § 1234(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2059"},"text":"102 Stat. 2059","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tX/s1057/b/5"},"text":"Pub. L. 109–163, div. A, title X, § 1057(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3441"},"text":"119 Stat. 3441","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title V, § 516(b), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4442"},"text":"122 Stat. 4442","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/h/4/C"},"text":"Pub. L. 111–383, div. A, title X, § 1075(h)(4)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4377"},"text":"124 Stat. 4377","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida1cfb8ec-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida1cfb8ed-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida1cfb8ee-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"324(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"324(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"32:114 (less 1st sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"32:114 (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-06-03/ch134/s77"},"text":"June 3, 1916, ch. 134, § 77","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/act/1933-06-15/ch87/s14"},"text":"June 15, 1933, ch. 87, § 14","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/act/1935-06-19/ch277/s4"},"text":"June 19, 1935, ch. 277, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/49/391"},"text":"49 Stat. 391","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1952-07-09/ch608/s803"},"text":"July 9, 1952, ch. 608, § 803","children":[],"tail":" (11th par.), "},{"tag":"html:a","attrib":{"href":"/us/stat/66/505"},"text":"66 Stat. 505","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “shall be discharged” are substituted for the words “shall thereupon cease to be a member thereof” since an official is required to give the officer a discharge certificate. The words “becomes 64 years of age” are substituted for the words “upon reaching the age of sixty-four years”. The words “his Federal recognition is withdrawn” are substituted for the words “When Federal recognition is withdrawn * * * as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s115"},"text":"section 115 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “Subject to subsection (a)” are inserted for clarity. The words “as provided by the laws” are substituted for the words “in such manner as * * * shall provide by law”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida1cfb8ef-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida1cfb8f0-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s1057/b/5"},"text":"Pub. L. 109–163, § 1057(b)(5)","children":[],"tail":". See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s1057/b/5"},"text":"Pub. L. 109–163, § 1057(b)(5)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":", substituted “State of whose National Guard he is a member, or by the laws of the Commonwealth of Puerto Rico, or the District of Columbia, Guam, or the Virgin Islands, of whose National Guard he is a member” for “State or Territory of whose National Guard he is a member, or by the laws of Puerto Rico or the District of Columbia, if he is a member of its National Guard”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" struck out “, the Canal Zone,” after “Puerto Rico”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida1cfb8f1-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida1cfb8f2-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/h"},"text":"Pub. L. 111–383, div. A, title X, § 1075(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4377"},"text":"124 Stat. 4377","children":[],"tail":", provided that the amendment made by section 1075(h)(4)(C) is effective as of "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" as enacted."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
