{"tag":"section","attrib":{"id":"ida1cfb91e-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s328"},"text":null,"children":[{"tag":"num","attrib":{"value":"328"},"text":"§ 328.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Active Guard and Reserve duty: Governor’s authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida1cfb91f-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s328/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Governor of a State or the Commonwealth of Puerto Rico, Guam, or the Virgin Islands, or the commanding general of the District of Columbia National Guard, as the case may be, with the consent of the Secretary concerned, may order a member of the National Guard to perform Active Guard and Reserve duty, as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/d/6"},"text":"section 101(d)(6) of title 10","children":[],"tail":", pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t32/s502/f"},"text":"section 502(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1cfb920-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s328/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of the National Guard performing duty under subsection (a) may perform the additional duties specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s502/f/2"},"text":"section 502(f)(2) of this title","children":[],"tail":" to the extent that the performance of those duties does not interfere with the performance of the member’s primary Active Guard and Reserve duties of organizing, administering, recruiting, instructing, and training the reserve components."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1d22a21-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s328/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver Authority","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida1d22a22-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s328/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/d/6/A"},"text":"section 101(d)(6)(A) of title 10","children":[],"tail":" and subsection (b) of this section, the Governor of a State or the Commonwealth of Puerto Rico, Guam, or the Virgin Islands, or the commanding general of the District of Columbia National Guard, as the case may be, may, at the request of the Secretary concerned, order a member of the National Guard to perform Active Guard and Reserve duty for purposes of performing training of the regular components of the armed forces as the primary duty."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1d22a23-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s328/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Training performed under paragraph (1) must be in compliance with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s502/f/2/B/i"},"text":"section 502(f)(2)(B)(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1d22a24-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s328/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No more than 100 personnel may be granted a waiver by a Secretary concerned under paragraph (1) at a time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1d22a25-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s328/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority under paragraph (1) shall terminate on ","children":[{"tag":"date","attrib":{"date":"2024-10-01"},"text":"October 1, 2024","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida1d22a26-2930-11f1-9ed5-c078b45cfa95"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s526/a"},"text":"Pub. L. 109–364, div. A, title V, § 526(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2196"},"text":"120 Stat. 2196","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tV/s515/a"},"text":"Pub. L. 117–263, div. A, title V, § 515(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2566"},"text":"136 Stat. 2566","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida1d22a27-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida1d22a28-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida1d22a29-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 328, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/608"},"text":"70A Stat. 608","children":[],"tail":", related to special courts-martial of the National Guard not in Federal service, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tV/s512/c"},"text":"Pub. L. 107–314, div. A, title V, § 512(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2537"},"text":"116 Stat. 2537","children":[],"tail":", applicable with respect to courts-martial convened after "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida1d22a2a-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
