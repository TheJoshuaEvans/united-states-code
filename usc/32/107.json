dren":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tXII/s1205"},"text":"Pub. L. 113–66, div. A, title XII, § 1205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/897"},"text":"127 Stat. 897","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tXII/s1203/a"},"text":"Pub. L. 114–92, div. A, title XII, § 1203(a)","children":[],"tail":"–(e), (g)–(i), "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1037-1039"},"text":"129 Stat. 1037–1039","children":[],"tail":", related to the Department of Defense State Partnership Program, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1246/e"},"text":"Pub. L. 114–328, div. A, title XII, § 1246(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2521"},"text":"130 Stat. 2521","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s341"},"text":"section 341 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida1c3d29f-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Limitation on Activities Under State Partnership Program Pending Compliance With Certain Program-Related Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tXII/s1204"},"text":"Pub. L. 112–239, div. A, title XII, § 1204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1982"},"text":"126 Stat. 1982","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/239/dA/tXII/s1204"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If both requirements specified in subsection (b) are not met as of ","children":[{"tag":"date","attrib":{"date":"2013-02-28"},"text":"February 28, 2013","children":[],"tail":", no activities may be carried out under the State Partnership Program after that date until both requirements are met."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements specified in this subsection are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The requirement for the Secretary of Defense to submit to the appropriate congressional committees the final regulations required by subsection (a) of [former] section 1210 of the National Defense Authorization Act for Fiscal Year 2010 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Public Law 111–84","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/123/2517"},"text":"123 Stat. 2517","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t32/s107"},"text":"32 U.S.C. 107","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A requirement for the Secretary of Defense to certify to the appropriate congressional committees that appropriate modifications have been made, and appropriate controls have been instituted, to ensure the compliance of the Program with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1341"},"text":"section 1341 of title 31","children":[],"tail":", United States Code (commonly referred to as the ‘Anti-Deficiency Act’), in the future."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate Congressional Committees Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘appropriate congressional committees’ has the meaning given that term in subsection (d) of [former] section 1210 of the National Defense Authorization Act for Fiscal Year 2010.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida1c3d2a0-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Availability of Appropriated Funds for the State Partnership Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tXII/s1210"},"text":"Pub. L. 111–84, div. A, title XII, § 1210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2517"},"text":"123 Stat. 2517","children":[],"tail":", which required the Secretary of Defense to prescribe regulations regarding appropriated funds for the State Partnership Program, submit the regulations to defense and foreign relations committees, and report to the committees, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tXII/s1205/h"},"text":"Pub. L. 113–66, div. A, title XII, § 1205(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/899"},"text":"127 Stat. 899","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
