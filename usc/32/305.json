{"tag":"section","attrib":{"id":"ida1cafe50-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s305"},"text":null,"children":[{"tag":"num","attrib":{"value":"305"},"text":"§ 305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal recognition of commissioned officers: persons eligible","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida1cafe51-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following categories are eligible for Federal recognition as commissioned officers of the National Guard:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida1cafe52-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s305/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the National Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1cafe53-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s305/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1cafe54-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s305/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Former officers of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1cafe55-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s305/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Former enlisted members of the armed forces who were discharged honorably or under honorable conditions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1cafe56-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s305/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Graduates of the United States Military Academy, the United States Naval Academy, the United States Air Force Academy, the United States Coast Guard Academy, or the United States Merchant Marine Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1cafe57-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s305/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Graduates of a school, college, university, or officer’s training camp who received military instruction under the supervision of a commissioned officer of the Regular Army or the Regular Air Force, and whose fitness for appointment has been certified by that officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1cafe58-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s305/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Civilians who are specially qualified for duty in a technical or staff branch or organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1cafe59-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To be eligible for Federal recognition under this section with a view to serving as a nurse, a person must be a graduate of a hospital or university training school and a registered nurse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida1cafe5a-2930-11f1-9ed5-c078b45cfa95"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/602"},"text":"70A Stat. 602","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s2/5"},"text":"Pub. L. 85–861, § 2(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1543"},"text":"72 Stat. 1543","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/130/s2/1"},"text":"Pub. L. 90–130, § 2(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-11-08"},"text":"Nov. 8, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/383"},"text":"81 Stat. 383","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s505"},"text":"Pub. L. 108–375, div. A, title V, § 505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1875"},"text":"118 Stat. 1875","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tV/s517"},"text":"Pub. L. 111–383, div. A, title V, § 517","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4214"},"text":"124 Stat. 4214","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida1cafe5b-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida1cafe5c-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida1cafe5d-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1956 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"305","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"32:111 (less 37th through 54th words).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-06-03/ch134/s74"},"text":"June 3, 1916, ch. 134, § 74","children":[],"tail":" (less 39th through 56th words); restated "},{"tag":"html:a","attrib":{"href":"/us/act/1920-06-04/ch227"},"text":"June 4, 1920, ch. 227","children":[],"tail":", subch. I, § 41 (less 39th through 56th words), "},{"tag":"html:a","attrib":{"href":"/us/stat/41/781"},"text":"41 Stat. 781","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “individual” is inserted for clarity to distinguish the individual Federal recognition that is necessary to membership as an officer from the general Federal recognition that is necessary to all membership in the National Guard (see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s301"},"text":"section 301 of this title","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “","children":[{"tag":"date","attrib":{"date":"1920-06-04"},"text":"June 4, 1920","children":[],"tail":"” are omitted as obsolete. The words “Only persons selected from the following categories are eligible for individual Federal recognition as commissioned officers” are substituted for the words “Persons commissioned * * * shall not be recognized as such under any of the provisions of this title unless they shall have been selected from the following classes”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (2), the words “reserve officers” are omitted as covered by the words “members of the Army, Navy, Air Force, or Marine Corps”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (4), the words “under honorable conditions” are inserted for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (5), the words “the United States Air Force Academy” are inserted to reflect the establishment of that institution by the Air Force Academy Act (","children":[{"tag":"ref","attrib":{"href":"/us/stat/68/47"},"text":"68 Stat. 47","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (7), the words “staff branch” are substituted for the words “Staff Corps and departments”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida1cafe5e-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida1cafe5f-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1958 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section of title 32","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"305(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"32 App.:4 (less applicability to age).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1956-07-30/ch789"},"text":"July 30, 1956, ch. 789","children":[],"tail":", §§ 2 (less applicability to age), 3, "},{"tag":"html:a","attrib":{"href":"/us/stat/70/729"},"text":"70 Stat. 729","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “who are citizens of the United States” are omitted as covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s313/b"},"text":"section 313(b) of this title","children":[],"tail":". The words “with a view to serving” are substituted for the words “to serve”. The words “and have the physical and other qualifications prescribed by the Secretary of the Army” and section 3 of the source statute are omitted as covered by "},{"tag":"ref","attrib":{"href":"/us/usc/t32/s307/a/2"},"text":"section 307(a)(2) of this title","children":[],"tail":". The applicability of section 3 of the source statute to section 1 of the source statute is omitted as unnecessary."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida1cafe60-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida1cafe61-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" substituted “the United States Coast Guard Academy, or the United States Merchant Marine Academy” for “or the United States Coast Guard Academy”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s505/1"},"text":"Pub. L. 108–375, § 505(1)","children":[],"tail":", substituted “armed forces” for “Army, Navy, Air Force, or Marine Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s505/2"},"text":"Pub. L. 108–375, § 505(2)","children":[],"tail":", substituted “the United States Air Force Academy, or the United States Coast Guard Academy” for “or the United States Air Force Academy”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/130/s2/1/A"},"text":"Pub. L. 90–130, § 2(1)(A)","children":[],"tail":", struck out provision that, except as provided in subsec. (b), only male persons from the enumerated categories were eligible for Federal recognition as commissioned officers of the National Guard."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/130/s2/1/B"},"text":"Pub. L. 90–130, § 2(1)(B)","children":[],"tail":", (C), struck out provision that women are eligible for Federal recognition as commissioned officers of the National Guard, with a view to serving as nurses or medical specialist, and substituted “person” for “woman” in description of the individual who must be a graduate of a hospital or university training school and a registered nurse in order to be eligible for Federal recognition under this section with a view to serving as a nurse."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s2/5/A"},"text":"Pub. L. 85–861, § 2(5)(A)","children":[],"tail":", designated existing provisions as subsec. (a) and substituted “Except as provided in subsection (b), only male persons” for “Only persons”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s2/5/B"},"text":"Pub. L. 85–861, § 2(5)(B)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
