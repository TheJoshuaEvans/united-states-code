{"tag":"section","attrib":{"id":"idce3104ab-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1722"},"text":null,"children":[{"tag":"num","attrib":{"value":"1722"},"text":"§ 1722.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce3104ac-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1722/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a broadband connection and digital literacy are increasingly critical to how individuals—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce3104ad-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1722/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in the society, economy, and civic institutions of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce3104ae-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1722/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access health care and essential services, obtain education, and build careers;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce3104af-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1722/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" digital exclusion—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce3104b0-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1722/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carries a high societal and economic cost;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce3104b1-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1722/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" materially harms the opportunity of an individual with respect to the economic success, educational achievement, positive health outcomes, social inclusion, and civic engagement of that individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce3104b2-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1722/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exacerbates existing wealth and income gaps, especially those experienced by covered populations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce3104b3-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1722/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieving digital equity for all people of the United States requires additional and sustained investment and research efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce3104b4-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1722/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Government, as well as State, tribal, territorial, and local governments, have made social, legal, and economic obligations that necessarily extend to how the citizens and residents of those governments access and use the internet; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce3104b5-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1722/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieving digital equity is a matter of social and economic justice and is worth pursuing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idce3104b6-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dF/tIII/s60303"},"text":"Pub. L. 117–58, div. F, title III, § 60303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1212"},"text":"135 Stat. 1212","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
