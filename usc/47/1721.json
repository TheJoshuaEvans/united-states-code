{"tag":"section","attrib":{"id":"idce31046b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721"},"text":null,"children":[{"tag":"num","attrib":{"value":"1721"},"text":"§ 1721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce31046c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adoption of broadband","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “adoption of broadband” means the process by which an individual obtains daily access to the internet—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce31046d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at a speed, quality, and capacity—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idce31046e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is necessary for the individual to accomplish common tasks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce31046f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such that the access qualifies as an advanced telecommunications capability;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce310470-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the digital skills that are necessary for the individual to participate online; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce310471-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" on a—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idce310472-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personal device; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce310473-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" secure and convenient network.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce310474-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced telecommunications capability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “advanced telecommunications capability” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1302/d"},"text":"section 1302(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce310475-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aging individual","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “aging individual” has the meaning given the term “older individual” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3002"},"text":"section 3002 of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce310476-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate committees of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce310477-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce310478-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce, Science, and Transportation of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce310479-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce31047a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Commerce of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce31047b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Assistant Secretary” means the Assistant Secretary of Commerce for Communications and Information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce31047c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community anchor institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “community anchor institution” means a public school, a public or multi-family housing authority, a library, a medical or healthcare provider, a community college or other institution of higher education, a State library agency, and any other nonprofit or governmental community support organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce31047d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered household","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered household” means a household, the income of which for the most recently completed year is not more than 150 percent of an amount equal to the poverty level, as determined by using criteria of poverty established by the Bureau of the Census.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce31047e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered populations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered populations” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce31047f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who live in covered households;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce310480-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aging individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce310481-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incarcerated individuals, other than individuals who are incarcerated in a Federal correctional facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce310482-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veterans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce310483-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/8/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce310484-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/8/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" individuals with a language barrier, including individuals who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idce310485-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/8/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are English learners; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce310486-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/8/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have low levels of literacy;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce310487-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/8/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who are members of a racial or ethnic minority group; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce310488-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/8/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who primarily reside in a rural area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce310489-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered programs” means the State Digital Equity Capacity Grant Program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1723"},"text":"section 1723 of this title","children":[],"tail":" and the Digital Equity Competitive Grant Program established under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s1724"},"text":"section 1724 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce31048a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Digital equity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “digital equity” means the condition in which individuals and communities have the information technology capacity that is needed for full participation in the society and economy of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce31048b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Digital inclusion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “digital inclusion”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce31048c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means the activities that are necessary to ensure that all individuals in the United States have access to, and the use of, affordable information and communication technologies, such as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idce31048d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/11/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reliable fixed and wireless broadband internet service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce31048e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/11/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" internet-enabled devices that meet the needs of the user; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce31048f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/11/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applications and online content designed to enable and encourage self-sufficiency, participation, and collaboration; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce310490-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idce310491-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/11/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtaining access to digital literacy training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce310492-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/11/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of quality technical support; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce310493-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/11/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtaining basic awareness of measures to ensure online privacy and cybersecurity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce310494-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Digital literacy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “digital literacy” means the skills associated with using technology to enable users to find, evaluate, organize, create, and communicate information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce310495-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1721/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disability","children":[],"tail":null},{"tag":"c