{"tag":"section","attrib":{"id":"idce2061df-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1402"},"text":null,"children":[{"tag":"num","attrib":{"value":"1402"},"text":"§ 1402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each range of frequencies described in this chapter shall be construed to be inclusive of the upper and lower frequencies in the range.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idce2061e0-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/96/tVI/s6002"},"text":"Pub. L. 112–96, title VI, § 6002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/204"},"text":"126 Stat. 204","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
