{"tag":"section","attrib":{"id":"idcdb06221-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s256"},"text":null,"children":[{"tag":"num","attrib":{"value":"256"},"text":"§ 256.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination for interconnectivity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcdb06222-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s256/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcdb06223-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s256/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to promote nondiscriminatory accessibility by the broadest number of users and vendors of communications products and services to public telecommunications networks used to provide telecommunications service through—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcdb06224-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s256/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinated public telecommunications network planning and design by telecommunications carriers and other providers of telecommunications service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcdb06225-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s256/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public telecommunications network interconnectivity, and interconnectivity of devices with such networks used to provide telecommunications service; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdb06226-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s256/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure the ability of users and information providers to seamlessly and transparently transmit and receive information between and across telecommunications networks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdb06227-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s256/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the purposes of this section, the Commission—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcdb06228-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s256/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall establish procedures for Commission oversight of coordinated network planning by telecommunications carriers and other providers of telecommunications service for the effective and efficient interconnection of public telecommunications networks used to provide telecommunications service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdb06229-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s256/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may participate, in a manner consistent with its authority and practice prior to ","children":[{"tag":"date","attrib":{"date":"1996-02-08"},"text":"February 8, 1996","children":[],"tail":", in the development by appropriate industry standards-setting organizations of public telecommunications network interconnectivity standards that promote access to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcdb0622a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s256/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public telecommunications networks used to provide telecommunications service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcdb0622b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s256/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" network capabilities and services by individuals with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcdb0622c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s256/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information services by subscribers of rural telephone companies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdb0622d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s256/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission’s authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as expanding or limiting any authority that the Commission may have under law in effect before ","children":[{"tag":"date","attrib":{"date":"1996-02-08"},"text":"February 8, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdb0622e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s256/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Public telecommunications network interconnectivity” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the term “public telecommunications network interconnectivity” means the ability of two or more public telecommunications networks used to provide telecommunications service to communicate and exchange information without degeneration, and to interact in concert with one another.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcdb0622f-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title II, § 256, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/104/tI/s101/a"},"text":"Pub. L. 104–104, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-08"},"text":"Feb. 8, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/76"},"text":"110 Stat. 76","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
