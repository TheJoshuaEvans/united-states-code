{"tag":"section","attrib":{"id":"idce1936c5-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1203"},"text":null,"children":[{"tag":"num","attrib":{"value":"1203"},"text":"§ 1203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idce1936c6-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary of Homeland Security for Science and Technology, in consultation with the director of the National Institute of Standards and Technology and the chairman of the Federal Communications Commission, shall establish a research, development, testing, and evaluation program based on the recommendations of the Commercial Mobile Service Alert Advisory Committee, established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1202/a"},"text":"section 1202(a) of this title","children":[],"tail":", to support the development of technologies to increase the number of commercial mobile service devices that can receive emergency alerts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce1936c7-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program established under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce1936c8-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1203/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fund research, development, testing, and evaluation at academic institutions, private sector entities, government laboratories, and other appropriate entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce1936c9-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1203/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that the program addresses, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce1936ca-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1203/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing innovative technologies that will transmit geographically targeted emergency alerts to the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce1936cb-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1203/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research on understanding and improving public response to warnings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idce1936cc-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347/tVI/s604"},"text":"Pub. L. 109–347, title VI, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1940"},"text":"120 Stat. 1940","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
