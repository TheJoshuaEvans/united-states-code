{"tag":"section","attrib":{"id":"idce22d3ca-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1427"},"text":null,"children":[{"tag":"num","attrib":{"value":"1427"},"text":"§ 1427.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial funding for the First Responder Network Authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idce22d3cb-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1427/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Borrowing authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to the deposit of proceeds into the Public Safety Trust Fund from the incentive auctions to be carried out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s309/j/8/G"},"text":"section 309(j)(8)(G) of this title","children":[],"tail":" or the auction of spectrum pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s1451"},"text":"section 1451 of this title","children":[],"tail":", the NTIA may borrow from the Treasury such sums as may be necessary, but not to exceed $2,000,000,000, to implement this subchapter. The NTIA shall reimburse the Treasury, without interest, from funds deposited into the Public Safety Trust Fund."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce22d3cc-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1427/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce22d3cd-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1427/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Administrative expenses of the First Responder Network Authority may not exceed $100,000,000 during the 10-year period beginning on ","children":[{"tag":"date","attrib":{"date":"2012-02-22"},"text":"February 22, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce22d3ce-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1427/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “administrative expenses” does not include the costs incurred by the First Responder Network Authority for oversight and audits to protect against waste, fraud, and abuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idce22d3cf-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/96/tVI/s6207"},"text":"Pub. L. 112–96, title VI, § 6207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/215"},"text":"126 Stat. 215","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idce22d3d0-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idce22d3d1-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idce22d3d2-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1451, referred to in subsec. (a), was in the original “section 6401” and means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/96/s6401"},"text":"section 6401 of Pub. L. 112–96","children":[],"tail":", which enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s1451"},"text":"section 1451 of this title","children":[],"tail":" and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s309"},"text":"section 309 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
