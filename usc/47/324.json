{"tag":"section","attrib":{"id":"idd2712e4f-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s324"},"text":null,"children":[{"tag":"num","attrib":{"value":"324"},"text":"§ 324.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of minimum power","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In all circumstances, except in case of radio communications or signals relating to vessels in distress, all radio stations, including those owned and operated by the United States, shall use the minimum amount of power necessary to carry out the communication desired.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd2712e50-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title III, § 324, "},{"tag":"ref","attrib":{"href":"/us/stat/48/1091"},"text":"48 Stat. 1091","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
