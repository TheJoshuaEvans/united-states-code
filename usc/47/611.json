{"tag":"section","attrib":{"id":"idd2a5aba4-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s611"},"text":null,"children":[{"tag":"num","attrib":{"value":"611"},"text":"§ 611.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Closed-captioning of public service announcements","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any television public service announcement that is produced or funded in whole or in part by any agency or instrumentality of Federal Government shall include closed captioning of the verbal content of such announcement. A television broadcast station licensee—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2a5aba5-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s611/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be required to supply closed captioning for any such announcement that fails to include it; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2a5aba6-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s611/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be liable for broadcasting any such announcement without transmitting a closed caption unless the licensee intentionally fails to transmit the closed caption that was included with the announcement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2a5aba7-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title VII, § 711, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/549/s8"},"text":"Pub. L. 98–549, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2804"},"text":"98 Stat. 2804","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/336/tIV/s402"},"text":"Pub. L. 101–336, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/369"},"text":"104 Stat. 369","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2a5aba8-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2a5aba9-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd2a5abaa-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336"},"text":"Pub. L. 101–336","children":[],"tail":" amended section generally, substituting provisions relating to closed-captioning of public service announcements for provisions relating to establishment, functions, composition, etc., of Telecommunications Policy Study Commission."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd2a5abab-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd2a5abac-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 60 days after ","children":[{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", except where otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/549/s9/a"},"text":"section 9(a) of Pub. L. 98–549","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s521"},"text":"section 521 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
