{"tag":"section","attrib":{"id":"idd241932f-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s217"},"text":null,"children":[{"tag":"num","attrib":{"value":"217"},"text":"§ 217.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agents’ acts and omissions; liability of carrier","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In construing and enforcing the provisions of this chapter, the act, omission, or failure of any officer, agent, or other person acting for or employed by any common carrier or user, acting within the scope of his employment, shall in every case be also deemed to be the act, omission, or failure of such carrier or user as well as that of the person.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd2419330-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title II, § 217, "},{"tag":"ref","attrib":{"href":"/us/stat/48/1077"},"text":"48 Stat. 1077","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2419331-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2419332-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd2419333-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"act June 19, 1934, ch. 652","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1064"},"text":"48 Stat. 1064","children":[],"tail":", known as the Communications Act of 1934, which is classified principally to this chapter. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s609"},"text":"section 609 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
