{"tag":"section","attrib":{"id":"idd2b192ef-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s765g"},"text":null,"children":[{"tag":"num","attrib":{"value":"765g"},"text":"§ 765g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusivity arrangements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2b192f0-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s765g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No satellite operator shall acquire or enjoy the exclusive right of handling telecommunications to or from the United States, its territories or possessions, and any other country or territory by reason of any concession, contract, understanding, or working arrangement to which the satellite operator or any persons or companies controlling or controlled by the operator are parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2b192f1-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s765g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In enforcing the provisions of this section, the Commission—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2b192f2-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s765g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not require the termination of existing satellite telecommunications services under contract with, or tariff commitment to, such satellite operator; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2b192f3-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s765g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may require the termination of new services only to the country that has provided the exclusive right to handle telecommunications, if the Commission determines the public interest, convenience, and necessity so requires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2b192f4-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/624/tVI/s648"},"text":"Pub. L. 87–624, title VI, § 648","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/180/s3"},"text":"Pub. L. 106–180, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-03-17"},"text":"Mar. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/57"},"text":"114 Stat. 57","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
