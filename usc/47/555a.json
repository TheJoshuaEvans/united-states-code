{"tag":"section","attrib":{"id":"idcdf31039-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s555a"},"text":null,"children":[{"tag":"num","attrib":{"value":"555a"},"text":"§ 555a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation of franchising authority liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcdf3103a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s555a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suits for damages prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any court proceeding pending on or initiated after ","children":[{"tag":"date","attrib":{"date":"1992-10-05"},"text":"October 5, 1992","children":[],"tail":", involving any claim against a franchising authority or other governmental entity, or any official, member, employee, or agent of such authority or entity, arising from the regulation of cable service or from a decision of approval or disapproval with respect to a grant, renewal, transfer, or amendment of a franchise, any relief, to the extent such relief is required by any other provision of Federal, State, or local law, shall be limited to injunctive relief and declaratory relief."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdf3103b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s555a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for completed cases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The limitation contained in subsection (a) shall not apply to actions that, prior to such violation, have been determined by a final order of a court of binding jurisdiction, no longer subject to appeal, to be in violation of a cable operator’s rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdf3103c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s555a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discrimination claims permitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as limiting the relief authorized with respect to any claim against a franchising authority or other governmental entity, or any official, member, employee, or agent of such authority or entity, to the extent such claim involves discrimination on the basis of race, color, sex, age, religion, national origin, or handicap.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdf3103d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s555a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as creating or authorizing liability of any kind, under any law, for any action or failure to act relating to cable service or the granting of a franchise by any franchising authority or other governmental entity, or any official, member, employee, or agent of such authority or entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcdf3103e-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title VI, § 635A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/385/s24/a"},"text":"Pub. L. 102–385, § 24(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-05"},"text":"Oct. 5, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1500"},"text":"106 Stat. 1500","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcdf3103f-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcdf31040-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcdf31041-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 60 days after ","children":[{"tag":"date","attrib":{"date":"1992-10-05"},"text":"Oct. 5, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/385/s28"},"text":"section 28 of Pub. L. 102–385","children":[],"tail":", set out as an Effective Date of 1992 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s325"},"text":"section 325 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
