{"tag":"section","attrib":{"id":"idcdfef7da-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s619"},"text":null,"children":[{"tag":"num","attrib":{"value":"619"},"text":"§ 619.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internet browsers built into telephones used with public mobile services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcdfef7db-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s619/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accessibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a manufacturer of a telephone used with public mobile services (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s610/b/4/B"},"text":"section 610(b)(4)(B) of this title","children":[],"tail":") includes an Internet browser in such telephone, or if a provider of mobile service arranges for the inclusion of a browser in telephones to sell to customers, the manufacturer or provider shall ensure that the functions of the included browser (including the ability to launch the browser) are accessible to and usable by individuals who are blind or have a visual impairment, unless doing so is not achievable, except that this subsection shall not impose any requirement on such manufacturer or provider—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcdfef7dc-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s619/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make accessible or usable any Internet browser other than a browser that such manufacturer or provider includes or arranges to include in the telephone; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdfef7dd-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s619/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make Internet content, applications, or services accessible or usable (other than enabling individuals with disabilities to use an included browser to access such content, applications, or services).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdfef7de-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s619/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industry flexibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A manufacturer or provider may satisfy the requirements of subsection (a) with respect to such telephone or services by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcdfef7df-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s619/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that the telephone or services that such manufacture or provider offers is accessible to and usable by individuals with disabilities without the use of third party applications, peripheral devices, software, hardware, or customer premises equipment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdfef7e0-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s619/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using third party applications, peripheral devices, software, hardware, or customer premises equipment that is available to the consumer at nominal cost and that individuals with disabilities can access.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcdfef7e1-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title VII, § 718, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/260/tI/s104/a"},"text":"Pub. L. 111–260, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-08"},"text":"Oct. 8, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2761"},"text":"124 Stat. 2761","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcdfef7e2-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcdfef7e3-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcdfef7e4-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/260/tI/s104/b"},"text":"Pub. L. 111–260, title I, § 104(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-08"},"text":"Oct. 8, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2761"},"text":"124 Stat. 2761","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/260/tI/s104/b"},"text":"“Section 718 of the Communications Act of 1934 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s619"},"text":"47 U.S.C. 619","children":[],"tail":"], as added by subsection (a), shall take effect 3 years after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2010-10-08"},"text":"Oct. 8, 2010","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
