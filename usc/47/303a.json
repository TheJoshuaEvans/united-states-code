{"tag":"section","attrib":{"id":"idcdb76709-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s303a"},"text":null,"children":[{"tag":"num","attrib":{"value":"303a"},"text":"§ 303a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards for children’s television programming","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcdb7670a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s303a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall, within 30 days after ","children":[{"tag":"date","attrib":{"date":"1990-10-18"},"text":"October 18, 1990","children":[],"tail":", initiate a rulemaking proceeding to prescribe standards applicable to commercial television broadcast licensees with respect to the time devoted to commercial matter in conjunction with children’s television programming. The Commission shall, within 180 days after "},{"tag":"date","attrib":{"date":"1990-10-18"},"text":"October 18, 1990","children":[],"tail":", complete the rulemaking proceeding and prescribe final standards that meet the requirements of subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdb7670b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s303a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advertising duration limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (c), the standards prescribed under subsection (a) shall include the requirement that each commercial television broadcast licensee shall limit the duration of advertising in children’s television programming to not more than 10.5 minutes per hour on weekends and not more than 12 minutes per hour on weekdays.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdb7670c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s303a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of advertising duration limitations; modification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After ","children":[{"tag":"date","attrib":{"date":"1993-01-01"},"text":"January 1, 1993","children":[],"tail":", the Commission—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcdb7670d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s303a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may review and evaluate the advertising duration limitations required by subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdb7670e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s303a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, after notice and public comment and a demonstration of the need for modification of such limitations, modify such limitations in accordance with the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdb7670f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s303a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Commercial television broadcast licensee” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the term “commercial television broadcast licensee” includes a cable operator, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s522"},"text":"section 522 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcdb76710-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/437/tI/s102"},"text":"Pub. L. 101–437, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-17"},"text":"Oct. 17, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/996"},"text":"104 Stat. 996","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcdb76711-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcdb76712-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcdb76713-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Children’s Television Act of 1990, and not as part of the Communications Act of 1934 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcdb76714-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcdb76715-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/437/tI/s101"},"text":"Pub. L. 101–437, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-17"},"text":"Oct. 17, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/996"},"text":"104 Stat. 996","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/437/tI/s101"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it has been clearly demonstrated that television can assist children to learn important information, skills, values, and behavior, while entertaining them and exciting their curiosity to learn about the world around them;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as part of their obligation to serve the public interest, television station operators and licensees should provide programming that serves the special needs of children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial support of advertisers assists in the provision of programming to children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special safeguards are appropriate to protect children from overcommercialization on television;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" television station operators and licensees should follow practices in connection with children’s television programming and advertising that take into consideration the characteristics of this child audience; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is therefore necessary that the Federal Communications Commission (hereinafter referred to as the ‘Commission’) take the actions required by this title [enacting sections 303a and 303b of this title].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
