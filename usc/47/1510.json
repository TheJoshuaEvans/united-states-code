{"tag":"section","attrib":{"id":"idd2d2fe03-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1510"},"text":null,"children":[{"tag":"num","attrib":{"value":"1510"},"text":"§ 1510.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wireless telecommunications tax and fee collection fairness","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2d2fe04-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1510/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may be cited as the “Wireless Telecommunications Tax and Fee Collection Fairness Act”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2d2fe05-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1510/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2d2fe06-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1510/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial transaction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “financial transaction” means a transaction in which the purchaser or user of a wireless telecommunications service upon whom a tax, fee, or surcharge is imposed gives cash, credit, or any other exchange of monetary value or consideration to the person who is required to collect or remit the tax, fee, or surcharge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d2fe07-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1510/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “local jurisdiction” means a political subdivision of a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d2fe08-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1510/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means any of the several States, the District of Columbia, and any territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d2fe09-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1510/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State or local jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State or local jurisdiction” includes any governmental entity or person acting on behalf of a State or local jurisdiction that has the authority to assess, impose, levy, or collect taxes or fees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d2fe0a-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1510/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wireless telecommunications service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “wireless telecommunications service” means a commercial mobile radio service, as defined in section 20.3 of title 47, Code of Federal Regulations, or any successor thereto.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2d2fe0b-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1510/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial transaction requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2d2fe0c-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1510/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State, or a local jurisdiction of a State, may not require a person who is neither a resident of such State or local jurisdiction nor an entity having its principal place of business in such State or local jurisdiction to collect from, or remit on behalf of, any other person a State or local tax, fee, or surcharge imposed on a purchaser or user with respect to the purchase or use of any wireless telecommunications service within the State unless the collection or remittance is in connection with a financial transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d2fe0d-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1510/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be construed to affect the right of a State or local jurisdiction to require the collection of any tax, fee, or surcharge in connection with a financial transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2d2fe0e-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1510/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2d2fe0f-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1510/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private right of action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person aggrieved by a violation of subsection (c) may bring a civil action in an appropriate district court of the United States for equitable relief in accordance with paragraph (2) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d2fe10-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1510/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of district courts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1341"},"text":"section 1341 of title 28","children":[],"tail":", or the constitution or laws of any State, the district courts of the United States shall have jurisdiction, without regard to the amount in controversy or citizenship of the parties, to grant such mandatory or prohibitive injunctive relief, interim equitable relief, and declaratory judgments as may be necessary to prevent, restrain, or terminate any acts in violation of subsection (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2d2fe11-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dP/tVI/s620"},"text":"Pub. L. 115–141, div. P, title VI, § 620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1114"},"text":"132 Stat. 1114","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
