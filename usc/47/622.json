{"tag":"section","attrib":{"id":"idd2acd81a-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s622"},"text":null,"children":[{"tag":"num","attrib":{"value":"622"},"text":"§ 622.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Optional electronic labeling of communications equipment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2acd81b-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s622/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2acd81c-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s622/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “electronic labeling” means displaying required labeling and regulatory information electronically; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2acd81d-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s622/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “radiofrequency device with display” means any equipment or device that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2acd81e-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s622/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is required under regulations of the Commission to be authorized by the Commission before the equipment or device may be marketed or sold within the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2acd81f-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s622/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the capability to digitally display required labeling and regulatory information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2acd820-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s622/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to promulgate regulations for electronic labeling","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 9 months after ","children":[{"tag":"date","attrib":{"date":"2014-11-26"},"text":"November 26, 2014","children":[],"tail":", the Commission shall promulgate regulations or take other appropriate action, as necessary, to allow manufacturers of radiofrequency devices with display the option to use electronic labeling for the equipment in place of affixing physical labels to the equipment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2acd821-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title VII, § 720, as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/197/s3"},"text":"Pub. L. 113–197, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2055"},"text":"128 Stat. 2055","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2acd822-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd2acd823-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idd2acd824-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Clause","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/197/s4"},"text":"Pub. L. 113–197, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2056"},"text":"128 Stat. 2056","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/197/s4"},"text":"“The amendment made by section 3 [enacting this section] shall not be construed to affect the authority of the Federal Communications Commission under section 302 of the Communications Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s302a"},"text":"47 U.S.C. 302a","children":[],"tail":") to provide for electronic labeling of devices.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd2acd825-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/197/s2"},"text":"Pub. L. 113–197, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2055"},"text":"128 Stat. 2055","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/197/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress finds the following:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal Communications Commission (referred to in this section as the ‘Commission’) first standardized physical labels for licensed products such as computers, phones, and other electronic devices in 1973, and the Commission has continually refined physical label requirements over time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As devices become smaller, compliance with physical label requirements can become more difficult and costly.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Many manufacturers and consumers of licensed devices in the United States would prefer to have the option to provide or receive important Commission labeling information digitally on the screen of the device, at the discretion of the user.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An electronic labeling option would give flexibility to manufacturers in meeting labeling requirements.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
