{"tag":"section","attrib":{"id":"idd24192f4-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s211"},"text":null,"children":[{"tag":"num","attrib":{"value":"211"},"text":"§ 211.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts of carriers; filing with Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd24192f5-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s211/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Every carrier subject to this chapter shall file with the Commission copies of all contracts, agreements, or arrangements with other carriers, or with common carriers not subject to the provisions of this chapter, in relation to any traffic affected by the provisions of this chapter to which it may be a party.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd24192f6-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s211/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall have authority to require the filing of any other contracts of any carrier, and shall also have authority to exempt any carrier from submitting copies of such minor contracts as the Commission may determine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd24192f7-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title II, § 211, "},{"tag":"ref","attrib":{"href":"/us/stat/48/1073"},"text":"48 Stat. 1073","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd24192f8-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd24192f9-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd24192fa-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"act June 19, 1934, ch. 652","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1064"},"text":"48 Stat. 1064","children":[],"tail":", known as the Communications Act of 1934, which is classified principally to this chapter. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s609"},"text":"section 609 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
