{"tag":"section","attrib":{"id":"idce251e15-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1457"},"text":null,"children":[{"tag":"num","attrib":{"value":"1457"},"text":"§ 1457.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public Safety Trust Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idce251e16-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1457/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Public Safety Trust Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce251e17-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1457/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a trust fund to be known as the Public Safety Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce251e18-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1457/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts deposited in the Public Safety Trust Fund shall remain available through fiscal year 2022. Any amounts remaining in the Fund after the end of such fiscal year shall be deposited in the general fund of the Treasury, where such amounts shall be dedicated for the sole purpose of deficit reduction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce251e19-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1457/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As amounts are deposited in the Public Safety Trust Fund, such amounts shall be used to make the following deposits or payments in the following order of priority:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce251e1a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1457/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment of amount borrowed for First Responder Network Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An amount not to exceed $2,000,000,000 shall be available to the NTIA to reimburse the general fund of the Treasury for any amounts borrowed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1427"},"text":"section 1427 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce251e1b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1457/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and Local Implementation Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"$135,000,000 shall be deposited in the State and Local Implementation Fund established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1441"},"text":"section 1441 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce251e1c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1457/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Buildout by First Responder Network Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"$7,000,000,000, reduced by the amount borrowed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1427"},"text":"section 1427 of this title","children":[],"tail":", shall be deposited in the Network Construction Fund established by "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s1426"},"text":"section 1426 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce251e1d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1457/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public safety research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"$100,000,000 shall be available to the Director of NIST to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1443"},"text":"section 1443 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce251e1e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1457/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deficit reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"$20,400,000,000 shall be deposited in the general fund of the Treasury, where such amount shall be dedicated for the sole purpose of deficit reduction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce251e1f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1457/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 9–1–1, E9–1–1, and Next Generation 9–1–1 implementation grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"$115,000,000 shall be available to the Assistant Secretary and the Administrator of the National Highway Traffic Safety Administration to carry out the grant program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s942"},"text":"section 942 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce251e20-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1457/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional public safety research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"$200,000,000 shall be available to the Director of NIST to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1443"},"text":"section 1443 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce251e21-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1457/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional deficit reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any remaining amounts deposited in the Public Safety Trust Fund shall be deposited in the general fund of the Treasury, where such amounts shall be dedicated for the sole purpose of deficit reduction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce251e22-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1457/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the Public Safety Trust Fund shall be invested in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s9702"},"text":"section 9702 of title 31","children":[],"tail":", and any interest on, and proceeds from, any such investment shall be credited to, and become a part of, the Fund."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idce251e23-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/96/tVI/s6413"},"text":"Pub. L. 112–96, title VI, § 6413","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/235"},"text":"126 Stat. 235","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
