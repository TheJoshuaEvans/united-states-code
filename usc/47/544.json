{"tag":"section","attrib":{"id":"idd299c4e0-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s544"},"text":null,"children":[{"tag":"num","attrib":{"value":"544"},"text":"§ 544.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulation of services, facilities, and equipment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd299c4e1-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s544/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulation by franchising authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any franchising authority may not regulate the services, facilities, and equipment provided by a cable operator except to the extent consistent with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd299c4e2-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s544/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests for proposals; establishment and enforcement of requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any franchise granted after the effective date of this subchapter, the franchising authority, to the extent related to the establishment or operation of a cable system—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd299c4e3-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s544/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in its request for proposals for a franchise (including requests for renewal proposals, subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s546"},"text":"section 546 of this title","children":[],"tail":"), may establish requirements for facilities and equipment, but may not, except as provided in subsection (h), establish requirements for video programming or other information services; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd299c4e4-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s544/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s545"},"text":"section 545 of this title","children":[],"tail":", may enforce any requirements contained within the franchise—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd299c4e5-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s544/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for facilities and equipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd299c4e6-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s544/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for broad categories of video programming or other services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd299c4e7-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s544/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement authority respecting franchises effective under prior law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any franchise in effect on the effective date of this subchapter, the franchising authority may, subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s545"},"text":"section 545 of this title","children":[],"tail":", enforce requirements contained within the franchise for the provision of services, facilities, and equipment, whether or not related to the establishment or operation of a cable system."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd299c4e8-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s544/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cable service unprotected by Constitution; blockage of premium channel upon request","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd299c4e9-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s544/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this subchapter shall be construed as prohibiting a franchising authority and a cable operator from specifying, in a franchise or renewal thereof, that certain cable services shall not be provided or shall be provided subject to conditions, if such cable services are obscene or are otherwise unprotected by the Constitution of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd299c4ea-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s544/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to restrict the viewing of of of ","children":[{"tag":"ref","attrib":{"idref":"fn002033"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002033"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" programming which is obscene or indecent, upon the request of a subscriber, a cable operator shall provide (by sale or lease) a device by which the subscriber can prohibit viewing of a particular cable service during periods selected by that subscriber."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd299c4eb-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s544/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd299c4ec-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s544/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If a cable operator provides a premium channel without charge to cable subscribers who do not subscribe to such premium channel, the cable operator shall, not later than 30 days before such premium channel is provided without charge—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd299c4ed-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s544/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify all cable subscribers that the cable operator plans to provide a premium channel without charge;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd299c4ee-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s544/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify all cable subscribers when the cable operator plans to offer a premium channel without charge;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd299c4ef-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s544/d/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify all cable subscribers that they have a right to request that the channel carrying the premium channel be blocked; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd299c4f0-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s544/d/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" block the channel carrying the premium channel upon the request of a subscriber.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd299c4f1-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s544/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of this section, the term “premium channel” shall mean any pay service offered on a per channel or per program basis, which offers movies rated by the Motion Picture Association of America as X, NC–17, or R.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd299c4f2-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s544/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within one year after ","children":[{"tag":"date","attrib":{"date":"1992-10-05"},"text":"October 5, 1992","children":[],"tail":", the Commission shall prescribe regulations which establish minimum technical standards relating to cable systems’ technical operation and signal quality. The Commission shall update such standards periodically to reflect improvements in technology. No State or franchising authority may prohibit, condition, or restrict a cable system’s use of any type of subscriber equipment or any transmission technology."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd299c4f3-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s544/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on regulatory powers of Federal agencies, States, or franchising authorities; exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd299c4f4-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s544/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any Federal agency, State, or franchising authority may not impose requirements regarding the provision or content of cable services, except as expressly provided in this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd299c4f5-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s544/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) shall not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd299c4f6-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s544/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any rule, regulation, or order issued under any Federal law, as such rule, regulation, or order (i) was in effect on ","children":[{"tag":"date","attrib":{"date":"1983-09-21"},"text":"September 21, 1983","children":[],"tail":", or (ii) may be amended after such date if the rule, regulation, or order as amended is not inconsistent with the express provisions of this subchapter; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd29c0ee7-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s544/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any rule, regulation, or order under title 17.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd29c0ee8-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s544/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to emergency information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any such rule, regulation, or order, each cable operator shall comply with such standards as the Commission shall prescribe to ensure that viewers of video programming on cable systems are afforded the same emergency information as is afforded by the emergency broadcasting system pursuant to Commission regulations in subpart G of part 73, title 47, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd29c0ee9-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s544/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of changes in and comments on services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A franchising authority may require a cable operator to do any one or more of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd29c0eea-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s544/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provide 30 days’ advance written notice of any change in channel assignment or in the video programming service provided over any such channel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd29c0eeb-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s544/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Inform subscribers, via written notice, that comments on programming and channel position changes are being recorded by a designated office of the franchising authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd29c0eec-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s544/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of cable upon termination of service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 120 days after ","children":[{"tag":"date","attrib":{"date":"1992-10-05"},"text":"October 5, 1992","children":[],"tail":", the Commission shall prescribe rules concerning the disposition, after a subscriber to a cable system terminates service, of any cable installed by the cable operator within the premises of such subscriber."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd29c0eed-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title VI, § 624, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/549/s2"},"text":"Pub. L. 98–549, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2789"},"text":"98 Stat. 2789","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/385"},"text":"Pub. L. 102–385","children":[],"tail":", §§ 15, 16, "},{"tag":"date","attrib":{"date":"1992-10-05"},"text":"Oct. 5, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1490"},"text":"106 Stat. 1490","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/414/tIII"},"text":"Pub. L. 103–414, title III","children":[],"tail":", §§ 303(a)(23), 304(a)(12), "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4295"},"text":"108 Stat. 4295","children":[],"tail":", 4297; "},{"tag":"ref","attrib":{"href":"/us/pl/104/104/tIII/s301/e"},"text":"Pub. L. 104–104, title III, § 301(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-08"},"text":"Feb. 8, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/116"},"text":"110 Stat. 116","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd29c0eee-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd29c0eef-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd29c0ef0-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For “the effective date of this subchapter”, referred to in subsecs. (b) and (c), as 60 days after ","children":[{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", except where otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/549/s9/a"},"text":"section 9(a) of Pub. L. 98–549","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s521"},"text":"section 521 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd29c0ef1-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/104"},"text":"Pub. L. 104–104","children":[],"tail":" substituted “No State or franchising authority may prohibit, condition, or restrict a cable system’s use of any type of subscriber equipment or any transmission technology.” for “A franchising authority may require as part of a franchise (including a modification, renewal, or transfer thereof) provisions for the enforcement of the standards prescribed under this subsection. A franchising authority may apply to the Commission for a waiver to impose standards that are more stringent than the standards prescribed by the Commission under this subsection.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/414/s304/a/12"},"text":"Pub. L. 103–414, § 304(a)(12)","children":[],"tail":", struck out designation “(A)”, inserted “of” after “restrict the viewing”, and struck out subpar. (B) which read as follows: “Subparagraph (A) shall take effect 180 days after the effective date of this subchapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/414/s303/a/23"},"text":"Pub. L. 103–414, § 303(a)(23)","children":[],"tail":", inserted “of” after “restrict the viewing” in subpar. (A)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/385/s16/c/1"},"text":"Pub. L. 102–385, § 16(c)(1)","children":[],"tail":", inserted “, except as provided in subsection (h),” after “but may not”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/385/s15"},"text":"Pub. L. 102–385, § 15","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/385/s16/a"},"text":"Pub. L. 102–385, § 16(a)","children":[],"tail":", amended subsec. (e) generally. Prior to amendment, subsec. (e) read as follows: “The Commission may establish technical standards relating to the facilities and equipment of cable systems which a franchising authority may require in the franchise.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/385/s16/b"},"text":"Pub. L. 102–385, § 16(b)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/385/s16/c/2"},"text":"Pub. L. 102–385, § 16(c)(2)","children":[],"tail":", added subsec. (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/385/s16/d"},"text":"Pub. L. 102–385, § 16(d)","children":[],"tail":", added subsec. (i)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd29c0ef2-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd29c0ef3-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/385"},"text":"Pub. L. 102–385","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"1992-10-05"},"text":"Oct. 5, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/385/s28"},"text":"section 28 of Pub. L. 102–385","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s325"},"text":"section 325 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd29c0ef4-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 60 days after ","children":[{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", except where otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/549/s9/a"},"text":"section 9(a) of Pub. L. 98–549","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s521"},"text":"section 521 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd29c0ef5-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Restoration, Retierment and Repricing of Service Previously Eliminated, Retiered, or Repriced","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section not to be construed to allow a franchising authority, or a State or political subdivision thereof, to require a cable operator to restore, retier or reprice cable service previously eliminated, retiered, or repriced as of ","children":[{"tag":"date","attrib":{"date":"1984-09-26"},"text":"Sept. 26, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/549/s9/b"},"text":"section 9(b) of Pub. L. 98–549","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s543"},"text":"section 543 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
