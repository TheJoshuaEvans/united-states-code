{"tag":"section","attrib":{"id":"idcd9141fb-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s158"},"text":null,"children":[{"tag":"num","attrib":{"value":"158"},"text":"§ 158.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcd9141fc-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s158/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority; establishment of schedule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall assess and collect application fees at such rates as the Commission shall establish in a schedule of application fees to recover the costs of the Commission to process applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcd9141fd-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s158/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment of schedule","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcd9141fe-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s158/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In every even-numbered year, the Commission shall review the schedule of application fees established under this section and, except as provided in paragraph (2), set a new amount for each fee in the schedule that is equal to the amount of the fee on the date when the fee was established or the date when the fee was last amended under subsection (c), whichever is later—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcd9141ff-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s158/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increased or decreased by the percentage change in the Consumer Price Index during the period beginning on such date and ending on the date of the review; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcd914200-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s158/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rounded to the nearest $5 increment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcd914201-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s158/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Threshold for adjustment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission may not adjust a fee under paragraph (1) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcd914202-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s158/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a fee the current amount of which is less than $200, the adjustment would result in a change in the current amount of less than $10; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcd914203-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s158/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a fee the current amount of which is $200 or more, the adjustment would result in a change in the current amount of less than 5 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcd914204-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s158/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Current amount defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In paragraph (2), the term “current amount” means, with respect to a fee, the amount of the fee on the date when the fee was established, the date when the fee was last adjusted under paragraph (1), or the date when the fee was last amended under subsection (c), whichever is latest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcd914205-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s158/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments to schedule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the adjustments required by subsection (b), the Commission shall by rule amend the schedule of application fees established under this section if the Commission determines that the schedule requires amendment—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcd914206-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s158/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" so that such fees reflect increases or decreases in the costs of processing applications at the Commission; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcd914207-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s158/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" so that such schedule reflects the consolidation or addition of new categories of applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcd914208-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s158/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcd914209-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s158/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parties to which fees are not applicable","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The application fees established under this section shall not be applicable to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcd91420a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s158/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a governmental entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcd91420b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s158/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit entity licensed in the Local Government, Police, Fire, Highway Maintenance, Forestry-Conservation, Public Safety, or Special Emergency Radio radio services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcd91420c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s158/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a noncommercial radio station or noncommercial television station.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcd91420d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s158/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost of collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, in the judgment of the Commission, the cost of collecting an application fee established under this section would exceed the amount collected, the Commission may by rule eliminate such fee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcd91420e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s158/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of collections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Moneys received from application fees established under this section shall be deposited in the general fund of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcd91420f-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title I, § 8, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tV/s5002/e"},"text":"Pub. L. 99–272, title V, § 5002(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/118"},"text":"100 Stat. 118","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/594/s5"},"text":"Pub. L. 100–594, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-03"},"text":"Nov. 3, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3021"},"text":"102 Stat. 3021","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tIII/s3001/a"},"text":"Pub. L. 101–239, title III, § 3001(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2124"},"text":"103 Stat. 2124","children":[],"tail":", 2131; "},{"tag":"ref","attrib":{"href":"/us/pl/102/538/tII/s209"},"text":"Pub. L. 102–538, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3544"},"text":"106 Stat. 3544","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tVI/s6003/a/2"},"text":"Pub. L. 103–66, title VI, § 6003(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/401"},"text":"107 Stat. 401","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/414/tIII"},"text":"Pub. L. 103–414, title III","children":[],"tail":", §§ 302, 303(a)(3), (4), "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4294"},"text":"108 Stat. 4294","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dP/tI/s102/a"},"text":"Pub. L. 115–141, div. P, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1082"},"text":"132 Stat. 1082","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcd914210-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcd914211-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcd914212-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" amended section generally. Prior to amendment, section related to application fees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/414/s303/a/3"},"text":"Pub. L. 103–414, § 303(a)(3)","children":[],"tail":", substituted “payment of an” for “payment of a”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/414/s303/a/4"},"text":"Pub. L. 103–414, § 303(a)(4)","children":[],"tail":", substituted “Additional Application Fee” for “Additional Charge” in item 7.f. under heading “"},{"tag":"inline","attrib":{},"text":"equipment approval services/experimental radio","children":[],"tail":"” in Schedule of Application Fees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/414/s302"},"text":"Pub. L. 103–414, § 302","children":[],"tail":", added item 1.d. under heading “"},{"tag":"inline","attrib":{},"text":"common carrier services","children":[],"tail":"” in Schedule of Application Fees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s6003/a/2/A"},"text":"Pub. L. 103–66, § 6003(a)(2)(A)","children":[],"tail":", substituted “Application fees” for “Charges” as section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s6003/a/2/B"},"text":"Pub. L. 103–66, § 6003(a)(2)(B)","children":[],"tail":"–(D), substituted “application fees” for “charges” and “Schedule of Application Fees” for “Schedule of Charges” wherever appearing, and substituted “application fee” for “charge” in subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s6003/a/2/D"},"text":"Pub. L. 103–66, § 6003(a)(2)(D)","children":[],"tail":", in text substituted “Schedule of Application Fees” for “Schedule of Charges”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s6003/a/2/E"},"text":"Pub. L. 103–66, § 6003(a)(2)(E)","children":[],"tail":", which directed amendment of schedule by substituting “"},{"tag":"inline","attrib":{},"text":"Schedule of Application Fees","children":[],"tail":"” for “"},{"tag":"inline","attrib":{},"text":"Schedule of Charges","children":[],"tail":"”, “"},{"tag":"inline","attrib":{},"text":"Application fees","children":[],"tail":"” for “"},{"tag":"inline","attrib":{},"text":"Charges","children":[],"tail":"”, “application fee” for “charge”, and “Application fees” for “Charges” was executed by substituting “SCHEDULE OF APPLICATION FEES” for “SCHEDULE OF CHARGES” in heading, “"},{"tag":"inline","attrib":{},"text":"miscellaneous application fees","children":[],"tail":"” for “"},{"tag":"inline","attrib":{},"text":"miscellaneous charges","children":[],"tail":"” in last subheading, and “application fee” for “charge” in two places in text of schedule, to reflect probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/538"},"text":"Pub. L. 102–538","children":[],"tail":" in Schedule of Charges added twenty-second category, relating to Low-Earth Orbit Satellite Systems, under heading “"},{"tag":"inline","attrib":{},"text":"common carrier services","children":[],"tail":"”, and substituted “75.00” for “360.00” in item 3.c., relating to inspection of vessels under the Great Lakes Agreement, under heading “"},{"tag":"inline","attrib":{},"text":"miscellaneous charges”.","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s3001/b/1"},"text":"Pub. L. 101–239, § 3001(b)(1)","children":[],"tail":", struck out at end “The Schedule of Charges established under this subsection shall be implemented not later than 360 days after "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"April 7, 1986","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s3001/b/2"},"text":"Pub. L. 101–239, § 3001(b)(2)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1991-10-01"},"text":"October 1, 1991","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1987-04-01"},"text":"April 1, 1987","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s3001/b/3"},"text":"Pub. L. 101–239, § 3001(b)(3)","children":[],"tail":", substituted “(A) to governmental entities and nonprofit entities licensed in the following radio services:” for “to the following radio services:” and inserted “(B)” after “Emergency Radio, or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s3001/a"},"text":"Pub. L. 101–239, § 3001(a)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/594"},"text":"Pub. L. 100–594","children":[],"tail":" substituted “two years after "},{"tag":"date","attrib":{"date":"1987-04-01"},"text":"April 1, 1987","children":[],"tail":",” for “two years after "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"April 7, 1986","children":[],"tail":",”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcd93b213-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcd93b214-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2018-10-01"},"text":"Oct. 1, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dP/s103"},"text":"section 103 of div. P of Pub. L. 115–141","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s156"},"text":"section 156 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcd93b215-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/tIII/s3001/c"},"text":"Pub. L. 101–239, title III, § 3001(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2131"},"text":"103 Stat. 2131","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/239/tIII/s3001/c"},"text":"“The amendments made by this section [amending this section] shall take effect on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":"], and the Schedule of Charges required by the amendment made by subsection (a) of this section shall be implemented not later than 150 days after the date of enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcd93b216-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transitional Rules for Application Fees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dP/tI/s102/d/1"},"text":"Pub. L. 115–141, div. P, title I, § 102(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1085"},"text":"132 Stat. 1085","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/141/dP/tI/s102/d/1"},"text":"“An application fee established under section 8 of the Communications Act of 1934 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s158"},"text":"47 U.S.C. 158","children":[],"tail":"], as such section is in effect on the day before the effective date described in "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s103"},"text":"section 103 of this title","children":[],"tail":" ["},{"tag":"date","attrib":{"date":"2018-10-01"},"text":"Oct. 1, 2018","children":[],"tail":"], shall remain in effect under section 8 of the Communications Act of 1934, as amended by subsection (a) of this section, until such time as the Commission [Federal Communications Commission] adjusts or amends such fee under subsection (b) or (c) of such section 8, as so amended.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcd93b217-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Schedule of Charges","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272/s5002/f"},"text":"Section 5002(f) of Pub. L. 99–272","children":[],"tail":" established the Schedule of Charges which the Federal Communications Commission is required to prescribe pursuant to subsec. (a) of this section. See subsec. (g) of this section as added by "},{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
