{"tag":"section","attrib":{"id":"idd259606f-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s261"},"text":null,"children":[{"tag":"num","attrib":{"value":"261"},"text":"§ 261.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2596070-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s261/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this part shall be construed to prohibit the Commission from enforcing regulations prescribed prior to ","children":[{"tag":"date","attrib":{"date":"1996-02-08"},"text":"February 8, 1996","children":[],"tail":", in fulfilling the requirements of this part, to the extent that such regulations are not inconsistent with the provisions of this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2596071-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s261/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing State regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this part shall be construed to prohibit any State commission from enforcing regulations prescribed prior to ","children":[{"tag":"date","attrib":{"date":"1996-02-08"},"text":"February 8, 1996","children":[],"tail":", or from prescribing regulations after "},{"tag":"date","attrib":{"date":"1996-02-08"},"text":"February 8, 1996","children":[],"tail":", in fulfilling the requirements of this part, if such regulations are not inconsistent with the provisions of this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2596072-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s261/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional State requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this part precludes a State from imposing requirements on a telecommunications carrier for intrastate services that are necessary to further competition in the provision of telephone exchange service or exchange access, as long as the State’s requirements are not inconsistent with this part or the Commission’s regulations to implement this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2596073-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title II, § 261, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/104/tI/s101/a"},"text":"Pub. L. 104–104, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-08"},"text":"Feb. 8, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/79"},"text":"110 Stat. 79","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
