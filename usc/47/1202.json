{"tag":"section","attrib":{"id":"idd2c4a5bb-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202"},"text":null,"children":[{"tag":"num","attrib":{"value":"1202"},"text":"§ 1202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial Mobile Service Alert Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2c4a5bc-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2006-10-13"},"text":"October 13, 2006","children":[],"tail":", the chairman of the Federal Communications Commission shall establish an advisory committee, to be known as the Commercial Mobile Service Alert Advisory Committee (referred to in this section as the “Advisory Committee”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2c4a5bd-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The chairman of the Federal Communications Commission shall appoint the members of the Advisory Committee, as soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2006-10-13"},"text":"October 13, 2006","children":[],"tail":", from the following groups:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2c4a5be-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and local government representatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Representatives of State and local governments and representatives of emergency response providers, selected from among individuals nominated by national organizations representing such governments and personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2c4a5bf-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal governments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Representatives from Federally recognized Indian tribes and National Indian organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2c4a5c0-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subject matter experts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Individuals who have the requisite technical knowledge and expertise to serve on the Advisory Committee in the fulfillment of its duties, including representatives of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2c4a5c1-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communications service providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2c4a5c2-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vendors, developers, and manufacturers of systems, facilities, equipment, and capabilities for the provision of communications services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2c4a5c3-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" third-party service bureaus;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2c4a5c4-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical experts from the broadcasting industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2c4a5c5-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the national organization representing the licensees and permittees of noncommercial broadcast television stations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2c4a5c6-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national organizations representing individuals with special needs, including individuals with disabilities and the elderly; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2c4a5c7-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other individuals with relevant technical expertise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2c4a5c8-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified representatives of other stakeholders and interested parties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Qualified representatives of such other stakeholders and interested and affected parties as the chairman deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2c4a5c9-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of system-critical recommendations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 1 year after ","children":[{"tag":"date","attrib":{"date":"2006-10-13"},"text":"October 13, 2006","children":[],"tail":", the Advisory Committee shall develop and submit to the Federal Communications Commission recommendations—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2c4a5ca-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for protocols, technical capabilities, and technical procedures through which electing commercial mobile service providers receive, verify, and transmit alerts to subscribers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2c4a5cb-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the establishment of technical standards for priority transmission of alerts by electing commercial mobile service providers to subscribers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2c4a5cc-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for relevant technical standards for devices and equipment and technologies used by electing commercial mobile service providers to transmit emergency alerts to subscribers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2c4a5cd-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the technical capability to transmit emergency alerts by electing commercial mobile providers to subscribers in languages in addition to English, to the extent practicable and feasible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2c4a5ce-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under which electing commercial mobile service providers may offer subscribers the capability of preventing the subscriber’s device from receiving emergency alerts, or classes of such alerts, (other than an alert issued by the President), consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1201/b/2/E"},"text":"section 1201(b)(2)(E) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2c4a5cf-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for a process under which commercial mobile service providers can elect to transmit emergency alerts if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2c4a5d0-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not all of the devices or equipment used by such provider are capable of receiving such alerts; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2c4a5d1-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provider cannot offer such alerts throughout the entirety of its service area; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2c4a5d2-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as otherwise necessary to enable electing commercial mobile service providers to transmit emergency alerts to subscribers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2c4a5d3-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2c4a5d4-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial meeting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The initial meeting of the Advisory Committee shall take place not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2006-10-13"},"text":"October 13, 2006","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2c4a5d5-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the initial meeting, the Advisory Committee shall meet at the call of the chair.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2c4a5d6-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice; open meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any meetings held by the Advisory Committee shall be duly noticed at least 14 days in advance and shall be open to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2c4a5d7-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2c4a5d8-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"One-third of the members of the Advisory Committee shall constitute a quorum for conducting business of the Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2c4a5d9-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subcommittees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To assist the Advisory Committee in carrying out its functions, the chair may establish appropriate subcommittees composed of members of the Advisory Committee and other subject matter experts as deemed necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2c4a5da-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee may adopt other rules as needed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2c4a5db-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Neither chapter 10 of title 5 nor any rule, order, or regulation promulgated under that chapter shall apply to the Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2c4a5dc-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1202/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with NIST","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall consult with the National Institute of Standards and Technology in its work on developing recommendations under paragraphs (2) and (3) of subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2c4a5dd-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347/tVI/s603"},"text":"Pub. L. 109–347, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1938"},"text":"120 Stat. 1938","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/300"},"text":"Pub. L. 117–286, § 4(a)(300)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4339"},"text":"136 Stat. 4339","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2c4a5de-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2c4a5df-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd2c4a5e0-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Chapter 10 of title 5” for “Federal Advisory Committee Act” in heading and “chapter 10 of title 5 nor any rule, order, or regulation promulgated under that chapter” for “the Federal Advisory Committee Act (5 U.S.C. App.) nor any rule, order, or regulation promulgated under that Act” in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
