{"tag":"section","attrib":{"id":"idd2ce4228-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1441"},"text":null,"children":[{"tag":"num","attrib":{"value":"1441"},"text":"§ 1441.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and Local Implementation Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2ce4229-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1441/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a fund to be known as the State and Local Implementation Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2ce422a-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1441/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts available for State and Local Implementation Grant Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amounts borrowed under subsection (c)(1) and any amounts in the State and Local Implementation Fund that are not necessary to reimburse the general fund of the Treasury for such borrowed amounts shall be available to the Assistant Secretary to implement ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1442"},"text":"section 1442 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2ce422b-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1441/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Borrowing authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2ce422c-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1441/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to the end of fiscal year 2022, the Assistant Secretary may borrow from the general fund of the Treasury such sums as may be necessary, but not to exceed $135,000,000, to implement ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1442"},"text":"section 1442 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2ce422d-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1441/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall reimburse the general fund of the Treasury, without interest, for any amounts borrowed under paragraph (1) as funds are deposited into the State and Local Implementation Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2ce422e-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1441/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of unused funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If there is a balance remaining in the State and Local Implementation Fund on ","children":[{"tag":"date","attrib":{"date":"2022-09-30"},"text":"September 30, 2022","children":[],"tail":", the Secretary of the Treasury shall transfer such balance to the general fund of the Treasury, where such balance shall be dedicated for the sole purpose of deficit reduction."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2ce422f-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/96/tVI/s6301"},"text":"Pub. L. 112–96, title VI, § 6301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/218"},"text":"126 Stat. 218","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
