{"tag":"section","attrib":{"id":"idd2d2fdcd-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1507"},"text":null,"children":[{"tag":"num","attrib":{"value":"1507"},"text":"§ 1507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlicensed spectrum policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2d2fdce-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the policy of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2d2fdcf-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1507/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maximize the benefit to the people of the United States of the spectrum resources of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d2fdd0-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1507/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to advance innovation and investment in wireless broadband services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d2fdd1-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1507/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote spectrum policy that makes available on an unlicensed basis radio frequency bands to address consumer demand for unlicensed wireless broadband operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2d2fdd2-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall ensure that the efforts of the Commission related to spectrum allocation and assignment made available on an unlicensed basis radio frequency bands to address demand for unlicensed wireless broadband operations if doing so is, after taking into account the future needs of homeland security, national security, and other spectrum users—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2d2fdd3-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1507/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d2fdd4-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1507/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2d2fdd5-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1507/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section confers any additional rights on unlicensed users or users licensed by rule under part 96 of title 47, Code of Federal Regulations, to protection from harmful interference.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2d2fdd6-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dP/tVI/s617"},"text":"Pub. L. 115–141, div. P, title VI, § 617","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1112"},"text":"132 Stat. 1112","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
