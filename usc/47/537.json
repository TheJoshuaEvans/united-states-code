{"tag":"section","attrib":{"id":"idd2975414-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s537"},"text":null,"children":[{"tag":"num","attrib":{"value":"537"},"text":"§ 537.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sales of cable systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A franchising authority shall, if the franchise requires franchising authority approval of a sale or transfer, have 120 days to act upon any request for approval of such sale or transfer that contains or is accompanied by such information as is required in accordance with Commission regulations and by the franchising authority. If the franchising authority fails to render a final decision on the request within 120 days, such request shall be deemed granted unless the requesting party and the franchising authority agree to an extension of time.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd2975415-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title VI, § 617, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/385/s13"},"text":"Pub. L. 102–385, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-05"},"text":"Oct. 5, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1489"},"text":"106 Stat. 1489","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/104/tIII/s301/i"},"text":"Pub. L. 104–104, title III, § 301(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-08"},"text":"Feb. 8, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/117"},"text":"110 Stat. 117","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2975416-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"not