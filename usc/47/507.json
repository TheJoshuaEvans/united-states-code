{"tag":"section","attrib":{"id":"idd29027be-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s507"},"text":null,"children":[{"tag":"num","attrib":{"value":"507"},"text":"§ 507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violation of Great Lakes Agreement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd29027bf-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any vessel of the United States that is navigated in violation of the provisions of the Great Lakes Agreement or the rules and regulations of the Commission made in pursuance thereof and any vessel of a foreign country that is so navigated on waters under the jurisdiction of the United States shall forfeit to the United States the sum of $500 recoverable by way of suit or libel. Each day during which such navigation occurs shall constitute a separate offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd29027c0-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Every willful failure on the part of the master of a vessel of the United States to enforce or to comply with the provisions of the Great Lakes Agreement or the rules and regulations of the Commission made in pursuance thereof shall cause him to forfeit to the United States the sum of $100.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd29027c1-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title V, § 506, formerly § 507, as added "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-13/ch735/s3"},"text":"Aug. 13, 1954, ch. 735, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/729"},"text":"68 Stat. 729","children":[],"tail":"; renumbered § 506, "},{"tag":"ref","attrib":{"href":"/us/pl/96/507/s1"},"text":"Pub. L. 96–507, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-08"},"text":"Dec. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2747"},"text":"94 Stat. 2747","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd29027c2-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd29027c3-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd29027c4-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 506 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"act June 19, 1934, ch. 652","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s506"},"text":"section 506 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/96/507"},"text":"Pub. L. 96–507","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd29027c5-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd29027c6-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading",