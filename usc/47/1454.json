{"tag":"section","attrib":{"id":"idd2d08cfd-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1454"},"text":null,"children":[{"tag":"num","attrib":{"value":"1454"},"text":"§ 1454.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guard bands and unlicensed use","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2d08cfe-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1454/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in subparagraph (G) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s309/j/8"},"text":"section 309(j)(8) of this title","children":[],"tail":" or in "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s1452"},"text":"section 1452 of this title","children":[],"tail":" shall be construed to prevent the Commission from using relinquished or other spectrum to implement band plans with guard bands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2d08cff-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1454/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Size of guard bands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such guard bands shall be no larger than is technically reasonable to prevent harmful interference between licensed services outside the guard bands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2d08d00-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1454/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlicensed use in guard bands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may permit the use of such guard bands for unlicensed use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2d08d01-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1454/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Database","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unlicensed use shall rely on a database or subsequent methodology as determined by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2d08d02-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1454/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protections against harmful interference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may not permit any use of a guard band that the Commission determines would cause harmful interference to licensed services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2d08d03-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/96/tVI/s6407"},"text":"Pub. L. 112–96, title VI, § 6407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/231"},"text":"126 Stat. 231","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
