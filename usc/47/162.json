{"tag":"section","attrib":{"id":"idcd962363-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s162"},"text":null,"children":[{"tag":"num","attrib":{"value":"162"},"text":"§ 162.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional research authorities of the FCC","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In order to carry out the purposes of this chapter, the Commission may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcd962364-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s162/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" undertake research and development work in connection with any matter in relation to which the Commission has jurisdiction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcd962365-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s162/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the carrying out of such research and development by others, or otherwise to arrange for such research and development to be carried out by others.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcd962366-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title I, § 12, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/358/tVIII/s803"},"text":"Pub. L. 111–358, title VIII, § 803","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4043"},"text":"124 Stat. 4043","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcd962367-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcd962368-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcd962369-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"act June 19, 1934, ch. 652","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1064"},"text":"48 Stat. 1064","children":[],"tail":", known as the Communications Act of 1934, which is classified principally to this chapter. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s609"},"text":"section 609 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
