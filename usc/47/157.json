{"tag":"section","attrib":{"id":"idd23cb10e-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s157"},"text":null,"children":[{"tag":"num","attrib":{"value":"157"},"text":"§ 157.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New technologies and services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd23cb10f-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s157/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It shall be the policy of the United States to encourage the provision of new technologies and services to the public. Any person or party (other than the Commission) who opposes a new technology or service proposed to be permitted under this chapter shall have the burden to demonstrate that such proposal is inconsistent with the public interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd23cb110-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s157/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall determine whether any new technology or service proposed in a petition or application is in the public interest within one year after such petition or application is filed. If the Commission initiates its own proceeding for a new technology or service, such proceeding shall be completed within 12 months after it is initiated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd23cb111-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title I, § 7, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/214/s12"},"text":"Pub. L. 98–214, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-08"},"text":"Dec. 8, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1471"},"text":"97 Stat. 1471","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/414/tIII/s304/a/1"},"text":"Pub. L. 103–414, title III, § 304(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4296"},"text":"108 Stat. 4296","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd23cb112-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd23cb113-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd23cb114-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"act June 19, 1934, ch. 652","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1064"},"text":"48 Stat. 1064","children":[],"tail":", known as the Communications Act of 1934, which is classified principally to this chapter. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s609"},"text":"section 609 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd23cb115-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/414"},"text":"Pub. L. 103–414","children":[],"tail":" struck out “or twelve months after "},{"tag":"date","attrib":{"date":"1983-12-08"},"text":"December 8, 1983","children":[],"tail":", if later” after “petition or application is filed” and after “12 months after it is initiated”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd23cb116-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd23cb117-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Advanced Telecommunications Incentives","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/104/tVII/s706"},"text":"Pub. L. 104–104, title VII, § 706","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-08"},"text":"Feb. 8, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/153"},"text":"110 Stat. 153","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1076/gg"},"text":"Pub. L. 107–110, title X, § 1076(gg)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2093"},"text":"115 Stat. 2093","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/385/tI/s103/a"},"text":"Pub. L. 110–385, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4096"},"text":"122 Stat. 4096","children":[],"tail":", was transferred and is classified to "},{"tag":"ref","attri