ic spectrum between the frequencies from 470 megahertz to 698 megahertz.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce2061d8-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/33"},"text":null,"children":[{"tag":"num","attrib":{"value":"33"},"text":"(33)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Very high frequency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “very high frequency” means, with respect to a television channel, that the channel is located in the portion of the electromagnetic spectrum between the frequencies from 54 megahertz to 72 megahertz, from 76 megahertz to 88 megahertz, or from 174 megahertz to 216 megahertz.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idce2061d9-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/96/tVI/s6001"},"text":"Pub. L. 112–96, title VI, § 6001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/201"},"text":"126 Stat. 201","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idce2061da-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idce2061db-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idce2061dc-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 6402, referred to in par. (17), is ","children":[{"ta