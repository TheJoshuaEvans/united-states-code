{"tag":"section","attrib":{"id":"idce2061a2-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401"},"text":null,"children":[{"tag":"num","attrib":{"value":"1401"},"text":"§ 1401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce2061a3-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 700 MHz band","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “700 MHz band” means the portion of the electromagnetic spectrum between the frequencies from 698 megahertz to 806 megahertz.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce2061a4-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 700 MHz D block spectrum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “700 MHz D block spectrum” means the portion of the electromagnetic spectrum between the frequencies from 758 megahertz to 763 megahertz and between the frequencies from 788 megahertz to 793 megahertz.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce2061a5-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate committees of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise specifically provided, the term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce2061a6-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce, Science, and Transportation of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce2061a7-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Commerce of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce2061a8-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Assistant Secretary” means the Assistant Secretary of Commerce for Communications and Information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce2061a9-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Board” means the Board of the First Responder Network Authority established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1424/b"},"text":"section 1424(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce2061aa-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Broadcast television licensee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “broadcast television licensee” means the licensee of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce2061ab-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a full-power television station; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce2061ac-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a low-power television station that has been accorded primary status as a Class A television licensee under section 73.6001(a) of title 47, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce2061ad-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Broadcast television spectrum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “broadcast television spectrum” means the portions of the electromagnetic spectrum between the frequencies from 54 megahertz to 72 megahertz, from 76 megahertz to 88 megahertz, from 174 megahertz to 216 megahertz, and from 470 megahertz to 698 megahertz.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce2061ae-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial mobile data service","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “commercial mobile data service” means any mobile service (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s153"},"text":"section 153 of this title","children":[],"tail":") that is—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce2061af-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a data service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce2061b0-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided for profit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce2061b1-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" available to the public or such classes of eligible users as to be effectively available to a substantial portion of the public, as specified by regulation by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce2061b2-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial mobile service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “commercial mobile service” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s332"},"text":"section 332 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce2061b3-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “commercial standards” means the technical standards followed by the commercial mobile service and commercial mobile data service industries for network, device, and Internet Protocol connectivity. Such term includes standards developed by the Third Generation Partnership Project (3GPP), the Institute of Electrical and Electronics Engineers (IEEE), the Alliance for Telecommunications Industry Solutions (ATIS), the Internet Engineering Task Force (IETF), and the International Telecommunication Union (ITU).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce2061b4-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commission” means the Federal Communications Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce2061b5-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Core network","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “core network” means the core network described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1422/b/1"},"text":"section 1422(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce2061b6-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency call","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “emergency call” means any real-time communication with a public safety answering point or other emergency management or response agency, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce2061b7-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through voice, text, or video and related data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce2061b8-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonhuman-initiated automatic event alerts, such as alarms, telematics, or sensor data, which may also include real-time voice, text, or video communications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce2061b9-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing public safety broadband spectrum","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “existing public safety broadband spectrum” means the portion of the electromagnetic spectrum between the frequencies—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce2061ba-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from 763 megahertz to 768 megahertz;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce2061bb-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from 793 megahertz to 798 megahertz;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce2061bc-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/14/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from 768 megahertz to 769 megahertz; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce2061bd-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/14/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from 798 megahertz to 799 megahertz.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce2061be-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First Responder Network Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “First Responder Network Authority” means the First Responder Network Authority established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1424"},"text":"section 1424 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce2061bf-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forward auction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “forward auction” means the portion of an incentive auction of broadcast television spectrum under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1452/c"},"text":"section 1452(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce2061c0-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentive auction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “incentive auction” means a system of competitive bidding under subparagraph (G) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s309/j/8"},"text":"section 309(j)(8) of this title","children":[],"tail":", as added by section 6402."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce2061c1-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interoperability Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Interoperability Board” means the Technical Advisory Board for First Responder Interoperability established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1423"},"text":"section 1423 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce2061c2-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multichannel video programming distributor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “multichannel video programming distributor” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s522"},"text":"section 522 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce2061c3-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Narrowband spectrum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “narrowband spectrum” means the portion of the electromagnetic spectrum between the frequencies from 769 megahertz to 775 megahertz and between the frequencies from 799 megahertz to 805 megahertz.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce2061c4-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nationwide public safety broadband network","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nationwide public safety broadband network” means the nationwide, interoperable public safety broadband network described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1422"},"text":"section 1422 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce2061c5-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Next Generation 9–1–1 services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Next Generation 9–1–1 services” means an IP-based system comprised of hardware, software, data, and operational policies and procedures that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce2061c6-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/22/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides standardized interfaces from emergency call and message services to support emergency communications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce2061c7-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/22/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" processes all types of emergency calls, including voice, text, data, and multimedia information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce2061c8-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/22/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquires and integrates additional emergency call data useful to call routing and handling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce2061c9-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/22/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delivers the emergency calls, messages, and data to the appropriate public safety answering point and other appropriate emergency entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce2061ca-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/22/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supports data or video communications needs for coordinated incident response and management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce2061cb-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/22/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides broadband service to public safety answering points or other first responder entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce2061cc-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/23"},"text":null,"children":[{"tag":"num","attrib":{"value":"23"},"text":"(23)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NIST","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “NIST” means the National Institute of Standards and Technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce2061cd-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/24"},"text":null,"children":[{"tag":"num","attrib":{"value":"24"},"text":"(24)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NTIA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “NTIA” means the National Telecommunications and Information Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce2061ce-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/25"},"text":null,"children":[{"tag":"num","attrib":{"value":"25"},"text":"(25)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public safety answering point","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “public safety answering point” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s222"},"text":"section 222 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce2061cf-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/26"},"text":null,"children":[{"tag":"num","attrib":{"value":"26"},"text":"(26)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public safety entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “public safety entity” means an entity that provides public safety services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce2061d0-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/27"},"text":null,"children":[{"tag":"num","attrib":{"value":"27"},"text":"(27)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public safety services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “public safety services”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce2061d1-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1401/27/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children"