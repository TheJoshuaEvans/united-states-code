{"tag":"section","attrib":{"id":"idd2e15596-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1754"},"text":null,"children":[{"tag":"num","attrib":{"value":"1754"},"text":"§ 1754.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Digital discrimination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2e15597-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1754/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the policy of the United States that, insofar as technically and economically feasible—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2e15598-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1754/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subscribers should benefit from equal access to broadband internet access service within the service area of a provider of such service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2e15599-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1754/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “equal access”, for purposes of this section, means the equal opportunity to subscribe to an offered service that provides comparable speeds, capacities, latency, and other quality of service metrics in a given area, for comparable terms and conditions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2e1559a-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1754/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commission should take steps to ensure that all people of the United States benefit from equal access to broadband internet access service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2e1559b-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1754/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adoption of rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Commission shall adopt final rules to facilitate equal access to broadband internet access service, taking into account the issues of technical and economic feasibility presented by that objective, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2e1559c-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1754/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preventing digital discrimination of access based on income level, race, ethnicity, color, religion, or national origin; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2e1559d-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1754/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying necessary steps for the Commissions to take to eliminate discrimination described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2e1559e-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1754/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal policies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission and the Attorney General shall ensure that Federal policies promote equal access to robust broadband internet access service by prohibiting deployment discrimination based on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2e1559f-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1754/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the income level of an area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2e155a0-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1754/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the predominant race or ethnicity composition of an area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2e155a1-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1754/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other factors the Commission determines to be relevant based on the findings in the record developed from the rulemaking under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2e155a2-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1754/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Model State and local policies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall develop model policies and best practices that can be adopted by States and localities to ensure that broadband internet access service providers do not engage in digital discrimination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2e155a3-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1754/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Complaints","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall revise its public complaint process to accept complaints from consumers or other members of the public that relate to digital discrimination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2e155a4-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dF/tV/s60506"},"text":"Pub. L. 117–58, div. F, title V, § 60506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1245"},"text":"135 Stat. 1245","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
