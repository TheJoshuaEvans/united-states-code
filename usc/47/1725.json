{"tag":"section","attrib":{"id":"idd2dee43a-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725"},"text":null,"children":[{"tag":"num","attrib":{"value":"1725"},"text":"§ 1725.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy research, data collection, analysis and modeling, evaluation, and dissemination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2dee43b-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2dee43c-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date on which the Assistant Secretary begins awarding grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1723/d/1"},"text":"section 1723(d)(1) of this title","children":[],"tail":", and annually thereafter, the Assistant Secretary shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2dee43d-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the appropriate committees of Congress a report that documents, for the year covered by the report—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd2dee43e-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the findings of each evaluation conducted under subparagraph (B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2dee43f-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a list of each grant awarded under each covered program, which shall include—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idd2dee440-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/a/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of each such grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd2dee441-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/a/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient of each such grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd2dee442-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/a/1/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purpose for which each such grant was awarded;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2dee443-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any deobligation, termination, or modification of a grant awarded under the covered programs, which shall include a description of the subsequent usage of any funds to which such an action applies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2dee444-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each challenge made by an applicant for, or a recipient of, a grant under the covered programs and the outcome of each such challenge; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2dee445-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct evaluations of the activities carried out under the covered programs, which shall include an evaluation of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd2dee446-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" whether eligible States to which grants are awarded under the program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1723"},"text":"section 1723 of this title","children":[],"tail":" are—"}],"tail":null},{"tag":"subclause","attrib":{"id":"idd2dee447-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/a/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" abiding by the assurances made by those States under subsection (e) of that section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd2dee448-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/a/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meeting, or have met, the stated goals of the Digital Equity Plans developed by the States under subsection (c) of that section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd2dee449-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/a/1/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfying the requirements imposed by the Assistant Secretary on those States under subsection (g) of that section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd2dee44a-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/a/1/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in compliance with any other rules, requirements, or regulations promulgated by the Assistant Secretary in implementing that program; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2dee44b-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" whether entities to which grants are awarded under the program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1724"},"text":"section 1724 of this title","children":[],"tail":" are—"}],"tail":null},{"tag":"subclause","attrib":{"id":"idd2dee44c-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/a/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" abiding by the assurances made by those entities under subsection (f) of that section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd2dee44d-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/a/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meeting, or have met, the stated goals of those entities with respect to the use of the grant amounts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd2dee44e-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/a/1/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfying the requirements imposed by the Assistant Secretary on those States under subsection (h) of that section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd2dee44f-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/a/1/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in compliance with any other rules, requirements, or regulations promulgated by the Assistant Secretary in implementing that program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2dee450-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary shall make each report submitted under paragraph (1)(A) publicly available in an online format that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2dee451-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitates access and ease of use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2dee452-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is searchable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2dee453-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is accessible—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd2dee454-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to individuals with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2dee455-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in languages other than English.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2dee456-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to contract and enter into other arrangements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary may award grants and enter into contracts, cooperative agreements, and other arrangements with Federal agencies, public and private organizations, and other entities with expertise that the Assistant Secretary determines appropriate in order to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2dee457-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the impact and efficacy of activities supported by grants awarded under the covered programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2dee458-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop, catalog, disseminate, and promote the exchange of best practices, both with respect to and independent of the covered programs, in order to achieve digital equity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2dee459-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation and public engagement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), and to further the objectives described in paragraphs (1) and (2) of subsection (b), the Assistant Secretary shall conduct ongoing collaboration and consult with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2dee45a-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2dee45b-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Housing and Urban Development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2dee45c-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2dee45d-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Labor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2dee45e-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Health and Human Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2dee45f-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Veterans Affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2dee460-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2dee461-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Communications Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2dee462-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Trade Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2dee463-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Institute of Museum and Library Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2dee464-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Small Business Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2dee465-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/c/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Co-Chair of the Appalachian Regional Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2dee466-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/c/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State agencies and governors of States (or equivalent officials);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2dee467-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/c/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entities serving as administering entities for States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1723/b"},"text":"section 1723(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2dee468-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/c/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national, State, tribal, and local organizations that provide digital inclusion, digital equity, or digital literacy services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2dee469-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/c/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" researchers, academics, and philanthropic organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2dee46a-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/c/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other agencies, organizations (including international organizations), entities (including entities with expertise in the fields of data collection, analysis and modeling, and evaluation), and community stakeholders, as determined appropriate by the Assistant Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2dee46b-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical support and assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall provide technical support and assistance, assistance to entities to prepare the applications of those entities with respect to grants awarded under the covered programs, and other resources, to the extent practicable, to ensure consistency in data reporting and to meet the objectives of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2dee46c-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1725/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out this section, which shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2dee46d-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dF/tIII/s60306"},"text":"Pub. L. 117–58, div. F, title III, § 60306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1228"},"text":"135 Stat. 1228","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
