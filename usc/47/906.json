{"tag":"section","attrib":{"id":"idce0ade92-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906"},"text":null,"children":[{"tag":"num","attrib":{"value":"906"},"text":"§ 906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wireless supply chain innovation and multilateral security","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idce0ade93-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Communications technology security funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce0ade94-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public Wireless Supply Chain Innovation Fund","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce0ade95-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idce0ade96-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a trust fund to be known as the “Public Wireless Supply Chain Innovation Fund” (referred to in this paragraph as the “Innovation Fund”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce0ade97-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idce0ade98-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated to the Innovation Fund shall remain available through the end of the tenth fiscal year beginning after the date on which funds are appropriated to the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idce0ade99-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remainder to Treasury","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amounts remaining in the Innovation Fund after the end of the tenth fiscal year beginning after the date of appropriation shall be deposited in the general fund of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce0ade9a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Fund","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idce0ade9b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated to the Innovation Fund shall be available to the Secretary, acting through the NTIA Administrator, to make grants on a competitive basis under this paragraph in such amounts as the Secretary, acting through the NTIA Administrator, determines appropriate, subject to clause (ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce0ade9c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on grant amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of a grant awarded under this paragraph to a recipient for a specific research focus area may not exceed $50,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce0ade9d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of Fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the NTIA Administrator, in consultation with the Commission, the Under Secretary of Commerce for Standards and Technology, the Secretary of Homeland Security, the Secretary of Defense, and the Director of the Intelligence Advanced Research Projects Activity of the Office of the Director of National Intelligence, shall establish criteria for grants awarded under this paragraph, by the NTIA Administrator and administer the Innovation Fund, to support the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idce0ade9e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promoting and deploying technology, including software, hardware, and microprocessing technology, that will enhance competitiveness in the fifth-generation (commonly known as “5G”) and successor wireless technology supply chains that use open and interoperable interface radio access networks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce0ade9f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Accelerating commercial deployments of open interface standards-based compatible, interoperable equipment, such as equipment developed pursuant to the standards set forth by organizations such as the O-RAN Alliance, the Telecom Infra Project, 3GPP, the Open-RAN Software Community, or any successor organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce0adea0-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promoting and deploying compatibility of new 5G equipment with future open standards-based, interoperable equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce0adea1-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Managing integration of multi-vendor network environments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce0adea2-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identifying objective criteria to define equipment as compliant with open standards for multi-vendor network equipment interoperability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce0adea3-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promoting and deploying security features enhancing the integrity and availability of equipment in multi-vendor networks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce0adea4-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/C/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promoting and deploying network function virtualization to facilitate multi-vendor interoperability and a more diverse vendor market.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce0adea5-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonduplication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the greatest extent practicable, the Secretary, acting through the NTIA Administrator, shall ensure that any research funded by a grant awarded under this paragraph avoids duplication of other Federal or private sector research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce0adea6-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after the date on which funds are appropriated to the Innovation Fund, the Secretary, acting through the NTIA Administrator, shall begin awarding grants under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce0adea7-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal advisory body","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idce0adea8-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the NTIA Administrator, and in consultation with the Under Secretary of Commerce for Standards and Technology, shall establish a Federal advisory committee, in accordance with the Federal Advisory Committee Act (5 U.S.C. App.),","children":[{"tag":"ref","attrib":{"idref":"fn002055"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002055"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" composed of government and private sector experts, to advise the Secretary and the NTIA Administrator on the administration of the Innovation Fund."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce0adea9-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The advisory committee established under clause (i) shall be composed of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idce0adeaa-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/F/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" representatives from—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idce0adeab-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/F/ii/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idce0adeac-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/F/ii/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idce0adead-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/F/ii/I/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Intelligence Advanced Research Projects Activity of the Office of the Director of National Intelligence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idce0adeae-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/F/ii/I/dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"dd"},"text":"(dd)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Institute of Standards and Technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idce0adeaf-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/F/ii/I/ee"},"text":null,"children":[{"tag":"num","attrib":{"value":"ee"},"text":"(ee)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idce0adeb0-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/F/ii/I/ff"},"text":null,"children":[{"tag":"num","attrib":{"value":"ff"},"text":"(ff)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Science Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idce0adeb1-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/F/ii/I/gg"},"text":null,"children":[{"tag":"num","attrib":{"value":"gg"},"text":"(gg)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Homeland Security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idce0adeb2-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/F/ii/I/hh"},"text":null,"children":[{"tag":"num","attrib":{"value":"hh"},"text":"(hh)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Telecommunications and Information Administration; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idce0adeb3-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/F/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other representatives from the private and public sectors, at the discretion of the NTIA Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce0adeb4-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The advisory committee established under clause (i) shall advise the Secretary and the NTIA Administrator on technology developments to help inform—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idce0adeb5-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/F/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the strategic direction of the Innovation Fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idce0adeb6-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/F/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts of the Federal Government to promote a more secure, diverse, sustainable, and competitive supply chain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce0adeb7-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idce0adeb8-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":", the Secretary, acting through the NTIA Administrator, shall submit to the relevant committees of Congress a report with—"}],"tail":null},{"tag":"subclause","attrib":{"id":"idce0adeb9-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/G/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional recommendations on promoting the competitiveness and sustainability of trusted suppliers in the wireless supply chain; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idce0adeba-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/G/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any additional authorities needed to facilitate the timely adoption of open standards-based equipment, including authority to provide loans, loan guarantees, and other forms of credit extension that would maximize the use of funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce0adebb-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each fiscal year for which amounts in the Innovation Fund are available under this paragraph, the Secretary, acting through the NTIA Administrator, shall submit to Congress a report that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idce0adebc-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/G/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes how, and to whom (including whether recipients are majority owned and controlled by minority individuals and majority owned and controlled by women), amounts in the Innovation Fund have been deployed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idce0adebd-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/G/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" details the progress of the Secretary and the NTIA Administrator in meeting the objectives described in subparagraph (C); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idce0adebe-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/1/G/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any additional information that the Secretary and the NTIA Administrator determine appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0adebf-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multilateral Telecommunications Security Fund","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce0adec0-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Fund","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idce0adec1-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a trust fund to be known as the “Multilateral Telecommunications Security Fund”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce0adec2-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated to the Multilateral Telecommunications Security Fund shall be available to the Secretary of State to make expenditures under this paragraph in such amounts as the Secretary of State determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce0adec3-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idce0adec4-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/2/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts appropriated to the Multilateral Telecommunications Security Fund—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idce0adec5-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/2/A/iii/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall remain available through the end of the tenth fiscal year beginning after the date of appropriation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idce0adec6-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/2/A/iii/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may only be allocated upon the Secretary of State reaching an arrangement or agreement with foreign government partners to participate in the common funding mechanism described in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idce0adec7-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/2/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remainder to Treasury","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amounts remaining in the Multilateral Telecommunications Security Fund after the end of the tenth fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":" shall be deposited in the general fund of the Treasury."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce0adec8-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of Fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State, in consultation with the NTIA Administrator, the Secretary of Homeland Security, the Secretary of Defense, the Secretary of the Treasury, the Director of National Intelligence, and the Commission, is authorized to establish a common funding mechanism, in coordination with foreign partners, that uses amounts from the Multilateral Telecommunications Security Fund to support the development and adoption of secure and trusted telecommunications technologies. In creating and sustaining a common funding mechanism, the Secretary of State should leverage United States funding in order to secure commitments and contributions from trusted foreign partners such as the United Kingdom, Canada, Australia, New Zealand, and Japan, and should prioritize the following objectives:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idce0adec9-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advancing research and development of secure and trusted communications technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce0adeca-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Strengthening supply chains.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce0adecb-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promoting the use of trusted vendors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce0adecc-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notifications to be provided by the Fund","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idce0adecd-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 15 days prior to the Fund making a financial commitment associated with the provision of expenditures under subparagraph (A)(ii) in an amount in excess of $1,000,000, the Secretary of State shall submit to the appropriate congressional committees a report in writing that contains the information required by clause (ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce0adece-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information required by this clause includes—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idce0adecf-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/2/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of each such expenditure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idce0aded0-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/2/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of the recipient or beneficiary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idce0aded1-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/2/C/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the project or activity and the purpose to be achieved of an expenditure by the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce0aded2-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arrangements or agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall notify the appropriate congressional committees not later than 30 days after entering into a new bilateral or multilateral arrangement or agreement described in subparagraph (A)(iii)(I)(bb).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce0aded3-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subparagraph, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idce0aded4-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/2/C/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idce0aded5-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/2/C/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idce0aded6-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/2/C/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idce0aded7-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/a/2/C/iv/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce0aded8-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promoting United States leadership in international organizations and communications standards-setting bodies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce0aded9-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State, the Secretary of Commerce, and the Chairman of the Commission, or their designees, shall consider how to enhance representation of the United States at international forums that set standards for 5G networks and for future generations of wireless communications networks, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce0adeda-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the International Telecommunication Union (commonly known as “ITU”);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce0adedb-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the International Organization for Standardization (commonly known as “ISO”);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce0adedc-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Inter-American Telecommunication Commission (commonly known as “CITEL”); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce0adedd-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the voluntary standards organizations that develop protocols for wireless devices and other equipment, such as the 3GPP and the Institute of Electrical and Electronics Engineers (commonly known as “IEEE”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0adede-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State, the Secretary of Commerce, and the Chairman of the Commission shall jointly submit to the relevant committees of Congress an annual report on the progress made under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce0adedf-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce0adee0-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “3GPP” means the Third Generation Partnership Project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0adee1-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “5G network” means a radio network as described by 3GPP Release 15 or higher.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0adee2-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Commission” means the Federal Communications Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0adee3-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “NTIA Administrator” means the Assistant Secretary of Commerce for Communications and Information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0adee4-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Open-RAN” means the Open Radio Access Network approach to standardization adopted by the O-RAN Alliance, Telecom Infra Project, or 3GPP, or any similar set of open standards for multi-vendor network equipment interoperability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0adee5-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “relevant committees of Congress” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce0adee6-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Select Committee on Intelligence of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce0adee7-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce0adee8-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/c/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Homeland Security and Governmental Affairs of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce0adee9-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/c/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce0adeea-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/c/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce, Science, and Transportation of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce0adeeb-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/c/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce0adeec-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/c/6/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Permanent Select Committee on Intelligence of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce0adeed-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/c/6/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce0adeee-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/c/6/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Homeland Security of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce0adeef-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/c/6/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce0adef0-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/c/6/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Commerce of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce0adef1-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/c/6/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0adef2-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s906/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idce0adef3-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dH/tXCII/s9202"},"text":"Pub. L. 116–283, div. H, title XCII, § 9202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4788"},"text":"134 Stat. 4788","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/