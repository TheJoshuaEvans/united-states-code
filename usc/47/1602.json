{"tag":"section","attrib":{"id":"idd2d56e3e-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1602"},"text":null,"children":[{"tag":"num","attrib":{"value":"1602"},"text":"§ 1602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on use of certain Federal subsidies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2d56e3f-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1602/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2d56e40-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1602/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Federal subsidy that is made available through a program administered by the Commission and that provides funds to be used for the capital expenditures necessary for the provision of advanced communications service may not be used to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2d56e41-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1602/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase, rent, lease, or otherwise obtain any covered communications equipment or service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2d56e42-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1602/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain any covered communications equipment or service previously purchased, rented, leased, or otherwise obtained.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d56e43-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1602/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall apply with respect to any covered communications equipment or service beginning on the date that is 60 days after the date on which the Commission places such equipment or service on the list required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1601/a"},"text":"section 1601(a) of this title","children":[],"tail":". In the case of any covered communications equipment or service that is on the initial list published under such section, such equipment or service shall be treated as being placed on the list on the date on which such list is published."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2d56e44-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1602/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Completion of proceeding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2020-03-12"},"text":"March 12, 2020","children":[],"tail":", the Commission shall adopt a Report and Order to implement subsection (a). If the Commission has, before "},{"tag":"date","attrib":{"date":"2020-03-12"},"text":"March 12, 2020","children":[],"tail":", taken action that in whole or in part implements subsection (a), the Commission is not required to revisit such action, but only to the extent such action is consistent with this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2d56e45-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/124/s3"},"text":"Pub. L. 116–124, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-12"},"text":"Mar. 12, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/159"},"text":"134 Stat. 159","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
