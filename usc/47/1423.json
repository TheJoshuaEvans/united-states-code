{"tag":"section","attrib":{"id":"idce206219-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423"},"text":null,"children":[{"tag":"num","attrib":{"value":"1423"},"text":"§ 1423.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public safety Interoperability Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idce20621a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Commission an advisory board to be known as the “Technical Advisory Board for First Responder Interoperability”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce20621b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce20621c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce20621d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"2012-02-22"},"text":"February 22, 2012","children":[],"tail":", the Chairman of the Commission shall appoint 14 voting members to the Interoperability Board, of which—"}],"tail":null},{"tag":"clause","attrib":{"id":"idce20621e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 4 members shall be representatives of wireless providers, of which—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idce20621f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/b/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 members shall be representatives of national wireless providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idce206220-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/b/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall be a representative of regional wireless providers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idce206221-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/b/1/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall be a representative of rural wireless providers;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce206222-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 members shall be representatives of equipment manufacturers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce206223-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 4 members shall be representatives of public safety entities, of which—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idce206224-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/b/1/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 1 member shall be a representative of management level employees of public safety entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idce206225-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/b/1/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 1 member shall be a representative of employees of public safety entities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce206226-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 members shall be representatives of State and local governments, chosen to reflect geographic and population density differences across the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce206227-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/b/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all members shall have specific expertise necessary to developing technical requirements under this section, such as technical expertise, public safety communications expertise, and commercial network experience.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce206228-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-voting member","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall appoint 1 non-voting member to the Interoperability Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce206229-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of appointment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce20622a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), members of the Interoperability Board shall be appointed for the life of the Interoperability Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce20622b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal for cause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Interoperability Board may be removed for cause upon the determination of the Chairman of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce20622c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vacancy in the Interoperability Board shall not affect the powers of the Interoperability Board, and shall be filled in the same manner as the original appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce20622d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson and Vice Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Interoperability Board shall select a Chairperson and Vice Chairperson from among the members of the Interoperability Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce20622e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the members of the Interoperability Board shall constitute a quorum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce20622f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of the Interoperability Board","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce206230-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of technical requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2012-02-22"},"text":"February 22, 2012","children":[],"tail":", the Interoperability Board, in consultation with the NTIA, NIST, and the Office of Emergency Communications of the Department of Homeland Security, shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce206231-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop recommended minimum technical requirements to ensure a nationwide level of interoperability for the nationwide public safety broadband network; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce206232-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Commission for review in accordance with paragraph (3) recommended minimum technical requirements described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce206233-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing recommended minimum technical requirements under paragraph (1), the Interoperability Board shall base the recommended minimum technical requirements on the commercial standards for Long Term Evolution (LTE) service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce206234-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of recommendations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce206235-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the date on which the Interoperability Board submits recommended minimum technical requirements under paragraph (1)(B), the Commission shall approve the recommendations, with any revisions it deems necessary, and transmit such recommendations to the First Responder Network Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce206236-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any actions taken under subparagraph (A) shall not be reviewable as a final agency action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce206237-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Interoperability Board shall be allowed travel expenses, including per diem in lieu of subsistence, at rates authorized for employees of agencies under subchapter I of chapter 57 of title 5, while away from their homes or regular places of business in the performance of services for the Interoperability Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce206238-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 shall not apply to the Interoperability Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce206239-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1423/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Interoperability Board shall terminate 15 days after the date on which the Commission transmits the recommendations to the First Responder Network Authority under subsection (c)(3)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idce20623a-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/96/tVI/s6203"},"text":"Pub. L. 112–96, title VI, § 6203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/207"},"text":"126 Stat. 207","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/301"},"text":"Pub. L. 117–286, § 4(a)(301)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4339"},"text":"136 Stat. 4339","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idce20623b-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idce20623c-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idce20623d-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5” for “FACA” in heading and “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 U.S.C. App.)” in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
