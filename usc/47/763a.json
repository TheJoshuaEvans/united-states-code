{"tag":"section","attrib":{"id":"idd2b192ab-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s763a"},"text":null,"children":[{"tag":"num","attrib":{"value":"763a"},"text":"§ 763a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific criteria for INTELSAT","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In securing the privatizations required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s763"},"text":"section 763 of this title","children":[],"tail":", the following additional criteria with respect to INTELSAT privatization shall be applied as licensing criteria for purposes of part A:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2b192ac-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s763a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002049"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002049"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No par. (2) has been enacted."}],"tail":" "},{"tag":"inline","attrib":{},"text":"Technical coordination under intelsat agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Technical coordination shall not be used to impair competition or competitors, and shall be conducted under International Telecommunication Union procedures and not under Article XIV(d) of the INTELSAT Agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2b192ad-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/624/tVI/s622"},"text":"Pub. L. 87–624, title VI, § 622","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/180/s3"},"text":"Pub. L. 106–180, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-03-17"},"text":"Mar. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/53"},"text":"114 Stat. 53","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
