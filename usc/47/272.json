{"tag":"section","attrib":{"id":"idcdb062c9-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272"},"text":null,"children":[{"tag":"num","attrib":{"value":"272"},"text":"§ 272.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate affiliate; safeguards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcdb062ca-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate affiliate required for competitive activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcdb062cb-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Bell operating company (including any affiliate) which is a local exchange carrier that is subject to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s251/c"},"text":"section 251(c) of this title","children":[],"tail":" may not provide any service described in paragraph (2) unless it provides that service through one or more affiliates that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcdb062cc-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are separate from any operating company entity that is subject to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s251/c"},"text":"section 251(c) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcdb062cd-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the requirements of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdb062ce-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services for which a separate affiliate is required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The services for which a separate affiliate is required by paragraph (1) are:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcdb2abbf-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Manufacturing activities (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s273/h"},"text":"section 273(h) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcdb2abc0-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Origination of interLATA telecommunications services, other than—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcdb2abc1-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incidental interLATA services described in paragraphs (1), (2), (3), (5), and (6) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s271/g"},"text":"section 271(g) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcdb2abc2-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" out-of-region services described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s271/b/2"},"text":"section 271(b)(2) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcdb2abc3-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" previously authorized activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s271/f"},"text":"section 271(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcdb2abc4-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" InterLATA information services, other than electronic publishing (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s274/h"},"text":"section 274(h) of this title","children":[],"tail":") and alarm monitoring services (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s275/e"},"text":"section 275(e) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdb2abc5-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Structural and transactional requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The separate affiliate required by this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcdb2abc6-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall operate independently from the Bell operating company;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdb2abc7-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall maintain books, records, and accounts in the manner prescribed by the Commission which shall be separate from the books, records, and accounts maintained by the Bell operating company of which it is an affiliate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdb2abc8-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have separate officers, directors, and employees from the Bell operating company of which it is an affiliate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdb2abc9-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not obtain credit under any arrangement that would permit a creditor, upon default, to have recourse to the assets of the Bell operating company; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdb2abca-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall conduct all transactions with the Bell operating company of which it is an affiliate on an arm’s length basis with any such transactions reduced to writing and available for public inspection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdb2abcb-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondiscrimination safeguards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In its dealings with its affiliate described in subsection (a), a Bell operating company—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcdb2abcc-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not discriminate between that company or affiliate and any other entity in the provision or procurement of goods, services, facilities, and information, or in the establishment of standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdb2abcd-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall account for all transactions with an affiliate described in subsection (a) in accordance with accounting principles designated or approved by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdb2abce-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biennial audit","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcdb2abcf-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A company required to operate a separate affiliate under this section shall obtain and pay for a joint Federal/State audit every 2 years conducted by an independent auditor to determine whether such company has complied with this section and the regulations promulgated under this section, and particularly whether such company has complied with the separate accounting requirements under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdb2abd0-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Results submitted to Commission; State commissions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The auditor described in paragraph (1) shall submit the results of the audit to the Commission and to the State commission of each State in which the company audited provides service, which shall make such results available for public inspection. Any party may submit comments on the final audit report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdb2abd1-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to documents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of conducting audits and reviews under this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcdb2abd2-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the independent auditor, the Commission, and the State commission shall have access to the financial accounts and records of each company and of its affiliates necessary to verify transactions conducted with that company that are relevant to the specific activities permitted under this section and that are necessary for the regulation of rates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcdb2abd3-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commission and the State commission shall have access to the working papers and supporting materials of any auditor who performs an audit under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcdb2abd4-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State commission shall implement appropriate procedures to ensure the protection of any proprietary information submitted to it under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdb2abd5-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fulfillment of certain requests","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Bell operating company and an affiliate that is subject to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s251/c"},"text":"section 251(c) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcdb2abd6-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall fulfill any requests from an unaffiliated entity for telephone exchange service and exchange access within a period no longer than the period in which it provides such telephone exchange service and exchange access to itself or to its affiliates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdb2abd7-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not provide any facilities, services, or information concerning its provision of exchange access to the affiliate described in subsection (a) unless such facilities, services, or information are made available to other providers of interLATA services in that market on the same terms and conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdb2abd8-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall charge the affiliate described in subsection (a), or impute to itself (if using the access for its provision of its own services), an amount for access to its telephone exchange service and exchange access that is no less than the amount charged to any unaffiliated interexchange carriers for such service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdb2abd9-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may provide any interLATA or intraLATA facilities or services to its interLATA affiliate if such services or facilities are made available to all carriers at the same rates and on the same terms and conditions, and so long as the costs are appropriately allocated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdb2abda-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcdb2abdb-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manufacturing and long distance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section (other than subsection (e)) shall cease to apply with respect to the manufacturing activities or the interLATA telecommunications services of a Bell operating company 3 years after the date such Bell operating company or any Bell operating company affiliate is authorized to provide interLATA telecommunications services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s271/d"},"text":"section 271(d) of this title","children":[],"tail":", unless the Commission extends such 3-year period by rule or order."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdb2abdc-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" InterLATA information services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section (other than subsection (e)) shall cease to apply with respect to the interLATA information services of a Bell operating company 4 years after ","children":[{"tag":"date","attrib":{"date":"1996-02-08"},"text":"February 8, 1996","children":[],"tail":", unless the Commission extends such 4-year period by rule or order."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdb2abdd-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of existing authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be construed to limit the authority of the Commission under any other section of this chapter to prescribe safeguards consistent with the public interest, convenience, and necessity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdb2abde-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint marketing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcdb2abdf-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affiliate sales of telephone exchange services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Bell operating company affiliate required by this section may not market or sell telephone exchange services provided by the Bell operating company unless that company permits other entities offering the same or similar service to market and sell its telephone exchange services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdb2abe0-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bell operating company sales of affiliate services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Bell operating company may not market or sell interLATA service provided by an affiliate required by this section within any of its in-region States until such company is authorized to provide interLATA services in such State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s271/d"},"text":"section 271(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdb2abe1-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The joint marketing and sale of services permitted under this subsection shall not be considered to violate the nondiscrimination provisions of subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdb2abe2-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s272/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to any activity in which a Bell operating company is engaged on ","children":[{"tag":"date","attrib":{"date":"1996-02-08"},"text":"February 8, 1996","children":[],"tail":", such company shall have one year from "},{"tag":"date","attrib":{"date":"1996-02-08"},"text":"February 8, 1996","children":[],"tail":", to comply with the requirements of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcdb2abe3-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title II, § 272, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/104/tI/s151/a"},"text":"Pub. L. 104–104, title I, § 151(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-08"},"text":"Feb. 8, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/92"},"text":"110 Stat. 92","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcdb2abe4-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcdb2abe5-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcdb2abe6-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (f)(3), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"act June 19, 1934, ch. 652","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1064"},"text":"48 Stat. 1064","children":[],"tail":", known as the Communications Act of 1934, which is classified principally to this chapter. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s609"},"text":"section 609 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
