{"tag":"section","attrib":{"id":"idce1ba736-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1303"},"text":null,"children":[{"tag":"num","attrib":{"value":"1303"},"text":"§ 1303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improving Federal data on broadband","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idce1ba737-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce1ba738-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International comparison","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce1ba739-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of its report under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s163"},"text":"section 163 of this title","children":[],"tail":", the Federal Communications Commission shall include information comparing the extent of broadband service capability (including data transmission speeds and price for broadband service capability) in a total of 75 communities in at least 25 countries abroad for each of the data rate benchmarks for broadband service utilized by the Commission to reflect different speed tiers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce1ba73a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall choose communities for the comparison under this subsection in a manner that will offer, to the extent possible, communities of a population size, population density, topography, and demographic profile that are comparable to the population size, population density, topography, and demographic profile of various communities within the United States. The Commission shall include in the comparison under this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce1ba73b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1303/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a geographically diverse selection of countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce1ba73c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1303/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communities including the capital cities of such countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce1ba73d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1303/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Similarities and differences","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall identify relevant similarities and differences in each community, including their market structures, the number of competitors, the number of facilities-based providers, the types of technologies deployed by such providers, the applications and services those technologies enable, the regulatory model under which broadband service capability is provided, the types of applications and services used, business and residential use of such services, and other media available to consumers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce1ba73e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer survey of broadband service capability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce1ba73f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1303/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of evaluating, on a statistically significant basis, the national characteristics of the use of broadband service capability, the Commission shall conduct and make public periodic surveys of consumers in urban, suburban, and rural areas in the large business, small business, and residential consumer markets to determine—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce1ba740-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1303/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of technology used to provide the broadband service capability to which consumers subscribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce1ba741-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1303/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts consumers pay per month for such capability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce1ba742-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1303/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual data transmission speeds of such capability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce1ba743-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1303/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of applications and services consumers most frequently use in conjunction with such capability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce1ba744-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1303/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for consumers who have declined to subscribe to broadband service capability, the reasons given by such consumers for declining such capability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce1ba745-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1303/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other sources of broadband service capability which consumers regularly use or on which they rely; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce1ba746-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1303/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information the Commission deems appropriate for such purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce1ba747-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1303/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall make publicly available the results of surveys conducted under this subsection at least once per year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce1ba748-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1303/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improving Census data on broadband","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce, in consultation with the Federal Communications Commission, shall expand the American Community Survey conducted by the Bureau of the Census to elicit information for residential households, including those located on native lands, to determine whether persons at such households own or use a computer at that address, whether persons at that address subscribe to Internet service and, if so, whether such persons subscribe to dial-up or broadband Internet service at that address.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce1ba749-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1303/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proprietary information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall reduce or remove any obligation the Commission has to protect proprietary information, nor shall this chapter be construed to compel the Commission to make publicly available any proprietary information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idce1ba74a-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/385/tI/s103"},"text":"Pub. L. 110–385, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4096"},"text":"122 Stat. 4096","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dP/tIV/s402/c"},"text":"Pub. L. 115–141, div. P, title IV, § 402(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1089"},"text":"132 Stat. 1089","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idce1ba74b-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idce1ba74c-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idce1ba74d-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/385/s103"},"text":"section 103 of Pub. L. 110–385","children":[],"tail":". Subsec. (a) of "},{"tag":"ref","attrib":{"href":"/us/pl/110/385/s103"},"text":"section 103 of Pub. L. 110–385","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s1302"},"text":"section 1302 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idce1ba74e-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “its report under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s163"},"text":"section 163 of this title","children":[],"tail":", the Federal Communications Commission” for “the assessment and report required by "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s1302"},"text":"section 1302 of this title","children":[],"tail":", the Federal Communications Commission”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
