{"tag":"section","attrib":{"id":"idce278e71-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1503"},"text":null,"children":[{"tag":"num","attrib":{"value":"1503"},"text":"§ 1503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Millimeter wave spectrum","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idce278e72-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FCC proceeding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2018-03-23"},"text":"March 23, 2018","children":[],"tail":", the Commission shall publish a notice of proposed rulemaking to consider service rules to authorize mobile or fixed terrestrial wireless operations, including for advanced mobile service operations, in the radio frequency band between 42000 and 42500 megahertz."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce278e73-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting a rulemaking under subsection (a), the Commission shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce278e74-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consider how the band described in subsection (a) may be used to provide commercial wireless broadband service, including whether—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce278e75-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1503/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such spectrum may be best used for licensed or unlicensed services, or some combination thereof; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce278e76-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1503/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to permit additional licensed operations in such band on a shared basis; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce278e77-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include technical characteristics under which the band described in subsection (a) may be employed for mobile or fixed terrestrial wireless operations, including any appropriate coexistence requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce278e78-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spectrum made available on and after ","children":[{"tag":"date","attrib":{"date":"2016-02-11"},"text":"February 11, 2016","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any spectrum that has been made available for licensed or unlicensed use on or after ","children":[{"tag":"date","attrib":{"date":"2016-02-11"},"text":"February 11, 2016","children":[],"tail":", and that otherwise satisfies the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s1502"},"text":"section 1502 of this title","children":[],"tail":" may be counted towards the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s1502/a"},"text":"section 1502(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idce278e79-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dP/tVI/s604"},"text":"Pub. L. 115–141, div. P, title VI, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1099"},"text":"132 Stat. 1099","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
