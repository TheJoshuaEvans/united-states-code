{"tag":"section","attrib":{"id":"idcd809f8f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s34"},"text":null,"children":[{"tag":"num","attrib":{"value":"34"},"text":"§ 34.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licenses for landing or operating cables connecting United States with foreign country; necessity for","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No person shall land or operate in the United States any submarine cable directly or indirectly connecting the United States with any foreign country, or connecting one portion of the United States with any other portion thereof, unless a written license to land or operate such cable has been issued by the President of the United States. The conditions of sections 34 to 39 of this title shall not apply to cables, all of which, including both terminals, lie wholly within the continental United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcd809f90-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-05-27/ch12/s1"},"text":"May 27, 1921, ch. 12, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/8"},"text":"42 Stat. 8","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcd809f91-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcd809f92-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcd809f93-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Submarine Cable Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcd809f94-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idcd809f95-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1921-05-27/ch12"},"text":"Act May 27, 1921, ch. 12","children":[],"tail":", which enacted sections 34 to 39 of this title, is popularly known as the Cable Landing Licensing Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idcd809f96-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"idcd809f97-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions, vested in President by sections 34 to 39 of this title, to Federal Communications Commission, see section 5(a) of Ex. Ord. No. 10530, eff. ","children":[{"tag":"date","attrib":{"date":"1954-05-10"},"text":"May 10, 1954","children":[],"tail":", 19 F.R. 2709, set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of Title 3","children":[],"tail":", The President."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
