{"tag":"section","attrib":{"id":"idce2061ea-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1404"},"text":null,"children":[{"tag":"num","attrib":{"value":"1404"},"text":"§ 1404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National security restrictions on use of funds and auction participation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idce2061eb-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1404/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No funds made available by subchapter II or III may be used to make payments under a contract to a person described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce2061ec-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1404/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Auction participation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person described in subsection (c) may not participate in a system of competitive bidding under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s309/j"},"text":"section 309(j) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idce2061ed-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1404/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is required to be conducted by this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce2061ee-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1404/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which any spectrum usage rights for which licenses are being assigned were made available under clause (i) of subparagraph (G) of paragraph (8) of such section, as added by section 6402.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce2061ef-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1404/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person described","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person described in this subsection is a person who has been, for reasons of national security, barred by any agency of the Federal Government from bidding on a contract, participating in an auction, or receiving a grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idce2061f0-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/96/tVI/s6004"},"text":"Pub. L. 112–96, title VI, § 6004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/205"},"text":"126 Stat. 205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idce2061f1-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idce2061f2-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idce2061f3-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 6402, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/96/s6402"},"text":"section 6402 of Pub. L. 112–96","children":[],"tail":", which amended "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s309"},"text":"section 309 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
