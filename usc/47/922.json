{"tag":"section","attrib":{"id":"idce0d4f0b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s922"},"text":null,"children":[{"tag":"num","attrib":{"value":"922"},"text":"§ 922.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National spectrum allocation planning","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary and the Chairman of the Commission shall meet, at least biannually, to conduct joint spectrum planning with respect to the following issues:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce0d4f0c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s922/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which licenses for spectrum use can be issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s309/j"},"text":"section 309(j) of this title","children":[],"tail":" to increase Federal revenues;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0d4f0d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s922/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the future spectrum requirements for public and private uses, including State and local government public safety agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0d4f0e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s922/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the spectrum allocation actions necessary to accommodate those uses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0d4f0f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s922/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions necessary to promote the efficient use of the spectrum, including spectrum management techniques to promote increased shared use of the spectrum that does not cause harmful interference as a means of increasing commercial access.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idce0d4f10-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/538/tI/s112"},"text":"Pub. L. 102–538, title I, § 112","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tVI/s6001/a/3"},"text":"Pub. L. 103–66, title VI, § 6001(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/380"},"text":"107 Stat. 380","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
