{"tag":"section","attrib":{"id":"idd2a0f077-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s558"},"text":null,"children":[{"tag":"num","attrib":{"value":"558"},"text":"§ 558.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal and civil liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be deemed to affect the criminal or civil liability of cable programmers or cable operators pursuant to the Federal, State, or local law of libel, slander, obscenity, incitement, invasions of privacy, false or misleading advertising, or other similar laws, except that cable operators shall not incur any such liability for any program carried on any channel designated for public, educational, governmental use or on any other channel obtained under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s532"},"text":"section 532 of this title","children":[],"tail":" or under similar arrangements unless the program involves obscene material."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd2a0f078-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title VI, § 638, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/549/s2"},"text":"Pub. L. 98–549, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2801"},"text":"98 Stat. 2801","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/385/s10/d"},"text":"Pub. L. 102–385, § 10(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-05"},"text":"Oct. 5, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1486"},"text":"106 Stat. 1486","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","att