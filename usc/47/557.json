{"tag":"section","attrib":{"id":"idcdf3104e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s557"},"text":null,"children":[{"tag":"num","attrib":{"value":"557"},"text":"§ 557.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing franchises","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcdf3104f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s557/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The provisions of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcdf31050-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s557/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any franchise in effect on the effective date of this subchapter, including any such provisions which relate to the designation, use, or support for the use of channel capacity for public, educational, or governmental use, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdf31051-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s557/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any law of any State (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s153"},"text":"section 153 of this title","children":[],"tail":") in effect on "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"October 30, 1984","children":[],"tail":", or any regulation promulgated pursuant to such law, which relates to such designation, use or support of such channel capacity,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall remain in effect, subject to the express provisions of this subchapter, and for not longer than the then current remaining term of the franchise as such franchi