{"tag":"section","attrib":{"id":"idce35e5e6-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1751"},"text":null,"children":[{"tag":"num","attrib":{"value":"1751"},"text":"§ 1751.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce35e5e7-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1751/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “broadband internet access service” has the meaning given the term in section 8.1(b) of title 47, Code of Federal Regulations, or any successor regulation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce35e5e8-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1751/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Commission” means the Federal Communications Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idce35e5e9-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dF/tV/s60501"},"text":"Pub. L. 117–58, div. F, title V, § 60501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1238"},"text":"135 Stat. 1238","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idce35e5ea-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idce35e5eb-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idce35e5ec-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in text, was in the original, “this title”, meaning title V of div. F of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", which enacted this section and sections 1753 and 1754 of this title, amended sections 644 and 1752 of this title, and enacted provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s1752"},"text":"section 1752 of this title","children":[],"tail":". For complete classification of title V to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
