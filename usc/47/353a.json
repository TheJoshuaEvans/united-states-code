{"tag":"section","attrib":{"id":"idcdd687a7-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s353a"},"text":null,"children":[{"tag":"num","attrib":{"value":"353a"},"text":"§ 353a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operators and watches on radiotelephone equipped ships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcdd687a8-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s353a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each cargo ship which in accordance with this part is equipped with a radiotelephone station shall, for safety purposes, carry at least one operator who may be the master, an officer, or a member of the crew.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdd687a9-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s353a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each cargo ship of the United States which in accordance with this part is equipped with a radiotelephone station shall, while being navigated in the open sea outside of a harbor or port, maintain continuous watch whenever the station is not being used for authorized traffic.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcdd687aa-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title III, § 354, as added "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-13/ch729/s2/b"},"text":"Aug. 13, 1954, ch. 729, § 2(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/706"},"text":"68 Stat. 706","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/121/s5"},"text":"Pub. L. 89–121, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-13"},"text":"Aug. 13, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/514"},"text":"79 Stat. 514","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcdd687ab-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcdd687ac-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcdd687ad-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1965—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/121"},"text":"Pub. L. 89–121","children":[],"tail":" substituted “radiotelephone station” for “radiotelephone installation” in two places, and “one operator who may be the master, an officer, or a member of the crew” for “one qualified operator who may be a member of the crew holding only a certificate for radio telephony”, inserted “in the open sea” before “outside of a harbor”, and required a continuous watch whenever the station is not being used for authorized traffic."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
