{"tag":"section","attrib":{"id":"idd2bd79be-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s924"},"text":null,"children":[{"tag":"num","attrib":{"value":"924"},"text":"§ 924.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal or limitation of assignment to Federal Government stations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2bd79bf-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s924/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2bd79c0-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s924/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within 6 months after receipt of a report by the Secretary under subsection (a), (d)(1), or (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s923"},"text":"section 923 of this title","children":[],"tail":", withdraw the assignment to a Federal Government station of any frequency which the report recommends for immediate reallocation;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2bd79c1-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s924/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within any such 6-month period, limit the assignment to a Federal Government station of any frequency which the report recommends be made immediately available for mixed use under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s923/b/2"},"text":"section 923(b)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2bd79c2-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s924/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the delayed effective date recommended by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s923/e"},"text":"section 923(e) of this title","children":[],"tail":" (except as provided in subsection (b)(4) of this section), withdraw or limit the assignment to a Federal Government station of any frequency which the report recommends be reallocated or made available for mixed use on such delayed effective date;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2bd79c3-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s924/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assign or reassign other frequencies to Federal Government stations as necessary to adjust to such withdrawal or limitation of assignments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2bd79c4-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s924/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transmit a notice and description to the Commission and each House of Congress of the actions taken under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2bd79c5-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s924/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2bd79c6-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s924/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to substitute","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the President determines that a circumstance described in paragraph (2) exists, the President—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2bd79c7-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s924/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may substitute an alternative frequency or frequencies for the frequency that is subject to such determination and withdraw (or limit) the assignment of that alternative frequency in the manner required by subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2bd79c8-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s924/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall submit a statement of the reasons for taking the action described in subparagraph (A) to the Commission, Committee on Energy and Commerce of the House of Representatives, and the Committee on Commerce, Science, and Transportation of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2bd79c9-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s924/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grounds for substitution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the following circumstances are described in this paragraph:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2bd79ca-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s924/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reassignment would seriously jeopardize the national defense interests of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2bd79cb-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s924/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the frequency proposed for reassignment is uniquely suited to meeting important governmental needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2bd79cc-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s924/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reassignment would seriously jeopardize public health or safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2bd79cd-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s924/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reassignment will result in costs to the Federal Government that are excessive in relation to the benefits that may be obtained from commercial or other non-Federal uses of the reassigned frequency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2bd79ce-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s924/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reassignment will disrupt the existing use of a Federal Government band of frequencies by amateur radio licensees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2bd79cf-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s924/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for substituted frequencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), a frequency may not be substituted for a frequency identified and recommended by the report of the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s923/a"},"text":"section 923(a) of this title","children":[],"tail":" unless the substituted frequency also meets each of the criteria specified by "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s923/a"},"text":"section 923(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2bd79d0-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s924/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delays in implementation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the President determines that any action cannot be completed by the delayed effective date recommended by the Secretary pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s923/e"},"text":"section 923(e) of this title","children":[],"tail":", or that such an action by such date would result in a frequency being unused as a consequence of the Commission’s plan under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s925"},"text":"section 925 of this title","children":[],"tail":", the President may—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2bd79d1-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s924/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withdraw or limit the assignment to Federal Government stations on a later date that is consistent with such plan, except that the President shall notify each committee specified in paragraph (1)(B) and the Commission of the reason that withdrawal or limitation at a later date is required; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2bd79d2-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s924/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substitute alternative frequencies pursuant to the provisions of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2bd79d3-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/538/tI/s114"},"text":"Pub. L. 102–538, title I, § 114","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tVI/s6001/a/3"},"text":"Pub. L. 103–66, title VI, § 6001(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/384"},"text":"107 Stat. 384","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tIII/s3002/d/2"},"text":"Pub. L. 105–33, title III, § 3002(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/264"},"text":"111 Stat. 264","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2bd79d4-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2bd79d5-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd2bd79d6-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s3002/d/2/A"},"text":"Pub. L. 105–33, § 3002(d)(2)(A)","children":[],"tail":", substituted “subsection (a), (d)(1), or (f)” for “subsection (a) or (d)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s3002/d/2/B"},"text":"Pub. L. 105–33, § 3002(d)(2)(B)","children":[],"tail":", substituted “any such 6-month period” for “either such 6-month period”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
