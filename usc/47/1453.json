{"tag":"section","attrib":{"id":"idd2d08cee-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1453"},"text":null,"children":[{"tag":"num","attrib":{"value":"1453"},"text":"§ 1453.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlicensed use in the 5 GHZ band","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2d08cef-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1453/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification of Commission regulations to allow certain unlicensed use","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2d08cf0-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1453/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2012-02-22"},"text":"February 22, 2012","children":[],"tail":", the Commission shall begin a proceeding to modify part 15 of title 47, Code of Federal Regulations, to allow unlicensed U–NII devices to operate in the 5350–5470 MHz band."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d08cf1-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1453/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required determinations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission may make the modification described in paragraph (1) only if the Commission, in consultation with the Assistant Secretary, determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2d08cf2-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1453/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" licensed users will be protected by technical solutions, including use of existing, modified, or new spectrum-sharing technologies and solutions, such as dynamic frequency selection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2d08cf3-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1453/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the primary mission of Federal spectrum users in the 5350–5470 MHz band will not be compromised by the introduction of unlicensed devices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2d08cf4-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1453/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study by NTIA","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2d08cf5-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1453/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary, in consultation with the Department of Defense and other impacted agencies, shall conduct a study evaluating known and proposed spectrum-sharing technologies and the risk to Federal users if unlicensed U–NII devices were allowed to operate in the 5350–5470 MHz band and in the 5850–5925 MHz band.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d08cf6-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1453/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary shall submit to the Commission and the Committee on Energy and Commerce of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2d08cf7-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1453/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 8 months after ","children":[{"tag":"date","attrib":{"date":"2012-02-22"},"text":"February 22, 2012","children":[],"tail":", a report on the portion of the study required by paragraph (1) with respect to the 5350–5470 MHz band; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2d08cf8-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1453/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2012-02-22"},"text":"February 22, 2012","children":[],"tail":", a report on the portion of the study required by paragraph (1) with respect to the 5850–5925 MHz band."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2d08cf9-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1453/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2d08cfa-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1453/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 5350–5470 MHz band","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “5350–5470 MHz band” means the portion of the electromagnetic spectrum between the frequencies from 5350 megahertz to 5470 megahertz.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d08cfb-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1453/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 5850–5925 MHz band","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “5850–5925 MHz band” means the portion of the electromagnetic spectrum between the frequencies from 5850 megahertz to 5925 megahertz.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2d08cfc-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/96/tVI/s6406"},"text":"Pub. L. 112–96, title VI, § 6406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/231"},"text":"126 Stat. 231","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
