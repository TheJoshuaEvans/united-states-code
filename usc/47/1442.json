{"tag":"section","attrib":{"id":"idd2ce4230-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442"},"text":null,"children":[{"tag":"num","attrib":{"value":"1442"},"text":"§ 1442.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and local implementation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2ce4231-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of State and Local Implementation Grant Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary, in consultation with the First Responder Network Authority, shall take such action as is necessary to establish a grant program to make grants to States to assist State, regional, tribal, and local jurisdictions to identify, plan, and implement the most efficient and effective way for such jurisdictions to utilize and integrate the infrastructure, equipment, and other architecture associated with the nationwide public safety broadband network to satisfy the wireless communications and data services needs of that jurisdiction, including with regards to coverage, siting, and other needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2ce4232-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirements; Federal share","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2ce4233-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of any activity carried out using a grant under this section may not exceed 80 percent of the eligible costs of carrying out that activity, as determined by the Assistant Secretary, in consultation with the First Responder Network Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2ce4234-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary may waive, in whole or in part, the requirements of paragraph (1) for good cause shown if the Assistant Secretary determines that such a waiver is in the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2ce4235-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programmatic requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"2012-02-22"},"text":"February 22, 2012","children":[],"tail":", the Assistant Secretary, in consultation with the First Responder Network Authority, shall establish requirements relating to the grant program to be carried out under this section, including the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2ce4236-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Defining eligible costs for purposes of subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2ce4237-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Determining the scope of eligible activities for grant funding under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2ce4238-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prioritizing grants for activities that ensure coverage in rural as well as urban areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2ce4239-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification and designation of officer or governmental body","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the grant program established under this section, the Assistant Secretary shall require each State to certify in its application for grant funds that the State has designated a single officer or governmental body to serve as the coordinator of implementation of the grant funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2ce423a-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State network","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2ce423b-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon the completion of the request for proposal process conducted by the First Responder Network Authority for the construction, operation, maintenance, and improvement of the nationwide public safety broadband network, the First Responder Network Authority shall provide to the Governor of each State, or his designee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2ce423c-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notice of the completion of the request for proposal process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2ce423d-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" details of the proposed plan for buildout of the nationwide, interoperable broadband network in such State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2ce423e-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funding level for the State as determined by the NTIA.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2ce423f-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State decision","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date on which the Governor of a State receives notice under paragraph (1), the Governor shall choose whether to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2ce4240-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in the deployment of the nationwide, interoperable broadband network as proposed by the First Responder Network Authority; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2ce4241-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct its own deployment of a radio access network in such State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2ce4242-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2ce4243-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon making a decision to opt-out under paragraph (2)(B), the Governor shall notify the First Responder Network Authority, the NTIA, and the Commission of such decision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2ce4244-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State request for proposals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after the date on which a Governor provides notice under subparagraph (A), the Governor shall develop and complete requests for proposals for the construction, maintenance, and operation of the radio access network within the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2ce4245-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission and approval of alternative plan","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd2ce4246-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/e/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The State shall submit an alternative plan for the construction, maintenance, operation, and improvements of the radio access network within the State to the Commission, and such plan shall demonstrate—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idd2ce4247-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/e/3/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the State will be in compliance with the minimum technical interoperability requirements developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1423"},"text":"section 1423 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd2ce4248-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/e/3/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interoperability with the nationwide public safety broadband network.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2ce4249-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/e/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission approval or disapproval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon submission of a State plan under clause (i), the Commission shall either approve or disapprove the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2ce424a-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/e/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Commission approves a plan under this subparagraph, the State—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idd2ce424b-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/e/3/C/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may apply to the NTIA for a grant to construct the radio access network within the State that includes the showing described in subparagraph (D); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd2ce424c-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/e/3/C/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall apply to the NTIA to lease spectrum capacity from the First Responder Network Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2ce424d-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/e/3/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disapproval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Commission disapproves a plan under this subparagraph, the construction, maintenance, operation, and improvements of the network within the State shall proceed in accordance with the plan proposed by the First Responder Network Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2ce424e-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to obtain grant funds and spectrum capacity leasing rights under subparagraph (C)(iii), a State shall demonstrate—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd2ce424f-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/e/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that the State has—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idd2ce4250-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/e/3/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the technical capabilities to operate, and the funding to support, the State radio access network;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd2ce4251-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/e/3/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the ability to maintain ongoing interoperability with the nationwide public safety broadband network; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd2ce4252-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/e/3/D/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability to complete the project within specified comparable timelines specific to the State;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2ce4253-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/e/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost-effectiveness of the State plan submitted under subparagraph (C)(i); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2ce4254-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/e/3/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comparable security, coverage, and quality of service to that of the nationwide public safety broadband network.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2ce4255-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" User fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State chooses to build its own radio access network, the State shall pay any user fees associated with State use of elements of the core network.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2ce4256-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2ce4257-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that chooses to build its own radio access network shall not provide commercial service to consumers or offer wholesale leasing capacity of the network within the State except directly through public-private partnerships for construction, maintenance, operation, and improvement of the network within the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2ce4258-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be construed to prohibit the State and a secondary user from entering into a covered leasing agreement. Any revenue gained by the State from such a leasing agreement shall be used only for constructing, maintaining, operating, or improving the radio access network of the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2ce4259-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2ce425a-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States District Court for the District of Columbia shall have exclusive jurisdiction to review a decision of the Commission made under subsection (e)(3)(C)(iv).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2ce425b-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard of review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The court shall affirm the decision of the Commission unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2ce425c-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the decision was procured by corruption, fraud, or undue means;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2ce425d-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there was actual partiality or corruption in the Commission; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2ce425e-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1442/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commission was guilty of misconduct in refusing to hear evidence pertinent and material to the decision or of any other misbehavior by which the rights of any party have been prejudiced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2ce425f-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/96/tVI/s6302"},"text":"Pub. L. 112–96, title VI, § 6302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/219"},"text":"126 Stat. 219","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
