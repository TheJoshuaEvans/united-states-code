{"tag":"section","attrib":{"id":"idd2c4a5f9-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206"},"text":null,"children":[{"tag":"num","attrib":{"value":"1206"},"text":"§ 1206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reliable emergency alert distribution improvement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2c4a5fa-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wireless emergency alerts system offerings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2c4a5fb-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2c4a5fc-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":", the Commission, in consultation with the Administrator, shall adopt regulations to implement the amendment made by paragraph (1)(B)."},{"tag":"ref","attrib":{"idref":"fn002063"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002063"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2c4a5fd-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State emergency alert system plans and emergency communications committees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2c4a5fe-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State emergency communications committee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":", the Commission shall adopt regulations that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2c4a5ff-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" encourage the chief executive of each State—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd2c4a600-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish an SECC if the State does not have an SECC; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2c4a601-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the State has an SECC, to review the composition and governance of the SECC;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2c4a602-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd2c4a603-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" each SECC, not less frequently than annually, shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idd2c4a604-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/b/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet to review and update its State EAS Plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd2c4a605-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/b/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify to the Commission that the SECC has met as required under subclause (I); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd2c4a606-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/b/1/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Commission an updated State EAS Plan; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2c4a607-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 60 days after the date on which the Commission receives an updated State EAS Plan under clause (i)(III), the Commission shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idd2c4a608-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/b/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approve or disapprove the updated State EAS Plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd2c4a609-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/b/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the chief executive of the State of the Commission’s approval or disapproval of such plan, and reason therefor; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2c4a60a-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a State EAS Plan content checklist for SECCs to use when reviewing and updating a State EAS Plan for submission to the Commission under subparagraph (B)(i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2c4a60b-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall consult with the Administrator regarding the adoption of regulations under paragraph (1)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2c4a60c-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2c4a60d-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “SECC” means a State Emergency Communications Committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2c4a60e-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” means any State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the United States Virgin Islands, Guam, American Samoa, the Commonwealth of the Northern Mariana Islands, and any possession of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2c4a60f-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State EAS Plan” means a State Emergency Alert System Plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2c4a610-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False alert reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":", the Commission, in consultation with the Administrator, shall complete a rulemaking proceeding to establish a system to receive from the Administrator or State, Tribal, or local governments reports of false alerts under the Emergency Alert System or the Wireless Emergency Alerts System for the purpose of recording such false alerts and examining the causes of such false alerts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2c4a611-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repeating emergency alert system messages for national security","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2c4a612-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":", the Commission, in consultation with the Administrator, shall complete a rulemaking proceeding to modify the Emergency Alert System to provide for repeating Emergency Alert System messages while an alert remains pending that is issued by—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2c4a613-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2c4a614-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2c4a615-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other entity determined appropriate under the circumstances by the Commission, in consultation with the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2c4a616-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of rulemaking","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2c4a617-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply to warnings of national security events, meaning emergencies of national significance, such as a missile threat, terror attack, or other act of war or threat to public safety; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2c4a618-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not apply to more typical warnings, such as a weather alert, AMBER Alert, or disaster alert.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2c4a619-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subsection shall be construed to impair, limit, or otherwise change—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2c4a61a-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority of the President granted by law to alert and warn the public; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2c4a61b-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the role of the President as commander-in-chief with respect to the identification, dissemination, notification, or alerting of information of missile threats against the United States, or threats to public safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2c4a61c-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internet and online streaming services emergency alert examination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2c4a61d-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":", and after providing public notice and opportunity for comment, the Commission shall complete an inquiry to examine the feasibility of updating the Emergency Alert System to enable or improve alerts to consumers provided through the internet, including through streaming services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2c4a61e-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after completing the inquiry under paragraph (1), the Commission shall submit a report on the findings and conclusions of the inquiry to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2c4a61f-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce, Science, and Transportation of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2c4a620-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Commerce of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2c4a621-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2c4a622-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Administrator” means the Administrator of the Federal Emergency Management Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2c4a623-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Commission” means the Federal Communications Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2c4a624-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Emergency Alert System” means the national public warning system, the rules for which are set forth in part 11 of title 47, Code of Federal Regulations (or any successor regulation); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2c4a625-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1206/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Wireless Emergency Alerts System” means the wireless national public warning system established under the Warning, Alert, and Response Network Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1201"},"text":"47 U.S.C. 1201","children":[],"tail":" et seq.), the rules for which are set forth in part 10 of title 47, Code of Federal Regulations (or any successor regulation)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2c4a626-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dH/tXCII/s9201"},"text":"Pub. L. 116–283, div. H, title XCII, § 9201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4785"},"text":"134 Stat. 4785","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2c4a627-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2c4a628-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd2c4a629-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The amendment made by paragraph (1)(B), referred to in subsec. (a)(2), means the amendment made by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s9201/a/1/B"},"text":"Pub. L. 116–283, § 9201(a)(1)(B)","children":[],"tail":" which amended "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s1201"},"text":"section 1201 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Warning, Alert, and Response Network Act, referred to in subsec. (f)(4), is title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347"},"text":"Pub. L. 109–347","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1936"},"text":"120 Stat. 1936","children":[],"tail":", which is classified principally to chapter 11 (§ 1201 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s1201"},"text":"section 1201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd2c4a62a-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the William M. (Mac) Thornberry National Defense Authorization Act for Fiscal Year 2021 and not as part of the Warning, Alert, and Response Network Act which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s9201"},"text":"section 9201 of Pub. L. 116–283","children":[],"tail":". Subsec. (a) of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s9201"},"text":"section 9201 of Pub. L. 116–283","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s1201"},"text":"section 1201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
