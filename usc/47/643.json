{"tag":"section","attrib":{"id":"idd2af21db-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s643"},"text":null,"children":[{"tag":"num","attrib":{"value":"643"},"text":"§ 643.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for an entity or individual to willfully and knowingly, or recklessly, submit information or data under this subchapter that is materially inaccurate or incomplete with respect to the availability of broadband internet access service or the quality of service with respect to broadband internet access service.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd2af21dc-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title VIII, § 803, as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/130/s2"},"text":"Pub. L. 116–130, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-23"},"text":"Mar. 23, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/236"},"text":"134 Stat. 236","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
