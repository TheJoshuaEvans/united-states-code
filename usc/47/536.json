{"tag":"section","attrib":{"id":"idd2975407-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s536"},"text":null,"children":[{"tag":"num","attrib":{"value":"536"},"text":"§ 536.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulation of carriage agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2975408-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s536/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within one year after ","children":[{"tag":"date","attrib":{"date":"1992-10-05"},"text":"October 5, 1992","children":[],"tail":", the Commission shall establish regulations governing program carriage agreements and related practices between cable operators or other multichannel video programming distributors and video programming vendors. Such regulations shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2975409-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s536/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include provisions designed to prevent a cable operator or other multichannel video programming distributor from requiring a financial interest in a program service as a condition for carriage on one or more of such operator’s systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd297540a-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s536/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include provisions designed to prohibit a cable operator or other multichannel video programming distributor from coercing a video programming vendor to provide, and from retaliating against such a vendor for failing to provide, exclusive rights against other multichannel video programming distributors as a condition of carriage on a system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd297540b-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s536/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain provisions designed to prevent a multichannel video programming distributor from engaging in conduct the effect of which is to unreasonably restrain the ability of an unaffiliated video programming vendor to compete fairly by discriminating in video programming distribution on the basis of affiliation or nonaffiliation of vendors in the selection, terms, or conditions for carriage of video programming provided by such vendors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd297540c-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s536/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for expedited review of any complaints made by a video programming vendor pursuant to this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd297540d-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s536/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for appropriate penalties and remedies for violations of this subsection, including carriage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd297540e-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s536/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide penalties to be assessed against any person filing a frivolous complaint pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd297540f-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s536/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Video programming vendor” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the term “video programming vendor” means a person engaged in the production, creation, or wholesale distribution of video programming for sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2975410-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title VI, § 616, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/385/s12"},"text":"Pub. L. 102–385, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-05"},"text":"Oct. 5, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1488"},"text":"106 Stat. 1488","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2975411-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd2975412-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd2975413-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 60 days after ","children":[{"tag":"date","attrib":{"date":"1992-10-05"},"text":"Oct. 5, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/385/s28"},"text":"section 28 of Pub. L. 102–385","children":[],"tail":", set out as an Effective Date of 1992 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s325"},"text":"section 325 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
