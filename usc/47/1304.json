{"tag":"section","attrib":{"id":"idce1ba74f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304"},"text":null,"children":[{"tag":"num","attrib":{"value":"1304"},"text":"§ 1304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encouraging State initiatives to improve broadband","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idce1ba750-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of any grant under subsection (b) are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce1ba751-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that all citizens and businesses in a State have access to affordable and reliable broadband service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce1ba752-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to achieve improved technology literacy, increased computer ownership, and broadband use among such citizens and businesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce1ba753-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish and empower local grassroots technology teams in each State to plan for improved technology use across multiple community sectors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce1ba754-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish and sustain an environment ripe for broadband services and information technology investment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce1ba755-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of State broadband data and development grant program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce1ba756-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce shall award grants, taking into account the results of the peer review process under subsection (d), to eligible entities for the development and implementation of statewide initiatives to identify and track the availability and adoption of broadband services within each State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce1ba757-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any grant under subsection (b) shall be awarded on a competitive basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce1ba758-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under subsection (b), an eligible entity shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce1ba759-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit an application to the Secretary of Commerce, at such time, in such manner, and containing such information as the Secretary may require;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce1ba75a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contribute matching non-Federal funds in an amount equal to not less than 20 percent of the total amount of the grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce1ba75b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agree to comply with confidentiality requirements in subsection (h)(2) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce1ba75c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer review; nondisclosure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce1ba75d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall by regulation require appropriate technical and scientific peer review of applications made for grants under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce1ba75e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review procedures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations required under paragraph (1) shall require that any technical and scientific peer review group—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce1ba75f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be provided a written description of the grant to be reviewed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce1ba760-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the results of any review by such group to the Secretary of Commerce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce1ba761-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify that such group will enter into voluntary nondisclosure agreements as necessary to prevent the unauthorized disclosure of confidential and proprietary information provided by broadband service providers in connection with projects funded by any such grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce1ba762-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant awarded to an eligible entity under subsection (b) shall be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce1ba763-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide a baseline assessment of broadband service deployment in each State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce1ba764-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to identify and track—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce1ba765-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" areas in each State that have low levels of broadband service deployment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce1ba766-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate at which residential and business users adopt broadband service and other related information technology services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce1ba767-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" possible suppliers of such services;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce1ba768-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to identify barriers to the adoption by individuals and businesses of broadband service and related information technology services, including whether or not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce1ba769-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the demand for such services is absent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce1ba76a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the supply for such services is capable of meeting the demand for such services;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce1ba76b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify the speeds of broadband connections made available to individuals and businesses within the State, and, at a minimum, to rely on the data rate benchmarks for broadband service utilized by the Commission to reflect different speed tiers, to promote greater consistency of data among the States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce1ba76c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to create and facilitate in each county or designated region in a State a local technology planning team—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce1ba76d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with members representing a cross section of the community, including representatives of business, telecommunications labor organizations, K–12 education, health care, libraries, higher education, community-based organizations, local government, tourism, parks and recreation, and agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce1ba76e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idce1ba76f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/e/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benchmark technology use across relevant community sectors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce1ba770-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/e/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set goals for improved technology use within each sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce1ba771-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/e/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a tactical business plan for achieving its goals, with specific recommendations for online application development and demand creation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce1ba772-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to work collaboratively with broadband service providers and information technology companies to encourage deployment and use, especially in unserved areas and areas in which broadband penetration is significantly below the national average, through the use of local demand aggregation, mapping analysis, and the creation of market intelligence to improve the business case for providers to deploy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce1ba773-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish programs to improve computer ownership and Internet access for unserved areas and areas in which broadband penetration is significantly below the national average;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce1ba774-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/e/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to collect and analyze detailed market data concerning the use and demand for broadband service and related information technology services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce1ba775-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/e/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate information exchange regarding the use and demand for broadband services between public and private sectors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce1ba776-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/e/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to create within each State a geographic inventory map of broadband service, including the data rate benchmarks for broadband service utilized by the Commission to reflect different speed tiers, which shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce1ba777-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/e/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify gaps in such service through a method of geographic information system mapping of service availability based on the geographic boundaries of where service is available or unavailable among residential or business customers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce1ba778-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/e/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a baseline assessment of statewide broadband deployment in terms of households with high-speed availability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce1ba779-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation limit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each State, an eligible entity may not receive a new grant under this section to fund the activities described in subsection (d) within such State if such organization obtained prior grant awards under this section to fund the same activities in that State in each of the previous 4 consecutive years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce1ba77a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting; broadband inventory map","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Commerce shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce1ba77b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require each recipient of a grant under subsection (b) to submit a report on the use of the funds provided by the grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce1ba77c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create a web page on the Department of Commerce website that aggregates relevant information made available to the public by grant recipients, including, where appropriate, hypertext links to any geographic inventory maps created by grant recipients under subsection (e)(10).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce1ba77d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to aggregate data","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce1ba77e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Commission shall provide eligible entities access, in electronic form, to aggregate data collected by the Commission based on the Form 477 submissions of broadband service providers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce1ba77f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any provision of Federal or State law to the contrary, an eligible entity shall treat any matter that is a trade secret, commercial or financial information, or privileged or confidential, as a record not subject to public disclosure except as otherwise mutually agreed to by the broadband service provider and the eligible entity. This paragraph applies only to information submitted by the Commission or a broadband provider to carry out the provisions of this chapter and shall not otherwise limit or affect the rules governing public disclosure of information collected by any Federal or State entity under any other Federal or State law or regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce1ba780-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce1ba781-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commission” means the Federal Communications Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce1ba782-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce1ba783-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an entity that is either—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idce1ba784-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/i/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agency or instrumentality of a State, or a municipality or other subdivision (or agency or instrumentality of a municipality or other subdivision) of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce1ba785-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/i/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit organization that is described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":" and that is exempt from taxation under section 501(a) of such title; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce1ba786-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/i/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an independent agency or commission in which an office of a State is a member on behalf of the State; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce1ba787-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the single eligible entity in the State that has been designated by the State to receive a grant under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce1ba788-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1304/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No regulatory authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as giving any public or private entity established or affected by this chapter any regulatory jurisdiction or oversight authority over providers of broadband services or information technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idce1ba789-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/385/tI/s106"},"text":"Pub. L. 110–385, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4099"},"text":"122 Stat. 4099","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
