{"tag":"section","attrib":{"id":"idcd7e2e5a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"§ 16.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Washington-Alaska Military Cable and Telegraph System; money transfers; portion of receipts withheld","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1926-05-20"},"text":"May 20, 1926","children":[],"tail":", such amount of money as may be authorized by the Secretary of the Army may be withheld temporarily from the receipts of the Washington-Alaska Military Cable and Telegraph System by the auditor of said system as a working balance from which to make payments of money transfers from and to Alaska and between points within Alaska, to be accounted for accordingly."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcd7e2e5b-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-05-20/ch345"},"text":"May 20, 1926, ch. 345","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/576"},"text":"44 Stat. 576","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title II, § 205(a), "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/310/tIII/s233"},"text":"Pub. L. 92–310, title III, § 233","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-06"},"text":"June 6, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/214"},"text":"86 Stat. 214","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcd7e2e5c-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcd7e2e5d-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcd7e2e5e-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/310"},"text":"Pub. L. 92–310","children":[],"tail":" struck out provisions which permitted the expenses of procuring necessary official bonds of certain enlisted men to be paid from the receipts of the system."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcd7e2e5f-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idcd7e2e60-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Department of War designated Department of the Army and title of Secretary of War changed to Secretary of the Army by section 205(a) of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343/tII"},"text":"act July 26, 1947, ch. 343, title II","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":". Section 205(a) of act "},{"tag":"date","attrib":{"date":"1947-07-26"},"text":"July 26, 1947","children":[],"tail":", was repealed by section 53 of "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/641"},"text":"70A Stat. 641","children":[],"tail":". Section 1 of act "},{"tag":"date","attrib":{"date":"1956-08-10"},"text":"Aug. 10, 1956","children":[],"tail":", enacted Title 10, Armed Forces, which in sections 3010 to 3013 continued Department of the Army under administrative supervision of Secretary of the Army."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
