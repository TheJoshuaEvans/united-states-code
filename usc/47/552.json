{"tag":"section","attrib":{"id":"idcdf0c6c7-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s552"},"text":null,"children":[{"tag":"num","attrib":{"value":"552"},"text":"§ 552.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer protection and customer service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcdf0c6c8-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s552/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Franchising authority enforcement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A franchising authority may establish and enforce—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcdf0c6c9-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s552/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" customer service requirements of the cable operator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdf0c6ca-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s552/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction schedules and other construction-related requirements, including construction-related performance requirements, of the cable operator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdf0c6cb-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s552/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall, within 180 days of ","children":[{"tag":"date","attrib":{"date":"1992-10-05"},"text":"October 5, 1992","children":[],"tail":", establish standards by which cable operators may fulfill their customer service requirements. Such standards shall include, at a minimum, requirements governing—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcdf0c6cc-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s552/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cable system office hours and telephone availability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdf0c6cd-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s552/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" installations, outages, and service calls; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdf0c6ce-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s552/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communications between the cable operator and the subscriber (including standards governing bills and refunds).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdf0c6cf-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s552/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subscriber notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A cable operator may provide notice of service and rate changes to subscribers using any reasonable written means at its sole discretion. Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s543/b/6"},"text":"section 543(b)(6) of this title","children":[],"tail":" or any other provision of this chapter, a cable operator shall not be required to provide prior notice of any rate change that is the result of a regulatory fee, franchise fee, or any other fee, tax, assessment, or charge of any kind imposed by any Federal agency, State, or franchising authority on the transaction between the operator and the subscriber."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdf0c6d0-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s552/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer protection laws and customer service agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcdf0c6d1-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s552/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer protection laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to prohibit any State or any franchising authority from enacting or enforcing any consumer protection law, to the extent not specifically preempted by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdf0c6d2-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s552/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Customer service requirement agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to preclude a franchising authority and a cable operator from agreeing to customer service requirements that exceed the standards established by the Commission under subsection (b). Nothing in this subchapter shall be construed to prevent the establishment or enforcement of any municipal law or regulation, or any State law, concerning customer service that imposes customer service requirements that exceed the standards set by the Commission under this section, or that addresses matters not addressed by the standards set by the Commission under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcdf0c6d3-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title VI, § 632, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/549/s2"},"text":"Pub. L. 98–549, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2796"},"text":"98 Stat. 2796","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/385/s8"},"text":"Pub. L. 102–385, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-05"},"text":"Oct. 5, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1484"},"text":"106 Stat. 1484","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/104/tIII/s301/g"},"text":"Pub. L. 104–104, title III, § 301(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-08"},"text":"Feb. 8, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/117"},"text":"110 Stat. 117","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcdf0c6d4-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcdf0c6d5-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcdf0c6d6-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"act June 19, 1934, ch. 652","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1064"},"text":"48 Stat. 1064","children":[],"tail":", known as the Communications Act of 1934, which is classified principally to this chapter. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s609"},"text":"section 609 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcdf0c6d7-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/104"},"text":"Pub. L. 104–104","children":[],"tail":" added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/385"},"text":"Pub. L. 102–385","children":[],"tail":" amended section generally. Prior to amendment, section read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) A franchising authority may require, as part of a franchise (including a franchise renewal, subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s546"},"text":"section 546 of this title","children":[],"tail":"), provisions for enforcement of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) customer service requirements of the cable operator; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) construction schedules and other construction-related requirements of the cable operator.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) A franchising authority may enforce any provision, contained in any franchise, relating to requirements described in paragraph (1) or (2) of subsection (a) of this section, to the extent not inconsistent with this subchapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) Nothing in this subchapter shall be construed to prohibit any State or any franchising authority from enacting or enforcing any consumer protection law, to the extent not inconsistent with this subchapter.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcdf0c6d8-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcdf0c6d9-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/385"},"text":"Pub. L. 102–385","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"1992-10-05"},"text":"Oct. 5, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/385/s28"},"text":"section 28 of Pub. L. 102–385","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s325"},"text":"section 325 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcdf0c6da-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 60 days after ","children":[{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", except where otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/549/s9/a"},"text":"section 9(a) of Pub. L. 98–549","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s521"},"text":"section 521 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
