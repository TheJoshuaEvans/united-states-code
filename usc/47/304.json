{"tag":"section","attrib":{"id":"idd262d64f-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s304"},"text":null,"children":[{"tag":"num","attrib":{"value":"304"},"text":"§ 304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver by license of claims to particular frequency or of electromagnetic spectrum","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No station license shall be granted by the Commission until the applicant therefor shall have waived any claim to the use of any particular frequency or of the electromagnetic spectrum as against the regulatory power of the United States because of the previous use of the same, whether by license or otherwise.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd262d650-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title III, § 304, "},{"tag":"ref","attrib":{"href":"/us/stat/48/1083"},"text":"48 Stat. 1083","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/259/tI/s127/a"},"text":"Pub. L. 97–259, title I, § 127(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1099"},"text":"96 Stat. 1099","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/538/tII/s204/a"},"text":"Pub. L. 102–538, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3543"},"text":"106 Stat. 3543","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd262d651-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd262d652-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd262d653-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/538"},"text":"Pub. L. 102–538","children":[],"tail":" substituted “waived” for “signed a waiver of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/259"},"text":"Pub. L. 97–259","children":[],"tail":" substituted “electromagnetic spectrum” for “ether”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
