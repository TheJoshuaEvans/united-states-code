{"tag":"section","attrib":{"id":"idcd809f86-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s31"},"text":null,"children":[{"tag":"num","attrib":{"value":"31"},"text":"§ 31.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summary trials","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of sections 391–396 of title 33 shall extend to the trial of offenses against the provisions of sections 24 and 25 of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcd809f87-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1888-02-29/ch17/s11"},"text":"Feb. 29, 1888, ch. 17, § 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/25/42"},"text":"25 Stat. 42","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
