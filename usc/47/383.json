{"tag":"section","attrib":{"id":"idcdd6882c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s383"},"text":null,"children":[{"tag":"num","attrib":{"value":"383"},"text":"§ 383.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions by Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commission shall exempt from the provisions of this part any vessel, or class of vessels, in the case of which the route or conditions of the voyage, or other conditions or circumstances, are such as to render a radio installation unreasonable, unnecessary, or ineffective, for the purposes of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcdd6882d-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title III, § 383, as added "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-06/ch973/s1"},"text":"Aug. 6, 1956, ch. 973, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/1048"},"text":"70 Stat. 1048","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/414/tIII/s303/a/20/C"},"text":"Pub. L. 103–414, title III, § 303(a)(20)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4295"},"text":"108 Stat. 4295","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcdd6882e-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcdd6882f-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","