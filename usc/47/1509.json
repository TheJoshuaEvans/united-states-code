{"tag":"section","attrib":{"id":"idce278ed9-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1509"},"text":null,"children":[{"tag":"num","attrib":{"value":"1509"},"text":"§ 1509.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spectrum Challenge Prize","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idce278eda-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1509/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may be cited as the “Spectrum Challenge Prize Act”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce278edb-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1509/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of prize competition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “prize competition” means a prize competition conducted by the Secretary under subsection (c)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce278edc-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1509/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spectrum Challenge Prize","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce278edd-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1509/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Assistant Secretary of Commerce for Communications and Information and the Under Secretary of Commerce for Standards and Technology, shall, subject to the availability of funds for prize competitions under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce278ede-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1509/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct prize competitions to dramatically accelerate the development and commercialization of technology that improves spectrum efficiency and is capable of cost-effective deployment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce278edf-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1509/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" define a measurable set of performance goals for participants in the prize competitions to demonstrate their solutions on a level playing field while making a significant advancement over the current state of the art.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce278ee0-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1509/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out paragraph (1), the Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce278ee1-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1509/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into a grant, contract, cooperative agreement, or other agreement with a private sector for-profit or nonprofit entity to administer the prize competitions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce278ee2-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1509/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" invite the Defense Advanced Research Projects Agency, the Commission, the National Aeronautics and Space Administration, the National Science Foundation, or any other Federal agency to provide advice and assistance in the design or administration of the prize competitions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce278ee3-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1509/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award not more than $5,000,000, in the aggregate, to the winner or winners of the prize competitions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce278ee4-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1509/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after the date on which funds for prize competitions are made available pursuant to this section, the Commission shall publish a technical paper on spectrum efficiency providing criteria that may be used for the design of the prize competitions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce278ee5-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1509/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idce278ee6-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dP/tVI/s619"},"text":"Pub. L. 115–141, div. P, title VI, § 619","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1113"},"text":"132 Stat. 1113","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
