{"tag":"section","attrib":{"id":"idd2299da5-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s32"},"text":null,"children":[{"tag":"num","attrib":{"value":"32"},"text":"§ 32.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of this chapter shall be held to apply only to cables to which the convention for the time being applies.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd2299da6-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1888-02-29/ch17/s12"},"text":"Feb. 29, 1888, ch. 17, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/25/42"},"text":"25 Stat. 42","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
