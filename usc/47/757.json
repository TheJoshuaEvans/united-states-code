{"tag":"section","attrib":{"id":"idd2af2258-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s757"},"text":null,"children":[{"tag":"num","attrib":{"value":"757"},"text":"§ 757.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2af2259-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s757/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “person” includes an individual, partnership, association, joint stock company, trust, or corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2af225a-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s757/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “satellite earth terminal station” means a complex of communications equipment located on land, operationally interconnected with one or more terrestrial communications systems, and capable of transmitting telecommunications to, or receiving telecommunications from, the space segment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2af225b-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s757/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “space segment” means any satellite (or capacity on a satellite) maintained under the authority of INMARSAT, for the purpose of providing international maritime telecommunications services, and the tracking, telemetry, command, control, monitoring, and related facilities and equipment required to support the operation of such satellite; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2af225c-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s757/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” means the several States, the District of Columbia, the Commonwealth of Puerto Rico, Guam, the Virgin Islands, the Trust Territory of the Pacific Islands, and any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2af225d-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/624/tV/s505"},"text":"Pub. L. 87–624, title V, § 505","children":[],"tail":", formerly § 508, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/564"},"text":"Pub. L. 95–564","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2396"},"text":"92 Stat. 2396","children":[],"tail":"; renumbered § 505, "},{"tag":"ref","attrib":{"href":"/us/pl/103/414/tIII/s304/b/6"},"text":"Pub. L. 103–414, title III, § 304(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4298"},"text":"108 Stat. 4298","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2af225e-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2af225f-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd2af2260-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attr