{"tag":"section","attrib":{"id":"idd284418e-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s393"},"text":null,"children":[{"tag":"num","attrib":{"value":"393"},"text":"§ 393.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for approval and expenditures by Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd284418f-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s393/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction and planning grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Corporation, public telecommunications entities, and as appropriate with others, shall establish criteria for making construction and planning grants. Such criteria shall be consistent with the objectives and provisions set forth in this subpart, and shall be made available to interested parties upon request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2844190-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s393/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis for determination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall base determinations of whether to approve applications for grants under this subpart, and the amount of such grants, on criteria developed pursuant to subsection (a) and designed to achieve—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2844191-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s393/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of new telecommunications facilities to extend service to areas currently not receiving public telecommunications services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2844192-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s393/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expansion of the service areas of existing public telecommunications entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2844193-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s393/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of public telecommunications facilities owned by, operated by, and available to minorities and women; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2844194-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s393/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the improvement of the capabilities of existing public broadcast stations to provide public telecommunications services, including services to underserved audiences such as deaf and hearing impaired individuals and blind and visually impaired individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2844195-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s393/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncommercial radio broadcast station facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the sums appropriated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s391"},"text":"section 391 of this title","children":[],"tail":" for any fiscal year, a substantial amount shall be available for the expansion and development of noncommercial radio broadcast station facilities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2844196-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title III, § 393, as added "},{"tag":"ref","attrib":{"href":"/us/pl/87/447"},"text":"Pub. L. 87–447","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-05-01"},"text":"May 1, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/66"},"text":"76 Stat. 66","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/90/129/tII/s201/2"},"text":"Pub. L. 90–129, title II, § 201(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-11-07"},"text":"Nov. 7, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/367"},"text":"81 Stat. 367","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/567/tI/s104"},"text":"Pub. L. 95–567, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-02"},"text":"Nov. 2, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2408"},"text":"92 Stat. 2408","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tV/s5001/b"},"text":"Pub. L. 99–272, title V, § 5001(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/117"},"text":"100 Stat. 117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/356/s3"},"text":"Pub. L. 102–356, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-08-26"},"text":"Aug. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/949"},"text":"106 Stat. 949","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2844197-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2844198-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd2844199-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/356"},"text":"Pub. L. 102–356","children":[],"tail":" inserted before period at end “, including services to underserved audiences such as deaf and hearing impaired individuals and blind and visually impaired individuals”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272"},"text":"Pub. L. 99–272","children":[],"tail":" redesignated subsec. (d) as (c) and struck out former subsec. (c) relating to extension of services to new areas."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/567"},"text":"Pub. L. 95–567","children":[],"tail":" amended section generally, striking out provisions dealing with keeping records and access to records by Secretary and Comptroller General and inserting provisions dealing with criteria for approval and expenditures by Secretary. See sections 392(h) and 395(h) of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/129"},"text":"Pub. L. 90–129","children":[],"tail":" substituted “subpart” for “part” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd284419a-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd284419b-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/567"},"text":"Pub. L. 95–567","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1978-11-02"},"text":"Nov. 2, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/567/s403"},"text":"section 403 of Pub. L. 95–567","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s390"},"text":"section 390 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
