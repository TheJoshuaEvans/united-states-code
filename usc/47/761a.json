{"tag":"section","attrib":{"id":"idd2b1927b-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s761a"},"text":null,"children":[{"tag":"num","attrib":{"value":"761a"},"text":"§ 761a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentives; limitation on expansion pending privatization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2b1927c-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s761a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Until INTELSAT, Inmarsat, and their successor or separate entities are privatized in accordance with the requirements of this subchapter, INTELSAT, Inmarsat, and their successor or separate entities, respectively, shall not be permitted to provide additional services. The Commission shall take all necessary measures to implement this requirement, including denial by the Commission of licensing for such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2b1927d-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s761a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Orbital location incentives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Until such privatization is achieved, the United States shall oppose and decline to facilitate applications by such entities for new orbital locations to provide such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2b1927e-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/624/tVI/s602"},"text":"Pub. L. 87–624, title VI, § 602","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/180/s3"},"text":"Pub. L. 106–180, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-03-17"},"text":"Mar. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/50"},"text":"114 Stat. 50","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
