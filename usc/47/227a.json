{"tag":"section","attrib":{"id":"idcda6c586-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s227a"},"text":null,"children":[{"tag":"num","attrib":{"value":"227a"},"text":"§ 227a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer education materials on how to avoid scams that rely upon misleading or inaccurate caller identification information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcda6c587-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s227a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of materials","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2018-03-23"},"text":"March 23, 2018","children":[],"tail":", the Commission, in coordination with the Federal Trade Commission, shall develop consumer education materials that provide information about—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcda6c588-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s227a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ways for consumers to identify scams and other fraudulent activity that rely upon the use of misleading or inaccurate caller identification information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcda6c589-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s227a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing technologies, if any, that a consumer can use to protect against such scams and other fraudulent activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcda6c58a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s227a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the consumer education materials under paragraph (1), the Commission shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcda6c58b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s227a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify existing technologies, if any, that can help consumers guard themselves against scams and other fraudulent activity that rely upon the use of misleading or inaccurate caller identification information, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcda6c58c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s227a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" descriptions of how a consumer can use the technologies to protect against such scams and other fraudulent activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcda6c58d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s227a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" details on how consumers can access and use the technologies; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcda6c58e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s227a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide other information that may help consumers identify and avoid scams and other fraudulent activity that rely upon the use of misleading or inaccurate caller identification information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcda6c58f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s227a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall ensure that the consumer education materials required under paragraph (1) are updated on a regular basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcda6c590-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s227a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Website","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall include the consumer education materials developed under paragraph (1) on its website.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcda6c591-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dP/tV/s503/b"},"text":"Pub. L. 115–141, div. P, title V, § 503(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1092"},"text":"132 Stat. 1092","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcda6c592-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcda6c593-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcda6c594-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Repack Airwaves Yielding Better Access for Users of Modern Services Act of 2018, also known as the RAY BAUM’S Act of 2018, and as part of the Consolidated Appropriations Act, 2018, and not as part of the Communications Act of 1934 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcda6c595-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idcda6c596-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “Commission” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dP/s2"},"text":"section 2 of div. P of Pub. L. 115–141","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s155a"},"text":"section 155a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
