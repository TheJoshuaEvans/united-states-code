{"tag":"section","attrib":{"id":"idcdd68804-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s361"},"text":null,"children":[{"tag":"num","attrib":{"value":"361"},"text":"§ 361.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Control by Commission; review of decisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be interpreted as lessening in any degree the control of the Commission over all matters connected with the radio equipment and its operation on shipboard and its decision and determination in regard to the radio requirements, installations, or exemptions from prescribed radio requirements shall be final, subject only to review in accordance with law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcdd68805-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title III, § 363, formerly § 361, as added "},{"tag":"ref","attrib":{"href":"/us/act/1937-05-20/ch229/s10/b"},"text":"May 20, 1937, ch. 229, § 10(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/196"},"text":"50 Stat. 196","children":[],"tail":"; renumbered § 363, "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-13/ch729/s2/a/1"},"text":"Aug. 13, 1954, ch. 729, § 2(a)(1)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/706"},"text":"68 Stat. 706","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcdd68806-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcdd68807-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcdd68808-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1937-05-20"},"text":"May 20, 1937","children":[],"tail":", see section 16 of act "},{"tag":"date","attrib":{"date":"1937-05-20"},"text":"May 20, 1937","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s351"},"text":"section 351 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
