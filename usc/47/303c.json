{"tag":"section","attrib":{"id":"idd262d63f-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s303c"},"text":null,"children":[{"tag":"num","attrib":{"value":"303c"},"text":"§ 303c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Television program improvement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd262d640-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s303c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may be cited as the “Television Program Improvement Act of 1990”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd262d641-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s303c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd262d642-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s303c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “antitrust laws” has the meaning given it in subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s12"},"text":"section 12 of title 15","children":[],"tail":", except that such term includes "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s45"},"text":"section 45 of title 15","children":[],"tail":" to the extent that "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s45"},"text":"section 45 of title 15","children":[],"tail":" applies to unfair methods of competition;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd262d643-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s303c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “person in the television industry” means a television network, any entity which produces programming (including theatrical motion pictures) for telecasting or telecasts programming, the National Cable Television Association, the Association of Independent Television Stations, Incorporated, the National Association of Broadcasters, the Motion Picture Association of America, the Community Antenna Television Association, and each of the networks’ affiliate organizations, and shall include any individual acting on behalf of such person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd262d644-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s303c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “telecast” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd262d645-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s303c/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to broadcast by a television broadcast station; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd262d646-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s303c/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to transmit by a cable television system or a satellite television distribution service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd262d647-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s303c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The antitrust laws shall not apply to any joint discussion, consideration, review, action, or agreement by or among persons in the television industry for the purpose of, and limited to, developing and disseminating voluntary guidelines designed to alleviate the negative impact of violence in telecast material.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd262d648-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s303c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd262d649-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s303c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The exemption provided in subsection (c) shall not apply to any joint discussion, consideration, review, action, or agreement which results in a boycott of any person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd262d64a-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s303c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The exemption provided in subsection (c) shall apply only to any joint discussion, consideration, review, action, or agreement engaged in only during the 3-year period beginning on ","children":[{"tag":"date","attrib":{"date":"1990-12-01"},"text":"December 1, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd262d64b-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/650/tV/s501"},"text":"Pub. L. 101–650, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5127"},"text":"104 Stat. 5127","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd262d64c-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd262d64d-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd262d64e-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Television Program Improvement Act of 1990 and also as part of the Judicial Improvements Act of 1990, and not as part of the Communications Act of 1934 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
