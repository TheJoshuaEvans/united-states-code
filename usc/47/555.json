{"tag":"section","attrib":{"id":"idcdf3102a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s555"},"text":null,"children":[{"tag":"num","attrib":{"value":"555"},"text":"§ 555.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial proceedings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcdf3102b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s555/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions to review determinations by franchising authorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any cable operator adversely affected by any final determination made by a franchising authority under section 541(a)(1), 545 or 546 of this title may commence an action within 120 days after receiving notice of such determination, which may be brought in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcdf3102c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s555/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the district court of the United States for any judicial district in which the cable system is located; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdf3102d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s555/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any State court of general jurisdiction having jurisdiction over the parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdf3102e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s555/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Available relief","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The court may award any appropriate relief consistent with the provisions of the relevant section described in subsection (a) and with the provisions of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdf3102f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s555/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of constitutionality of sections 534 and 535","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcdf31030-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s555/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, any civil action challenging the constitutionality of section 534 or 535 of this title or any provision thereof shall be heard by a district court of three judges convened pursuant to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2284"},"text":"section 2284 of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdf31031-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s555/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, an interlocutory or final judgment, decree, or order of the court of three judges in an action under paragraph (1) holding section 534 or 535 of this title or any provision thereof unconstitutional shall be reviewable as a matter of right by direct appeal to the Supreme Court. Any such appeal shall be filed not more than 20 days after entry of such judgment, decree, or order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcdf31032-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title VI, § 635, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/549/s2"},"text":"Pub. L. 98–549, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2800"},"text":"98 Stat. 2800","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/385"},"text":"Pub. L. 102–385","children":[],"tail":", §§ 7(a)(2), 23, 24(b), "},{"tag":"date","attrib":{"date":"1992-10-05"},"text":"Oct. 5, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1483"},"text":"106 Stat. 1483","children":[],"tail":", 1500, 1501.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcdf31033-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcdf31034-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcdf31035-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/385/s7/a/2"},"text":"Pub. L. 102–385, § 7(a)(2)","children":[],"tail":", inserted “541(a)(1),” after “section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/385/s24/b"},"text":"Pub. L. 102–385, § 24(b)","children":[],"tail":", inserted “and with the provisions of subse