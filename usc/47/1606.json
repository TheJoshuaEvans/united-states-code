{"tag":"section","attrib":{"id":"idd2d56eb8-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1606"},"text":null,"children":[{"tag":"num","attrib":{"value":"1606"},"text":"§ 1606.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2d56eb9-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1606/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A violation of this chapter or a regulation promulgated under this chapter shall be treated as a violation of the Communications Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s151"},"text":"47 U.S.C. 151","children":[],"tail":" et seq.) or a regulation promulgated under such Act, respectively. The Commission shall enforce this chapter and the regulations promulgated under this chapter in the same manner, by the same means, and with the same jurisdiction, powers, and duties as though all applicable terms and provisions of the Communications Act of 1934 were incorporated into and made a part of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2d56eba-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1606/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2d56ebb-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1606/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), in addition to penalties under the Communications Act of 1934, a recipient of a reimbursement under the Program found to have violated ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1603"},"text":"section 1603 of this title","children":[],"tail":", the regulations promulgated under such section, or the commitments made by the recipient in the application for the reimbursement—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2d56ebc-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1606/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall repay to the Commission all reimbursement funds provided to the recipient under the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2d56ebd-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1606/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be barred from further participation in the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2d56ebe-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1606/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be referred to all appropriate law enforcement agencies or officials for further action under applicable criminal and civil laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2d56ebf-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1606/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be barred by the Commission from participation in other programs of the Commission, including the Federal universal service support programs established under section 254 of the Communications Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s254"},"text":"47 U.S.C. 254","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d56ec0-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1606/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and opportunity to cure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The penalties described in paragraph (1) shall not apply to a recipient of a reimbursement under the Program unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2d56ec1-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1606/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commission provides the recipient with notice of the violation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2d56ec2-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1606/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient fails to cure the violation within 180 days after the Commission provides such notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2d56ec3-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1606/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall immediately take action to recover all reimbursement funds awarded to a recipient of a reimbursement under the Program in any case in which such recipient is required to repay reimbursement funds under subsection (b)(1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2d56ec4-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/124/s7"},"text":"Pub. L. 116–124, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-12"},"text":"Mar. 12, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/167"},"text":"134 Stat. 167","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2d56ec5-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2d56ec6-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd2d56ec7-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Communications Act of 1934, referred to in subsecs. (a) and (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"act June 19, 1934, ch. 652","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1064"},"text":"48 Stat. 1064","children":[],"tail":", which is classified principally to chapter 5 (§ 151 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s609"},"text":"section 609 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
