{"tag":"section","attrib":{"id":"idce16ec52-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1010"},"text":null,"children":[{"tag":"num","attrib":{"value":"1010"},"text":"§ 1010.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idce16ec53-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1010/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports by Attorney General","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce16ec54-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1010/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On or before ","children":[{"tag":"date","attrib":{"date":"1995-11-30"},"text":"November 30, 1995","children":[],"tail":", and on or before November 30 of each year thereafter, the Attorney General shall submit to Congress and make available to the public a report on the amounts paid during the preceding fiscal year to telecommunications carriers under sections 1003(e) and 1008 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce16ec55-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1010/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A report under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce16ec56-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1010/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed accounting of the amounts paid to each carrier and the equipment, facility, or service for which the amounts were paid; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce16ec57-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1010/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projections of the amounts expected to be paid in the current fiscal year, the carriers to which payment is expected to be made, and the equipment, facilities, or services for which payment is expected to be made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce16ec58-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1010/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports by Comptroller General and Inspector General","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce16ec59-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1010/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" On or before ","children":[{"tag":"date","attrib":{"date":"1996-04-01"},"text":"April 1, 1996","children":[],"tail":", the Comptroller General of the United States, and every two years thereafter, the Inspector General of the Department of Justice, shall submit to the Congress a report, after consultation with the Attorney General and the telecommunications industry—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce16ec5a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1010/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing the type of equipment, facilities, and services that have been brought into compliance under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce16ec5b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1010/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflecting its analysis of the reasonableness and cost-effectiveness of the payments made by the Attorney General to telecommunications carriers for modifications necessary to ensure compliance with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce16ec5c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1010/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance cost estimates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A report under paragraph (1) shall include findings and conclusions on the costs to be incurred by telecommunications carriers to comply with the assistance capability requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1002"},"text":"section 1002 of this title","children":[],"tail":" after the effective date of such "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s1002"},"text":"section 1002 of this title","children":[],"tail":", including projections of the amounts expected to be incurred and a description of the equipment, facilities, or services for which they are expected to be incurred."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idce16ec5d-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/414/tI/s112"},"text":"Pub. L. 103–414, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4288"},"text":"108 Stat. 4288","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/316/tI/s126/b"},"text":"Pub. L. 104–316, title I, § 126(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3840"},"text":"110 Stat. 3840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idce16ec5e-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idce16ec5f-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idce16ec60-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The effective date of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1002"},"text":"section 1002 of this title","children":[],"tail":", referred to in subsec. (b)(2), is the date that is 4 years after "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/414/s111/b"},"text":"section 111(b) of Pub. L. 103–414","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idce16ec61-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316/s126/b/1"},"text":"Pub. L. 104–316, § 126(b)(1)","children":[],"tail":", inserted introductory provisions and struck out heading and text of former introductory provisions. Text read as follows: “On or before "},{"tag":"date","attrib":{"date":"1996-04-01"},"text":"April 1, 1996","children":[],"tail":", and every 2 years thereafter, the Comptroller General of the United States, after consultation with the Attorney General and the telecommunications industry, shall submit to the Congress a report—”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316/s126/b/2"},"text":"Pub. L. 104–316, § 126(b)(2)","children":[],"tail":", substituted “findings and conclusions” for “the findings and conclusions of the Comptroller General”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
