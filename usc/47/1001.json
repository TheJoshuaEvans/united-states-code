{"tag":"section","attrib":{"id":"idce147bbb-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1001"},"text":null,"children":[{"tag":"num","attrib":{"value":"1001"},"text":"§ 1001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce147bbc-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1001/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2510"},"text":"section 2510 of title 18","children":[],"tail":" have, respectively, the meanings stated in that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce147bbd-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1001/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “call-identifying information” means dialing or signaling information that identifies the origin, direction, destination, or termination of each communication generated or received by a subscriber by means of any equipment, facility, or service of a telecommunications carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce147bbe-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1001/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Commission” means the Federal Communications Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce147bbf-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1001/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “electronic messaging services” means software-based services that enable the sharing of data, images, sound, writing, or other information among computing devices controlled by the senders or recipients of the messages.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce147bc0-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1001/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “government” means the government of the United States and any agency or instrumentality thereof, the District of Columbia, any commonwealth, territory, or possession of the United States, and any State or political subdivision thereof authorized by law to conduct electronic surveillance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce147bc1-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1001/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “information services”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce147bc2-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1001/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means the offering of a capability for generating, acquiring, storing, transforming, processing, retrieving, utilizing, or making available information via telecommunications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce147bc3-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1001/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idce147bc4-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1001/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a service that permits a customer to retrieve stored information from, or file information for storage in, information storage facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce147bc5-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1001/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electronic publishing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce147bc6-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1001/6/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electronic messaging services; but","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce147bc7-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1001/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include any capability for a telecommunications carrier’s internal management, control, or operation of its telecommunications network.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce147bc8-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1001/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “telecommunications support services” means a product, software, or service used by a telecommunications carrier for the internal signaling or switching functions of its telecommunications network.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce147bc9-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1001/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “telecommunications carrier”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce147bca-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1001/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a person or entity engaged in the transmission or switching of wire or electronic communications as a common carrier for hire; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce147bcb-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1001/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idce147bcc-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1001/8/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person or entity engaged in providing commercial mobile service (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s332/d"},"text":"section 332(d) of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce147bcd-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1001/8/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person or entity engaged in providing wire or electronic communication switching or transmission service to the extent that the Commission finds that such service is a replacement for a substantial portion of the local telephone exchange service and that it is in the public interest to deem such a person or entity to be a telecommunications carrier for purposes of this subchapter; but","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce147bce-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1001/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idce147bcf-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1001/8/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" persons or entities insofar as they are engaged in providing information services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce147bd0-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1001/8/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any class or category of telecommunications carriers that the Commission exempts by rule after consultation with the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idce147bd1-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/414/tI/s102"},"text":"Pub. L. 103–414, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4279"},"text":"108 Stat. 4279","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idce147bd2-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idce147bd3-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idce147bd4-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/414/tI/s111"},"text":"Pub. L. 103–414, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4288"},"text":"108 Stat. 4288","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/414/tI/s111"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), this title [enacting this subchapter and provisions set out below] shall take effect on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance Capability and Systems Security and Integrity Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Sections 103 and 105 of this title [enacting sections 1002 and 1004 of this title] shall take effect on the date that is 4 years after the date of enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idce147bd5-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/414/tI/s101"},"text":"Pub. L. 103–414, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4279"},"text":"108 Stat. 4279","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/414/tI/s101"},"text":"“This title [enacting this subchapter and provisions set out as a note above] may be cited as the ‘Communications Assistance for Law Enforcement Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
