{"tag":"section","attrib":{"id":"idd2ce420f-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1430"},"text":null,"children":[{"tag":"num","attrib":{"value":"1430"},"text":"§ 1430.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2ce4210-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1430/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2012-02-22"},"text":"February 22, 2012","children":[],"tail":", and each year thereafter, the First Responder Network Authority shall submit an annual report covering the preceding fiscal year to the appropriate committees of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2ce4211-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1430/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2ce4212-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1430/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comprehensive and detailed report of the operations, activities, financial condition, and accomplishments of the First Responder Network Authority under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2ce4213-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1430/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such recommendations or proposals for legislative or administrative action as the First Responder Network Authority deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2ce4214-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1430/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability to testify","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The members of the Board and employees of the First Responder Network Authority shall be available to testify before the appropriate committees of the Congress with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2ce4215-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1430/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the report required under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2ce4216-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1430/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the report of any audit conducted under section 1429 ","children":[{"tag":"ref","attrib":{"idref":"fn002066"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002066"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2ce4217-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1430/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other matter which such committees may determine appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2ce4218-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/96/tVI/s6210"},"text":"Pub. L. 112–96, title VI, § 6210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/217"},"text":"126 Stat. 217","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2ce4219-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2ce421a-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd2ce421b-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1429"},"text":"Section 1429 of this title","children":[],"tail":", referred to in subsec. (c)(2), was in the original a reference to "},{"tag":"ref","attrib":{"href":"/us/pl/112/96/s6210"},"text":"section 6210 of Pub. L. 112–96","children":[],"tail":", this section, and was translated as if it had been a reference to "},{"tag":"ref","attrib":{"href":"/us/pl/112/96/s6209"},"text":"section 6209 of Pub. L. 112–96","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s1429"},"text":"section 1429 of this title","children":[],"tail":", to reflect the probable intent of 