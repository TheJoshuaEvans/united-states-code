{"tag":"section","attrib":{"id":"idd2d56eff-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1701"},"text":null,"children":[{"tag":"num","attrib":{"value":"1701"},"text":"§ 1701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress finds the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2d56f00-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1701/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Access to affordable, reliable, high-speed broadband is essential to full participation in modern life in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d56f01-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1701/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The persistent “digital divide” in the United States is a barrier to the economic competitiveness of the United States and equitable distribution of essential public services, including health care and education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d56f02-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1701/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The digital divide disproportionately affects communities of color, lower-income areas, and rural areas, and the benefits of broadband should be broadly enjoyed by all.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d56f03-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1701/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In many communities across the country, increased competition among broadband providers has the potential to offer consumers more affordable, high-quality options for broadband service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d56f04-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1701/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The 2019 novel coronavirus pandemic has underscored the critical importance of affordable, high-speed broadband for individuals, families, and communities to be able to work, learn, and connect remotely while supporting social distancing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2d56f05-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dF/tI/s60101"},"text":"Pub. L. 117–58, div. F, title I, § 60101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1182"},"text":"135 Stat. 1182","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2d56f06-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd2d56f07-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idd2d56f08-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dF/tIII/s60301"},"text":"Pub. L. 117–58, div. F, title III, § 60301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1209"},"text":"135 Stat. 1209","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/58/dF/tIII/s60301"},"text":"“This title [enacting subchapter II of this chapter] may be cited as the ‘Digital Equity Act of 2021’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
