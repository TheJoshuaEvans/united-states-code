{"tag":"section","attrib":{"id":"idcd809fa0-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s36"},"text":null,"children":[{"tag":"num","attrib":{"value":"36"},"text":"§ 36.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preventing landing or operating of cables; injunction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President is empowered to prevent the landing of any cable about to be landed in violation of sections 34 to 39 of this title. When any such cable is about to be or is landed or is being operated without a license, any district court of the United States exercising jurisdiction in the district in which such cable is about to be or is landed, or any district court of the United States having jurisdiction of the parties, shall have jurisdiction, at the suit of the United States, to enjoin the landing or operation of such cable or to compel, by injunction, the removal thereof.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcd809fa1-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-05-27/ch12/s3"},"text":"May 27, 1921, ch. 12, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/8"},"text":"42 Stat. 8","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcd809fa2-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcd809fa3-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcd809fa4-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Submarine Cable Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idcd809fa5-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"idcd809fa6-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions vested in President by this section to Federal Communications Commission, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s34"},"text":"section 34 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
