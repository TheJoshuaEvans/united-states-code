{"tag":"section","attrib":{"id":"idce22d44f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1451"},"text":null,"children":[{"tag":"num","attrib":{"value":"1451"},"text":"§ 1451.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadlines for auction of certain spectrum","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idce22d450-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1451/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clearing certain Federal spectrum","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce22d451-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1451/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce22d452-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1451/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2012-02-22"},"text":"February 22, 2012","children":[],"tail":", begin the process of withdrawing or modifying the assignment to a Federal Government station of the electromagnetic spectrum described in paragraph (2); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce22d453-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1451/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 30 days after completing the withdrawal or modification, notify the Commission that the withdrawal or modification is complete.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce22d454-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1451/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spectrum described","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The electromagnetic spectrum described in this paragraph is the 15 megahertz of spectrum between 1675 megahertz and 1710 megahertz identified under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce22d455-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1451/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification by Secretary of Commerce","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2012-02-22"},"text":"February 22, 2012","children":[],"tail":", the Secretary of Commerce shall submit to the President a report identifying 15 megahertz of spectrum between 1675 megahertz and 1710 megahertz for reallocation from Federal use to non-Federal use."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce22d456-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1451/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallocation and auction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce22d457-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1451/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraph (15)(A) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s309/j"},"text":"section 309(j) of this title","children":[],"tail":", not later than 3 years after "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"February 22, 2012","children":[],"tail":", the Commission shall, except as provided in paragraph (4)—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce22d458-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1451/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allocate the spectrum described in paragraph (2) for commercial use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce22d459-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1451/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through a system of competitive bidding under such section, grant new initial licenses for the use of such spectrum, subject to flexible-use service rules.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce251d4a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1451/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spectrum described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The spectrum described in this paragraph is the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce251d4b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1451/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The frequencies between 1915 megahertz and 1920 megahertz.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce251d4c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1451/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The frequencies between 1995 megahertz and 2000 megahertz.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce251d4d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1451/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The frequencies described in subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce251d4e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1451/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The frequencies between 2155 megahertz and 2180 megahertz.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce251d4f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1451/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fifteen megahertz of contiguous spectrum to be identified by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce251d50-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1451/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proceeds to cover 110 percent of Federal relocation or sharing costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in paragraph (1) shall be construed to relieve the Commission from the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s309/j/16/B"},"text":"section 309(j)(16)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce251d51-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1451/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination by Commission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Commission determines that the band of frequencies described in paragraph (2)(A) or the band of frequencies described in paragraph (2)(B) cannot be used without causing harmful interference to commercial mobile service licensees in the frequencies between 1930 megahertz and 1995 megahertz, the Commission may not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce251d52-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1451/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allocate such band for commercial use under paragraph (1)(A); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce251d53-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1451/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant licenses under paragraph (1)(B) for the use of such band.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce251d54-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1451/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"chil