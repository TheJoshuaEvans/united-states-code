{"tag":"section","attrib":{"id":"idd2bd79ef-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s926"},"text":null,"children":[{"tag":"num","attrib":{"value":"926"},"text":"§ 926.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to recover reassigned frequencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2bd79f0-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s926/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of President","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsequent to the withdrawal of assignment to Federal Government stations pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s924"},"text":"section 924 of this title","children":[],"tail":", the President may reclaim reassigned frequencies for reassignment to Federal Government stations in accordance with this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2bd79f1-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s926/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure for reclaiming frequencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2bd79f2-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s926/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unallocated frequencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the frequencies to be reclaimed have not been allocated or assigned by the Commission pursuant to the 1934 Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s151"},"text":"47 U.S.C. 151","children":[],"tail":" et seq.], the President shall follow the procedures for substitution of frequencies established by "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s924/b"},"text":"section 924(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2bd79f3-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s926/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocated frequencies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the frequencies to be reclaimed have been allocated or assigned by the Commission, the President shall follow the procedures for substitution of frequencies established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s924/b"},"text":"section 924(b) of this title","children":[],"tail":", except that the statement required by "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s924/b/1/B"},"text":"section 924(b)(1)(B) of this title","children":[],"tail":" shall include—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2bd79f4-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s926/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a timetable to accommodate an orderly transition for licensees to obtain new frequencies and equipment necessary for its utilization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2bd79f5-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s926/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the cost of displacing spectrum users licensed by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2bd79f6-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s926/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs of reclaiming frequencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Government shall bear all costs of reclaiming frequencies pursuant to this section, including the cost of equipment which is rendered unusable, the cost of relocating operations to a different frequency, and any other costs that are directly attributable to the reclaiming of the frequency pursuant to this section, and there are authorized to be appropriated such sums as may be necessary to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2bd79f7-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s926/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date of reclaimed frequencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall not withdraw licenses for any reclaimed frequencies until the end of the fiscal year following the fiscal year in which a statement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s924/b/1/B"},"text":"section 924(b)(1)(B) of this title","children":[],"tail":" pertaining to such frequencies is received by the Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2bd79f8-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s926/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to limit or otherwise affect the authority of the President under section 706 of the 1934 Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s606"},"text":"47 U.S.C. 606","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2bd79f9-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/538/tI/s116"},"text":"Pub. L. 102–538, title I, § 116","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tVI/s6001/a/3"},"text":"Pub. L. 103–66, title VI, § 6001(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/386"},"text":"107 Stat. 386","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2bd79fa-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2bd79fb-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd2bd79fc-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of the 1934 Act, referred to in subsec. (b)(1), see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s921/3"},"text":"section 921(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
