{"tag":"section","attrib":{"id":"idd281f6ee-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s356"},"text":null,"children":[{"tag":"num","attrib":{"value":"356"},"text":"§ 356.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of installations by Commission","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Insofar as is necessary to carry out the purposes and requirements of this part, the Commission shall have authority, for any ship subject to this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd281f6ef-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s356/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To approve the details as to the location and manner of installations of the equipment required by this part or of equipment necessitated by reason of the purposes and requirements of this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd281f6f0-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s356/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To approve installations, apparatus, and spare parts necessary to comply with the purposes and requirements of this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd281f6f1-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s356/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To prescribe such additional equipment as may be determined to be necessary to supplement that specified in this part, for the proper functioning of the radio installation installed in accordance with this part or for the proper conduct of radio communication in time of emergency or distress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd281f6f2-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title III, § 358, formerly § 356, as added "},{"tag":"ref","attrib":{"href":"/us/act/1937-05-20/ch229/s10/b"},"text":"May 20, 1937, ch. 229, § 10(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/194"},"text":"50 Stat. 194","children":[],"tail":"; renumbered § 358, "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-13/ch729/s2/a/1"},"text":"Aug. 13, 1954, ch. 729, § 2(a)(1)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/706"},"text":"68 Stat. 706","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/414/tIII/s303/a/19"},"text":"Pub. L. 103–414, title III, § 303(a)(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4295"},"text":"108 Stat. 4295","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd281f6f3-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd281f6f4-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd281f6f5-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part, referred to in text, commences with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s351"},"text":"section 351 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"am