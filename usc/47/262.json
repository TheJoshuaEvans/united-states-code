{"tag":"section","attrib":{"id":"idcdb06257-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s262"},"text":null,"children":[{"tag":"num","attrib":{"value":"262"},"text":"§ 262.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ensuring the integrity of voice communications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcdb06258-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s262/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration and compliance by intermediate providers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An intermediate provider that offers or holds itself out as offering the capability to transmit covered voice communications from one destination to another and that charges any rate to any other entity (including an affiliated entity) for the transmission shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcdb06259-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s262/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" register with the Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdb0625a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s262/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with the service quality standards for such transmission to be established by the Commission under subsection (c)(1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdb0625b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s262/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required use of registered intermediate providers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A covered provider may not use an intermediate provider to transmit covered voice communications unless such intermediate provider is registered under subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdb0625c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s262/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcdb0625d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s262/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcdb0625e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s262/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registry","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2018-02-26"},"text":"February 26, 2018","children":[],"tail":", the Commission shall promulgate rules to establish a registry to record registrations under subsection (a)(1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcdb0625f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s262/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service quality standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2018-02-26"},"text":"February 26, 2018","children":[],"tail":", the Commission shall promulgate rules to establish service quality standards for the transmission of covered voice communications by intermediate providers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdb06260-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s262/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In promulgating the rules required by paragraph (1), the Commission shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcdb06261-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s262/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the integrity of the transmission of covered voice communications to all customers in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcdb06262-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s262/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent unjust or unreasonable discrimination among areas of the United States in the delivery of covered voice communications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdb06263-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s262/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability of registry","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall make the registry established under subsection (c)(1)(A) publicly available on the website of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdb06264-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s262/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of this section shall apply regardless of the format by which any communication or service is provided, the protocol or format by which the transmission of such communication or service is achieved, or the regulatory classification of such communication or service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdb06265-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s262/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to affect the regulatory classification of any communication or service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdb06266-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s262/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to preempt or expand the authority of a State public utility commission or other relevant State agency to collect data, or investigate and enforce State law and regulations, regarding the completion of intrastate voice communications, regardless of the format by which any communication or service is provided, the protocol or format by which the transmission of such communication or service is achieved, or the regulatory classification of such communication or service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdb06267-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s262/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirement under subsection (a)(2) to comply with the service quality standards established under subsection (c)(1)(B) shall not apply to a covered provider that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcdb06268-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s262/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on or before the date that is 1 year after ","children":[{"tag":"date","attrib":{"date":"2018-02-26"},"text":"February 26, 2018","children":[],"tail":", has certified as a Safe Harbor provider under section 64.2107(a) of title 47, Code of Federal Regulations, or any successor regulation; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdb06269-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s262/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continues to meet the requirements under such section 64.2107(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdb0626a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s262/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcdb0626b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s262/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered provider","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered provider” has the meaning given the term in section 64.2101 of title 47, Code of Federal Regulations, or any successor thereto.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdb0626c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s262/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered voice communication","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered voice communication” means a voice communication (including any related signaling information) that is generated—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcdb0626d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s262/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the placement of a call from a connection using a North American Numbering Plan resource or a call placed to a connection using such a numbering resource; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcdb0626e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s262/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through any service provided by a covered provider.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdb0626f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s262/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intermediate provider","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “intermediate provider” means any entity that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcdb06270-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s262/i/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" enters into a business arrangement with a covered provider or other intermediate provider for the specific purpose of carrying, routing, or transmitting voice traffic that is generated from the placement of a call placed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcdb06271-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s262/i/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from an end user connection using a North American Numbering Plan resource; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcdb06272-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s262/i/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to an end user connection using such a numbering resource; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcdb06273-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s262/i/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not itself, either directly or in conjunction with an affiliate, serve as a covered provider in the context of originating or terminating a given call.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcdb06274-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title II, § 262, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/129/s2"},"text":"Pub. L. 115–129, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-26"},"text":"Feb. 26, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/329"},"text":"132 Stat. 329","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
