{"tag":"section","attrib":{"id":"idd2c4a5e9-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1204"},"text":null,"children":[{"tag":"num","attrib":{"value":"1204"},"text":"§ 1204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program for remote community alert systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2c4a5ea-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1204/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary of Commerce for Oceans and Atmosphere, in consultation with the Secretary of Homeland Security, shall establish a program under which grants may be made to provide for outdoor alerting technologies in remote communities effectively unserved by commercial mobile service (as determined by the Federal Communications Commission within 180 days after ","children":[{"tag":"date","attrib":{"date":"2006-10-13"},"text":"October 13, 2006","children":[],"tail":") for the purpose of enabling residents of those communities to receive emergency alerts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2c4a5eb-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1204/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications and conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the program, the Under Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2c4a5ec-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1204/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall establish a notification and application procedure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2c4a5ed-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1204/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may establish such conditions, and require such assurances, as may be appropriate to ensure the efficiency and integrity of the grant program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2c4a5ee-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1204/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary may not make grants under subsection (a) more than 5 years after ","children":[{"tag":"date","attrib":{"date":"2006-10-13"},"text":"October 13, 2006","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2c4a5ef-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1204/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The sum of the amounts awarded for all fiscal years as grants under this section may not exceed $10,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2c4a5f0-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347/tVI/s605"},"text":"Pub. L. 109–347, title VI, § 605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1940"},"text":"120 Stat. 1940","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
