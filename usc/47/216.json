{"tag":"section","attrib":{"id":"idcd9addfd-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s216"},"text":null,"children":[{"tag":"num","attrib":{"value":"216"},"text":"§ 216.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receivers and trustees; application of chapter","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of this chapter shall apply to all receivers and operating trustees of carriers subject to this chapter to the same extent that it applies to carriers.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcd9addfe-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title II, § 216, "},{"tag":"ref","attrib":{"href":"/us/stat/48/1077"},"text":"48 Stat. 1077","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcd9addff-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcd9ade00-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcd9ade01-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"act June 19, 1934, ch. 652","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1064"},"text":"48 Stat. 1064","children":[],"tail":", known as the Communications Act of 1934, which is classified principally to this chapter. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s609"},"text":"section 609 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
