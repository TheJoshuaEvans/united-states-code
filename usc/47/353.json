{"tag":"section","attrib":{"id":"idd27f86b6-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s353"},"text":null,"children":[{"tag":"num","attrib":{"value":"353"},"text":"§ 353.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Radio equipment and operators","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd27f86b7-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s353/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Two radio officers required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each cargo ship which in accordance with this part is equipped with a radiotelegraph station and which is not equipped with a radiotelegraph auto alarm, and each passenger ship required by this part to be equipped with a radiotelegraph station, shall, for safety purposes, carry at least two radio officers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd27f86b8-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s353/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" One radio officer required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A cargo ship which in accordance with this part is equipped with a radiotelegraph station, which is equipped with a radiotelegraph auto alarm, shall, for safety purposes, carry at least one radio officer who shall have had at least six months’ previous service in the aggregate as a radio officer in a station on board a ship or ships of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd27f86b9-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s353/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required watches","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each ship of the United States which in accordance with this part is equipped with a radiotelegraph station shall, while being navigated in the open sea outside of a harbor or port, keep a continuous watch by means of radio officers whenever the station is not being used for authorized traffic: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That, in lieu thereof, on a cargo ship equipped with a radiotelegraph auto alarm in proper operating condition, a watch of at least eight hours per day, in the aggregate, shall be maintained by means of a radio officer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd27f86ba-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s353/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hours of watch","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall, when it finds it necessary for safety purposes, have authority to prescribe the particular hours of watch on a ship of the United States which in accordance with this part is equipped with a radiotelegraph station.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd27f86bb-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s353/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operational status of auto alarms in open sea","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On all ships of the United States equipped with a radiotelegraph auto alarm, said apparatus shall be in operation at all times while the ship is being navigated in the open sea outside of a harbor or port when the radio officer is not on watch.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd27f86bc-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title III, § 353, as added "},{"tag":"ref","attrib":{"href":"/us/act/1937-05-20/ch229/s10/b"},"text":"May 20, 1937, ch. 229, § 10(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/193"},"text":"50 Stat. 193","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1941-07-08/ch278"},"text":"July 8, 1941, ch. 278","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/579"},"text":"55 Stat. 579","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1943-06-22/ch137"},"text":"June 22, 1943, ch. 137","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/57/161"},"text":"57 Stat. 161","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1947-07-25/ch327/s2/a"},"text":"July 25, 1947, ch. 327, § 2(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/451"},"text":"61 Stat. 451","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-13/ch729/s1/d"},"text":"Aug. 13, 1954, ch. 729, § 1(d)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/705"},"text":"68 Stat. 705","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/121/s4"},"text":"Pub. L. 89–121, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-13"},"text":"Aug. 13, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/513"},"text":"79 Stat. 513","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd27f86bd-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd27f86be-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd27f86bf-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1965—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/121"},"text":"Pub. L. 89–121","children":[],"tail":", among other changes, substituted wherever appearing “radiotelegraph station” for “radiotelegraph installation”, “radiotelegraph auto alarm” for “auto-alarm”, and “radio officer” and “radio officers” for “qualified operator” and “qualified operators”, required a continuous watch to be kept when the radiotelegraph station is not being used for authorized traffic, and inserted “while being navigated in the open sea” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Act ","children":[{"tag":"date","attrib":{"date":"1954-08-13"},"text":"Aug. 13, 1954","children":[],"tail":", amended section to make clear that it applies only to ships equipped with a radiotelegraph installation, not those fitted with a radiotelephone installation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1943—Subsec. (b). Act ","children":[{"tag":"date","attrib":{"date":"1943-06-22"},"text":"June 22, 1943","children":[],"tail":", substituted “the termination of such emergency or such earlier date as Congress by concurrent resolution may designate” for “"},{"tag":"date","attrib":{"date":"1943-06-30"},"text":"June 30, 1943","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1941—Subsec. (b). Act ","children":[{"tag":"date","attrib":{"date":"1941-07-08"},"text":"July 8, 1941","children":[],"tail":", inserted exception respecting national emergency."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd27f86c0-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd27f86c1-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Partial Repeal Effective ","children":[{"tag":"date","attrib":{"date":"1948-07-01"},"text":"July 1, 1948","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"Acts ","children":[{"tag":"date","attrib":{"date":"1941-07-08"},"text":"July 8, 1941","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1943-06-22"},"text":"June 22, 1943","children":[],"tail":", which amended subsec. (b) of this section by adding the clause authorizing suspension or modification of the service requirement during the emergency, were repealed, effective "},{"tag":"date","attrib":{"date":"1948-07-01"},"text":"July 1, 1948","children":[],"tail":", by act "},{"tag":"date","attrib":{"date":"1947-07-25"},"text":"July 25, 1947","children":[],"tail":", which provided that such acts should remain in full force and effect until such date."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd27f86c2-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1937-05-20"},"text":"May 20, 1937","children":[],"tail":", unless deferred by the Commission, see section 16 of act "},{"tag":"date","attrib":{"date":"1937-05-20"},"text":"May 20, 1937","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s351"},"text":"section 351 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd27f86c3-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Approval of Operators by Secretary of Navy During War","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1941-12-17/ch588"},"text":"Act Dec. 17, 1941, ch. 588","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/808"},"text":"55 Stat. 808","children":[],"tail":", as amended "},{"tag":"ref","attrib":{"href":"/us/act/1943-06-28/ch174"},"text":"June 28, 1943, ch. 174","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/57/244"},"text":"57 Stat. 244","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1945-06-13/ch190"},"text":"June 13, 1945, ch. 190","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/259"},"text":"59 Stat. 259","children":[],"tail":"; 1946 Reorg. Plan No. 3, § 101, eff. "},{"tag":"date","attrib":{"date":"1946-07-16"},"text":"July 16, 1946","children":[],"tail":", 11 F.R. 7875, "},{"tag":"ref","attrib":{"href":"/us/stat/60/1097"},"text":"60 Stat. 1097","children":[],"tail":", prohibiting employment of radio operators who were disapproved by the Secretary of the Navy during World War II, was repealed by "},{"tag":"ref","attrib":{"href":"/us/act/1947-07-25/ch327/s1"},"text":"act July 25, 1947, ch. 327, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/449"},"text":"61 Stat. 449","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
