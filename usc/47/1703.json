{"tag":"section","attrib":{"id":"idd2da29a8-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1703"},"text":null,"children":[{"tag":"num","attrib":{"value":"1703"},"text":"§ 1703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Broadband DATA maps","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2da29a9-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “Commission” means the Federal Communications Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2da29aa-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A broadband provider shall provide the Commission with any information, in the format, type, or specification requested by the Commission, necessary to augment the collection of data by the Commission under—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2da29ab-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1703/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" title VIII of the Communications Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s641"},"text":"47 U.S.C. 641","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2da29ac-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1703/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Form 477 data collection program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2da29ad-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1703/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of initial broadband DATA collection filing deadline","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2da29ae-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1703/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide notice to broadband providers not later than 60 days before the initial deadline for submission of data under section 802(a)(1)(A) of the Communications Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s642/a/1/A"},"text":"47 U.S.C. 642(a)(1)(A)","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2da29af-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1703/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding any prior decision of the Commission to the contrary, shall not be required to provide notice not later than 6 months before the initial deadline described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2da29b0-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dF/tI/s60103"},"text":"Pub. L. 117–58, div. F, title I, § 60103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1205"},"text":"135 Stat. 1205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2da29b1-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2da29b2-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd2da29b3-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Communications Act of 1934, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"act June 19, 1934, ch. 652","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1064"},"text":"48 Stat. 1064","children":[],"tail":". Title VIII of the Act is classified generally to subchapter VII (§ 641 et seq.) of chapter 5 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s609"},"text":"section 609 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd2da29b4-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s60103"},"text":"section 60103 of Pub. L. 117–58","children":[],"tail":". Subsecs. (d) and (e) of "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/s60103"},"text":"section 60103 of Pub. L. 117–58","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s642"},"tex