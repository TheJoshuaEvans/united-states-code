{"tag":"section","attrib":{"id":"idce278e53-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1502"},"text":null,"children":[{"tag":"num","attrib":{"value":"1502"},"text":"§ 1502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identifying 255 megahertz","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idce278e54-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce278e55-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2022-12-31"},"text":"December 31, 2022","children":[],"tail":", the Secretary, working through the NTIA, and the Commission shall identify a total of at least 255 megahertz of Federal and non-Federal spectrum for mobile and fixed wireless broadband use."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce278e56-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlicensed and licensed use","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the spectrum identified under paragraph (1), not less than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce278e57-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1502/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 megahertz below the frequency of 8000 megahertz shall be identified for use on an unlicensed basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce278e58-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1502/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 megahertz below the frequency of 6000 megahertz shall be identified for use on an exclusive, licensed basis for commercial mobile use, pursuant to the Commission’s authority to implement such licensing in a flexible manner, and subject to potential continued use of such spectrum by incumbent Federal entities in designated geographic areas indefinitely or for such length of time stipulated in transition plans approved by the Technical Panel under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s923/h"},"text":"section 923(h) of this title","children":[],"tail":" for those incumbent entities to be relocated to alternate spectrum; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce278e59-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1502/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 55 megahertz below the frequency of 8000 megahertz shall be identified for use on either a licensed or unlicensed basis, or a combination of licensed and unlicensed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce278e5a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1502/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-eligible spectrum","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of satisfying the requirement under paragraph (1), the following spectrum shall not be counted:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce278e5b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1502/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The frequencies between 1695 and 1710 megahertz.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce278e5c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1502/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The frequencies between 1755 and 1780 megahertz.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce278e5d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1502/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The frequencies between 2155 and 2180 megahertz.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce278e5e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1502/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The frequencies between 3550 and 3700 megahertz.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce278e5f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1502/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Spectrum that the Commission determines had more than de minimis mobile or fixed wireless broadband operations within the band on the day before ","children":[{"tag":"date","attrib":{"date":"2018-03-23"},"text":"March 23, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce278e60-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1502/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain other spectrum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Spectrum identified pursuant to this section may include eligible spectrum, if any, identified after ","children":[{"tag":"date","attrib":{"date":"2018-03-23"},"text":"March 23, 2018","children":[],"tail":", pursuant to title X of the Bipartisan Budget Act of 2015 ("},{"tag":"ref","attrib":{"href":"/us/pl/114/74"},"text":"Public Law 114–74","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce278e61-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1502/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spectrum made available on and after ","children":[{"tag":"date","attrib":{"date":"2016-02-11"},"text":"February 11, 2016","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any spectrum that has been made available for licensed or unlicensed use on and after ","children":[{"tag":"date","attrib":{"date":"2016-02-11"},"text":"February 11, 2016","children":[],"tail":", and that otherwise satisfies the requirements of this section may be counted towards the requirements of this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce278e62-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1502/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relocation prioritized over sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall be carried out in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s923/j"},"text":"section 923(j) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce278e63-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1502/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In identifying spectrum for use under this section, the Secretary, working through the NTIA, and Commission shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce278e64-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1502/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need to preserve critical existing and planned Federal Government capabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce278e65-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1502/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact on existing State, local, and tribal government capabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce278e66-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1502/a/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the international implications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce278e67-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1502/a/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for appropriate enforcement mechanisms and authorities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce278e68-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1502/a/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the importance of the deployment of wireless broadband services in rural areas of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce278e69-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce278e6a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to impair or otherwise affect the functions of the Director of OMB relating to budgetary, administrative, or legislative proposals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce278e6b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require the disclosure of classified information, law enforcement sensitive information, or other information that must be protected in the interest of national security; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce278e6c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1502/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to affect any requirement under section 156 of the National Telecommunications and Information Administration Organization Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s921"},"text":"47 U.S.C. 921","children":[],"tail":" note), as added by section 1062(a) of the National Defense Authorization Act for Fiscal Year 2000, or any other relevant statutory requirement applicable to the reallocation of Federal spectrum."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idce278e6d-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dP/tVI/s603"},"text":"Pub. L. 115–141, div. P, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1098"},"text":"132 Stat. 1098","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idce278e6e-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idce278e6f-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idce278e70-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Bipartisan Budget Act of 2015, referred to in subsec. (a)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/74"},"text":"Pub. L. 114–74","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-02"},"text":"Nov. 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/584"},"text":"129 Stat. 584","children":[],"tail":". Title X of the Act, known as the Spectrum Pipeline Act of 2015, is title X of "},{"tag":"ref","attrib":{"href":"/us/pl/114/74"},"text":"Pub. L. 114–74","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-02"},"text":"Nov. 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/621"},"text":"129 Stat. 621","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2015 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s901"},"text":"section 901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 156 of the National Telecommunications and Information Administration Organization Act, as added by section 1062(a) of the National Defense Authorization Act for Fiscal Year 2000, referred to in subsec. (b)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/538/tI/s156"},"text":"section 156 of title I of Pub. L. 102–538","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1062/a"},"text":"Pub. L. 106–65, div. A, title X, § 1062(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/767"},"text":"113 Stat. 767","children":[],"tail":", formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s921"},"text":"section 921 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
