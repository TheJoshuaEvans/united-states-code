{"tag":"section","attrib":{"id":"idd29c0f58-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s547"},"text":null,"children":[{"tag":"num","attrib":{"value":"547"},"text":"§ 547.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions of sale","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd29c0f59-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s547/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If a renewal of a franchise held by a cable operator is denied and the franchising authority acquires ownership of the cable system or effects a transfer of ownership of the system to another person, any such acquisition or transfer shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd29c0f5a-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s547/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at fair market value, determined on the basis of the cable system valued as a going concern but with no value allocated to the franchise itself, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd29c0f5b-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s547/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any franchise existing on the effective date of this subchapter, at a price determined in accordance with the franchise if such franchise contains provisions applicable to such an acquisition or transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd29c0f5c-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s547/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If a franchise held by a cable operator is revoked for cause and the franchising authority acquires ownership of the cable system or effects a transfer of ownership of the system to another person, any such acquisition or transfer shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd29c0f5d-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s547/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at an equitable price, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd29c0f5e-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s547/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any franchise existing on the effective date of this subchapter, at a price determined in accordance with the franchise if such franchise contains provisions applicable to such an acquisition or transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd29c0f5f-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title VI, § 627, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/549/s2"},"text":"Pub. L. 98–549, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2793"},"text":"98 Stat. 2793","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd29c0f60-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd29c0f61-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd29c0f62-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For “the effective date of this subchapter”, referred to in subsecs. (a)(2) and (b)(2), as 60 days after ","children":[{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", except where otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/549/s9/a"},"text":"section 9(a) of Pub. L. 98–549","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s521"},"text":"section 521 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd29c0f63-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd29c0f64-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 60 days after ","children":[{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", except where otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/549/s9/a"},"text":"section 9(a) of Pub. L. 98–549","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s521"},"text":"section 521 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
