{"tag":"section","attrib":{"id":"idd23cb135-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s159"},"text":null,"children":[{"tag":"num","attrib":{"value":"159"},"text":"§ 159.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulatory fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd23cb136-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s159/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall assess and collect regulatory fees to recover the costs of carrying out the activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s156/a"},"text":"section 156(a) of this title","children":[],"tail":" only to the extent, and in the total amounts, provided for in Appropriations Acts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd23cb137-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s159/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of schedule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall assess and collect regulatory fees at such rates as the Commission shall establish in a schedule of regulatory fees that will result in the collection, in each fiscal year, of an amount that can reasonably be expected to equal the amounts described in subsection (a) with respect to such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd23cb138-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s159/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment of schedule","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd23cb139-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s159/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each fiscal year, the Commission shall by rule adjust the schedule of regulatory fees established under this section to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd23cb13a-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s159/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflect unexpected increases or decreases in the number of units subject to the payment of such fees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd23cb13b-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s159/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" result in the collection of the amount required by subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd23cb13c-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s159/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rounding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making adjustments under this subsection, the Commission may round fees to the nearest $5 increment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd23cb13d-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s159/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments to schedule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the adjustments required by subsection (c), the Commission shall by rule amend the schedule of regulatory fees established under this section if the Commission determines that the schedule requires amendment so that such fees reflect the full-time equivalent number of employees within the bureaus and offices of the Commission, adjusted to take into account factors that are reasonably related to the benefits provided to the payor of the fee by the Commission’s activities. In making an amendment under this subsection, the Commission may not change the total amount of regulatory fees required by subsection (b) to be collected in a fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd23cb13e-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s159/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd23cb13f-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s159/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parties to which fees are not applicable","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulatory fees established under this section shall not be applicable to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd23cb140-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s159/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a governmental entity or nonprofit entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd23cb141-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s159/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amateur radio operator licensee under part 97 of the Commission’s rules (47 CFR part 97); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd23cb142-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s159/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a noncommercial radio station or noncommercial television station.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd23cb143-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s159/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost of collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, in the judgment of the Commission, the cost of collecting a regulatory fee established under this section from a party would exceed the amount collected from such party, the Commission may exempt such party from paying such fee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd23cb144-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s159/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of collections","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd23cb145-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s159/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts received from fees authorized by this section shall be deposited as an offsetting collection in, and credited to, the account through which funds are made available to carry out the activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s156/a"},"text":"section 156(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd23cb146-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s159/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of excess collections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any regulatory fees collected in excess of the total amount of fees provided for in Appropriations Acts for a fiscal year shall be deposited in the general fund of the Treasury of the United States for the sole purpose of deficit reduction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd23cb147-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title I, § 9, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tVI/s6003/a/1"},"text":"Pub. L. 103–66, title VI, § 6003(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/397"},"text":"107 Stat. 397","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/121/tI"},"text":"Pub. L. 103–121, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-10-27"},"text":"Oct. 27, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1167"},"text":"107 Stat. 1167","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/414/tIII/s303/a/5"},"text":"Pub. L. 103–414, title III, § 303(a)(5)","children":[],"tail":", (6), "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4294"},"text":"108 Stat. 4294","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dP/tI/s102/b"},"text":"Pub. L. 115–141, div. P, title I, § 102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1083"},"text":"132 Stat. 1083","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd23cb148-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd23cb149-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd23cb14a-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" amended section generally. Prior to amendment, section related to regulatory fees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/414/s303/a/5"},"text":"Pub. L. 103–414, § 303(a)(5)","children":[],"tail":", designated second sentence of par. (1) as par. (2) and inserted par. (2) heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/414/s303/a/6"},"text":"Pub. L. 103–414, § 303(a)(6)","children":[],"tail":", inserted “95” after “(47 C.F.R. Part” in item pertaining to Interactive Video Data Service under Private Radio Bureau in Schedule of Regulatory Fees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/121"},"text":"Pub. L. 103–121","children":[],"tail":" designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd23cb14b-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd23cb14c-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2018-10-01"},"text":"Oct. 1, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dP/s103"},"text":"section 103 of div. P of Pub. L. 115–141","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s156"},"text":"section 156 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd23cb14d-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Continued Applicability of Regulatory Fees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dP/tI/s102/d/2"},"text":"Pub. L. 115–141, div. P, title I, § 102(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1086"},"text":"132 Stat. 1086","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/141/dP/tI/s102/d/2"},"text":"“A regulatory fee established under section 9 of the Communications Act of 1934 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s159"},"text":"47 U.S.C. 159","children":[],"tail":"], as such section is in effect on the day before the effective date described in "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s103"},"text":"section 103 of this title","children":[],"tail":" ["},{"tag":"date","attrib":{"date":"2018-10-01"},"text":"Oct. 1, 2018","children":[],"tail":"], shall remain in effect under section 9 of the Communications Act of 1934, as amended by subsection (b) of this section, until such time as the Commission [Federal Communications Commission] adjusts or amends such fee under subsection (c) or (d) of such section 9, as so amended.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd23cb14e-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rulemaking To Amend Schedule of Regulatory Fees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dP/tI/s102/e/1"},"text":"Pub. L. 115–141, div. P, title I, § 102(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1086"},"text":"132 Stat. 1086","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/141/dP/tI/s102/e/1"},"text":"“Not later than 1 year after the effective date described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s103"},"text":"section 103 of this title","children":[],"tail":" ["},{"tag":"date","attrib":{"date":"2018-10-01"},"text":"Oct. 1, 2018","children":[],"tail":"], the Commission [Federal Communications Commission] shall complete a rulemaking proceeding under subsection (d) of section 9 of the Communications Act of 1934 ["},{"tag":"ref","attrib":{"href":"/us/usc/t47/s159"},"text":"47 U.S.C. 159","children":[],"tail":"], as amended by subsection (b) of this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
