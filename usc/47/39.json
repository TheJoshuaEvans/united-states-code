{"tag":"section","attrib":{"id":"idcd809fb2-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s39"},"text":null,"children":[{"tag":"num","attrib":{"value":"39"},"text":"§ 39.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment, modification, etc., of rights granted","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No right shall accrue to any government, person, or corporation under the terms of sections 34 to 39 of this title that may not be rescinded, changed, modified, or amended by the Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcd809fb3-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-05-27/ch12/s6"},"text":"May 27, 1921, ch. 12, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/9"},"text":"42 Stat. 9","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcd809fb4-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcd809fb5-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcd809fb6-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Submarine Cable Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
