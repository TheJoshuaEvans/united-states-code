{"tag":"section","attrib":{"id":"idce22d374-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1425"},"text":null,"children":[{"tag":"num","attrib":{"value":"1425"},"text":"§ 1425.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory committees of the First Responder Network Authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idce22d375-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1425/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The First Responder Network Authority—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce22d376-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1425/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall establish a standing public safety advisory committee to assist the First Responder Network Authority in carrying out its duties and responsibilities under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce22d377-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1425/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may establish additional standing or ad hoc committees, panels, or councils as the First Responder Network Authority determines are necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce22d378-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1425/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of agents, consultants, and experts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce22d379-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1425/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The First Responder Network Authority shall select parties to serve as its agents, consultants, or experts in a fair, transparent, and objective manner, and such agents may include a program manager to carry out certain of the duties and responsibilities of deploying and operating the nationwide public safety broadband network described in subsections (b) and (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1426"},"text":"section 1426 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce22d37a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1425/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Binding and final","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the selection of an agent, consultant, or expert satisfies the requirements under paragraph (1), the selection of that agent, consultant, or expert shall be final and binding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idce22d37b-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/96/tVI/s6205"},"text":"Pub. L. 112–96, title VI, § 6205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/211"},"text":"126 Stat. 211","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
