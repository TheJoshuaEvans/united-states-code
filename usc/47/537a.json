{"tag":"section","attrib":{"id":"idd297541b-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s537a"},"text":null,"children":[{"tag":"num","attrib":{"value":"537a"},"text":"§ 537a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carriage of certain programming","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd297541c-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s537a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd297541d-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s537a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “local commercial television station” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s534/h"},"text":"section 534(h) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd297541e-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s537a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “multichannel video programming distributor” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s522"},"text":"section 522 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd297541f-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s537a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “qualified noncommercial educational television station” has the meaning given the term in section 535(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2975420-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s537a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “retransmission consent” means the authority granted to a multichannel video programming distributor under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s325/b"},"text":"section 325(b) of this title","children":[],"tail":" to retransmit the signal of a television broadcast station; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2975421-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s537a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “television broadcast station” has the meaning given the term in section 76.66(a) of title 47, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2975422-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s537a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carriage of certain content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, a multichannel video programming distributor may not be directly or indirectly required, including as a condition of obtaining retransmission consent, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2975423-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s537a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry non-incidental video content from a local commercial television station, qualified noncommercial educational television station, or television broadcast station to the extent that such content is owned, controlled, or financed (in whole or in part) by the Government of the Russian Federation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2975424-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s537a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lease, or otherwise make available, channel capacity to any person for the provision of video programming that is owned, controlled, or financed (in whole or in part) by the Government of the Russian Federation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2975425-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s537a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed as applying to the editorial use by a local commercial television station, qualified noncommercial educational television station, or television broadcast station of programming that is owned, controlled, or financed (in whole or in part) by the Government of the Russian Federation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2975426-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1093"},"text":"Pub. L. 115–91, div. A, title X, § 1093","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1611"},"text":"131 Stat. 1611","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2975427-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2975428-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd2975429-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Defense Authorization Act for Fiscal Year 2018, and not as part of the Communications Act of 1934 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
