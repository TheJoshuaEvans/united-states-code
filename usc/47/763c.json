{"tag":"section","attrib":{"id":"idd2b192b1-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s763c"},"text":null,"children":[{"tag":"num","attrib":{"value":"763c"},"text":"§ 763c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Space segment capacity of the GMDSS","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The United States shall preserve the space segment capacity of the GMDSS. This section is not intended to alter the status that the GMDSS would otherwise have under United States laws and regulations of the International Telecommunication Union with respect to spectrum, orbital locations, or other operational parameters, or to be a barrier to competition for the provision of GMDSS services.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd2b192b2-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/624/tVI/s624"},"text":"Pub. L. 87–624, title VI, § 624","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/180/s3"},"text":"Pub. L. 106–180, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-03-17"},"text":"Mar. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/54"},"text":"114 Stat. 54","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/34/s3"},"text":"Pub. L. 109–34, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-07-12"},"text":"July 12, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/377"},"text":"119 Stat. 377","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2b192b3-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2b192b4-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd2b192b5-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/34"},"text":"Pub. L. 109–34","children":[],"tail":" amended section catchline and text generally, substituting provisions relating to space segment capacity of the GMDSS for provisions relating to specific criteria for Inmarsat privatization."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
