{"tag":"section","attrib":{"id":"idd2ce4221-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1432"},"text":null,"children":[{"tag":"num","attrib":{"value":"1432"},"text":"§ 1432.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on direct offering of commercial telecommunications service directly to consumers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2ce4222-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1432/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The First Responder Network Authority shall not offer, provide, or market commercial telecommunications or information services directly to consumers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2ce4223-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1432/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to prohibit the First Responder Network Authority and a secondary user from entering into a covered leasing agreement pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1428/a/2/B"},"text":"section 1428(a)(2)(B) of this title","children":[],"tail":". Nothing in this section shall be construed to limit the First Responder Network Authority from collecting lease fees related to network equipment and infrastructure pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s1428/a/3"},"text":"section 1428(a)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2ce4224-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/96/tVI/s6212"},"text":"Pub. L. 112–96, title VI, § 6212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/218"},"text":"126 Stat. 218","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
