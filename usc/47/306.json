{"tag":"section","attrib":{"id":"idcdb9d86f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s306"},"text":null,"children":[{"tag":"num","attrib":{"value":"306"},"text":"§ 306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign ships; application of section 301","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s301"},"text":"Section 301 of this title","children":[],"tail":" shall not apply to any person sending radio communications or signals on a foreign ship while the same is within the jurisdiction of the United States, but such communications or signals shall be transmitted only in accordance with such regulations designed to prevent interference as may be promulgated under the authority of this chapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcdb9d870-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title III, § 306, "},{"tag":"ref","attrib":{"href":"/us/stat/48/1083"},"text":"48 Stat. 1083","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcdb9d871-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcdb9d872-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcdb9d873-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"act June 19, 1934, ch. 652","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1064"},"text":"48 Stat. 1064","children":[],"tail":", known as the Communications Act of 1934, which is classified principally to this chapter. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s609"},"text":"section 609 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
