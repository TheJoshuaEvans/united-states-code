{"tag":"section","attrib":{"id":"idd281f6e7-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s355"},"text":null,"children":[{"tag":"num","attrib":{"value":"355"},"text":"§ 355.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survival craft","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every ship required to be provided with survival craft radio by treaty to which the United States is a party, by statute, or by regulation made in conformity with a treaty, convention, or statute, shall be fitted with efficient radio equipment appropriate to such requirement under such rules and regulations as the Commission may find necessary for safety of life. For purposes of this section, “radio equipment” shall include portable as well as nonportable apparatus.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd281f6e8-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title III, § 357, formerly § 355, as added "},{"tag":"ref","attrib":{"href":"/us/act/1937-05-20/ch229/s10/b"},"text":"May 20, 1937, ch. 229, § 10(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/194"},"text":"50 Stat. 194","children":[],"tail":"; renumbered § 357 and amended "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-13/ch729/s2/a/1"},"text":"Aug. 13, 1954, ch. 729, § 2(a)(1)","children":[],"tail":", (e), "},{"tag":"ref","attrib":{"href":"/us/stat/68/706"},"text":"68 Stat. 706","children":[],"tail":", 707; "},{"tag":"ref","attrib":{"href":"/us/pl/89/121/s8"},"text":"Pub. L. 89–121, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-13"},"text":"Aug. 13, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/516"},"text":"79 Stat. 516","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd281f6e9-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd281f6ea-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd281f6eb-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1965—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/121"},"text":"Pub. L. 89–121","children":[],"tail":" substituted “survival craft” for “lifeboat”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Act ","children":[{"tag":"date","attrib":{"date":"1954-08-13"},"text":"Aug. 13, 1954","children":[],"tail":", § 2(a)(1), amended credit to section by changing section number from “355” to “357” of act "},{"tag":"date","attrib":{"date":"1934-06-19"},"text":"June 19, 1934","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1954-08-13"},"text":"Aug. 13, 1954","children":[],"tail":", § 2(e), provided that lifeboats be equipped with “radio equipment” rather than a “radio installation” and defined “radio equipment” as including portable as well as nonportable apparatus."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd281f6ec-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd281f6ed-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1937-05-20"},"text":"May 20, 1937","children":[],"tail":", unless deferred by the Commission, see section 16 of act "},{"tag":"date","attrib":{"date":"1937-05-20"},"text":"May 20, 1937","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s351"},"text":"section 351 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
