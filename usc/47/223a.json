{"tag":"section","attrib":{"id":"idcd9f98e5-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s223a"},"text":null,"children":[{"tag":"num","attrib":{"value":"223a"},"text":"§ 223a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and removal of nonconsensual intimate visual depictions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcd9f98e6-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s223a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcd9f98e7-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s223a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and removal process","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcd9f98e8-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s223a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2025-05-19"},"text":"May 19, 2025","children":[],"tail":", a covered platform shall establish a process whereby an identifiable individual (or an authorized person acting on behalf of such individual) may—"}],"tail":null},{"tag":"clause","attrib":{"id":"idcd9f98e9-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s223a/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" notify the covered platform of an intimate visual depiction published on the covered platform that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idcd9f98ea-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s223a/a/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a depiction of the identifiable individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcd9f98eb-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s223a/a/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was published without the consent of the identifiable individual; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcd9f98ec-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s223a/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit a request for the covered platform to remove such intimate visual depiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcd9f98ed-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s223a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A notification and request for removal of an intimate visual depiction submitted under the process established under subparagraph (A) shall include, in writing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcd9f98ee-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s223a/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a physical or electronic signature of the identifiable individual (or an authorized person acting on behalf of such individual);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcd9f98ef-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s223a/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of, and information reasonably sufficient for the covered platform to locate, the intimate visual depiction of the identifiable individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcd9f98f0-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s223a/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a brief statement that the identifiable individual has a good faith belief that any intimate visual depiction identified under clause (ii) is not consensual, including any relevant information for the covered platform to determine the intimate visual depiction was published without the consent of the identifiable individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcd9f98f1-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s223a/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information sufficient to enable the covered platform to contact the identifiable individual (or an authorized person acting on behalf of such individual).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcd9f98f2-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s223a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of process","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A covered platform shall provide on the platform a clear and conspicuous notice, which may be provided through a clear and conspicuous link to another web page or disclosure, of the notice and removal process established under paragraph (1)(A) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcd9f98f3-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s223a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is easy to read and in plain language; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcd9f98f4-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s223a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides information regarding the responsibilities of the covered platform under this section, including a description of how an individual can submit a notification and request for removal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcd9f98f5-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s223a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of nonconsensual intimate visual depictions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon receiving a valid removal request from an identifiable individual (or an authorized person acting on behalf of such individual) using the process described in paragraph (1)(A)(ii), a covered platform shall, as soon as possible, but not later than 48 hours after receiving such request—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcd9f98f6-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s223a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remove the intimate visual depiction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcd9f98f7-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s223a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make reasonable efforts to identify and remove any known identical copies of such depiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcd9f98f8-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s223a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A covered platform shall not be liable for any claim based on the covered platform’s good faith disabling of access to, or removal of, material claimed to be a nonconsensual intimate visual depiction based on facts or circumstances from which the unlawful publishing of an intimate visual depiction is apparent, regardless of whether the intimate visual depiction is ultimately determined to be unlawful or not.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcd9f98f9-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s223a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement by the Commission","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcd9f98fa-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s223a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unfair or deceptive acts or practices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A failure to reasonably comply with the notice and takedown obligations under subsection (a) shall be treated as a violation of a rule defining an unfair or a deceptive act or practice under section 18(a)(1)(B) of the Federal Trade Commission Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s57a/a/1/B"},"text":"15 U.S.C. 57a(a)(1)(B)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcd9f98fb-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s223a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of the Commission","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcd9f98fc-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s223a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (D), the Commission shall enforce this section in the same manner, by the same means, and with the same jurisdiction, powers, and duties as though all applicable terms and provisions of the Federal Trade Commission Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s41"},"text":"15 U.S.C. 41","children":[],"tail":" et seq.) were incorporated into and made a part of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcd9f98fd-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s223a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privileges and immunities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who violates this section shall be subject to the penalties and entitled to the privileges and immunities provided in the Federal Trade Commission Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s41"},"text":"15 U.S.C. 41","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcd9f98fe-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s223a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority preserved","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this Act shall be construed to limit the authority of the Federal Trade Commission under any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcd9f98ff-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s223a/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding sections 4, 5(a)(2), or 6 of the Federal Trade Commission Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s44"},"text":"15 U.S.C. 44","children":[],"tail":", 45(a)(2), 46), or any jurisdictional limitation of the Commission, the Commission shall also enforce this section in the same manner provided in subparagraph (A), with respect to organizations that are not organized to carry on business for their own profit or that of their members."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcd9f9900-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/12/s3"},"text":"Pub. L. 119–12, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-05-19"},"text":"May 19, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/59"},"text":"139 Stat. 59","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcd9f9901-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcd9f9902-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcd9f9903-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Trade Commission Act, referred to in subsec. (b)(2)(A), (B), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-09-26/ch311"},"text":"act Sept. 26, 1914, ch. 311","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/717"},"text":"38 Stat. 717","children":[],"tail":", which is classified generally to subchapter I (§ 41 et seq.) of chapter 2 of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s58"},"text":"section 58 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (b)(2)(C), is Pub. L. 119—12, ","children":[{"tag":"date","attrib":{"date":"2025-05-19"},"text":"May 19, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/55"},"text":"139 Stat. 55","children":[],"tail":", which enacted this section, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s223"},"text":"section 223 of this title","children":[],"tail":", and enacted provisions set out as notes under this section and sections 223 and 609 of this title. For complete classification of this Act to the Code, see Short Title of 2025 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s609"},"text":"section 609 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcd9f9904-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Tools to Address Known Exploitation by Immobilizing Technological Deepfakes on Websites and Networks Act, also known as the TAKE IT DOWN Act, and not as part of the Communications Act of 1934 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcd9f9905-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idcd9f9906-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/12/s4"},"text":"Pub. L. 119–12, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-05-19"},"text":"May 19, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/61"},"text":"139 Stat. 61","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/12/s4"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this Act [see Short Title of 2025 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s609"},"text":"section 609 of this title","children":[],"tail":"]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Commission’ means the Federal Trade Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consent; digital forgery; identifiable individual; intimate visual depiction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms ‘consent’, ‘digital forgery’, ‘identifiable individual’, ‘intimate visual depiction’, and ‘minor’ have the meaning given such terms in section 223(h) of the Communications Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s223"},"text":"47 U.S.C. 223","children":[],"tail":"[(h)]), as added by section 2."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered platform.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘covered platform’ means a website, online service, online application, or mobile application—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that serves the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that primarily provides a forum for user-generated content, including messages, videos, images, games, and audio files; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"“(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which it is in the regular course of trade or business of the website, online service, online application, or mobile application to publish, curate, host, or make available content of nonconsensual intimate visual depictions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘covered platform’ shall not include the following:","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A provider of broadband internet access service (as described in section 8.1(b) of title 47, Code of Federal Regulations, or successor regulation).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Electronic mail.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subparagraph (A)(ii)(II), an online service, application, or website—","children":[],"tail":null},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"     “(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that consists primarily of content that is not user generated but is preselected by the provider of such online service, application, or website; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"     “(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which any chat, comment, or interactive functionality is incidental to, directly related to, or dependent on the provision of the content described in subclause (I).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
