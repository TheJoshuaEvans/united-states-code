{"tag":"section","attrib":{"id":"idcd809fac-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s38"},"text":null,"children":[{"tag":"num","attrib":{"value":"38"},"text":"§ 38.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “United States” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The term “United States” as used in sections 34 to 39 of this title includes the Canal Zone and all territory continental or insular, subject to the jurisdiction of the United States of America.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcd809fad-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-05-27/ch12/s5"},"text":"May 27, 1921, ch. 12, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/8"},"text":"42 Stat. 8","children":[],"tail":"; Proc. No. 2695, eff. "},{"tag":"date","attrib":{"date":"1946-07-04"},"text":"July 4, 1946","children":[],"tail":", 11 F.R. 7517, "},{"tag":"ref","attrib":{"href":"/us/stat/60/1352"},"text":"60 Stat. 1352","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcd809fae-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"referencesInText","id":"idcd809faf-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of Canal Zone, referred to in text, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3602/b"},"text":"section 3602(b) of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcd809fb0-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcd809fb1-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “the Philippine Islands” deleted on authority of Proc. No. 2695 issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1394"},"text":"section 1394 of Title 22","children":[],"tail":", Foreign Relations and Intercourse, which recognized independence of Philippine Islands as of "},{"tag":"date","attrib":{"date":"1946-07-04"},"text":"July 4, 1946","children":[],"tail":". Proc. No. 2695 is set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1394"},"text":"section 1394 of Title 22","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Submarine Cable Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
