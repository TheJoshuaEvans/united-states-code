{"tag":"section","attrib":{"id":"idd2b192b6-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s763d"},"text":null,"children":[{"tag":"num","attrib":{"value":"763d"},"text":"§ 763d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encouraging market access and privatization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2b192b7-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s763d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NTIA determination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2b192b8-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s763d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 180 days after ","children":[{"tag":"date","attrib":{"date":"2000-03-17"},"text":"March 17, 2000","children":[],"tail":", the Secretary of Commerce shall, through the Assistant Secretary for Communications and Information, transmit to the Commission—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2b192b9-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s763d/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of Member countries of INTELSAT and Inmarsat that are not Members of the World Trade Organization and that impose barriers to market access for private satellite systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2b192ba-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s763d/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of Member countries of INTELSAT and Inmarsat that are not Members of the World Trade Organization and that are not supporting pro-competitive privatization of INTELSAT and Inmarsat.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2b192bb-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s763d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary’s determinations under paragraph (1) shall be made in consultation with the Federal Communications Commission, the Secretary of State, and the United States Trade Representative, and shall take into account the totality of a country’s actions in all relevant fora, including the Assemblies of Parties of INTELSAT and Inmarsat.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2b192bc-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s763d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of cost-based settlement rate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2b192bd-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s763d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any higher settlement rate that an overseas carrier charges any United States carrier to originate or terminate international message telephone services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2b192be-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s763d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any transition period that would otherwise apply,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Commission may by rule prohibit United States carriers from paying an amount in excess of a cost-based settlement rate to overseas carriers in countries listed by the Commission pursuant to subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2b192bf-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s763d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Settlements policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall, in exercising its authority to establish settlements rates for United States international common carriers, seek to advance United States policy in favor of cost-based settlements in all relevant fora on international telecommunications policy, including in meetings with parties and signatories of INTELSAT and Inmarsat.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2b192c0-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/624/tVI/s625"},"text":"Pub. L. 87–624, title VI, § 625","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/180/s3"},"text":"Pub. L. 106–180, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-03-17"},"text":"Mar. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/54"},"text":"114 Stat. 54","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
