{"tag":"section","attrib":{"id":"idcdf31069-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s560"},"text":null,"children":[{"tag":"num","attrib":{"value":"560"},"text":"§ 560.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scrambling of cable channels for nonsubscribers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcdf3106a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s560/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subscriber request","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon request by a cable service subscriber, a cable operator shall, without charge, fully scramble or otherwise fully block the audio and video programming of each channel carrying such programming so that one not a subscriber does not receive it.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdf3106b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s560/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Scramble” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the term “scramble” means to rearrange the content of the signal of the programming so that the programming cannot be viewed or heard in an understandable manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcdf3106c-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title VI, § 640, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/104/tV/s504"},"text":"Pub. L. 104–104, title V, § 504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-08"},"text":"Feb. 8, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/136"},"text":"110 Stat. 136","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
