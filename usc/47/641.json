{"tag":"section","attrib":{"id":"idd2acd845-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s641"},"text":null,"children":[{"tag":"num","attrib":{"value":"641"},"text":"§ 641.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2acd846-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s641/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Broadband internet access service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “broadband internet access service” has the meaning given the term in section 8.1(b) of title 47, Code of Federal Regulations, or any successor regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2acd847-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s641/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Broadband map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Broadband Map” means the map created by the Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s642/c/1/A"},"text":"section 642(c)(1)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2acd848-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s641/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cell edge probability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “cell edge probability” means the likelihood that the minimum threshold download and upload speeds with respect to broadband internet access service will be met or exceeded at a distance from a base station that is intended to indicate the ultimate edge of the coverage area of a cell.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2acd849-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s641/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cell loading","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “cell loading” means the percentage of the available air interface resources of a base station that are used by consumers with respect to broadband internet access service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2acd84a-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s641/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clutter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “clutter” means a natural or man-made surface feature that affects the propagation of a signal from a base station.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2acd84b-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s641/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fabric","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Fabric” means the Broadband Serviceable Location Fabric established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s642/b/1/B"},"text":"section 642(b)(1)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2acd84c-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s641/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form 477","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Form 477” means Form 477 of the Commission relating to local telephone competition and broadband reporting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2acd84d-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s641/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian Tribe” has the meaning given the term “Indian tribe” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2acd84e-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s641/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mobility Fund Phase II","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Mobility Fund Phase II” means the second phase of the proceeding to provide universal service support from the Mobility Fund (WC Docket No. 10–90; WT Docket No. 10–208).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2acd84f-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s641/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Propagation model","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “propagation model” means a mathematical formulation for the characterization of radio wave propagation as a function of frequency, distance, and other conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2acd850-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s641/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provider","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “provider” means a provider of fixed or mobile broadband internet access service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2acd851-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s641/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quality of service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “quality of service” means, with respect to broadband internet access service, the download and upload speeds (and, for relevant services, latency) with respect to that service, as determined by, and to the extent otherwise collected by, the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2acd852-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s641/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shapefile","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “shapefile” means a digital storage format containing geospatial or location-based data and attribute information—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2acd853-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s641/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regarding the availability of broadband internet access service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2acd854-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s641/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that can be viewed, edited, and mapped in geographic information system software.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2acd855-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s641/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard broadband installation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “standard broadband installation”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2acd856-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s641/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means the initiation by a provider of fixed broadband internet access service in an area in which the provider has not previously offered that service, with no charges or delays attributable to the extension of the network of the provider; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2acd857-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s641/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the initiation of fixed broadband internet access service through routine installation that can be completed not later than 10 business days after the date on which the service request is submitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2acd858-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title VIII, § 801, as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/130/s2"},"text":"Pub. L. 116–130, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-23"},"text":"Mar. 23, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/228"},"text":"134 Stat. 228","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
