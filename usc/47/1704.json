{"tag":"section","attrib":{"id":"idd2da29b5-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704"},"text":null,"children":[{"tag":"num","attrib":{"value":"1704"},"text":"§ 1704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Broadband Deployment Locations Map","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2da29b6-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2da29b7-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Broadband infrastructure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “broadband infrastructure” means any cables, fiber optics, wiring, or other permanent (integral to the structure) infrastructure, including wireless infrastructure, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2da29b8-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is capable of providing access to internet connections in individual locations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2da29b9-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an advanced telecommunications capability, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1302/d"},"text":"section 1302(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2da29ba-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commission” means the Federal Communications Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2da29bb-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deployment Locations Map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Deployment Locations Map” means the mapping tool required to be established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2da29bc-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Deployment Locations Map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Commission shall, in consultation with all relevant Federal agencies, establish an online mapping tool to provide a locations overview of the overall geographic footprint of each broadband infrastructure deployment project funded by the Federal Government."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2da29bd-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Deployment Locations Map shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2da29be-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the centralized, authoritative source of information on funding made available by the Federal Government for broadband infrastructure deployment in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2da29bf-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made publicly available on the website of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2da29c0-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing the Deployment Locations Map, the Commission shall ensure that the Deployment Locations Map—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2da29c1-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" compiles data related to Federal funding for broadband infrastructure deployment provided by the Commission, the National Telecommunications and Information Administration, the Department of Agriculture, the Department of Health and Human Services, the Department of the Treasury, the Department of Housing and Urban Development, the Institute of Museum and Library Sciences, and any other Federal agency that provides such data relating to broadband infrastructure deployment funding to the Commission, including funding under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2da29c2-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this Act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2da29c3-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Coronavirus Aid, Relief, and Economic Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136"},"text":"Public Law 116–136","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2da29c4-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Consolidated Appropriations Act, 2021 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Public Law 116–260","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2da29c5-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" American Rescue Plan Act of 2021 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2"},"text":"Public Law 117–2","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2da29c6-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Federal amounts appropriated or any Federal program authorized after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", to fund broadband infrastructure deployment;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2da29c7-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contains data, with respect to each broadband infrastructure deployment program, relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2da29c8-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal agency of jurisdiction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2da29c9-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2da29ca-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the network type, including wired, terrestrial fixed, wireless, mobile, and satellite broadband infrastructure deployment;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2da29cb-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" allows users to manipulate the Deployment Locations Map to identify, search, and filter broadband infrastructure deployment projects by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2da29cc-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" company name;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2da29cd-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" duration timeline, including the dates of a project’s beginning and ending, or anticipated beginning or ending date;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2da29ce-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" total number of locations to which a project makes service available; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2da29cf-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relevant download and upload speeds; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2da29d0-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporates broadband service availability data as depicted in the Broadband Map created under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s642/c/1"},"text":"section 642(c)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2da29d1-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic updates","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2da29d2-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall, in consultation with relevant Federal agencies, ensure the Deployment Locations Map is maintained and up to date on a periodic basis, but not less frequently than once every 180 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2da29d3-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Federal agency providing funding for broadband infrastructure deployment shall report relevant data to the Commission on a periodic basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2da29d4-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No effect on programmatic missions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to affect the programmatic missions of Federal agencies providing funding for broadband infrastructure development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2da29d5-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonduplication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements in this section shall be consistent with and avoid duplication with the provisions of section 903 of division FF of the Consolidated Appropriations Act, 2021 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Public Law 116–260","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t47/s1307"},"text":"47 U.S.C. 1307","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2da29d6-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1704/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts appropriated to carry out this division under this Act, $10,000,000 shall be made available to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2da29d7-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dF/tI/s60105"},"text":"Pub. L. 117–58, div. F, title I, § 60105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1206"},"text":"135 Stat. 1206","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2da29d8-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2da29d9-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd2da29da-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsecs. (d)(1)(A) and (h), means div. F of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1182"},"text":"135 Stat. 1182","children":[],"tail":", see Definitions note set out below. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Coronavirus Aid, Relief, and Economic Security Act, referred to in subsec. (d)(1)(B), also known as the CARES Act, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136"},"text":"Pub. L. 116–136","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"t