{"tag":"section","attrib":{"id":"idd281f705-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s358"},"text":null,"children":[{"tag":"num","attrib":{"value":"358"},"text":"§ 358.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Master’s control over operations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The radio installation, the operators, the regulation of their watches, the transmission and receipt of messages, and the radio service of the ship except as they may be regulated by law or international agreement, or by rules and regulations made in pursuance thereof, shall in the case of a ship of the United States be under the supreme control of the master.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd281f706-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title III, § 360, formerly § 358, as added "},{"tag":"ref","attrib":{"href":"/us/act/1937-05-20/ch229/s10/b"},"text":"May 20, 1937, ch. 229, § 10(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/195"},"text":"50 Stat. 195","children":[],"tail":"; renumbered § 360, ch. 729, § 2(a)(1), "},{"tag":"date","attrib":{"date":"1954-08-13"},"text":"Aug. 13, 1954","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/706"},"text":"68 Stat. 706","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd281f707-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd281f708-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd281f709-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1937-05-20"},"text":"May 20, 1937","children":[],"tail":", see section 16 of act "},{"tag":"date","attrib":{"date":"1937-05-20"},"text":"May 20, 1937","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s351"},"text":"section 351 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
