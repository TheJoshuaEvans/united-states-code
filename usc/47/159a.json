{"tag":"section","attrib":{"id":"idcd93b232-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s159a"},"text":null,"children":[{"tag":"num","attrib":{"value":"159a"},"text":"§ 159a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions applicable to application and regulatory fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcd93b233-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s159a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any adjustment or amendment to a schedule of fees under subsection (b) or (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s158"},"text":"section 158 of this title","children":[],"tail":" or subsection (c) or (d) of "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s159"},"text":"section 159 of this title","children":[],"tail":" is not subject to judicial review."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcd93b234-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s159a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall transmit to Congress notification—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcd93b235-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s159a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of any adjustment under section 158(b) or 159(c) of this title immediately upon the adoption of such adjustment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcd93b236-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s159a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of any amendment under section 158(c) or 159(d) of this title not later than 90 days before the effective date of such amendment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcd93b237-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s159a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcd93b238-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s159a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties for late payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall by rule prescribe an additional penalty for late payment of fees under section 158 or 159 of this title. Such additional penalty shall be 25 percent of the amount of the fee that was not paid in a timely manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcd93b239-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s159a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest on unpaid fees and penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall charge interest, at a rate determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3717"},"text":"section 3717 of title 31","children":[],"tail":", on a fee under section 158 or 159 of this title or an additional penalty under this subsection that is not paid in a timely manner. Such section 3717 shall not otherwise apply with respect to such a fee or penalty."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcd93b23a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s159a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dismissal of applications or filings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may dismiss any application or other filing for failure to pay in a timely manner any fee under section 158 or 159 of this title or any interest or additional penalty under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcd93b23b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s159a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcd93b23c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s159a/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to or in lieu of the penalties and dismissals authorized by this subsection, the Commission may revoke any instrument of authorization held by any licensee that has not paid in a timely manner a regulatory fee assessed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s159"},"text":"section 159 of this title","children":[],"tail":" or any related interest or penalty."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcd93b23d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s159a/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Revocation action may be taken by the Commission under this paragraph after notice of the Commission’s intent to take such action is sent to the licensee by registered mail, return receipt requested, at the licensee’s last known address. The notice shall provide the licensee at least 30 days to either pay the fee, interest, and any penalty or show cause why the fee, interest, or penalty does not apply to the licensee or should otherwise be waived or payment deferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcd93b23e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s159a/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearing","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcd93b23f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s159a/c/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Generally not required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A hearing is not required under this paragraph unless the licensee’s response presents a substantial and material question of fact.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcd93b240-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s159a/c/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evidence and burdens","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case where a hearing is conducted under this paragraph, the hearing shall be based on written evidence only, and the burden of proceeding with the introduction of evidence and the burden of proof shall be on the licensee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcd93b241-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s159a/c/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless the licensee substantially prevails in the hearing, the Commission may assess the licensee for the costs of such hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcd93b242-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s159a/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opportunity to pay prior to revocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any Commission order adopted under this paragraph shall determine the amount due, if any, and provide the licensee with at least 30 days to pay that amount or have its authorization revoked.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcd93b243-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s159a/c/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No order of revocation under this paragraph shall become final until the licensee has exhausted its right to judicial review of such order under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s402/b/5"},"text":"section 402(b)(5) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcd93b244-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s159a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver, reduction, and deferment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may waive, reduce, or defer payment of a fee under section 158 or 159 of this title or an interest charge or penalty under this section in any specific instance for good cause shown, where such action would promote the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcd93b245-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s159a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall by rule permit payment—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcd93b246-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s159a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of fees under section 158 or 159 of this title in large amounts, by installments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcd93b247-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s159a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of fees under section 158 or 159 of this title in small amounts, in advance for a number of years not to exceed the term of the license held by the payor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcd93b248-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s159a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accounting system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall develop accounting systems necessary to make the amendments authorized by sections 158(c) and 159(d) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcd93b249-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title I, § 9A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dP/tI/s102/c"},"text":"Pub. L. 115–141, div. P, title I, § 102(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1084"},"text":"132 Stat. 1084","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcd93b24a-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcd93b24b-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcd93b24c-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2018-10-01"},"text":"Oct. 1, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dP/s103"},"text":"section 103 of div. P of Pub. L. 115–141","children":[],"tail":", set out as an Effective Date of 2018 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s156"},"text":"section 156 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
