{"tag":"section","attrib":{"id":"idcdb76716-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s303b"},"text":null,"children":[{"tag":"num","attrib":{"value":"303b"},"text":"§ 303b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of children’s television service in broadcast license renewal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcdb76717-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s303b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" After the standards required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s303a"},"text":"section 303a of this title","children":[],"tail":" are in effect, the Commission shall, in its review of any application for renewal of a commercial or noncommercial television broadcast license, consider the extent to which the licensee—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcdb9d818-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s303b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has complied with such standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdb9d819-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s303b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has served the educational and informational needs of children through the licensee’s overall programming, including programming specifically designed to serve such needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdb9d81a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s303b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In addition to consideration of the licensee’s programming as required under subsection (a), the Commission may consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcdb9d81b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s303b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any special nonbroadcast efforts by the licensee which enhance the educational and informational value of such programming to children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdb9d81c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s303b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any special efforts by the licensee to produce or support programming broadcast by another station in the licensee’s marketplace which is specifically designed to serve the educational and informational needs of children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcdb9d81d-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/437/tI/s103"},"text":"Pub. L. 101–437, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-17"},"text":"Oct. 17, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/997"},"text":"104 Stat. 997","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/356/s15"},"text":"Pub. L. 102–356, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-08-26"},"text":"Aug. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/954"},"text":"106 Stat. 954","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/414/tIII/s303/c"},"text":"Pub. L. 103–414, title III, § 303(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4296"},"text":"108 Stat. 4296","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcdb9d81e-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcdb9d81f-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcdb9d820-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Children’s Television Act of 1990, and not as part of the Communications Act of 1934 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcdb9d821-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/414"},"text":"Pub. L. 103–414","children":[],"tail":" substituted “noncommercial” for “noncommerical”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/356"},"text":"Pub. L. 102–356","children":[],"tail":" inserted reference to commercial or noncommercial television broadcast licenses."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
