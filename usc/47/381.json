{"tag":"section","attrib":{"id":"idd281f737-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s381"},"text":null,"children":[{"tag":"num","attrib":{"value":"381"},"text":"§ 381.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vessels transporting more than six passengers for hire required to be equipped with radiotelephone","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s382"},"text":"section 382 of this title","children":[],"tail":", it shall be unlawful for any vessel of the United States, transporting more than six passengers for hire, to be navigated in the open sea or any tidewater within the jurisdiction of the United States adjacent or contiguous to the open sea, unless such vessel is equipped with an efficient radiotelephone installation in operating condition."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd281f738-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title III, § 381, as added "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-06/ch973/s1"},"text":"Aug. 6, 1956, ch. 973, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/1047"},"text":"70 Stat. 1047","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/414/tIII/s303/a/20/A"},"text":"Pub. L. 103–414, title III, § 303(a)(20)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4295"},"text":"108 Stat. 4295","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd281f739-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"