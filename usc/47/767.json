{"tag":"section","attrib":{"id":"idd2b192f6-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s767"},"text":null,"children":[{"tag":"num","attrib":{"value":"767"},"text":"§ 767.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methods to pursue privatization","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President shall secure the pro-competitive privatizations required by this subchapter in a manner that meets the criteria in part B.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd2b192f7-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/624/tVI/s661"},"text":"Pub. L. 87–624, title VI, § 661","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/180/s3"},"text":"Pub. L. 106–180, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-03-17"},"text":"Mar. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/58"},"text":"114 Stat. 58","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
