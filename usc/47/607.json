{"tag":"section","attrib":{"id":"idd2a33b46-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s607"},"text":null,"children":[{"tag":"num","attrib":{"value":"607"},"text":"§ 607.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date of chapter","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This chapter shall take effect upon the organization of the Commission, except that this section and sections 151 and 154 of this title shall take effect ","children":[{"tag":"date","attrib":{"date":"1934-07-01"},"text":"July 1, 1934","children":[],"tail":". The Commission shall be deemed to be organized upon such date as four members of the Commission have taken office."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd2a33b47-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title VII, § 707, formerly title VI, § 607, "},{"tag":"ref","attrib":{"href":"/us/stat/48/1105"},"text":"48 Stat. 1105","children":[],"tail":"; renumbered title VII, § 707, "},{"tag":"ref","attrib":{"href":"/us/pl/98/549/s6/a"},"text":"Pub. L. 98–549, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2804"},"text":"98 Stat. 2804","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2a33b48-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2a33b49-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd2a33b4a-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"act June 19, 1934, ch. 652","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1064"},"text":"48 Stat. 1064","children":[],"tail":", known as the Communications Act of 1934, which is classified principally to this chapter. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s609"},"text":"section 609 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
