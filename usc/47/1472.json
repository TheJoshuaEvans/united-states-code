{"tag":"section","attrib":{"id":"idd2d2fd46-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1472"},"text":null,"children":[{"tag":"num","attrib":{"value":"1472"},"text":"§ 1472.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parity of protection for provision or use of Next Generation 9–1–1 services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2d2fd47-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1472/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immunity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A provider or user of Next Generation 9–1–1 services, a public safety answering point, and the officers, directors, employees, vendors, agents, and authorizing government entity (if any) of such provider, user, or public safety answering point, shall have immunity and protection from liability under Federal and State law to the extent provided in subsection (b) with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2d2fd48-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1472/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the release of subscriber information related to emergency calls or emergency services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d2fd49-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1472/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use or provision of 9–1–1 services, E9–1–1 services, or Next Generation 9–1–1 services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d2fd4a-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1472/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other matters related to 9–1–1 services, E9–1–1 services, or Next Generation 9–1–1 services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2d2fd4b-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1472/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of immunity and protection from liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The scope and extent of the immunity and protection from liability afforded under subsection (a) shall be the same as that provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s615a"},"text":"section 615a of this title","children":[],"tail":" to wireless carriers, public safety answering points, and users of wireless 9–1–1 service (as defined in paragraphs (4), (3), and (6), respectively, of "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s615b"},"text":"section 615b of this title","children":[],"tail":" "},{"tag":"ref","attrib":{"idref":"fn002068"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002068"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":") with respect to such release, use, and other matters."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2d2fd4c-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/96/tVI/s6506"},"text":"Pub. L. 112–96, title VI, § 6506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/242"},"text":"126 Stat. 242","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2d2fd4d-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2d2fd4e-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd2d2fd4f-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s615b"},"text":"Section 615b of this title","children":[],"tail":", referred to in subsec. (b), was in the original a reference to section 6 of the Wireless Communications and Public Safety Act of 1999, "},{"tag":"ref","attrib":{"href":"/us/pl/106/81"},"text":"Pub. L. 106–81","children":[],"tail":", and was translated as if it had been a reference to "},{"tag":"ref","attrib":{"href":"/us/pl/106/81/s7"},"text":"section 7 of Pub. L. 106–81","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s615b"},"text":"section 615b of this title","children":[],"tail":", to reflect the probable intent of Congress and the renumbering of "},{"tag":"ref","attrib":{"href":"/us/pl/106/81/s6"},"text":"section 6 of Pub. L. 106–81","children":[],"tail":" as section 7 by "},{"tag":"ref","attrib":{"href":"/us/pl/110/283/tI/s101/1"},"text":"Pub. L. 110–283, title I, § 101(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-23"},"text":"July 23, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2620"},"text":"122 Stat. 2620","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/110/283/tI/s101/3"},"text":"Pub. L. 110–283, title I, § 101(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-23"},"text":"July 23, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2620"},"text":"122 Stat. 2620","children":[],"tail":" enacted a new section 6 of the Wireless Communications and Public Safety Act of 1999 which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s215a–1"},"text":"section 215a–1 of this title","children":[],"tail":", but that section does not contain definitions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
