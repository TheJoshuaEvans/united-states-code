{"tag":"section","attrib":{"id":"idd29298e2-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s510"},"text":null,"children":[{"tag":"num","attrib":{"value":"510"},"text":"§ 510.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeiture of communications devices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd29298e3-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s510/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violation with willful and knowing intent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any electronic, electromagnetic, radio frequency, or similar device, or component thereof, used, sent, carried, manufactured, assembled, possessed, offered for sale, sold, or advertised with willful and knowing intent to violate section 301 or 302a of this title, or rules prescribed by the Commission under such sections, may be seized and forfeited to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd29298e4-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s510/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seizure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any property subject to forfeiture to the United States under this section may be seized by the Attorney General of the United States upon process issued pursuant to the supplemental rules for certain admiralty and maritime claims by any district court of the United States having jurisdiction over the property, except that seizure without such process may be made if the seizure is incident to a lawful arrest or search.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd29298e5-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s510/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Laws applicable to seizure and forfeiture","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"All provisions of law relating to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd29298e6-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s510/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the seizure, summary and judicial forfeiture, and condemnation of property for violation of the customs laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd29298e7-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s510/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disposition of such property or the proceeds from the sale thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd29298e8-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s510/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the remission or mitigation of such forfeitures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd29298e9-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s510/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the compromise of claims with respect to such forfeitures;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall apply to seizures and forfeitures incurred, or alleged to have been incurred, under the provisions of this section, insofar as applicable and not inconsistent with the provisions of this section, except that such seizures and forfeitures shall be limited to the communications device, devices, or components thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd29298ea-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s510/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of forfeited property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever property is forfeited under this section, the Attorney General of the United States may forward it to the Commission or sell any forfeited property which is not harmful to the public. The proceeds from any such sale shall be deposited in the general fund of the Treasury of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd29298eb-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title V, § 510, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/259/tI/s125"},"text":"Pub. L. 97–259, title I, § 125","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1098"},"text":"96 Stat. 1098","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd29298ec-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd29298ed-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd29298ee-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The supplemental rules for certain admiralty and maritime claims, referred to in subsec. (b), were renamed the Supplemental Rules for Admiralty or Maritime Claims and Asset Forfeiture Actions and are set out as part of the Federal Rules of Civil Procedure in the Appendix to Title 28, Judiciary and Judicial Procedure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idd29298ef-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 510, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652/tV/s510"},"text":"act June 19, 1934, ch. 652, title V, § 510","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1962-05-11"},"text":"May 11, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/87/448/s1"},"text":"Pub. L. 87–448, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/68"},"text":"76 Stat. 68","children":[],"tail":", related to forfeitures for violations of rules and regulations by radio stations operating in common carrier, safety and special radio fields, prior to repeal effective the thirtieth day after "},{"tag":"date","attrib":{"date":"1978-02-21"},"text":"Feb. 21, 1978","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/95/234"},"text":"Pub. L. 95–234","children":[],"tail":", §§ 4, 7, "},{"tag":"date","attrib":{"date":"1978-02-21"},"text":"Feb. 21, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/35"},"text":"92 Stat. 35","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
