{"tag":"section","attrib":{"id":"idce29ffc2-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1608"},"text":null,"children":[{"tag":"num","attrib":{"value":"1608"},"text":"§ 1608.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce29ffc3-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1608/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced communications service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “advanced communications service” has the meaning given the term “advanced telecommunications capability” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1302"},"text":"section 1302 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce29ffc4-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1608/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate national security agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate national security agency” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce29ffc5-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1608/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Homeland Security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce29ffc6-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1608/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce29ffc7-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1608/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of the Director of National Intelligence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce29ffc8-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1608/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Security Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce29ffc9-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1608/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Bureau of Investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce29ffca-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1608/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commission” means the Federal Communications Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce29ffcb-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1608/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Communications equipment or service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “communications equipment or service” means any equipment or service that is essential to the provision of advanced communications service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce29ffcc-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1608/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered communications equipment or service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered communications equipment or service” means any communications equipment or service that is on the list published by the Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1601/a"},"text":"section 1601(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce29ffcd-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1608/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Customers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “customers” means, with respect to a provider of advanced communications service—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce29ffce-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1608/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the customers of such provider; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce29ffcf-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1608/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the customers of any affiliate (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s153"},"text":"section 153 of this title","children":[],"tail":") of such provider."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce29ffd0-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1608/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive branch interagency body","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “executive branch interagency body” means an interagency body established in the executive branch.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce29ffd1-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1608/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means an individual or entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce29ffd2-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1608/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Program” means the Secure and Trusted Communications Networks Reimbursement Program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1603/a"},"text":"section 1603(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce29ffd3-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1608/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provider of advanced communications service","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “provider of advanced communications service”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce29ffd4-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1608/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a person who provides advanced communications service to United States customers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce29ffd5-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1608/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idce29ffd6-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1608/10/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accredited public or private noncommercial educational institutions, providing their own facilities-based educational broadband service, as defined in section 27.4 of title 47, Code of Federal Regulations, or any successor regulation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce29ffd7-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1608/10/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health care providers and libraries providing advanced communications service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce29ffd8-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1608/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recipient","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “recipient” means any provider of advanced communications service the application of which for a reimbursement under the Program has been approved by the Commission, regardless of whether the provider has received reimbursement funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce29ffd9-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1608/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “reimbursement funds” means any reimbursement received under the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idce29ffda-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/124/s9"},"text":"Pub. L. 116–124, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-12"},"text":"Mar. 12, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/169"},"text":"134 Stat. 169","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/tIX/s901/2"},"text":"Pub. L. 116–260, div. N, title IX, § 901(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2121"},"text":"134 Stat. 2121","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idce29ffdb-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idce29ffdc-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idce29ffdd-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Par. (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" amended par. (10) generally. Prior to amendment, text read as follows: “The term ‘provider of advanced communications service’ means a person who provides advanced communications service to United States customers.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
