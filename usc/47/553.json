{"tag":"section","attrib":{"id":"idd29e7fe8-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s553"},"text":null,"children":[{"tag":"num","attrib":{"value":"553"},"text":"§ 553.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unauthorized reception of cable service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd29e7fe9-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s553/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unauthorized interception or receipt or assistance in intercepting or receiving service; “assist in intercepting or receiving” defined","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd29e7fea-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s553/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No person shall intercept or receive or assist in intercepting or receiving any communications service offered over a cable system, unless specifically authorized to do so by a cable operator or as may otherwise be specifically authorized by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd29e7feb-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s553/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of this section, the term “assist in intercepting or receiving” shall include the manufacture or distribution of equipment intended by the manufacturer or distributor (as the case may be) for unauthorized reception of any communications service offered over a cable system in violation of subparagraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd29e7fec-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s553/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties for willful violation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd29e7fed-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s553/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who willfully violates subsection (a)(1) shall be fined not more than $1,000 or imprisoned for not more than 6 months, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd29e7fee-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s553/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who violates subsection (a)(1) willfully and for purposes of commercial advantage or private financial gain shall be fined not more than $50,000 or imprisoned for not more than 2 years, or both, for the first such offense and shall be fined not more than $100,000 or imprisoned for not more than 5 years, or both, for any subsequent offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd29e7fef-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s553/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of all penalties and remedies established for violations of subsection (a)(1), the prohibited activity established herein as it applies to each such device shall be deemed a separate violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd29e7ff0-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s553/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil action in district court; injunctions; damages; attorney’s fees and costs; regulation by States or franchising authorities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd29e7ff1-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s553/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person aggrieved by any violation of subsection (a)(1) may bring a civil action in a United States district court or in any other court of competent jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd29e7ff2-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s553/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The court may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd29e7ff3-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s553/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant temporary and final injunctions on such terms as it may deem reasonable to prevent or restrain violations of subsection (a)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd29e7ff4-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s553/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award damages as described in paragraph (3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd29e7ff5-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s553/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct the recovery of full costs, including awarding reasonable attorneys’ fees to an aggrieved party who prevails.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd29e7ff6-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s553/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd29e7ff7-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s553/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Damages awarded by any court under this section shall be computed in accordance with either of the following clauses:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd29e7ff8-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s553/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the party aggrieved may recover the actual damages suffered by him as a result of the violation and any profits of the violator that are attributable to the violation which are not taken into account in computing the actual damages; in determining the violator’s profits, the party aggrieved shall be required to prove only the violator’s gross revenue, and the violator shall be required to prove his deductible expenses and the elements of profit attributable to factors other than the violation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd29e7ff9-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s553/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the party aggrieved may recover an award of statutory damages for all violations involved in the action, in a sum of not less than $250 or more than $10,000 as the court considers just.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd29e7ffa-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s553/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case in which the court finds that the violation was committed willfully and for purposes of commercial advantage or private financial gain, the court in its discretion may increase the award of damages, whether actual or statutory under subparagraph (A), by an amount of not more than $50,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd29e7ffb-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s553/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case where the court finds that the violator was not aware and had no reason to believe that his acts constituted a violation of this section, the court in its discretion may reduce the award of damages to a sum of not less than $100.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd29e7ffc-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s553/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this subchapter shall prevent any State or franchising authority from enacting or enforcing laws, consistent with this section, regarding the unauthorized interception or reception of any cable service or other communications service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd29e7ffd-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title VI, § 633, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/549/s2"},"text":"Pub. L. 98–549, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2796"},"text":"98 Stat. 2796","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/385/s21"},"text":"Pub. L. 102–385, § 21","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-05"},"text":"Oct. 5, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1498"},"text":"106 Stat. 1498","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd29e7ffe-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd29e7fff-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd29e8000-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/385/s21/1"},"text":"Pub. L. 102–385, § 21(1)","children":[],"tail":", substituted “$50,000” for “$25,000”, “2 years” for “1 year”, “$100,000” for “$50,000”, and “5 years” for “2 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/385/s21/2"},"text":"Pub. L. 102–385, § 21(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd29e8001-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idd29e8002-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/385"},"text":"Pub. L. 102–385","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"1992-10-05"},"text":"Oct. 5, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/385/s28"},"text":"section 28 of Pub. L. 102–385","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s325"},"text":"section 325 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd29e8003-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 60 days after ","children":[{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", except where otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/549/s9/a"},"text":"section 9(a) of Pub. L. 98–549","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s521"},"text":"section 521 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
