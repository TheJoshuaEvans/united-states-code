{"tag":"section","attrib":{"id":"idd275e920-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s334"},"text":null,"children":[{"tag":"num","attrib":{"value":"334"},"text":"§ 334.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on revision of equal employment opportunity regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd275e921-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s334/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as specifically provided in this section, the Commission shall not revise—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd275e922-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s334/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the regulations concerning equal employment opportunity as in effect on ","children":[{"tag":"date","attrib":{"date":"1992-09-01"},"text":"September 1, 1992","children":[],"tail":" (47 C.F.R. 73.2080) as such regulations apply to television broadcast station licensees and permittees; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd275e923-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s334/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the forms used by such licensees and permittees to report pertinent employment data to the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd275e924-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s334/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Midterm review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall revise the regulations described in subsection (a) to require a midterm review of television broadcast station licensees’ employment practices and to require the Commission to inform such licensees of necessary improvements in recruitment practices identified as a consequence of such review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd275e925-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s334/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to make technical revisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may revise the regulations described in subsection (a) to make nonsubstantive technical or clerical revisions in such regulations as necessary to reflect changes in technology, terminology, or Commission organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd275e926-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title III, § 334, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/385/s22/f"},"text":"Pub. L. 102–385, § 22(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-05"},"text":"Oct. 5, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1499"},"text":"106 Stat. 1499","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd275e927-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd275e928-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd275e929-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 60 days after ","children":[{"tag":"date","attrib":{"date":"1992-10-05"},"text":"Oct. 5, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/385/s28"},"text":"section 28 of Pub. L. 102–385","children":[],"tail":", set out as an Effective Date of 1992 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s325"},"text":"section 325 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
