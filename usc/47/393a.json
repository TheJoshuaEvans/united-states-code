{"tag":"section","attrib":{"id":"idd284419c-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s393a"},"text":null,"children":[{"tag":"num","attrib":{"value":"393a"},"text":"§ 393a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Long-range planning for facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd284419d-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s393a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, in consultation with the Corporation, public telecommunications entities, and as appropriate with other parties, shall develop a long-range plan to accomplish the objectives set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s390"},"text":"section 390 of this title","children":[],"tail":". Such plan shall include a detailed 5-year projection of the broadcast and nonbroadcast public telecommunications facilities required to meet such objectives, and the expenditures necessary to provide such facilities."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd284419e-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s393a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66/tI/s1021/a"},"text":"Pub. L. 104–66, title I, § 1021(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/712"},"text":"109 Stat. 712","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd284419f-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title III, § 393A, for