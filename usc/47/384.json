{"tag":"section","attrib":{"id":"idd281f751-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s384"},"text":null,"children":[{"tag":"num","attrib":{"value":"384"},"text":"§ 384.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Commission; operations, installations, and additional equipment","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Commission shall have authority with respect to any vessel subject to this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd281f752-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s384/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to specify operating and technical conditions and characteristics including frequencies, emissions, power, communication capability and range, of installations required by reason of this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd281f753-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s384/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to approve the details as to the location and manner of installation of the equipment required by this part or of equipment necessitated by reason of the purposes and requirements of this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd281f754-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s384/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to approve installations, apparatus and spare parts necessary to comply with the purposes and requirements of this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd281f755-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s384/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prescribe such additional equipment as may be determined to be necessary to supplement that specified herein for the proper functioning of the radio installation installed in accordance with this part or for the proper conduct of radio communication in time of emergency or distress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd281f756-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title III, § 384, as added "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-06/ch973/s1"},"text":"Aug. 6, 1956, ch. 973, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/1048"},"text":"70 Stat. 1048","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/414/tIII/s303/a/20/D"},"text":"Pub. L. 103–414, title III, § 303(a)(20)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4295"},"text":"108 Stat. 4295","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd281f757-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd281f758-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd281f759-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/414"},"text":"Pub. L. 103–414","children":[],"tail":" inserted section catchline."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd281f75a-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd281f75b-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1957-03-01"},"text":"Mar. 1, 1957","children":[],"tail":", see section 4 of act "},{"tag":"date","attrib":{"date":"1956-08-06"},"text":"Aug. 6, 1956","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s381"},"text":"section 381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
