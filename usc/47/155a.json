{"tag":"section","attrib":{"id":"idd23a6705-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s155a"},"text":null,"children":[{"tag":"num","attrib":{"value":"155a"},"text":"§ 155a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Chief Information Officer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd23a6706-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s155a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall ensure that the Chief Information Officer of the Commission has a significant role in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd23a6707-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s155a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the decision-making process for annual and multi-year planning, programming, budgeting, and execution decisions, related reporting requirements, and reports related to information technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd23a6708-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s155a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the management, governance, and oversight processes related to information technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd23a6709-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s155a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the hiring of personnel with information technology responsibilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd23a670a-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s155a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CIO approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Information Officer of the Commission, in consultation with the Chief Financial Officer of the Commission and budget officials, shall specify and approve the allocation of amounts appropriated to the Commission for information technology, consistent with the provisions of appropriations Acts, budget guidelines, and recommendations from the Director of the Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd23a670b-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dP/tV/s502"},"text":"Pub. L. 115–141, div. P, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1091"},"text":"132 Stat. 1091","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd23a670c-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd23a670d-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd23a670e-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Repack Airwaves Yielding Better Access for Users of Modern Services Act of 2018, also known as the RAY BAUM’S Act of 2018, and also as part of the Consolidated Appropriations Act, 2018, and not as part of the Communications Act of 1934 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd23a670f-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idd23a6710-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dP/s2"},"text":"Pub. L. 115–141, div. P, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1081"},"text":"132 Stat. 1081","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/141/dP/s2"},"text":"“In this division [see Short Title of 2018 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s609"},"text":"section 609 of this title","children":[],"tail":"], the term ‘Commission’ means the Federal Communications Commission.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
