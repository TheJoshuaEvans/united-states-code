{"tag":"section","attrib":{"id":"idd2ce4225-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1433"},"text":null,"children":[{"tag":"num","attrib":{"value":"1433"},"text":"§ 1433.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commission may provide technical assistance to the First Responder Network Authority and may take any action necessary to assist the First Responder Network Authority in effectuating its duties and responsibilities under this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd2ce4226-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/96/tVI/s6213"},"text":"Pub. L. 112–96, title VI, § 6213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/218"},"text":"126 Stat. 218","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
