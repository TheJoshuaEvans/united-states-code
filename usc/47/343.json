{"tag":"section","attrib":{"id":"idcdd1a610-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s343"},"text":null,"children":[{"tag":"num","attrib":{"value":"343"},"text":"§ 343.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions on commercial terrestrial operations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcdd1a611-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s343/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall not permit commercial terrestrial operations in the 1525–1559 megahertz band or the 1626.5–1660.5 megahertz band until the date that is 90 days after the Commission resolves concerns of widespread harmful interference by such operations in such band to covered GPS devices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdd41712-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s343/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcdd41713-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s343/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the conclusion of the decision regarding whether to permit such operations in such band, the Commission shall submit to the congressional committees described in paragraph (2) official copies of the documents containing the final decision of the Commission. If the decision is to permit such operations in such band, such documents shall contain or be accompanied by an explanation of how the concerns described in subsection (a) have been resolved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdd41714-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s343/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional committees described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The congressional committees described in this paragraph are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcdd41715-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s343/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Energy and Commerce and the Committee on Armed Services of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcdd41716-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s343/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Commerce, Science, and Transportation and the Committee on Armed Services of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdd41717-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s343/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered GPS device defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “covered GPS device” means a Global Positioning System device of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcdd41718-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title III, § 343, as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXVI/s1698/a"},"text":"Pub. L. 114–328, div. A, title XVI, § 1698(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2641"},"text":"130 Stat. 2641","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
