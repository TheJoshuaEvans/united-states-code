{"tag":"section","attrib":{"id":"idcdfef816-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s624"},"text":null,"children":[{"tag":"num","attrib":{"value":"624"},"text":"§ 624.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure requirements for United States-based foreign media outlets","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcdfef817-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s624/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports by outlets to Commission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2018-08-13"},"text":"August 13, 2018","children":[],"tail":", and not less frequently than every 6 months thereafter, a United States-based foreign media outlet shall submit to the Commission a report that contains the following information:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcdfef818-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s624/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name of such outlet.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdfef819-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s624/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the relationship of such outlet to the foreign principal of such outlet, including a description of the legal structure of such relationship and any funding that such outlet receives from such principal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdfef81a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s624/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports by Commission to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2018-08-13"},"text":"August 13, 2018","children":[],"tail":", and not less frequently than every 6 months thereafter, the Commission shall transmit to Congress a report that summarizes the contents of the reports submitted by United States-based foreign media outlets under subsection (a) during the preceding 6-month period."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdfef81b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s624/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall make publicly available on the internet website of the Commission each report submitted by a United States-based foreign media outlet under subsection (a) not later than the earlier of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcdfef81c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s624/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that is 30 days after the outlet submits the report to the Commission; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdfef81d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s624/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the Commission transmits to Congress under subsection (b) the report covering the 6-month period during which the report of the outlet was submitted to the Commission under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcdfef81e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s624/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcdfef81f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s624/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign principal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “foreign principal” has the meaning given such term in section 1(b)(1) of the Foreign Agents Registration Act of 1938 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s611/b/1"},"text":"22 U.S.C. 611(b)(1)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdfef820-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s624/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States-based foreign media outlet","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “United States-based foreign media outlet” means an entity that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcdfef821-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s624/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produces or distributes video programming (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s522"},"text":"section 522 of this title","children":[],"tail":") that is transmitted, or intended for transmission, by a multichannel video programming distributor (as defined in such section) to consumers in the United States; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcdfef822-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s624/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would be an agent of a foreign principal (as defined in paragraph (1)) for purposes of the Foreign Agents Registration Act of 1938 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s611"},"text":"22 U.S.C. 611","children":[],"tail":" et seq.) but for section 1(d) of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s611/d"},"text":"22 U.S.C. 611(d)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcdfef823-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title VII, § 722, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tX/s1085"},"text":"Pub. L. 115–232, div. A, title X, § 1085","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1991"},"text":"132 Stat. 1991","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcdfef824-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcdfef825-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcdfef826-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Agents Registration Act of 1938, referred to in subsec. (d)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-08/ch327"},"text":"act June 8, 1938, ch. 327","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/631"},"text":"52 Stat. 631","children":[],"tail":", which is classified generally to subchapter II (§ 611 et seq.) of chapter 11 of Title 22, Foreign Relations and Intercourse. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s611"},"text":"section 611 of Title 22","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
