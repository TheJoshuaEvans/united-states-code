{"tag":"section","attrib":{"id":"idcdfcad59-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s615b"},"text":null,"children":[{"tag":"num","attrib":{"value":"615b"},"text":"§ 615b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this Act:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcdfcad5a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s615b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdfcad5b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s615b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means any of the several States, the District of Columbia, or any territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdfcad5c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s615b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public safety answering point; PSAP","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “public safety answering point” or “PSAP” means a facility that has been designated to receive 9–1–1 calls and route them to emergency service personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdfcad5d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s615b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wireless carrier","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “wireless carrier” means a provider of commercial mobile services or any other radio communications service that the Federal Communications Commission requires to provide wireless 9–1–1 service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdfcad5e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s615b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced wireless 9–1–1 service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “enhanced wireless 9–1–1 service” means any enhanced 9–1–1 service so designated by the Federal Communications Commission in the proceeding entitled “Revision of the Commission’s Rules to Ensure Compatibility with Enhanced 9–1–1 Emergency Calling Systems” (CC Docket No. 94–102; RM–8143), or any successor proceeding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdfcad5f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s615b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wireless 9–1–1 service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “wireless 9–1–1 service” means any 9–1–1 service provided by a wireless carrier, including enhanced wireless 9–1–1 service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdfcad60-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s615b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency dispatch providers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “emergency dispatch providers” shall include governmental and nongovernmental providers of emergency dispatch services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdfcad61-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s615b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002040"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002040"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Two pars. (8) have been enacted."}],"tail":" IP-enabled voice service"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “IP-enabled voice service” has the meaning given the term “interconnected VoIP service” by section 9.3 of the Federal Communications Commission’s regulations (47 CFR 9.3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdfcad62-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s615b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" Other emergency communications service"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “other emergency communications service” means the provision of emergency information to a public safety answering point via wire or radio communications, and may include 9–1–1 and enhanced 9–1–1 service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdfcad63-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s615b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other emergency communications service provider","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “other emergency communications service provider” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcdfcad64-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s615b/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity other than a local exchange carrier, wireless carrier, or an IP-enabled voice service provider that is required by the Federal Communications Commission consistent with the Commission’s authority under the Communications Act of 1934 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s151"},"text":"47 U.S.C. 151","children":[],"tail":" et seq.] to provide other emergency communications services; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcdfcad65-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s615b/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the absence of a Commission requirement as described in subparagraph (A), an entity that voluntarily elects to provide other emergency communications services and is specifically authorized by the appropriate local or State 9–1–1 service governing authority to provide other emergency communications services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcdfcad66-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s615b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced 9–1–1 service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “enhanced 9–1–1 service” means the delivery of 9–1–1 calls with automatic number identification and automatic location identification, or successor or equivalent information features over the wireline E911 network (as defined in section 9.3 of the Federal Communications Commission’s regulations (47 C.F.R. 9.3) as of ","children":[{"tag":"date","attrib":{"date":"2008-07-23"},"text":"July 23, 2008","children":[],"tail":") and equivalent or successor networks and technologies. The term also includes any enhanced 9–1–1 service so designated by the Commission in its Report and Order in WC Docket Nos. 04–36 and 05–196, or any successor proceeding."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcdfcad67-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/81/s7"},"text":"Pub. L. 106–81, § 7","children":[],"tail":", formerly § 6, "},{"tag":"date","attrib":{"date":"1999-10-26"},"text":"Oct. 26, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1289"},"text":"113 Stat. 1289","children":[],"tail":"; renumbered § 7 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/283/tI/s101/1"},"text":"Pub. L. 110–283, title I, § 101(1)","children":[],"tail":", (3), title II, § 201(b), "},{"tag":"date","attrib":{"date":"2008-07-23"},"text":"July 23, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2620"},"text":"122 Stat. 2620","children":[],"tail":", 2623, 2624.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcdfcad68-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcdfcad69-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcdfcad6a-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/81"},"text":"Pub. L. 106–81","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-26"},"text":"Oct. 26, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1286"},"text":"113 Stat. 1286","children":[],"tail":", known as the Wireless Communications and Public Safety Act of 1999, which enacted sections 615 to 615b of this title, amended sections 222 and 251 of this title, and enacted provisions set out as notes under sections 609 and 615 of this title. For complete classification of this Act to the Code, see Short Title of 1999 Amendments note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s609"},"text":"section 609 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Communications Act of 1934, referred to in par. (9)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"act June 19, 1934, ch. 652","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1064"},"text":"48 Stat. 1064","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s609"},"text":"section 609 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcdfcad6b-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Wireless Communications and Public Safety Act of 1999, and not as part of the Communications Act of 1934 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcdfcad6c-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/283/s201/b"},"text":"Pub. L. 110–283, § 201(b)","children":[],"tail":", added par. (8) defining “other emergency communications service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/283/s101/3"},"text":"Pub. L. 110–283, § 101(3)","children":[],"tail":", added par. (8) defining “IP-enabled voice service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (9), (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/283/s201/b"},"text":"Pub. L. 110–283, § 201(b)","children":[],"tail":", added pars. (9) and (10)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
