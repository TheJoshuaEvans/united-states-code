{"tag":"section","attrib":{"id":"idd27d14fd-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s341"},"text":null,"children":[{"tag":"num","attrib":{"value":"341"},"text":"§ 341.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carriage of television signals to certain subscribers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd27d14fe-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s341/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd27d14ff-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s341/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A cable operator or satellite carrier may elect to retransmit, to subscribers in an eligible county—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd27d1500-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s341/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any television broadcast stations that are located in the State in which the county is located and that any cable operator or satellite carrier was retransmitting to subscribers in the county on ","children":[{"tag":"date","attrib":{"date":"2004-01-01"},"text":"January 1, 2004","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd27d1501-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s341/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" up to 2 television broadcast stations located in the State in which the county is located, if the number of television broadcast stations that the cable operator or satellite carrier is authorized to carry under paragraph (1) is less than 3.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd27d1502-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s341/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deemed Significantly Viewed","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A station described in subsection (a) is deemed to be significantly viewed in the eligible county within the meaning of section 76.54 of the Commission’s regulations (47 CFR 76.54).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd27d1503-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s341/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Eligible County","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “eligible county” means any 1 of 4 counties that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd27d1504-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s341/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are all in a single State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd27d1505-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s341/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on ","children":[{"tag":"date","attrib":{"date":"2004-01-01"},"text":"January 1, 2004","children":[],"tail":", were each in designated market areas in which the majority of counties were located in another State or States; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd27d1506-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s341/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a group had a combined total of 41,340 television households according to the U.S. Television Household Estimates by Nielsen Media Research for 2003–2004.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd27d1507-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s341/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Carriage of a station under this section shall be at the option of the cable operator or satellite carrier.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd27d1508-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s341/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain Markets","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, a satellite carrier may not carry the signal of a television station into an adjacent local market that is comprised of only a portion of a county, other than to unserved households located in that county.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd27d1509-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title III, § 341, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/dJ/tIX"},"text":"Pub. L. 108–447, div. J, title IX","children":[],"tail":" [title II, § 211], "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3430"},"text":"118 Stat. 3430","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
