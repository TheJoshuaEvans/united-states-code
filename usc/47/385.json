{"tag":"section","attrib":{"id":"idd281f75c-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s385"},"text":null,"children":[{"tag":"num","attrib":{"value":"385"},"text":"§ 385.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspections","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commission or an entity designated by the Commission shall make such inspections as may be necessary to insure compliance with the requirements of this part. In accordance with such other provisions of law as apply to Government contracts, the Commission may enter into contracts with any person for the purpose of carrying out such inspections and certifying compliance with those requirements, and may, as part of any such contract, allow any such person to accept reimbursement from the license holder for travel and expense costs of any employee conducting an inspection or certification.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd281f75d-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title III, § 385, as added "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-06/ch973/s1"},"text":"Aug. 6, 1956, ch. 973, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/1048"},"text":"70 Stat. 1048","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/414/tIII/s303/a/20/E"},"text":"Pub. L. 103–414, title III, § 303(a)(20)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4295"},"text":"108 Stat. 4295","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/104/tIV/s403"},"text":"Pub. L. 104–104, title IV, § 403","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1996-02-08"},"text":"Feb. 8, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/132"},"text":"110 Stat. 132","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd281f75e-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd281f75f-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd281f760-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/104"},"text":"Pub. L. 104–104","children":[],"tail":" inserted “or an entity designated by the Commission” after “The Commission” and inserted at end “In accordance with such other provisions of law as apply to Government contracts, the Commission may enter into contracts with any person for the purpose of carrying out such inspections and certifying compliance with those requirements, and may, as part of any such contract, allow any such person to accept reimbursement from the license holder for travel and expense costs of any employee conducting an inspection or certification.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/414"},"text":"Pub. L. 103–414","children":[],"tail":" inserted section catchline."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd281f761-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","ch