{"tag":"section","attrib":{"id":"idd2c2345d-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1009"},"text":null,"children":[{"tag":"num","attrib":{"value":"1009"},"text":"§ 1009.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this subchapter a total of $500,000,000 for fiscal years 1995, 1996, 1997, and 1998. Such sums are authorized to remain available until expended.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd2c2345e-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/414/tI/s110"},"text":"Pub. L. 103–414, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4288"},"text":"108 Stat. 4288","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
