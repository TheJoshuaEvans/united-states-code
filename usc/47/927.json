{"tag":"section","attrib":{"id":"idd2bd79fd-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s927"},"text":null,"children":[{"tag":"num","attrib":{"value":"927"},"text":"§ 927.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing allocation and transfer authority retained","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2bd79fe-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s927/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional reallocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter prevents or limits additional reallocation of spectrum from the Federal Government to other users.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2bd79ff-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s927/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of new technologies and services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2bd7a00-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s927/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s903/e"},"text":"section 903(e) of this title","children":[],"tail":", at any time allow frequencies allocated on a primary basis for Federal Government use to be used by non-Federal licensees on a mixed-use basis for the purpose of facilitating the prompt implementation of new technologies or services and for other purposes; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2bd7a01-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s927/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commission shall make any allocation and licensing decisions with respect to such frequencies in a timely manner and in no event later than the date required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s157"},"text":"section 157 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2bd7a02-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/538/tI/s117"},"text":"Pub. L. 102–538, title I, § 117","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tVI/s6001/a/3"},"text":"Pub. L. 103–66, title VI, § 6001(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/386"},"text":"107 Stat. 386","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
