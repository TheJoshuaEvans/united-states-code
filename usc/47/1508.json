{"tag":"section","attrib":{"id":"idd2d2fdd7-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1508"},"text":null,"children":[{"tag":"num","attrib":{"value":"1508"},"text":"§ 1508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National plan for unlicensed spectrum","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2d2fdd8-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2d2fdd9-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1508/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spectrum Relocation Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Spectrum Relocation Fund” means the Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s928"},"text":"section 928 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d2fdda-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1508/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlicensed or licensed by rule operations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “unlicensed or licensed by rule operations” means the use of spectrum on a non-exclusive basis under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2d2fddb-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1508/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" part 15 of title 47, Code of Federal Regulations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2d2fddc-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1508/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" licensing by rule under part 96 of title 47, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2d2fddd-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2018-03-23"},"text":"March 23, 2018","children":[],"tail":", the Commission, in consultation with the NTIA, shall develop a national plan for making additional radio frequency bands available for unlicensed or licensed by rule operations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2d2fdde-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1508/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan developed under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2d2fddf-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1508/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify an approach that ensures that consumers have access to additional spectrum to conduct unlicensed or licensed by rule operations in a range of radio frequencies to meet consumer demand;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d2fde0-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1508/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommend specific actions by the Commission and the NTIA to permit unlicensed or licensed by rule operations in additional radio frequency ranges that the Commission finds—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2d2fde1-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1508/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with the statement of policy under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1507/a"},"text":"section 1507(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2d2fde2-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1508/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" will—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd2d2fde3-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1508/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand opportunities for unlicensed or licensed by rule operations in a spectrum band; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2d2fde4-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1508/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise improve spectrum utilization and intensity of use of bands where unlicensed or licensed by rule operations are already permitted;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2d2fde5-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1508/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not cause harmful interference to Federal or non-Federal users of such bands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2d2fde6-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1508/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not significantly impact homeland security or national security communications systems; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d2fde7-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1508/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" examine additional ways, with respect to existing and planned databases or spectrum access systems designed to promote spectrum sharing and access to spectrum for unlicensed or licensed by rule operations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2d2fde8-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1508/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve accuracy and efficacy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2d2fde9-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1508/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce burdens on consumers, manufacturers, and service providers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2d2fdea-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1508/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect sensitive Government information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2d2fdeb-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1508/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spectrum Relocation Fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be included as an appendix as part of the plan developed under this section, the NTIA, in consultation with the Director of the Office of Management and Budget, shall share with the Commission recommendations about how to reform the Spectrum Relocation Fund—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2d2fdec-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1508/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to address costs incurred by Federal entities related to sharing radio frequency bands with radio technologies conducting unlicensed or licensed by rule operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d2fded-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1508/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to ensure the Spectrum Relocation Fund has sufficient funds to cover—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2d2fdee-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1508/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2d2fdef-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1508/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other expenditures allowed of the Spectrum Relocation Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s928"},"text":"section 928 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2d2fdf0-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1508/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2d2fdf1-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1508/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2018-03-23"},"text":"March 23, 2018","children":[],"tail":", the Commission shall submit to the appropriate committees of Congress a report that describes the plan developed under this section, including any recommendations for legislative change."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d2fdf2-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1508/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication on commission website","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the date on which the Commission submits the report under paragraph (1), the Commission shall make the report publicly available on the website of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2d2fdf3-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1508/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section confers any additional rights on unlicensed users or users licensed by rule under part 96 of title 47, Code of Federal Regulations, to protection from harmful interference.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2d2fdf4-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dP/tVI/s618"},"text":"Pub. L. 115–141, div. P, title VI, § 618","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1112"},"text":"132 Stat. 1112","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
