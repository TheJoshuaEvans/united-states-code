{"tag":"section","attrib":{"id":"idce1df177-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308"},"text":null,"children":[{"tag":"num","attrib":{"value":"1308"},"text":"§ 1308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency agreement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idce1df178-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may be cited as the “Broadband Interagency Coordination Act of 2020”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce1df179-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency agreement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce1df17a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce1df17b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “covered agency” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idce1df17c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Communications Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce1df17d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce1df17e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Telecommunications and Information Administration; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce1df17f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “high-cost programs” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idce1df180-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program for Universal Service Support for High-Cost Areas set forth under subpart D of part 54 of title 47, Code of Federal Regulations, or any successor thereto;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce1df181-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Rural Digital Opportunity Fund set forth under subpart J of part 54 of title 47, Code of Federal Regulations, or any successor thereto;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce1df182-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Interstate Common Line Support Mechanism for Rate-of-Return Carriers set forth under subpart K of part 54 of title 47, Code of Federal Regulations, or any successor thereto;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce1df183-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Mobility Fund and 5G Fund set forth under subpart L of part 54 of title 47, Code of Federal Regulations, or any successor thereto; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce1df184-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the High Cost Loop Support for Rate-of-Return Carriers program set forth under subpart M of part 54 of title 47, Code of Federal Regulations, or any successor thereto.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce206185-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the heads of the covered agencies shall enter into an interagency agreement requiring coordination between the covered agencies for the distribution of funds for broadband deployment under—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce206186-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the high-cost programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce206187-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the programs administered by the Rural Utilities Service of the Department of Agriculture and the Department of Agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce206188-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the programs administered by or coordinated through the National Telecommunications and Information Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce206189-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In entering into an interagency agreement with respect to the programs described in paragraph (2), the heads of the covered agencies shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce20618a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that the covered agencies share information with each other about existing or planned projects that have received or will receive funds under the programs described in paragraph (2) for new broadband deployment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce20618b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idce20618c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" subject to clause (ii), upon request from another covered agency with authority to award or authorize any funds for new broadband deployment in a project area, a covered agency shall provide the other covered agency with any information the covered agency possesses regarding, with respect to the project area—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idce20618d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each entity that provides broadband service in the area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idce20618e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" levels of broadband service provided in the area, including the speed of broadband service and the technology provided;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idce20618f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/3/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the geographic scope of broadband service coverage in the area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idce206190-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/3/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each entity that has received or will receive funds under the programs described in paragraph (2) to provide broadband service in the area; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce206191-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a covered agency designates any information provided to another covered agency under clause (i) as confidential, the other covered agency shall protect the confidentiality of that information;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce206192-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider basing the distribution of funds for broadband deployment under the programs described in paragraph (2) on standardized data regarding broadband coverage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce206193-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that the interagency agreement shall be updated periodically, except that the scope of the agreement with respect to the Federal Communications Commission may not expand beyond the high-cost programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce206194-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of agreement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce206195-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public comment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after entering into the interagency agreement required under paragraph (2), the Federal Communications Commission shall seek public comment on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idce206196-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of the interagency agreement in facilitating efficient use of funds for broadband deployment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce206197-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of Tribal, State, and local data regarding broadband deployment and the inclusion of that data in interagency coordination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce206198-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modifications to the interagency agreement that would improve the efficacy of interagency coordination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce206199-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment; report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Federal Communications Commission shall—"}],"tail":null},{"tag":"clause","attrib":{"id":"idce20619a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and assess the comments received under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce20619b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1308/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Energy and Commerce of the House of Representatives a report detailing any findings and recommendations from the assessment conducted under clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idce20619c-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tIX/s904"},"text":"Pub. L. 116–260, div. FF, title IX, § 904","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3214"},"text":"134 Stat. 3214","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idce20619d-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"referencesInText","id":"idce20619e-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section, referred to in subsec. (b)(1), was in the original “this Act”, which was translated as meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s904"},"text":"section 904 of Pub. L. 116–260","children":[],"tail":", div. FF, title IX, "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3214"},"text":"134 Stat. 3214","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idce20619f-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Broadband Interagency Coordination Act of 2020 and as part the Consolidated Appropriations Act, 2021, and not as part of the Broadband Data Improvement Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
