{"tag":"section","attrib":{"id":"idd2e1558a-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1753"},"text":null,"children":[{"tag":"num","attrib":{"value":"1753"},"text":"§ 1753.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adoption of consumer broadband labels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2e1558b-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1753/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Commission shall promulgate regulations to require the display of broadband consumer labels, as described in the Public Notice of the Commission issued on "},{"tag":"date","attrib":{"date":"2016-04-04"},"text":"April 4, 2016","children":[],"tail":" (DA 16–357), to disclose to consumers information regarding broadband internet access service plans."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2e1558c-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1753/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Introductory rate information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2e1558d-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1753/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The broadband consumer label required under subsection (a) shall also include information regarding whether the offered price is an introductory rate and, if so, the price the consumer will be required to pay following the introductory period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2e1558e-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1753/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use in broadband data collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall rely on the price information displayed on the broadband consumer label required under subsection (a) for any collection of data relating to the price and subscription rates of each covered broadband internet access service under section 60502(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2e1558f-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1753/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In issuing the final rule under subsection (a), the Commission shall conduct a series of public hearings to assess, at the time of the proceeding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2e15590-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1753/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how consumers evaluate broadband internet access service plans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2e15591-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1753/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether disclosures to consumers of information regarding broadband internet access service plans, including the disclosures required under section 8.1 of title 47, Code of Federal Regulations, are available, effective, and sufficient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2e15592-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dF/tV/s60504"},"text":"Pub. L. 117–58, div. F, title V, § 60504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1244"},"text":"135 Stat. 1244","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2e15593-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2e15594-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd2e15595-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 60502(c), referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s60502/c"},"text":"section 60502(c) of Pub. L. 117–58","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s1752"},"text":"section 1752 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
