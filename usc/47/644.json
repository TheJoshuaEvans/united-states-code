{"tag":"section","attrib":{"id":"idce0168d0-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s644"},"text":null,"children":[{"tag":"num","attrib":{"value":"644"},"text":"§ 644.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improving data accuracy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idce0168d1-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s644/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall conduct regular audits of information submitted to the Commission by providers under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s642/b/2"},"text":"section 642(b)(2) of this title","children":[],"tail":" to ensure that the providers are complying with this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce0168d2-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s644/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crowdsourcing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce0168d3-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s644/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall develop a process through which entities or individuals in the United States may submit specific information about the deployment and availability of broadband internet access service in the United States on an ongoing basis so that the information may be used to verify and supplement information provided by providers of broadband internet access service for inclusion in the maps created under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s642/c/1"},"text":"section 642(c)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0168d4-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s644/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the efforts of the Commission to facilitate the ability of entities and individuals to submit information under paragraph (1), the Commission shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce0168d5-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s644/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prioritize the consideration of data provided by data collection applications used by consumers that the Commission has determined—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idce0168d6-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s644/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are highly reliable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce0168d7-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s644/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have proven methodologies for determining network coverage and network performance; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce0168d8-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s644/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with the Postmaster General, the heads of other Federal agencies that operate delivery fleet vehicles, and the Director of the Bureau of the Census for assistance with data collection whenever coordination could feasibly yield more specific geographic data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce0168d9-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s644/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance to Indian Tribes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce0168da-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s644/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Commission shall hold workshops for Tribal Governments in each of the 12 Bureau of Indian Affairs regions to provide technical assistance with the collection and submission of data under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s642/a/2"},"text":"section 642(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0168db-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s644/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each year, the Commission, in consultation with Indian Tribes, shall review the need for continued workshops required under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce0168dc-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s644/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance to small service providers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall establish a process through which a provider that has fewer than 100,000 active broadband internet access service connections may request and receive assistance from the Commission with respect to geographic information system data processing to ensure that the provider is able to comply with the requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s642/b"},"text":"section 642(b) of this title","children":[],"tail":" in a timely and accurate manner."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce0168dd-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s644/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance to State, local, and Tribal governments and consumers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall provide technical assistance to consumers and State, local, and Tribal governmental entities with respect to the challenge process established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s642/b/5"},"text":"section 642(b)(5) of this title","children":[],"tail":", which shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idce0168de-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s644/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detailed tutorials and webinars; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0168df-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s644/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of staff of the Commission to provide assistance, as needed, throughout the entirety of the challenge process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce0168e0-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s644/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GAO Assessment of Fabric source data","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce0168e1-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s644/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General of the United States shall conduct an assessment of key data sources that are used for purposes of the Fabric to identify and geocode locations where fixed broadband internet access service can be installed in order for the Comptroller General to develop recommendations for how the quality and completeness of those data sources can be improved as data sources for the Fabric.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0168e2-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s644/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sources included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of the assessment conducted under paragraph (1), the key data sources described in that paragraph shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce0168e3-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s644/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any relevant sources of Federal data, including the National Address Database administered by the Department of Transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce0168e4-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s644/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State- and county-level digitized parcel data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce0168e5-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s644/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" property tax attribute recording.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0168e6-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s644/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-03-23"},"text":"March 23, 2020","children":[],"tail":", the Comptroller General of the United States shall submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Energy and Commerce of the House of Representatives a report that contains the recommendations developed under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idce0168e7-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title VIII, § 804, as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/130/s2"},"text":"Pub. L. 116–130, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-23"},"text":"Mar. 23, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/237"},"text":"134 Stat. 237","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dF/tV/s60503"},"text":"Pub. L. 117–58, div. F, title V, § 60503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1244"},"text":"135 Stat. 1244","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idce0168e8-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idce0168e9-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idce0168ea-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(2)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" added subpar. (B) and struck out former subpars. (B) and (C) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-03-23"},"text":"March 23, 2020","children":[],"tail":", conclude a process that tests the feasibility of partnering with Federal agencies that operate delivery fleet vehicles, including the United States Postal Service, to facilitate the collection and submission of information described in that paragraph; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) not later than 14 months after ","children":[{"tag":"date","attrib":{"date":"2020-03-23"},"text":"March 23, 2020","children":[],"tail":", publish on the website of the Commission, and submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Energy and Commerce of the House of Representatives, a report regarding the testing described in subparagraph (B), which shall include—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) a determination regarding whether the partnerships with Federal agencies described in that subparagraph are able to facilitate the collection and submission of information described in paragraph (1); and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) any steps that the Commission plans to take to facilitate the partnerships described in that subparagraph.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
