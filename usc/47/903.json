{"tag":"section","attrib":{"id":"idce0ade5c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s903"},"text":null,"children":[{"tag":"num","attrib":{"value":"903"},"text":"§ 903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spectrum management activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idce0ade5d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision of regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 180 days after ","children":[{"tag":"date","attrib":{"date":"1992-10-27"},"text":"October 27, 1992","children":[],"tail":", the Secretary of Commerce and the NTIA shall amend the Department of Commerce spectrum management document entitled “Manual of Regulations and Procedures for Federal Radio Frequency Management” to improve Federal spectrum management activities and shall publish in the Federal Register any changes in the regulations in such document."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce0ade5e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for revisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amendments required by subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce0ade5f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s903/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for a period at the beginning of each meeting of the Interdepartmental Radio Advisory Committee to be open to the public to make presentations and receive advice, and provide the public with other meaningful opportunities to make presentations and receive advice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0ade60-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s903/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include provisions that will require (A) publication in the Federal Register of major policy proposals that are not classified and that involve spectrum management, and (B) adequate opportunity for public review and comment on those proposals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0ade61-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s903/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include provisions that will require publication in the Federal Register of major policy decisions that are not classified and that involve spectrum management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0ade62-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s903/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include provisions that will require that nonclassified spectrum management information be made available to the public, including access to electronic databases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0ade63-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s903/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish procedures that provide for the prompt and impartial consideration of requests for access to Government spectrum by the public, which procedures shall include provisions that will require the disclosure of the status and ultimate disposition of any such request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce0ade64-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1992-10-27"},"text":"October 27, 1992","children":[],"tail":", the Secretary of Commerce shall certify to Congress that the Secretary has complied with this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce0ade65-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s903/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Radio services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce0ade66-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s903/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignments for radio services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In assigning frequencies for mobile radio services and other radio services, the Secretary of Commerce shall promote efficient and cost-effective use of the spectrum to the maximum extent feasible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0ade67-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s903/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to withhold assignments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce shall have the authority to withhold or refuse to assign frequencies for mobile radio service or other radio service in order to further the goal of making efficient and cost-effective use of the spectrum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0ade68-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s903/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spectrum plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"By ","children":[{"tag":"date","attrib":{"date":"1993-10-01"},"text":"October 1, 1993","children":[],"tail":", the Secretary of Commerce shall adopt and commence implementation of a plan for Federal agencies with existing mobile radio systems to use more spectrum-efficient technologies that are at least as spectrum-efficient and cost-effective as readily available commercial mobile radio systems. The plan shall include a time schedule for implementation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0ade69-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s903/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"By ","children":[{"tag":"date","attrib":{"date":"1993-10-01"},"text":"October 1, 1993","children":[],"tail":", the Secretary of Commerce shall submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Energy and Commerce of the House of Representatives a report summarizing the plan adopted under paragraph (3), including the implementation schedule for the plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce0ade6a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s903/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proof of compliance with FCC licensing requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce0ade6b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s903/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment to manual required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 90 days after ","children":[{"tag":"date","attrib":{"date":"1993-08-10"},"text":"August 10, 1993","children":[],"tail":", the Secretary and the NTIA shall amend the spectrum management document described in subsection (a) to require that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce0ade6c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s903/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no person or entity (other than an agency or instrumentality of the United States) shall be permitted, after 1 year after ","children":[{"tag":"date","attrib":{"date":"1993-08-10"},"text":"August 10, 1993","children":[],"tail":", to operate a radio station utilizing a frequency that is authorized for the use of government stations pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s902/b/2/A"},"text":"section 902(b)(2)(A) of this title","children":[],"tail":" for any non-government application unless such person or entity has submitted to the NTIA proof, in a form prescribed by such manual, that such person or entity has obtained a license from the Commission; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce0ade6d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s903/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no person or entity (other than an agency or instrumentality of the United States) shall be permitted, after 1 year after ","children":[{"tag":"date","attrib":{"date":"1993-08-10"},"text":"August 10, 1993","children":[],"tail":", to utilize a radio station belonging to the United States for any non-government application unless such person or entity has submitted to the NTIA proof, in a form prescribed by such manual, that such person or entity has obtained a license from the Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0ade6e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s903/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention of forms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The NTIA shall maintain on file the proofs submitted under paragraph (1), or facsimiles thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0ade6f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s903/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 1 year after ","children":[{"tag":"date","attrib":{"date":"1993-08-10"},"text":"August 10, 1993","children":[],"tail":", the Secretary and the NTIA shall certify to the Committee on Energy and Commerce of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce0ade70-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s903/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amendments required by paragraph (1) have been accomplished; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce0ade71-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s903/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements of subparagraphs (A) and (B) of such paragraph are being enforced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idce0ade72-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/538/tI/s104"},"text":"Pub. L. 102–538, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3537"},"text":"106 Stat. 3537","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tVI/s6001/b"},"text":"Pub. L. 103–66, title VI, § 6001(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/387"},"text":"107 Stat. 387","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idce0ade73-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idce0ade74-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idce0ade75-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idce0ade76-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idce0ade77-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Energy and Commerce of House of Representatives treated as referring to Committee on Commerce of House of Representatives by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/14/s1/a"},"text":"section 1(a) of Pub. L. 104–14","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s21"},"text":"section 21 of Title 2","children":[],"tail":", The Congress. Committee on Commerce of House of Representatives changed to Committee on Energy and Commerce of House of Representatives, and jurisdiction over matters relating to securities and exchanges and insurance generally transferred to Committee on Financial Services of House of Representatives by House Resolution No. 5, One Hundred Seventh Congress, "},{"tag":"date","attrib":{"date":"2001-01-03"},"text":"Jan. 3, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idce0ade78-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authorization of Use of Spectrum By, and Provision of Spectrum Functions to, Federal Entity; Reimbursement","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dB/tII"},"text":"Pub. L. 108–7, div. B, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/71"},"text":"117 Stat. 71","children":[],"tail":", provided in part: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/7/dB/tII"},"text":"“That hereafter, notwithstanding any other provision of law, NTIA [National Telecommunications and Information Administration] shall not authorize spectrum use or provide any spectrum functions pursuant to the National Telecommunications and Information Administration Organization Act, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s902–903"},"text":"47 U.S.C. 902–903","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t47/s901"},"text":"47 U.S.C. 901","children":[],"tail":" et seq.], to any Federal entity without reimbursement as required by NTIA for such spectrum management costs, and Federal entities withholding payment of such cost shall not use spectrum”."}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/77/tII"},"text":"Pub. L. 107–77, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-28"},"text":"Nov. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/772"},"text":"115 Stat. 772","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/553/s1/a/2/tII"},"text":"Pub. L. 106–553, § 1(a)(2) [title II]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2762"},"text":"114 Stat. 2762","children":[],"tail":", 2762A–72."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/1/tII"},"text":"Pub. L. 106–113, div. B, § 1000(a)(1) [title II]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1535"},"text":"113 Stat. 1535","children":[],"tail":", 1501A–26."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/b/tII"},"text":"Pub. L. 105–277, div. A, § 101(b) [title II]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-50"},"text":"112 Stat. 2681–50","children":[],"tail":", 2681–80."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/119/tII"},"text":"Pub. L. 105–119, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-26"},"text":"Nov. 26, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2474"},"text":"111 Stat. 2474","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/a/tII"},"text":"Pub. L. 104–208, div. A, title I, § 101(a) [title II]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009"},"text":"110 Stat. 3009","children":[],"tail":", 3009–35."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
