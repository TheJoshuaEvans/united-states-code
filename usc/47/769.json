{"tag":"section","attrib":{"id":"idce03d9ec-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769"},"text":null,"children":[{"tag":"num","attrib":{"value":"769"},"text":"§ 769.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idce03d9ed-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce03d9ee-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" INTELSAT","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “INTELSAT” means the International Telecommunications Satellite Organization established pursuant to the Agreement Relating to the International Telecommunications Satellite Organization (INTELSAT).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce03d9ef-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inmarsat","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Inmarsat” means the International Mobile Satellite Organization established pursuant to the Convention on the International Maritime Organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce03d9f0-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Signatories","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “signatories”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce03d9f1-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of INTELSAT, or INTELSAT successors or separated entities, means a Party, or the telecommunications entity designated by a Party, that has signed the Operating Agreement and for which such Agreement has entered into force; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce03d9f2-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of Inmarsat, or Inmarsat successors or separated entities, means either a Party to, or an entity that has been designated by a Party to sign, the Operating Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce03d9f3-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Party","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Party”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce03d9f4-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of INTELSAT, means a nation for which the INTELSAT agreement has entered into force; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce03d9f5-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of Inmarsat, means a nation for which the Inmarsat convention has entered into force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce03d9f6-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commission” means the Federal Communications Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce03d9f7-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International Telecommunication Union","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “International Telecommunication Union” means the intergovernmental organization that is a specialized agency of the United Nations in which member countries cooperate for the development of telecommunications, including adoption of international regulations governing terrestrial and space uses of the frequency spectrum as well as use of the geostationary satellite orbit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce03d9f8-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Successor entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “successor entity”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce03d9f9-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means any privatized entity created from the privatization of INTELSAT or Inmarsat or from the assets of INTELSAT or Inmarsat; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce03d9fa-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include any entity that is a separated entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce03d9fb-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separated entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “separated entity” means a privatized entity to whom a portion of the assets owned by INTELSAT or Inmarsat are transferred prior to full privatization of INTELSAT or Inmarsat, including in particular the entity whose structure was under discussion by INTELSAT as of ","children":[{"tag":"date","attrib":{"date":"1998-03-25"},"text":"March 25, 1998","children":[],"tail":", but excluding ICO."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce03d9fc-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Orbital location","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “orbital location” means the location for placement of a satellite on the geostationary orbital arc as defined in the International Telecommunication Union Radio Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce03d9fd-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Space segment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “space segment” means the satellites, and the tracking, telemetry, command, control, monitoring and related facilities and equipment used to support the operation of satellites owned or leased by INTELSAT, Inmarsat, or a separated entity or successor entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce03d9fe-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-core services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “non-core services” means, with respect to INTELSAT provision, services other than public-switched network voice telephony and occasional-use television, and with respect to Inmarsat provision, services other than global maritime distress and safety services or other existing maritime or aeronautical services for which there are not alternative providers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce03d9ff-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “additional services” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce03da00-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for Inmarsat, those non-maritime or non-aeronautical mobile services in the 1.5 and 1.6 Ghz band on planned satellites or the 2 Ghz band; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce03da01-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for INTELSAT, direct-to-home (DTH) or direct broadcast satellite (DBS) video services, or services in the Ka or V bands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce03da02-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" INTELSAT Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “INTELSAT Agreement” means the Agreement Relating to the International Telecommunications Satellite Organization (“INTELSAT”), including all its annexes (TIAS 7532, 23 UST 3813).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0622f3-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Headquarters Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Headquarters Agreement” means the International Telecommunication ","children":[{"tag":"ref","attrib":{"idref":"fn002052"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002052"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Telecommunications”."}],"tail":" Satellite Organization Headquarters Agreement ("},{"tag":"date","attrib":{"date":"1976-11-24"},"text":"November 24, 1976","children":[],"tail":") (TIAS 8542, 28 UST 2248)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0622f4-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operating Agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Operating Agreement” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce0622f5-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of INTELSAT, the agreement, including its annex but excluding all titles of articles, opened for signature at Washington on ","children":[{"tag":"date","attrib":{"date":"1971-08-20"},"text":"August 20, 1971","children":[],"tail":", by Governments or telecommunications entities designated by Governments in accordance with the provisions of the Agreement; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce0622f6-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of Inmarsat, the Operating Agreement on the International Maritime Satellite Organization, including its annexes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0622f7-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inmarsat Convention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Inmarsat Convention” means the Convention on the International Maritime Satellite Organization (Inmarsat) (TIAS 9605, 31 UST 1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0622f8-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “national corporation” means a corporation the ownership of which is held through publicly traded securities, and that is incorporated under, and subject to, the laws of a national, state, or territorial government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0622f9-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" COMSAT","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “COMSAT” means the corporation established pursuant to subchapter III of this chapter, or the successor in interest to such corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0622fa-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ICO","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “ICO” means the company known, as of ","children":[{"tag":"date","attrib":{"date":"2000-03-17"},"text":"March 17, 2000","children":[],"tail":", as ICO Global Communications, Inc."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0622fb-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Global maritime distress and safety services or GMDSS","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “global maritime distress and safety services” or “GMDSS” means the automated ship-to-shore distress alerting system which uses satellite and advanced terrestrial systems for international distress communications and promoting maritime safety in general. The GMDSS permits the worldwide alerting of vessels, coordinated search and rescue operations, and dissemination of maritime safety information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce0622fc-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/a/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National security agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “national security agency” means the National Security Agency, the Director of Central Intelligence and the Central Intelligence Agency, the Department of Defense, and the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce0622fd-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s769/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Common terminology","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in subsection (a), terms used in this subchapter that are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s153"},"text":"section 153 of this title","children":[],"tail":" have the meanings provided in such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idce0622fe-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/624/tVI/s681"},"text":"Pub. L. 87–624, title VI, § 681","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/180/s3"},"text":"Pub. L. 106–180, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-03-17"},"text":"Mar. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/58"},"text":"114 Stat. 58","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idce0622ff-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idce062300-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idce062301-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to the Director of Central Intelligence or the Director of the Central Intelligence Agency in the Director’s capacity as the head of the intelligence community deemed to be a reference to the Director of National Intelligence. Reference to the Director of Central Intelligence or the Director of the Central Intelligence Agency in the Director’s capacity as the head of the Central Intelligence Agency deemed to be a reference to the Director of the Central Intelligence Agency. See section 1081(a), (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of Title 50","children":[],"tail":", War and National Defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idce062302-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
