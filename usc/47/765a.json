{"tag":"section","attrib":{"id":"idd2b192ca-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s765a"},"text":null,"children":[{"tag":"num","attrib":{"value":"765a"},"text":"§ 765a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Signatory role","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2b192cb-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s765a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on signatories","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2b192cc-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s765a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National security limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Communications Commission, after a public interest determination, in consultation with the executive branch, may restrict foreign ownership of a United States signatory if the Commission determines that not to do so would constitute a threat to national security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2b192cd-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s765a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No signatories required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Government shall not require signatories to represent the United States in INTELSAT or Inmarsat or in any successor entities after a pro-competitive privatization is achieved consistent with sections 763, 763a, and 763c ","children":[{"tag":"ref","attrib":{"idref":"fn002050"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002050"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2b192ce-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s765a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification of privileges and immunities of COMSAT","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2b192cf-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s765a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Generally not immunized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other law or executive agreement, COMSAT shall not be entitled to any privileges or immunities under the laws of the United States or any State on the basis of its status as a signatory of INTELSAT or Inmarsat.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2b192d0-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s765a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited immunity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"COMSAT or any successor in interest shall not be liable for action taken by it in carrying out the specific, written instruction of the United States issued in connection with its relationships and activities with foreign governments, international entities, and the intergovernmental satellite organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2b192d1-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s765a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No joint or several liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If COMSAT is found liable for any action taken in its status as a signatory or a representative of the party to INTELSAT, any such liability shall be limited to the portion of the judgment that corresponds to COMSAT’s percentage of the ownership of INTELSAT at the time the activity began which lead to the liability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2b192d2-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s765a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions prospective","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply with respect to liability for any action taken by COMSAT before ","children":[{"tag":"date","attrib":{"date":"2000-03-17"},"text":"March 17, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2b192d3-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s765a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parity of treatment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other law or executive agreement, the Commission shall have the authority to impose similar regulatory fees on the United States signatory which it imposes on other entities providing similar services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2b192d4-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/624/tVI/s642"},"text":"Pub. L. 87–624, title VI, § 642","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/180/s3"},"text":"Pub. L. 106–180, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-03-17"},"text":"Mar. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/55"},"text":"114 Stat. 55","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2b192d5-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2b192d6-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd2b192d7-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s763c"},"text":"Section 763c of this title","children":[],"tail":", referred to in subsec. (a)(2), was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/109/34/s3"},"text":"Pub. L. 109–34, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-07-12"},"text":"July 12, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/377"},"text":"119 Stat. 377","children":[],"tail":", and no longer relates to specific criteria for Inmarsat privatization."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
