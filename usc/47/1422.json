{"tag":"section","attrib":{"id":"idd2cbd129-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1422"},"text":null,"children":[{"tag":"num","attrib":{"value":"1422"},"text":"§ 1422.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public safety broadband network","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2cbd12a-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1422/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The First Responder Network Authority shall ensure the establishment of a nationwide, interoperable public safety broadband network.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2cbd12b-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1422/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Network components","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The nationwide public safety broadband network shall be based on a single, national network architecture that evolves with technological advancements and initially consists of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2cbd12c-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1422/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a core network that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2cbd12d-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1422/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consists of national and regional data centers, and other elements and functions that may be distributed geographically, all of which shall be based on commercial standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2cbd12e-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1422/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides the connectivity between—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd2cbd12f-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1422/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the radio access network; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2cbd130-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1422/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public Internet or the public switched network, or both; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2cbd131-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1422/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a radio access network that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2cbd132-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1422/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consists of all cell site equipment, antennas, and backhaul equipment, based on commercial standards, that are required to enable wireless communications with devices using the public safety broadband spectrum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2cbd133-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1422/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be developed, constructed, managed, maintained, and operated taking into account the plans developed in the State, local, and tribal planning and implementation grant program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1442/a"},"text":"section 1442(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2cbd134-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/96/tVI/s6202"},"text":"Pub. L. 112–96, title VI, § 6202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/206"},"text":"126 Stat. 206","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
