{"tag":"section","attrib":{"id":"idce206203-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1421"},"text":null,"children":[{"tag":"num","attrib":{"value":"1421"},"text":"§ 1421.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Single public safety wireless network licensee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idce206204-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1421/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallocation and grant of license","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, and subject to the provisions of this chapter, the Commission shall reallocate and grant a license to the First Responder Network Authority for the use of the 700 MHz D block spectrum and existing public safety broadband spectrum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce206205-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1421/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of license","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce206206-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1421/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial license","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The license granted under subsection (a) shall be for an initial term of 10 years from the date of the initial issuance of the license.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce206207-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1421/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal of license","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to expiration of the term of the initial license granted under subsection (a) or the expiration of any subsequent renewal of such license, the First Responder Network Authority shall submit to the Commission an application for the renewal of such license. Such renewal application shall demonstrate that, during the preceding license term, the First Responder Network Authority has met the duties and obligations set forth under this chapter. A renewal license granted under this paragraph shall be for a term of not to exceed 10 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce206208-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1421/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilitation of transition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall take all actions necessary to facilitate the transition of the existing public safety broadband spectrum to the First Responder Network Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idce206209-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/96/tVI/s6201"},"text":"Pub. L. 112–96, title VI, § 6201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/206"},"text":"126 Stat. 206","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idce20620a-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idce20620b-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idce20620c-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (b)(2), was in the original “this Act”, and was translated as reading “this title”, meaning title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/96"},"text":"Pub. L. 112–96","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/201"},"text":"126 Stat. 201","children":[],"tail":", to reflect the probable intent of Congress. Title VI enacted this chapter and "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s929"},"text":"section 929 of this title","children":[],"tail":", amended sections 309, 337, 614, 902, 923, 928, and 942 of this title, and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s1401"},"text":"section 1401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
