{"tag":"section","attrib":{"id":"idd2af21fc-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s646"},"text":null,"children":[{"tag":"num","attrib":{"value":"646"},"text":"§ 646.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2af21fd-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s646/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" OMB","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the initial rule making required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s642/a/1"},"text":"section 642(a)(1) of this title","children":[],"tail":" shall be exempt from review by the Office of Management and Budget."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2af21fe-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s646/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" PRA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subchapter I of chapter 35 of title 44 (commonly known as the “Paperwork Reduction Act”) shall not apply to any rule making or other action by the Commission required under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2af21ff-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s646/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Execution of responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except, with respect to an entity that is not the Universal Service Administrative Company, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s642/a/2/B"},"text":"section 642(a)(2)(B) of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s642/b/1/A/ii"},"text":"section 642(b)(1)(A)(ii) of this title","children":[],"tail":", and subsections (c), (d), and (e) of "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s644"},"text":"section 644 of this title","children":[],"tail":", the Commission—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2af2200-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s646/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" including the offices of the Commission, shall carry out the responsibilities assigned to the Commission under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2af2201-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s646/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not delegate any of the responsibilities assigned to the Commission under this subchapter to any third party, including the Universal Service Administrative Company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2af2202-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s646/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each fiscal year, the Commission shall submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Energy and Commerce of the House of Representatives a report that summarizes the implementation of this subchapter and associated enforcement activities conducted during the previous fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2af2203-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s646/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Commission, before ","children":[{"tag":"date","attrib":{"date":"2020-03-23"},"text":"March 23, 2020","children":[],"tail":", has taken an action that, in whole or in part, implements this subchapter, the Commission shall not be required to revisit such action to the extent that such action is consistent with this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2af2204-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title VIII, § 806, as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/130/s2"},"text":"Pub. L. 116–130, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-23"},"text":"Mar. 23, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/238"},"text":"134 Stat. 238","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dF/tI/s60102/h/2/E/ii"},"text":"Pub. L. 117–58, div. F, title I, § 60102(h)(2)(E)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1198"},"text":"135 Stat. 1198","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2af2205-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2af2206-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd2af2207-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" substituted “any rule making or other action by the Commission required under this subchapter” for “the initial rule making required under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s642/a/1"},"text":"section 642(a)(1) of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd2af2208-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd2af2209-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For requirement to implement amendment made by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s60102/h/2/E/ii"},"text":"section 60102(h)(2)(E)(ii) of Pub. L. 117–58","children":[],"tail":" as soon as possible after "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s1702/h/2/E/iii"},"text":"section 1702(h)(2)(E)(iii) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
