{"tag":"section","attrib":{"id":"idce22d400-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1431"},"text":null,"children":[{"tag":"num","attrib":{"value":"1431"},"text":"§ 1431.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public safety roaming and priority access","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Commission may adopt rules, if necessary in the public interest, to improve the ability of public safety networks to roam onto commercial networks and to gain priority access to commercial networks in an emergency if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce22d401-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1431/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public safety entity equipment is technically compatible with the commercial network;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce22d402-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1431/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the commercial network is reasonably compensated; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce22d403-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1431/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such access does not preempt or otherwise terminate or degrade all existing voice conversations or data sessions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idce22d404-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/96/tVI/s6211"},"text":"Pub. L. 112–96, title VI, § 6211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/218"},"text":"126 Stat. 218","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
