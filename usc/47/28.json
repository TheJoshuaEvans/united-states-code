{"tag":"section","attrib":{"id":"idcd7e2e80-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s28"},"text":null,"children":[{"tag":"num","attrib":{"value":"28"},"text":"§ 28.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties not to bar suits for damages","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The penalties provided in this chapter for the breaking or injury of a submarine cable shall not be a bar to a suit for damages on account of such breaking or injury.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcd809f81-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1888-02-29/ch17/s8"},"text":"Feb. 29, 1888, ch. 17, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/25/42"},"text":"25 Stat. 42","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
