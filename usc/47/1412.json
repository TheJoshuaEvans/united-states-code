{"tag":"section","attrib":{"id":"idd2cbd119-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1412"},"text":null,"children":[{"tag":"num","attrib":{"value":"1412"},"text":"§ 1412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flexible use of narrowband spectrum","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commission may allow the narrowband spectrum to be used in a flexible manner, including usage for public safety broadband communications, subject to such technical and interference protection measures as the Commission may require.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd2cbd11a-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/96/tVI/s6102"},"text":"Pub. L. 112–96, title VI, § 6102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/205"},"text":"126 Stat. 205","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
