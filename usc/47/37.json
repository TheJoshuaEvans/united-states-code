{"tag":"section","attrib":{"id":"idd22c0ec4-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s37"},"text":null,"children":[{"tag":"num","attrib":{"value":"37"},"text":"§ 37.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations; punishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever knowingly commits, instigates, or assists in any act forbidden by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s34"},"text":"section 34 of this title","children":[],"tail":" shall be guilty of a misdemeanor and shall be fined not more than $5,000, or imprisoned for not more than one year, or both."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd22c0ec5-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-05-27/ch12/s4"},"text":"May 27, 1921, ch. 12, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/8"},"text":"42 Stat. 8","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd22c0ec6-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd22c0ec7-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idd22c0ec8-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Submarine Cable Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
