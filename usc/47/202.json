{"tag":"section","attrib":{"id":"idcd962384-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s202"},"text":null,"children":[{"tag":"num","attrib":{"value":"202"},"text":"§ 202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discriminations and preferences","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcd962385-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charges, services, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any common carrier to make any unjust or unreasonable discrimination in charges, practices, classifications, regulations, facilities, or services for or in connection with like communication service, directly or indirectly, by any means or device, or to make or give any undue or unreasonable preference or advantage to any particular person, class of persons, or locality, or to subject any particular person, class of persons, or locality to any undue or unreasonable prejudice or disadvantage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcd962386-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charges or services included","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Charges or services, whenever referred to in this chapter, include charges for, or services in connection with, the use of common carrier lines of communication, whether derived from wire or radio facilities, in chain broadcasting or incidental to radio communication of any kind.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcd962387-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s202/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any carrier who knowingly violates the provisions of this section shall forfeit to the United States the sum of $6,000 for each such offense and $300 for each and every day of the continuance of such offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcd962388-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title II, § 202, "},{"tag":"ref","attrib":{"href":"/us/stat/48/1070"},"text":"48 Stat. 1070","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/751"},"text":"Pub. L. 86–751","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-13"},"text":"Sept. 13, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/888"},"text":"74 Stat. 888","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tIII/s3002/a"},"text":"Pub. L. 101–239, title III, § 3002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2131"},"text":"103 Stat. 2131","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcd962389-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcd96238a-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcd96238b-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"act June 19, 1934, ch. 652","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1064"},"text":"48 Stat. 1064","children":[],"tail":", known as the Communications Act of 1934, which is classified principally to this chapter. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s609"},"text":"section 609 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcd96238c-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" substituted “$6,000” for “$500” and “$300” for “$25”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/751"},"text":"Pub. L. 86–751","children":[],"tail":" substituted “common carrier lines of communication, whether derived from wire or radio facilities,” for “wires”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
