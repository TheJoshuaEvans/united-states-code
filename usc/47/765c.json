{"tag":"section","attrib":{"id":"idce03d9d0-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s765c"},"text":null,"children":[{"tag":"num","attrib":{"value":"765c"},"text":"§ 765c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ITU functions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idce03d9d1-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s765c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission and United States satellite companies shall utilize the International Telecommunication Union procedures for technical coordination with INTELSAT and its successor entities and separated entities, rather than INTELSAT procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce03d9d2-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s765c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ITU notifying administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President and the Commission shall take the action necessary to ensure that the United States remains the ITU notifying administration for the privatized INTELSAT’s existing and future orbital slot registrations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idce03d9d3-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/624/tVI/s644"},"text":"Pub. L. 87–624, title VI, § 644","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/180/s3"},"text":"Pub. L. 106–180, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-03-17"},"text":"Mar. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/56"},"text":"114 Stat. 56","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
