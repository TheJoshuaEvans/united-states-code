{"tag":"section","attrib":{"id":"idd281f763-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s386"},"text":null,"children":[{"tag":"num","attrib":{"value":"386"},"text":"§ 386.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeitures","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The following forfeitures shall apply to this part in addition to penalties and forfeitures provided by subchapter V of this chapter:","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd281f764-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s386/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any vessel of the United States that is navigated in violation of the provisions of this part or of the rules and regulations of the Commission made in pursuance thereof shall forfeit to the United States the sum of $5,000 recoverable by way of suit or libel. Each day during which such navigation occurs shall constitute a separate offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd281f765-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s386/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Every willful failure on the part of the master of a vessel of the United States to enforce or to comply with the provisions of this part or the rules and regulations of the Commission made in pursuance thereof shall cause him to forfeit to the United States the sum of $1,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd281f766-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title III, § 386, as added "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-06/ch973/s1"},"text":"Aug. 6, 1956, ch. 973, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/1048"},"text":"70 Stat. 1048","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tIII/s3002/h"},"text":"Pub. L. 101–239, title III, § 3002(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2131"},"text":"103 Stat. 2131","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/414/tIII/s303/a/20/F"},"text":"Pub. L. 103–414, title III, § 303(a)(20)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4295"},"text":"108 Stat. 4295","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd281f767-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd281f768-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd281f769-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/414"},"text":"Pub. L. 103–414","children":[],"tail":" inserted section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s3002/h/1"},"text":"Pub. L. 101–239, § 3002(h)(1)","children":[],"tail":", substituted “$5,000” for “$500”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s3002/h/2"},"text":"Pub. L. 101–239, § 3002(h)(2)","children":[],"tail":", substituted “$1,000” for “$100”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd281f76a-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idd281f76b-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1957-03-01"},"text":"Mar. 1, 1957","children":[],"tail":", see section 4 of act "},{"tag":"date","attrib":{"date":"1956-08-06"},"text":"Aug. 6, 1956","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s381"},"text":"section 381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
