{"tag":"section","attrib":{"id":"idcd9ade30-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222"},"text":null,"children":[{"tag":"num","attrib":{"value":"222"},"text":"§ 222.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy of customer information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcd9ade31-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every telecommunications carrier has a duty to protect the confidentiality of proprietary information of, and relating to, other telecommunication carriers, equipment manufacturers, and customers, including telecommunication carriers reselling telecommunications services provided by a telecommunications carrier.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcd9ade32-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality of carrier information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A telecommunications carrier that receives or obtains proprietary information from another carrier for purposes of providing any telecommunications service shall use such information only for such purpose, and shall not use such information for its own marketing efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcd9ade33-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality of customer proprietary network information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcd9ade34-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy requirements for telecommunications carriers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as required by law or with the approval of the customer, a telecommunications carrier that receives or obtains customer proprietary network information by virtue of its provision of a telecommunications service shall only use, disclose, or permit access to individually identifiable customer proprietary network information in its provision of (A) the telecommunications service from which such information is derived, or (B) services necessary to, or used in, the provision of such telecommunications service, including the publishing of directories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcd9ade35-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure on request by customers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A telecommunications carrier shall disclose customer proprietary network information, upon affirmative written request by the customer, to any person designated by the customer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcd9ade36-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregate customer information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A telecommunications carrier that receives or obtains customer proprietary network information by virtue of its provision of a telecommunications service may use, disclose, or permit access to aggregate customer information other than for the purposes described in paragraph (1). A local exchange carrier may use, disclose, or permit access to aggregate customer information other than for purposes described in paragraph (1) only if it provides such aggregate information to other carriers or persons on reasonable and nondiscriminatory terms and conditions upon reasonable request therefor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcd9ade37-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section prohibits a telecommunications carrier from using, disclosing, or permitting access to customer proprietary network information obtained from its customers, either directly or indirectly through its agents—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcd9ade38-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to initiate, render, bill, and collect for telecommunications services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcd9ade39-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect the rights or property of the carrier, or to protect users of those services and other carriers from fraudulent, abusive, or unlawful use of, or subscription to, such services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcd9ade3a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide any inbound telemarketing, referral, or administrative services to the customer for the duration of the call, if such call was initiated by the customer and the customer approves of the use of such information to provide such service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcd9ade3b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to provide call location information concerning the user of a commercial mobile service (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s332/d"},"text":"section 332(d) of this title","children":[],"tail":") or the user of an IP-enabled voice service (as such term is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s615b"},"text":"section 615b of this title","children":[],"tail":")—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcd9ade3c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a public safety answering point, emergency medical service provider or emergency dispatch provider, public safety, fire service, or law enforcement official, or hospital emergency or trauma care facility, in order to respond to the user’s call for emergency services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcd9ade3d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to inform the user’s legal guardian or members of the user’s immediate family of the user’s location in an emergency situation that involves the risk of death or serious physical harm; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcd9ade3e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to providers of information or database management services solely for purposes of assisting in the delivery of emergency services in response to an emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcd9ade3f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subscriber list information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsections (b), (c), and (d), a telecommunications carrier that provides telephone exchange service shall provide subscriber list information gathered in its capacity as a provider of such service on a timely and unbundled basis, under nondiscriminatory and reasonable rates, terms, and conditions, to any person upon request for the purpose of publishing directories in any format.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcd9ade40-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to use location information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (c)(1), without the express prior authorization of the customer, a customer shall not be considered to have approved the use or disclosure of or access to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcd9ade41-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" call location information concerning the user of a commercial mobile service (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s332/d"},"text":"section 332(d) of this title","children":[],"tail":") or the user of an IP-enabled voice service (as such term is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s615b"},"text":"section 615b of this title","children":[],"tail":"), other than in accordance with subsection (d)(4); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcd9ade42-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" automatic crash notification information to any person other than for use in the operation of an automatic crash notification system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcd9ade43-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subscriber listed and unlisted information for emergency services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsections (b), (c), and (d), a telecommunications carrier that provides telephone exchange service or a provider of IP-enabled voice service (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s615b"},"text":"section 615b of this title","children":[],"tail":") shall provide information described in subsection (i)(3)(A) "},{"tag":"ref","attrib":{"idref":"fn002003"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002003"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be subsection “(h)(3)(A)”."}],"tail":" (including information pertaining to subscribers whose information is unlisted or unpublished) that is in its possession or control (including information pertaining to subscribers of other carriers) on a timely and unbundled basis, under nondiscriminatory and reasonable rates, terms, and conditions to providers of emergency services, and providers of emergency support services, solely for purposes of delivering or assisting in the delivery of emergency services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcd9ade44-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcd9ade45-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Customer proprietary network information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “customer proprietary network information” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcd9ade46-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information that relates to the quantity, technical configuration, type, destination, location, and amount of use of a telecommunications service subscribed to by any customer of a telecommunications carrier, and that is made available to the carrier by the customer solely by virtue of the carrier-customer relationship; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcd9ade47-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information contained in the bills pertaining to telephone exchange service or telephone toll service received by a customer of a carrier;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except that such term does not include subscriber list information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcd9ade48-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregate information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “aggregate customer information” means collective data that relates to a group or category of services or customers, from which individual customer identities and characteristics have been removed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcd9ade49-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subscriber list information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “subscriber list information” means any information—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcd9ade4a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying the listed names of subscribers of a carrier and such subscribers’ telephone numbers, addresses, or primary advertising classifications (as such classifications are assigned at the time of the establishment of such service), or any combination of such listed names, numbers, addresses, or classifications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcd9ade4b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the carrier or an affiliate has published, caused to be published, or accepted for publication in any directory format.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcd9ade4c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public safety answering point","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “public safety answering point” means a facility that has been designated to receive emergency calls and route them to emergency service personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcd9ade4d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “emergency services” means 9–1–1 emergency services and emergency notification services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcd9ade4e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/h/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency notification services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “emergency notification services” means services that notify the public of an emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcd9ade4f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s222/h/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency support services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “emergency support services” means information or data base management services used in support of emergency services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcd9ade50-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title II, § 222, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/104/tVII/s702"},"text":"