{"tag":"section","attrib":{"id":"idce16ec0a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1006"},"text":null,"children":[{"tag":"num","attrib":{"value":"1006"},"text":"§ 1006.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical requirements and standards; extension of compliance date","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idce16ec0b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1006/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safe harbor","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce16ec0c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1006/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To ensure the efficient and industry-wide implementation of the assistance capability requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1002"},"text":"section 1002 of this title","children":[],"tail":", the Attorney General, in coordination with other Federal, State, and local law enforcement agencies, shall consult with appropriate associations and standard-setting organizations of the telecommunications industry, with representatives of users of telecommunications equipment, facilities, and services, and with State utility commissions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce16ec0d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1006/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance under accepted standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A telecommunications carrier shall be found to be in compliance with the assistance capability requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1002"},"text":"section 1002 of this title","children":[],"tail":", and a manufacturer of telecommunications transmission or switching equipment or a provider of telecommunications support services shall be found to be in compliance with "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s1005"},"text":"section 1005 of this title","children":[],"tail":", if the carrier, manufacturer, or support service provider is in compliance with publicly available technical requirements or standards adopted by an industry association or standard-setting organization, or by the Commission under subsection (b), to meet the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s1002"},"text":"section 1002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce16ec0e-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1006/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Absence of standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The absence of technical requirements or standards for implementing the assistance capability requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1002"},"text":"section 1002 of this title","children":[],"tail":" shall not—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce16ec0f-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1006/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preclude a telecommunications carrier, manufacturer, or telecommunications support services provider from deploying a technology or service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce16ec10-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1006/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relieve a carrier, manufacturer, or telecommunications support services provider of the obligations imposed by section 1002 or 1005 of this title, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce16ec11-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1006/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If industry associations or standard-setting organizations fail to issue technical requirements or standards or if a Government ","children":[{"tag":"ref","attrib":{"idref":"fn002058"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002058"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" agency or any other person believes that such requirements or standards are deficient, the agency or person may petition the Commission to establish, by rule, technical requirements or standards that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idce16ec12-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1006/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the assistance capability requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1002"},"text":"section 1002 of this title","children":[],"tail":" by cost-effective methods;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce16ec13-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1006/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect the privacy and security of communications not authorized to be intercepted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce16ec14-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1006/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize the cost of such compliance on residential ratepayers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce16ec15-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1006/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve the policy of the United States to encourage the provision of new technologies and services to the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce16ec16-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1006/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a reasonable time and conditions for compliance with and the transition to any new standard, including defining the obligations of telecommunications carriers under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1002"},"text":"section 1002 of this title","children":[],"tail":" during any transition period."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce16ec17-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1006/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of compliance date for equipment, facilities, and services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce16ec18-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1006/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A telecommunications carrier proposing to install or deploy, or having installed or deployed, any equipment, facility, or service prior to the effective date of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1002"},"text":"section 1002 of this title","children":[],"tail":" may petition the Commission for 1 or more extensions of the deadline for complying with the assistance capability requirements under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s1002"},"text":"section 1002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce16ec19-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1006/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grounds for extension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may, after consultation with the Attorney General, grant an extension under this subsection, if the Commission determines that compliance with the assistance capability requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1002"},"text":"section 1002 of this title","children":[],"tail":" is not reasonably achievable through application of technology available within the compliance period."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce16ec1a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1006/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Length of extension","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An extension under this subsection shall extend for no longer than the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce16ec1b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1006/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date determined by the Commission as necessary for the carrier to comply with the assistance capability requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1002"},"text":"section 1002 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce16ec1c-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1006/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that is 2 years after the date on which the extension is granted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce16ec1d-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1006/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of extension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An extension under this subsection shall apply to only that part of the carrier’s business on which the new equipment, facility, or service is used.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idce16ec1e-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/414/tI/s107"},"text":"Pub. L. 103–414, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4284"},"text":"108 Stat. 4284","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idce16ec1f-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idce16ec20-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idce16ec21-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The effective date of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1002"},"text":"section 1002 of this title","children":[],"tail":", referred to in subsec. (c)(1), is the date that is 4 years after "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/414/s111/b"},"text":"section 111(b) of Pub. L. 103–414","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
