{"tag":"section","attrib":{"id":"idd2a0f07f-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s559"},"text":null,"children":[{"tag":"num","attrib":{"value":"559"},"text":"§ 559.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obscene programming","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever transmits over any cable system any matter which is obscene or otherwise unprotected by the Constitution of the United States shall be fined under title 18 or imprisoned not more than 2 years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idd2a0f080-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title VI, § 639, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/549/s2"},"text":"Pub. L. 98–549, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2801"},"text":"98 Stat. 2801","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/104/tV/s503"},"text":"Pub. L. 104–104, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-08"},"text":"Feb. 8, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/136"},"text":"110 Stat. 136","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd2a0f081-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd2a0f082-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd2a0f083-4ef6-11f