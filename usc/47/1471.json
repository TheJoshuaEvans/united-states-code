{"tag":"section","attrib":{"id":"idd2d2fd41-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1471"},"text":null,"children":[{"tag":"num","attrib":{"value":"1471"},"text":"§ 1471.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2d2fd42-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1471/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 9–1–1 services and E9–1–1 services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “9–1–1 services” and “E9–1–1 services” shall have the meaning given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s942"},"text":"section 942 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d2fd43-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1471/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multi-line telephone system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “multi-line telephone system” or “MLTS” means a system comprised of common control units, telephone sets, control hardware and software and adjunct systems, including network and premises based systems, such as Centrex and VoIP, as well as PBX, Hybrid, and Key Telephone Systems (as classified by the Commission under part 68 of title 47, Code of Federal Regulations), and includes systems owned or leased by governmental agencies and non-profit entities, as well as for profit businesses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d2fd44-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1471/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Office” means the 9–1–1 Implementation Coordination Office established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s942"},"text":"section 942 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2d2fd45-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/96/tVI/s6502"},"text":"Pub. L. 112–96, title VI, § 6502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/237"},"text":"126 Stat. 237","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
