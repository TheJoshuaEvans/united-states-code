{"tag":"section","attrib":{"id":"idd2d2fdaf-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1506"},"text":null,"children":[{"tag":"num","attrib":{"value":"1506"},"text":"§ 1506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking related to partitioning or disaggregating licenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd2d2fdb0-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2d2fdb1-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1506/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered small carrier","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered small carrier” means a carrier (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s153"},"text":"section 153 of this title","children":[],"tail":") that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2d2fdb2-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1506/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not more than 1,500 employees (as determined under section 121.106 of title 13, Code of Federal Regulations, or any successor thereto); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2d2fdb3-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1506/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offers services using the facilities of the carrier.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d2fdb4-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1506/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural area","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “rural area” means any area other than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2d2fdb5-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1506/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a city, town, or incorporated area that has a population of more than 20,000 inhabitants; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2d2fdb6-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1506/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an urbanized area contiguous and adjacent to a city or town that has a population of more than 50,000 inhabitants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd2d2fdb7-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd2d2fdb8-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1506/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2018-03-23"},"text":"March 23, 2018","children":[],"tail":", the Commission shall initiate a rulemaking proceeding to assess whether to establish a program, or modify existing programs, under which a licensee that receives a license for the exclusive use of spectrum in a specific geographic area under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s301"},"text":"section 301 of this title","children":[],"tail":" may partition or disaggregate the license by sale or long-term lease—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2d2fdb9-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1506/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in order to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd2d2fdba-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1506/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide services consistent with the license; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2d2fdbb-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1506/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make unused spectrum available to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idd2d2fdbc-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1506/b/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an unaffiliated covered small carrier; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idd2d2fdbd-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1506/b/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an unaffiliated carrier to serve a rural area; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2d2fdbe-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1506/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the Commission finds that such a program would promote—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd2d2fdbf-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1506/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of advanced telecommunications services in rural areas; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2d2fdc0-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1506/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" spectrum availability for covered small carriers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d2fdc1-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1506/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the rulemaking proceeding under paragraph (1), the Commission shall consider, with respect to the program proposed to be established under that paragraph—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd2d2fdc2-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1506/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether reduced performance requirements with respect to spectrum obtained through the program would facilitate deployment of advanced telecommunications services in the areas covered by the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2d2fdc3-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1506/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" what conditions may be needed on transfers of spectrum under the program to allow covered small carriers that obtain spectrum under the program to build out the spectrum in a reasonable period of time;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2d2fdc4-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1506/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" what incentives may be appropriate to encourage licensees to lease or sell spectrum, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd2d2fdc5-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1506/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extending the term of a license granted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s301"},"text":"section 301 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2d2fdc6-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1506/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modifying performance requirements of the license relating to the leased or sold spectrum; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd2d2fdc7-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1506/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the administrative feasibility of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd2d2fdc8-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1506/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the incentives described in subparagraph (C); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd2d2fdc9-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1506/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other incentives considered by the Commission that further the goals of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d2fdca-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1506/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeiture of spectrum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a party fails to meet any build out requirements set by the Commission for any spectrum sold or leased under this section, the right to the spectrum shall be forfeited to the Commission unless the Commission finds that there is good cause for the failure of the party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd2d2fdcb-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s1506/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may offer a licensee incentives or reduced performance requirements under this section only if the Commission finds that doing so would likely result in increased availability of advanced telecommunications services in a rural area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd2d2fdcc-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dP/tVI/s616"},"text":"Pub. L. 115–141, div. P, title VI, § 616","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1110"},"text":"132 Stat. 1110","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
