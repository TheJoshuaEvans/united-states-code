{"tag":"section","attrib":{"id":"idce251de8-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455"},"text":null,"children":[{"tag":"num","attrib":{"value":"1455"},"text":"§ 1455.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wireless facilities deployment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idce251de9-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facility modifications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce251dea-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding section 704 of the Telecommunications Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/104"},"text":"Public Law 104–104","children":[],"tail":") or any other provision of law, a State or local government may not deny, and shall approve, any eligible facilities request for a modification of an existing wireless tower or base station that does not substantially change the physical dimensions of such tower or base station."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce251deb-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible facilities request","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “eligible facilities request” means any request for modification of an existing wireless tower or base station that involves—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce251dec-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collocation of new transmission equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce251ded-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" removal of transmission equipment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce251dee-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" replacement of transmission equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce251def-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of environmental laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in paragraph (1) shall be construed to relieve the Commission from the requirements of the National Historic Preservation Act ","children":[{"tag":"ref","attrib":{"idref":"fn002067"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002067"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" or the National Environmental Policy Act of 1969."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce251df0-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal easements, rights-of-way, and leases","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce251df1-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an executive agency, a State, a political subdivision or agency of a State, or a person, firm, or organization applies for the grant of an easement, right-of-way, or lease to, in, over, or on a building or other property owned by the Federal Government for the right to install, construct, modify, or maintain a communications facility installation, the executive agency having control of the building or other property may grant to the applicant, on behalf of the Federal Government, subject to paragraph (3), an easement, right-of-way, or lease to perform such installation, construction, modification, or maintenance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce251df2-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce251df3-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of General Services shall develop a common form for applications for easements, rights-of-way, and leases under paragraph (1) for all executive agencies that, except as provided in subparagraph (B), shall be used by all executive agencies and applicants with respect to the buildings or other property of each such agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce251df4-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirement under subparagraph (A) for an executive agency to use the common form developed by the Administrator of General Services shall not apply to an executive agency if the head of an executive agency notifies the Administrator that the executive agency uses a substantially similar application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce251df5-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timely consideration of applications","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce251df6-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 270 days after the date on which an executive agency receives a duly filed application for an easement, right-of-way, or lease under this subsection, the executive agency shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idce251df7-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant or deny, on behalf of the Federal Government, the application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce251df8-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the applicant of the grant or denial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce251df9-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Explanation of denial","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an executive agency denies an application under subparagraph (A), the executive agency shall notify the applicant in writing, including a clear statement of the reasons for the denial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce251dfa-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of environmental laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this paragraph shall be construed to relieve an executive agency of the requirements of division A of subtitle III of title 54 or the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce251dfb-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Point of contact","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon receiving an application under subparagraph (A), an executive agency shall designate one or more appropriate individuals within the executive agency to act as a point of contact with the applicant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce251dfc-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Master contracts for communications facility installation sitings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce251dfd-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding section 704 of the Telecommunications Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/104"},"text":"Public Law 104–104","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/110/151"},"text":"110 Stat. 151","children":[],"tail":") or any other provision of law, the Administrator of General Services shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce251dfe-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop one or more master contracts that shall govern the placement of communications facility installations on buildings and other property owned by the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce251dff-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in developing the master contract or contracts, standardize the treatment of the placement of communications facility installations on building rooftops or facades, the placement of communications facility installations on rooftops or inside buildings, the technology used in connection with communications facility installations placed on Federal buildings and other property, and any other key issues the Administrator of General Services considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce251e00-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The master contract or contracts developed by the Administrator of General Services under paragraph (1) shall apply to all publicly accessible buildings and other property owned by the Federal Government, unless the Administrator of General Services decides that issues with respect to the siting of a communications facility installation on a specific building or other property warrant nonstandard treatment of such building or other property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce251e01-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce251e02-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of General Services shall develop a common form or set of forms for communications facility installation siting applications that, except as provided in subparagraph (B), shall be used by all executive agencies and applicants with respect to the buildings and other property of each such agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce251e03-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirement under subparagraph (A) for an executive agency to use the common form or set of forms developed by the Administrator of General Services shall not apply to an executive agency if the head of the executive agency notifies the Administrator that the executive agency uses a substantially similar application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce251e04-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce251e05-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Communications facility installation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “communications facility installation” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce251e06-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any infrastructure, including any transmitting device, tower, or support structure, and any equipment, switches, wiring, cabling, power sources, shelters, or cabinets, associated with the licensed or permitted unlicensed wireless or wireline transmission of writings, signs, signals, data, images, pictures, and sounds of all kinds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce251e07-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any antenna or apparatus that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idce251e08-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designed for the purpose of emitting radio frequency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce251e09-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designed to be operated, or is operating, from a fixed location pursuant to authorization by the Federal Communications Commission or is using duly authorized devices that do not require individual licenses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idce251e0a-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/d/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is added to a tower, building, or other structure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce251e0b-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1455/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “executive agency” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s102"},"text":"section 102 of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idce251e0c-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/96/tVI/s6409"},"text":"Pub. L. 112–96, title VI, § 6409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/232"},"text":"126 Stat. 232","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dP/tVI/s606/a"},"text":"Pub. L. 115–141, div. P, title VI, § 606(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1101"},"text":"132 Stat. 1101","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idce251e0d-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idce251e0e-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idce251e0f-7553-11f1-8811-da7bbbed8cd8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 704 of the Telecommunications Act of 1996, referred to in subsecs. (a)(1) and (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/104/s704"},"text":"section 704 of Pub. L. 104–104","children":[],"tail":", title VII, "},{"tag":"date","attrib":{"date":"1996-02-08"},"text":"Feb. 8, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/151"},"text":"110 Stat. 151","children":[],"tail":". Subsec. (a) of "},{"tag":"ref","attrib":{"href":"/us/pl/104/104/s704"},"text":"section 704 of Pub. L. 104–104","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s332"},"text":"section 332 of this title","children":[],"tail":". Subsec. (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/104/104/s704"},"text":"section 704 of Pub. L. 104–104","children":[],"tail":" is not classified to the Code. Subsec. (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/104/104/s704"},"text":"section 704 of Pub. L. 104–104","children":[],"tail":" is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s332"},"text":"section 332 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The National Historic Preservation Act, referred to in subsec. (a)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/665"},"text":"Pub. L. 89–665","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/915"},"text":"80 Stat. 915","children":[],"tail":", which was classified generally to subchapter II (§ 470 et seq.) of chapter 1A of Title 16, Conservation. The Act, except for section 1, was repealed and restated in division A (§ 300101 et seq.) of subtitle III of Title 54, National Park Service and Related Programs, by "},{"tag":"ref","attrib":{"href":"/us/pl/113/287"},"text":"Pub. L. 113–287","children":[],"tail":", §§ 3, 7, "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3094"},"text":"128 Stat. 3094","children":[],"tail":", 3272. For complete classification of this Act to the Code, see Tables. For disposition of former sections of Title 16, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100101"},"text":"section 100101 of Title 54","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsecs. (a)(3) and (b)(3)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idce251e10-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" added subsecs. (b) to (d) and struck out former subsecs. (b) to (d) which related to Federal easements and rights-of-way, master contracts for wireless facility sitings, and definition of executive agency, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idce251e11-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idce251e12-7553-11f1-8811-da7bbbed8cd8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dP/tVI/s606/b"},"text":"Pub. L. 115–141, div. P, title VI, § 606(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1103"},"text":"132 Stat. 1103","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/141/dP/tVI/s606/b"},"text":"“An application for an easement, right-of-way, or lease that was made or granted under section 6409 of the Middle Class Tax Relief and Job Creation Act of 2012 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1455"},"text":"47 U.S.C. 1455","children":[],"tail":") before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":"] shall continue, subject to that section as in effect on the day before such date of enactment.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dP/tVI/s606/d"},"text":"Pub. L. 115–141, div. P, title VI, § 606(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1104"},"text":"132 Stat. 1104","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/141/dP/tVI/s606/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Real property authorities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section [amending this section and enacting provisions set out as a note under this section], or the amendments made by this section, shall be construed as providing any executive agency with any new leasing or other real property authorities not existing prior to the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect on other laws","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section, or the amendments made by this section, and no actions taken pursuant to this section, or the amendments made by this section, shall impact a decision or determination by any executive agency to sell, dispose of, declare excess or surplus, lease, reuse, or redevelop any Federal real property pursuant to title 40, United States Code, the Federal Assets Sale and Transfer Act of 2016 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/287"},"text":"Public Law 114–287","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t40/s1303"},"text":"40 U.S.C. 1303","children":[],"tail":" note], or any other law governing real property activities of the Federal Government. No agreement entered into pursuant to this section, or the amendments made by this section, may obligate the Federal Government to hold, control, or otherwise retain or use real property that may otherwise be deemed as excess, surplus, or that could be otherwise sold, leased, or redeveloped.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
