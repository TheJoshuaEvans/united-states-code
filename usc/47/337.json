{"tag":"section","attrib":{"id":"idd27859d1-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337"},"text":null,"children":[{"tag":"num","attrib":{"value":"337"},"text":"§ 337.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation and assignment of new public safety services licenses and commercial licenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idd27859d2-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1998-01-01"},"text":"January 1, 1998","children":[],"tail":", the Commission shall allocate the electromagnetic spectrum between 746 megahertz and 806 megahertz, inclusive, as follows:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idd27859d3-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 34 megahertz of that spectrum for public safety services according to the terms and conditions established by the Commission, in consultation with the Secretary of Commerce and the Attorney General; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd27859d4-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 26 megahertz of that spectrum for commercial use to be assigned by competitive bidding pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s309/j"},"text":"section 309(j) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd27859d5-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall commence assignment of licenses for public safety services created pursuant to subsection (a) no later than ","children":[{"tag":"date","attrib":{"date":"1998-09-30"},"text":"September 30, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd27859d6-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licensing of unused frequencies for public safety services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd27859d7-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of unused channels for public safety services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon application by an entity seeking to provide public safety services, the Commission shall waive any requirement of this chapter or its regulations implementing this chapter (other than its regulations regarding harmful interference) to the extent necessary to permit the use of unassigned frequencies for the provision of public safety services by such entity. An application shall be granted under this subsection if the Commission finds that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd27859d8-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no other spectrum allocated to public safety services is immediately available to satisfy the requested public safety service use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd27859d9-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requested use is technically feasible without causing harmful interference to other spectrum users entitled to protection from such interference under the Commission’s regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd27859da-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of the unassigned frequency for the provision of public safety services is consistent with other allocations for the provision of such services in the geographic area for which the application is made;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd27859db-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the unassigned frequency was allocated for its present use not less than 2 years prior to the date on which the application is granted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd27859dc-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" granting such application is consistent with the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd27859dd-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall apply to any application to provide public safety services that is pending or filed on or after ","children":[{"tag":"date","attrib":{"date":"1997-08-05"},"text":"August 5, 1997","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd27859de-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions on licenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing service rules with respect to licenses granted pursuant to this section, the Commission—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd27859df-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall establish interference limits at the boundaries of the spectrum block and service area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd27859e0-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall establish any additional technical restrictions necessary to protect full-service analog television service and digital television service during a transition to digital television service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd27859e1-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may permit public safety services licensees and commercial licensees—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd27859e2-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to aggregate multiple licenses to create larger spectrum blocks and service areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd27859e3-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to disaggregate or partition licenses to create smaller spectrum blocks or service areas; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd27859e4-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall establish rules insuring that public safety services licensees using spectrum reallocated pursuant to subsection (a)(1) shall not be subject to harmful interference from television broadcast licensees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd27859e5-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal and relocation of incumbent broadcast licensees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd27859e6-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Channels 52 to 69","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any full-power television station licensee that holds a television broadcast license to operate between 698 and 806 megahertz may not operate at that frequency after ","children":[{"tag":"date","attrib":{"date":"2009-06-12"},"text":"June 12, 2009","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd27859e7-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incumbent qualifying low-power stations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After making any allocation or assignment under this section, the Commission shall seek to assure, consistent with the Commission’s plan for allotments for digital television service, that each qualifying low-power television station is assigned a frequency below 698 megahertz to permit the continued operation of such station.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idd27859e8-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idd27859e9-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public safety services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “public safety services” means services—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd27859ea-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sole or principal purpose of which is to protect the safety of life, health, or property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd27859eb-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that are provided—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idd27859ec-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by State or local government entities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idd27859ed-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by nongovernmental organizations that are authorized by a governmental entity whose primary mission is the provision of such services; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd27859ee-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are not made commercially available to the public by the provider.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idd27859ef-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying low-power television stations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A station is a qualifying low-power television station if, during the 90 days preceding ","children":[{"tag":"date","attrib":{"date":"1997-08-05"},"text":"August 5, 1997","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idd27859f0-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such station broadcast a minimum of 18 hours per day;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd27859f1-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such station broadcast an average of at least 3 hours per week of programming that was produced within the market area served by such station; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idd27859f2-4ef6-11f1-9110-db228fde61c5","identifier":"/us/usc/t47/s337/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such station was in compliance with the requirements applicable to low-power television stations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idd27859f3-4ef6-11f1-9110-db228fde61c5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", title III, § 337, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tIII/s3004"},"text":"Pub. L. 105–33, title III, § 3004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/266"},"text":"111 Stat. 266","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/79/tVIII/s8124/a"},"text":"Pub. L. 106–79, title VIII, § 8124(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-25"},"text":"Oct. 25, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1262"},"text":"113 Stat. 1262","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/5/tII/s213/a/1"},"text":"Pub. L. 106–113, div. B, § 1000(a)(5) [title II, § 213(a)(1), (d)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–295, 1501A–297; "},{"tag":"ref","attrib":{"href":"/us/pl/109/171/tIII/s3002/c/1"},"text":"Pub. L. 109–171, title III, § 3002(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-02-08"},"text":"Feb. 8, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/21"},"text":"120 Stat. 21","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/4/s2/b/3"},"text":"Pub. L. 111–4, § 2(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-11"},"text":"Feb. 11, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/112"},"text":"123 Stat. 112","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/96/tVI/s6101/b"},"text":"Pub. L. 112–96, title VI, § 6101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/205"},"text":"126 Stat. 205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idd27859f4-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idd27859f5-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idd27859f6-4ef6-11f1-9110-db228fde61c5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c)(1), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"act June 19, 1934, ch. 652","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1064"},"text":"48 Stat. 1064","children":[],"tail":", known as the Communications Act of 1934, which is classified principally to this chapter. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s609"},"text":"section 609 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idd27859f7-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/96/s6101/b/1"},"text":"Pub. L. 112–96, § 6101(b)(1)","children":[],"tail":", substituted “34” for “24”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/96/s6101/b/2"},"text":"Pub. L. 112–96, § 6101(b)(2)","children":[],"tail":", substituted “26” for “36”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/4"},"text":"Pub. L. 111–4","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2009-06-12"},"text":"June 12, 2009","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"February 17, 2009","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/s3002/c/1/A"},"text":"Pub. L. 109–171, § 3002(c)(1)(A)","children":[],"tail":", substituted “Channels 52 to 69” for “Channels 60 to 69” in heading and substituted in text “full-power television station licensee that” for “person who”, “698 and 806 megahertz” for “746 and 806 megahertz”, and “"},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"February 17, 2009","children":[],"tail":"” for “the date on which the digital television service transition period terminates, as determined by the Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/s3002/c/1/B"},"text":"Pub. L. 109–171, § 3002(c)(1)(B)","children":[],"tail":", substituted “698 megahertz” for “746 megahertz”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/5/tII/s213/a/1"},"text":"Pub. L. 106–113, § 1000(a)(5) [title II, § 213(a)(1)]","children":[],"tail":", substituted “The Commission shall commence assignment of licenses for public safety services created pursuant to subsection (a) no later than "},{"tag":"date","attrib":{"date":"1998-09-30"},"text":"September 30, 1998","children":[],"tail":".” for “The Commission shall—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) commence assignment of the licenses for public safety services created pursuant to subsection (a) no later than ","children":[{"tag":"date","attrib":{"date":"1998-09-30"},"text":"September 30, 1998","children":[],"tail":"; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/79"},"text":"Pub. L. 106–79","children":[],"tail":", which struck out par. (2) reading “commence competitive bidding for the commercial licenses created pursuant to subsection (a) after "},{"tag":"date","attrib":{"date":"2001-01-01"},"text":"January 1, 2001","children":[],"tail":".”, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/5/tII/s213/d"},"text":"Pub. L. 106–113, § 1000(a)(5) [title II, § 213(d)]","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idd27859f8-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd27859f9-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Interference Protection","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/195/s6"},"text":"Pub. L. 107–195, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-19"},"text":"June 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/717"},"text":"116 Stat. 717","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/195/s6"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interference Waivers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In granting a request by a television broadcast station licensee assigned to any of channels 52–69 to utilize any channel of channels 2–51 that is assigned for digital broadcasting in order to continue analog broadcasting during the transition to digital broadcasting, the Federal Communications Commission may not, either at the time of the grant or thereafter, waive or otherwise reduce—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the spacing requirements provided for analog broadcasting licensees within channels 2–51 as required by section 73.610 of the Commission’s rules (and the table contained therein) (47 CFR 73.610), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interference standards provided for digital broadcasting licensees within channels 2–51 as required by sections 73.622 and 73.623 of such rules (47 CFR 73.622, 73.623),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"if such waiver or reduction will result in any degradation in or loss of service, or an increased level of interference, to any television household except as the Commission’s rules would otherwise expressly permit, exclusive of any waivers previously granted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for Public Safety Channel Clearing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The restrictions in subsection (a) shall not apply to a station licensee that is seeking authority (either by waiver or otherwise) to vacate the frequencies that constitute television channel 63, 64, 68, or 69 in order to make such frequencies available for public safety purposes pursuant to the provisions of section 337 of the Communications Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s337"},"text":"47 U.S.C. 337","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idd27859fa-4ef6-11f1-9110-db228fde61c5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Competitive Bidding Process for Commercial Licenses for Assigned Frequencies","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/5/tII/s213"},"text":"Pub. L. 106–113, div. B, § 1000(a)(5) [title II, § 213]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–295, as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/195/s3/b/3"},"text":"Pub. L. 107–195, § 3(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-19"},"text":"June 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/717"},"text":"116 Stat. 717","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/195/s3/b/3"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revised Schedule for Competitive Bidding of Spectrum","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" [Amended subsec. (b) of this section.]","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“[(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":", (3) Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/195/s3/b/3"},"text":"Pub. L. 107–195, § 3(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-19"},"text":"June 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/717"},"text":"116 Stat. 717","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To expedite the assignment by competitive bidding of the frequencies identified in section 337(a)(2) of the Communications Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s337/a/2"},"text":"47 U.S.C. 337(a)(2)","children":[],"tail":"), the rules governing such frequencies shall be effective immediately upon publication in the Federal Register without regard to sections 553(d), 801(a)(3), 804(2), and 806(a) of title 5, United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 6 of title 5, United States Code, section 3 of the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632"},"text":"15 U.S.C. 632","children":[],"tail":"), and sections 3507 and 3512 of title 44, United States Code, shall not apply to the rules and competitive bidding procedures governing the frequencies described in subparagraph (A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding section 309(b) of the Communications Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s309/b"},"text":"47 U.S.C. 309(b)","children":[],"tail":"), no application for an instrument of authorization for the frequencies described in paragraph (4) may be granted by the Federal Communications Commission earlier than 7 days following issuance of public notice by the Commission of the acceptance for filing of such application or of any substantial amendment thereto."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding section 309(d)(1) of the Communications Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s309/d/1"},"text":"47 U.S.C. 309(d)(1)","children":[],"tail":"), the Federal Communications Commission may specify a period (which shall be not less than 5 days following issuance of the public notice described in paragraph (5)) for the filing of petitions to deny any application for an instrument of authorization for the frequencies described in paragraph (4)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 30 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":"], the Director of the Office of Management and Budget and the Federal Communications Commission shall each submit to the appropriate congressional committees a report which shall—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" set forth the anticipated schedule (including specific dates) for—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparing and conducting the competitive bidding process required by subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" depositing the receipts of the competitive bidding process;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth each significant milestone in the rulemaking process with respect to the competitive bidding process; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include an explanation of the effect of each requirement in subsection (a) on the schedule for the competitive bidding process and any post-bidding activities (including the deposit of receipts) when compared with the schedule for the competitive bidding and any post-bidding activities (including the deposit of receipts) that would otherwise have occurred under section 337(b)(2) of the Communications Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s337/b/2"},"text":"47 U.S.C. 337(b)(2)","children":[],"tail":") if not for the enactment of subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 60 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":"], the Federal Communications Commission shall submit to the appropriate congressional committees a report which shall set forth for each spectrum auction held by the Commission since "},{"tag":"date","attrib":{"date":"1998-01-01"},"text":"January 1, 1998","children":[],"tail":", information on—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time required for each stage of preparation for the auction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the commencement and of the completion of the auction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time which elapsed between the date of the completion of the auction and the date of the first deposit of receipts from the auction in the Treasury; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts, summarized by month, of all subsequent deposits in a Treasury receipt account from the auction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"2000-10-31"},"text":"October 31, 2000","children":[],"tail":", the Federal Communications Commission shall submit to the appropriate congressional committees a report which shall—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the course of the competitive bidding process required by subsection (a) through ","children":[{"tag":"date","attrib":{"date":"2000-09-30"},"text":"September 30, 2000","children":[],"tail":", including the amount of any receipts from the competitive bidding process deposited in the Treasury as of "},{"tag":"date","attrib":{"date":"2000-09-30"},"text":"September 30, 2000","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the course of the competitive bidding process has included any deviations from the schedule set forth under paragraph (1)(A), an explanation for such deviations from the schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each report required by this subsection shall be prepared by the agency concerned without influence of any other Federal department or agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection, the term “appropriate congressional committees” means the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committees on Appropriations, the Budget, and Commerce, Science, and Transportation of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committees on Appropriations, the Budget, and Commerce of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to supersede the requirements placed on the Federal Communications Commission by section 337(d)(4) of the Communications Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s337/d/4"},"text":"47 U.S.C. 337(d)(4)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repeal of Superseded Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Section 8124 of the Department of Defense Appropriations Act, 2000 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/79"},"text":"Pub. L. 106–79","children":[],"tail":", amending this section and enacting provisions formerly set out under this section] is repealed.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/79/tVIII/s8124"},"text":"Pub. L. 106–79, title VIII, § 8124","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-25"},"text":"Oct. 25, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1262"},"text":"113 Stat. 1262","children":[],"tail":", related to the establishment of a competitive bidding process for commercial licenses and required reports to Congressional committees, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/5/tII/s213/d"},"text":"Pub. L. 106–113, div. B, § 1000(a)(5) [title II, § 213(d)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–297."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
