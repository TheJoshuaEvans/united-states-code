{"tag":"section","attrib":{"id":"idce337552-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1726"},"text":null,"children":[{"tag":"num","attrib":{"value":"1726"},"text":"§ 1726.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idce337553-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1726/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondiscrimination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce337554-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1726/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No individual in the United States may, on the basis of actual or perceived race, color, religion, national origin, sex, gender identity, sexual orientation, age, or disability, be excluded from participation in, be denied the benefits of, or be subjected to discrimination under any program or activity that is funded in whole or in part with funds made available to carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce337555-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1726/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall effectuate paragraph (1) with respect to any program or activity described in that paragraph by issuing regulations and taking actions consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000d–1"},"text":"section 2000d–1 of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idce337556-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1726/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Judicial review of an action taken by the Assistant Secretary under paragraph (2) shall be available to the extent provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000d–2"},"text":"section 2000d–2 of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce337557-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1726/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technological neutrality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall, to the extent practicable, carry out this subchapter in a technologically neutral manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idce337558-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1726/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit and oversight","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning in the first fiscal year in which amounts are made available to carry out an activity authorized under this subchapter, and in each of the 4 fiscal years thereafter, there is authorized to be appropriated to the Office of Inspector General for the Department of Commerce $1,000,000 for audits and oversight of funds made available to carry out this subchapter, which shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idce337559-7553-11f1-8811-da7bbbed8cd8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dF/tIII/s60307"},"text":"Pub. L. 117–58, div. F, title III, § 60307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1230"},"text":"135 Stat. 1230","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
