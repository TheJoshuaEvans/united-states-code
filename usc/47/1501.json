{"tag":"section","attrib":{"id":"idce278e43-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1501"},"text":null,"children":[{"tag":"num","attrib":{"value":"1501"},"text":"§ 1501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idce278e44-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate committees of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idce278e45-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1501/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce, Science, and Transportation of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce278e46-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1501/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Commerce of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idce278e47-7553-11f1-8811-da7bbbed8cd8","identifier":"/us/usc/t47/s1501/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each committee of the Senate or of the House of Representatives with jurisdiction over a Federal entity affected by the applicable section in which the term appears.","children":[],"tail":"\n"}],"tail":"\n"