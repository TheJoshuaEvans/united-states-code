{"tag":"section","attrib":{"id":"idf3e2e186-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s363"},"text":null,"children":[{"tag":"num","attrib":{"value":"363"},"text":"§ 363.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International application designating the United States: Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An international application designating the United States shall have the effect, from its international filing date under article 11 of the treaty, of a national application for patent regularly filed in the Patent and Trademark Office.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf3e2e187-d790-11f0-9f07-ba4fc64746bc"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/131/s1"},"text":"Pub. L. 94–131, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-14"},"text":"Nov. 14, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/686"},"text":"89 Stat. 686","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/622/tIV/s403/a"},"text":"Pub. L. 98–622, title IV, § 403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3392"},"text":"98 Stat. 3392","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/29"},"text":"Pub. L. 112–29","children":[],"tail":", §§ 3(g)(3), 20(j), "},{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/288"},"text":"125 Stat. 288","children":[],"tail":", 335.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3e2e188-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf3e2e189-d790-11f0-9f07-ba4fc6474