{"tag":"section","attrib":{"id":"idf3de266c-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s312"},"text":null,"children":[{"tag":"num","attrib":{"value":"312"},"text":"§ 312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf3de266d-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements of Petition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A petition filed under section 311 may be considered only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf3de266e-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s312/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the petition is accompanied by payment of the fee established by the Director under section 311;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3de266f-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s312/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the petition identifies all real parties in interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3de2670-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s312/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the petition identifies, in writing and with particularity, each claim challenged, the grounds on which the challenge to each claim is based, and the evidence that supports the grounds for the challenge to each claim, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf3de2671-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s312/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" copies of patents and printed publications that the petitioner relies upon in support of the petition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf3de2672-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s312/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affidavits or declarations of supporting evidence and opinions, if the petitioner relies on expert opinions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3de2673-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s312/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the petition provides such other information as the Director may require by regulation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3de2674-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s312/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the petitioner provides copies of any of the documents required under paragraphs (2), (3), and (4) to the patent owner or, if applicable, the designated representative of the patent owner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3de2675-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As soon as practicable after the receipt of a petition under section 311, the Director shall make the petition available to the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf3de2676-d790-11f0-9f07-ba4fc64746bc"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tIV/s4604/a"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title IV, § 4604(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–568; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tIII"},"text":"Pub. L. 107–273, div. C, title III","children":[],"tail":", §§ 13105(a), 13202(a)(2), (c)(1), "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1900-1902"},"text":"116 Stat. 1900–1902","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/29/s6/a"},"text":"Pub. L. 112–29, § 6(a)","children":[],"tail":", (c)(3)(A)(i), "},{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/300"},"text":"125 Stat. 300","children":[],"tail":", 305.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3de2677-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf3de2678-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf3de2679-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s6/a"},"text":"Pub. L. 112–29, § 6(a)","children":[],"tail":", amended section generally. Prior to amendment, section related to determination of issue by Director."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s6/c/3/A/i/I"},"text":"Pub. L. 112–29, § 6(c)(3)(A)(i)(I)","children":[],"tail":", substituted “the information presented in the request shows that there is a reasonable likelihood that the requester would prevail with respect to at least 1 of the claims challenged in the request,” for “a substantial new question of patentability affecting any claim of the patent concerned is raised by the request,” and “A showing that there is a reasonable likelihood that the requester would prevail with respect to at least 1 of the claims challenged in the request” for “The existence of a substantial new question of patentability”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s6/c/3/A/i/II"},"text":"Pub. L. 112–29, § 6(c)(3)(A)(i)(II)","children":[],"tail":", substituted “the showing required by subsection (a) has not been made,” for “no substantial new question of patentability has been raised,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s13202/c/1"},"text":"Pub. L. 107–273, § 13202(c)(1)","children":[],"tail":", made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":", which enacted this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s13202/a/2/A"},"text":"Pub. L. 107–273, § 13202(a)(2)(A)","children":[],"tail":", struck out second sentence which read as follows: “On the Director’s initiative, and at any time, the Director may determine whether a substantial new question of patentability is raised by patents and publications.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s13105/a"},"text":"Pub. L. 107–273, § 13105(a)","children":[],"tail":", inserted at end “The existence of a substantial new question of patentability is not precluded by the fact that a patent or printed publication was previously cited by or to the Office or considered by the Office.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s13202/a/2/B"},"text":"Pub. L. 107–273, § 13202(a)(2)(B)","children":[],"tail":", struck out “, if any” after “third-party requester”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf3de267a-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf3de267b-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s6/a"},"text":"section 6(a) of Pub. L. 112–29","children":[],"tail":" effective upon the expiration of the 1-year period beginning on "},{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", and applicable to any patent issued before, on, or after that effective date, with provisions for graduated implementation, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/29/s6/c/2"},"text":"section 6(c)(2) of Pub. L. 112–29","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s311"},"text":"section 311 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s6/c/3/B"},"text":"Pub. L. 112–29, § 6(c)(3)(B)","children":[],"tail":", (C), "},{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/305"},"text":"125 Stat. 305","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/29/s6/c/3/B"},"text":"\n","children":[{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amendments made by this paragraph [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t35/s313"},"text":"section 313 of this title","children":[],"tail":"]—"}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall apply to requests for inter partes reexamination that are filed on or after such date of enactment, but before the effective date set forth in paragraph (2)(A) of this subsection [set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t35/s311"},"text":"section 311 of this title","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continued applicability of prior provisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The provisions of chapter 31 of title 35, United States Code, as amended by this paragraph [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t35/s313"},"text":"section 313 of this title","children":[],"tail":"], shall continue to apply to requests for inter partes reexamination that are filed before the effective date set forth in paragraph (2)(A) as if subsection (a) [enacting "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s319"},"text":"section 319 of this title","children":[],"tail":" and amending this section and sections 312 to 318 of this title] had not been enacted.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf3de267c-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s13105/a"},"text":"section 13105(a) of Pub. L. 107–273","children":[],"tail":" applicable with respect to any determination of the Director of the United States Patent and Trademark Office that is made on or after "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/s13105/b"},"text":"section 13105(b) of Pub. L. 107–273","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s303"},"text":"section 303 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf3de267d-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", and applicable to any patent issuing from an original application filed in the United States on or after that date, see section 1000(a)(9) [title IV, § 4608(a)] of "},{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":", set out as an Effective Date of 1999 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s41"},"text":"section 41 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
