{"tag":"section","attrib":{"id":"idf3e09728-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s326"},"text":null,"children":[{"tag":"num","attrib":{"value":"326"},"text":"§ 326.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conduct of post-grant review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf3e09729-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s326/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall prescribe regulations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf3e0972a-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s326/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing that the file of any proceeding under this chapter shall be made available to the public, except that any petition or document filed with the intent that it be sealed shall, if accompanied by a motion to seal, be treated as sealed pending the outcome of the ruling on the motion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e0972b-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s326/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" setting forth the standards for the showing of sufficient grounds to institute a review under subsections (a) and (b) of section 324;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e0972c-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s326/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing procedures for the submission of supplemental information after the petition is filed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e0972d-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s326/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing and governing a post-grant review under this chapter and the relationship of such review to other proceedings under this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e0972e-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s326/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" setting forth standards and procedures for discovery of relevant evidence, including that such discovery shall be limited to evidence directly related to factual assertions advanced by either party in the proceeding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e0972f-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s326/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribing sanctions for abuse of discovery, abuse of process, or any other improper use of the proceeding, such as to harass or to cause unnecessary delay or an unnecessary increase in the cost of the proceeding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e09730-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s326/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for protective orders governing the exchange and submission of confidential information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e09731-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s326/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for the filing by the patent owner of a response to the petition under section 323 after a post-grant review has been instituted, and requiring that the patent owner file with such response, through affidavits or declarations, any additional factual evidence and expert opinions on which the patent owner relies in support of the response;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e09732-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s326/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" setting forth standards and procedures for allowing the patent owner to move to amend the patent under subsection (d) to cancel a challenged claim or propose a reasonable number of substitute claims, and ensuring that any information submitted by the patent owner in support of any amendment entered under subsection (d) is made available to the public as part of the prosecution history of the patent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e09733-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s326/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing either party with the right to an oral hearing as part of the proceeding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e09734-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s326/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requiring that the final determination in any post-grant review be issued not later than 1 year after the date on which the Director notices the institution of a proceeding under this chapter, except that the Director may, for good cause shown, extend the 1-year period by not more than 6 months, and may adjust the time periods in this paragraph in the case of joinder under section 325(c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e09735-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s326/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing the petitioner with at least 1 opportunity to file written comments within a time period established by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3e09736-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s326/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In prescribing regulations under this section, the Director shall consider the effect of any such regulation on the economy, the integrity of the patent system, the efficient administration of the Office, and the ability of the Office to timely complete proceedings instituted under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3e09737-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s326/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Patent Trial and Appeal Board","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Patent Trial and Appeal Board shall, in accordance with section 6, conduct each post-grant review instituted under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3e09738-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s326/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amendment of the Patent.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf3e09739-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s326/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"During a post-grant review instituted under this chapter, the patent owner may file 1 motion to amend the patent in 1 or more of the following ways:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf3e0973a-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s326/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cancel any challenged patent claim.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf3e0973b-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s326/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each challenged claim, propose a reasonable number of substitute claims.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e0973c-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s326/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional motions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Additional motions to amend may be permitted upon the joint request of the petitioner and the patent owner to materially advance the settlement of a proceeding under section 327, or upon the request of the patent owner for good cause shown.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e0973d-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s326/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope of claims","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An amendment under this subsection may not enlarge the scope of the claims of the patent or introduce new matter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3e0973e-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s326/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evidentiary Standards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In a post-grant review instituted under this chapter, the petitioner shall have the burden of proving a proposition of unpatentability by a preponderance of the evidence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf3e0973f-d790-11f0-9f07-ba4fc64746bc"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s6/d"},"text":"Pub. L. 112–29, § 6(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/308"},"text":"125 Stat. 308","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3e09740-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf3e09741-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf3e09742-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the expiration of the 1-year period beginning ","children":[{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", and applicable only to patents described in "},{"tag":"ref","attrib":{"href":"/us/pl/112/29/s3/n/1"},"text":"section 3(n)(1) of Pub. L. 112–29","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t35/s100"},"text":"35 U.S.C. 100","children":[],"tail":" note), with certain exceptions and limitations, see section 6(f)(2), (3) of "},{"tag":"ref","attrib":{"href":"/us/pl/112/29"},"text":"Pub. L. 112–29","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s321"},"text":"section 321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
