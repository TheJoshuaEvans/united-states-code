{"tag":"section","attrib":{"id":"idf3d4b0cd-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s267"},"text":null,"children":[{"tag":"num","attrib":{"value":"267"},"text":"§ 267.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for taking action in Government applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding the provisions of sections 133 and 151, the Director may extend the time for taking any action to three years, when an application has become the property of the United States and the head of the appropriate department or agency of the Government has certified to the Director that the invention disclosed therein is important to the armament or defense of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf3d4b0ce-d790-11f0-9f07-ba4fc64746bc"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-07-19/ch950"},"text":"July 19, 1952, ch. 950","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/811"},"text":"66 Stat. 811","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tIV/s4732/a/10/A"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title IV, § 4732(a)(10)(A)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–582; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tIII/s13206/b/1/B"},"text":"Pub. L. 107–273, div. C, title III, § 13206(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1906"},"text":"116 Stat. 1906","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/29/s20/j"},"text":"Pub. L. 112–29, § 20(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/335"},"text":"125 Stat. 335","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3d4b0cf-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf3d4b0d0-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on Title 35, U.S.C., 1946 ed., § 37 (R.S. 4894, amended (1) ","children":[{"tag":"ref","attrib":{"href":"/us/act/1897-03-03/ch391/s4"},"text":"Mar. 3, 1897, ch. 391, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/29/692"},"text":"29 Stat. 692","children":[],"tail":", 693, (2) "},{"tag":"ref","attrib":{"href":"/us/act/1916-07-06/ch225/s1"},"text":"July 6, 1916, ch. 225, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/345"},"text":"39 Stat. 345","children":[],"tail":", 347–8, (3) "},{"tag":"ref","attrib":{"href":"/us/act/1927-03-02/ch273/s1"},"text":"Mar. 2, 1927, ch. 273, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1335"},"text":"44 Stat. 1335","children":[],"tail":", (4) "},{"tag":"ref","attrib":{"href":"/us/act/1939-08-07/ch568"},"text":"Aug. 7, 1939, ch. 568","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1264"},"text":"53 Stat. 1264","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This provision, which appears as the last two sentences of the corresponding section of the present statute (see note to section 133) is made a separate section and rewritten in simpler form.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf3d4b0d1-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children