{"tag":"section","attrib":{"id":"idf3e551e8-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s372"},"text":null,"children":[{"tag":"num","attrib":{"value":"372"},"text":"§ 372.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National stage: Requirements and procedure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf3e551e9-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s372/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All questions of substance and, within the scope of the requirements of the treaty and Regulations, procedure in an international application designating the United States shall be determined as in the case of national applications regularly filed in the Patent and Trademark Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3e551ea-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s372/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In case of international applications designating but not originating in, the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf3e551eb-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s372/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director may cause to be reexamined questions relating to form and contents of the application in accordance with the requirements of the treaty and the Regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e551ec-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s372/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director may cause the question of unity of invention to be reexamined under section 121, within the scope of the requirements of the treaty and the Regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e551ed-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s372/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director may require a verification of the translation of the international application or any other document pertaining to the application if the application or other document was filed in a language other than English.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf3e551ee-d790-11f0-9f07-ba4fc64746bc"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/131/s1"},"text":"Pub. L. 94–131, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-14"},"text":"Nov. 14, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/689"},"text":"89 Stat. 689","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/622/tIV"},"text":"Pub. L. 98–622, title IV","children":[],"tail":", §§ 402(e), (f), 403(a), "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3392"},"text":"98 Stat. 3392","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tIV/s4732/a/10/A"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title IV, § 4732(a)(10)(A)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–582; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tIII/s13206/b/1/B"},"text":"Pub. L. 107–273, div. C, title III, § 13206(b)(1)(B)","children":[],"