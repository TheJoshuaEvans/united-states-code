{"tag":"section","attrib":{"id":"idf3ac1a34-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"§ 11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchange of copies of patents and applications with foreign countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf3ac1a35-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s11/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director may exchange copies of specifications and drawings of United States patents and published applications for patents for those of foreign countries. The Director shall not enter into an agreement to provide such copies of specifications and drawings of United States patents and applications to a foreign country, other than a USMCA country or a WTO member country, without the express authorization of the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3ac1a36-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s11/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf3ac1a37-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s11/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “USMCA country” has the meaning given that term in section 3 of the United States-Mexico-Canada Agreement Implementation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4502"},"text":"19 U.S.C. 4502","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3ac1a38-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s11/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “WTO member country” has the meaning given that term in section 2(10) of the Uruguay Round Agreements Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501/10"},"text":"19 U.S.C. 3501(10)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf3ac1a39-d790-11f0-9f07-ba4fc64746bc"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-07-19/ch950"},"text":"July 19, 1952, ch. 950","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/794"},"text":"66 Stat. 794","children":[],"tail":", § 12; renumbered § 11 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tIV/s4507/2"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title IV, §§ 4507(2), 4717(1), 4732(a)(10)(A), 4808]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–565, 1501A–580, 1501A–582, 1501A–591; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tIII"},"text":"Pub. L. 107–273, div. C, title III","children":[],"tail":", §§ 13205(2)(B), 13206(b)(1)(B), "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1903"},"text":"116 Stat. 1903","children":[],"tail":", 1906; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dO/tVI/s602/d"},"text":"Pub. L. 116–260, div. O, title VI, § 602(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2153"},"text":"134 Stat. 2153","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3ac1a3a-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf3ac1a3b-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on Title 35, U.S.C., 1946 ed., §§ 15, and 78, part (","children":[{"tag":"date","attrib":{"date":"1915-01-14"},"text":"Jan. 14, 1915","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/1221"},"text":"38 Stat. 1221","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1922-02-18/ch58/s9"},"text":"Feb. 18, 1922, ch. 58, § 9","children":[],"tail":", proviso in, "},{"tag":"ref","attrib":{"href":"/us/stat/42/393"},"text":"42 Stat. 393","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The first act mentioned applies to Canada only, the second to any country; these are consolidated in one section, specific reference to one country not being necessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Language is changed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf3ac1a3c-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idf3ac1a3d-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 11 was renumbered ","children":[