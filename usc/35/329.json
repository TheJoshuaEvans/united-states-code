{"tag":"section","attrib":{"id":"idf3e09756-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s329"},"text":null,"children":[{"tag":"num","attrib":{"value":"329"},"text":"§ 329.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeal","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A party dissatisfied with the final written decision of the Patent Trial and Appeal Board under section 328(a) may appeal the decision pursuant to sections 141 through 144. Any party to the post-grant review shall have the right to be a party to the appeal.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf3e09757-d790-11f0-9f07-ba4fc64746bc"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s6/d"},"text":"Pub. L. 112–29, § 6(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/311"},"text":"125 Stat. 311","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3e09758-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf3e09759-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf3e0975a-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the expiration of the 1-year period beginning ","children":[{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", and applicable only to patents described in "},{"tag":"ref","attrib":{"href":"/us/pl/112/29/s3/n/1"},"text":"section 3(n)(1) of Pub. L. 112–29","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t35/s100"},"text":"35 U.S.C. 100","children":[],"tail":" note), with certain exceptions and limitations, see section 6(f)(2), (3) of "},{"tag":"ref","attrib":{"href":"/us/pl/112/29"},"text":"Pub. L. 112–29","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s321"},"text":"section 321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
