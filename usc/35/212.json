{"tag":"section","attrib":{"id":"idf3d23f4c-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s212"},"text":null,"children":[{"tag":"num","attrib":{"value":"212"},"text":"§ 212.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of rights in educational awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No scholarship, fellowship, training grant, or other funding agreement made by a Federal agency primarily to an awardee for educational purposes will contain any provision giving the Federal agency any rights to inventions made by the awardee.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf3d23f4d-d790-11f0-9f07-ba4fc64746bc"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620/tV/s501/14"},"text":"Pub. L. 98–620, title V, § 501(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3368"},"text":"98 Stat. 3368","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
