{"tag":"section","attrib":{"id":"idf3e55244-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s383"},"text":null,"children":[{"tag":"num","attrib":{"value":"383"},"text":"§ 383.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International design application","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In addition to any requirements pursuant to chapter 16, the international design application shall contain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf3e55245-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s383/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a request for international registration under the treaty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e55246-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s383/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an indication of the designated Contracting Parties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e55247-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s383/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data concerning the applicant as prescribed in the treaty and the Regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e55248-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s383/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" copies of a reproduction or, at the choice of the applicant, of several different reproductions of the industrial design that is the subject of the international design application, presented in the number and manner prescribed in the treaty and the Regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e55249-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s383/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an indication of the product or products that constitute the industrial design or in relation to which the industrial design is to be used, as prescribed in the treaty and the Regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e5524a-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s383/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fees prescribed in the treaty and the Regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e5524b-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s383/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other particulars prescribed in the Regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf3e5524c-d790-11f0-9f07-ba4fc64746bc"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/211/tI/s101/a"},"text":"Pub. L. 112–211, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-18"},"text":"Dec. 18, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1528"},"text":"126 Stat. 1528","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3e5524d-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf3e5524e-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf3e5524f-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the later of the date that is 1 year after ","children":[{"tag":"date","attrib":{"date":"2012-12-18"},"text":"Dec. 18, 2012","children":[],"tail":", or the date that the Geneva Act of the Hague Agreement Concerning the International Registration of Industrial Designs enters into force with respect to the United States ("},{"tag":"date","attrib":{"date":"2015-05-13"},"text":"May 13, 2015","children":[],"tail":"), and applicable only to certain applications filed on and after that effective date and patents issuing thereon, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/211/s103"},"text":"section 103 of Pub. L. 112–211","children":[],"tail":", set out as an Effective Date of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s100"},"text":"section 100 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
