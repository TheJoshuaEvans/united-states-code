{"tag":"section","attrib":{"id":"idf3d23f47-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s211"},"text":null,"children":[{"tag":"num","attrib":{"value":"211"},"text":"§ 211.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to antitrust laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be deemed to convey to any person immunity from civil or criminal liability, or to create any defenses to actions, under any antitrust law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf3d23f48-d790-11f0-9f07-ba4fc64746bc"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/517/s6/a"},"text":"Pub. L. 96–517, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3027"},"text":"94 Stat. 3027","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3d23f49-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf3d23f4a-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf3d23f4b-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-07-01"},"text":"July 1, 1981","children":[],"tail":", but implementing regulations authorized to be issued earlier, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/517/s8/f"},"text":"section 8(f) of Pub. L. 96–517","children":[],"tai