{"tag":"section","attrib":{"id":"idf3cb1443-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s173"},"text":null,"children":[{"tag":"num","attrib":{"value":"173"},"text":"§ 173.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of design patent","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Patents for designs shall be granted for the term of 15 years from the date of grant.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf3cb1444-d790-11f0-9f07-ba4fc64746bc"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-07-19/ch950"},"text":"July 19, 1952, ch. 950","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/805"},"text":"66 Stat. 805","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/247/s16"},"text":"Pub. L. 97–247, § 16","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-27"},"text":"Aug. 27, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/321"},"text":"96 Stat. 321","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tV/s532/c/3"},"text":"Pub. L. 103–465, title V, § 532(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4987"},"text":"108 Stat. 4987","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/211/tI/s102/7"},"text":"Pub. L. 112–211, title I, § 102(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-18"},"text":"Dec. 18, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1532"},"text":"126 Stat. 1532","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3cb1445-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf3cb1446-d790-11f0-9f07-