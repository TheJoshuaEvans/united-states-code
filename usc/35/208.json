{"tag":"section","attrib":{"id":"idf3d23f00-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s208"},"text":null,"children":[{"tag":"num","attrib":{"value":"208"},"text":"§ 208.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations governing Federal licensing","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce is authorized to promulgate regulations specifying the terms and conditions upon which any federally owned invention, other than inventions owned by the Tennessee Valley Authority, may be licensed on a nonexclusive, partially exclusive, or exclusive basis.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf3d23f01-d790-11f0-9f07-ba4fc64746bc"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/517/s6/a"},"text":"Pub. L. 96–517, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3024"},"text":"94 Stat. 3024","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/620/tV/s501/12"},"text":"Pub. L. 98–620, title V, § 501(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3367"},"text":"98 Stat. 3367","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3d23f02-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf3d23f03-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf3d23f04-d790-11f0-9f07-ba4fc64746bc"},"text":null,