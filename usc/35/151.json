{"tag":"section","attrib":{"id":"idf3c65823-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s151"},"text":null,"children":[{"tag":"num","attrib":{"value":"151"},"text":"§ 151.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issue of patent","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf3c65824-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s151/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If it appears that an applicant is entitled to a patent under the law, a written notice of allowance of the application shall be given or mailed to the applicant. The notice shall specify a sum, constituting the issue fee and any required publication fee, which shall be paid within 3 months thereafter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3c65825-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s151/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of Payment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon payment of this sum the patent may issue, but if payment is not timely made, the application shall be regarded as abandoned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf3c65826-d790-11f0-9f07-ba4fc64746bc"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/211/tII/s202/b/6"},"text":"Pub. L. 112–211, title II, § 202(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-18"},"text":"Dec. 18, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1536"},"text":"126 Stat. 1536","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3c65827-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf3c65828-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idf3c65829-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 151, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-07-19/ch950"},"text":"act July 19, 1952, ch. 950","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/803"},"text":"66 Stat. 803","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/83/s4"},"text":"Pub. L. 89–83, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-24"},"text":"July 24, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/260"},"text":"79 Stat. 260","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/601/s3"},"text":"Pub. L. 93–601, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-02"},"text":"Jan. 2, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1956"},"text":"88 Stat. 1956","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tIV/s4732/a/10/A"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title IV, § 4732(a)(10)(A)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–582; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tIII/s13206/b/1