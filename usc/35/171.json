{"tag":"section","attrib":{"id":"idf3cb142f-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s171"},"text":null,"children":[{"tag":"num","attrib":{"value":"171"},"text":"§ 171.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Patents for designs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf3cb1430-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s171/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever invents any new, original and ornamental design for an article of manufacture may obtain a patent therefor, subject to the conditions and requirements of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3cb1431-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s171/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of This Title","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The provisions of this title relating to patents for inventions shall apply to patents for designs, except as otherwise provided.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3cb1432-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s171/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Filing Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The filing date of an application for patent for design shall be the date on which the specification as prescribed by section 112 and any required drawings are filed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf3cb1433-d790-11f0-9f07-ba4fc64746bc"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-07-19/ch950"},"text":"July 19, 1952, ch. 950","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/805"},"text":"66 Stat. 805","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/211/tII/s202/a"},"text":"Pub. L. 112–211, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-18"},"text":"Dec. 18, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1535"},"text":"126 Stat. 1535","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3cb1434-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf3cb1435-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on Title 35, U.S.C., 1946 ed., § 73 (R.S. 4929, amended (1) ","children":[{"tag":"ref","attrib":{"href":"/us/act/1902-05-09/ch783"},"text":"May 9, 1902, ch. 783","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/193"},"text":"32 Stat. 193","children":[],"tail":", (2) "},{"tag":"ref","attrib":{"href":"/us/act/1939-08-05/ch450/s1"},"text":"Aug. 5, 1939, ch. 450, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1212"},"text":"53 Stat. 1212","children":[],"tail":"; R.S. 4933)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The list of conditions specified in the corresponding section of existing statute is omitted as unnecessary in view of the general inclusion of all conditions applying to other patents. Language is changed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf3cb1436-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf3cb1437-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/211"},"text":"Pub. L. 112–211","children":[],"tail":" designated first and second pars. as subsecs. (a) and (b), respectively, inserted headings, and added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf3cb1438-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf3cb1439-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/211"},"text":"Pub. L. 112–211","children":[],"tail":" effective on the date that is 1 year after "},{"tag":"date","attrib":{"date":"2012-12-18"},"text":"Dec. 18, 2012","children":[],"tail":", applicable to patents issued before, on, or after that effective date and patent applications pending on or filed after that effective date, and not effective with respect to patents in litigation commenced before that effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/211/s203"},"text":"section 203 of Pub. L. 112–211","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s27"},"text":"section 27 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
