{"tag":"section","attrib":{"id":"idf3ae8b5e-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"§ 21.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing date and day for taking action","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf3ae8b5f-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s21/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director may by rule prescribe that any paper or fee required to be filed in the Patent and Trademark Office will be considered filed in the Office on the date on which it was deposited with the United States Postal Service or would have been deposited with the United States Postal Service but for postal service interruptions or emergencies designated by the Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3ae8b60-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s21/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the day, or the last day, for taking any action or paying any fee in the United States Patent and Trademark Office falls on Saturday, Sunday, or a Federal holiday within the District of Columbia, the action may be taken, or the fee paid, on the next succeeding secular or business day.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf3ae8b61-d790-11f0-9f07-ba4fc64746bc"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-07-19/ch950"},"text":"July 19, 1952, ch. 950","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/794"},"text":"66 Stat. 794","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/596/s1"},"text":"Pub. L. 93–596, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-02"},"text":"Jan. 2, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1949"},"text":"88 Stat. 1949","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/247/s12"},"text":"Pub. L. 97–247, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-27"},"text":"Aug. 27, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/321"},"text":"96 Stat. 321","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tIV/s4732/a/10/A"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title IV, § 4732(a)(10)(A)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–582; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tIII/s13206/b/1/B"},"text":"Pub. L. 107–273, div. C, title III, § 13206(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1906"},"text":"116 Stat. 1906","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3ae8b62-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf3ae8b63-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on Title 35, U.S.C., 1946 ed., § 21 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-02/ch273/s14"},"text":"Mar. 2, 1927, ch. 273, § 14","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1337"},"text":"44 Stat. 1337","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Fixed by statute” is omitted from the corresponding section of the existing statute as unnecessary. Saturday is added as a day on which action need not be taken.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf3ae8b64-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf3ae8b65-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":". See 1999 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":", substituted “Director” for “Commissioner” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/247"},"text":"Pub. L. 97–247","children":[],"tail":" substituted “Filing date and day for taking action” for “Day for taking action falling on Saturday, Sunday, or holiday” as section catchline, added subsec. (a), redesignated existing provisions as subsec. (b) and inserted “Federal” after “Sunday, or a”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/596"},"text":"Pub. L. 93–596","children":[],"tail":" substituted “Patent and Trademark Office” for “Patent Office”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":