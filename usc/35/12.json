{"tag":"section","attrib":{"id":"idf3ac1a42-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"§ 12.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copies of patents and applications for public libraries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director may supply copies of specifications and drawings of patents and published applications for patents in printed or electronic form to public libraries in the United States which shall maintain such copies for the use of the public, at the rate for each year’s issue established for this purpose in section 41(d).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf3ae8b43-d790-11f0-9f07-ba4fc64746bc"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-07-19/ch950"},"text":"July 19, 1952, ch. 950","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/794"},"text":"66 Stat. 794","children":[],"tail":", § 13; "},{"tag":"ref","attrib":{"href":"/us/pl/97/247/s15"},"text":"Pub. L. 97–247, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-27"},"text":"Aug. 27, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/321"},"text":"96 Stat. 321","children":[],"tail":"; renumbered § 12 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tIV/s4507/3"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title IV, §§ 4507(3), 4717(1), 4732(a)(10)(A), 4804(c)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–565, 1501A–580, 1501A–582, 1501A–589; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tIII"},"text":"Pub. L. 107–273, div. C, title III","children":[],"tail":",