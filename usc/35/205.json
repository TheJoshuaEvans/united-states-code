{"tag":"section","attrib":{"id":"idf3cfcedd-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s205"},"text":null,"children":[{"tag":"num","attrib":{"value":"205"},"text":"§ 205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Federal agencies are authorized to withhold from disclosure to the public information disclosing any invention in which the Federal Government owns or may own a right, title, or interest (including a nonexclusive license) for a reasonable time in order for a patent application to be filed. Furthermore, Federal agencies shall not be required to release copies of any document which is part of an application for patent filed with the United States Patent and Trademark Office or with any foreign patent office.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf3cfcede-d790-11f0-9f07-ba4fc64746bc"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/517/s6/a"},"text":"Pub. L. 96–517, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3023"},"text":"94 Stat. 3023","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3cfcedf-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf3cfcee0-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf3cfcee1-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-07-01"},"text":"July 1, 1981","children":[],"tail":", but implementing regulations authorized to be issued earlier, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/517/s8/f"},"text":"section 8(f) of Pub. L. 96–517","children":[],"tail":", set out as an Effective Date of 1980 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s41"},"text":"section 41 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
