{"tag":"section","attrib":{"id":"idf3e2e18f-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s364"},"text":null,"children":[{"tag":"num","attrib":{"value":"364"},"text":"§ 364.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International stage: Procedure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf3e2e190-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s364/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" International applications shall be processed by the Patent and Trademark Office when acting as a Receiving Office, International Searching Authority, or International Preliminary Examining Authority, in accordance with the applicable provisions of the treaty, the Regulations, and this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3e2e191-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s364/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An applicant’s failure to act within prescribed time limits in connection with requirements pertaining to an international application may be excused as provided in the treaty and the Regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf3e2e192-d790-11f0-9f07-ba4fc64746bc"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/131/s1"},"text":"Pub. L. 94–131, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-14"},"text":"Nov. 14, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/686"},"text":"89 Stat. 686","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/622/tIV/s403/a"},"text":"Pub. L. 98–622, title IV, § 403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3392"},"text":"98 Stat. 3392","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/616/s5"},"text":"Pub. L. 99–616, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-06"},"text":"Nov. 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3485"},"text":"100 Stat. 3485","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tIV/s4732/a/10/A"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title IV, § 4732(a)(10)(A)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–582; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tIII/s13206/b/1/B"},"text":"Pub. L. 107–273, div. C, title III, § 13206(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1906"},"text":"116 Stat. 1906","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/211/tII/s202/b/8"},"text":"Pub. L. 112–211, title II, § 202(b)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-18"},"text":"Dec. 18, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1536"},"text":"126 Stat. 1536","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3e2e193-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf3e2e194-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf3e2e195-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/211"},"text":"Pub. L. 112–211","children":[],"tail":" added subsec. (b) and struck out former subsec. (b) which read as follows: “An applicant’s failure to act within prescribed time limits in connection with requirements pertaining to a pending international application may be excused upon a showing satisfactory to the Director of unavoidable delay, to the extent not precluded by the treaty and the Regulations, and provided the conditions imposed by the treaty and the Regulations regarding the excuse of such failure to act are complied with.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":". See 1999 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":", substituted “Director” for “Commissioner”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/616"},"text":"Pub. L. 99–616","children":[],"tail":" substituted a comma for “or” before “International Searching Authority” and “International Preliminary Examining Authority” for “both”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/622"},"text":"Pub. L. 98–622","children":[],"tail":" substituted “Patent and Trademark Office” for “Patent Offic