{"tag":"section","attrib":{"id":"idf3ae8b9d-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s28"},"text":null,"children":[{"tag":"num","attrib":{"value":"28"},"text":"§ 28.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award of certificates to accelerate certain matters at the Patent and Trademark Office","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf3ae8b9e-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s28/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible entity” means an entity that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf3ae8b9f-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s28/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits an application under subsection (d) for a patent that addresses a humanitarian issue; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3ae8ba0-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s28/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the requirements specified by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3ae8ba1-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s28/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established a competition, to be held not less frequently than biennially, to award eligible entities certificates that can be redeemed to accelerate one of the following matters:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf3ae8ba2-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s28/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An ex parte reexamination proceeding, including 1 appeal to the Patent Trial and Appeal Board from that proceeding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3ae8ba3-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s28/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An application for a patent, including 1 appeal to the Patent Trial and Appeal Board from that application.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3ae8ba4-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s28/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An appeal to the Patent Trial and Appeal Board of a claim twice rejected in a patent application or reissue application or finally rejected in an ex parte reexamination, without accelerating the underlying matter that generated the appeal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3ae8ba5-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s28/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A matter identified by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3ae8ba6-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s28/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director shall administer the competition established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3ae8ba7-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s28/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An entity seeking an award under subsection (b) shall submit to the Director an application at such time, in such manner, and containing such information as the Director may require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3ae8ba8-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s28/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Promotion of Competition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director shall promote the competition established under subsection (b) through the satellite offices established pursuant to section 1.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3ae8ba9-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s28/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment as Successor","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The competition established under subsection (b) shall be treated as a successor to the Patents for Humanity Program (established in the notice entitled “Humanitarian Awards Pilot Program”, published at 77 Fed. Reg. 6544 (","children":[{"tag":"date","attrib":{"date":"2012-02-08"},"text":"February 8, 2012","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf3ae8baa-d790-11f0-9f07-ba4fc64746bc"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/245/s2/a"},"text":"Pub. L. 117–245, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-20"},"text":"Dec. 20, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2343"},"text":"136 Stat. 2343","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3ae8bab-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf3ae8bac-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf3ae8bad-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/245/s2/b"},"text":"Pub. L. 117–245, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-20"},"text":"Dec. 20, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2344"},"text":"136 Stat. 2344","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/245/s2/b"},"text":"“Nothing in this section [enacting this section], or the amendments made by this section, may be construed as affecting any action taken by the Under Secretary of Commerce for Intellectual Property and Director of the United States Patent and Trademark Office before the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-20"},"text":"Dec. 20, 2022","children":[],"tail":"] with respect to the administration of the Patents for Humanity Program established in the notice entitled ‘Humanitarian Awards Pilot Program’, published at 77 Fed. Reg. 6544 ("},{"tag":"date","attrib":{"date":"2012-02-08"},"text":"February 8, 2012","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
