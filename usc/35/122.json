{"tag":"section","attrib":{"id":"idf3bf2c58-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122"},"text":null,"children":[{"tag":"num","attrib":{"value":"122"},"text":"§ 122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidential status of applications; publication of patent applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf3bf2c59-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Confidentiality","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), applications for patents shall be kept in confidence by the Patent and Trademark Office and no information concerning the same given without authority of the applicant or owner unless necessary to carry out the provisions of an Act of Congress or in such special circumstances as may be determined by the Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3bf2c5a-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf3bf2c5b-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf3bf2c5c-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), each application for a patent shall be published, in accordance with procedures determined by the Director, promptly after the expiration of a period of 18 months from the earliest filing date for which a benefit is sought under this title. At the request of the applicant, an application may be published earlier than the end of such 18-month period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf3bf2c5d-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No information concerning published patent applications shall be made available to the public except as the Director determines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf3bf2c5e-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, a determination by the Director to release or not to release information concerning a published patent application shall be final and nonreviewable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3bf2c5f-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf3bf2c60-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An application shall not be published if that application is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf3bf2c61-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no longer pending;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf3bf2c62-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to a secrecy order under section 181;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf3bf2c63-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a provisional application filed under section 111(b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf3bf2c64-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an application for a design patent filed under chapter 16.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf3bf2c65-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf3bf2c66-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an applicant makes a request upon filing, certifying that the invention disclosed in the application has not and will not be the subject of an application filed in another country, or under a multilateral international agreement, that requires publication of applications 18 months after filing, the application shall not be published as provided in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf3bf2c67-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An applicant may rescind a request made under clause (i) at any time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf3bf2c68-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An applicant who has made a request under clause (i) but who subsequently files, in a foreign country or under a multilateral international agreement specified in clause (i), an application directed to the invention disclosed in the application filed in the Patent and Trademark Office, shall notify the Director of such filing not later than 45 days after the date of the filing of such foreign or international application. A failure of the applicant to provide such notice within the prescribed period shall result in the application being regarded as abandoned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf3bf2c69-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an applicant rescinds a request made under clause (i) or notifies the Director that an application was filed in a foreign country or under a multilateral international agreement specified in clause (i), the application shall be published in accordance with the provisions of paragraph (1) on or as soon as is practical after the date that is specified in clause (i).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf3bf2c6a-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/b/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an applicant has filed applications in one or more foreign countries, directly or through a multilateral international agreement, and such foreign filed applications corresponding to an application filed in the Patent and Trademark Office or the description of the invention in such foreign filed applications is less extensive than the application or description of the invention in the application filed in the Patent and Trademark Office, the applicant may submit a redacted copy of the application filed in the Patent and Trademark Office eliminating any part or description of the invention in such application that is not also contained in any of the corresponding applications filed in a foreign country. The Director may only publish the redacted copy of the application unless the redacted copy of the application is not received within 16 months after the earliest effective filing date for which a benefit is sought under this title. The provisions of section 154(d) shall not apply to a claim if the description of the invention published in the redacted application filed under this clause with respect to the claim does not enable a person skilled in the art to make and use the subject matter of the claim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3c19d6b-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protest and Pre-Issuance Opposition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director shall establish appropriate procedures to ensure that no protest or other form of pre-issuance opposition to the grant of a patent on an application may be initiated after publication of the application without the express written consent of the applicant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3c19d6c-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Security","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No application for patent shall be published under subsection (b)(1) if the publication or disclosure of such invention would be detrimental to the national security. The Director shall establish appropriate procedures to ensure that such applications are promptly identified and the secrecy of such inventions is maintained in accordance with chapter 17.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3c19d6d-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preissuance Submissions by Third Parties.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf3c19d6e-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any third party may submit for consideration and inclusion in the record of a patent application, any patent, published patent application, or other printed publication of potential relevance to the examination of the application, if such submission is made in writing before the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf3c19d6f-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date a notice of allowance under section 151 is given or mailed in the application for patent; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf3c19d70-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the later of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf3c19d71-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 6 months after the date on which the application for patent is first published under section 122 by the Office, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf3c19d72-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the first rejection under section 132 of any claim by the examiner during the examination of the application for patent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3c19d73-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any submission under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf3c19d74-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth a concise description of the asserted relevance of each submitted document;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf3c19d75-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be accompanied by such fee as the Director may prescribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf3c19d76-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s122/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a statement by the person making such submission affirming that the submission was made in compliance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf3c19d77-d790-11f0-9f07-ba4fc64746bc"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-07-19/ch950"},"text":"July 19, 1952, ch. 950","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/801"},"text":"66 Stat. 801","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/596/s1"},"text":"Pub. L. 93–596, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-02"},"text":"Jan. 2, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1949"},"text":"88 Stat. 1949","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tIV/s4502/a"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title IV, § 4502(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–561; "},{"tag":"ref","attrib":{"href":"/us/pl/112/29"},"text":"Pub. L. 112–29","children":[],"tail":", §§ 8(a), 20(j), "},{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/315"},"text":"125 Stat. 315","children":[],"tail":", 335; "},{"tag":"ref","attrib":{"href":"/us/pl/112/211/tII/s202/b/4"},"text":"Pub. L. 112–211, title II, § 202(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-18"},"text":"Dec. 18, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1536"},"text":"126 Stat. 1536","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3c19d78-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf3c19d79-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section enacts the Patent Office rule of secrecy of applications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf3c19d7a-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf3c19d7b-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (b)(2)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/211"},"text":"Pub. L. 112–211","children":[],"tail":" struck out “, unless it is shown to the satisfaction of the Director that the delay in submitting the notice was unintentional” after “regarded as abandoned”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (b)(2)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s20/j"},"text":"Pub. L. 112–29, § 20(j)","children":[],"tail":", struck out “of this title” after “181”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s20/j"},"text":"Pub. L. 112–29, § 20(j)","children":[],"tail":", struck out “of this title” after “111(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s20/j"},"text":"Pub. L. 112–29, § 20(j)","children":[],"tail":", struck out “of this title” after “16”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s20/j"},"text":"Pub. L. 112–29, § 20(j)","children":[],"tail":", struck out “of this title” after “17”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s8/a"},"text":"Pub. L. 112–29, § 8(a)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text read as follows: “Applications for patents shall be kept in confidence by the Patent and Trademark Office and no information concerning the same given without authority of the applicant or owner unless necessary to carry out the provisions of any Act of Congress or in such special circumstances as may be determined by the Commissioner.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/596"},"text":"Pub. L. 93–596","children":[],"tail":" substituted “Patent and Trademark Office” for “Patent Office”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf3c19d7c-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf3c19d7d-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/211"},"text":"Pub. L. 112–211","children":[],"tail":" effective on the date that is 1 year after "},{"tag":"date","attrib":{"date":"2012-12-18"},"text":"Dec. 18, 2012","children":[],"tail":", applicable to patents issued before, on, or after that effective date and patent applications pending on or filed after that effective date, and not effective with respect to patents in litigation commenced before that effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/211/s203"},"text":"section 203 of Pub. L. 112–211","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s27"},"text":"section 27 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf3c19d7e-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s8/b"},"text":"Pub. L. 112–29, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/316"},"text":"125 Stat. 316","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/29/s8/b"},"text":"“The amendments made by this section [amending this section] shall take effect upon the expiration of the 1-year period beginning on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":"] and shall apply to any patent application filed before, on, or after that effective date.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s20/j"},"text":"section 20(j) of Pub. L. 112–29","children":[],"tail":" effective upon the expiration of the 1-year period beginning on "},{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", and applicable to proceedings commenced on or after that effective date, see section 20("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of "},{"tag":"ref","attrib":{"href":"/us/pl/112/29"},"text":"Pub. L. 112–29","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf3c19d7f-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 19