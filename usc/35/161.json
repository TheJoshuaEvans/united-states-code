{"tag":"section","attrib":{"id":"idf3cb140c-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s161"},"text":null,"children":[{"tag":"num","attrib":{"value":"161"},"text":"§ 161.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Patents for plants","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever invents or discovers and asexually reproduces any distinct and new variety of plant, including cultivated sports, mutants, hybrids, and newly found seedlings, other than a tuber propagated plant or a plant found in an uncultivated state, may obtain a patent therefor, subject to the conditions and requirements of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The provisions of this title relating to patents for inventions shall apply to patents for plants, except as otherwise provided.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf3cb140d-d790-11f0-9f07-ba4fc64746bc"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-07-19/ch950"},"text":"July 19, 1952, ch. 950","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/804"},"text":"66 Stat. 804","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-09-03/ch1259"},"text":"Sept. 3, 1954, ch. 1259","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1190"},"text":"68 Stat. 1190","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3cb140e-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf3cb140f-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on Title 35, U.S.C., 1946 ed., § 31, part (R.S. 4886, amended (1) ","children":[{"tag":"ref","attrib":{"href":"/us/act/1897-03-03/ch391/s1"},"text":"Mar. 3, 1897, ch. 391, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/29/692"},"text":"29 Stat. 692","children":[],"tail":", (2) "},{"tag":"ref","attrib":{"href":"/us/act/1930-05-23/ch312/s1"},"text":"May 23, 1930, ch. 312, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/376"},"text":"46 Stat. 376","children":[],"tail":", (3) "},{"tag":"ref","attrib":{"href":"/us/act/1939-08-05/ch450/s1"},"text":"Aug. 5, 1939, ch. 450, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1212"},"text":"53 Stat. 1212","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The provision relating to plants in the corresponding section of existing statute is made a separate section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf3cb1410-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf3cb1411-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1954—Act ","children":[{"tag":"date","attrib":{"date":"1954-09-03"},"text":"Sept. 3, 1954","children":[],"tail":", provided that plant seedlings, discovered, propagated asexually, and proved to have new characteristics distinct from other known plants are patentable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
