{"tag":"section","attrib":{"id":"idf3ba71ab-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s111"},"text":null,"children":[{"tag":"num","attrib":{"value":"111"},"text":"§ 111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf3ba71ac-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf3ba71ad-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s111/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Written application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An application for patent shall be made, or authorized to be made, by the inventor, except as otherwise provided in this title, in writing to the Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3ba71ae-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s111/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such application shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf3ba71af-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s111/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a specification as prescribed by section 112;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf3ba71b0-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s111/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a drawing as prescribed by section 113; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf3ba71b1-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s111/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an oath or declaration as prescribed by section 115.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3ba71b2-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s111/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fee, oath or declaration, and claims","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The application shall be accompanied by the fee required by law. The fee, oath or declaration, and 1 or more claims may be submitted after the filing date of the application, within such period and under such conditions, including the payment of a surcharge, as may be prescribed by the Director. Upon failure to submit the fee, oath or declaration, and 1 or more claims within such prescribed period, the application shall be regarded as abandoned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3ba71b3-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s111/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Filing date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The filing date of an application shall be the date on which a specification, with or without claims, is received in the United States Patent and Trademark Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3ba71b4-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provisional Application.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf3ba71b5-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s111/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A provisional application for patent shall be made or authorized to be made by the inventor, except as otherwise provided in this title, in writing to the Director. Such application shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf3ba71b6-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s111/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a specification as prescribed by section 112(a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf3ba71b7-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s111/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a drawing as prescribed by section 113.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3ba71b8-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s111/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Claim","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A claim, as required by subsections (b) through (e) of section 112, shall not be required in a provisional application.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3ba71b9-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s111/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The application shall be accompanied by the fee required by law. The fee may be submitted after the filing date of the application, within such period and under such conditions, including the payment of a surcharge, as may be prescribed by the Director. Upon failure to submit the fee within such prescribed period, the application shall be regarded as abandoned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3ba71ba-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s111/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Filing date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The filing date of a provisional application shall be the date on which a specification, with or without claims, is received in the United States Patent and Trademark Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3ba71bb-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s111/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Abandonment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding the absence of a claim, upon timely request and as prescribed by the Director, a provisional application may be treated as an application filed under subsection (a). Subject to section 119(e)(3), if no such request is made, the provisional application shall be regarded as abandoned 12 months after the filing date of such application and shall not be subject to revival after such 12-month period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3ba71bc-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s111/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other basis for provisional application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to all the conditions in this subsection and section 119(e), and as prescribed by the Director, an application for patent filed under subsection (a) may be treated as a provisional application for patent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3ba71bd-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s111/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No right of priority or benefit of earliest filing date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A provisional application shall not be entitled to the right of priority of any other application under section 119, 365(a), or 386(a) or to the benefit of an earlier filing date in the United States under section 120, 121, 365(c), or 386(c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3ba71be-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s111/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicable provisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The provisions of this title relating to applications for patent shall apply to provisional applications for patent, except as otherwise provided, and except that provisional applications for patent shall not be subject to sections 131 and 135.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3ba71bf-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s111/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prior Filed Application","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding the provisions of subsection (a), the Director may prescribe the conditions, including the payment of a surcharge, under which a reference made upon the filing of an application under subsection (a) to a previously filed application, specifying the previously filed application by application number and the intellectual property authority or country in which the application was filed, shall constitute the specification and any drawings of the subsequent application for purposes of a filing date. A copy of the specification and any drawings of the previously filed application shall be submitted within such period and under such conditions as may be prescribed by the Director. A failure to submit the copy of the specification and any drawings of the previously filed application within the prescribed period shall result in the application being regarded as abandoned. Such application shall be treated as having never been filed, unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf3ba71c0-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s111/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application is revived under section 27; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3ba71c1-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s111/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of the specification and any drawings of the previously filed application are submitted to the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf3ba71c2-d790-11f0-9f07-ba4fc64746bc"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-07-19/ch950"},"text":"July 19, 1952, ch. 950","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/798"},"text":"66 Stat. 798","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/247/s5"},"text":"Pub. L. 97–247, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-27"},"text":"Aug. 27, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/319"},"text":"96 Stat. 319","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tV/s532/b/3"},"text":"Pub. L. 103–465, title V, § 532(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4986"},"text":"108 Stat. 4986","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tIV/s4732/a/10/A"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title IV, §§ 4732(a)(10)(A), 4801(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–582, 1501A–588; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tIII/s13206/b/1/B"},"text":"Pub. L. 107–273, div. C, title III, § 13206(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1906"},"text":"116 Stat. 1906","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/29"},"text":"Pub. L. 112–29","children":[],"tail":", §§ 3(e)(2), 4(a)(3), (d), 20(j), "},{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/287"},"text":"125 Stat. 287","children":[],"tail":", 295, 296, 335; "},{"tag":"ref","attrib":{"href":"/us/pl/112/211/tI/s102/3"},"text":"Pub. L. 112–211, title I, § 102(3)","children":[],"tail":", title II, § 201(a), "},{"tag":"date","attrib":{"date":"2012-12-18"},"text":"Dec. 18, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1531"},"text":"126 Stat. 1531","children":[],"tail":", 1533.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3ba71c3-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf3ba71c4-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on Title 35, U.S.C., 1946 ed., § 33 (R.S. 4888, amended (1) ","children":[{"tag":"ref","attrib":{"href":"/us/act/1915-03-03/ch94/s1"},"text":"Mar. 3, 1915, ch. 94, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/958"},"text":"38 Stat. 958","children":[],"tail":"; (2) "},{"tag":"ref","attrib":{"href":"/us/act/1930-05-23/ch312/s2"},"text":"May 23, 1930, ch. 312, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/376"},"text":"46 Stat. 376","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The corresponding section of existing statute is divided into an introductory section relating to the application generally (this section) and a section on the specification (sec. 112).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The parts of the application are specified and the requirement for signature is placed in this general section so as to insure that only one signature will suffice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf3ba71c5-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf3ba71c6-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (a)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/211/s201/a/1"},"text":"Pub. L. 112–211, § 201(a)(1)","children":[],"tail":", added pars. (3) and (4) and struck out former pars. (3) and (4) which related to fee and oath or declaration and failure to submit."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/211/s201/a/2"},"text":"Pub. L. 112–211, § 201(a)(2)","children":[],"tail":", added pars. (3) and (4) and struck out former pars. (3) and (4) which related to fee and filing date of a provisional application."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/211/s102/3"},"text":"Pub. L. 112–211, § 102(3)","children":[],"tail":", substituted “section 119, 365(a), or 386(a)” for “section 119 or 365(a)” and “section 120, 121, 365(c), or 386(c)” for “section 120, 121, or 365(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/211/s201/a/3"},"text":"Pub. L. 112–211, § 201(a)(3)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s20/j"},"text":"Pub. L. 112–29, § 20(j)","children":[],"tail":", struck out “of this title” after “112”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s20/j"},"text":"Pub. L. 112–29, § 20(j)","children":[],"tail":", struck out “of this title” after “113”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s20/j"},"text":"Pub. L. 112–29, § 20(j)","children":[],"tail":", struck out “of this title” after “115”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s4/a/3/A"},"text":"Pub. L. 112–29, § 4(a)(3)(A)","children":[],"tail":", substituted “or declaration” for “by the applicant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s4/a/3/B"},"text":"Pub. L. 112–29, § 4(a)(3)(B)","children":[],"tail":", (C), inserted “or declaration” after “and oath” in heading and text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s4/a/3/C"},"text":"Pub. L. 112–29, § 4(a)(3)(C)","children":[],"tail":", inserted “or declaration” after “and oath” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s4/d/1"},"text":"Pub. L. 112–29, § 4(d)(1)","children":[],"tail":", substituted “section 112(a)” for “the first paragraph of "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s112"},"text":"section 112 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s20/j"},"text":"Pub. L. 112–29, § 20(j)","children":[],"tail":", struck out “of this title” after “113”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s4/d/2"},"text":"Pub. L. 112–29, § 4(d)(2)","children":[],"tail":", substituted “subsections (b) through (e) of section 112,” for “the second through fifth paragraphs of section 112,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s20/j"},"text":"Pub. L. 112–29, § 20(j)","children":[],"tail":", struck out “of this title” after “119(e)(3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s20/j"},"text":"Pub. L. 112–29, § 20(j)","children":[],"tail":", struck out “of this title” after “119(e)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s20/j"},"text":"Pub. L. 112–29, § 20(j)","children":[],"tail":", struck out “of this title” after “365(a)” and after “365(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s20/j"},"text":"Pub. L. 112–29, § 20(j)","children":[],"tail":", struck out “of this title” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s3/e/2"},"text":"Pub. L. 112–29, § 3(e)(2)","children":[],"tail":", substituted “sections 131 and 135” for “sections 115, 131, 135, and 157”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsecs. (a)(1), (3), (4), (b)(1), (3)(B), (C), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/9/tIV/s4732/a/10/A"},"text":"Pub. L. 106–113, § 1000(a)(9) [title IV, § 4732(a)(10)(A)]","children":[],"tail":". See 1999 Amendment notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsecs. (a)(1), (3), (4), (b)(1), (3)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/9/tIV/s4732/a/10/A"},"text":"Pub. L. 106–113, § 1000(a)(9) [title IV, § 4732(a)(10)(A)]","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":", substituted “Director” for “Commissioner”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/9/tIV/s4801/a"},"text":"Pub. L. 106–113, § 1000(a)(9) [title IV, § 4801(a)]","children":[],"tail":", amended heading and text of par. (5) generally. Prior to amendment, text read as follows: “The provisional application shall be regarded as abandoned 12 months after the filing date of such application and shall not be subject to revival thereafter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/9/tIV/s4732/a/10/A"},"text":"Pub. L. 106–113, § 1000(a)(9) [title IV, § 4732(a)(10)(A)]","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":", substituted “Director” for “Commissioner”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “Application for patent shall be made, or authorized to be made, by the inventor, except as otherwise provided in this title, in writing to the Commissioner. Such application shall include (1) a specification as prescribed by "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s112"},"text":"section 112 of this title","children":[],"tail":"; (2) a drawing as prescribed by "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s113"},"text":"section 113 of this title","children":[],"tail":"; and (3) an oath by the applicant as prescribed by "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s115"},"text":"section 115 of this title","children":[],"tail":". The application must be accompanied by the fee required by law. The fee and oath may be submitted after the specification and any required drawing are submitted, within such period and under such conditions, including the payment of a surcharge, as may be prescribed by the Commissioner. Upon failure to submit the fee and oath within such prescribed period, the application shall be regarded as abandoned, unless it is shown to the satisfaction of the Commissioner that the delay in submitting the fee and oath was unavoidable. The filing date of an application shall be the date on which the specification and any required drawing are received in the Patent and Trademark Office.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/247"},"text":"Pub. L. 97–247","children":[],"tail":" inserted “, or authorized to be made,” after “shall be made”, struck out the colon after “shall include”, struck out “signed by the applicant and” after “The application”, and inserted provisions that the fee and oath may be submitted after the specification and any required drawing are submitted, within such period and under such conditions, including the payment of a surcharge, as may be prescribed by the Commissioner, that upon failure to submit the fee and oath within such prescribed period, the application shall be regarded as abandoned, unless it is shown to the satisfaction of the Commissioner that the delay in submitting the fee and oath was unavoidable, and that the filing date of an application shall be the date on which the specification and any required drawing are received in the Patent and Trademark Office."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf3bcbbb7-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf3bcbbb8-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/211/s102/3"},"text":"section 102(3) of Pub. L. 112–211","children":[],"tail":" effective on the later of the date that is 1 year after "},{"tag":"date","attrib":{"date":"2012-12-18"},"text":"Dec. 18, 2012","children":[],"tail":", or the date that the Geneva Act of the Hague Agreement Concerning the International Registration of Industrial Designs enters into force with respect to the United States ("},{"tag":"date","attrib":{"date":"2015-05-13"},"text":"May 13, 2015","children":[],"tail":"), and applicable only to certain applications filed on and after that effective date and patents issuing thereon, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/211/s103"},"text":"section 103 of Pub. L. 112–211","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s100"},"text":"section 100 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag