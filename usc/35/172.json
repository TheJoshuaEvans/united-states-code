{"tag":"section","attrib":{"id":"idf3cb143a-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s172"},"text":null,"children":[{"tag":"num","attrib":{"value":"172"},"text":"§ 172.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right of priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The right of priority provided for by subsections (a) through (d) of section 119 shall be six months in the case of designs. The right of priority provided for by section 119(e) shall not apply to designs.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf3cb143b-d790-11f0-9f07-ba4fc64746bc"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-07-19/ch950"},"text":"July 19, 1952, ch. 950","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/805"},"text":"66 Stat. 805","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tV/s532/c/2"},"text":"Pub. L. 103–465, title V, § 532(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4987"},"text":"108 Stat. 4987","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/29"},"text":"Pub. L. 112–29","children":[],"tail":", §§ 3(g)(1), 20(j), "},{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/288"},"text":"125 Stat. 288","children":[],"tail":", 335.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3cb143c-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf3cb143d-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on Title 35, U.S.C., 1