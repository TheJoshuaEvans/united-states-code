{"tag":"section","attrib":{"id":"idf3b5b734-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s42"},"text":null,"children":[{"tag":"num","attrib":{"value":"42"},"text":"§ 42.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Patent and Trademark Office funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf3b5b735-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s42/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All fees for services performed by or materials furnished by the Patent and Trademark Office will be payable to the Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3b5b736-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s42/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All fees paid to the Director and all appropriations for defraying the costs of the activities of the Patent and Trademark Office will be credited to the Patent and Trademark Office Appropriation Account in the Treasury of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3b5b737-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s42/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf3b5b738-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s42/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent and in the amounts provided in advance in appropriations Acts, fees authorized in this title or any other Act to be charged or established by the Director shall be collected by and shall, subject to paragraph (3), be available to the Director to carry out the activities of the Patent and Trademark Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3b80129-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s42/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established in the Treasury a Patent and Trademark Fee Reserve Fund. If fee collections by the Patent and Trademark Office for a fiscal year exceed the amount appropriated to the Office for that fiscal year, fees collected in excess of the appropriated amount shall be deposited in the Patent and Trademark Fee Reserve Fund. To the extent and in the amounts provided in appropriations Acts, amounts in the Fund shall be made available until expended only for obligation and expenditure by the Office in accordance with paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3b8012a-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s42/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf3b8012b-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s42/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any fees that are collected under this title, and any surcharges on such fees, may only be used for expenses of the Office relating to the processing of patent applications and for other activities, services, and materials relating to patents and to cover a proportionate share of the administrative costs of the Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf3b8012c-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s42/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any fees that are collected under section 31 of the Trademark Act of 1946, and any surcharges on such fees, may only be used for expenses of the Office relating to the processing of trademark registrations and for other activities, services, and materials relating to trademarks and to cover a proportionate share of the administrative costs of the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3b8012d-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s42/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director may refund any fee paid by mistake or any amount paid in excess of that required.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3b8012e-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s42/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Commerce shall, on the day each year on which the President submits the annual budget to the Congress, provide to the Committees on the Judiciary of the Senate and the House of Representatives—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf3b8012f-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s42/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of patent and trademark fee collections by the Patent and Trademark Office during the preceding fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3b80130-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s42/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of activities of the Patent and Trademark Office during the preceding fiscal year which were supported by patent fee expenditures, trademark fee expenditures, and appropriations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3b80131-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s42/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" budget plans for significant programs, projects, and activities of the Office, including out-year funding estimates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3b80132-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s42/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any proposed disposition of surplus fees by the Office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3b80133-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s42/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the committees consider necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf3b80134-d790-11f0-9f07-ba4fc64746bc"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-07-19/ch950"},"text":"July 19, 1952, ch. 950","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/796"},"text":"66 Stat. 796","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/131/s4"},"text":"Pub. L. 94–131, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-14"},"text":"Nov. 14, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/690"},"text":"89 Stat. 690","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/517/s3"},"text":"Pub. L. 96–517, § 3","