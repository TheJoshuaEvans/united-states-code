{"tag":"section","attrib":{"id":"idf3e2e17a-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s362"},"text":null,"children":[{"tag":"num","attrib":{"value":"362"},"text":"§ 362.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International Searching Authority and International Preliminary Examining Authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf3e2e17b-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s362/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Patent and Trademark Office may act as an International Searching Authority and International Preliminary Examining Authority with respect to international applications in accordance with the terms and conditions of an agreement which may be concluded with the International Bureau, and may discharge all duties required of such Authorities, including the collection of handling fees and their transmittal to the International Bureau.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3e2e17c-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s362/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The handling fee, preliminary examination fee, and any additional fees due for international preliminary examination shall be paid within such time as may be fixed by the Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf3e2e17d-d790-11f0-9f07-ba4fc64746bc"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/131/s1"},"text":"Pub. L. 94–131, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-14"},"text":"Nov. 14, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/686"},"text":"89 Stat. 686","children":[],"tail":"; amended "},{"tag":"ref","attrib":