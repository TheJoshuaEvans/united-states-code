{"tag":"section","attrib":{"id":"idf3e551fc-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s374"},"text":null,"children":[{"tag":"num","attrib":{"value":"374"},"text":"§ 374.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of international application","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The publication under the treaty defined in section 351(a), of an international application designating the United States shall be deemed a publication under section 122(b), except as provided in section 154(d).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf3e551fd-d790-11f0-9f07-ba4fc64746bc"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/131/s1"},"text":"Pub. L. 94–131, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-14"},"text":"Nov. 14, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/689"},"text":"89 Stat. 689","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tIV/s4507/10"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title IV, § 4507(10)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–566; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tIII/s13205/2/E"},"text":"Pub. L. 107–273, div. C, title III, § 13205(2)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1903"},"text":"116 Stat. 1903","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/29"},"text":"Pub. L. 112–29","children":[],"tail":", §§ 3(g)(4), 20(j), "},{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"