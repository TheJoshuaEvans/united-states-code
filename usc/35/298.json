{"tag":"section","attrib":{"id":"idf3dbdd04-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s298"},"text":null,"children":[{"tag":"num","attrib":{"value":"298"},"text":"§ 298.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advice of counsel","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The failure of an infringer to obtain the advice of counsel with respect to any allegedly infringed patent, or the failure of the infringer to present such advice to the court or jury, may not be used to prove that the accused infringer willfully infringed the patent or that the infringer intended to induce infringement of the patent.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf3dbdd05-d790-11f0-9f07-ba4fc64746bc"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s17/a"},"text":"Pub. L. 112–29, § 17(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/329"},"text":"125 Stat. 329","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3dbdd06-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf3dbdd07-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf3dbdd08-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/274/s1/a"},"text":"Pub. L. 112–274, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-14"},"text":"Jan. 14, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2456"},"text":"126 Stat. 2456","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/274/s1/a"},"text":"“Notwithstanding section 35 of the Leahy-Smith America Invents Act [","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29"},"text":"Pub. L. 112–29","children":[],"tail":"] ("},{"tag":"ref","attrib":{"href":"/us/usc/t35/s1"},"text":"35 U.S.C. 1","children":[],"tail":" note), "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s298"},"text":"section 298 of title 35","children":[],"tail":", United States Code, shall apply to any civil action commenced on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2013-01-14"},"text":"Jan. 14, 2013","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Except as otherwise provided in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29"},"text":"Pub. L. 112–29","children":[],"tail":", section effective upon the expiration of the 1-year period beginning on "},{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", and applicable to any patent issued on or after that effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/29/s35"},"text":"section 35 of Pub. L. 112–29","children":[],"tail":", set out as an Effective Date of 2011 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
