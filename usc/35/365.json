ading","topic":"editorialNotes","id":"idf3e2e1a2-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf3e2e1a3-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/211/s201/c/2"},"text":"Pub. L. 112–211, § 201(c)(2)","children":[],"tail":", inserted at end “The Director may establish procedures, including the requirement for payment of the fee specified in section 41(a)(7), to accept an unintentionally delayed claim for priority under the treaty and the Regulations, and to accept a priority claim that pertains to an application that was not filed within the priority period specified in the treaty and Regulations, but was filed within the additional 2-month period specified under section 119(a) or the treaty and Regulations.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/211/s102/8"},"text":"Pub. L. 112–211, § 102(8)","children":[],"tail":", substituted “, a prior international application designating the United States, or a prior international design application as defined in section 381(a)(6) designating the United States” for “or a prior international application designating the United States” and inserted “or a prior international design application as defined in section 381(a)(6) which designated but did not originate in the United States” after “did not originate in the United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29"},"text":"Pub. L. 112–29","children":[],"tail":" struck out “of this title” after “119”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29"},"text":"Pub. L. 112–29","children":[],"tail":" struck out “of this title” after “119(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29"},"text":"Pub. L. 112–29","children":[],"tail":" struck out “of this title” after “120”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":". See 1999 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":", substituted “Director” for “Commissioner”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s532/c/4/A"},"text":"Pub. L. 103–465, § 532(c)(4)(A)","children":[],"tail":", substituted “subsections (a) through (d) of section 119” for “section 119”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s532/c/4/B"},"text":"Pub. L. 103–465, § 532(c)(4)(B)","children":[],"tail":", substituted “section 119(a)” for “the first paragraph of section 119”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/622"},"text":"Pub. L. 98–622","children":[],"tail":" substituted “Patent and Trademark Office” for “Patent Office”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf3e2e1a4-d7