null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1978-01-24"},"text":"Jan. 24, 1978","children":[],"tail":", and applicable to international and national applications filed on and after that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/94/131/s11"},"text":"section 11 of Pub. L. 94–131","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s351"},"text":"section 351 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
