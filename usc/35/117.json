{"tag":"section","attrib":{"id":"idf3bcbc16-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s117"},"text":null,"children":[{"tag":"num","attrib":{"value":"117"},"text":"§ 117.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Death or incapacity of inventor","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Legal representatives of deceased inventors and of those under legal incapacity may make application for patent upon compliance with the requirements and on the same terms and conditions applicable to the inventor.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf3bcbc17-d790-11f0-9f07-ba4fc64746bc"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-07-19/ch950"},"text":"July 19, 1952, ch. 950","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/799"},"text":"66 Stat. 799","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3bcbc18-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf3bcbc19-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on Title 35, U.S.C., 1946 ed., § 46 (R.S. 4896, amended (1) ","children":[{"tag":"ref","attrib":{"href":"/us/act/1899-02-28/ch227"},"text":"Feb. 28, 1899, ch. 227","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/915"},"text":"30 Stat. 915","children":[],"tail":", (2) "},{"tag":"ref","attrib":{"href":"/us/act/1903-03-03/ch1019/s3"},"text":"Mar. 3, 1903, ch. 1019, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/1225"},"text":"32 Stat. 1225","children":[],"tail":", 1226, (3) "},{"tag":"ref","attrib":{"href":"/us/act/1908-05-23/ch188"},"text":"May 23, 1908, ch. 188","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/245"},"text":"35 Stat. 245","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The language has been considerably simplified.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
