{"tag":"section","attrib":{"id":"idf3e2e1d1-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s371"},"text":null,"children":[{"tag":"num","attrib":{"value":"371"},"text":"§ 371.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National stage: Commencement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf3e2e1d2-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s371/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Receipt from the International Bureau of copies of international applications with any amendments to the claims, international search reports, and international preliminary examination reports including any annexes thereto may be required in the case of international applications designating or electing the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3e2e1d3-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s371/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subsection (f) of this section, the national stage shall commence with the expiration of the applicable time limit under article 22(1) or (2), or under article 39(1)(a) of the treaty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3e2e1d4-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s371/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The applicant shall file in the Patent and Trademark Office—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf3e551d5-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s371/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the national fee provided in section 41(a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e551d6-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s371/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of the international application, unless not required under subsection (a) of this section or already communicated by the International Bureau, and a translation into the English language of the international application, if it was filed in another language;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e551d7-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s371/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amendments, if any, to the claims in the international application, made under article 19 of the treaty, unless such amendments have been communicated to the Patent and Trademark Office by the International Bureau, and a translation into the English language if such amendments were made in another language;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e551d8-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s371/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an oath or declaration of the inventor (or other person authorized under chapter 11) complying with the requirements of section 115 and with regulations prescribed for oaths or declarations of applicants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e551d9-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s371/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a translation into the English language of any annexes to the international preliminary examination report, if such annexes were made in another language.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3e551da-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s371/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The requirements with respect to the national fee referred to in subsection (c)(1), the translation referred to in subsection (c)(2), and the oath or declaration referred to in subsection (c)(4) of this section shall be complied with by the date of the commencement of the national stage or by such later time as may be fixed by the Director. The copy of the international application referred to in subsection (c)(2) shall be submitted by the date of the commencement of the national stage. Failure to comply with these requirements shall be regarded as abandonment of the application by the parties thereof. The payment of a surcharge may be required as a condition of accepting the national fee referred to in subsection (c)(1) or the oath or declaration referred to in subsection (c)(4) of this section if these requirements are not met by the date of the commencement of the national stage. The requirements of subsection (c)(3) of this section shall be complied with by the date of the commencement of the national stage, and failure to do so shall be regarded as a cancellation of the amendments to the claims in the international application made under article 19 of the treaty. The requirement of subsection (c)(5) shall be complied with at such time as may be fixed by the Director and failure to do so shall be regarded as cancellation of the amendments made under article 34(2)(b) of the treaty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3e551db-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s371/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After an international application has entered the national stage, no patent may be granted or refused thereon before the expiration of the applicable time limit under article 28 or article 41 of the treaty, except with the express consent of the applicant. The applicant may pre­sent amendments to the specification, claims and drawings of the application after the national stage has commenced.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3e551dc-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s371/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At the express request of the applicant, the national stage of processing may be commenced at any time at which the application is in order for such purpose and the applicable requirements of subsection (c) of this section have been complied with.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf3e551dd-d790-11f0-9f07-ba4fc64746bc"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/131/s1"},"text":"Pub. L. 94–131, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-14"},"text":"Nov. 14, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/688"},"text":"89 Stat. 688","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/622/tIV"},"text":"Pub. L. 98–622, title IV","children":[],"tail":", §§ 402(a)–(d), 403(a), "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3391"},"text":"98 Stat. 3391","children":[],"tail":", 3392; "},{"tag":"ref","attrib":{"href":"/us/pl/99/616/s7"},"text":"Pub. L. 99–616, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-06"},"text":"Nov. 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3486"},"text":"100 Stat. 3486","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/204/s5/g/2"},"text":"Pub. L. 102–204, § 5(g)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-10"},"text":"Dec. 10, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1641"},"text":"105 Stat. 1641","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tIV/s4732/a/10/A"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title IV, § 4732(a)(10)(A)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–582; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tIII/s13206/a/20"},"text":"Pub. L. 107–273, div. C, title III, § 13206(a)(20)","children":[],"tail":", (b)(1)(B), "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1905"},"text":"116 Stat. 1905","children":[],"tail":", 1906; "},{"tag":"ref","attrib":{"href":"/us/pl/112/29/s20/i/5"},"text":"Pub. L. 112–29, § 20(i)(5)","children":[],"tail":", (j), "},{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/335"},"text":"125 Stat. 335","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/211/tII/s202/b/9"},"text":"Pub. L. 112–211, title II, § 202(b)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-18"},"text":"Dec. 18, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1536"},"text":"126 Stat. 1536","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3e551de-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf3e551df-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf3e551e0-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/211"},"text":"Pub. L. 112–211","children":[],"tail":" struck out “, unless it be shown to the satisfaction of the Director that such failure to comply was unavoidable” after “by the parties thereof”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s20/i/5"},"text":"Pub. L. 112–29, § 20(i)(5)","children":[],"tail":", substituted “of the treaty.” for “of the treaty”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s20/j"},"text":"Pub. L. 112–29, § 20(j)","children":[],"tail":", struck out “of this title” after “41(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s20/j"},"text":"Pub. L. 112–29, § 20(j)","children":[],"tail":", struck out “of this title” after “11” and after “115”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s13206/b/1/B"},"text":"Pub. L. 107–273, § 13206(b)(1)(B)","children":[],"tail":", made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":". See 1999 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s13206/a/20"},"text":"Pub. L. 107–273, § 13206(a)(20)","children":[],"tail":", inserted period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/s13206/b/1/B"},"text":"Pub. L. 107–273, § 13206(b)(1)(B)","children":[],"tail":", substituted “Director” for “Commissioner” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/204"},"text":"Pub. L. 102–204","children":[],"tail":" substituted “provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s41/a"},"text":"section 41(a) of this title","children":[],"tail":"” for “prescribed under section 376(a)(4) of this part”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/616/s7/a"},"text":"Pub. L. 99–616, § 7(a)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “Receipt from the International Bureau of copies of international applications with amendments to the claims, if any, and international search reports may be required in the case of all international applications designating the United States.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/616/s7/b"},"text":"Pub. L. 99–616, § 7(b)","children":[],"tail":", amended subsec. (b) generally, substituting “, or under article 39(1)(a) of the treaty” for “of the treaty.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/616/s7/c"},"text":"Pub. L. 99–616, § 7(c)","children":[],"tail":", (d), substituted a semicolon for a period at end of par. (4) and added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/616/s7/e"},"text":"Pub. L. 99–616, § 7(e)","children":[],"tail":", inserted “The requirement of subsection (c)(5) shall be complied with at such time as may be fixed by the Commissioner and failure to do so shall be regarded as cancellation of the amendments made under article 34(2)(b) of the treaty” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/616/s7/f"},"text":"Pub. L. 99–616, § 7(f)","children":[],"tail":", inserted “or article 41” after “article 28”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/622/s402/a"},"text":"Pub. L. 98–622, § 402(a)","children":[],"tail":", substituted “may be” for “is” and struck out “, except those filed in the Patent Office” after “United States”, which amendment was executed by striking out “, except those filed in the Patent and Trademark Office” as the probable intent of Congress in view of the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/98/622/s403/a"},"text":"section 403(a) of Pub. L. 98–622","children":[],"tail":". See Effective Date of 1984 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/622/s403/a"},"text":"Pub. L. 98–622, § 403(a)","children":[],"tail":", substituted “Patent and Trademark Office” for “Patent Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/622"},"text":"Pub. L. 98–622","children":[],"tail":" struck out “, at which time the applicant shall have complied with the applicable requirements specified in subsection (c) of this section” after “of the treaty”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/622/s403/a"},"text":"Pub. L. 98–622, § 403(a)","children":[],"tail":", substituted “Patent and Trademark Office” for “Patent Office” in provisions preceding par. (1) and in par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/622/s402/c/1"},"text":"Pub. L. 98–622, § 402(c)(1)","children":[],"tail":", (2), substituted “communicated by” for “received from” and struck out “verified” before “translation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/622/s402/d"},"text":"Pub. L. 98–622, § 402(d)","children":[],"tail":", substituted provisions setting forth time periods for compliance with the requirements of subsec. (c), payments of surcharges, and the effect of failure to comply for provisions related only to the effect of failure to comply with the requirements of subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf3e551e1-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf3e551e2-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/211"},"text":"Pub. L. 112–211","children":[],"tail":" effective on the date that is 1 year after "},{"tag":"date","attrib":{"date":"2012-12-18"},"text":"Dec. 18, 2012","children":[],"tail":", applicable to patents issued before, on, or after that effective date and patent applications pending on or filed after that effective date, and not effective with respect to patents in litigation commenced before that effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/211/s203"},"text":"section 203 of Pub. L. 112–211","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s27"},"text":"section 27 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf3e551e3-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29"},"text":"Pub. L. 112–29","children":[],"tail":" effective upon the expiration of the 1-year period beginning on "},{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", and applicable to proceedings commenced on or after that effective date, see section 20("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of "},{"tag":"ref","attrib":{"href":"/us/pl/112/29"},"text":"Pub. L. 112–29","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf3e551e4-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" effective 4 months after "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", see section 1000(a)(9) [title IV, § 4731] of "},{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf3e551e5-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/616"},"text":"Pub. L. 99–616","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1987-07-01"},"text":"July 1, 1987","children":[],"tail":", and applicable to all international applications pending before or after that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/616/s9"},"text":"section 9 of Pub. L. 99–616","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s351"},"text":"section 351 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf3e551e6-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by section 402(a)–(d) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/622"},"text":"Pub. L. 98–622","children":[],"tail":" effective six months after "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/622/s406/b"},"text":"section 406(b) of Pub. L. 98–622","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s3"},"text":"section 3 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/622/s403/a"},"text":"section 403(a) of Pub. L. 98–622","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/622/s406/a"},"text":"section 406(a) of Pub. L. 98–622","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s351"},"text":"section 351 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf3e551e7-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1978-01-24"},"text":"Jan. 24, 1978","children":[],"tail":", and applicable to international and national applications filed, on and after that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/94/131/s11"},"text":"section 11 of Pub. L. 94–131","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s351"},"text":"section 351 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
