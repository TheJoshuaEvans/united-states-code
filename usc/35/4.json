{"tag":"section","attrib":{"id":"idf3a9a8d2-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"§ 4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on officers and employees as to interest in patents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Officers and employees of the Patent and Trademark Office shall be incapable, during the period of their appointments and for one year thereafter, of applying for a patent and of acquiring, directly or indirectly, except by inheritance or bequest, any patent or any right or interest in any patent, issued or to be issued by the Office. In patents applied for thereafter they shall not be entitled to any priority date earlier than one year after the termination of their appointment.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf3a9a8d3-d790-11f0-9f07-ba4fc64746bc"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-07-19/ch950"},"text":"July 19, 1952, ch. 950","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/793"},"text":"66 Stat. 793","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/596/s1"},"text":"Pub. L. 93–596, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-02"},"text":"Jan. 2, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1949"},"text":"88 Stat. 1949","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3a9a8d4-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf3a9a8d5-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on Title 35, U.S.C., 1946 ed., § 4 (R.S. 480).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The language is revised and inability to apply for a patent, included in the original language, is made explicit.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The period of disability is increased to include one year after leaving the Office.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The further restriction, that no priority date earlier than one year after leaving the Office can be claimed, is added.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The one year period is made inapplicable to applications which may be pending when the revised title goes into effect by section 4(g) of the bill.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf3a9a8d6-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf3a9a8d7-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/596"},"text":"Pub. L. 93–596","children":[],"tail":" substituted “Patent and Trademark Office” for “Patent Office”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf3a9a8d8-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf3a9a8d9-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1975 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/596"},"text":"Pub. L. 93–596","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1975-01-02"},"text":"Jan. 2, 1975","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/596/s4"},"text":"section 4 of Pub. L. 93–596","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1111"},"text":"section 1111 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
