{"tag":"section","attrib":{"id":"idf3dbdcd2-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s295"},"text":null,"children":[{"tag":"num","attrib":{"value":"295"},"text":"§ 295.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presumption: Product made by patented process","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In actions alleging infringement of a process patent based on the importation, sale, offer for sale, or use of a product which is made from a process patented in the United States, if the court finds—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf3dbdcd3-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s295/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that a substantial likelihood exists that the product was made by the patented process, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3dbdcd4-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s295/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the plaintiff has made a reasonable effort to determine the process actually used in the production of the product and was unable to so determine,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the product shall be presumed to have been so made, and the burden of establishing that the product was not made by the process shall be on the party asserting that it was not so made.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf3dbdcd5-d790-11f0-9f07-ba4fc64746bc"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tIX/s9005/a"},"text":"Pub. L. 100–418, title IX, § 9005(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1566"},"text":"102 Stat. 1566","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tV/s533/b/7"},"text":"Pub. L. 103–465, title V, § 533(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4990"},"text":"108 Stat. 4990","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3dbdcd6-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf3dbdcd7-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf3dbdcd8-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" substituted “sale, offer for sale, or use” for “sale, or use” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf3dbdcd9-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf3dbdcda-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" effective on date that is one year after date on which the WTO Agreement enters into force with respect to the United States ["},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"], with provisions relating to earliest filed patent application, see section 534(a), (b)(3) of "},{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s154"},"text":"section 154 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf3dbdcdb-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 6 months after ","children":[{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", and, subject to enumerated exceptions, applicable only with respect to products made or imported after such effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/s9006"},"text":"section 9006 of Pub. L. 100–418","children":[],"tail":", set out as an Effective Date of 1988 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s271"},"text":"section 271 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
