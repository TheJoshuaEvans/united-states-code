{"tag":"section","attrib":{"id":"idf3e55210-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s376"},"text":null,"children":[{"tag":"num","attrib":{"value":"376"},"text":"§ 376.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf3e55211-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s376/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The required payment of the international fee and the handling fee, which amounts are specified in the Regulations, shall be paid in United States currency. The Patent and Trademark Office shall charge a national fee as provided in section 41(a), and may also charge the following fees:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf3e55212-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s376/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A transmittal fee (see section 361(d)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e55213-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s376/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A search fee (see section 361(d)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e55214-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s376/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A supplemental search fee (to be paid when required).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e55215-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s376/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A preliminary examination fee and any additional fees (see section 362(b)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e55216-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s376/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other fees as established by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3e55217-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s376/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amounts of fees specified in subsection (a) of this section, except the international fee and the handling fee, shall be prescribed by the Director. He may refund any sum paid by mistake or in excess of the fees so specified, or if required under the treaty and the Regulations. The Director may also refund any part of the search fee, the national fee, the preliminary examination fee, and any additional fees, where he determines such refund to be warranted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf3e55218-d790-11f0-9f07-ba4fc64746bc"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/131/s1"},"text":"Pub. L. 94–131, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-14"},"text":"Nov. 14, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/690"},"text":"89 Stat. 690","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/622/tIV"},"text":"Pub. L. 98–622, title IV","children":[],"tail":", §§ 402(g), 403(a), "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3392"},"text":"98 Stat. 3392","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/616/s8"},"text":"Pub. L. 99–616, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-06"},"text":"Nov. 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3486"},"text":"100 Stat. 3486","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/204/s5/g/1"},"text":"Pub. L. 102–204, § 5(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-10"},"text":"Dec. 10, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1640"},"text":"105 Stat. 1640","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tIV/s4732/a/10/A"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title IV, § 4732(a)(10)(A)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–582; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tIII/s13206/a/21"},"text":"Pub. L. 107–273, div. C, title III, § 13206(a)(21)","children":[],"tail":", (b)(1)(B), "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1905"},"text":"116 Stat. 1905","children":[],"tail":", 1906.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3e55219-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf3e5521a-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf3e5521b-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading"