{"tag":"section","attrib":{"id":"idf3d96b4f-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s285"},"text":null,"children":[{"tag":"num","attrib":{"value":"285"},"text":"§ 285.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attorney fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The court in exceptional cases may award reasonable attorney fees to the prevailing party.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf3d96b50-d790-11f0-9f07-ba4fc64746bc"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-07-19/ch950"},"text":"July 19, 1952, ch. 950","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/813"},"text":"66 Stat. 813","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3d96b51-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf3d96b52-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on Title 35, U.S.C., 1946 ed., § 70, part (R.S. 4921, amended (1) ","children":[{"tag":"ref","attrib":{"href":"/us/act/1897-03-03/ch391/s6"},"text":"Mar. 3, 1897, ch. 391, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/29/694"},"text":"29 Stat. 694","children":[],"tail":", (2) "},{"tag":"ref","attrib":{"href":"/us/act/1922-02-18/ch58/s8"},"text":"Feb. 18, 1922, ch. 58, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/392"},"text":"42 Stat. 392","children":[],"tail":", (3) "},{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch726/s1"},"text":"Aug. 1, 1946, ch. 726, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/778"},"text":"60 Stat. 778","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section is substantially the same as the corresponding provision in R.S. 4921; “in exceptional cases” has been added as expressing the intention of the present statute as shown by its legislative history and as interpreted by the courts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
