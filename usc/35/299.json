{"tag":"section","attrib":{"id":"idf3dbdd09-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s299"},"text":null,"children":[{"tag":"num","attrib":{"value":"299"},"text":"§ 299.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joinder of parties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf3dbdd0a-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s299/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Joinder of Accused Infringers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to any civil action arising under any Act of Congress relating to patents, other than an action or trial in which an act of infringement under section 271(e)(2) has been pled, parties that are accused infringers may be joined in one action as defendants or counterclaim defendants, or have their actions consolidated for trial, only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf3dbdd0b-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s299/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any right to relief is asserted against the parties jointly, severally, or in the alternative with respect to or arising out of the same transaction, occurrence, or series of transactions or occurrences relating to the making, using, importing into the United States, offering for sale, or selling of the same accused product or process; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3dbdd0c-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s299/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" questions of fact common to all defendants or counterclaim defendants will arise in the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3dbdd0d-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s299/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allegations Insufficient for Joinder","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this subsection, accused infringers may not be joined in one action as defendants or counterclaim defendants, or have their actions consolidated for trial, based solely on allegations that they each have infringed the patent or patents in suit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3dbdd0e-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s299/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A party that is an accused infringer may waive the limitations set forth in this section with respect to that party.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf3dbdd0f-d790-11f0-9f07-ba4fc64746bc"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s19/d/1"},"text":"Pub. L. 112–29, § 19(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/332"},"text":"125 Stat. 332","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/274/s1/c"},"text":"Pub. L. 112–274, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-14"},"text":"Jan. 14, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2456"},"text":"126 Stat. 2456","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3dbdd10-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf3dbdd11-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf3dbdd12-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/274"},"text":"Pub. L. 112–274","children":[],"tail":" substituted “only if” for “or counterclaim defendants only if” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf3dbdd13-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf3dbdd14-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/274"},"text":"Pub. L. 112–274","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2013-01-14"},"text":"Jan. 14, 2013","children":[],"tail":", and applicable to proceedings commenced on or after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/274/s1/n"},"text":"section 1(n) of Pub. L. 112–274","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s5"},"text":"section 5 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf3dbdd15-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to any civil action commenced on or after ","children":[{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/29/s19/e"},"text":"section 19(e) of Pub. L. 112–29","children":[],"tail":", set out as an Effective Date of 2011 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1295"},"text":"section 1295 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
