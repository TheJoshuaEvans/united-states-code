{"tag":"section","attrib":{"id":"idf3cd8494-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s188"},"text":null,"children":[{"tag":"num","attrib":{"value":"188"},"text":"§ 188.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations, delegation of power","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Atomic Energy Commission, the Secretary of a defense department, the chief officer of any other department or agency of the Government designated by the President as a defense agency of the United States, and the Secretary of Commerce, may separately issue rules and regulations to enable the respective department or agency to carry out the provisions of this chapter, and may delegate any power conferred by this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf3cd8495-d790-11f0-9f07-ba4fc64746bc"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-07-19/ch950"},"text":"July 19, 1952, ch. 950","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/808"},"text":"66 Stat. 808","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3cd8496-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf3cd8497-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on Title 35, U.S.C., 1946 ed., § 158 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-02-01/ch4/s8"},"text":"Feb. 1, 1952, ch. 4, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/6"},"text":"66 Stat. 6","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Language is changed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf3cd8498-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idf3cd8499-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Atomic Energy Commission abolished and functions transferred by sections 5814 and 5841 of Title 42, The Public Health and Welfare. See, also, Transfer of Functions notes set out under those sections.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idf3cd849a-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf3cd849b-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Defense Agencies","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Department of Justice designated as a defense agency of United States for purposes of this chapter by Executive Order No. 10457, ","children":[{"tag":"date","attrib":{"date":"1953-05-27"},"text":"May 27, 1953","children":[],"tail":", 18 F.R. 3083."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
