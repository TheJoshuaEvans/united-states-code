{"tag":"section","attrib":{"id":"idf3e55228-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s381"},"text":null,"children":[{"tag":"num","attrib":{"value":"381"},"text":"§ 381.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf3e55229-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s381/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"When used in this part, unless the context otherwise indicates—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf3e5522a-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s381/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “treaty” means the Geneva Act of the Hague Agreement Concerning the International Registration of Industrial Designs adopted at Geneva on ","children":[{"tag":"date","attrib":{"date":"1999-07-02"},"text":"July 2, 1999","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e5522b-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s381/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “regulations”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf3e5522c-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s381/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when capitalized, means the Common Regulations under the treaty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf3e5522d-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s381/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when not capitalized, means the regulations established by the Director under this title;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e5522e-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s381/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “designation”, “designating”, and “designate” refer to a request that an international registration have effect in a Contracting Party to the treaty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e5522f-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s381/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “International Bureau” means the international intergovernmental organization that is recognized as the coordinating body under the treaty and the Regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e55230-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s381/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “effective registration date” means the date of international registration determined by the International Bureau under the treaty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e55231-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s381/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “international design application” means an application for international registration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e55232-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s381/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “international registration” means the international registration of an industrial design filed under the treaty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3e55233-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s381/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Terms and expressions not defined in this part are to be taken in the sense indicated by the treaty and the Regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf3e55234-d790-11f0-9f07-ba4fc64746bc"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/211/tI/s101/a"},"text":"Pub. L. 112–211, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-18"},"text":"Dec. 18, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1527"},"text":"126 Stat. 1527","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3e55235-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf3e55236-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf3e55237-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the later of the date that is 1 year after ","children":[{"tag":"date","attrib":{"date":"2012-12-18"},"text":"Dec. 18, 2012","children":[],"tail":", or the date that the Geneva Act of the Hague Agreement Concerning the International Registration of Industrial Designs enters into force with respect to the United States ("},{"tag":"date","attrib":{"date":"2015-05-13"},"text":"May 13, 2015","children":[],"tail":"), and applicable only to certain applications filed on and after that effective date and patents issuing thereon, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/211/s103"},"text":"section 103 of Pub. L. 112–211","children":[],"tail":", set out as an Effective Date of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s100"},"text":"section 100 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
