 "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/9/tIV/s4732/a/10/A"},"text":"Pub. L. 106–113, § 1000(a)(9) [title IV, § 4732(a)(10)(A)]","children":[],"tail":". See 1999 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s13106/c"},"text":"Pub. L. 107–273, § 13106(c)","children":[],"tail":", inserted “, or a third-party requester in an inter partes reexamination proceeding, who is” after “patent owner” in third sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/9/tIV/s4732/a/10/A"},"text":"Pub. L. 106–113, § 1000(a)(9) [title IV, § 4732(a)(10)(A)]","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/s13206/b/1/B"},"text":"Pub. L. 107–273, § 13206(b)(1)(B)","children":[],"tail":", substituted “Director” for “Commissioner”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/9/tIV/s4605/c"},"text":"Pub. L. 106–113, § 1000(a)(9) [title IV, § 4605(c)]","children":[],"tail":", inserted after second sentence “A patent owner in any reexamination proceeding dissatisfied with the final decision in an appeal to the Board of Patent Appeals and Interferences under section 134 may appeal the decision only to the United States Court of Appeals for the Federal Circuit.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/622/s203/a/1/A"},"text":"Pub. L. 98–622, § 203(a)(1)(A)","children":[],"tail":", substituted “in an appeal to the Board of Patent Appeals and Interferences under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s134"},"text":"section 134 of this title","children":[],"tail":" may appeal the decision” for “of the Board of Patent Appeals may appeal” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/622/s203/a/1/B"},"text":"Pub. L. 98–622, § 203(a)(1)(B)","children":[],"tail":", substituted “. By filing such an appeal the applicant waives his or her right” for “, thereby waiving his right” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/622/s203/a/2/A"},"text":"Pub. L. 98–622, § 203(a)(2)(A)","children":[],"tail":", substituted “Board of Patent Appeals and Interferences on the interference may appeal the decision” for “board of patent interferences on the question of priority of appeal” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/622/s203/a/2/B"},"text":"Pub. L. 98–622, § 203(a)(2)(B)","children":[],"tail":", substituted “In accordance with” for “according to” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/622/s203/a/2/C"},"text":"Pub. L. 98–622, § 203(a)(2)(C)","children":[],"tail":", substituted “the party” for “he” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/622/s203/a/3"},"text":"Pub. L. 98–622, § 203(a)(3)","children":[],"tail":", reenacted last sentence with minor changes in wording."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164/s163/b/2"},"text":"Pub. L. 97–164, § 163(b)(2)","children":[],"tail":", substituted “Court of Appeals for the Federal Circuit” for “Court of Customs and Patent Appeals” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164/s163/a/7"},"text":"Pub. L. 97–164, § 163(a)(7)","children":[],"tail":", substituted “Court of Appeals for the Federal Circuit” for “Court of Customs and Patent Appeals” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"cro