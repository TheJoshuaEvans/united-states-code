{"tag":"section","attrib":{"id":"idf3cd8490-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s187"},"text":null,"children":[{"tag":"num","attrib":{"value":"187"},"text":"§ 187.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability to certain persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The prohibitions and penalties of this chapter shall not apply to any officer or agent of the United States acting within the scope of his authority, nor to any person acting upon his written instructions or permission.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf3cd8491-d790-11f0-9f07-ba4fc64746bc"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-07-19/ch950"},"text":"July 19, 1952, ch. 950","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/808"},"text":"66 Stat. 808","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3cd8492-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf3cd8493-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on Title 35, U.S.C., 1946 ed., § 157 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-02-01/ch4/s7"},"text":"Feb. 1, 1952, ch. 4, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/6"},"text":"66 Stat. 6","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Language is changed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
