{"tag":"section","attrib":{"id":"idf3cfcee2-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s206"},"text":null,"children":[{"tag":"num","attrib":{"value":"206"},"text":"§ 206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniform clauses and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce may issue regulations which may be made applicable to Federal agencies implementing the provisions of sections 202 through 204 of this chapter and shall establish standard funding agreement provisions required under this chapter. The regulations and the standard funding agreement shall be subject to public comment before their issuance.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf3cfcee3-d790-11f0-9f07-ba4fc64746bc"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/517/s6/a"},"text":"Pub. L. 96–517, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3023"},"text":"94 Stat. 3023","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/620/tV/s501/10"},"text":"Pub. L. 98–620, title V, § 501(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3367"},"text":"98 Stat. 3367","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3cfcee4-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf3cfcee5-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf3cfcee6-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620"},"text":"Pub. L. 98–620","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “The Office of Federal Procurement Policy, after receiving recommendations of the Office of Science and Technology Policy, may issue regulations which may be made applicable to Federal agencies implementing the provisions of sections 202 through 204 of this chapter and the Office of Federal Procurement Policy shall establish standard funding agreement provisions required under this chapter.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf3cfcee7-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf3cfcee8-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-07-01"},"text":"July 1, 1981","children":[],"tail":", but implementing regulations authorized to be issued earlier, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/517/s8/f"},"text":"section 8(f) of Pub. L. 96–517","children":[],"tail":", set out as an Effective Date of 1980 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s41"},"text":"section 41 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
