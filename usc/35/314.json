{"tag":"section","attrib":{"id":"idf3de2686-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s314"},"text":null,"children":[{"tag":"num","attrib":{"value":"314"},"text":"§ 314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution of inter partes review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf3de2687-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Threshold","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director may not authorize an inter partes review to be instituted unless the Director determines that the information presented in the petition filed under section 311 and any response filed under section 313 shows that there is a reasonable likelihood that the petitioner would prevail with respect to at least 1 of the claims challenged in the petition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3de2688-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall determine whether to institute an inter partes review under this chapter pursuant to a petition filed under section 311 within 3 months after—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf3de2689-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s314/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receiving a preliminary response to the petition under section 313; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3de268a-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s314/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if no such preliminary response is filed, the last date on which such response may be filed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3de268b-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s314/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director shall notify the petitioner and patent owner, in writing, of the Director’s determination under subsection (a), and shall make such notice available to the public as soon as is practicable. Such notice shall include the date on which the review shall commence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3de268c-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s314/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Appeal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The determination by the Director whether to institute an inter partes review under this section shall be final and nonappealable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf3de268d-d790-11f0-9f07-ba4fc64746bc"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tIV/s4604/a"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title IV, § 4604(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–568; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tIII/s13202/a/3"},"text":"Pub. L. 107–273, div. C, title III, § 13202(a)(3)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1901"},"text":"116 Stat. 1901","children":[],"tail":", 1902; "},{"tag":"ref","attrib":{"href":"/us/pl/112/29/s6/a"},"text":"Pub. L. 112–29, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/300"},"text":"125 Stat. 300","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3de268e-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf3de268f-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf3de2690-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29"},"text":"Pub. L. 112–29","children":[],"tail":" amended section generally. Prior to amendment, section related to conduct of inter partes reexamination proceedings."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s13202/c/1"},"text":"Pub. L. 107–273, § 13202(c)(1)","children":[],"tail":", made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":", which enacted this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s13202/a/3"},"text":"Pub. L. 107–273, § 13202(a)(3)","children":[],"tail":", redesignated par. (2) as (1), substituted “the Office shall send to the third-party requester a copy” for “the third-party requester shall receive a copy”, redesignated par. (3) as (2), and struck out former par. (1) which read as follows: “This subsection shall apply to any inter partes reexamination proceeding in which the order for inter partes reexamination is based upon a request by a third-party requester.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf3de2691-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf3de2692-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29"},"text":"Pub. L. 112–29","children":[],"tail":" effective upon the expiration of the 1-year period beginning on "},{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", and applicable to any patent issued before, on, or after that effective date, with provisions for graduated implementation, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/29/s6/c/2"},"text":"section 6(c)(2) of Pub. L. 112–29","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s311"},"text":"section 311 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf3de2693-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", and applicable to any patent issuing from an original application filed in the United States on or after that date, see section 1000(a)(9) [title IV, § 4608(a)] of "},{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":", set out as an Effective Date of 1999 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s41"},"text":"section 41 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
