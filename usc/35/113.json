{"tag":"section","attrib":{"id":"idf3bcbbce-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s113"},"text":null,"children":[{"tag":"num","attrib":{"value":"113"},"text":"§ 113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drawings","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The applicant shall furnish a drawing where necessary for the understanding of the subject matter sought to be patented. When the nature of such subject matter admits of illustration by a drawing and the applicant has not furnished such a drawing, the Director may require its submission within a time period of not less than two months from the sending of a notice thereof. Drawings submitted after the filing date of the application may not be used (i) to overcome any insufficiency of the specification due to lack of an enabling disclosure or otherwise inadequate disclosure therein, or (ii) to supplement the original disclosure thereof for the purpose of interpretation of the scope of any claim.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf3bcbbcf-d790-11f0-9f07-ba4fc64746bc"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-07-19/ch950"},"text":"July 19, 1952, ch. 950","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/799"},"text":"66 Stat. 799","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/131/s8"},"text":"Pub. L. 94–131, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-14"},"text":"Nov. 14, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/691"},"text":"89 Stat. 691","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tIV/s4732/a/10/A"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title IV, § 4732(a)(10)(A)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–582; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tIII/s13206/b/1/B"},"text":"Pub. L. 107–273, div. C, title III, § 13206(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1906"},"text":"116 Stat. 1906","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3bcbbd0-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf3bcbbd1-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on Title 35, U.S.C., 1946 ed., § 34, part (R.S. 4889, amended ","children":[{"tag":"ref","attrib":{"href":"/us/act/1915-03-03/ch94/s2"},"text":"Mar. 3, 1915, ch. 94, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/958"},"text":"38 Stat. 958","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The requirement for signature in the corresponding section of existing statute is omitted; regulations of the Patent Office can take care of any substitute. A redundant clause is omitted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf3bcbbd2-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf3bcbbd3-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":". See 1999 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":", substituted “Director” for “Commissioner”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/131"},"text":"Pub. L. 94–131","children":[],"tail":" substituted provisions respecting drawings requiring necessary-for-understanding drawings and submission of drawings within prescribed time period and limiting use of drawings submitted after filing date of application for prior provision requiring the applicant to furnish a drawing when the nature of the case admitted it."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf3bcbbd4-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf3bcbbd5-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" effective 4 months after "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", see section 1000(a)(9) [title IV, § 4731] of "},{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf3bcbbd6-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1975 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/131"},"text":"Pub. L. 94–131","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1978-01-24"},"text":"Jan. 24, 1978","children":[],"tail":", and applicable on and after that date to patent applications filed in the United States and to international applications, where applicable, see "},{"tag":"ref","attrib":{"href":"/us/pl/94/131/s11"},"text":"section 11 of Pub. L. 94–131","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s351"},"text":"section 351 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
