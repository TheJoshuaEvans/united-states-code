{"tag":"section","attrib":{"id":"idf3e55264-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s387"},"text":null,"children":[{"tag":"num","attrib":{"value":"387"},"text":"§ 387.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relief from prescribed time limits","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An applicant’s failure to act within prescribed time limits in connection with requirements pertaining to an international design application may be excused as to the United States upon a showing satisfactory to the Director of unintentional delay and under such conditions, including a requirement for payment of the fee specified in section 41(a)(7), as may be prescribed by the Director.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf3e55265-d790-11f0-9f07-ba4fc64746bc"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/211/tI/s101/a"},"text":"Pub. L. 112–211, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-18"},"text":"Dec. 18, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1530"},"text":"126 Stat. 1530","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3e55266-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf3e55267-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf3e55268-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the later of the date that is 1 year after ","children":[{"tag":"date","attrib":{"date":"2012-12-18"},"text":"Dec. 18, 2012","children":[],"tail":", or the date that the Geneva Act of the Hague Agreement Concerning the International Registration of Industrial Designs enters into force with respect to the United States ("},{"tag":"date","attrib":{"date":"2015-05-13"},"text":"May 13, 2015","children":[],"tail":"), and applicable only to certain applications filed on and after that effective date and patents issuing thereon, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/211/s103"},"text":"section 103 of Pub. L. 112–211","children":[],"tail":", set out as an Effective Date of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s100"},"text":"section 100 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
