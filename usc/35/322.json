{"tag":"section","attrib":{"id":"idf3e096f4-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s322"},"text":null,"children":[{"tag":"num","attrib":{"value":"322"},"text":"§ 322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf3e096f5-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s322/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements of Petition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A petition filed under section 321 may be considered only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf3e096f6-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s322/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the petition is accompanied by payment of the fee established by the Director under section 321;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e096f7-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s322/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the petition identifies all real parties in interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e096f8-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s322/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the petition identifies, in writing and with particularity, each claim challenged, the grounds on which the challenge to each claim is based, and the evidence that supports the grounds for the challenge to each claim, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf3e096f9-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s322/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" copies of patents and printed publications that the petitioner relies upon in support of the petition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf3e096fa-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s322/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affidavits or declarations of supporting evidence and opinions, if the petitioner relies on other factual evidence or on expert opinions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e096fb-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s322/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the petition provides such other information as the Director may require by regulation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e096fc-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s322/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the petitioner provides copies of any of the documents required under paragraphs (2), (3), and (4) to the patent owner or, if applicable, the designated representative of the patent owner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3e096fd-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s322/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As soon as practicable after the receipt of a petition under section 321, the Director shall make the petition available to the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf3e096fe-d790-11f0-9f07-ba4fc64746bc"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s6/d"},"text":"Pub. L. 112–29, § 6(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/306"},"text":"125 Stat. 306","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3e096ff-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf3e09700-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf3e09701-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the expiration of the 1-year period beginning ","children":[{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", and applicable only to patents described in "},{"tag":"ref","attrib":{"href":"/us/pl/112/29/s3/n/1"},"text":"section 3(n)(1) of Pub. L. 112–29","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t35/s100"},"text":"35 U.S.C. 100","children":[],"tail":" note), with certain exceptions and limitations, see section 6(f)(2), (3) of "},{"tag":"ref","attrib":{"href":"/us/pl/112/29"},"text":"Pub. L. 112–29","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s321"},"text":"section 321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
