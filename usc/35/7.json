{"tag":"section","attrib":{"id":"idf3ac1a0b-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"§ 7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Library","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director shall maintain a library of scientific and other works and periodicals, both foreign and domestic, in the Patent and Trademark Office to aid the officers in the discharge of their duties.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf3ac1a0c-d790-11f0-9f07-ba4fc64746bc"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-07-19/ch950"},"text":"July 19, 1952, ch. 950","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/793"},"text":"66 Stat. 793","children":[],"tail":", § 8; "},{"tag":"ref","attrib":{"href":"/us/pl/93/596/s1"},"text":"Pub. L. 93–596, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-02"},"text":"Jan. 2, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1949"},"text":"88 Stat. 1949","children":[],"tail":"; renumbered § 7 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tIV/s4717/1"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title IV, §§ 4717(1), 4732(a)(10)(A)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–580, 1501A–582; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tIII/s13206/b/1/B"},"text":"Pub. L. 107–273, div. C, title III, § 13206(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1906"},"text":"116 Stat. 1906","children":[]