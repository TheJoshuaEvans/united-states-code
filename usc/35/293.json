{"tag":"section","attrib":{"id":"idf3d96bbb-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s293"},"text":null,"children":[{"tag":"num","attrib":{"value":"293"},"text":"§ 293.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonresident patentee; service and notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every patentee not residing in the United States may file in the Patent and Trademark Office a written designation stating the name and address of a person residing within the United States on whom may be served process or notice of proceedings affecting the patent or rights thereunder. If the person designated cannot be found at the address given in the last designation, or if no person has been designated, the United States District Court for the Eastern District of Virginia shall have jurisdiction and summons shall be served by publication or otherwise as the court directs. The court shall have the same jurisdiction to take any action respecting the patent or rights thereunder that it would have if the patentee were personally within the jurisdiction of the court.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf3d96bbc-d790-11f0-9f07-ba4fc64746bc"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-07-19/ch950"},"text":"July 19, 1952, ch. 950","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/814"},"text":"66 Stat. 814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/596/s1"},"text":"Pub. L. 93–596, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-02"},"text":"Jan. 2, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1949"},"text":"88 Stat. 1949","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/29/s9/a"},"text":"Pub. L. 112–29, § 9(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/316"},"text":"125 Stat. 316","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3d96bbd-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf3d96bbe-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section provides for service on non-resident patentees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf3d96bbf-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf3d96bc0-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29"},"text":"Pub. L. 112–29","children":[],"tail":" substituted “United States District Court for the Eastern District of Virginia” for “United States District Court for the District of Columbia”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/596"},"text":"Pub. L. 93–596","children":[],"tail":" substituted “Patent and Trademark Office” for “Patent Office”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf3d96bc1-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf3d96bc2-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29"},"text":"Pub. L. 112–29","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", and applicable to any civil action commenced on or after that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/29/s9/b"},"text":"section 9(b) of Pub. L. 112–29","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1071"},"text":"section 1071 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf3d96bc3-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1975 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/596"},"text":"Pub. L. 93–596","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1975-01-02"},"text":"Jan. 2, 1975","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/596/s4"},"text":"section 4 of Pub. L. 93–596","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1111"},"text":"section 1111 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
