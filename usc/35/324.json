{"tag":"section","attrib":{"id":"idf3e09707-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s324"},"text":null,"children":[{"tag":"num","attrib":{"value":"324"},"text":"§ 324.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution of post-grant review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf3e09708-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s324/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Threshold","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director may not authorize a post-grant review to be instituted unless the Director determines that the information presented in the petition filed under section 321, if such information is not rebutted, would demonstrate that it is more likely than not that at least 1 of the claims challenged in the petition is unpatentable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3e09709-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s324/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Grounds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The determination required under subsection (a) may also be satisfied by a showing that the petition raises a novel or unsettled legal question that is important to other patents or patent applications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3e0970a-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s324/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall determine whether to institute a post-grant review under this chapter pursuant to a petition filed under section 321 within 3 months after—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf3e0970b-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s324/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receiving a preliminary response to the petition under section 323; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf3e0970c-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s324/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if no such preliminary response is filed, the last date on which such response may be filed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3e0970d-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s324/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director shall notify the petitioner and patent owner, in writing, of the Director’s determination under subsection (a) or (b), and shall make such notice available to the public as soon as is practicable. Such notice shall include the date on which the review shall commence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3e0970e-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s324/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Appeal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The determination by the Director whether to institute a post-grant review under this section shall be final and nonappealable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf3e0970f-d790-11f0-9f07-ba4fc64746bc"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s6/d"},"text":"Pub. L. 112–29, § 6(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/306"},"text":"125 Stat. 306","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3e09710-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf3e09711-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf3e09712-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the expiration of the 1-year period beginning ","children":[{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", and applicable only to patents described in "},{"tag":"ref","attrib":{"href":"/us/pl/112/29/s3/n/1"},"text":"section 3(n)(1) of Pub. L. 112–29","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t35/s100"},"text":"35 U.S.C. 100","children":[],"tail":" note), with certain exceptions and limitations, see section 6(f)(2), (3) of "},{"tag":"ref","attrib":{"href":"/us/pl/112/29"},"text":"Pub. L. 112–29","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s321"},"text":"section 321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
