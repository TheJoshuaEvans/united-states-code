{"tag":"section","attrib":{"id":"idf3e7c36e-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s389"},"text":null,"children":[{"tag":"num","attrib":{"value":"389"},"text":"§ 389.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examination of international design application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf3e7c36f-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s389/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director shall cause an examination to be made pursuant to this title of an international design application designating the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3e7c370-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s389/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Chapter","children":[],"tail":" 16.—"}],"tail":null},{"tag":"content","attrib":{},"text":"All questions of substance and, unless otherwise required by the treaty and Regulations, procedures regarding an international design application designating the United States shall be determined as in the case of applications filed under chapter 16.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3e7c371-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s389/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director may prescribe fees for filing international design applications, for designating the United States, and for any other processing, services, or materials relating to international design applications, and may provide for later payment of such fees, including surcharges for later submission of fees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf3e7c372-d790-11f0-9f07-ba4fc64746bc","identifier":"/us/usc/t35/s389/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Issuance of Patent","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director may issue a patent based on an international design application designating the United States, in accordance with the provisions of this title. Such patent shall have the force and effect of a patent issued on an application filed under chapter 16.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf3e7c373-d790-11f0-9f07-ba4fc64746bc"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/211/tI/s101/a"},"text":"Pub. L. 112–211, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-18"},"text":"Dec. 18, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1530"},"text":"126 Stat. 1530","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf3e7c374-d790-11f0-9f07-ba4fc64746bc"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf3e7c375-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf3e7c376-d790-11f0-9f07-ba4fc64746bc"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the later of the date that is 1 year after ","children":[{"tag":"date","attrib":{"date":"2012-12-18"},"text":"Dec. 18, 2012","children":[],"tail":", or the date that the Geneva Act of the Hague Agreement Concerning the International Registration of Industrial Designs enters into force with respect to the United States ("},{"tag":"date","attrib":{"date":"2015-05-13"},"text":"May 13, 2015","children":[],"tail":"), and applicable only to certain applications filed on and after that effective date and patents issuing thereon, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/211/s103"},"text":"section 103 of Pub. L. 112–211","children":[],"tail":", set out as an Effective Date of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s100"},"text":"section 100 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
