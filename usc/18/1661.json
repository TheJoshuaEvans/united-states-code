{"tag":"section","attrib":{"id":"idb92ad5e4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1661"},"text":null,"children":[{"tag":"num","attrib":{"value":"1661"},"text":"§ 1661.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Robbery ashore","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being engaged in any piratical cruise or enterprise, or being of the crew of any piratical vessel, lands from such vessel and commits robbery on shore, is a pirate, and shall be imprisoned for life.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb92ad5e5-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/775"},"text":"62 Stat. 775","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92ad5e6-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb92ad5e7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 493 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s302"},"text":"Mar. 4, 1909, ch. 321, § 302","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1147"},"text":"35 Stat. 1147","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transposition of several words was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
