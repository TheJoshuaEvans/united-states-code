usc/t18/s212"},"text":"18 U.S.C. 212","children":[],"tail":", 1964 ed.)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “and upon conviction thereof” are omitted as unnecessary because punishment can be imposed only after conviction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9392d30-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9392d31-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $500”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
