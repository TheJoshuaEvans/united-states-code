{"tag":"section","attrib":{"id":"idb9c5dc9b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4050"},"text":null,"children":[{"tag":"num","attrib":{"value":"4050"},"text":"§ 4050.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secure firearms storage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9c5dc9c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4050/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c5dc9d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4050/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “employee” means a qualified law enforcement officer employed by the Bureau of Prisons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c5dc9e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4050/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “firearm” and “qualified law enforcement officer” have the meanings given those terms under section 926B.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c5dc9f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4050/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secure Firearms Storage","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Bureau of Prisons shall ensure that each chief executive officer of a Federal penal or correctional institution—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c5dca0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4050/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c5dca1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4050/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides a secure storage area located outside of the secure perimeter of the institution for employees to store firearms; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c5dca2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4050/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allows employees to store firearms in a vehicle lockbox approved by the Director of the Bureau of Prisons; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c5dca3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4050/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding any other provision of law, allows employees to carry concealed firearms on the premises outside of the secure perimeter of the institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9c5dca4-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/391/tII/s202/a"},"text":"Pub. L. 115–391, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5216"},"text":"132 Stat. 5216","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
