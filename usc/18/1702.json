{"tag":"section","attrib":{"id":"idb92d1f29-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1702"},"text":null,"children":[{"tag":"num","attrib":{"value":"1702"},"text":"§ 1702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obstruction of correspondence","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever takes any letter, postal card, or package out of any post office or any authorized depository for mail matter, or from any letter or mail carrier, or which has been in any post office or authorized depository, or in the custody of any letter or mail carrier, before it has been delivered to the person to whom it was directed, with design to obstruct the correspondence, or to pry into the business or secrets of another, or opens, secretes, embezzles, or destroys the same, shall be fined under this title or imprisoned not more than five years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb92d1f2a-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/778"},"text":"62 Stat. 778","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/I"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(I)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92d1f2b-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb92d1f2c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 317 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s194"},"text":"Mar. 4, 1909, ch. 321, § 194","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1125"},"text":"35 Stat. 1125","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1925-02-25/ch318"},"text":"Feb. 25, 1925, ch. 318","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/977"},"text":"43 Stat. 977","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-26/ch693"},"text":"Aug. 26, 1935, ch. 693","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/867"},"text":"49 Stat. 867","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1939-08-07/ch557"},"text":"Aug. 7, 1939, ch. 557","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1256"},"text":"53 Stat. 1256","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 317 of said title 18, U.S.C., 1940 ed., was incorporated in this and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1708"},"text":"section 1708 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92d1f2d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92d1f2e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted