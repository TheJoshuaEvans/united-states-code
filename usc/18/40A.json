{"tag":"section","attrib":{"id":"idb8a79b71-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s40A"},"text":null,"children":[{"tag":"num","attrib":{"value":"40A"},"text":"§ 40A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation of unauthorized unmanned aircraft over wildfires","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8a79b72-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s40A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), an individual who operates an unmanned aircraft and knowingly or recklessly interferes with a wildfire suppression, or law enforcement or emergency response efforts ","children":[{"tag":"ref","attrib":{"idref":"fn002015"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002015"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “effort”."}],"tail":" related to a wildfire suppression, shall be fined under this title, imprisoned for not more than 2 years, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a79b73-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s40A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not apply to the operation of an unmanned aircraft conducted by a unit or agency of the United States Government or of a State, tribal, or local government (including any individual conducting such operation pursuant to a contract or other agreement entered into with the unit or agency) for the purpose of protecting the public safety and welfare, including firefighting, law enforcement, or emergency response.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a79b74-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s40A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a79b75-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s40A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unmanned aircraft","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “unmanned aircraft” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44801"},"text":"section 44801 of title 49","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a79b76-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s40A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Wildfire","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “wildfire” has the meaning given that term in section 2 of the Emergency Wildfire Suppression Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1856m"},"text":"42 U.S.C. 1856m","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a79b77-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s40A/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Wildfire suppression","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “wildfire suppression” means an effort to contain, extinguish, or suppress a wildfire.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8a79b78-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tIII/s382/a"},"text":"Pub. L. 115–254, div. B, title III, § 382(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3320"},"text":"132 Stat. 3320","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
