{"tag":"section","attrib":{"id":"idb98ca3b6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3122"},"text":null,"children":[{"tag":"num","attrib":{"value":"3122"},"text":"§ 3122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for an order for a pen register or a trap and trace device","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb98ca3b7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb98ca3b8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3122/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An attorney for the Government may make application for an order or an extension of an order under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3123"},"text":"section 3123 of this title","children":[],"tail":" authorizing or approving the installation and use of a pen register or a trap and trace device under this chapter, in writing under oath or equivalent affirmation, to a court of competent jurisdiction."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb98ca3b9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3122/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Unless prohibited by State law, a State investigative or law enforcement officer may make application for an order or an extension of an order under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3123"},"text":"section 3123 of this title","children":[],"tail":" authorizing or approving the installation and use of a pen register or a trap and trace device under this chapter, in writing under oath or equivalent affirmation, to a court of competent jurisdiction of such State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb98ca3ba-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of Application","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application under subsection (a) of this section shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb98ca3bb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3122/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity of the attorney for the Government or the State law enforcement or investigative officer making the application and the identity of the law enforcement agency conducting the investigation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb98ca3bc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3122/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification by the applicant that the information likely to be obtained is relevant to an ongoing criminal investigation being conducted by that agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb98ca3bd-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/508/tIII/s301/a"},"text":"Pub. L. 99–508, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1869"},"text":"100 Stat. 1869","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb98ca3be-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb98ca3bf-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb98ca3c0-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", and, in case of conduct pursuant to court order or extension, applicable only with respect to court orders and extensions made after such date, with special rule for State authorizations of interceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/508/s302"},"text":"section 302 of Pub. L. 99–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3121"},"text":"section 3121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
