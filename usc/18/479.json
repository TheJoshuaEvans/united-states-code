{"tag":"section","attrib":{"id":"idb8cb77a5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s479"},"text":null,"children":[{"tag":"num","attrib":{"value":"479"},"text":"§ 479.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uttering counterfeit foreign obligations or securities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, within the United States, knowingly and with intent to defraud, utters, passes, or puts off, in payment or negotiation, any false, forged, or counterfeited bond, certificate, obligation, security, treasury note, bill, or promise to pay, mentioned in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s478"},"text":"section 478 of this title","children":[],"tail":", whether or not the same was made, altered, forged, or counterfeited within the United States, shall be fined under this title or imprisoned not more than 20 years, or both."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8cb77a6-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/707"},"text":"62 Stat. 707","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/J"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(J)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tIII/s375/b"},"text":"Pub. L. 107–56, title III, § 375(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/341"},"text":"115 Stat. 341","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8cb77a7-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8cb77a8-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 271 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s157"},"text":"Mar. 4, 1909, ch. 321, § 157","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1118"},"text":"35 Stat. 1118","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Mandatory punishment provision was rephrased in the alternative.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8cb77a9-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8cb77aa-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56"},"text":"Pub. L. 107–56","children":[],"tail":" substituted “20 years” for “three years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $3,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
