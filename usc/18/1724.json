{"tag":"section","attrib":{"id":"idb92f9056-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1724"},"text":null,"children":[{"tag":"num","attrib":{"value":"1724"},"text":"§ 1724.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Postage on mail delivered by foreign vessels","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided by treaty or convention the Postal Service may require the transportation by any steamship of mail between the United States and any foreign port at the compensation fixed under authority of law. Upon refusal by the master or the commander of such steamship or vessel to accept the mail, when tendered by the Postal Service or its representative, the collector or other officer of the port empowered to grant clearance, on notice of the refusal aforesaid, shall withhold clearance, until the collector or other officer of the port is informed by the Postal Service or its representative that the master or commander of the steamship or vessel has accepted the mail or that conveyance by his steamship or vessel is no longer required by the Postal Service.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb92f9057-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/784"},"text":"62 Stat. 784","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1951-09-25/ch413/s1/4"},"text":"Sept. 25, 1951, ch. 413, § 1(4)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/336"},"text":"65 Stat. 336","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s6/j/32"},"text":"Pub. L. 91–375, § 6(j)(32)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/780"},"text":"84 Stat. 780","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92f9058-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb92f9059-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 326 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s203"},"text":"Mar. 4, 1909, ch. 321, § 203","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1127"},"text":"35 Stat. 1127","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1929-02-06/ch157"},"text":"Feb. 6, 1929, ch. 157","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1153"},"text":"45 Stat. 1153","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92f905a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92f905b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":" substituted “Postal Service” and “Postal Service or its representative” for “Postmaster General” and “Postmaster General or his representative”, respectively, in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1951—Act ","children":[{"tag":"date","attrib":{"date":"1951-09-25"},"text":"Sept. 25, 1951","children":[],"tail":", repealed former first paragraph relating to penalties for failure to pay postage on or unlawful conveyance of mail to or from any part of the United States by foreign vessels."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb92f905c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb92f905d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":" effective within 1 year after "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", on date established therefor by Board of Governors of United States Postal Service and published by it in Federal Register, see "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as an Effective Date note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of Title 39","children":[],"tail":", Postal Service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
