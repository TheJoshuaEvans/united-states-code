{"tag":"section","attrib":{"id":"idb91c7d8e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365"},"text":null,"children":[{"tag":"num","attrib":{"value":"1365"},"text":"§ 1365.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tampering with consumer products","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb91c7d8f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whoever, with reckless disregard for the risk that another person will be placed in danger of death or bodily injury and under circumstances manifesting extreme indifference to such risk, tampers with any consumer product that affects interstate or foreign commerce, or the labeling of, or container for, any such product, or attempts to do so, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91c7d90-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an attempt, be fined under this title or imprisoned not more than ten years, or both;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91c7d91-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if death of an individual results, be fined under this title or imprisoned for any term of years or for life, or both;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91c7d92-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if serious bodily injury to any individual results, be fined under this title or imprisoned not more than twenty years, or both; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91c7d93-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any other case, be fined under this title or imprisoned not more than ten years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91c7d94-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever, with intent to cause serious injury to the business of any person, taints any consumer product or renders materially false or misleading the labeling of, or container for, a consumer product, if such consumer product affects interstate or foreign commerce, shall be fined under this title or imprisoned not more than three years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91c7d95-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91c7d96-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever knowingly communicates false information that a consumer product has been tainted, if such product or the results of such communication affect interstate or foreign commerce, and if such tainting, had it occurred, would create a risk of death or bodily injury to another person, shall be fined under this title or imprisoned not more than five years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91c7d97-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As used in paragraph (1) of this subsection, the term “communicates false information” means communicates information that is false and that the communicator knows is false, under circumstances in which the information may reasonably be expected to be believed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91c7d98-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever knowingly threatens, under circumstances in which the threat may reasonably be expected to be believed, that conduct that, if it occurred, would violate subsection (a) of this section will occur, shall be fined under this title or imprisoned not more than five years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91c7d99-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever is a party to a conspiracy of two or more persons to commit an offense under subsection (a) of this section, if any of the parties intentionally engages in any conduct in furtherance of such offense, shall be fined under this title or imprisoned not more than ten years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91c7d9a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91c7d9b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever, without the consent of the manufacturer, retailer, or distributor, intentionally tampers with a consumer product that is sold in interstate or foreign commerce by knowingly placing or inserting any writing in the consumer product, or in the container for the consumer product, before the sale of the consumer product to any consumer shall be fined under this title, imprisoned not more than 1 year, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91c7d9c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding the provisions of paragraph (1), if any person commits a violation of this subsection after a prior conviction under this section becomes final, such person shall be fined under this title, imprisoned for not more than 3 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91c7d9d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this subsection, the term “writing” means any form of representation or communication, including hand-bills, notices, or advertising, that contain letters, words, or pictorial representations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91c7d9e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to any other agency which has authority to investigate violations of this section, the Food and Drug Administration and the Department of Agriculture, respectively, have authority to investigate violations of this section involving a consumer product that is regulated by a provision of law such Administration or Department, as the case may be, administers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91c7d9f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91c7da0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “consumer product” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb91c7da1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any “food”, “drug”, “device”, or “cosmetic”, as those terms are respectively defined in section 201 of the Federal Food, Drug, and Cosmetic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s321"},"text":"21 U.S.C. 321","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91c7da2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any article, product, or commodity which is customarily produced or distributed for consumption by individuals, or use by individuals for purposes of personal care or in the performance of services ordinarily rendered within the household, and which is designed to be consumed or expended in the course of such consumption or use;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91c7da3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “labeling” has the meaning given such term in section 201(m) of the Federal Food, Drug, and Cosmetic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s321/m"},"text":"21 U.S.C. 321(m)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91c7da4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “serious bodily injury” means bodily injury which involves—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb91c7da5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a substantial risk of death;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91c7da6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extreme physical pain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91c7da7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/h/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protracted and obvious disfigurement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91c7da8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/h/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protracted loss or impairment of the function of a bodily member, organ, or mental faculty; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91c7da9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “bodily injury” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb91c7daa-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/h/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a cut, abrasion, bruise, burn, or disfigurement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91c7dab-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/h/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical pain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91c7dac-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/h/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" illness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91c7dad-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/h/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impairment of the function of a bodily member, organ, or mental faculty; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91c7dae-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1365/h/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other injury to the body, no matter how temporary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb91c7daf-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/127/s2"},"text":"Pub. L. 98–127, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-10-13"},"text":"Oct. 13, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/831"},"text":"97 Stat. 831","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXV/s3544"},"text":"Pub. L. 101–647, title XXXV, § 3544","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4926"},"text":"104 Stat. 4926","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/L"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(L)","children":[],"tail":", (O), (Q), (S), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":", 2148; "},{"tag":"ref","attrib":{"href":"/us/pl/107/307/s2"},"text":"Pub. L. 107–307, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2445"},"text":"116 Stat. 2445","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91c7db0-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb91c7db1-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb91c7db2-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 1365 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1366"},"text":"section 1366 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb91c7db3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsecs. (f) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/307"},"text":"Pub. L. 107–307","children":[],"tail":" added subsec. (f) and redesignated former subsecs. (f) and (g) as (g) and (h), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/1/O"},"text":"Pub. L. 103–322, § 330016(1)(O)","children":[],"tail":", substituted “fined under this title” for “fined not more than $25,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/1/S"},"text":"Pub. L. 103–322, § 330016(1)(S)","children":[],"tail":", substituted “fined under this title” for “fined not more than $100,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/1/Q"},"text":"Pub. L. 103–322, § 330016(1)(Q)","children":[],"tail":", substituted “fined under this title” for “fined not more than $50,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/1/L"},"text":"Pub. L. 103–322, § 330016(1)(L)","children":[],"tail":", substituted “fined under this title” for “fined not more than $10,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c)(1), (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/1/O"},"text":"Pub. L. 103–322, § 330016(1)(O)","children":[],"tail":", substituted “fined under this title” for “fined not more than $25,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (g)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":" inserted opening quotation marks before “device”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb91c7db4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb91c7db5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/307/s1"},"text":"Pub. L. 107–307, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2445"},"text":"116 Stat. 2445","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/307/s1"},"text":"“This Act [amending this section] may be cited as the ‘Product Packaging Protection Act of 2002’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idb91c7db6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/127/s1"},"text":"Pub. L. 98–127, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-10-13"},"text":"Oct. 13, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/831"},"text":"97 Stat. 831","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/127/s1"},"text":"“That this Act [enacting this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t35/s155A"},"text":"section 155A of Title 35","children":[],"tail":", Patents] may be cited as the ‘Federal Anti-Tampering Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
