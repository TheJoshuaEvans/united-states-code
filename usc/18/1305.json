{"tag":"section","attrib":{"id":"idb91a0cc4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1305"},"text":null,"children":[{"tag":"num","attrib":{"value":"1305"},"text":"§ 1305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fishing contests","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of this chapter shall not apply with respect to any fishing contest not conducted for profit wherein prizes are awarded for the specie, size, weight, or quality of fish caught by contestants in any bona fide fishing or recreational event.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb91a0cc5-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-08-16/ch722/s1"},"text":"Aug. 16, 1950, ch. 722, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/451"},"text":"64 Stat. 451","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
