{"tag":"section","attrib":{"id":"idb9a471cc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3526"},"text":null,"children":[{"tag":"num","attrib":{"value":"3526"},"text":"§ 3526.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation of other Federal agencies and State governments; reimbursement of expenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9a471cd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3526/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each Federal agency shall cooperate with the Attorney General in carrying out the provisions of this chapter and may provide, on a reimbursable basis, such personnel and services as the Attorney General may request in carrying out those provisions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9a471ce-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3526/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In any case in which a State government requests the Attorney General to provide protection to any person under this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9a471cf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3526/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General may enter into an agreement with that State government in which that government agrees to reimburse the United States for expenses incurred in providing protection to that person under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a471d0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3526/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General shall enter into an agreement with that State government in which that government agrees to cooperate with the Attorney General in carrying out the provisions of this chapter with respect to all persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9a471d1-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s1208"},"text":"Pub. L. 98–473, title II, § 1208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2162"},"text":"98 Stat. 2162","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9a471d2-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9a471d3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9a471d4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1984-10-01"},"text":"Oct. 1, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/s1210"},"text":"section 1210 of Pub. L. 98–473","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3521"},"text":"section 3521 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
