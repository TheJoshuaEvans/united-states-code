{"tag":"section","attrib":{"id":"idb92f9093-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1733"},"text":null,"children":[{"tag":"num","attrib":{"value":"1733"},"text":"§ 1733.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mailing periodical publications without prepayment of postage","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, except as permitted by law, knowingly mails any periodical publication without the prepayment of postage, or, being an officer or employee of the Postal Service, knowingly permits any periodical publication to be mailed without prepayment of postage, shall be fined under this title, or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb92f9094-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/682/s7"},"text":"Pub. L. 86–682, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-02"},"text":"Sept. 2, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/705"},"text":"74 Stat. 705","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s6/j/36/A"},"text":"Pub. L. 91–375, § 6(j)(36)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/780"},"text":"84 Stat. 780","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92f9095-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92f9096-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92f9097-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $1,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":" substituted “Mailing periodical publications without prepayment of postage” for “Affidavits relating to second class mail” as section catchline, struck out subsec. (a) penalty provision for fine of not more than $1,000 for each refusal to make affidavits relating to second class mail when tendering for mailing such mail without any affidavits, and reenacted subsec. (b) as the section without any subsection designation, inserting “, except as permitted by law,” and substituting “periodical publication” for “second class mail” in two places, “prepayment of postage” for “payment of postage” where first appearing, and “officer or employee of the Postal Service” for “postmaster or postal official”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb92f9098-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id"