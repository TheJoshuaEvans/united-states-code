{"tag":"section","attrib":{"id":"idb8d4ed65-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s647"},"text":null,"children":[{"tag":"num","attrib":{"value":"647"},"text":"§ 647.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receiving loan from court officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever knowingly receives, from a clerk or other officer of a court of the United States, as a deposit, loan, or otherwise, any money belonging in the registry of such court, is guilty of embezzlement, and shall be fined under this title or not more than the amount embezzled, whichever is greater, or imprisoned not more than ten years, or both; but if the amount embezzled does not exceed $1,000, he shall be fined under this title or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8d4ed66-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/727"},"text":"62 Stat. 727","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", (2)(G), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":", 2148; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s606/a"},"text":"Pub. L. 104–294, title VI, § 606(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3511"},"text":"110 Stat. 3511","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8d4ed67-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8d4ed68-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 187 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s100"},"text":"Mar. 4, 1909, ch. 321, § 100","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1107"},"text":"35 Stat. 1107","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The punishment provision of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s185"},"text":"section 185 of title 18","children":[],"tail":", U.S.C., 1940 ed., now "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s646"},"text":"section 646 of this title","children":[],"tail":", was substituted for the words “punished as prescribed in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s185"},"text":"section 185 of this title","children":[],"tail":"” and the smaller punishment for an offense involving $100 or less was inserted. (See reviser’s notes under sections 641 and 645 of this title.)"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8d4ed69-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8d4ed6a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" substituted “$1,000” for “$100”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/2/G"},"text":"Pub. L. 103–322, § 330016(2)(G)","children":[],"tail":", substituted “shall be fined under this title or not more than the amount embezzled, whichever is greater, or imprisoned” for “shall be fined not more than the amount embezzled or imprisoned”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/1/H"},"text":"Pub. L. 103–322, § 330016(1)(H)","children":[],"tail":", substituted “fined under this title” for “fined not more than $1,000” after “he shall be”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
