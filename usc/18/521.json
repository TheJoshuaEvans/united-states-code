{"tag":"section","attrib":{"id":"idb8d031e3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s521"},"text":null,"children":[{"tag":"num","attrib":{"value":"521"},"text":"§ 521.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal street gangs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8d031e4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s521/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions.—","children":[],"tail":null}],"tail":null},{"tag":"chapeau","attrib":{},"text":"“conviction” includes a finding, under State or Federal law, that a person has committed an act of juvenile delinquency involving a violent or controlled substances felony.","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"“criminal street gang” means an ongoing group, club, organization, or association of 5 or more persons—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8d031e5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s521/a/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has as 1 of its primary purposes the commission of 1 or more of the criminal offenses described in subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8d031e6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s521/a/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the members of which engage, or have engaged within the past 5 years, in a continuing series of offenses described in subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8d031e7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s521/a/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities of which affect interstate or foreign commerce.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"“State” means a State of the United States, the District of Columbia, and any commonwealth, territory, or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8d031e8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s521/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The sentence of a person convicted of an offense described in subsection (c) shall be increased by up to 10 years if the offense is committed under the circumstances described in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8d031e9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s521/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offenses","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The offenses described in this section are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8d031ea-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s521/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal felony involving a controlled substance (as defined in section 102 of the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"21 U.S.C. 802","children":[],"tail":")) for which the maximum penalty is not less than 5 years;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d031eb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s521/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal felony crime of violence that has as an element the use or attempted use of physical force against the person of another;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d031ec-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s521/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal offense involving human trafficking, sexual abuse, sexual exploitation, or transportation for prostitution or any illegal sexual activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d031ed-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s521/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a conspiracy to commit an offense described in paragraph (1), (2), or (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8d031ee-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s521/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Circumstances","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The circumstances described in this section are that the offense described in subsection (c) was committed by a person who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8d031ef-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s521/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participates in a criminal street gang with knowledge that its members engage in or have engaged in a continuing series of offenses described in subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d031f0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s521/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intends to promote or further the felonious activities of the criminal street gang or maintain or increase his or her position in the gang; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d031f1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s521/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has been convicted within the past 5 years for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8d031f2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s521/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an offense described in subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8d031f3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s521/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a State offense—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8d031f4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s521/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involving a controlled substance (as defined in section 102 of the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"21 U.S.C. 802","children":[],"tail":")) for which the maximum penalty is not less than 5 years’ imprisonment; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8d031f5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s521/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is a felony crime of violence that has as an element the use or attempted use of physical force against the person of another;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8d031f6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s521/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Federal or State felony offense that by its nature involves a substantial risk that physical force against the person of another may be used in the course of committing the offense; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8d031f7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s521/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a conspiracy to commit an offense described in subparagraph (A), (B), or (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8d031f8-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXV/s150001/a"},"text":"Pub. L. 103–322, title XV, § 150001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2034"},"text":"108 Stat. 2034","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s607/q"},"text":"Pub. L. 104–294, title VI, § 607(q)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3513"},"text":"110 Stat. 3513","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dB/tIV/s4002/b/3"},"text":"Pub. L. 107–273, div. B, title IV, § 4002(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1807"},"text":"116 Stat. 1807","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/392/s12"},"text":"Pub. L. 115–392, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5255"},"text":"132 Stat. 5255","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8d031f9-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8d031fa-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8d031fb-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/392"},"text":"Pub. L. 115–392","children":[],"tail":" added par. (3), redesignated former par. (3) as (4), and in par. (4), substituted “(1), (2), or (3)” for “(1) or (2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" realigned margins of par. defining “State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" inserted par. defining “State” at end."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
