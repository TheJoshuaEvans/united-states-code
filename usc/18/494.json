{"tag":"section","attrib":{"id":"idb8cdc0fa-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s494"},"text":null,"children":[{"tag":"num","attrib":{"value":"494"},"text":"§ 494.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contractors’ bonds, bids, and public records","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever falsely makes, alters, forges, or counterfeits any bond, bid, proposal, contract, guarantee, security, official bond, public record, affidavit, or other writing for the purpose of defrauding the United States; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever utters or publishes as true or possesses with intent to utter or publish as true, any such false, forged, altered, or counterfeited writing, knowing the same to be false, forged, altered, or counterfeited; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever transmits to, or presents at any office or to any officer of the United States, any such false, forged, altered, or counterfeited writing, knowing the same to be false, forged, altered, or counterfeited—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Shall be fined under this title or imprisoned not more than ten years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8cdc0fb-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/711"},"text":"62 Stat. 711","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8cdc0fc-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8cdc0fd-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 72 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s28"},"text":"Mar. 4, 1909, ch. 321, § 28","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1094"},"text":"35 Stat. 1094","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to persons causing, procuring, aiding or assisting was omitted as unnecessary as such persons are made principals by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were also made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8cdc0fe-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8cdc0ff-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $1,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
