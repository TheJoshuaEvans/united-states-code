{"tag":"section","attrib":{"id":"idb8d031bd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s513"},"text":null,"children":[{"tag":"num","attrib":{"value":"513"},"text":"§ 513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Securities of the States and private entities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8d031be-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s513/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever makes, utters or possesses a counterfeited security of a State or a political subdivision thereof or of an organization, or whoever makes, utters or possesses a forged security of a State or political subdivision thereof or of an organization, with intent to deceive another person, organization, or government shall be fined under this title ","children":[{"tag":"ref","attrib":{"idref":"fn002047"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002047"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See 1994 Amendment note below."}],"tail":" or imprisoned for not more than ten years, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8d031bf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s513/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever makes, receives, possesses, sells or otherwise transfers an implement designed for or particularly suited for making a counterfeit or forged security with the intent that it be so used shall be punished by a fine under this title or by imprisonment for not more than ten years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8d031c0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s513/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8d031c1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s513/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “counterfeited” means a document that purports to be genuine but is not, because it has been falsely made or manufactured in its entirety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d031c2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s513/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “forged” means a document that purports to be genuine but is not because it has been falsely altered, com­pleted, signed, or endorsed, or contains a false addition thereto or insertion therein, or is a combination of parts of two or more genuine documents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d031c3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s513/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “security” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8d031c4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s513/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a note, stock certificate, treasury stock certificate, bond, treasury bond, debenture, certificate of deposit, interest coupon, bill, check, draft, warrant, debit instrument as defined in section 916(c) ","children":[{"tag":"ref","attrib":{"idref":"fn002048"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002048"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of the Electronic Fund Transfer Act, money order, traveler’s check, letter of credit, warehouse receipt, negotiable bill of lading, evidence of indebtedness, certificate of interest in or participation in any profit-sharing agreement, collateral-trust certificate, pre-reorganization certificate of subscription, transferable share, investment contract, voting trust certificate, or certificate of interest in tangible or intangible property;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8d031c5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s513/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an instrument evidencing ownership of goods, wares, or merchandise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8d031c6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s513/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other written instrument commonly known as a security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8d031c7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s513/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certificate of interest in, certificate of participation in, certificate for, receipt for, or warrant or option or other right to subscribe to or purchase, any of the foregoing; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8d031c8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s513/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a blank form of any of the foregoing;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d031c9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s513/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “organization” means a legal entity, other than a government, established or organized for any purpose, and includes a corporation, company, association, firm, partnership, joint stock company, foundation, institution, society, union, or any other association of persons which operates in or the activities of which affect interstate or foreign commerce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d031ca-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s513/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” includes a State of the United States, the District of Columbia, Puerto Rico, Guam, the Virgin Islands, and any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8d031cb-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s1105/a"},"text":"Pub. L. 98–473, title II, § 1105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2144"},"text":"98 Stat. 2144","children":[],"tail":", § 511; renumbered § 513, "},{"tag":"ref","attrib":{"href":"/us/pl/99/646/s31/a"},"text":"Pub. L. 99–646, § 31(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3598"},"text":"100 Stat. 3598","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXV/s3515"},"text":"Pub. L. 101–647, title XXXV, § 3515","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4923"},"text":"104 Stat. 4923","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII"},"text":"Pub. L. 103–322, title XXXIII","children":[],"tail":", §§ 330008(1), 330016(2)(C), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2142"},"text":"108 Stat. 2142","children":[],"tail":", 2148.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8d031cc-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8d031cd-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8d031ce-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 916 of the Electronic Fund Transfer Act, referred to in subsec. (c)(3)(A), was renumbered section 917 by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/24/tIV/s401/1"},"text":"Pub. L. 111–24, title IV, § 401(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1751"},"text":"123 Stat. 1751","children":[],"tail":", and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1693n"},"text":"section 1693n of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8d031cf-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/2/C"},"text":"Pub. L. 103–322, § 330016(2)(C)","children":[],"tail":", which directed the amendment of this section by substituting “under this title” for “of not more than $250,000”, was executed by making the substitution for “not more than $250,000”, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/2/C"},"text":"Pub. L. 103–322, § 330016(2)(C)","children":[],"tail":", substituted “fine under this title” for “fine of not more than $250,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330008/1"},"text":"Pub. L. 103–322, § 330008(1)","children":[],"tail":", substituted “association of persons” for “association or persons”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (c)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":" struck out “("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1693/c"},"text":"15 U.S.C. 1693(c)","children":[],"tail":")” after “Electronic Fund Transfer Act” and inserted comma after “profit-sharing agreement”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
