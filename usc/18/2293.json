{"tag":"section","attrib":{"id":"idb95a7137-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2293"},"text":null,"children":[{"tag":"num","attrib":{"value":"2293"},"text":"§ 2293.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bar to prosecution","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb95a7138-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2293/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is a bar to prosecution under this chapter if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95a7139-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2293/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct in question occurred within the United States in relation to a labor dispute, and such conduct is prohibited as a felony under the law of the State in which it was committed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95a713a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2293/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such conduct is prohibited as a misdemeanor, and not as a felony, under the law of the State in which it was committed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95a713b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2293/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95a713c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2293/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Labor dispute","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “labor dispute” has the same meaning given that term in section 13(c) of the Act to amend the Judicial Code and to define and limit the jurisdiction of courts sitting in equity, and for other purposes (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s113/c"},"text":"29 U.S.C. 113(c)","children":[],"tail":", commonly known as the Norris-LaGuardia Act)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95a713d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2293/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “State” means a State of the United States, the District of Columbia, and any commonwealth, territory, or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb95a713e-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/tIII/s306/a"},"text":"Pub. L. 109–177, title III, § 306(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/239"},"text":"120 Stat. 239","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
