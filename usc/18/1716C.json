{"tag":"section","attrib":{"id":"idb92f8fc6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1716C"},"text":null,"children":[{"tag":"num","attrib":{"value":"1716C"},"text":"§ 1716C.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forged agricultural certifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever forges or counterfeits any certification authorized under any rules or regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3014/c"},"text":"section 3014(c) of title 39","children":[],"tail":" with intent to make it appear that such is a genuine certification, or makes or knowingly uses or sells, or possesses with intent to use or sell, any forged or counterfeited certification so authorized, or device for imprinting any such certification, shall be fined under this title, or imprisoned not more than one year, or both."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb92f8fc7-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/574/s2/a"},"text":"Pub. L. 100–574, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2893"},"text":"102 Stat. 2893","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92f8fc8-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb92f8fc9-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb92f8fca-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1989-10-31"},"text":"Oct. 31, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/574/s4"},"text":"section 4 of Pub. L. 100–574","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s3014"},"text":"section 3014 of Title 39","children":[],"tail":", Postal Service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
