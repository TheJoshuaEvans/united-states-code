{"tag":"section","attrib":{"id":"idb9640d99-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332g"},"text":null,"children":[{"tag":"num","attrib":{"value":"2332g"},"text":"§ 2332g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Missile systems designed to destroy aircraft","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9640d9a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unlawful Conduct.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9640d9b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (3), it shall be unlawful for any person to knowingly produce, construct, otherwise acquire, transfer directly or indirectly, receive, possess, import, export, or use, or possess and threaten to use—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9640d9c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332g/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an explosive or incendiary rocket or missile that is guided by any system designed to enable the rocket or missile to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9640d9d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332g/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek or proceed toward energy radiated or reflected from an aircraft or toward an image locating an aircraft; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9640d9e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332g/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise direct or guide the rocket or missile to an aircraft;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9640d9f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332g/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any device designed or intended to launch or guide a rocket or missile described in subparagraph (A); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9640da0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332g/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any part or combination of parts designed or redesigned for use in assembling or fabricating a rocket, missile, or device described in subparagraph (A) or (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9640da1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonweapon","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1)(A) does not apply to any device that is neither designed nor redesigned for use as a weapon.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9640da2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332g/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Excluded conduct","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection does not apply with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9640da3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332g/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct by or under the authority of the United States or any department or agency thereof or of a State or any department or agency thereof; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9640da4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332g/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct pursuant to the terms of a contract with the United States or any department or agency thereof or with a State or any department or agency thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9640da5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Conduct prohibited by subsection (a) is within the jurisdiction of the United States if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9640da6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense occurs in or affects interstate or foreign commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9640da7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense occurs outside of the United States and is committed by a national of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9640da8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332g/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense is committed against a national of the United States while the national is outside the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9640da9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332g/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense is committed against any property that is owned, leased, or used by the United States or by any department or agency of the United States, whether the property is within or outside the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9640daa-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332g/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an offender aids or abets any person over whom jurisdiction exists under this subsection in committing an offense under this section or conspires with any person over whom jurisdiction exists under this subsection to commit an offense under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9640dab-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criminal Penalties.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9640dac-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332g/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person who violates, or attempts or conspires to violate, subsection (a) shall be fined not more than $2,000,000 and shall be sentenced to a term of imprisonment not less than 25 years or to imprisonment for life.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9640dad-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332g/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other circumstances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person who, in the course of a violation of subsection (a), uses, attempts or conspires to use, or possesses and threatens to use, any item or items described in subsection (a), shall be fined not more than $2,000,000 and imprisoned for not less than 30 years or imprisoned for life.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9640dae-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332g/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special circumstances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the death of another results from a person’s violation of subsection (a), the person shall be fined not more than $2,000,000 and punished by imprisonment for life.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9640daf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As used in this section, the term “aircraft” has the definition set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s40102/a/6"},"text":"section 40102(a)(6) of title 49","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9640db0-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/tVI/s6903"},"text":"Pub. L. 108–458, title VI, § 6903","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3770"},"text":"118 Stat. 3770","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
