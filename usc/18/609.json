{"tag":"section","attrib":{"id":"idb8d4ed0c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s609"},"text":null,"children":[{"tag":"num","attrib":{"value":"609"},"text":"§ 609.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of military authority to influence vote of member of Armed Forces","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being a commissioned, noncommissioned, warrant, or petty officer of an Armed Force, uses military authority to influence the vote of a member of the Armed Forces or to require a member of the Armed Forces to march to a polling place, or attempts to do so, shall be fined in accordance with this title or imprisoned not more than five years, or both. Nothing in this section shall prohibit free discussion of political issues or candidates for public office.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8d4ed0d-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/410/tII/s202/a"},"text":"Pub. L. 99–410, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-28"},"text":"Aug. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/929"},"text":"100 Stat. 929","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8d4ed0e-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8d4ed0f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb8d4ed10-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 609, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"act June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/723"},"text":"62 Stat. 723","children":[],"tail":", prescribed maximum contributions and expenditures limitation of $3,000,000 for any calendar year, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/92/225/tII/s204"},"text":"Pub. L. 92–225, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-02-07"},"text":"Feb. 7, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/10"},"text":"86 Stat. 10","children":[],"tail":", effective sixty days after "},{"tag":"date","attrib":{"date":"1972-02-07"},"text":"Feb. 7, 1972","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8d4ed11-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8d4ed12-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to elections taking place after ","children":[{"tag":"date","attrib":{"date":"1987-12-31"},"text":"Dec. 31, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/410/s204"},"text":"section 204 of Pub. L. 99–410","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s20301"},"text":"section 20301 of Title 52","children":[],"tail":", Voting and Elections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
