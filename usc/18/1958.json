{"tag":"section","attrib":{"id":"idb93de80b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1958"},"text":null,"children":[{"tag":"num","attrib":{"value":"1958"},"text":"§ 1958.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of interstate commerce facilities in the commission of murder-for-hire","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb93de80c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1958/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever travels in or causes another (including the intended victim) to travel in interstate or foreign commerce, or uses or causes another (including the intended victim) to use the mail or any facility of interstate or foreign commerce, with intent that a murder be committed in violation of the laws of any State or the United States as consideration for the receipt of, or as consideration for a promise or agreement to pay, anything of pecuniary value, or who conspires to do so, shall be fined under this title or imprisoned for not more than ten years, or both; and if personal injury results, shall be fined under this title or imprisoned for not more than twenty years, or both; and if death results, shall be punished by death or life imprisonment, or shall be fined not more than $250,000, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb93de80d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1958/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in this section and section 1959—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb93de80e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1958/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “anything of pecuniary value” means anything of value in the form of money, a negotiable instrument, a commercial interest, or anything else the primary significance of which is economic advantage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb93de80f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1958/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “facility of interstate or foreign commerce” includes means of transportation and communication; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb93de810-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1958/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” includes a State of the United States, the District of Columbia, and any commonwealth, territory, or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb93de811-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s1002/a"},"text":"Pub. L. 98–473, title II, § 1002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2136"},"text":"98 Stat. 2136","children":[],"tail":", § 1952A; renumbered § 1958 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII"},"text":"Pub. L. 100–690, title VII","children":[],"tail":", §§ 7053(a), 7058(b), "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4402"},"text":"102 Stat. 4402","children":[],"tail":", 4403; "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXII/s1205/k"},"text":"Pub. L. 101–647, title XII, § 1205(k)","children":[],"tail":", title XXXV, § 3558, "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4831"},"text":"104 Stat. 4831","children":[],"tail":", 4927; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tVI/s60003/a/11"},"text":"Pub. L. 103–322, title VI, § 60003(a)(11)","children":[],"tail":", title XIV, § 140007(b), title XXXII, § 320105, title XXXIII, § 330016(1)(L), (N), (Q), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1969"},"text":"108 Stat. 1969","children":[],"tail":", 2033, 2111, 2147, 2148; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI"},"text":"Pub. L. 104–294, title VI","children":[],"tail":", §§ 601(g)(3), 605(a), "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3500"},"text":"110 Stat. 3500","children":[],"tail":", 3509; "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tVI/s6704"},"text":"Pub. L. 108–458, title VI, § 6704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3766"},"text":"118 Stat. 3766","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb93de812-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb93de813-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb93de814-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s6704/1"},"text":"Pub. L. 108–458, § 6704(1)","children":[],"tail":", substituted “facility of” for “facility in”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s6704/2"},"text":"Pub. L. 108–458, § 6704(2)","children":[],"tail":", inserted “or foreign” after “interstate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" substituted comma for “or who conspires to do so” after “or who conspires to do so” and substituted “this title or imprisoned” for “this title and imprisoned” before “for not more than twenty years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/1/Q"},"text":"Pub. L. 103–322, § 330016(1)(Q)","children":[],"tail":", which directed the amendment of this section by substituting “under this title” for “not more than $50,000”, could not be executed because the phrase “not more than $50,000” did not appear in text subsequent to amendment of subsec. (a) by "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/s60003/a/11"},"text":"Pub. L. 103–322, § 60003(a)(11)","children":[],"tail":". See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/1/N"},"text":"Pub. L. 103–322, § 330016(1)(N)","children":[],"tail":", substituted “fined under this title” for “fined not more than $20,000” after “injury results, shall be”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/1/L"},"text":"Pub. L. 103–322, § 330016(1)(L)","children":[],"tail":", substituted “fined under this title” for “fined not more than $10,000” before “or imprisoned for not more than ten years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":", §§ 140007(b), 320105, each amended subsec. (a) by inserting “or who conspires to do so” after “anything of pecuniary value,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s60003/a/11"},"text":"Pub. L. 103–322, § 60003(a)(11)","children":[],"tail":", substituted “and if death results, shall be punished by death or life imprisonment, or shall be fined not more than $250,000, or both” for “and if death results, shall be subject to imprisonment for any term of years or for life, or shall be fined not more than $50,000, or both” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/s3558"},"text":"Pub. L. 101–647, § 3558","children":[],"tail":", substituted “section 1959” for “section 1952B” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/s1205/k"},"text":"Pub. L. 101–647, § 1205(k)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7053/a"},"text":"Pub. L. 100–690, § 7053(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1952A"},"text":"section 1952A of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7058/b"},"text":"Pub. L. 100–690, § 7058(b)","children":[],"tail":", substituted “ten years” for “five years”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
