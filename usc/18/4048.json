{"tag":"section","attrib":{"id":"idb9c5dc5e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048"},"text":null,"children":[{"tag":"num","attrib":{"value":"4048"},"text":"§ 4048.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees for health care services for prisoners","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9c5dc5f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c5dc60-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “account” means the trust fund account (or institutional equivalent) of a prisoner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c5dc61-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Director” means the Director of the Bureau of Prisons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c5dc62-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “health care provider” means any person who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c5dc63-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorized by the Director to provide health care services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c5dc64-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operating within the scope of such authorization;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c5dc65-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “health care visit”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c5dc66-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a visit, as determined by the Director, by a prisoner to an institutional or noninstitutional health care provider; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c5dc67-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include a visit initiated by a prisoner—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9c5dc68-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to a staff referral; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9c5dc69-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain staff-approved follow-up treatment for a chronic condition; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c5dc6a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “prisoner” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c5dc6b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual who is incarcerated in an institution under the jurisdiction of the Bureau of Prisons; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c5dc6c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other individual, as designated by the Director, who has been charged with or convicted of an offense against the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c5dc6d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fees for Health Care Services.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c5dc6e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director, in accordance with this section and with such regulations as the Director shall promulgate to carry out this section, may assess and collect a fee for health care services provided in connection with each health care visit requested by a prisoner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c5dc6f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director may not assess or collect a fee under this section for preventative health care services, emergency services, prenatal care, diagnosis or treatment of chronic infectious diseases, mental health care, or substance abuse treatment, as determined by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c5dc70-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Persons Subject to Fee","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each fee assessed under this section shall be collected by the Director from the account of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c5dc71-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prisoner receiving health care services in connection with a health care visit described in subsection (b)(1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c5dc72-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of health care services provided in connection with a health care visit described in subsection (b)(1) that results from an injury inflicted on a prisoner by another prisoner, the prisoner who inflicted the injury, as determined by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c5dc73-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of Fee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any fee assessed and collected under this section shall be in an amount of not less than $1.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c5dc74-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Consent Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, the consent of a prisoner shall not be required for the collection of a fee from the account of the prisoner under this section. However, each such prisoner shall be given a reasonable opportunity to dispute the amount of the fee or whether the prisoner qualifies under an exclusion under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c5dc75-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Refusal of Treatment For Financial Reasons","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section may be construed to permit any refusal of treatment to a prisoner on the basis that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c5dc76-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the account of the prisoner is insolvent; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c5dc77-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prisoner is otherwise unable to pay a fee assessed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c5dc78-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Amounts.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c5dc79-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restitution of specific victims","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts collected by the Director under this section from a prisoner subject to an order of restitution issued pursuant to section 3663 or 3663A shall be paid to victims in accordance with the order of restitution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c5dc7a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allocation of other amounts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of amounts collected by the Director under this section from prisoners not subject to an order of restitution issued pursuant to section 3663 or 3663A—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c5dc7b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 75 percent shall be deposited in the Crime Victims Fund established under section 1402 of the Victims of Crime Act of 1984 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10601"},"text":"42 U.S.C. 10601","children":[],"tail":"); "},{"tag":"ref","attrib":{"idref":"fn002279"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002279"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c5dc7c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 25 percent shall be available to the Attorney General for administrative expenses incurred in carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c5dc7d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice to Prisoners of Law","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each person who is or becomes a prisoner shall be provided with written and oral notices of the provisions of this section and the applicability of this section to the prisoner. Notwithstanding any other provision of this section, a fee under this section may not be assessed against, or collected from, such person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c5dc7e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" until the expiration of the 30-day period beginning on the date on which each prisoner in the prison system is provided with such notices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c5dc7f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for services provided before the expiration of such period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c5dc80-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice to Prisoners of Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The regulations promulgated by the Director under subsection (b)(1), and any amendments to those regulations, shall not take effect until the expiration of the 30-day period beginning on the date on which each prisoner in the prison system is provided with written and oral notices of the provisions of those regulations (or amendments, as the case may be). A fee under this section may not be assessed against, or collected from, a prisoner pursuant to such regulations (or amendments, as the case may be) for services provided before the expiration of such period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c5dc81-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice Before Public Comment Period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before the beginning of any period a proposed regulation under this section is open to public comment, the Director shall provide written and oral notice of the provisions of that proposed regulation to groups that advocate on behalf of Federal prisoners and to each prisoner subject to such proposed regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c5dc82-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of the enactment of the Federal Prisoner Health Care Copayment Act of 2000, and annually thereafter, the Director shall transmit to Congress a report, which shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c5dc83-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the amounts collected under this section during the preceding 12-month period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c5dc84-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the effects of the implementation of this section, if any, on the nature and extent of heath care visits by prisoners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c5dc85-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/k/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an itemization of the cost of implementing and administering the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c5dc86-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/k/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of current inmate health status indicators as compared to the year prior to enactment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c5dc87-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/k/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the quality of health care services provided to inmates during the preceding 12-month period, as compared with the quality of those services provided during the 12-month period ending on the date of the enactment of such Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c5dc88-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4048/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Comprehensive HIV/AIDS Services Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Bureau of Prisons shall provide comprehensive coverage for services relating to human immunodeficiency virus (HIV) and acquired immune deficiency syndrome (AIDS) to each Federal prisoner in the custody of the Bureau of Prisons when medically appropriate. The Bureau of Prisons may not assess or collect a fee under this section for providing such coverage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9c5dc89-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/294/s2/a"},"text":"Pub. L. 106–294, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-12"},"text":"Oct. 12, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1038"},"text":"114 Stat. 1038","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9c5dc8a-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9c5dc8b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9c5dc8c-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1402 of the Victims of Crime Act of 1984, referred to in subsec. (g)(2)(A), is section 1402 of chapter XIV of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10601"},"text":"section 10601 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification as "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s20101"},"text":"section 20101 of Title 34","children":[],"tail":", Crime Control and Law Enforcement."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of the enactment of the Federal Prisoner Health Care Copayment Act of 2000, referred to in subsec. (k), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/294"},"text":"Pub. L. 106–294","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2000-10-12"},"text":"Oct. 12, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
