{"tag":"section","attrib":{"id":"idb904b088-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s985"},"text":null,"children":[{"tag":"num","attrib":{"value":"985"},"text":"§ 985.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil forfeiture of real property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb904b089-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s985/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, all civil forfeitures of real property and interests in real property shall proceed as judicial forfeitures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb904b08a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s985/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb904b08b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s985/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb904b08c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s985/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" real property that is the subject of a civil forfeiture action shall not be seized before entry of an order of forfeiture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb904b08d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s985/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owners or occupants of the real property shall not be evicted from, or otherwise deprived of the use and enjoyment of, real property that is the subject of a pending forfeiture action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb904b08e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s985/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The filing of a lis pendens and the execution of a writ of entry for the purpose of conducting an inspection and inventory of the property shall not be considered a seizure under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb904b08f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s985/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb904b090-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s985/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Government shall initiate a civil forfeiture action against real property by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb904b091-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s985/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" filing a complaint for forfeiture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb904b092-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s985/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" posting a notice of the complaint on the property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb904b093-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s985/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serving notice on the property owner, along with a copy of the complaint.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb904b094-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s985/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the property owner cannot be served with the notice under paragraph (1) because the owner—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb904b095-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s985/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a fugitive;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb904b096-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s985/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resides outside the United States and efforts at service pursuant to rule 4 of the Federal Rules of Civil Procedure are unavailing; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb904b097-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s985/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cannot be located despite the exercise of due diligence,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"constructive service may be made in accordance with the laws of the State in which the property is located.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb904b098-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s985/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If real property has been posted in accordance with this subsection, it shall not be necessary for the court to issue an arrest warrant in rem, or to take any other action to establish in rem jurisdiction over the property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb904b099-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s985/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb904b09a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s985/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Real property may be seized prior to the entry of an order of forfeiture if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb904b09b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s985/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Government notifies the court that it intends to seize the property before trial; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb904b09c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s985/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the court—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb904b09d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s985/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issues a notice of application for warrant, causes the notice to be served on the property owner and posted on the property, and conducts a hearing in which the property owner has a meaningful opportunity to be heard; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb904b09e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s985/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes an ex parte determination that there is probable cause for the forfeiture and that there are exigent circumstances that permit the Government to seize the property without prior notice and an opportunity for the property owner to be heard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb904b09f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s985/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of paragraph (1)(B)(ii), to establish exigent circumstances, the Government shall show that less restrictive measures such as a lis pendens, restraining order, or bond would not suffice to protect the Government’s interests in preventing the sale, destruction, or continued unlawful use of the real property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb906f990-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s985/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the court authorizes a seizure of real property under subsection (d)(1)(B)(ii), it shall conduct a prompt post-seizure hearing during which the property owner shall have an opportunity to contest the basis for the seizure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb906f991-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s985/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb906f992-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s985/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applies only to civil forfeitures of real property and interests in real property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb906f993-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s985/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not apply to forfeitures of the proceeds of the sale of such property or interests, or of money or other assets intended to be used to acquire such property or interests; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb906f994-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s985/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not affect the authority of the court to enter a restraining order relating to real property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb906f995-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/185/s7/a"},"text":"Pub. L. 106–185, § 7(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-25"},"text":"Apr. 25, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/214"},"text":"114 Stat. 214","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb906f996-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb906f997-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb906f998-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Civil Procedure, referred to in subsec. (c)(2)(B), are set out in the Appendix to Title 28, Judiciary and Judicial Procedure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb906f999-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb906f99a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to any forfeiture proceeding commenced on or after the date that is 120 days after ","children":[{"tag":"date","attrib":{"date":"2000-04-25"},"text":"Apr. 25, 2000","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/185/s21"},"text":"section 21 of Pub. L. 106–185","children":[],"tail":", set out as an Effective Date of 2000 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1324"},"text":"section 1324 of Title 8","children":[],"tail":", Aliens and Nationality."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
