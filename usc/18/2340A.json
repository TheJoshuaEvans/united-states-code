{"tag":"section","attrib":{"id":"idb96b391f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2340A"},"text":null,"children":[{"tag":"num","attrib":{"value":"2340A"},"text":"§ 2340A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Torture","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb96b3920-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2340A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offense","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever outside the United States commits or attempts to commit torture shall be fined under this title or imprisoned not more than 20 years, or both, and if death results to any person from conduct prohibited by this subsection, shall be punished by death or imprisoned for any term of years or for life.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96b3921-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2340A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is jurisdiction over the activity prohibited in subsection (a) if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96b3922-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2340A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the alleged offender is a national of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96b3923-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2340A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the alleged offender is present in the United States, irrespective of the nationality of the victim or alleged offender.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96b3924-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2340A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conspiracy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person who conspires to commit an offense under this section shall be subject to the same penalties (other than the penalty of death) as the penalties prescribed for the offense, the commission of which was the object of the conspiracy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb96b3925-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tV/s506/a"},"text":"Pub. L. 103–236, title V, § 506(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/463"},"text":"108 Stat. 463","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tVI/s60020"},"text":"Pub. L. 103–322, title VI, § 60020","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1979"},"text":"108 Stat. 1979","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tVIII/s811/g"},"text":"Pub. L. 107–56, title VIII, § 811(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/381"},"text":"115 Stat. 381","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb96b3926-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb96b3927-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb96b3928-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56"},"text":"Pub. L. 107–56","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" inserted “punished by death or” before “imprisoned for any term of years or for life”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb96b3929-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb96b392a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the later of ","children":[{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", or the date on which the United States has become a party to the Convention Against Torture and Other Cruel, Inhuman or Degrading Treatment or Punishment ("},{"tag":"date","attrib":{"date":"1994-11-20"},"text":"Nov. 20, 1994","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/s506/c"},"text":"section 506(c) of Pub. L. 103–236","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2340"},"text":"section 2340 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
