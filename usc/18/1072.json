{"tag":"section","attrib":{"id":"idb910976a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1072"},"text":null,"children":[{"tag":"num","attrib":{"value":"1072"},"text":"§ 1072.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concealing escaped prisoner","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever willfully harbors or conceals any prisoner after his escape from the custody of the Attorney General or from a Federal penal or correctional institution, shall be imprisoned not more than three years.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb910976b-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/755"},"text":"62 Stat. 755","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb910976c-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb910976d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., §§ 753i, 910 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-05-14/ch274/s10"},"text":"May 14, 1930, ch. 274, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/327"},"text":"46 Stat. 327","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1930-05-27/ch339/s10"},"text":"May 27, 1930, ch. 339, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/390"},"text":"46 Stat. 390","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section consolidates similar language of said sections of title 18, U.S.C., 1940 ed. Remaining provisions are in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s752"},"text":"section 752 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “willfully harbors” were added in conformity with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1071"},"text":"section 1071 of this title","children":[],"tail":". Punishment for harboring violators of the Espionage laws is provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s792"},"text":"section 792 of this title","children":[],"tail":". Punishment for harboring deserters from the armed forces is provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1381"},"text":"section 1381 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
