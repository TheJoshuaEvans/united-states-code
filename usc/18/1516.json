{"tag":"section","attrib":{"id":"idb9261a50-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1516"},"text":null,"children":[{"tag":"num","attrib":{"value":"1516"},"text":"§ 1516.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obstruction of Federal audit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9261a51-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1516/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever, with intent to deceive or defraud the United States, endeavors to influence, obstruct, or impede a Federal auditor in the performance of official duties relating to a person, entity, or program receiving in excess of $100,000, directly or indirectly, from the United States in any 1 year period under a contract or subcontract, grant, or cooperative agreement, or relating to any property that is security for a mortgage note that is insured, guaranteed, acquired, or held by the Secretary of Housing and Urban Development pursuant to any Act administered by the Secretary, or relating to any property that is security for a loan that is made or guaranteed under title V of the Housing Act of 1949, shall be fined under this title, or imprisoned not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9261a52-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1516/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9261a53-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1516/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Federal auditor” means any person employed on a full- or part-time or contractual basis to perform an audit or a quality assurance inspection for or on behalf of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9261a54-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1516/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “in any 1 year period” has the meaning given to the term “in any one-year period” in section 666.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9261a55-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7078/a"},"text":"Pub. L. 100–690, title VII, § 7078(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4406"},"text":"102 Stat. 4406","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXII/s320609"},"text":"Pub. L. 103–322, title XXXII, § 320609","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2120"},"text":"108 Stat. 2120","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s604/b/43"},"text":"Pub. L. 104–294, title VI, § 604(b)(43)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3509"},"text":"110 Stat. 3509","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/65/tV/s564"},"text":"Pub. L. 105–65, title V, § 564","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-10-27"},"text":"Oct. 27, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1420"},"text":"111 Sta