{"tag":"section","attrib":{"id":"idb91a0c9c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1265"},"text":null,"children":[{"tag":"num","attrib":{"value":"1265"},"text":"§ 1265.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" C.O.D. shipments prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any railroad or express company, or other common carrier which, or any person who, in connection with the transportation of any spirituous, vinous, malted, or other fermented liquor, or any compound containing any spirituous, vinous, malted, or other fermented liquor fit for use for beverage purposes, into any State, Territory, District or Possession of the United States, which prohibits the delivery or sale therein of such liquor, collects the purchase price or any part thereof, before, on, or after delivery, from the consignee, or from any other person, or in any manner acts as the agent of the buyer or seller of any such liquor, for the purpose of buying or selling or completing the sale thereof, saving only in the actual transportation and delivery of the same, shall be fined under this title or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb91a0c9d-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/762"},"text":"62 Stat. 762","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91a0c9e-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb91a0c9f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 389 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s239"},"text":"Mar. 4, 1909, ch. 321, § 239","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1136"},"text":"35 Stat. 1136","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-25/ch815/s7"},"text":"June 25, 1936, ch. 815, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1929"},"text":"49 Stat. 1929","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes similar to those made in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1264"},"text":"section 1264 of this title","children":[],"tail":" were also made in this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb91a0ca0-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb91a0ca1-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $5,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
