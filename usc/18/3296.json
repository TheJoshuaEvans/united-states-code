{"tag":"section","attrib":{"id":"idb99ad4d0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3296"},"text":null,"children":[{"tag":"num","attrib":{"value":"3296"},"text":"§ 3296.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counts dismissed pursuant to a plea agreement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb99ad4d1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3296/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this chapter, any counts of an indictment or information that are dismissed pursuant to a plea agreement shall be reinstated by the District Court if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb99ad4d2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3296/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the counts sought to be reinstated were originally filed within the applicable limitations period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb99ad4d3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3296/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the counts were dismissed pursuant to a plea agreement approved by the District Court under which the defendant pled guilty to other charges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb99ad4d4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3296/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the guilty plea was subsequently vacated on the motion of the defendant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb99ad4d5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3296/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States moves to reinstate the dismissed counts within 60 days of the date on which the order vacating the plea becomes final.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb99ad4d6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3296/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defenses; Objections","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall preclude the District Court from considering any defense or objection, other than statute of limitations, to the prosecution of the counts reinstated under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb99ad4d7-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/dB/tIII/s3003/a"},"text":"Pub. L. 107–273, div. B, title III, § 3003(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1805"},"text":"116 Stat. 1805","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
