{"tag":"section","attrib":{"id":"idb9915ef0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3151"},"text":null,"children":[{"tag":"num","attrib":{"value":"3151"},"text":"§ 3151.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refund of forfeited bail","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Appropriations available to refund money erroneously received and deposited in the Treasury are available to refund any part of forfeited bail deposited into the Treasury and ordered remitted under the Federal Rules of Criminal Procedure.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9915ef1-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7084/a"},"text":"Pub. L. 100–690, title VII, § 7084(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4408"},"text":"102 Stat. 4408","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9915ef2-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9915ef3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9915ef4-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Criminal Procedure, referred to in text, are set out in the Appendix to this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb9915ef5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3151, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/465/s3/a"},"text":"Pub. L. 89–465, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-06-22"},"text":"June 22, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/216"},"text":"80 Stat. 216","children":[],"tail":", related to contempt power of courts, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s203/a"},"text":"Pub. L. 98–473, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1976"},"text":"98 Stat. 1976","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
