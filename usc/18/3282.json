{"tag":"section","attrib":{"id":"idb9988b73-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3282"},"text":null,"children":[{"tag":"num","attrib":{"value":"3282"},"text":"§ 3282.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offenses not capital","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9988b74-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3282/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise expressly provided by law, no person shall be prosecuted, tried, or punished for any offense, not capital, unless the indictment is found or the information is instituted within five years next after such offense shall have been committed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9988b75-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3282/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" DNA ","children":[{"tag":"inline","attrib":{},"text":"Profile Indictment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9988b76-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3282/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In any indictment for an offense under chapter 109A for which the identity of the accused is unknown, it shall be sufficient to describe the accused as an individual whose name is unknown, but who has a particular DNA profile.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9988b77-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3282/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any indictment described under paragraph (1), which is found not later than 5 years after the offense under chapter 109A is committed, shall not be subject to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9988b78-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3282/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the limitations period described under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9988b79-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3282/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of chapter 208 until the individual is arrested or served with a summons in connection with the charges contained in the indictment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9988b7a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3282/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defined term","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this subsection, the term “DNA profile” means a set of DNA identification characteristics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9988b7b-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/828"},"text":"62 Stat. 828","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-09-01/ch1214/s12/a"},"text":"Sept. 1, 1954, ch. 1214, § 12(a)","children":[],"tail":", formerly § 10(a), "},{"tag":"ref","attrib":{"href":"/us/stat/68/1145"},"text":"68 Stat. 1145","children":[],"tail":"; renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/87/299/s1"},"text":"Pub. L. 87–299, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-26"},"text":"Sept. 26, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/648"},"text":"75 Stat. 648","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/21/tVI/s610/a"},"text":"Pub. L. 108–21, title VI, § 610(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-30"},"text":"Apr. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/692"},"text":"117 Stat. 692","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9988b7c-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9988b7d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s746/g"},"text":"section 746(g) of title 8","children":[],"tail":", U.S.C., 1940 ed., Aliens and Nationality, and on title 18, U.S.C., 1940 ed., § 582 (R.S. § 1044; "},{"tag":"ref","attrib":{"href":"/us/act/1876-04-13/ch56"},"text":"Apr. 13, 1876, ch. 56","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/19/32"},"text":"19 Stat. 32","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1921-11-17/ch124/s1"},"text":"Nov. 17, 1921, ch. 124, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/220"},"text":"42 Stat. 220","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1927-12-27/ch6"},"text":"Dec. 27, 1927, ch. 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/51"},"text":"45 Stat. 51","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1940-10-14/ch876"},"text":"Oct. 14, 1940, ch. 876","children":[],"tail":", title I, subchap. III, § 346(g), "},{"tag":"ref","attrib":{"href":"/us/stat/54/1167"},"text":"54 Stat. 1167","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s582"},"text":"Section 582 of title 18","children":[],"tail":", U.S.C., 1940 ed., and "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s746/g"},"text":"section 746(g) of title 8","children":[],"tail":", U.S.C., 1940 ed., Aliens and Nationality, were consolidated. “Except as otherwise expressly provided by law” was inserted to avoid enumeration of exceptive provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The proviso contained in the act of 1927 “That nothing herein contained shall apply to any offense for which an indictment has been heretofore found or an information instituted, or to any proceedings under any such indictment or information,” was omitted as no longer necessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the consolidation of these sections the 5-year period of limitation for violations of the Nationality Code, provided for in said ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s746/g"},"text":"section 746(g) of title 8","children":[],"tail":", U.S.C., 1940 ed., Aliens and Nationality, is reduced to 3 years. There seemed no sound basis for considering 3 years adequate in the case of heinous felonies and gross frauds against the United States but inadequate for misuse of a passport or false statement to a naturalization examiner."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9988b7e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9988b7f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21"},"text":"Pub. L. 108–21","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Act ","children":[{"tag":"date","attrib":{"date":"1954-09-01"},"text":"Sept. 1, 1954","children":[],"tail":", changed the limitation period from three years to five years."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9988b80-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb9988b81-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1954 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1954-09-01/ch1214/s12/b"},"text":"Act Sept. 1, 1954, ch. 1214, § 12(b)","children":[],"tail":", formerly section 10(b), "},{"tag":"ref","attrib":{"href":"/us/stat/68/1145"},"text":"68 Stat. 1145","children":[],"tail":", as renumbered by "},{"tag":"ref","attrib":{"href":"/us/pl/87/299/s1"},"text":"Pub. L. 87–299, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-26"},"text":"Sept. 26, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/648"},"text":"75 Stat. 648","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/87/299/s1"},"text":"“The amendment made by subsection (a) [amending this section] shall be effective with respect to offenses (1) committed on or after ","children":[{"tag":"date","attrib":{"date":"1954-09-01"},"text":"September 1, 1954","children":[],"tail":", or (2) committed prior to such date, if on such date prosecution therefor is not barred by provisions of law in effect prior to such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb9988b82-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Fugitives From Justice","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Statutes of limitations as not extending to persons fleeing from justice, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3290"},"text":"section 3290 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb9988b83-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Offenses Against Internal Security","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Limitation period in connection with offenses against internal security, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s783"},"text":"section 783 of Title 50","children":[],"tail":", War and National Defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb9988b84-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Sections 792, 793, and 794 of This Title; Limitation Period","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Limitation period in connection with sections 792, 793, and 794 of this title, see note set out under section 792.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
