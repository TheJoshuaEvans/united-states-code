{"tag":"section","attrib":{"id":"idb923a9d0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1513"},"text":null,"children":[{"tag":"num","attrib":{"value":"1513"},"text":"§ 1513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retaliating against a witness, victim, or an informant","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb923a9d1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1513/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb923a9d2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1513/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whoever kills or attempts to kill another person with intent to retaliate against any person for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb923a9d3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1513/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the attendance of a witness or party at an official proceeding, or any testimony given or any record, document, or other object produced by a witness in an official proceeding; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb923a9d4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1513/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing to a law enforcement officer any information relating to the commission or possible commission of a Federal offense or a violation of conditions of probation, supervised release, parole, or release pending judicial proceedings,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished as provided in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb923a9d5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1513/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The punishment for an offense under this subsection is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb923a9d6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1513/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a killing, the punishment provided in sections 1111 and 1112; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb923a9d7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1513/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an attempt, imprisonment for not more than 30 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb923a9d8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1513/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whoever knowingly engages in any conduct and thereby causes bodily injury to another person or damages the tangible property of another person, or threatens to do so, with intent to retaliate against any person for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb923a9d9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1513/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the attendance of a witness or party at an official proceeding, or any testimony given or any record, document, or other object produced by a witness in an official proceeding; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb923a9da-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1513/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any information relating to the commission or possible commission of a Federal offense or a violation of conditions of probation, supervised release, parole, or release pending judicial proceedings given by a person to a law enforcement officer;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"or attempts to do so, shall be fined under this title or imprisoned not more than 20 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb923a9db-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1513/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the retaliation occurred because of attendance at or testimony in a criminal case, the maximum term of imprisonment which may be imposed for the offense under this section shall be the higher of that otherwise provided by law or the maximum term that could have been imposed for any offense charged in such case.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb923a9dc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1513/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is extraterritorial Federal jurisdiction over an offense under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb923a9dd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1513/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever knowingly, with the intent to retaliate, takes any action harmful to any person, including interference with the lawful employment or livelihood of any person, for providing to a law enforcement officer any truthful information relating to the commission or possible commission of any Federal offense, shall be fined under this title or imprisoned not more than 10 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb923a9de-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1513/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever conspires to commit any offense under this section shall be subject to the same penalties as those prescribed for the offense the commission of which was the object of the conspiracy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb923a9df-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1513/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A prosecution under this section may be brought in the district in which the official proceeding (whether pending, about to be instituted, or completed) was intended to be affected, or in which the conduct constituting the alleged offense occurred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb923a9e0-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/291/s4/a"},"text":"Pub. L. 97–291, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1250"},"text":"96 Stat. 1250","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tVI/s60017"},"text":"Pub. L. 103–322, title VI, § 60017","children":[],"tail":", title XXXIII, § 330016(1)(U), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1975"},"text":"108 Stat. 1975","children":[],"tail":", 2148; "},{"tag":"ref","attrib":{"href":"/us/pl/104/214/s1/1"},"text":"Pub. L. 104–214, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3017"},"text":"110 Stat. 3017","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/204/tXI/s1107/a"},"text":"Pub. L. 107–204, title XI, § 1107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/810"},"text":"116 Stat. 810","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dB/tIII/s3001/b"},"text":"Pub. L. 107–273, div. B, title III, § 3001(b)","children":[],"tail":", (c)(2), title IV, § 4002(b)(4), "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1804"},"text":"116 Stat. 1804","children":[],"tail":", 1807; "},{"tag":"ref","attrib":{"href":"/us/pl/110/177/tII"},"text":"Pub. L. 110–177, title II","children":[],"tail":", §§ 204, 206, "},{"tag":"date","attrib":{"date":"2008-01-07"},"text":"Jan. 7, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2537"},"text":"121 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb923a9e1-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb923a9e2-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb923a9e3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/177/s206/1"},"text":"Pub. L. 110–177, § 206(1)","children":[],"tail":", inserted comma after “probation” and struck out comma after “release,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/177/s206/2"},"text":"Pub. L. 110–177, § 206(2)","children":[],"tail":", substituted “30 years” for “20 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/177/s206/3/B"},"text":"Pub. L. 110–177, § 206(3)(B)","children":[],"tail":", substituted “20 years” for “ten years” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/177/s206/3/A"},"text":"Pub. L. 110–177, § 206(3)(A)","children":[],"tail":", inserted comma after “probation” and struck out comma after “release,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/177/s206/4"},"text":"Pub. L. 110–177, § 206(4)","children":[],"tail":", redesignated subsec. (e) relating to conspiracy to commit any offense under this section as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/177/s204"},"text":"Pub. L. 110–177, § 204","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsecs. (a)(1)(B), (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s3001/c/2"},"text":"Pub. L. 107–273, § 3001(c)(2)","children":[],"tail":", inserted “supervised release,” after “probation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s4002/b/4"},"text":"Pub. L. 107–273, § 4002(b)(4)","children":[],"tail":", transferred subsec. (d) to appear after subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s3001/b"},"text":"Pub. L. 107–273, § 3001(b)","children":[],"tail":", added subsec. (e) relating to conspiracy to commit any offense under this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204"},"text":"Pub. L. 107–204","children":[],"tail":" added subsec. (e) relating to taking of action harmful to any person for providing law enforcement officer truthful information relating to commission of offense."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/214/s1/1/B"},"text":"Pub. L. 104–214, § 1(1)(B)","children":[],"tail":", added subsec. (c) at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/214/s1/1/A"},"text":"Pub. L. 104–214, § 1(1)(A)","children":[],"tail":", redesignated subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/214/s1/1/A"},"text":"Pub. L. 104–214, § 1(1)(A)","children":[],"tail":", redesignated subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s60017/2"},"text":"Pub. L. 103–322, § 60017(2)","children":[],"tail":", added subsec. (a). Former subsec. (a) redesignated (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/1/U"},"text":"Pub. L. 103–322, § 330016(1)(U)","children":[],"tail":", substituted “fined under this title” for “fined not more than $250,000” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s60017/1"},"text":"Pub. L. 103–322, § 60017(1)","children":[],"tail":", redesignated subsec. (a) as (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s60017/1"},"text":"Pub. L. 103–322, § 60017(1)","children":[],"tail":", redesignated subsec. (b) as (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb923a9e4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb923a9e5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/291/s9/a"},"text":"section 9(a) of Pub. L. 97–291","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1512"},"text":"section 1512 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
