{"tag":"section","attrib":{"id":"idb8bf90ce-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s228"},"text":null,"children":[{"tag":"num","attrib":{"value":"228"},"text":"§ 228.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to pay legal child support obligations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8bf90cf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s228/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offense","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8bf90d0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s228/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully fails to pay a support obligation with respect to a child who resides in another State, if such obligation has remained unpaid for a period longer than 1 year, or is greater than $5,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf90d1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s228/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" travels in interstate or foreign commerce with the intent to evade a support obligation, if such obligation has remained unpaid for a period longer than 1 year, or is greater than $5,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf90d2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s228/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully fails to pay a support obligation with respect to a child who resides in another State, if such obligation has remained unpaid for a period longer than 2 years, or is greater than $10,000;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished as provided in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8bf90d3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s228/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Presumption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The existence of a support obligation that was in effect for the time period charged in the indictment or information creates a rebuttable presumption that the obligor has the ability to pay the support obligation for that time period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8bf90d4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s228/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Punishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The punishment for an offense under this section is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8bf90d5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s228/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a first offense under subsection (a)(1), a fine under this title, imprisonment for not more than 6 months, or both; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf90d6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s228/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an offense under paragraph (2) or (3) of subsection (a), or a second or subsequent offense under subsection (a)(1), a fine under this title, imprisonment for not more than 2 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8bf90d7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s228/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mandatory Restitution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon a conviction under this section, the court shall order restitution under section 3663A in an amount equal to the total unpaid support obligation as it exists at the time of sentencing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8bf90d8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s228/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Venue","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to an offense under this section, an action may be inquired of and prosecuted in a district court of the United States for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8bf90d9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s228/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the district in which the child who is the subject of the support obligation involved resided during a period during which a person described in subsection (a) (referred to in this subsection as an “obliger”) failed to meet that support obligation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf90da-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s228/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the district in which the obliger resided during a period described in paragraph (1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf90db-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s228/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other district with jurisdiction otherwise provided for by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8bf90dc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s228/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8bf90dd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s228/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Indian tribe” has the meaning given that term in section 102 of the Federally Recognized Indian Tribe List Act of 1994 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s479a"},"text":"25 U.S.C. 479a","children":[],"tail":"); "},{"tag":"ref","attrib":{"idref":"fn002029"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002029"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf90de-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s228/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” includes any State of the United States, the District of Columbia, and any commonwealth, territory, or possession of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf90df-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s228/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “support obligation” means any amount determined under a court order or an order of an administrative process pursuant to the law of a State or of an Indian tribe to be due from a person for the support and maintenance of a child or of a child and the parent with whom the child is living.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8bf90e0-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/521/s2/a"},"text":"Pub. L. 102–521, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-25"},"text":"Oct. 25, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3403"},"text":"106 Stat. 3403","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s607"},"text":"Pub. L. 104–294, title VI, § 607","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3512"},"text":"110 Stat. 3512","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/187/s2"},"text":"Pub. L. 105–187, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-24"},"text":"June 24, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/618"},"text":"112 Stat. 618","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8bf90e1-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8bf90e2-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8bf90e3-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 102 of the Federally Recognized Indian Tribe List Act of 1994 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s479a"},"text":"25 U.S.C. 479a","children":[],"tail":"), referred to in subsec. (f)(1), was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s479a"},"text":"section 479a of Title 25","children":[],"tail":", Indians, prior to editorial reclassification as "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5130"},"text":"section 5130 of Title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8bf90e4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/187"},"text":"Pub. L. 105–187","children":[],"tail":" reenacted section catchline without change and amended text generally. Prior to amendment, section consisted of subsecs. (a) to (d) relating to a description of the offense, punishment for an offense, restitution upon conviction of an offense, and definitions of terms used in this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" inserted “commonwealth,” before “possession or territory of the United States”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8bf90e5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb8bf90e6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/187/s1"},"text":"Pub. L. 105–187, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-24"},"text":"June 24, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/618"},"text":"112 Stat. 618","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/187/s1"},"text":"“This Act [amending this section] may be cited as the ‘Deadbeat Parents Punishment Act of 1998’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idb8bf90e7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/521/s1"},"text":"Pub. L. 102–521, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-25"},"text":"Oct. 25, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3403"},"text":"106 Stat. 3403","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/521/s1"},"text":"“This Act [enacting this section and sections 3796cc to 3796cc–6 of Title 42, The Public Health and Welfare, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3563"},"text":"section 3563 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3797"},"text":"section 3797 of Title 42","children":[],"tail":", and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12301"},"text":"section 12301 of Title 42","children":[],"tail":"] may be cited as the ‘Child Support Recovery Act of 1992’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
