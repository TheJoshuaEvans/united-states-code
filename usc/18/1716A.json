{"tag":"section","attrib":{"id":"idb92f8fb7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1716A"},"text":null,"children":[{"tag":"num","attrib":{"value":"1716A"},"text":"§ 1716A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonmailable locksmithing devices and motor vehicle master keys","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb92f8fb8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1716A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever knowingly deposits for mailing or delivery, or knowingly causes to be delivered by mail according to the direction thereon, or at any place to which it is directed to be delivered by the person to whom it is addressed, any matter declared to be nonmailable by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3002"},"text":"section 3002 of title 39","children":[],"tail":", shall be fined under this title or imprisoned not more than one year, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92f8fb9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1716A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever knowingly deposits for mailing or delivery, causes to be delivered by mail, or causes to be delivered by any interstate mailing or delivery other than by the United States Postal Service, any matter declared to be nonmailable by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3002a"},"text":"section 3002a of title 39","children":[],"tail":", shall be fined under this title, imprisoned not more than one year, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb92f8fba-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/560/s2/1"},"text":"Pub. L. 90–560, § 2(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-12"},"text":"Oct. 12, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/997"},"text":"82 Stat. 997","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", § 6(j)(26), "},{"tag":"ref","attrib":{"href":"/us/stat/84/780"},"text":"84 Stat. 780","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7090/c"},"text":"Pub. L. 100–690, title VII, § 7090(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4410"},"text":"102 Stat. 4410","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXV/s3551"},"text":"Pub. L. 101–647, title XXXV, § 3551","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4926"},"text":"104 Stat. 4926","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92f8fbb-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92f8fbc-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92f8fbd-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":" substituted “shall be fined under this title or” for “shall be under this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" inserted “locksmithing devices and” in section catchline, designated existing provisions as subsec. (a), substituted “under this title” for “fined not more than $1,000, or”, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":" substituted “section 3002” for “section 4010” of title 39."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb92f8fbe-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb92f8fbf-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":" effective within 1 year after "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", on date established therefor by Board of Governors of United States Postal Service and published by it in Federal Register, see "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as an Effective Date note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of Title 39","children":[],"tail":", Postal Service."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id