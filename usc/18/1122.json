{"tag":"section","attrib":{"id":"idb9155144-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1122"},"text":null,"children":[{"tag":"num","attrib":{"value":"1122"},"text":"§ 1122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection against the human immunodeficiency virus","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9155145-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever, after testing positive for the Human Immunodeficiency Virus (HIV) and receiving actual notice of that fact, knowingly donates or sells, or knowingly attempts to donate or sell, blood, semen, tissues, organs, or other bodily fluids for use by another, except as determined necessary for medical research or testing or in accordance with all applicable guidelines and regulations made by the Secretary of Health and Human Services under section 377E of the Public Health Service Act, shall be fined or imprisoned in accordance with subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9155146-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transmission Not Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Transmission of the Human Immunodeficiency Virus does not have to occur for a person to be convicted of a violation of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9155147-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1122/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person convicted of violating the provisions of subsection (a) shall be subject to a fine under this title of not less than $10,000, imprisoned for not less than 1 year nor more than 10 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9155148-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/333/tV/s514"},"text":"Pub. L. 103–333, title V, § 514","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-30"},"text":"Sept. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2574"},"text":"108 Stat. 2574","children":[],"tail":", § 1118; renumbered § 1122 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s601/a/5"},"text":"Pub. L. 104–294, title VI, § 601(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3498"},"text":"110 Stat. 3498","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/51/s3"},"text":"Pub. L. 113–51, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-11-21"},"text":"Nov. 21, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/581"},"text":"127 Stat. 581","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9155149-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb915514a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb915514b-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 377E of the Public Health Service Act, referred to in subsec. (a), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s274f–5"},"text":"section 274f–5 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb915514c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/51"},"text":"Pub. L. 113–51","children":[],"tail":" inserted “or in accordance with all applicable guidelines and regulations made by the Secretary of Health and Human Services under section 377E of the Public Health Service Act” after “research or testing”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294/s601/a/5/A"},"text":"Pub. L. 104–294, § 601(a)(5)(A)","children":[],"tail":", renumbered section 1118, relating to protection against human immunodeficiency virus, as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294/s601/a/5/B"},"text":"Pub. L. 104–294, § 601(a)(5)(B)","children":[],"tail":", inserted “under this title” after “fine” and struck out “nor more than $20,000” after “$10,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
