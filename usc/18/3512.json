{"tag":"section","attrib":{"id":"idb9a2013a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3512"},"text":null,"children":[{"tag":"num","attrib":{"value":"3512"},"text":"§ 3512.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign requests for assistance in criminal investigations and prosecutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9a2013b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3512/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Execution of Request for Assistance.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9a2013c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3512/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon application, duly authorized by an appropriate official of the Department of Justice, of an attorney for the Government, a Federal judge may issue such orders as may be necessary to execute a request from a foreign authority for assistance in the investigation or prosecution of criminal offenses, or in proceedings related to the prosecution of criminal offenses, including proceedings regarding forfeiture, sentencing, and restitution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a2013d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3512/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope of orders","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any order issued by a Federal judge pursuant to paragraph (1) may include the issuance of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9a2013e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3512/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a search warrant, as provided under Rule 41 of the Federal Rules of Criminal Procedure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9a2013f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3512/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a warrant or order for contents of stored wire or electronic communications or for records related thereto, as provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2703"},"text":"section 2703 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9a20140-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3512/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an order for a pen register or trap and trace device as provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3123"},"text":"section 3123 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9a20141-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3512/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an order requiring the appearance of a person for the purpose of providing testimony or a statement, or requiring the production of documents or other things, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9a20142-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3512/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment of Persons To Take Testimony or Statements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9a20143-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3512/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In response to an application for execution of a request from a foreign authority as described under subsection (a), a Federal judge may also issue an order appointing a person to direct the taking of testimony or statements or of the production of documents or other things, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a20144-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3512/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of appointed person","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person appointed under an order issued pursuant to paragraph (1) may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9a20145-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3512/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue orders requiring the appearance of a person, or the production of documents or other things, or both;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9a20146-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3512/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer any necessary oath; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9a20147-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3512/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take testimony or statements and receive documents or other things.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9a20148-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3512/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Filing of Requests","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided under subsection (d), an application for execution of a request from a foreign authority under this section may be filed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9a20149-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3512/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the district in which a person who may be required to appear resides or is located or in which the documents or things to be produced are located;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a2014a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3512/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cases in which the request seeks the appearance of persons or production of documents or things that may be located in multiple districts, in any one of the districts in which such a person, documents, or things may be located; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a2014b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3512/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any case, the district in which a related Federal criminal investigation or prosecution is being conducted, or in the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9a2014c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3512/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Search Warrant Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An application for execution of a request for a search warrant from a foreign authority under this section, other than an application for a warrant issued as provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2703"},"text":"section 2703 of this title","children":[],"tail":", shall be filed in the district in which the place or person to be searched is located."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9a2014d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3512/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Search Warrant Standard","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Federal judge may issue a search warrant under this section only if the foreign offense for which the evidence is sought involves conduct that, if committed in the United States, would be considered an offense punishable by imprisonment for more than one year under Federal or State law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9a2014e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3512/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service of Order or Warrant","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided under subsection (d), an order or warrant issued pursuant to this section may be served or executed in any place in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9a2014f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3512/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to preclude any foreign authority or an interested person from obtaining assistance in a criminal investigation or prosecution pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1782"},"text":"section 1782 of title 28","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9a20150-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3512/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9a20151-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3512/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal judge","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms “Federal judge” and “attorney for the Government” have the meaning given such terms for the purposes of the Federal Rules of Criminal Procedure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a20152-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3512/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “foreign authority” means a foreign judicial authority, a foreign authority responsible for the investigation or prosecution of criminal offenses or for proceedings related to the prosecution of criminal offenses, or an authority designated as a competent authority or central authority for the purpose of making requests for assistance pursuant to an agreement or treaty with the United States regarding assistance in criminal matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9a20153-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/79/s2/4"},"text":"Pub. L. 111–79, § 2(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-19"},"text":"Oct. 19, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2087"},"text":"123 Stat. 2087","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9a20154-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9a20155-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9a20156-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Criminal Procedure, referred to in subsecs. (a)(2)(A) and (h)(1), are set out in the Appendix to this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
