{"tag":"section","attrib":{"id":"idb942a337-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2076"},"text":null,"children":[{"tag":"num","attrib":{"value":"2076"},"text":"§ 2076.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clerk of United States District Court","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being a clerk of a district court of the United States, willfully refuses or neglects to make or forward any report, certificate, statement, or document as required by law, shall be fined under this title or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb942a338-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/796"},"text":"62 Stat. 796","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s601/a/11"},"text":"Pub. L. 104–294, title VI, § 601(a)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3498"},"text":"110 Stat. 3498","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb942a339-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb942a33a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s522"},"text":"section 522 of title 28","children":[],"tail":", U.S.C., 1940 ed., Judicial Code and Judiciary ("},{"tag":"ref","attrib":{"href":"/us/act/1875-02-22/ch95/s6"},"text":"Feb. 22, 1875, ch. 95, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/18/334"},"text":"18 Stat. 334","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The reference to the offense as a misdemeanor was omitted as unnecessary in view of the definition of “misdemeanor” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The last sentence providing that conviction should not be a condition precedent to removal from office was omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb942a33b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb942a33c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" substituted “fined under this title or imprisoned not more than one year, or both” for “fined not more than $1,000 or imprisoned not more than one year” before period at end."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
