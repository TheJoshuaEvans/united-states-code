{"tag":"section","attrib":{"id":"idb928639b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1545"},"text":null,"children":[{"tag":"num","attrib":{"value":"1545"},"text":"§ 1545.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safe conduct violation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever violates any safe conduct or passport duly obtained and issued under authority of the United States shall be fined under this title, imprisoned not more than 10 years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb928639c-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/771"},"text":"62 Stat. 771","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXIII/s130009/a/3"},"text":"Pub. L. 103–322, title XIII, § 130009(a)(3)","children":[],"tail":", title XXXIII, § 330016(1)(I), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2030"},"text":"108 Stat. 2030","children":[],"tail":", 2147.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb928639d-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb928639e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s251"},"text":"section 251 of title 22","children":[],"tail":", U.S.C., 1940 ed., Foreign Relations and Intercourse (R.S. 4062)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The punishment provision was rewritten to permit the alternative of a fine of not more than $2,000 or imprisonment, or both, instead of imprisonment and fine “at the discretion of the court”, to conform with other sections embracing offenses of comparable gravity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb928639f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92863a0-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/1/I"},"text":"Pub. L. 103–322, § 330016(1)(I)","children":[],"tail":", which directed the amendment of this section by substituting “under this title” for “not more than $2,000”, could not be executed because the words “not more than $2,000” did not appear in text subsequent to amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/s130009/a/3"},"text":"Pub. L. 103–322, § 130009(a)(3)","children":[],"tail":". See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s130009/a/3"},"text":"Pub. L. 103–322, § 130009(a)(3)","children":[],"tail":", substituted “under this title, imprisoned not more than 10 years” for “not more than $2,000 or imprisoned not more than three years”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
