{"tag":"section","attrib":{"id":"idb91307c3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1093"},"text":null,"children":[{"tag":"num","attrib":{"value":"1093"},"text":"§ 1093.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91307c4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1093/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “children” means the plural and means individuals who have not attained the age of eighteen years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91307c5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1093/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “ethnic group” means a set of individuals whose identity as such is distinctive in terms of common cultural traditions or heritage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91307c6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1093/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “incites” means urges another to engage imminently in conduct in circumstances under which there is a substantial likelihood of imminently causing such conduct;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91307c7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1093/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “members” means the plural;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91307c8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1093/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “national group” means a set of individuals whose identity as such is distinctive in terms of nationality or national origins;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91307c9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1093/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “racial group” means a set of individuals whose identity as such is distinctive in terms of physical characteristics or biological descent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91307ca-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1093/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “religious group” means a set of individuals whose identity as such is distinctive in terms of common religious creed, beliefs, doctrines, practices, or rituals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91307cb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1093/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “substantial part” means a part of a group of such numerical significance that the destruction or loss of that part would cause the destruction of the group as a viable entity within the nation of which such group is a part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb91307cc-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/606/s2/a"},"text":"Pub. L. 100–606, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3046"},"text":"102 Stat. 3046","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
