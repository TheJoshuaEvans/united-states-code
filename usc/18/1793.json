{"tag":"section","attrib":{"id":"idb9320140-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1793"},"text":null,"children":[{"tag":"num","attrib":{"value":"1793"},"text":"§ 1793.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trespass on Bureau of Prisons reservations and land","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, without lawful authority or permission, goes upon a reservation, land, or a facility of the Bureau of Prisons shall be fined under this title or imprisoned not more than six months, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9320141-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646/s64/a"},"text":"Pub. L. 99–646, § 64(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3614"},"text":"100 Stat. 3614","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/G"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(G)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9320142-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9320143-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9320144-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $500”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
