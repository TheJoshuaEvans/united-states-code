{"tag":"section","attrib":{"id":"idb9096a7f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1024"},"text":null,"children":[{"tag":"num","attrib":{"value":"1024"},"text":"§ 1024.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase or receipt of military, naval, or veteran’s facilities property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever purchases, or receives in pledge from any person any arms, equipment, ammunition, clothing, military stores, or other property furnished by the United States under a clothing allowance or otherwise, to any member of the Armed Forces of the United States or of the National Guard or Naval Militia, or to any person accompanying, serving, or retained with the land or naval forces and subject to military or naval law, or to any former member of such Armed Forces at or by any hospital, home, or facility maintained by the United States, having knowledge or reason to believe that the property has been taken from the possession of or furnished by the United States under such allowance, or otherwise, shall be fined under this title or imprisoned not more than two years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9096a80-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/754"},"text":"62 Stat. 754","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/G"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(G)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9096a81-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9096a82-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 86 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s35"},"text":"Mar. 4, 1909, ch. 321, § 35","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1095"},"text":"35 Stat. 1095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1918-10-23/ch194"},"text":"Oct. 23, 1918, ch. 194","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/1015"},"text":"40 Stat. 1015","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1934-06-18/ch587"},"text":"June 18, 1934, ch. 587","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/996"},"text":"48 Stat. 996","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1938-04-04/ch69"},"text":"Apr. 4, 1938, ch. 69","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/197"},"text":"52 Stat. 197","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1940-04-30/ch164"},"text":"Apr. 30, 1940, ch. 164","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/171"},"text":"54 Stat. 171","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9096a83-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9096a84-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $500”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
