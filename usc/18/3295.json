{"tag":"section","attrib":{"id":"idb99ad4ce-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3295"},"text":null,"children":[{"tag":"num","attrib":{"value":"3295"},"text":"§ 3295.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arson offenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No person shall be prosecuted, tried, or punished for any non-capital offense under section 81 or subsection (f), (h), or (i) of section 844 unless the indictment is found or the information is instituted not later than 10 years after the date on which the offense was committed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb99ad4cf-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/tVII/s708/c/1"},"text":"Pub. L. 104–132, title VII, § 708(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1297"},"text":"110 Stat. 1297","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
