{"tag":"section","attrib":{"id":"idb94031aa-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1967"},"text":null,"children":[{"tag":"num","attrib":{"value":"1967"},"text":"§ 1967.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evidence","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In any proceeding ancillary to or in any civil action instituted by the United States under this chapter the proceedings may be open or closed to the public at the discretion of the court after consideration of the rights of affected persons.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb94031ab-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/452/tIX/s901/a"},"text":"Pub. L. 91–452, title IX, § 901(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-15"},"text":"Oct. 15, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/944"},"text":"84 Stat. 944","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
