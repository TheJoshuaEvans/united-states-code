{"tag":"section","attrib":{"id":"idb98a32f0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3071"},"text":null,"children":[{"tag":"num","attrib":{"value":"3071"},"text":"§ 3071.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information for which rewards authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb98a32f1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3071/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to acts of terrorism primarily within the territorial jurisdiction of the United States, the Attorney General may reward any individual who furnishes information—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb98a32f2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3071/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leading to the arrest or conviction, in any country, of any individual or individuals for the commission of an act of terrorism against a United States person or United States property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb98a32f3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3071/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leading to the arrest or conviction, in any country, of any individual or individuals for conspiring or attempting to commit an act of terrorism against a United States person or property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb98a32f4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3071/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leading to the prevention, frustration, or favorable resolution of an act of terrorism against a United States person or property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb98a32f5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3071/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to acts of espionage involving or directed at the United States, the Attorney General may reward any individual who furnishes information—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb98a32f6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3071/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leading to the arrest or conviction, in any country, of any individual or individuals for commission of an act of espionage against the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb98a32f7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3071/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leading to the arrest or conviction, in any country, of any individual or individuals for conspiring or attempting to commit an act of espionage against the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb98a32f8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3071/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leading to the prevention or frustration of an act of espionage against the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb98a32f9-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/533/tI/s101/a"},"text":"Pub. L. 98–533, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2706"},"text":"98 Stat. 2706","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/359/tVIII/s803/a"},"text":"Pub. L. 103–359, title VIII, § 803(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-14"},"text":"Oct. 14, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3438"},"text":"108 Stat. 3438","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb98a32fa-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb98a32fb-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb98a32fc-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/359"},"text":"Pub. L. 103–359","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb98a32fd-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idb98a32fe-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/533/s1"},"text":"Pub. L. 98–533, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2706"},"text":"98 Stat. 2706","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/533/s1"},"text":"“This Act [enacting this chapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2708"},"text":"section 2708 of Title 22","children":[],"tail":", Foreign Relations and Intercourse, amending sections 2669, 2678 and 2704 of Title 22, enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5928"},"text":"section 5928 of Title 5","children":[],"tail":", Government Organization and Employees and amending provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of Title 22","children":[],"tail":"] may be cited as the ‘1984 Act to Combat International Terrorism’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb98a32ff-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Attorney General’s Authority To Pay Rewards To Combat Terrorism","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/tV/s501"},"text":"Pub. L. 107–56, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/363"},"text":"115 Stat. 363","children":[],"tail":", which provided that funds available to Attorney General could be used for payment of rewards to combat terrorism and defend Nation against terrorist acts, in accordance with procedures and regulations established or issued by Attorney General, and set forth conditions in making such rewards, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dA/tIII/s301/c/1"},"text":"Pub. L. 107–273, div. A, title III, § 301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1781"},"text":"116 Stat. 1781","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
