{"tag":"section","attrib":{"id":"idb993a8fe-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3173"},"text":null,"children":[{"tag":"num","attrib":{"value":"3173"},"text":"§ 3173.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sixth amendment rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No provision of this chapter shall be interpreted as a bar to any claim of denial of speedy trial as required by amendment VI of the Constitution.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb993a8ff-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/619/tI/s101"},"text":"Pub. L. 93–619, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2085"},"text":"88 Stat. 2085","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
