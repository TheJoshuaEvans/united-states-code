{"tag":"section","attrib":{"id":"idb9961a8b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3196"},"text":null,"children":[{"tag":"num","attrib":{"value":"3196"},"text":"§ 3196.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extradition of United States citizens","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If the applicable treaty or convention does not obligate the United States to extradite its citizens to a foreign country, the Secretary of State may, nevertheless, order the surrender to that country of a United States citizen whose extradition has been requested by that country if the other requirements of that treaty or convention are met.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9961a8c-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/623/s11/a"},"text":"Pub. L. 101–623, § 11(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-21"},"text":"Nov. 21, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3356"},"text":"104 Stat. 3356","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
