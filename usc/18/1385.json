{"tag":"section","attrib":{"id":"idb91eedff-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1385"},"text":null,"children":[{"tag":"num","attrib":{"value":"1385"},"text":"§ 1385.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Army, Navy, Marine Corps, Air Force, and Space Force as posse comitatus","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, except in cases and under circumstances expressly authorized by the Constitution or Act of Congress, willfully uses any part of the Army, the Navy, the Marine Corps, the Air Force, or the Space Force as a posse comitatus or otherwise to execute the laws shall be fined under this title or imprisoned not more than two years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb91eee00-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041/s18/a"},"text":"Aug. 10, 1956, ch. 1041, § 18(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/626"},"text":"70A Stat. 626","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/86/70/s17/d"},"text":"Pub. L. 86–70, § 17(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-06-25"},"text":"June 25, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/144"},"text":"73 Stat. 144","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/L"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(L)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tX/s1045/a"},"text":"Pub. L. 117–81, div. A, title X, § 1045(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date"