{"tag":"section","attrib":{"id":"idb936bb95-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1866"},"text":null,"children":[{"tag":"num","attrib":{"value":"1866"},"text":"§ 1866.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Historic, archeologic, or prehistoric items and antiquities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb936bb96-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1866/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Violation of Regulations Authorized by Chapter ","children":[],"tail":"3201"},{"tag":"inline","attrib":{},"text":" of Title ","children":[],"tail":"54.—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person that violates any of the regulations authorized by chapter 3201 of title 54 shall be fined under this title and be adjudged to pay all cost of the proceedings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb936bb97-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1866/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriation of, Injury to, or Destruction of Historic or Prehistoric Ruin or Monument or Object of Antiquity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person that appropriates, excavates, injures, or destroys any historic or prehistoric ruin or monument or any other object of antiquity that is situated on land owned or controlled by the Federal Government without the permission of the head of the Federal agency having jurisdiction over the land on which the object is situated, shall be imprisoned not more than 90 days, fined under this title, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb936bb98-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s4/a/1"},"text":"Pub. L. 113–287, § 4(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3261"},"text":"128 Stat. 3261","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb936bb99-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb936bb9a-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb936bb9b-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1866(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s462/k"},"text":"16 U.S.C. 462(k)","children":[],"tail":" (last sentence)"}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1935-08-21/ch593/s2/k"},"text":"Aug. 21, 1935, ch. 593, § 2(k)","children":[],"tail":" (last sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/49/667"},"text":"49 Stat. 667","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1866(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s433"},"text":"16 U.S.C. 433","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1906-06-08/ch3060/s1"},"text":"June 8, 1906, ch. 3060, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/34/225"},"text":"34 Stat. 225","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the provision is transferred to title 18 to make clear that it is a criminal penalty. The words “fined under this title” are substituted for “punished by a fine of not more than $500” for consistency with chapter 227.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “fined under this title” are substituted for “fined in a sum of not more than $500” for consistency with chapter 227.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
