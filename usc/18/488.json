{"tag":"section","attrib":{"id":"idb8cb77db-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s488"},"text":null,"children":[{"tag":"num","attrib":{"value":"488"},"text":"§ 488.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Making or possessing counterfeit dies for foreign coins","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, within the United States, without lawful authority, makes any die, hub, or mold, or any part thereof, either of steel or of plaster, or of any other substance, in the likeness or similitude, as to the design or the inscription thereon, of any die, hub, or mold designated for the coining of the genuine coin of any foreign government; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever, without lawful authority, possesses any such die, hub, or mold, or any part thereof, or conceals, or knowingly suffers the same to be used for the counterfeiting of any foreign coin—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Shall be fined under this title or imprisoned not more than five years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8cb77dc-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/709"},"text":"62 Stat. 709","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8cb77dd-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8cb77de-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 284 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s170"},"text":"Mar. 4, 1909, ch. 321, § 170","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1120"},"text":"35 Stat. 1120","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to persons causing, procuring, aiding or assisting was omitted as unnecessary as such persons are made principals by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provision for $2,000 fine was increased to $5,000 to conform with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s481"},"text":"section 481 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8cb77df-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8cb77e0-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $5,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
