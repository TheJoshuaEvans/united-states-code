{"tag":"section","attrib":{"id":"idb8a06f56-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"§ 12.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Postal Service defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As used in this title, the term “Postal Service” means the United States Postal Service established under title 39, and every officer and employee of that Service, whether or not such officer or employee has taken the oath of office.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8a06f57-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/686"},"text":"62 Stat. 686","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s6/j/2"},"text":"Pub. L. 91–375, § 6(j)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/777"},"text":"84 Stat. 777","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXV/s3505"},"text":"Pub. L. 101–647, title XXXV, § 3505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4921"},"text":"104 Stat. 4921","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8a06f58-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8a06f59-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., §§ 301, 360 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321"},"text":"Mar. 4, 1909, ch. 321","children":[],"tail":", §§ 230, 231, "},{"tag":"ref","attrib":{"href":"/us/stat/35/1134"},"text":"35 Stat. 1134","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section consolidates sections 301 and 360 of title 18, U.S.C., 1940 ed., with necessary changes in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8a06f5a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8a06f5b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":" substituted “whether or not such officer or employee has taken the oath of office” for “whether he has taken the oath of office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":" inserted “United States” before “Postal Service” in section catchline and substituted in text as definition of “Postal Service” the United States Postal Service established under title 39, and every officer and employee of that Service, whether he has taken the oath of office, for prior definition which included the Post Office Department and every employee, thereof, whether or not he has taken the oath of office."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8a2e05c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8a2e05d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":" effective within 1 year after "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", on date established therefor by the Board of Governors of the United States Postal Service and published by it in the Federal Register, see "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as an Effective Date note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of Title 39","children":[],"tail":", Postal Service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
