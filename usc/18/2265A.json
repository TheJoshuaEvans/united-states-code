{"tag":"section","attrib":{"id":"idb955b5c4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2265A"},"text":null,"children":[{"tag":"num","attrib":{"value":"2265A"},"text":"§ 2265A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repeat offenders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb955b5c5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2265A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Term of Imprisonment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The maximum term of imprisonment for a violation of this chapter after a prior domestic violence or stalking offense shall be twice the term otherwise provided under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb955b5c6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2265A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb955b5c7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2265A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “prior domestic violence or stalking offense” means a conviction for an offense—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb955b5c8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2265A/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under section 2261, 2261A, or 2262 of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb955b5c9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2265A/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under State or tribal law for an offense consisting of conduct that would have been an offense under a section referred to in subparagraph (A) if the conduct had occurred within the special maritime and territorial jurisdiction of the United States, or in interstate or foreign commerce; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb955b5ca-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2265A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” means a State of the United States, the District of Columbia, or any commonwealth, territory, or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb955b5cb-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/tI/s115"},"text":"Pub. L. 109–162, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2988"},"text":"119 Stat. 2988","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/tIX/s906/c"},"text":"Pub. L. 113–4, title IX, § 906(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/125"},"text":"127 Stat. 125","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb955b5cc-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb955b5cd-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb955b5ce-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4"},"text":"Pub. L. 113–4","children":[],"tail":" inserted “or tribal” after “State”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
