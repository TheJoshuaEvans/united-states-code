{"tag":"section","attrib":{"id":"idb92ad585-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1597"},"text":null,"children":[{"tag":"num","attrib":{"value":"1597"},"text":"§ 1597.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful conduct with respect to immigration documents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb92ad586-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1597/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Destruction, Concealment, Removal, Confiscation, or Possession of Immigration Documents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be unlawful for any person to knowingly destroy, conceal, remove, confiscate, or possess, an actual or purported passport or other immigration document of another individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92ad587-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1597/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the course of violating ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1351"},"text":"section 1351 of this title","children":[],"tail":" or section 274 of the Immigration and Nationality Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1324"},"text":"8 U.S.C. 1324","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92ad588-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1597/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with intent to violate ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1351"},"text":"section 1351 of this title","children":[],"tail":" or section 274 of the Immigration and Nationality Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1324"},"text":"8 U.S.C. 1324","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92ad589-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1597/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in order to, without lawful authority, maintain, prevent, or restrict the labor of services of the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92ad58a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1597/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person who violates subsection (a) shall be fined under this title, imprisoned for not more than 1 year, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92ad58b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1597/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Obstruction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person who knowingly obstructs, attempts to obstruct, or in any way interferes with or prevents the enforcement of this section, shall be subject to the penalties described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb92ad58c-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/tXII/s1211/c/1"},"text":"Pub. L. 113–4, title XII, § 1211(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/142"},"text":"127 Stat. 142","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
