{"tag":"section","attrib":{"id":"idb8d9a823-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s670"},"text":null,"children":[{"tag":"num","attrib":{"value":"670"},"text":"§ 670.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Theft of medical products","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8d9a824-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s670/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibited Conduct","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever, in, or using any means or facility of, interstate or foreign commerce—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8d9a825-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s670/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" embezzles, steals, or by fraud or deception obtains, or knowingly and unlawfully takes, carries away, or conceals a pre-retail medical product;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d9a826-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s670/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly and falsely makes, alters, forges, or counterfeits the labeling or documentation (including documentation relating to origination or shipping) of a pre-retail medical product;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d9a827-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s670/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly possesses, transports, or traffics in a pre-retail medical product that was involved in a violation of paragraph (1) or (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d9a828-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s670/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with intent to defraud, buys, or otherwise obtains, a pre-retail medical product that has expired or been stolen;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d9a829-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s670/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with intent to defraud, sells, or distributes, a pre-retail medical product that is expired or stolen; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8dc192a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s670/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attempts or conspires to violate any of paragraphs (1) through (5);","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished as provided in subsection (c) and subject to the other sanctions provided in this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8dc192b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s670/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aggravated Offenses","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An offense under this section is an aggravated offense if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8dc192c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s670/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the defendant is employed by, or is an agent of, an organization in the supply chain for the pre-retail medical product; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8dc192d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s670/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the violation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8dc192e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s670/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involves the use of violence, force, or a threat of violence or force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8dc192f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s670/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involves the use of a deadly weapon;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8dc1930-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s670/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" results in serious bodily injury or death, including serious bodily injury or death resulting from the use of the medical product involved; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8dc1931-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s670/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is subsequent to a prior conviction for an offense under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8dc1932-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s670/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criminal Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever violates subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8dc1933-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s670/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the offense is an aggravated offense under subsection (b)(2)(C), shall be fined under this title or imprisoned not more than 30 years, or both;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8dc1934-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s670/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the value of the medical products involved in the offense is $5,000 or greater, shall be fined under this title, imprisoned for not more than 15 years, or both, but if the offense is an aggravated offense other than one under subsection (b)(2)(C), the maximum term of imprisonment is 20 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8dc1935-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s670/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any other case, shall be fined under this title, imprisoned for not more than 3 years, or both, but if the offense is an aggravated offense other than one under subsection (b)(2)(C), the maximum term of imprisonment is 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8dc1936-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s670/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever violates subsection (a) is subject to a civil penalty in an amount not more than the greater of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8dc1937-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s670/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three times the economic loss attributable to the violation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8dc1938-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s670/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8dc1939-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s670/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8dc193a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s670/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “pre-retail medical product” means a medical product that has not yet been made available for retail purchase by a consumer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8dc193b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s670/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “medical product” means a drug, biological product, device, medical food, or infant formula;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8dc193c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s670/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “device”, “drug”, “infant formula”, and “labeling” have, respectively, the meanings given those terms in section 201 of the Federal Food, Drug, and Cosmetic Act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8dc193d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s670/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “biological product” has the meaning given the term in section 351 of the Public Health Service Act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8dc193e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s670/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “medical food” has the meaning given the term in section 5(b) of the Orphan Drug Act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8dc193f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s670/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “supply chain” includes manufacturer, wholesaler, repacker, own-labeled distributor, private-label distributor, jobber, broker, drug trader, transportation company, hospital, pharmacy, or security company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8dc1940-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/186/s2/a"},"text":"Pub. L. 112–186, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-10-05"},"text":"Oct. 5, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1427"},"text":"126 Stat. 1427","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8dc1941-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8dc1942-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8dc1943-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 201 of the Federal Food, Drug, and Cosmetic Act, referred to in subsec. (e)(3), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s321"},"text":"section 321 of Title 21","children":[],"tail":", Food and Drugs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 351 of the Public Health Service Act, referred to in subsec. (e)(4), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"section 262 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 5(b) of the Orphan Drug Act, referred to in subsec. (e)(5), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360ee/b"},"text":"section 360ee(b) of Title 21","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8dc1944-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8dc1945-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Priority Given to Certain Investigations and Prosecutions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/186/s4/e"},"text":"Pub. L. 112–186, § 4(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-10-05"},"text":"Oct. 5, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1429"},"text":"126 Stat. 1429","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/186/s4/e"},"text":"“The Attorney General shall give increased priority to efforts to investigate and prosecute offenses under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s670"},"text":"section 670 of title 18","children":[],"tail":", United States Code, that involve pre-retail medical products.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
