{"tag":"section","attrib":{"id":"idb9320138-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1792"},"text":null,"children":[{"tag":"num","attrib":{"value":"1792"},"text":"§ 1792.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mutiny and riot prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever instigates, connives, willfully attempts to cause, assists, or conspires to cause any mutiny or riot, at any Federal penal, detention, or correctional facility, shall be imprisoned not more than ten years or fined under this title, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9320139-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/786"},"text":"62 Stat. 786","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s1109/b"},"text":"Pub. L. 98–473, title II, § 1109(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2148"},"text":"98 Stat. 2148","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/646/s53/a"},"text":"Pub. L. 99–646, § 53(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3607"},"text":"100 Stat. 3607","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/O"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(O)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2148"},"text":"108 Stat. 2148","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb932013a-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb932013b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 252 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-05-18/ch303/s1"},"text":"May 18, 1934, ch. 303, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/782"},"text":"48 Stat. 782","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Escape provisions of this section were incorporated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s752"},"text":"section 752 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to persons causing, procuring, aiding and assisting was omitted. Such persons are principals under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in translation and phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb932013c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb932013d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $25,000”."}],"ta