{"tag":"section","attrib":{"id":"idb8bf905c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s217"},"text":null,"children":[{"tag":"num","attrib":{"value":"217"},"text":"§ 217.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of consideration for adjustment of farm indebtedness","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being an officer or employee of, or person acting for the United States or any agency thereof, accepts any fee, commission, gift, or other consideration in connection with the compromise, adjustment, or cancellation of any farm indebtedness as provided by sections 1150, 1150a, and 1150b of Title 12, shall be fined under this title or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8bf905d-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/696"},"text":"62 Stat. 696","children":[],"tail":", § 217, formerly § 222; renumbered § 217, "},{"tag":"ref","attrib":{"href":"/us/pl/87/849/s1/d"},"text":"Pub. L. 87–849, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-23"},"text":"Oct. 23, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1125"},"text":"76 Stat. 1125","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8bf905e-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8bf905f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1150c/b"},"text":"section 1150c(b) of title 12","children":[],"tail":", U.S.C., 1940 ed., Banks and Banking ("},{"tag":"ref","attrib":{"href":"/us/act/1944-12-20/ch623/s4/b"},"text":"Dec. 20, 1944, ch. 623, § 4(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/837"},"text":"58 Stat. 837","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “upon conviction thereof” were omitted as surplusage, since punishment cannot be imposed until after conviction.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Other changes were made in phraseology without change of substance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8bf9060-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb8bf9061-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 217 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s212"},"text":"section 212 of this title","children":[],"tail":" and subsequently repealed."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8bf9062-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $1,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
