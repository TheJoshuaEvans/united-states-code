{"tag":"section","attrib":{"id":"idb9915f35-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3156"},"text":null,"children":[{"tag":"num","attrib":{"value":"3156"},"text":"§ 3156.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9915f36-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3156/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in sections 3141–3150 of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9915f37-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3156/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “judicial officer” means, unless otherwise indicated, any person or court authorized pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3041"},"text":"section 3041 of this title","children":[],"tail":", or the Federal Rules of Criminal Procedure, to detain or release a person before trial or sentencing or pending appeal in a court of the United States, and any judge of the Superior Court of the District of Columbia;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9915f38-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3156/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “offense” means any criminal offense, other than an offense triable by court-martial, military commission, provost court, or other military tribunal, which is in violation of an Act of Congress and is triable in any court established by Act of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9915f39-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3156/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “felony” means an offense punishable by a maximum term of imprisonment of more than one year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9915f3a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3156/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “crime of violence” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9915f3b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3156/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an offense that has as an element of the offense the use, attempted use, or threatened use of physical force against the person or property of another;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9915f3c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3156/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other offense that is a felony and that, by its nature, involves a substantial risk that physical force against the person or property of another may be used in the course of committing the offense; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9915f3d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3156/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any felony under chapter 77, 109A, 110, or 117; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9915f3e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3156/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” includes a State of the United States, the District of Columbia, and any commonwealth, territory, or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9915f3f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3156/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in sections 3152–3155 of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9915f40-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3156/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “judicial officer” means, unless otherwise indicated, any person or court authorized pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3041"},"text":"section 3041 of this title","children":[],"tail":", or the Federal Rules of Criminal Procedure, to detain or release a person before trial or sentencing or pending appeal in a court of the United States, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9915f41-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3156/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “offense” means any Federal criminal offense which is in violation of any Act of Congress and is triable by any court established by Act of Congress (other than a Class B or C misdemeanor or an infraction, or an offense triable by court-martial, military commission, provost court, or other military tribunal).","children":[],"tail":"\n"}],"tail":"\n"}],"tai