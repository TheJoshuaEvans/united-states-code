{"tag":"section","attrib":{"id":"idb9c0fa8f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771"},"text":null,"children":[{"tag":"num","attrib":{"value":"3771"},"text":"§ 3771.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crime victims’ rights","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9c0fa90-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rights of Crime Victims","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A crime victim has the following rights:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c0fa91-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The right to be reasonably protected from the accused.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fa92-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The right to reasonable, accurate, and timely notice of any public court proceeding, or any parole proceeding, involving the crime or of any release or escape of the accused.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fa93-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The right not to be excluded from any such public court proceeding, unless the court, after receiving clear and convincing evidence, determines that testimony by the victim would be materially altered if the victim heard other testimony at that proceeding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fa94-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The right to be reasonably heard at any public proceeding in the district court involving release, plea, sentencing, or any parole proceeding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fa95-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The reasonable right to confer with the attorney for the Government in the case.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fa96-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The right to full and timely restitution as provided in law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fa97-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The right to proceedings free from unreasonable delay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fa98-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The right to be treated with fairness and with respect for the victim’s dignity and privacy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fa99-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The right to be informed in a timely manner of any plea bargain or deferred prosecution agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fa9a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The right to be informed of the rights under this section and the services described in section 503(c) of the Victims’ Rights and Restitution Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10607/c"},"text":"42 U.S.C. 10607(c)","children":[],"tail":") "},{"tag":"ref","attrib":{"idref":"fn002277"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002277"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and provided contact information for the Office of the Victims’ Rights Ombudsman of the Department of Justice."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c0fa9b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rights Afforded","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c0fa9c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In any court proceeding involving an offense against a crime victim, the court shall ensure that the crime victim is afforded the rights described in subsection (a). Before making a determination described in subsection (a)(3), the court shall make every effort to permit the fullest attendance possible by the victim and shall consider reasonable alternatives to the exclusion of the victim from the criminal proceeding. The reasons for any decision denying relief under this chapter shall be clearly stated on the record.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fa9d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Habeas corpus proceedings.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c0fa9e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In a Federal habeas corpus proceeding arising out of a State conviction, the court shall ensure that a crime victim is afforded the rights described in paragraphs (3), (4), (7), and (8) of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0fa9f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enforcement.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idb9c0faa0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"These rights may be enforced by the crime victim or the crime victim’s lawful representative in the manner described in paragraphs (1) and (3) of subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9c0faa1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Multiple victims","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In a case involving multiple victims, subsection (d)(2) shall also apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0faa2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This paragraph relates to the duties of a court in relation to the rights of a crime victim in Federal habeas corpus proceedings arising out of a State conviction, and does not give rise to any obligation or requirement applicable to personnel of any agency of the Executive Branch of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0faa3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this paragraph, the term “crime victim” means the person against whom the State offense is committed or, if that person is killed or incapacitated, that person’s family member or other lawful representative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c0faa4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Best Efforts To Accord Rights.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c0faa5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Government","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Officers and employees of the Department of Justice and other departments and agencies of the United States engaged in the detection, investigation, or prosecution of crime shall make their best efforts to see that crime victims are notified of, and accorded, the rights described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0faa6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advice of attorney","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The prosecutor shall advise the crime victim that the crime victim can seek the advice of an attorney with respect to the rights described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0faa7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notice of release otherwise required pursuant to this chapter shall not be given if such notice may endanger the safety of any person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c0faa8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enforcement and Limitations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c0faa9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rights","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The crime victim or the crime victim’s lawful representative, and the attorney for the Government may assert the rights described in subsection (a). A person accused of the crime may not obtain any form of relief under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0faaa-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Multiple crime victims","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In a case where the court finds that the number of crime victims makes it impracticable to accord all of the crime victims the rights described in subsection (a), the court shall fashion a reasonable procedure to give effect to this chapter that does not unduly complicate or prolong the proceedings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0faab-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Motion for relief and writ of mandamus","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The rights described in subsection (a) shall be asserted in the district court in which a defendant is being prosecuted for the crime or, if no prosecution is underway, in the district court in the district in which the crime occurred. The district court shall take up and decide any motion asserting a victim’s right forthwith. If the district court denies the relief sought, the movant may petition the court of appeals for a writ of mandamus. The court of appeals may issue the writ on the order of a single judge pursuant to circuit rule or the Federal Rules of Appellate Procedure. The court of appeals shall take up and decide such application forthwith within 72 hours after the petition has been filed, unless the litigants, with the approval of the court, have stipulated to a different time period for consideration. In deciding such application, the court of appeals shall apply ordinary standards of appellate review. In no event shall proceedings be stayed or subject to a continuance of more than five days for purposes of enforcing this chapter. If the court of appeals denies the relief sought, the reasons for the denial shall be clearly stated on the record in a written opinion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0faac-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Error","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In any appeal in a criminal case, the Government may assert as error the district court’s denial of any crime victim’s right in the proceeding to which the appeal relates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0faad-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on relief","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In no case shall a failure to afford a right under this chapter provide grounds for a new trial. A victim may make a motion to re-open a plea or sentence only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c0faae-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the victim has asserted the right to be heard before or during the proceeding at issue and such right was denied;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0faaf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the victim petitions the court of appeals for a writ of mandamus within 14 days; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0fab0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a plea, the accused has not pled to the highest offense charged.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"This paragraph does not affect the victim’s right to restitution as provided in title 18, United States Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fab1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No cause of action","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this chapter shall be construed to authorize a cause of action for damages or to create, to enlarge, or to imply any duty or obligation to any victim or other person for the breach of which the United States or any of its officers or employees could be held liable in damages. Nothing in this chapter shall be construed to impair the prosecutorial discretion of the Attorney General or any officer under his direction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c0fab2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c0fab3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Court of appeals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “court of appeals” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c0fab4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States court of appeals for the judicial district in which a defendant is being prosecuted; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0fab5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a prosecution in the Superior Court of the District of Columbia, the District of Columbia Court of Appeals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fab6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Crime victim.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c0fab7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “crime victim” means a person directly and proximately harmed as a result of the commission of a Federal offense or an offense in the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0fab8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minors and certain other victims","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a crime victim who is under 18 years of age, incompetent, incapacitated, or deceased, the legal guardians of the crime victim or the representatives of the crime victim’s estate, family members, or any other persons appointed as suitable by the court, may assume the crime victim’s rights under this chapter, but in no event shall the defendant be named as such guardian or representative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fab9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"District court; court","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms “district court” and “court” include the Superior Court of the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c0faba-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures To Promote Compliance.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c0fabb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of enactment of this chapter, the Attorney General of the United States shall promulgate regulations to enforce the rights of crime victims and to ensure compliance by responsible officials with the obligations described in law respecting crime victims.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fabc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations promulgated under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c0fabd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate an administrative authority within the Department of Justice to receive and investigate complaints relating to the provision or violation of the rights of a crime victim;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0fabe-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require a course of training for employees and offices of the Department of Justice that fail to comply with provisions of Federal law pertaining to the treatment of crime victims, and otherwise assist such employees and offices in responding more effectively to the needs of crime victims;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0fabf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain disciplinary sanctions, including suspension or termination from employment, for employees of the Department of Justice who willfully or wantonly fail to comply with provisions of Federal law pertaining to the treatment of crime victims; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0fac0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that the Attorney General, or the designee of the Attorney General, shall be the final arbiter of the complaint, and that there shall be no judicial review of the final decision of the Attorney General by a complainant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9c0fac1-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/405/tI/s102/a"},"text":"Pub. L. 108–405, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2261"},"text":"118 Stat. 2261","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/248/tII/s212"},"text":"Pub. L. 109–248, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/616"},"text":"120 Stat. 616","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/16/s3/12"},"text":"Pub. L. 111–16, § 3(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-07"},"text":"May 7, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1608"},"text":"123 Stat. 1608","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/22/tI/s113/a"},"text":"Pub. L. 114–22, title I, § 113(a)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"2015-05-29"},"text":"May 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/240"},"text":"129 Stat. 240","children":[],"tail":", 241.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9c0fac2-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9c0fac3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9c0fac4-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 503(c) of the Victims’ Rights and Restitution Act of 1990, referred to in subsec. (a)(10), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tV/s503/c"},"text":"section 503(c) of title V of Pub. L. 101–647","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10607/c"},"text":"section 10607(c) of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification as "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s20141/c"},"text":"section 20141(c) of Title 34","children":[],"tail":", Crime Control and Law Enforcement."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Rules of Appellate Procedure, referred to in subsec. (d)(3), are set out in the Appendix to Title 28, Judiciary and Judicial Procedure.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of this chapter, referred to in subsec. (f)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/405"},"text":"Pub. L. 108–405","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb9c0fac5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3771, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/846"},"text":"62 Stat. 846","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-05-24/ch139/s59"},"text":"May 24, 1949, ch. 139, § 59","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/98"},"text":"63 Stat. 98","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1950-05-10/ch174/s1"},"text":"May 10, 1950, ch. 174, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/158"},"text":"64 Stat. 158","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1958-07-07"},"text":"July 7, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/508/s12/k"},"text":"Pub. L. 85–508, § 12(k)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/348"},"text":"72 Stat. 348","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1959-03-18"},"text":"Mar. 18, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/86/3/s14/g"},"text":"Pub. L. 86–3, § 14(g)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/11"},"text":"73 Stat. 11","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1968-10-17"},"text":"Oct. 17, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/90/578/tIII/s301/a/2"},"text":"Pub. L. 90–578, title III, § 301(a)(2)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1115"},"text":"82 Stat. 1115","children":[],"tail":", related to procedure to and including verdict, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/702/tIV"},"text":"Pub. L. 100–702, title IV","children":[],"tail":", §§ 404(a), 407, "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4651"},"text":"102 Stat. 4651","children":[],"tail":", 4652, effective "},{"tag":"date","attrib":{"date":"1988-12-01"},"text":"Dec. 1, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9c0fac6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(9), (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22/s113/a/1"},"text":"Pub. L. 114–22, § 113(a)(1)","children":[],"tail":", added pars. (9) and (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22/s113/c/1"},"text":"Pub. L. 114–22, § 113(c)(1)","children":[],"tail":", inserted “In deciding such application, the court of appeals shall apply ordinary standards of appellate review.” before “In no event shall”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22/s113/a/2"},"text":"Pub. L. 114–22, § 113(a)(2)","children":[],"tail":", inserted “, unless the litigants, with the approval of the court, have stipulated to a different time period for consideration” after “after the petition has been filed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22/s113/a/3"},"text":"Pub. L. 114–22, § 113(a)(3)","children":[],"tail":", substituted “For the purposes of this chapter:” for “For the purposes of this chapter, the term”, designated remainder of existing provisions as par. (2) and inserted par. heading, in par. (2), inserted subpar. (A) designation, heading, and “The term” before “ ‘crime victim’ means” and inserted subpar. (B) designation and heading before “In the case”, and added pars. (1) and (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (d)(5)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/16"},"text":"Pub. L. 111–16","children":[],"tail":" substituted “14 days” for “10 days”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248"},"text":"Pub. L. 109–248","children":[],"tail":" designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9c0fac7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb9c0fac8-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22/tI/s113/c/2"},"text":"Pub. L. 114–22, title I, § 113(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-05-29"},"text":"May 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/241"},"text":"129 Stat. 241","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/22/tI/s113/c/2"},"text":"“The amendment made by paragraph (1) [amending this section] shall apply with respect to any petition for a writ of mandamus filed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3771/d/3"},"text":"section 3771(d)(3) of title 18","children":[],"tail":", United States Code, that is pending on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2015-05-29"},"text":"May 29, 2015","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb9c0fac9-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/16"},"text":"Pub. L. 111–16","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-12-01"},"text":"Dec. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/16/s7"},"text":"section 7 of Pub. L. 111–16","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s109"},"text":"section 109 of Title 11","children":[],"tail":", Bankruptcy."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb9c0faca-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/405/tI/s101"},"text":"Pub. L. 108–405, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2261"},"text":"118 Stat. 2261","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/405/tI/s101"},"text":"“This title [enacting this chapter and sections 10603d and 10603e of Title 42, The Public Health and Welfare, repealing ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10606"},"text":"section 10606 of Title 42","children":[],"tail":", and enacting provisions set out as a note under this section] may be cited as the ‘Scott Campbell, Stephanie Roper, Wendy Preston, Louarna Gillis, and Nila Lynn Crime Victims’ Rights Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb9c0facb-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reports on Assertion of Crime Victims’ Rights in Criminal Cases","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/405/tI/s104/a"},"text":"Pub. L. 108–405, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2265"},"text":"118 Stat. 2265","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/405/tI/s104/a"},"text":"“Not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":"] and annually thereafter, the Administrative Office of the United States Courts, for each Federal court, shall report to Congress the number of times that a right established in chapter 237 of title 18, United States Code, is asserted in a criminal case and the relief requested is denied and, with respect to each such denial, the reason for such denial, as well as the number of times a mandamus action is brought pursuant to chapter 237 of title 18, and the result reached.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
