ndRevision","id":"idb936bbb9-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s176b"},"text":"section 176b of title 15","children":[],"tail":", U.S.C., 1940 ed., Commerce and Trade; "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s216"},"text":"section 216 of title 18","children":[],"tail":", U.S.C., 1940 ed.; "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1335"},"text":"section 1335 of title 19","children":[],"tail":", U.S.C., 1940 ed., Customs Duties (R.S. § 3167; "},{"tag":"ref","attrib":{"href":"/us/act/1894-08-27/ch349/s24"},"text":"Aug. 27, 1894, ch. 349, § 24","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/557"},"text":"28 Stat. 557","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1926-02-26/ch27/s1115"},"text":"Feb. 26, 1926, ch. 27, § 1115","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/117"},"text":"44 Stat. 117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title III, § 335, "},{"tag":"ref","attrib":{"href":"/us/stat/46/701"},"text":"46 Stat. 701","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1938-01-27/ch11/s2"},"text":"Jan. 27, 1938, ch. 11, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/8"},"text":"52 Stat. 8","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section consolidates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s176b"},"text":"section 176b of title 15","children":[],"tail":", U.S.C., 1940 ed., Commerce and Trade; "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s216"},"text":"section 216 of title 18","children":[],"tail":", U.S.C., 1940 ed., and "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1335"},"text":"section 1335 of title 19","children":[],"tail":", U.S.C., 1940 ed., Customs Duties."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “or of any department or agency thereof” and words “such department or agency” were inserted so as to eliminate any possible ambiguity as to scope of section. (See definition of “department” and “agency” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s6"},"text":"section 6 of this title","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"References to the offenses as misdemeanors, contained in all of said sections, were omitted in view of definitive ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s216"},"text":"section 216 of title 18","children":[],"tail":", U.S.C., 1940 ed., relating to publication of income tax data by “any person”, were omitted as covered by "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s55/f/1"},"text":"section 55(f)(1) of title 26","children":[],"tail":", U.S.C., 1940 ed., Internal Revenue Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in translations and phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb936bbba-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb936bbbb-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Antitrust Civil Process Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/664"},"text":"Pub. L. 87–664","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-19"},"text":"Sept. 19, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/548"},"text":"76 Stat. 548","children":[],"tail":", which is classified principally to chapter 34 (§ 1311 et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1311"},"text":"section 1311 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb936bbbc-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289"},"text":"Pub. L. 110–289","children":[],"tail":" substituted “Federal Housing Finance Agency” for “Office of Federal Housing Enterprise Oversight”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/347"},"text":"Pub. L. 107–347","children":[],"tail":" inserted “or being an employee of a private sector organization who is or was assigned to an agency under chapter 37 of title 5,” after “("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1311–131"},"text":"15 U.S.C. 1311–131","children":[],"tail":"4),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" substituted “fined under this title” for “fined not more than $1,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" inserted “any person acting on behalf of the Office of Federal Housing Enterprise Oversight,” after “or agency thereof,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/349"},"text":"Pub. L. 96–349","children":[],"tail":" provided for punishment and removal from office of an agent of the Department of Justice as defined in the Antitrust Civil Process Act for disclosure of confidential information."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb936bbbd-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb936bbbe-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/347"},"text":"Pub. L. 107–347","children":[],"tail":" effective 120 days after "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/347/s402/a"},"text":"section 402(a) of Pub. L. 107–347","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3601"},"text":"section 3601 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
