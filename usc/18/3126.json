{"tag":"section","attrib":{"id":"idb98ca401-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3126"},"text":null,"children":[{"tag":"num","attrib":{"value":"3126"},"text":"§ 3126.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports concerning pen registers and trap and trace devices","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall annually report to Congress on the number of pen register orders and orders for trap and trace devices applied for by law enforcement agencies of the Department of Justice, which report shall include information concerning—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb98ca402-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3126/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period of interceptions authorized by the order, and the number and duration of any extensions of the order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb98ca403-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3126/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense specified in the order or application, or extension of an order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb98ca404-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3126/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of investigations involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb98ca405-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3126/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and nature of the facilities affected; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb98ca406-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3126/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity, including district, of the applying investigative or law enforcement agency making the application and the person authorizing the order.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb98ca407-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/508/tIII/s301/a"},"text":"Pub. L. 99–508, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1871"},"text":"100 Stat. 1871","children":[],"tail":", § 3125; renumbered § 3126, "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7092/a/1"},"text":"Pub. L. 100–690, title VII, § 7092(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4410"},"text":"102 Stat. 4410","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/197/s3"},"text":"Pub. L. 106–197, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-02"},"text":"May 2, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/247"},"text":"114 Stat. 247","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb98ca408-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb98ca409-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb98ca40a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3126 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3127"},"text":"section 3127 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb98ca40b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/197"},"text":"Pub. L. 106–197","children":[],"tail":" substituted “, which report shall include information concerning—” and pars. (1) to (5) for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3125"},"text":"section 3125 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb98ca40c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb98ca40d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", and, in case of conduct pursuant to court order or extension, applicable only with respect to court orders and extensions made after such date, with special rule for State authorizations of interceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/508/s302"},"text":"section 302 of Pub. L. 99–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3121"},"text":"section 3121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb98ca40e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report on Use of DCS 1000 (Carnivore) To Implement Orders Under Section 3123","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/dA/tIII/s305/a"},"text":"Pub. L. 107–273, div. A, title III, § 305(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1782"},"text":"116 Stat. 1782","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/273/dA/tIII/s305/a"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“At the same time that the Attorney General submits to Congress the annual reports required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3126"},"text":"section 3126 of title 18","children":[],"tail":", United States Code, that are respectively next due after the end of each of the fiscal years 2002 and 2003, the Attorney General shall also submit to the Chairmen and ranking minority members of the Committees on the Judiciary of the Senate and of the House of Representatives a report, covering the same respective time period, on the number of orders under section 3123 applied for by law enforcement agencies of the Department of Justice whose implementation involved the use of the DCS 1000 program (or any subsequent version of such program), which report shall include information concerning—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period of interceptions authorized by the order, and the number and duration of any extensions of the order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense specified in the order or application, or extension of an order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of investigations involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and nature of the facilities affected;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity of the applying investigative or law enforcement agency making the application for an order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific persons authorizing the use of the DCS 1000 program (or any subsequent version of such program) in the implementation of such order.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
