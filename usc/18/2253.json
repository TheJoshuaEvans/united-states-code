alNotes","id":"idb94e89ac-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb94e89ad-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2253 was redesignated ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2256"},"text":"section 2256 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb94e89ae-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/s505/b/1"},"text":"Pub. L. 109–248, § 505(b)(1)","children":[],"tail":", inserted “or who is convicted of an offense under section 2252B of this chapter,” after “2260 of this chapter” and substituted “an offense under chapter 109A” for “an offense under section 2421, 2422, or 2423 of chapter 117” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/s505/b/2"},"text":"Pub. L. 109–248, § 505(b)(2)","children":[],"tail":", inserted “2252A, 2252B, or 2260” after “2252”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/s505/b/3"},"text":"Pub. L. 109–248, § 505(b)(3)","children":[],"tail":", inserted “or any property traceable to such property” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/109/248/s505/c"},"text":"Pub. L. 109–248, § 505(c)","children":[],"tail":", added subsec. (b) and struck out former subsecs. (b) to ("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":") which related, respectively, to third party transfers, protective orders, warrant of seizure, order of forfeiture, execution of order, disposition of property, authority of Attorney General, applicability of civil forfeiture provisions, bar on intervention, jurisdiction to enter orders, depositions, third party interests, construction of section, and substitute assets."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/314"},"text":"Pub. L. 105–314","children":[],"tail":" substituted “2252, 2252A, or 2260 of this chapter, or who is convicted of an offense under section 2421, 2422, or 2423 of chapter 117,” for “or 2252 of this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330011/m/1"},"text":"Pub. L. 103–322, § 330011(m)(1)","children":[],"tail":", amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/s3564/1"},"text":"Pub. L. 101–647, § 3564(1)","children":[],"tail":". See 1990 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/s3564/1"},"text":"Pub. L. 101–647, § 3564(1)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330011/m/1"},"text":"Pub. L. 103–322, § 330011(m)(1)","children":[],"tail":", substituted “section 2251” for “sections 2251” in introductory provisions and in par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/s3564/2"},"text":"Pub. L. 101–647, § 3564(2)","children":[],"tail":", substituted “under section 616 of the Tariff Act of 1930” for “in accordance with the provisions of section 1616, title 19, United States Code”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" amended section generally, substituting subsecs. (a) to ("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":") for former subsecs. (a) to (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb94e89af-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb94e89b0-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330011/m"},"text":"Pub. L. 103–322, title XXXIII, § 330011(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2145"},"text":"108 Stat. 2145","children":[],"tail":", provided that the amendment made by that section is effective as of "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
