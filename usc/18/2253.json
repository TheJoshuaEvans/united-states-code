{"tag":"section","attrib":{"id":"idb94e89a4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2253"},"text":null,"children":[{"tag":"num","attrib":{"value":"2253"},"text":"§ 2253.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal forfeiture","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb94e89a5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2253/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Property Subject to Criminal Forfeiture","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person who is convicted of an offense under this chapter involving a visual depiction described in section 2251, 2251A, 2252, 2252A, or 2260 of this chapter or who is convicted of an offense under section 2252B of this chapter,,","children":[{"tag":"ref","attrib":{"idref":"fn002149"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002149"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The extra comma probably should follow “2260 of this chapter”."}],"tail":" or who is convicted of an offense under chapter 109A, shall forfeit to the United States such person’s interest in—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb94e89a6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2253/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any visual depiction described in section 2251, 2251A, or 2252 ","children":[{"tag":"ref","attrib":{"idref":"fn002150"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002150"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “2251A, 2252,”."}],"tail":" 2252A, 2252B, or 2260 of this chapter, or any book, magazine, periodical, film, videotape, or other matter which contains any such visual depiction, which was produced, transported, mailed, shipped or received in violation of this chapter;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94e89a7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2253/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any property, real or personal, constituting or traceable to gross profits or other proceeds obtained from such offense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94e89a8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2253/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any property, real or personal, used or intended to be used to commit or to promote the commission of such offense or any property traceable to such property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb94e89a9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2253/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 413 of the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s853"},"text":"21 U.S.C. 853","children":[],"tail":") with the exception of subsections (a) and (d), applies to the criminal forfeiture of property pursuant to subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb94e89aa-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/292/s6"},"text":"Pub. L. 98–292, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-05-21"},"text