{"tag":"section","attrib":{"id":"idb94e898f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2252B"},"text":null,"children":[{"tag":"num","attrib":{"value":"2252B"},"text":"§ 2252B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Misleading domain names on the Internet","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb94e8990-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2252B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever knowingly uses a misleading domain name on the Internet with the intent to deceive a person into viewing material constituting obscenity shall be fined under this title or imprisoned not more than 2 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb94e8991-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2252B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever knowingly uses a misleading domain name on the Internet with the intent to deceive a minor into viewing material that is harmful to minors on the Internet shall be fined under this title or imprisoned not more than 10 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb94e8992-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2252B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this section, a domain name that includes a word or words to indicate the sexual content of the site, such as “sex” or “porn”, is not misleading.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb94e8993-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2252B/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purposes of this section, the term “material that is harmful to minors” means any communication, consisting of nudity, sex, or excretion, that, taken as a whole and with reference to its context—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb94e8994-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2252B/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" predominantly appeals to a prurient interest of minors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94e8995-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2252B/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is patently offensive to prevailing standards in the adult community as a whole with respect to what is suitable material for minors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94e8996-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2252B/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lacks serious literary, artistic, political, or scientific value for minors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb94e8997-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2252B/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of subsection (d), the term “sex” means acts of masturbation, sexual intercourse, or physcial ","children":[{"tag":"ref","attrib":{"idref":"fn002148"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002148"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “physical”."}],"tail":" contact with a person’s genitals, or the condition of human male or female genitals when in a state of sexual stimulation or arousal."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb94e8998-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21/tV/s521/a"},"text":"Pub. L. 108–21, title V, § 521(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-30"},"text":"Apr. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/686"},"text":"117 Stat. 686","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/248/tII/s206/b/4"},"text":"Pub. L. 109–248, title II, § 206(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/614"},"text":"120 Stat. 614","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb94e8999-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb94e899a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb94e899b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248"},"text":"Pub. L. 109–248","children":[],"tail":" substituted “10 years” for “4 years”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
