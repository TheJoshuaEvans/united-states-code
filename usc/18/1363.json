{"tag":"section","attrib":{"id":"idb91c7d82-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1363"},"text":null,"children":[{"tag":"num","attrib":{"value":"1363"},"text":"§ 1363.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Buildings or property within special maritime and territorial jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, within the special maritime and territorial jurisdiction of the United States, willfully and maliciously destroys or injures any structure, conveyance, or other real or personal property, or attempts or conspires to do such an act, shall be fined under this title or imprisoned not more than five years, or both, and if the building be a dwelling, or the life of any person be placed in jeopardy, shall be fined under this title or imprisoned not more than twenty years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb91c7d83-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/764"},"text":"62 Stat. 764","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", (K), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tVII/s703"},"text":"Pub. L. 104–132, title VII, § 703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1294"},"text":"110 Stat. 1294","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tVIII/s811/d"},"text":"Pub. L. 107–56, title VIII, § 811(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/381"},"text":"115 Stat. 381","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91c7d84-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb91c7d85-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., §§ 464, 465 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321"},"text":"Mar. 4, 1909, ch. 321","children":[],"tail":", §§ 285, 286, "},{"tag":"ref","attrib":{"href":"/us/stat/35/1144"},"text":"35 Stat. 1144","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Said sections were consolidated and rewritten both as to form and substance. The provisions relating to arson are incorporated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s81"},"text":"section 81 of this title","children":[],"tail":". (See reviser’s note under said "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s81"},"text":"section 81 of this title","children":[],"tail":" for explanation of changes.)"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb91c7d86-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb91c7d87-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56"},"text":"Pub. L. 107–56","children":[],"tail":" struck out “or attempts to destroy or injure” after “destroys or injures” and inserted “or attempts or conspires to do such an act,” after “personal property,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132"},"text":"Pub. L. 104–132","children":[],"tail":" substituted “any structure, conveyance, or other real or personal property” for “any building, structure or vessel, any machinery or building materials and supplies, military or naval stores, munitions of war or any structural aids or appliances for navigation or shipping”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $1,000” after “shipping, shall be” and for “fined not more than $5,000” after “jeopardy, shall be”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
