l":", "},{"tag":"html:a","attrib":{"href":"/us/stat/66/72"},"text":"66 Stat. 72","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1952-07-09/ch600"},"text":"July 9, 1952, ch. 600","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/66/479"},"text":"66 Stat. 479","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9c5dc42-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9c5dc43-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9c5dc44-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb9c5dc45-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Expenditures; Inmate Telephone System","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/b/tI/s108"},"text":"Pub. L. 105–277, div. A, § 101(b) [title I, § 108]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-50"},"text":"112 Stat. 2681–50","children":[],"tail":", 2681–67, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/277/dA/s101/b/tI/s108"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“For fiscal year 1999 and thereafter, the Director of the Bureau of Prisons may make expenditures out of the Commissary Fund of the Federal Prison System, regardless of whether any such expenditure is security-related, for programs, goods, and services for the benefit of inmates (to the extent the provision of those programs, goods, or services to inmates is not otherwise prohibited by law), including—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the installation, operation, and maintenance of the Inmate Telephone System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment of all the equipment purchased or leased in connection with the Inmate Telephone System; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the salaries, benefits, and other expenses of personnel who install, operate, and maintain the Inmate Telephone System.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb9c5dc46-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deposit or Investment of Excess Amounts in Federal Prison Commissary Fund","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 108 of H.R. 2076, One Hundred Fourth Congress, as passed by the House of Representatives on ","children":[{"tag":"date","attrib":{"date":"1995-12-06"},"text":"Dec. 6, 1995","children":[],"tail":", and as enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/104/91/tI/s101/a"},"text":"Pub. L. 104–91, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-01-06"},"text":"Jan. 6, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/11"},"text":"110 Stat. 11","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/99/tII/s211"},"text":"Pub. L. 104–99, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-01-26"},"text":"Jan. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/37"},"text":"110 Stat. 37","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/99/tII/s211"},"text":"“For fiscal year 1996 and each fiscal year thereafter, amounts in the Federal Prison System’s Commissary Fund, Federal Prisons, which are not currently needed for operations, shall be kept on deposit or invested in obligations of, or guaranteed by, the United States and all earnings on such investment shall be deposited in the Commissary Fund.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation act:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/317/tI/s107"},"text":"Pub. L. 103–317, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-26"},"text":"Aug. 26, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1735"},"text":"108 Stat. 1735","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
