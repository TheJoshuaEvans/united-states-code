{"tag":"section","attrib":{"id":"idb9619c87-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2325"},"text":null,"children":[{"tag":"num","attrib":{"value":"2325"},"text":"§ 2325.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter, the term “telemarketing or email marketing”—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9619c88-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2325/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means a plan, program, promotion, or campaign that is conducted to induce—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9619c89-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2325/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchases of goods or services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9619c8a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2325/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participation in a contest or sweepstakes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9619c8b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2325/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a charitable contribution, donation, or gift of money or any other thing of value;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9619c8c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2325/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investment for financial profit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9619c8d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2325/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participation in a business opportunity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9619c8e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2325/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commitment to a loan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9619c8f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2325/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participation in a fraudulent medical study, research study, or pilot study,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"by use of one or more interstate telephone calls, emails, text messages, or electronic instant messages initiated either by a person who is conducting the plan, program, promotion, or campaign or by a prospective purchaser or contest or sweepstakes participant or charitable contributor, donor, or investor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9619c90-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2325/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include the solicitation through the posting, publication, or mailing of a catalog or brochure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9619c91-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2325/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains a written description or illustration of the goods, services, or other opportunities being offered;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9619c92-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2325/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the business address of the solicitor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9619c93-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2325/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes multiple pages of written material or illustration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9619c94-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2325/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been issued not less frequently than once a year,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"if the person making the solicitation does not solicit customers by telephone, email, text message, or electronic instant message, but only receives interstate telephone calls, emails, text messages, or electronic instant messages initiated by customers in response to the written materials, whether in hard copy or digital format, and in response to those interstate telephone calls, emails, text messages, or electronic instant messages does not conduct further solicitation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9619c95-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/70/tIV/s402/a/2"},"text":"Pub. L. 115–70, title IV, § 402(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-10-18"},"text":"Oct. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1213"},"text":"131 Stat. 1213","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9619c96-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9619c97-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb9619c98-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2325, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXV/s250002/a/2"},"text":"Pub. L. 103–322, title XXV, § 250002(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2082"},"text":"108 Stat. 2082","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tX/s1011/d"},"text":"Pub. L. 107–56, title X, § 1011(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/396"},"text":"115 Stat. 396","children":[],"tail":", related to definition of “telemarketing”, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/70/tIV/s402/a/2"},"text":"Pub. L. 115–70, title IV, § 402(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-10-18"},"text":"Oct. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1213"},"text":"131 Stat. 1213","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9619c99-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idb9619c9a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXV/s250001"},"text":"Pub. L. 103–322, title XXV, § 250001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2081"},"text":"108 Stat. 2081","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/322/tXXV/s250001"},"text":"“This Act [probably should be “title”, meaning title XXV (§§ 250001–250008) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":", which enacted this chapter, amended sections 1029, 1341, and 3059 of this title, and enacted provisions set out as notes under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s994"},"text":"section 994 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure] may be cited as the ‘Senior Citizens Against Marketing Scams Act of 1994’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb9619c9b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Information Network","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXV/s250008"},"text":"Pub. L. 103–322, title XXV, § 250008","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2088"},"text":"108 Stat. 2088","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s604/b/29"},"text":"Pub. L. 104–294, title VI, § 604(b)(29)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3508"},"text":"110 Stat. 3508","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/294/tVI/s604/b/29"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hotline","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall, subject to the availability of appropriations, establish a national toll-free hotline for the purpose of—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing general information on telemarketing fraud to interested persons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gathering information related to possible violations of provisions of law amended by this title [see Short Title note above].","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Action on Information Gathered","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Attorney General shall work in cooperation with the Federal Trade Commission to ensure that information gathered through the hotline shall be acted on in an appropriate manner.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
