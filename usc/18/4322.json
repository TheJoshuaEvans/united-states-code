{"tag":"section","attrib":{"id":"idb9d1c432-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322"},"text":null,"children":[{"tag":"num","attrib":{"value":"4322"},"text":"§ 4322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of restraints on prisoners during the period of pregnancy, labor, and postpartum recovery prohibited","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9d1c433-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), beginning on the date on which pregnancy is confirmed by a healthcare professional, and ending at the conclusion of postpartum recovery, a prisoner in the custody of the Bureau of Prisons, or in the custody of the United States Marshals Service pursuant to section 4086, shall not be placed in restraints.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9d1c434-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9d1c435-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The prohibition under subsection (a) shall not apply if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9d1c436-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an appropriate corrections official, or a United States marshal, as applicable, makes a determination that the prisoner—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9d1c437-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an immediate and credible flight risk that cannot reasonably be prevented by other means; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9d1c438-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" poses an immediate and serious threat of harm to herself or others that cannot reasonably be prevented by other means; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9d1c439-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a healthcare professional responsible for the health and safety of the prisoner determines that the use of restraints is appropriate for the medical safety of the prisoner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9d1c43a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Least restrictive restraints","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case that restraints are used pursuant to an exception under paragraph (1), only the least restrictive restraints necessary to prevent the harm or risk of escape described in paragraph (1) may be used.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9d1c43b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9d1c43c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The exceptions under paragraph (1) may not be applied—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9d1c43d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to place restraints around the ankles, legs, or waist of a prisoner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9d1c43e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to restrain a prisoner’s hands behind her back;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9d1c43f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to restrain a prisoner using 4-point restraints; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9d1c440-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/b/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to attach a prisoner to another prisoner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9d1c441-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Medical request","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding paragraph (1), upon the request of a healthcare professional who is responsible for the health and safety of a prisoner, a corrections official or United States marshal, as applicable, shall refrain from using restraints on the prisoner or shall remove restraints used on the prisoner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9d1c442-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9d1c443-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report to the director and healthcare professional","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a corrections official or United States marshal uses restraints on a prisoner under subsection (b)(1), that official or marshal shall submit, not later than 30 days after placing the prisoner in restraints, to the Director of the Bureau of Prisons or the Director of the United States Marshals Service, as applicable, and to the healthcare professional responsible for the health and safety of the prisoner, a written report that describes the facts and circumstances surrounding the use of restraints, and includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9d1c444-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasoning upon which the determination to use restraints was made;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9d1c445-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the details of the use of restraints, including the type of restraints used and length of time during which restraints were used; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9d1c446-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any resulting physical effects on the prisoner observed by or known to the corrections official or United States marshal, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9d1c447-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Supplemental report to the director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon receipt of a report under paragraph (1), the healthcare professional responsible for the health and safety of the prisoner may submit to the Director such information as the healthcare professional determines is relevant to the use of restraints on the prisoner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9d1c448-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report to judiciary committees.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9d1c449-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of enactment of this section, and annually thereafter, the Director of the Bureau of Prisons and the Director of the United States Marshals Service shall each submit to the Judiciary Committee of the Senate and of the House of Representatives a report that certifies compliance with this section and includes the information required to be reported under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9d1c44a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Personally identifiable information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The report under this paragraph shall not contain any personally identifiable information of any prisoner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9d1c44b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 48 hours after the confirmation of a prisoner’s pregnancy by a healthcare professional, that prisoner shall be notified by an appropriate healthcare professional, corrections official, or United States marshal, as applicable, of the restrictions on the use of restraints under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9d1c44c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Violation Reporting Process","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Bureau of Prisons, in consultation with the Director of the United States Marshals Service, shall establish a process through which a prisoner may report a violation of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9d1c44d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9d1c44e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Bureau of Prisons and the Director of the United States Marshals Service shall each develop training guidelines regarding the use of restraints on female prisoners during the period of pregnancy, labor, and postpartum recovery, and shall incorporate such guidelines into appropriate training programs. Such training guidelines shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9d1c44f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how to identify certain symptoms of pregnancy that require immediate referral to a healthcare professional;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9d1c450-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" circumstances under which the exceptions under subsection (b) would apply;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9d1c451-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case that an exception under subsection (b) applies, how to apply restraints in a way that does not harm the prisoner, the fetus, or the neonate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9d1c452-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information required to be reported under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9d1c453-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/f/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right of a healthcare professional to request that restraints not be used, and the requirement under subsection (b)(3)(B) to comply with such a request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9d1c454-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Development of guidelines","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In developing the guidelines required by paragraph (1), the Directors shall each consult with healthcare professionals with expertise in caring for women during the period of pregnancy and postpartum recovery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9d1c455-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9d1c456-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Postpartum recovery","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “postpartum recovery” means the 12-week period, or longer as determined by the healthcare professional responsible for the health and safety of the prisoner, following delivery, and shall include the entire period that the prisoner is in the hospital or infirmary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9d1c457-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prisoner","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “prisoner” means a person who has been sentenced to a term of imprisonment pursuant to a conviction for a Federal criminal offense, or a person in the custody of the Bureau of Prisons, including a person in a Bureau of Prisons contracted facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9d1c458-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4322/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restraints","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “restraints” means any physical or mechanical device used to control the movement of a prisoner’s body, limbs, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9d1c459-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/391/tIII/s301/a"},"text":"Pub. L. 115–391, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5217"},"text":"132 Stat. 5217","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9d1c45a-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9d1c45b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9d1c45c-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (c)(3)(A), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/391"},"text":"Pub. L. 115–391","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
