{"tag":"section","attrib":{"id":"idb8ea7075-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s879"},"text":null,"children":[{"tag":"num","attrib":{"value":"879"},"text":"§ 879.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Threats against former Presidents and certain other persons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8ea7076-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s879/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whoever knowingly and willfully threatens to kill, kidnap, or inflict bodily harm upon—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8ea7077-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s879/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a former President or a member of the immediate family of a former President;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8ea7078-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s879/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the immediate family of the President, the President-elect, the Vice President, or the Vice President-elect;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8ea7079-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s879/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a major candidate for the office of President or Vice President, or a member of the immediate family of such candidate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8ea707a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s879/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person protected by the Secret Service under section 3056(a)(6);","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title or imprisoned not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8ea707b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s879/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8ea707c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s879/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “immediate family” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8ea707d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s879/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to subsection (a)(1) of this section, the spouse of a former President during a former President’s lifetime, the surviving spouse of a former President until the surviving spouse’s death or remarriage, and minor children of a former President until they reach sixteen years of age; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8ea707e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s879/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to subsection (a)(2) and (a)(3) of this section, a person to whom the President, President-elect, Vice President, Vice President-elect, or major candidate for the office of President or Vice President—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8ea707f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s879/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is related by blood, marriage, or adoption; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8ea7080-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s879/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stands in loco parentis;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8ea7081-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s879/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “major candidate for the office of President or Vice President” means a candidate referred to in subsection (a)(7) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3056"},"text":"section 3056 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8ea7082-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s879/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “President-elect” and “Vice President-elect” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s871/b"},"text":"section 871(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8ea7083-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attri