ag":"note","attrib":{"topic":"amendments","id":"idb8ea7086-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/272"},"text":"Pub. L. 117–272","children":[],"tail":" substituted “the spouse of a former President during a former President’s lifetime, the surviving spouse of a former President until the surviving spouse’s death or remarriage” for “the wife of a former President during his lifetime, the widow of a former President until her death or remarriage”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/544/s2/b/1"},"text":"Pub. L. 106–544, § 2(b)(1)","children":[],"tail":", struck out “protected by the Secret Service” after “other persons” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/544/s2/a/1"},"text":"Pub. L. 106–544, § 2(a)(1)","children":[],"tail":"–(4), in par. (3), substituted “a member of the immediate family” for “the spouse”, added par. (4), and, in concluding provisions, struck out “who is protected by the Secret Service as provided by law,” before “shall be fined” and substituted “5 years” for “three years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/544/s2/a/5"},"text":"Pub. L. 106–544, § 2(a)(5)","children":[],"tail":", in introductory provisions, inserted “and (a)(3)” after “subsection (a)(2)” and substituted “Vice President-elect, or major candidate for the office of President or Vice President” for “or Vice President-elect”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $1,000” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/587"},"text":"Pub. L. 98–587","children":[],"tail":" substituted “subsection (a)(7) of "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3056"},"text":"section 3056 of this title","children":[],"tail":"” for “the first section of the joint resolution entitled ‘Joint resolution to authorize the United States Secret Service to furnish protection to major Presidential or Vice Presidential candidates’, approved "},{"tag":"date","attrib":{"date":"1968-06-06"},"text":"June 6, 1968","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3056"},"text":"18 U.S.C. 3056","children":[],"tail":" note)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8ea7087-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idb8ea7088-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of the functions, personnel, assets, and obligations of the United States Secret Service, including the functions of the Secretary of the Treasury relating thereto, to the Secretary of Homeland Security, and for treatment of related references, see sections 381, 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
