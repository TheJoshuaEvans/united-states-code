{"tag":"section","attrib":{"id":"idb91a0c45-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1203"},"text":null,"children":[{"tag":"num","attrib":{"value":"1203"},"text":"§ 1203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hostage taking","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb91a0c46-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b) of this section, whoever, whether inside or outside the United States, seizes or detains and threatens to kill, to injure, or to continue to detain another person in order to compel a third person or a governmental organization to do or abstain from doing any act as an explicit or implicit condition for the release of the person detained, or attempts or conspires to do so, shall be punished by imprisonment for any term of years or for life and, if the death of any person results, shall be punished by death or life imprisonment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91a0c47-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91a0c48-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1203/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" It is not an offense under this section if the conduct required for the offense occurred outside the United States unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb91a0c49-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1203/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offender or the person seized or detained is a national of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91a0c4a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1203/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offender is found in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91a0c4b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1203/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the governmental organization sought to be compelled is the Government of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91a0c4c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1203/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is not an offense under this section if the conduct required for the offense occurred inside the United States, each alleged offender and each person seized or detained are nationals of the United States, and each alleged offender is found in the United States, unless the governmental organization sought to be compelled is the Government of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91a0c4d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1203/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As used in this section, the term “national of the United States” has the meaning given such term in section 101(a)(22) of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/22"},"text":"8 U.S.C. 1101(a)(22)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb91a0c4e-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s2002/a"},"text":"Pub. L. 98–473, title II, § 2002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2186"},"text":"98 Stat. 2186","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7028"},"text":"Pub. L. 100–690, title VII, § 7028","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4397"},"text":"102 Stat. 4397","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tVI/s60003/a/10"},"text":"Pub. L. 103–322, title VI, § 60003(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1969"},"text":"108 Stat. 1969","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tVII/s723/a/1"},"text":"Pub. L. 104–132, title VII, § 723(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1300"},"text":"110 Stat. 1300","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91a0c4f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb91a0c50-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb91a0c51-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132"},"text":"Pub. L. 104–132","children":[],"tail":" inserted “or conspires” after “attempts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" inserted before period at end “and, if the death of any person results, shall be punished by death or life imprisonment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" substituted “(c) As” for “(C) As”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb91a0c52-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb91a0c53-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s2003"},"text":"Pub. L. 98–473, title II, § 2003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2186"},"text":"98 Stat. 2186","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/473/tII/s2003"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“This part [part A (§§ 2001–2003) of chapter XX of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":", enacting this section and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1201"},"text":"section 1201 of this title","children":[],"tail":"] and the amendments made by this part shall take effect on the later of—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the enactment of this joint resolution [","children":[{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":"]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date the International Convention Against the Taking of Hostages has come into force and the United States has become a party to that convention [the convention entered into force ","children":[{"tag":"date","attrib":{"date":"1983-06-06"},"text":"June 6, 1983","children":[],"tail":"; and entered into force for the United States "},{"tag":"date","attrib":{"date":"1985-01-06"},"text":"Jan. 6, 1985","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
