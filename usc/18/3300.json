{"tag":"section","attrib":{"id":"idb99ad4e6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3300"},"text":null,"children":[{"tag":"num","attrib":{"value":"3300"},"text":"§ 3300.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recruitment or use of child soldiers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No person may be prosecuted, tried, or punished for a violation of section 2442 unless the indictment or the information is filed not later than 10 years after the commission of the offense.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb99ad4e7-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/340/s2/a/2"},"text":"Pub. L. 110–340, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3736"},"text":"122 Stat. 3736","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
