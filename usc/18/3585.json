{"tag":"section","attrib":{"id":"idb9ade7f1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3585"},"text":null,"children":[{"tag":"num","attrib":{"value":"3585"},"text":"§ 3585.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation of a term of imprisonment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9ade7f2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3585/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commencement of Sentence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A sentence to a term of imprisonment commences on the date the defendant is received in custody awaiting transportation to, or arrives voluntarily to commence service of sentence at, the official detention facility at which the sentence is to be served.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9ade7f3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3585/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Credit for Prior Custody","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A defendant shall be given credit toward the service of a term of imprisonment for any time he has spent in official detention prior to the date the sentence commences—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9ade7f4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3585/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a result of the offense for which the sentence was imposed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9ade7f5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3585/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a result of any other charge for which the defendant was arrested after the commission of the offense for which the sentence was imposed;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"that has not been credited against another sentence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9ade7f6-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s212/a/2"},"text":"Pub. L. 98–473, title II, § 212(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2001"},"text":"98 Stat. 2001","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9ade7f7-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9ade7f8-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9ade7f9-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1987-11-01"},"text":"Nov. 1, 1987","children":[],"tail":", and applicable only to offenses committed after the taking effect of this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/s235/a/1"},"text":"section 235(a)(1) of Pub. L. 98–473","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3551"},"text":"section 3551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
