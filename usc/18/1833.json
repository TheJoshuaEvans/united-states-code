{"tag":"section","attrib":{"id":"idb9344a69-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1833"},"text":null,"children":[{"tag":"num","attrib":{"value":"1833"},"text":"§ 1833.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions to prohibitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9344a6a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1833/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This chapter does not prohibit or create a private right of action for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9344a6b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1833/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any otherwise lawful activity conducted by a governmental entity of the United States, a State, or a political subdivision of a State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9344a6c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1833/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disclosure of a trade secret in accordance with subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9344a6d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1833/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Immunity From Liability for Confidential Disclosure of a Trade Secret to the Government or in a Court Filing.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9344a6e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1833/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Immunity","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual shall not be held criminally or civilly liable under any Federal or State trade secret law for the disclosure of a trade secret that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9344a6f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1833/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is made—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9344a70-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1833/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in confidence to a Federal, State, or local government official, either directly or indirectly, or to an attorney; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9344a71-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1833/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solely for the purpose of reporting or investigating a suspected violation of law; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9344a72-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1833/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is made in a complaint or other document filed in a lawsuit or other proceeding, if such filing is made under seal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9344a73-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1833/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of trade secret information in anti-retaliation lawsuit","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual who files a lawsuit for retaliation by an employer for reporting a suspected violation of law may disclose the trade secret to the attorney of the individual and use the trade secret information in the court proceeding, if the individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9344a74-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1833/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" files any document containing the trade secret under seal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9344a75-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1833/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not disclose the trade secret, except pursuant to court order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9344a76-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1833/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9344a77-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1833/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An employer shall provide notice of the immunity set forth in this subsection in any contract or agreement with an employee that governs the use of a trade secret or other confidential information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9344a78-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1833/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policy document","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An employer shall be considered to be in compliance with the notice requirement in subparagraph (A) if the employer provides a cross-reference to a policy document provided to the employee that sets forth the employer’s reporting policy for a suspected violation of law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9344a79-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1833/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Non-compliance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If an employer does not comply with the notice requirement in subparagraph (A), the employer may not be awarded exemplary damages or attorney fees under subparagraph (C) or (D) of section 1836(b)(3) in an action against an employee to whom notice was not provided.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9344a7a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1833/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This paragraph shall apply to contracts and agreements that are entered into or updated after the date of enactment of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9344a7b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1833/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employee defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this subsection, the term “employee” includes any individual performing work as a contractor or consultant for an employer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9344a7c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1833/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as expressly provided for under this subsection, nothing in this subsection shall be construed to authorize, or limit liability for, an act that is otherwise prohibited by law, such as the unlawful access of material by unauthorized means.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9344a7d-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294/tI/s101/a"},"text":"Pub. L. 104–294, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3489"},"text":"110 Stat. 3489","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/153"},"text":"Pub. L. 114–153","children":[],"tail":", §§ 2(c), 7(a), "},{"tag":"date","attrib":{"date":"2016-05-11"},"text":"May 11, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/381"},"text":"130 Stat. 381","children":[],"tail":", 384.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9344a7e-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9344a7f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9344a80-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this subsection, referred to in subsec. (b)(3)(D), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/153"},"text":"Pub. L. 114–153","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2016-05-11"},"text":"May 11, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9344a81-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/153/s7/a/1"},"text":"Pub. L. 114–153, § 7(a)(1)","children":[],"tail":", (3), designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/153/s2/c"},"text":"Pub. L. 114–153, § 2(c)","children":[],"tail":", inserted “or create a private right of action for” after “prohibit” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/153/s7/a/2"},"text":"Pub. L. 114–153, § 7(a)(2)","children":[],"tail":", substituted “the disclosure of a trade secret in accordance with subsection (b)” for “the reporting of a suspected violation of law to any governmental entity of the United States, a State, or a political subdivision of a State, if such entity has lawful authority with respect to that violation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9344a82-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb9344a83-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/153/s2/e"},"text":"Pub. L. 114–153, § 2(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-05-11"},"text":"May 11, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/381"},"text":"130 Stat. 381","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/153/s2/e"},"text":"“The amendments made by this section [amending this section and sections 1836 and 1839 of this title] shall apply with respect to any misappropriation of a trade secret (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1839"},"text":"section 1839 of title 18","children":[],"tail":", United States Code, as amended by this section) for which any act occurs on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2016-05-11"},"text":"May 11, 2016","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb9344a84-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/153/s2/f"},"text":"Pub. L. 114–153, § 2(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-05-11"},"text":"May 11, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/382"},"text":"130 Stat. 382","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/153/s2/f"},"text":"“Nothing in the amendments made by this section [amending this section and sections 1836 and 1839 of this title] shall be construed to modify the rule of construction under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1838"},"text":"section 1838 of title 18","children":[],"tail":", United States Code, or to preempt any other provision of law.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb9344a85-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/153/s2"},"text":"Section 2 of Pub. L. 114–153","children":[],"tail":" to Other Laws"}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/153/s2/g"},"text":"Pub. L. 114–153, § 2(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-05-11"},"text":"May 11, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/382"},"text":"130 Stat. 382","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/153/s2/g"},"text":"“This section [amending this section and sections 1836 and 1839 of this title and enacting provisions set out as notes under this section] and the amendments made by this section shall not be construed to be a law pertaining to intellectual property for purposes of any other Act of Congress.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
