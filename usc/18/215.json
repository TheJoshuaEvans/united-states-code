{"tag":"section","attrib":{"id":"idb8bf9042-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s215"},"text":null,"children":[{"tag":"num","attrib":{"value":"215"},"text":"§ 215.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receipt of commissions or gifts for procuring loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8bf9043-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s215/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whoever—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8bf9044-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s215/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" corruptly gives, offers, or promises anything of value to any person, with intent to influence or reward an officer, director, employee, agent, or attorney of a financial institution in connection with any business or transaction of such institution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf9045-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s215/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as an officer, director, employee, agent, or attorney of a financial institution, corruptly solicits or demands for the benefit of any person, or corruptly accepts or agrees to accept, anything of value from any person, intending to be influenced or rewarded in connection with any business or transaction of such institution;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined not more than $1,000,000 or three times the value of the thing given, offered, promised, solicited, demanded, accepted, or agreed to be accepted, whichever is greater, or imprisoned not more than 30 years, or both, but if the value of the thing given, offered, promised, solicited, demanded, accepted, or agreed to be accepted does not exceed $1,000, shall be fined under this title or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8bf9046-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s215/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"[(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transferred]","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8bf9047-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s215/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall not apply to bona fide salary, wages, fees, or other compensation paid, or expenses paid or reimbursed, in the usual course of business.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8bf9048-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s215/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal agencies with responsibility for regulating a financial institution shall jointly establish such guidelines as are appropriate to assist an officer, director, employee, agent, or attorney of a financial institution to comply with this section. Such agencies shall make such guidelines available to the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8bf9049-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/695"},"text":"62 Stat. 695","children":[],"tail":", § 215, formerly § 220; "},{"tag":"ref","attrib":{"href":"/us/act/1950-09-21/ch967/s4"},"text":"Sept. 21, 1950, ch. 967, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/894"},"text":"64 Stat. 894","children":[],"tail":"; renumbered § 215, "},{"tag":"ref","attrib":{"href":"/us/pl/87/849/s1/d"},"text":"Pub. L. 87–849, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-23"},"text":"Oct. 23, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1125"},"text":"76 Stat. 1125","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s1107/a"},"text":"Pub. L. 98–473, title II, § 1107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2145"},"text":"98 Stat. 2145","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/370/s2"},"text":"Pub. L. 99–370, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-04"},"text":"Aug. 4, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/779"},"text":"100 Stat. 779","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tIX"},"text":"Pub. L. 101–73, title IX","children":[],"tail":", §§ 961(a), 962(e)(1), "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/499"},"text":"103 Stat. 499","children":[],"tail":", 503; "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV/s2504/a"},"text":"Pub. L. 101–647, title XXV, § 2504(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4861"},"text":"104 Stat. 4861","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s606/a"},"text":"Pub. L. 104–294, title VI, § 606(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3511"},"text":"110 Stat. 3511","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8bf904a-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8bf904b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on sections 595, 1125, and 1315 of title 12, U.S.C., 1940 ed., Banks and Banking (","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-12-23/ch6/s22"},"text":"Dec. 23, 1913, ch. 6, § 22","children":[],"tail":", first sentence of second paragraph, "},{"tag":"ref","attrib":{"href":"/us/stat/38/272"},"text":"38 Stat. 272","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1916-07-17/ch245/s211/e"},"text":"July 17, 1916, ch. 245, § 211(e)","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1923-03-04/ch252/s2"},"text":"Mar. 4, 1923, ch. 252, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/1460"},"text":"42 Stat. 1460","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1917-06-21/ch32/s11"},"text":"June 21, 1917, ch. 32, § 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/240"},"text":"40 Stat. 240","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1918-09-26/ch177/s5"},"text":"Sept. 26, 1918, ch. 177, § 5","children":[],"tail":", part 22(c), "},{"tag":"ref","attrib":{"href":"/us/stat/40/970"},"text":"40 Stat. 970","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1923-03-04/ch252"},"text":"Mar. 4, 1923, ch. 252","children":[],"tail":", title II, § 216(e), "},{"tag":"ref","attrib":{"href":"/us/stat/42/1472"},"text":"42 Stat. 1472","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The punishment provisions of the three sections were identical, and all other provisions thereof were similar, except that ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s595"},"text":"section 595 of title 12","children":[],"tail":", U.S.C., 1940 ed., Banks and Banking, relating to officers, directors, employees, or attorneys of member banks of the Federal Reserve System, did not include the terms “agent” and “acceptance” and did not include the phrase “or extension or renewal of loan or substitution of security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “shall be deemed guilty of a misdemeanor” were omitted because of definition of misdemeanor in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “and upon conviction” and “and shall upon conviction thereof” were omitted as surplusage because punishment cannot be imposed until after conviction.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Verbal changes were made for style purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8bf904c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb8bf904d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s215"},"text":"section 215 of this title","children":[],"tail":" was renumbered section 211."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8bf904e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" substituted “$1,000” for “$100” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $1,000” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":" substituted “30” for “20” before “years” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s961/a"},"text":"Pub. L. 101–73, § 961(a)","children":[],"tail":", in closing provisions, substituted “$1,000,000” for “$5,000” and “20 years” for “five years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s962/e/1"},"text":"Pub. L. 101–73, § 962(e)(1)","children":[],"tail":", transferred subsec. (b) to "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s20"},"text":"section 20 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/370"},"text":"Pub. L. 99–370","children":[],"tail":" amended section generally, combining in subsec. (a) the statement of prohibited activities formerly set out in subsecs. (a) and (b), transferring to subsec. (b) and expanding provisions formerly set out in subsec. (c) which defined “financial institution”, transferring to subsec. (c) and amending provisions formerly set out in subsec. (d) relating to applicability of section, and adding new subsec. (d) relating to establishment of guidelines to assist financial institutions in complying with this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":" amended section generally. Prior to amendment section read as follows: “Whoever, being an officer, director, employee, agent, or attorney of any bank, the deposits of which are insured by the Federal Deposit Insurance Corporation, of a Federal intermediate credit bank, or of a National Agricultural Credit Corporation, except as provided by law, stipulates for or receives or consents or agrees to receive any fee, commission, gift, or thing of value, from any person, firm, or corporation, for procuring or endeavoring to procure for such person, firm, or corporation, or for any other person, firm, or corporation, from any such bank or corporation, any loan or extension or renewal of loan or substitution of security, or the purchase or discount or acceptance of any paper, note, draft, check, or bill of exchange by any such bank or corporation, shall be fined not more than $5,000 or imprisoned not more than one year or both.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1950—Act ","children":[{"tag":"date","attrib":{"date":"1950-09-21"},"text":"Sept. 21, 1950","children":[],"tail":", substituted “any bank, the deposits of which are insured by the Federal Deposit Insurance Corporation” for “a member bank of the Federal Reserve System”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8bf904f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8bf9050-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/370/s3"},"text":"Pub. L. 99–370, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-04"},"text":"Aug. 4, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/780"},"text":"100 Stat. 780","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/370/s3"},"text":"“This Act and the amendments made by this Act [amending this section and enacting a provision set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s201"},"text":"section 201 of this title","children":[],"tail":"] shall take effect 30 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1986-08-04"},"text":"Aug. 4, 1986","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
