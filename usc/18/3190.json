{"tag":"section","attrib":{"id":"idb9961a67-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3190"},"text":null,"children":[{"tag":"num","attrib":{"value":"3190"},"text":"§ 3190.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evidence on hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Depositions, warrants, or other papers or copies thereof offered in evidence upon the hearing of any extradition case shall be received and admitted as evidence on such hearing for all the purposes of such hearing if they shall be properly and legally authenticated so as to entitle them to be received for similar purposes by the tribunals of the foreign country from which the accused party shall have escaped, and the certificate of the principal diplomatic or consular officer of the United States resident in such foreign country shall be proof that the same, so offered, are authenticated in the manner required.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9961a68-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/824"},"text":"62 Stat. 824","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9961a69-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9961a6a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 655 (R.S. § 5271; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1882-08-03/ch378/s5"},"text":"Aug. 3, 1882, ch. 378, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/22/216"},"text":"22 Stat. 216","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Unnecessary words were deleted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
