{"tag":"section","attrib":{"id":"idb96d83e6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2421"},"text":null,"children":[{"tag":"num","attrib":{"value":"2421"},"text":"§ 2421.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation generally","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb96d83e7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2421/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever knowingly transports any individual in interstate or foreign commerce, or in any Territory or Possession of the United States, with intent that such individual engage in prostitution, or in any sexual activity for which any person can be charged with a criminal offense, or attempts to do so, shall be fined under this title or imprisoned not more than 10 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96d83e8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2421/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requests To Prosecute Violations by State Attorneys General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96d83e9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2421/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Attorney General shall grant a request by a State attorney general that a State or local attorney be cross designated to prosecute a violation of this section unless the Attorney General determines that granting the request would undermine the administration of justice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96d83ea-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2421/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reason for denial","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Attorney General denies a request under paragraph (1), the Attorney General shall submit to the State attorney general a detailed reason for the denial not later than 60 days after the date on which a request is received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb96d83eb-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22/tIII/s303"},"text":"Pub. L. 114–22, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-05-29"},"text":"May 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/255"},"text":"129 Stat. 255","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb96d83ec-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb96d83ed-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb96d83ee-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A