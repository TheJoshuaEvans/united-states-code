{"tag":"section","attrib":{"id":"idb9344add-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1838"},"text":null,"children":[{"tag":"num","attrib":{"value":"1838"},"text":"§ 1838.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction with other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as provided in section 1833(b), this chapter shall not be construed to preempt or displace any other remedies, whether civil or criminal, provided by United States Federal, State, commonwealth, possession, or territory law for the misappropriation of a trade secret, or to affect the otherwise lawful disclosure of information by any Government employee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":" (commonly known as the Freedom of Information Act)."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9344ade-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294/tI/s101/a"},"text":"Pub. L. 104–294, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3490"},"text":"110 Stat. 3490","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/153/s7/b"},"text":"Pub. L. 114–153, § 7(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-05-11"},"text":"May 11, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/385"},"text":"130 Stat. 385","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9344adf-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9344ae0-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9344ae1-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/153"},"text":"Pub. L. 114–153","children":[],"tail":" substituted “Except as provided in section 1833(b), this chapter” for “This chapter”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
