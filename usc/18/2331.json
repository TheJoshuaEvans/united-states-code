{"tag":"section","attrib":{"id":"idb9619cc7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2331"},"text":null,"children":[{"tag":"num","attrib":{"value":"2331"},"text":"§ 2331.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9619cc8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2331/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “international terrorism” means activities that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9619cc9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2331/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve violent acts or acts dangerous to human life that are a violation of the criminal laws of the United States or of any State, or that would be a criminal violation if committed within the jurisdiction of the United States or of any State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9619cca-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2331/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" appear to be intended—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9619ccb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2331/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to intimidate or coerce a civilian population;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9619ccc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2331/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to influence the policy of a government by intimidation or coercion; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9619ccd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2331/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to affect the conduct of a government by mass destruction, assassination, or kidnapping; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9619cce-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2331/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" occur primarily outside the territorial jurisdiction of the United States, or transcend national boundaries in terms of the means by which they are accomplished, the persons they appear intended to intimidate or coerce, or the locale in which their perpetrators operate or seek asylum;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9619ccf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2331/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “national of the United States” has the meaning given such term in section 101(a)(22) of the Immigration and Nationality Act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9619cd0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2331/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “person” means any individual or entity capable of holding a legal or beneficial interest in property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9619cd1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2331/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “act of war” means any act occurring in the course of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9619cd2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2331/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" declared war;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9619cd3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2331/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" armed conflict, whether or not war has been declared, between two or more nations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9619cd4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2331/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" armed conflict between military forces of any origin;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9619cd5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2331/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “domestic terrorism” means activities that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9619cd6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2331/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve acts dangerous to human life that are a violation of the criminal laws of the United States or of any State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9619cd7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2331/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" appear to be intended—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9619cd8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2331/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to intimidate or coerce a civilian population;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9619cd9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2331/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to influence the policy of a government by intimidation or coercion; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9619cda-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2331/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to affect the conduct of a government by mass destruction, assassination, or kidnapping; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9619cdb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2331/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" occur primarily within the territorial jurisdiction of the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9619cdc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2331/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “military force” does not include any person that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9619cdd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2331/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has been designated as a—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9619cde-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2331/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign terrorist organization by the Secretary of State under section 219 of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1189"},"text":"8 U.S.C. 1189","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9619cdf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2331/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specially designated global terrorist (as such term is defined in section 594.310 of title 31, Code of Federal Regulations) by the Secretary of State or the Secretary of the Treasury; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9619ce0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2331/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been determined by the court to not be a “military force”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9619ce1-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572/tX/s1003/a/3"},"text":"Pub. L. 102–572, title X, § 1003(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4521"},"text":"106 Stat. 4521","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tVIII/s802/a"},"text":"Pub. L. 107–56, title VIII, § 802(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/376"},"text":"115 Stat. 376","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/253/s2/a"},"text":"Pub. L. 115–253, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-03"},"text":"Oct. 3, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3183"},"text":"132 Stat. 3183","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9619ce2-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9619ce3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9619ce4-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 101(a)(22) of the Immigration and Nationality Act, referred to in par. (2), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/22"},"text":"sectio