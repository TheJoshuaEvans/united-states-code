{"tag":"section","attrib":{"id":"idb8a2e0b9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s27"},"text":null,"children":[{"tag":"num","attrib":{"value":"27"},"text":"§ 27.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mortgage lending business defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In this title, the term “mortgage lending business” means an organization which finances or refinances any debt secured by an interest in real estate, including private mortgage companies and any subsidiaries of such organizations, and whose activities affect interstate or foreign commerce.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8a2e0ba-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/21/s2/b/1"},"text":"Pub. L. 111–21, § 2(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1617"},"text":"123 Stat. 1617","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
