{"tag":"section","attrib":{"id":"idb8b137df-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s153"},"text":null,"children":[{"tag":"num","attrib":{"value":"153"},"text":"§ 153.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Embezzlement against estate","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8b137e0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s153/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offense","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person described in subsection (b) who knowingly and fraudulently appropriates to the person’s own use, embezzles, spends, or transfers any property or secretes or destroys any document belonging to the estate of a debtor shall be fined under this title, imprisoned not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b137e1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s153/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Person to Whom Section Applies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person described in this subsection is one who has access to property or documents belonging to an estate by virtue of the person’s participation in the administration of the estate as a trustee, custodian, marshal, attorney, or other officer of the court or as an agent, employee, or other person engaged by such an officer to perform a service with respect to the estate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8b137e2-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/690"},"text":"62 Stat. 690","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/tIII/s314/a/1"},"text":"Pub. L. 95–598, title III, § 314(a)(1)","children":[],"tail":", (d)(1), (2), "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2676"},"text":"92 Stat. 2676","children":[],"tail":", 2677; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/394/tIII/s312/a/1/A"},"text":"Pub. L. 103–394, title III, § 312(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4139"},"text":"108 Stat. 4139","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s601/a/1"},"text":"Pub. L. 104–294, title VI, § 601(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3497"},"text":"110 Stat. 3497","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8b137e3-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8b137e4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s52/a"}