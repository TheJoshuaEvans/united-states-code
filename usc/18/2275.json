{"tag":"section","attrib":{"id":"idb9582707-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2275"},"text":null,"children":[{"tag":"num","attrib":{"value":"2275"},"text":"§ 2275.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Firing or tampering with vessels","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever sets fire to any vessel of foreign registry, or any vessel of American registry entitled to engage in commerce with foreign nations, or to any vessel of the United States, or to the cargo of the same, or tampers with the motive power of instrumentalities of navigation of such vessel, or places bombs or explosives in or upon such vessel, or does any other act to or upon such vessel while within the jurisdiction of the United States, or, if such vessel is of American registry, while she is on the high sea, with intent to injure or endanger the safety of the vessel or of her cargo, or of persons on board, whether the injury or danger is so intended to take place within the jurisdiction of the United States, or after the vessel shall have departed therefrom and whoever attempts to do so shall be fined under this title or imprisoned not more than twenty years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9582708-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/804"},"text":"62 Stat. 804","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/L"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(L)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9582709-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb958270a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 502 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-06-15/ch30"},"text":"June 15, 1917, ch. 30","children":[],"tail":", title III, § 1, "},{"tag":"ref","attrib":{"href":"/us/stat/40/221"},"text":"40 Stat. 221","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s501"},"text":"section 501 of this title","children":[],"tail":",” were omitted in view of "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s9"},"text":"section 9 of this title","children":[],"tail":", defining vessel of the United States."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Last sentence of said section 502, defining “United States”, was incorporated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s5"},"text":"section 5 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provision prohibiting conspiracy was deleted as adequately covered by the general conspiracy statute, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s371"},"text":"section 371 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb958270b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb958270c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $10,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
