{"tag":"section","attrib":{"id":"idb95a709a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281"},"text":null,"children":[{"tag":"num","attrib":{"value":"2281"},"text":"§ 2281.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violence against maritime fixed platforms","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb95a709b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offenses.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95a709c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person who unlawfully and intentionally—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95a709d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seizes or exercises control over a fixed platform by force or threat thereof or any other form of intimidation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95a709e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performs an act of violence against a person on board a fixed platform if that act is likely to endanger its safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95a709f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" destroys a fixed platform or causes damage to it which is likely to endanger its safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95a70a0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" places or causes to be placed on a fixed platform, by any means whatsoever, a device or substance which is likely to destroy that fixed platform or likely to endanger its safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95a70a1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" injures or kills any person in connection with the commission or the attempted commission of any of the offenses set forth in subparagraphs (A) through (D); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95a70a2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attempts or conspires to do anything prohibited under subparagraphs (A) through (E),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title, imprisoned not more than 20 years, or both; and if death results to any person from conduct prohibited by this paragraph, shall be punished by death or imprisoned for any term of years or for life.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95a70a3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Threat to safety","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person who threatens to do anything prohibited under paragraph (1)(B) or (C), with apparent determination and will to carry the threat into execution, if the threatened act is likely to endanger the safety of the fixed platform, shall be fined under this title, imprisoned not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95a70a4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is jurisdiction over the activity prohibited in subsection (a) if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95a70a5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such activity is committed against or on board a fixed platform—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95a70a6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is located on the continental shelf of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95a70a7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is located on the continental shelf of another country, by a national of the United States or by a stateless person whose habitual residence is in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95a70a8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an attempt to compel the United States to do or abstain from doing any act;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95a70a9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the commission of such activity against or on board a fixed platform located on a continental shelf, a national of the United States is seized, threatened, injured or killed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95a70aa-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such activity is committed against or on board a fixed platform located outside the United States and beyond the continental shelf of the United States and the offender is later found in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95a70ab-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bar To Prosecution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It is a bar to Federal prosecution under subsection (a) for conduct that occurred within the United States that the conduct involved was during or in relation to a labor dispute, and such conduct is prohibited as a felony under the law of the State in which it was committed. For purposes of this section, the term “labor dispute” has the meaning set forth in section 13(c) of the Norris-LaGuardia Act, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s113/c"},"text":"29 U.S.C. 113(c)","children":[],"tail":"), and the term “State” means a State of the United States, the District of Columbia, and any commonwealth, territory, or possession of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95a70ac-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section—","children":[{"tag":"p","attrib":{"role":"listItem"},"text":"“continental shelf” means the sea-bed and subsoil of the submarine areas that extend beyond a country’s territorial sea to the limits provided by customary international law as reflected in Article 76 of the 1982 Convention on the Law of the Sea.","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"“fixed platform” means an artificial island, installation or structure permanently attached to the sea-bed for the purpose of exploration or exploitation of resources or for other economic purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95a70ad-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section does not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95a70ae-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities of armed forces during an armed conflict, as those terms are understood under the law of war, which are governed by that law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95a70af-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities undertaken by military forces of a state in the exercise of their official duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb95a70b0-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tVI/s60019/a"},"text":"Pub. L. 103–322, title VI, § 60019(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1977"},"text":"108 Stat. 1977","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tVII/s723/a/1"},"text":"Pub. L. 104–132, title VII, § 723(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1300"},"text":"110 Stat. 1300","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s607/p"},"text":"Pub. L. 104–294, title VI, § 607(p)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3513"},"text":"110 Stat. 3513","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/23/tVIII/s803"},"text":"Pub. L. 114–23, title VIII, § 803","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-02"},"text":"June 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/307"},"text":"129 Stat. 307","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb95a70b1-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb95a70b2-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb95a70b3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s803/1"},"text":"Pub. L. 114–23, § 803(1)","children":[],"tail":", substituted “section 13(c)” for “section 2(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s803/2"},"text":"Pub. L. 114–23, § 803(2)","children":[],"tail":", struck out definitions of “national of the United States”, “territorial sea of the United States”, and “United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s803/3"},"text":"Pub. L. 114–23, § 803(3)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132"},"text":"Pub. L. 104–132","children":[],"tail":" inserted “or conspires” after “attempts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" inserted before period at end “, and the term ‘State’ means a State of the United States, the District of Columbia, and any commonwealth, territory, or possession of the United States”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb95a70b4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb95a70b5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1995-03-06"},"text":"Mar. 6, 1995","children":[],"tail":", see section 60019(c)(1), (2)(B) of "},{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2280"},"text":"section 2280 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idb95a70b6-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2280/d"},"text":"section 2280(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb95a70b7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb95a70b8-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Territorial Sea of United States","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For extension of territorial sea of United States, see Proc. No. 5928, set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1331"},"text":"section 1331 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
