{"tag":"section","attrib":{"id":"idb9096a79-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1023"},"text":null,"children":[{"tag":"num","attrib":{"value":"1023"},"text":"§ 1023.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insufficient delivery of money or property for military or naval service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, having charge, possession, custody, or control of any money or other public property used or to be used in the military or naval service, with intent to defraud the United States, or any agency thereof, or any corporation in which the United States has a proprietary interest, or intending to conceal such money or other property, delivers to any person having authority to receive the same any amount of such money or other property less than that for which he received a certificate or took a receipt, shall be fined under this title or imprisoned not more than ten years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9096a7a-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/754"},"text":"62 Stat. 754","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/L"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(L)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9096a7b-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9096a7c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 85 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s35"},"text":"Mar. 4, 1909, ch. 321, § 35","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1095"},"text":"35 Stat. 1095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1918-10-23/ch194"},"text":"Oct. 23, 1918, ch. 194","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/1015"},"text":"40 Stat. 1015","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1934-06-18/ch587"},"text":"June 18, 1934, ch. 587","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/996"},"text":"48 Stat. 996","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1938-04-04/ch69"},"text":"Apr. 4, 1938, ch. 69","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/197"},"text":"52 Stat. 197","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Word “agency” was substituted for “department” so as to eliminate any possible ambiguity as to scope of section. (See definitions of “department” and “agency” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s6"},"text":"section 6 of this title","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to persons causing or procuring was omitted as unnecessary in view of definition of “principal” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9096a7d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9096a7e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $10,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
