{"tag":"section","attrib":{"id":"idb9ca9793-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4113"},"text":null,"children":[{"tag":"num","attrib":{"value":"4113"},"text":"§ 4113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of alien offender transferred to a foreign country","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9ca9794-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An alien who is deportable from the United States but who has been granted voluntary departure pursuant to section 240B of the Immigration and Nationality Act and who is transferred to a foreign country pursuant to this chapter shall be deemed for all purposes to have voluntarily departed from this country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9ca9795-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An alien who is the subject of an order of removal from the United States pursuant to section 240 of the Immigration and Nationality Act who is transferred to a foreign country pursuant to this chapter shall be deemed for all purposes to have been removed from this country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9ca9796-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4113/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An alien who is the subject of an order of removal from the United States pursuant to section 240 of the Immigration and Nationality Act, who is transferred to a foreign country pursuant to this chapter shall be deemed for all purposes to have been excluded from admission and removed from the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9ca9797-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/144/s1"},"text":"Pub. L. 95–144, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-28"},"text":"Oct. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1219"},"text":"91 Stat. 1219","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tIII/s308/d/4/U"},"text":"Pub. L. 104–208, div. C, title III, § 308(d)(4)(U)","children":[],"tail":", (e)(1)(Q), (2)(I), (g)(3)(B), (5)(A)(iv), "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-619"},"text":"110 Stat. 3009–619","children":[],"tail":", 3009–620, 3009–622, 3009–623.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9ca9798-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9ca9799-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9ca979a-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 240B of the Immigration and Nationality Act, referred to in subsec. (a), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1229c"},"text":"section 1229c of Title 8","children":[],"tail":", Aliens and Nationality."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 240 of the Immigration and Nationality Act, referred to in subsecs. (b) and (c), i