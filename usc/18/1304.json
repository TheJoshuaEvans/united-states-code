{"tag":"section","attrib":{"id":"idb91a0cbd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1304"},"text":null,"children":[{"tag":"num","attrib":{"value":"1304"},"text":"§ 1304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Broadcasting lottery information","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever broadcasts by means of any radio or television station for which a license is required by any law of the United States, or whoever, operating any such station, knowingly permits the broadcasting of, any advertisement of or information concerning any lottery, gift enterprise, or similar scheme, offering prizes dependent in whole or in part upon lot or chance, or any list of the prizes drawn or awarded by means of any such lottery, gift enterprise, or scheme, whether said list contains any part or all of such prizes, shall be fined under this title or imprisoned not more than one year, or both.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Each day’s broadcasting shall constitute a separate offense.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb91a0cbe-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/763"},"text":"62 Stat. 763","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/625/s3/a/4"},"text":"Pub. L. 100–625, § 3(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3206"},"text":"102 Stat. 3206","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91a0cbf-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb91a0cc0-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s316"},"text":"section 316 of title 47","children":[],"tail":", U.S.C., 1940 ed., Telegraphs, Telephones, and Radiotelegraphs ("},{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652/s316"},"text":"June 19, 1934, ch. 652, § 316","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1088"},"text":"48 Stat. 1088","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “upon conviction thereof” were deleted as surplusage since punishment can be imposed only after a conviction.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb91a0cc1-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $1,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/625"},"text":"Pub. L. 100–625","children":[],"tail":" inserted “or television” after “radio” in first sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb91a0cc2-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb91a0cc3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/625/s5"},"text":"Pub. L. 100–625, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3206"},"text":"102 Stat. 3206","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/625/s5"},"text":"“The amendments made by this Act [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1307"},"text":"section 1307 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s3005"},"text":"section 3005 of Title 39","children":[],"tail":", Postal Service] shall take effect 18 months after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
