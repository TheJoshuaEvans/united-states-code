{"tag":"section","attrib":{"id":"idb97720d6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2520"},"text":null,"children":[{"tag":"num","attrib":{"value":"2520"},"text":"§ 2520.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of civil damages authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb97720d7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2520/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in section 2511(2)(a)(ii), any person whose wire, oral, or electronic communication is intercepted, disclosed, or intentionally used in violation of this chapter may in a civil action recover from the person or entity, other than the United States, which engaged in that violation such relief as may be appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb97720d8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2520/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relief","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In an action under this section, appropriate relief includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb97720d9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2520/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such preliminary and other equitable or declaratory relief as may be appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97720da-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2520/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" damages under subsection (c) and punitive damages in appropriate cases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97720db-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2520/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reasonable attorney’s fee and other litigation costs reasonably incurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb97720dc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2520/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Computation of Damages","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb97720dd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2520/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In an action under this section, if the conduct in violation of this chapter is the private viewing of a private satellite video communication that is not scrambled or encrypted or if the communication is a radio communication that is transmitted on frequencies allocated under subpart D of part 74 of the rules of the Federal Communications Commission that is not scrambled or encrypted and the conduct is not for a tortious or illegal purpose or for purposes of direct or indirect commercial advantage or private commercial gain, then the court shall assess damages as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb97720de-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2520/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the person who engaged in that conduct has not previously been enjoined under section 2511(5) and has not been found liable in a prior civil action under this section, the court shall assess the greater of the sum of actual damages suffered by the plaintiff, or statutory damages of not less than $50 and not more than $500.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb97720df-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2520/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If, on one prior occasion, the person who engaged in that conduct has been enjoined under section 2511(5) or has been found liable in a civil action under this section, the court shall assess the greater of the sum of actual damages suffered by the plaintiff, or statutory damages of not less than $100 and not more than $1000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97720e0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2520/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In any other action under this section, the court may assess as damages whichever is the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb97720e1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2520/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sum of the actual damages suffered by the plaintiff and any profits made by the violator as a result of the violation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb97720e2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2520/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" statutory damages of whichever is the greater of $100 a day for each day of violation or $10,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb97720e3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2520/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defense","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A good faith reliance on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb97720e4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2520/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a court warrant or order, a grand jury subpoena, a legislative authorization, or a statutory authorization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97720e5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2520/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a request of an investigative or law enforcement officer under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2518/7"},"text":"section 2518(7) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97969d6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2520/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a good faith determination that section 2511(3), 2511(2)(i), or 2511(2)(j) of this title permitted the conduct complained of;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is a complete defense against any civil or criminal action brought under this chapter or any other law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb97969d7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2520/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A civil action under this section may not be commenced later than two years after the date upon which the claimant first has a reasonable opportunity to discover the violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb97969d8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2520/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative Discipline","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a court or appropriate department or agency determines that the United States or any of its departments or agencies has violated any provision of this chapter, and the court or appropriate department or agency finds that the circumstances surrounding the violation raise serious questions about whether or not an officer or employee of the United States acted willfully or intentionally with respect to the violation, the department or agency shall, upon receipt of a true and correct copy of the decision and findings of the court or appropriate department or agency promptly initiate a proceeding to determine whether disciplinary action against the officer or employee is warranted. If the head of the department or agency involved determines that disciplinary action is not warranted, he or she shall notify the Inspector General with jurisdiction over the department or agency concerned and shall provide the Inspector General with the reasons for such determination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb97969d9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2520/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Improper Disclosure Is Violation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any willful disclosure or use by an investigative or law enforcement officer or governmental entity of information beyond the extent permitted by section 2517 is a violation of this chapter for purposes of section 2520(a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb97969da-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tIII/s802"},"text":"Pub. L. 90–351, title III, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-06-19"},"text":"June 19, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/223"},"text":"82 Stat. 223","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/358/tII/s211/c"},"text":"Pub. L. 91–358, title II, § 211(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-07-29"},"text":"July 29, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/654"},"text":"84 Stat. 654","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/508/tI/s103"},"text":"Pub. L. 99–508, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1853"},"text":"100 Stat. 1853","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tII/s223/a"},"text":"Pub. L. 107–56, title II, § 223(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/293"},"text":"115 Stat. 293","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXXII/s2207/e"},"text":"Pub. L. 107–296, title XXII, § 2207(e)","children":[],"tail":", formerly title II, § 225(e), "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2157"},"text":"116 Stat. 2157","children":[],"tail":", renumbered § 2207(e), "},{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/g/2/I"},"text":"Pub. L. 115–278, § 2(g)(2)(I)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-11-16"},"text":"Nov. 16, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4178"},"text":"132 Stat. 4178","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dV/s104/1/B"},"text":"Pub. L. 115–141, div. V, § 104(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1216"},"text":"132 Stat. 1216","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb97969db-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb97969dc-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb97969dd-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" amended par. (3) generally. Prior to amendment, par. (3) read as follows: “a good faith determination that section 2511(3) or 2511(2)(i) of this title permitted the conduct complained of;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" inserted “or 2511(2)(i)” after “2511(3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/s223/a/1"},"text":"Pub. L. 107–56, § 223(a)(1)","children":[],"tail":", inserted “, other than the United States,” after “person or entity”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/s223/a/2"},"text":"Pub. L. 107–56, § 223(a)(2)","children":[],"tail":", (3), added subsecs. (f) and (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/508"},"text":"Pub. L. 99–508","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “Any person whose wire or oral communication is intercepted, disclosed, or used in violation of this chapter shall (1) have a civil cause of action against any person who intercepts, discloses, or uses, or procures any other person to intercept, disclose, or use such communications, and (2) be entitled to recover from any such person—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) actual damages but not less than liquidated damages computed at the rate of $100 a day for each day of violation or $1,000, whichever is higher;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) punitive damages; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) a reasonable attorney’s fee and other litigation costs reasonably incurred.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"A good faith reliance on a court order or legislative authorization shall constitute a complete defense to any civil or criminal action brought under this chapter or under any other law.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/358"},"text":"Pub. L. 91–358","children":[],"tail":" substituted provisions that a good faith reliance on a court order or legislative authorization constitute a complete defense to any civil or criminal action brought under this chapter or under any other law, for provisions that a good faith reliance on a court order or on the provisions of section 2518(7) of this chapter constitute a complete defense to any civil or criminal action brought under this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb97969de-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb97969df-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s4"},"text":"section 4 of Pub. L. 107–296","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb97969e0-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/508"},"text":"Pub. L. 99–508","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", and, in case of conduct pursuant to court order or extension, applicable only with respect to court orders and extensions made after such date, with special rule for State authorizations of interceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/508/s111"},"text":"section 111 of Pub. L. 99–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2510"},"text":"section 2510 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb97969e1-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/358"},"text":"Pub. L. 91–358","children":[],"tail":" effective on first day of seventh calendar month which begins after "},{"tag":"date","attrib":{"date":"1970-07-29"},"text":"July 29, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/358/s901/a"},"text":"section 901(a) of Pub. L. 91–358","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb97969e2-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dV/s106"},"text":"Pub. L. 115–141, div. V, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1224"},"text":"132 Stat. 1224","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/141/dV/s106"},"text":"“Nothing in this division [see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s101"},"text":"section 101 of Pub. L. 115–141","children":[],"tail":", set out as a Short Title of 2018 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1"},"text":"section 1 of this title","children":[],"tail":"], or the amendments made by this division, shall be construed to preclude any foreign authority from obtaining assistance in a criminal investigation or prosecution pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3512"},"text":"section 3512 of title 18","children":[],"tail":", United States Code, "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1782"},"text":"section 1782 of title 28","children":[],"tail":", United States Code, or as otherwise provided by law.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
