{"tag":"section","attrib":{"id":"idb8b137eb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s154"},"text":null,"children":[{"tag":"num","attrib":{"value":"154"},"text":"§ 154.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adverse interest and conduct of officers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A person who, being a custodian, trustee, marshal, or other officer of the court—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b137ec-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s154/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly purchases, directly or indirectly, any property of the estate of which the person is such an officer in a case under title 11;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b137ed-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s154/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly refuses to permit a reasonable opportunity for the inspection by parties in interest of the documents and accounts relating to the affairs of estates in the person’s charge by parties when directed by the court to do so; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b137ee-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s154/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly refuses to permit a reasonable opportunity for the inspection by the United States Trustee of the documents and accounts relating to the affairs of an estate in the person’s charge,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title and shall forfeit the person’s office, which shall thereupon become vacant.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8b137ef-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/690"},"text":"62 Stat. 690","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/tIII/s314/a/2"},"text":"Pub. L. 95–598, title III, § 314(a)(2)","children":[],"tail":", (e)(1), (2), "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2676"},"text":"92 Stat. 2676","children":[],"tail":", 2677; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/G"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(G)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/394/tIII/s312/a/1/A"},"text":"Pub. L. 103–394, title III, § 312(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4139"},"text":"108 Stat. 4139","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s601/a/1"},"text":"Pub. L. 104–294, title VI, § 601(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3497"},"text":"110 Stat. 3497","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8b137f0-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8b137f1-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s52/c"},"text":"section 52(c) of title 11","children":[],"tail":", U.S.C., 1940 ed., Bankruptcy ("},{"tag":"ref","attrib":{"href":"/us/act/1898-07-01/ch541/s29c"},"text":"July 1, 1898, ch. 541, § 29c","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/554"},"text":"30 Stat. 554","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1938-06-22/ch575/s1"},"text":"June 22, 1938, ch. 575, § 1","children":[],"tail":" (part), "},{"tag":"ref","attrib":{"href":"/us/stat/52/856"},"text":"52 Stat. 856","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8b137f2-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8b137f3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" substituted “fined under this title” for “fined not more than $5,000” in closing provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/394"},"text":"Pub. L. 103–394","children":[],"tail":" amended section generally. Prior to amendment, section read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Whoever, being a custodian, trustee, marshal, or other officer of the court, knowingly purchases, directly or indirectly, any property of the estate of which he is such officer in a case under title 11; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Whoever being such officer, knowingly refuses to permit a reasonable opportunity for the inspection of the documents and accounts relating to the affairs of estates in his charge by parties in interest when directed by the court to do so—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Shall be fined under this title, and shall forfeit his office, which shall thereupon become vacant.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $500” in third par."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":" struck out “referees and other” before “officers” in section catchline, and in text struck out “Whoever knowingly acts as a referee in a case in which he is directly or indirectly interested; or” before “Whoever, being a” and “referee, receiver,” before “custodian” and substituted “case under title 11” for “bankruptcy proceeding”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8b137f4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8b137f5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/394"},"text":"Pub. L. 103–394","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", and not applicable with respect to cases commenced under Title 11, Bankruptcy, before "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/394/s702"},"text":"section 702 of Pub. L. 103–394","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of Title 11","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8b137f6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/s402/a"},"text":"section 402(a) of Pub. L. 95–598","children":[],"tail":", set out as an Effective Date note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of Title 11","children":[],"tail":", Bankruptcy."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idb8b137f7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598/s314"},"text":"section 314 of Pub. L. 95–598","children":[],"tail":" not to affect the application of chapter 9 (§ 151 et seq.), chapter 96 (§ 1961 et seq.), or section 2516, 3057, or 3284 of this title to any act of any person (1) committed before "},{"tag":"date","a