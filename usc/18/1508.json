{"tag":"section","attrib":{"id":"idb923a95b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1508"},"text":null,"children":[{"tag":"num","attrib":{"value":"1508"},"text":"§ 1508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recording, listening to, or observing proceedings of grand or petit juries while deliberating or voting","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Whoever knowingly and willfully, by any means or device whatsoever—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb923a95c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" records, or attempts to record, the proceedings of any grand or petit jury in any court of the United States while such jury is deliberating or voting; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb923a95d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" listens to or observes, or attempts to listen to or observe, the proceedings of any grand or petit jury of which he is not a member in any court of the United States while such jury is deliberating or voting—","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title or imprisoned not more than one year, or both.","children":[],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Nothing in paragraph (a) of this section shall be construed to prohibit the taking of notes by a grand or petit juror in any court of the United States in connection with and solely for the purpose of assisting him in the performance of his duties as such juror.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb923a95e-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-02/ch879/s1"},"text":"Aug. 2, 1956, ch. 879, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/935"},"text":"70 Stat. 935","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s601/f/13"},"text":"Pub. L. 104–294, title VI, § 601(f)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3500"},"text":"110 Stat. 3500","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb923a95f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb923a960-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb923a961-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" realigned margins for provisions beginning “shall be fined” and ending “one year, or both.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $1,000” in par. following par. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
