{"tag":"section","attrib":{"id":"idb942a362-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2112"},"text":null,"children":[{"tag":"num","attrib":{"value":"2112"},"text":"§ 2112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal property of United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever robs or attempts to rob another of any kind or description of personal property belonging to the United States, shall be imprisoned not more than fifteen years.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb942a363-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/796"},"text":"62 Stat. 796","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXII/s320903/a/2"},"text":"Pub. L. 103–322, title XXXII, § 320903(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2124"},"text":"108 Stat. 2124","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb942a364-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb942a365-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 99 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s46"},"text":"Mar. 4, 1909, ch. 321, § 46","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1097"},"text":"35 Stat. 1097","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"That portion of said section 99 relating to felonious taking was omitted as covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s641"},"text":"section 641 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The punishment by fine of not more than $5,000 or imprisoned not more than 10 years, or both, was changed to harmonize with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2111"},"text":"section 2111 of this title","children":[],"tail":". The 15–year penalty is not excessive for an offense of this type."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor verbal change was made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb942a366-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb942a367-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" inserted “or attempts to rob” after “robs”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
