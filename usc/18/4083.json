{"tag":"section","attrib":{"id":"idb9c826e2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4083"},"text":null,"children":[{"tag":"num","attrib":{"value":"4083"},"text":"§ 4083.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penitentiary imprisonment; consent","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Persons convicted of offenses against the United States or by courts-martial punishable by imprisonment for more than one year may be confined in any United States penitentiary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"A sentence for an offense punishable by imprisonment for one year or less shall not be served in a penitentiary without the consent of the defendant.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9c826e3-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/850"},"text":"62 Stat. 850","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/256"},"text":"Pub. L. 86–256","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-14"},"text":"Sept. 14, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/518"},"text":"73 Stat. 518","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9c826e4-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9c826e5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., §§ 753f, 762 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-03-02/ch189/s1"},"text":"Mar. 2, 1895, ch. 189, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/957"},"text":"28 Stat. 957","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1896-06-10/ch400/s1"},"text":"June 10, 1896, ch. 400, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/29/380"},"text":"29 Stat. 380","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1930-05-14/ch274/s7"},"text":"May 14, 1930, ch. 274, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/326"},"text":"46 Stat. 326","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1941-06-14/ch204"},"text":"June 14, 1941, ch. 204","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/252"},"text":"55 Stat. 252","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1941-10-21/ch453"},"text":"Oct. 21, 1941, ch. 453","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/743"},"text":"55 Stat. 743","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Said section 762 was condensed and simplified and extended to all penitentiaries instead of to Leavenworth only, since the section is merely declaratory of existing law. (See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1"},"text":"section 1 of this title","children":[],"tail":" classifying offenses and notes thereunder.)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The second paragraph is derived from said ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s753f"},"text":"section 753f of title 18","children":[],"tail":", U.S.C., 1940 ed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes of phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9c826e6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9c826e7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1959—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/256"},"text":"Pub. L. 86–256","children":[],"tail":" substituted “punishable by imprisonment for” for “and sentenced to terms of imprisonment of” in first sentence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
