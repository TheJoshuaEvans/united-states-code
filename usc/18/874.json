{"tag":"section","attrib":{"id":"idb8e80048-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s874"},"text":null,"children":[{"tag":"num","attrib":{"value":"874"},"text":"§ 874.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Kickbacks from public works employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, by force, intimidation, or threat of procuring dismissal from employment, or by any other manner whatsoever induces any person employed in the construction, prosecution, completion or repair of any public building, public work, or building or work financed in whole or in part by loans or grants from the United States, to give up any part of the compensation to which he is entitled under his contract of employment, shall be fined under this title or imprisoned not more than five years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8e80049-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/740"},"text":"62 Stat. 740","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8e8004a-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8e8004b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s276b"},"text":"section 276b of title 40","children":[],"tail":", U.S.C., 1940 ed., Public Buildings, Property, and Works ("},{"tag":"ref","attrib":{"href":"/us/act/1934-06-13/ch482/s1"},"text":"June 13, 1934, ch. 482, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/948"},"text":"48 Stat. 948","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Slight changes of phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8e8004c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8e8004d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $5,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
