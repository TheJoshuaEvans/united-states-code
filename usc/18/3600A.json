{"tag":"section","attrib":{"id":"idb9b058f5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3600A"},"text":null,"children":[{"tag":"num","attrib":{"value":"3600A"},"text":"§ 3600A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of biological evidence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9b058f6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3600A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, the Government shall preserve biological evidence that was secured in the investigation or prosecution of a Federal offense, if a defendant is sentenced to imprisonment for such offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9b058f7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3600A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defined Term","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “biological evidence” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9b058f8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3600A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sexual assault forensic examination kit; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9b058f9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3600A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" semen, blood, saliva, hair, skin tissue, or other identified biological material.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9b058fa-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3600A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9b058fb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3600A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after a conviction becomes final and the defendant has exhausted all opportunities for direct review of the conviction, the defendant is notified that the biological evidence may be destroyed and the defendant does not file a motion under section 3600 within 180 days of receipt of the notice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9b058fc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3600A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9b058fd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3600A/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the evidence must be returned to its rightful owner, or is of such a size, bulk, or physical character as to render retention impracticable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9b058fe-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3600A/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Government takes reasonable measures to remove and preserve portions of the material evidence sufficient to permit future DNA testing; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9b058ff-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3600A/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the biological evidence has already been subjected to DNA testing under section 3600 and the results included the defendant as the source of such evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9b05900-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3600A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Preservation Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall preempt or supersede any statute, regulation, court order, or other provision of law that may require evidence, including biological evidence, to be preserved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9b05901-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3600A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of enactment of the Innocence Protection Act of 2004, the Attorney General shall promulgate regulations to implement and enforce this section, including appropriate disciplinary sanctions to ensure that employees comply with such regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9b05902-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3600A/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criminal Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever knowingly and intentionally destroys, alters, or tampers with biological evidence that is required to be preserved under this section with the intent to prevent that evidence from being subjected to DNA testing or prevent the production or use of that evidence in an official proceeding, shall be fined under this title, imprisoned for not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9b05903-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3600A/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Habeas Corpus","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall provide a basis for relief in any Federal habeas corpus proceeding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9b05904-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/405/tIV/s411/a/1"},"text":"Pub. L. 108–405, title IV, § 411(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2283"},"text":"118 Stat. 2283","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/324/s11/b"},"text":"Pub. L. 114–324, § 11(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1957"},"text":"130 Stat. 1957","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9b05905-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9b05906-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9b05907-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Innocence Protection Act of 2004, referred to in subsec. (e), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/405"},"text":"Pub. L. 108–405","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9b05908-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/324/s11/b/1"},"text":"Pub. L. 114–324, § 11(b)(1)","children":[],"tail":", substituted “sentenced to” for “under a sentence of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/324/s11/b/2"},"text":"Pub. L. 114–324, § 11(b)(2)","children":[],"tail":", redesignated pars. (3) to (5) as (1) to (3), respectively, and struck out former pars. (1) and (2) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) a court has denied a request or motion for DNA testing of the biological evidence by the defendant under section 3600, and no appeal is pending;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the defendant knowingly and voluntarily waived the right to request DNA testing of the biological evidence in a court proceeding conducted after the date of enactment of the Innocence Protection Act of 2004;”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
