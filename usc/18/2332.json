{"tag":"section","attrib":{"id":"idb9619cec-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332"},"text":null,"children":[{"tag":"num","attrib":{"value":"2332"},"text":"§ 2332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9619ced-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Homicide","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever kills a national of the United States, while such national is outside the United States, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9619cee-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the killing is murder (as defined in section 1111(a)), be fined under this title, punished by death or imprisonment for any term of years or for life, or both;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9619cef-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the killing is a voluntary manslaughter as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1112/a"},"text":"section 1112(a) of this title","children":[],"tail":", be fined under this title or imprisoned not more than ten years, or both; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9619cf0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the killing is an involuntary manslaughter as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1112/a"},"text":"section 1112(a) of this title","children":[],"tail":", be fined under this title or imprisoned not more than three years, or both."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9619cf1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Attempt or Conspiracy With Respect to Homicide","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever outside the United States attempts to kill, or engages in a conspiracy to kill, a national of the United States shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9619cf2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an attempt to commit a killing that is a murder as defined in this chapter, be fined under this title or imprisoned not more than 20 years, or both; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9619cf3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a conspiracy by two or more persons to commit a killing that is a murder as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1111/a"},"text":"section 1111(a) of this title","children":[],"tail":", if one or more of such persons do any overt act to effect the object of the conspiracy, be fined under this title or imprisoned for any term of years or for life, or both so fined and so imprisoned."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9619cf4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Conduct","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever outside the United States engages in physical violence—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9619cf5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with intent to cause serious bodily injury to a national of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9619cf6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the result that serious bodily injury is caused to a national of the United States;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title or imprisoned not more than ten years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9619cf7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Prosecution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No prosecution for any offense described in this section shall be undertaken by the United States except on written certification of the Attorney General or the highest ranking subordinate of the Attorney General with responsibility for criminal prosecutions that, in the judgment of the certifying official, such offense was intended to coerce, intimidate, or retaliate against a government or a civilian population.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9619cf8-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/tXII/s1202/a"},"text":"Pub. L. 99–399, title XII, § 1202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/896"},"text":"100 Stat. 896","children":[],"tail":", § 2331; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/519/s132/b"},"text":"Pub. L. 101–519, § 132(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2250"},"text":"104 Stat. 2250","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/27/tIV/s402"},"text":"Pub. L. 102–27, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-04-10"},"text":"Apr. 10, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/155"},"text":"105 Stat. 155","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/136/s126"},"text":"Pub. L. 102–136, § 126","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-25"},"text":"Oct. 25, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/643"},"text":"105 Stat. 643","children":[],"tail":"; renumbered § 2332 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tX/s1003/a/1"},"text":"Pub. L. 102–572, title X, § 1003(a)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4521"},"text":"106 Stat. 4521","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tVI/s60022"},"text":"Pub. L. 103–322, title VI, § 60022","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1980"},"text":"108 Stat. 1980","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tVII/s705/a/6"},"text":"Pub. L. 104–132, title VII, § 705(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1295"},"text":"110 Stat. 1295","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9619cf9-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9619cfa-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9619cfb-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132"},"text":"Pub. L. 104–132","children":[],"tail":" substituted “ten years” for “five years” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" amended par. (1) generally. Prior to amendment, par. (1) read as follows: “if the killing is a murder as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1111/a"},"text":"section 1111(a) of this title","children":[],"tail":", be fined under this title or imprisoned for any term of years or for life, or both so fined and so imprisoned;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2331"},"text":"section 2331 of this title","children":[],"tail":" as this section, substituted “Criminal penalties” for “Terrorist acts abroad against United States national” in section catchline, redesignated subsec. (e) as (d), and struck out former subsec. (d) which read as follows: “"},{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—As used in this section the term ‘national of the United States’ has the meaning given such term in section 101(a)(22) of the Immigration and Nationality Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/22"},"text":"8 U.S.C. 1101(a)(22)","children":[],"tail":").”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/27/s402"},"text":"Pub. L. 102–27, § 402","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/102/136/s126"},"text":"Pub. L. 102–136, § 126","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/101/519/s132"},"text":"Pub. L. 101–519, § 132","children":[],"tail":", and amended this section to read as if "},{"tag":"ref","attrib":{"href":"/us/pl/101/519/s132"},"text":"Pub. L. 101–519, § 132","children":[],"tail":", had not been enacted, effective as of "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/101/519"},"text":"Pub. L. 101–519","children":[],"tail":". See Codification note preceding this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/519/s132"},"text":"Pub. L. 101–519, § 132","children":[],"tail":", which amended this section, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/102/27/s402"},"text":"Pub. L. 102–27, § 402","children":[],"tail":", as amended. See 1991 Amendment note above."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9640cfc-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb9640cfd-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" applicable to any pending case or any cause of action arising on or after 4 years before "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/s1003/c"},"text":"section 1003(c) of Pub. L. 102–572","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2331"},"text":"section 2331 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
