{"tag":"section","attrib":{"id":"idb9096a4a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1016"},"text":null,"children":[{"tag":"num","attrib":{"value":"1016"},"text":"§ 1016.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acknowledgment of appearance or oath","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being an officer authorized to administer oaths or to take and certify acknowledgments, knowingly makes any false acknowledgment, certificate, or statement concerning the appearance before him or the taking of an oath or affirmation by any person with respect to any proposal, contract, bond, undertaking, or other matter submitted to, made with, or taken on behalf of the United States or any department or agency thereof, concerning which an oath or affirmation is required by law or lawful regulation, or with respect to the financial standing of any principal, surety, or other party to any such proposal, contract, bond, undertaking, or other instrument, shall be fined under this title or imprisoned not more than two years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9096a4b-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/753"},"text":"62 Stat. 753","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/I"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(I)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9096a4c-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9096a4d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 75 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s31"},"text":"Mar. 4, 1909, ch. 321, § 31","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1094"},"text":"35 Stat. 1094","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “or of any department or agency thereof” were inserted after “United States” so as to remove any ambiguity as to scope of section. (See definitions of “department” and “agency” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s6"},"text":"section 6 of this title","children":[],"tail":".)"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9096a4e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9096a4f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $2,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
