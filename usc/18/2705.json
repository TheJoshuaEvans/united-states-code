{"tag":"section","attrib":{"id":"idb97bdc03-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2705"},"text":null,"children":[{"tag":"num","attrib":{"value":"2705"},"text":"§ 2705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delayed notice","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb97bdc04-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2705/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delay of Notification","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb97bdc05-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2705/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A governmental entity acting under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2703/b"},"text":"section 2703(b) of this title","children":[],"tail":" may—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb97bdc06-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2705/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where a court order is sought, include in the application a request, which the court shall grant, for an order delaying the notification required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2703/b"},"text":"section 2703(b) of this title","children":[],"tail":" for a period not to exceed ninety days, if the court determines that there is reason to believe that notification of the existence of the court order may have an adverse result described in paragraph (2) of this subsection; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb97bdc07-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2705/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where an administrative subpoena authorized by a Federal or State statute or a Federal or State grand jury subpoena is obtained, delay the notification required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2703/b"},"text":"section 2703(b) of this title","children":[],"tail":" for a period not to exceed ninety days upon the execution of a written certification of a supervisory official that there is reason to believe that notification of the existence of the subpoena may have an adverse result described in paragraph (2) of this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97bdc08-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2705/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An adverse result for the purposes of paragraph (1) of this subsection is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb97bdc09-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2705/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" endangering the life or physical safety of an individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb97bdc0a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2705/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flight from prosecution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb97bdc0b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2705/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" destruction of or tampering with evidence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb97bdc0c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2705/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intimidation of potential witnesses; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb97bdc0d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2705/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise seriously jeopardizing an investigation or unduly delaying a trial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97bdc0e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2705/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The governmental entity shall maintain a true copy of certification under paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97bdc0f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2705/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Extensions of the delay of notification provided in section 2703 of up to ninety days each may be granted by the court upon application, or by certification by a governmental entity, but only in accordance with subsection (b) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97bdc10-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2705/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Upon expiration of the period of delay of notification under paragraph (1) or (4) of this subsection, the governmental entity shall serve upon, or deliver by registered or first-class mail to, the customer or subscriber a copy of the process or request together with notice that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb97bdc11-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2705/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" states with reasonable specificity the nature of the law enforcement inquiry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb97bdc12-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2705/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" informs such customer or subscriber—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb97bdc13-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2705/a/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that information maintained for such customer or subscriber by the service provider named in such process or request was supplied to or requested by that governmental authority and the date on which the supplying or request took place;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb97bdc14-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2705/a/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that notification of such customer or subscriber was delayed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb97bdc15-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2705/a/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" what governmental entity or court made the certification or determination pursuant to which that delay was made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb97bdc16-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2705/a/5/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which provision of this chapter allowed such delay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97bdc17-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2705/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As used in this subsection, the term “supervisory official” means the investigative agent in charge or assistant investigative agent in charge or an equivalent of an investigating agency’s headquarters or regional office, or the chief prosecuting attorney or the first assistant prosecuting attorney or an equivalent of a prosecuting attorney’s headquarters or regional office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb97bdc18-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2705/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preclusion of Notice to Subject of Governmental Access","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A governmental entity acting under section 2703, when it is not required to notify the subscriber or customer under section 2703(b)(1), or to the extent that it may delay such notice pursuant to subsection (a) of this section, may apply to a court for an order commanding a provider of electronic communications service or remote computing service to whom a warrant, subpoena, or court order is directed, for such period as the court deems appropriate, not to notify any other person of the existence of the warrant, subpoena, or court order. The court shall enter such an order if it determines that there is reason to believe that notification of the existence of the warrant, subpoena, or court order will result in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb97bdc19-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2705/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" endangering the life or physical safety of an individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97bdc1a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2705/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flight from prosecution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97bdc1b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2705/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" destruction of or tampering with evidence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97bdc1c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2705/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intimidation of potential witnesses; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97bdc1d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2705/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise seriously jeopardizing an investigation or unduly delaying a trial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb97bdc1e-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/508/tII/s201"},"text":"Pub. L. 99–508, title II, § 201[(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1864"},"text":"100 Stat. 1864","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb97bdc1f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb97bdc20-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb97bdc21-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", and, in the case of conduct pursuant to a court order or extension, applicable only with respect to court orders or extensions made after such effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/508/s202"},"text":"section 202 of Pub. L. 99–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2701"},"text":"section 2701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
