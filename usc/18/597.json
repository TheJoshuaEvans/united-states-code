{"tag":"section","attrib":{"id":"idb8d2a3ae-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s597"},"text":null,"children":[{"tag":"num","attrib":{"value":"597"},"text":"§ 597.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures to influence voting","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever makes or offers to make an expenditure to any person, either to vote or withhold his vote, or to vote for or against any candidate; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever solicits, accepts, or receives any such expenditure in consideration of his vote or the withholding of his vote—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Shall be fined under this title or imprisoned not more than one year, or both; and if the violation was willful, shall be fined under this title or imprisoned not more than two years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8d2a3af-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/721"},"text":"62 Stat. 721","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s601/a/12"},"text":"Pub. L. 104–294, title VI, § 601(a)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3498"},"text":"110 Stat. 3498","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8d2a3b0-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8d2a3b1-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on sections 250, 252, of title 2, U.S.C., 1940 ed., The Congress (","children":[{"tag":"ref","attrib":{"href":"/us/act/1925-02-28/ch368"},"text":"Feb. 28, 1925, ch. 368","children":[],"tail":", title III, §§ 311, 314, "},{"tag":"ref","attrib":{"href":"/us/stat/43/1073"},"text":"43 Stat. 1073","children":[],"tail":", 1074)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section consolidates the provisions of sections 250 and 252 of title 2, U.S.C., 1940 ed., The Congress.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to persons causing or procuring was omitted as unnecessary in view of definition of “principal” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The punishment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s252"},"text":"section 252 of title 2","children":[],"tail":", U.S.C., 1940 ed., The Congress, were incorporated at end of section upon authority of reference in such section making them applicable to this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “or both” were added to conform to the almost universal formula of the punishment provisions of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8d2a3b2-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8d2a3b3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" substituted “shall be fined under this title” for “shall be fined not more than $10,000” in last par."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “shall be fined under this title” for “shall be fined not more than $1,000” in last par."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
