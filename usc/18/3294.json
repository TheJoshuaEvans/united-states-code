{"tag":"section","attrib":{"id":"idb99ad4cc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3294"},"text":null,"children":[{"tag":"num","attrib":{"value":"3294"},"text":"§ 3294.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Theft of major artwork","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No person shall be prosecuted, tried, or punished for a violation of or conspiracy to violate section 668 unless the indictment is returned or the information is filed within 20 years after the commission of the offense.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb99ad4cd-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXII/s320902/b"},"text":"Pub. L. 103–322, title XXXII, § 320902(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2124"},"text":"108 Stat. 2124","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
