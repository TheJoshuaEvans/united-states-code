{"tag":"section","attrib":{"id":"idb8c6955a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s292"},"text":null,"children":[{"tag":"num","attrib":{"value":"292"},"text":"§ 292.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitation of employment and receipt of unapproved fees concerning Federal employees’ compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever solicits employment for himself or another in respect to a case, claim, or award for compensation under, or to be brought under, subchapter I of chapter 81 of title 5; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever receives a fee, other consideration, or gratuity on account of legal or other services furnished in respect to a case, claim, or award for compensation under subchapter I of chapter 81 of title 5, unless the fee, consideration, or gratuity is approved by the Secretary of Labor—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Shall, for each offense, be fined under this title or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8c6955b-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s3/b"},"text":"Pub. L. 89–554, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/608"},"text":"80 Stat. 608","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c6955c-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8c6955d-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8c6955e-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s773/b"},"text":"5 U.S.C. 773(b)","children":[],"tail":" (last sentence)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-10-14/ch691/s208"},"text":"Oct. 14, 1949, ch. 691, § 208","children":[],"tail":" “Sec. 23(b) (last sentence)”, "},{"tag":"html:a","attrib":{"href":"/us/stat/63/865"},"text":"63 Stat. 865","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “under subchapter I of chapter 81 of title 5” are substituted for “under this Act” (Federal Employees’ Compensation Act) to reflect the codification of the Act in title 5, United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “is approved by the Secretary of Labor” are substituted for “is so approved”. The words “Secretary of Labor” are substituted for “Administrator” (Federal Security Administrator) on authority of 1950 Reorg. Plan No. 19, § 1, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/1271"},"text":"64 Stat. 1271","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “shall be guilty of a misdemeanor” are omitted as unnecessary in view of the definitive ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1"},"text":"section 1 of this title","children":[],"tail":". (See reviser’s note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s212"},"text":"18 U.S.C. 212","children":[],"tail":", 1964 ed.)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “and upon conviction thereof” are omitted as unnecessary because punishment can be imposed only after conviction.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “or both” are substituted for “or by both such fine and imprisonment”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes in phraseology are made to conform to the style of title 18.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8c6955f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8c69560-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $1,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
