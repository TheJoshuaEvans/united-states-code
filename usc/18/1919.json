68/1135"},"text":"68 Stat. 1135","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “under chapter 85 of title 5” are substituted for “under this title” (Title XV of the Social Security Act, as amended) to reflect the codification of the Title in title 5, United States Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
