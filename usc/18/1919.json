{"tag":"section","attrib":{"id":"idb9392d1c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1919"},"text":null,"children":[{"tag":"num","attrib":{"value":"1919"},"text":"§ 1919.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False statement to obtain unemployment compensation for Federal service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever makes a false statement or representation of a material fact knowing it to be false, or knowingly fails to disclose a material fact, to obtain or increase for himself or for any other individual any payment authorized to be paid under chapter 85 of title 5 or under an agreement thereunder, shall be fined not more than $1,000 or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9392d1d-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s3/d"},"text":"Pub. L. 89–554, § 3(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/609"},"text":"80 Stat. 609","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9392d1e-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9392d1f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb9392d20-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attri