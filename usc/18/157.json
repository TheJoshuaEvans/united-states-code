{"tag":"section","attrib":{"id":"idb8b13810-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s157"},"text":null,"children":[{"tag":"num","attrib":{"value":"157"},"text":"§ 157.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bankruptcy fraud","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A person who, having devised or intending to devise a scheme or artifice to defraud and for the purpose of executing or concealing such a scheme or artifice or attempting to do so—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b13811-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s157/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" files a petition under title 11, including a fraudulent involuntary petition under section 303 of such title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b13812-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s157/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" files a document in a proceeding under title 11; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b13813-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s157/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes a false or fraudulent representation, claim, or promise concerning or in relation to a proceeding under title 11, at any time before or after the filing of the petition, or in relation to a proceeding falsely asserted to be pending under such title,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title, imprisoned not more than 5 years, or both.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8b13814-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/394/tIII/s312/a/1/B"},"text":"Pub. L. 103–394, title III, § 312(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4140"},"text":"108 Stat. 4140","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/tIII/s332/c"},"text":"Pub. L. 109–8, title III, § 332(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/103"},"text":"119 Stat. 103","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/327/s2/b"},"text":"Pub. L. 111–327, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3562"},"text":"124 Stat. 3562","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8b13815-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8b13816-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8b13817-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/327/s2/b/1"},"text":"Pub. L. 111–327, § 2(b)(1)","children":[],"tail":", struck out “bankruptcy” after “involuntary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/327/s2/b/2"},"text":"Pub. L. 111–327, § 2(b)(2)","children":[],"tail":", struck out “, including a fraudulent involuntary bankruptcy petition under section 303 of such title” after “title 11”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Pars. (1) to (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8"},"text":"Pub. L. 109–8","children":[],"tail":", which directed insertion of “, including a fraudulent involuntary bankruptcy petition under section 303 of such title” after “title 11”, was executed by making the insertion after “title 11” wherever appearing, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8b13818-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8b13819-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8"},"text":"Pub. L. 109–8","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", and not applicable with respect to cases commenced under Title 11, Bankruptcy, before such effective date, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1501"},"text":"section 1501 of Pub. L. 109–8","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of Title 11","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8b1381a-47c4-11f1-9a61