{"tag":"section","attrib":{"id":"idb9344ad9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1837"},"text":null,"children":[{"tag":"num","attrib":{"value":"1837"},"text":"§ 1837.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability to conduct outside the United States","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"This chapter also applies to conduct occurring outside the United States if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9344ada-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1837/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offender is a natural person who is a citizen or permanent resident alien of the United States, or an organization organized under the laws of the United States or a State or political subdivision thereof; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9344adb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1837/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an act in furtherance of the offense was committed in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9344adc-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294/tI/s101/a"},"text":"Pub. L. 104–294, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3490"},"text":"110 Stat. 3490","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
