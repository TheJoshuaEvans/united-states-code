{"tag":"section","attrib":{"id":"idb8d4ed1b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s611"},"text":null,"children":[{"tag":"num","attrib":{"value":"611"},"text":"§ 611.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting by aliens","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8d4ed1c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s611/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" It shall be unlawful for any alien to vote in any election held solely or in part for the purpose of electing a candidate for the office of President, Vice President, Presidential elector, Member of the Senate, Member of the House of Representatives, Delegate from the District of Columbia, or Resident Commissioner, unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8d4ed1d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s611/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the election is held partly for some other purpose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d4ed1e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s611/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aliens are authorized to vote for such other purpose under a State constitution or statute or a local ordinance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d4ed1f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s611/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" voting for such other purpose is conducted independently of voting for a candidate for such Federal offices, in such a manner that an alien has the opportunity to vote for such other purpose, but not an opportunity to vote for a candidate for any one or more of such Federal offices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8d4ed20-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s611/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who violates this section shall be fined under this title, imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8d4ed21-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s611/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subsection (a) does not apply to an alien if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8d4ed22-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s611/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each natural parent of the alien (or, in the case of an adopted alien, each adoptive parent of the alien) is or was a citizen (whether by birth or naturalization);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d4ed23-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s611/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the alien permanently resided in the United States prior to attaining the age of 16; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d4ed24-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s611/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the alien reasonably believed at the time of voting in violation of such subsection that he or she was a citizen of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8d4ed25-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tII/s216/a"},"text":"Pub. L. 104–208, div. C, title II, § 216(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-572"},"text":"110 Stat. 3009–572","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/395/tII/s201/d/1"},"text":"Pub. L. 106–395, title II, § 201(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1635"},"text":"114 Stat. 1635","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8d4ed26-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8d4ed27-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb8d4ed28-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 611, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/724"},"text":"62 Stat. 724","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1972-02-07"},"text":"Feb. 7, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/225/tII/s206"},"text":"Pub. L. 92–225, title II, § 206","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/10"},"text":"86 Stat. 10","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1974-10-15"},"text":"Oct. 15, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/93/443/tI"},"text":"Pub. L. 93–443, title I","children":[],"tail":", §§ 101(e)(2), 103, "},{"tag":"ref","attrib":{"href":"/us/stat/88/1267"},"text":"88 Stat. 1267","children":[],"tail":", 1272, prohibited campaign contributions by government contractors, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/283/tII/s201/a"},"text":"Pub. L. 94–283, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-11"},"text":"May 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/496"},"text":"90 Stat. 496","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30119"},"text":"section 30119 of Title 52","children":[],"tail":", Voting and Elections."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8d4ed29-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/395"},"text":"Pub. L. 106–395","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8d4ed2a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8d4ed2b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/395/tII/s201/d/3"},"text":"Pub. L. 106–395, title II, § 201(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1636"},"text":"114 Stat. 1636","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/395/tII/s201/d/3"},"text":"“The amendment made by paragraph (1) [amending this section] shall be effective as if included in the enactment of section 216 of the Illegal Immigration Reform and Immigrant Responsibility Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Public Law 104–208","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-572"},"text":"110 Stat. 3009–572","children":[],"tail":"). The amendment made by paragraph (2) [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1015"},"text":"section 1015 of this title","children":[],"tail":"] shall be effective as if included in the enactment of section 215 of the Illegal Immigration Reform and Immigrant Responsibility Act of 1996 ("},{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Public Law 104–208","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-572"},"text":"110 Stat. 3009–572","children":[],"tail":"). The amendments made by paragraphs (1) and (2) shall apply to an alien prosecuted on or after "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"September 30, 1996","children":[],"tail":", except in the case of an alien whose criminal proceeding (including judicial review thereof) has been finally concluded before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
