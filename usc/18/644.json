{"tag":"section","attrib":{"id":"idb8d4ed51-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s644"},"text":null,"children":[{"tag":"num","attrib":{"value":"644"},"text":"§ 644.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Banker receiving unauthorized deposit of public money","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, not being an authorized depositary of public moneys, knowingly receives from any disbursing officer, or collector of internal revenue, or other agent of the United States, any public money on deposit, or by way of loan or accommodation, with or without interest, or otherwise than in payment of a debt against the United States, or uses, transfers, converts, appropriates, or applies any portion of the public money for any purpose not prescribed by law is guilty of embezzlement and shall be fined under this title or not more than the amount so embezzled, whichever is greater, or imprisoned not more than ten years, or both; but if the amount embezzled does not exceed $1,000, he shall be fined not more than $1,000 or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8d4ed52-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/726"},"text":"62 Stat. 726","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/2/G"},"text":"Pub. L. 103–322, title XXXIII, § 330016(2)(G)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2148"},"text":"108 Stat. 2148","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s606/a"},"text":"Pub. L. 104–294, title VI, § 606(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3511"},"text":"110 Stat. 3511","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8d4ed53-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8d4ed54-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 182 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s96"},"text":"Mar. 4, 1909, ch. 321, § 96","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1106"},"text":"35 Stat. 1106","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The smaller punishment for an offense involving $100 or less was added. (See reviser’s notes under sections 641 and 645 of this title.)","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8d4ed55-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8d4ed56-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" substituted “does not exceed $1,000” for “does not exceed $100”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “shall be fined under this title or not more than the amount so embezzled, whichever is greater, or imprisoned” for “shall be fined not more than the amount so embezzled or imprisoned”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
