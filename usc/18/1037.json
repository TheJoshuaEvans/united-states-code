{"tag":"section","attrib":{"id":"idb91096ff-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1037"},"text":null,"children":[{"tag":"num","attrib":{"value":"1037"},"text":"§ 1037.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraud and related activity in connection with electronic mail","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9109700-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1037/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever, in or affecting interstate or foreign commerce, knowingly—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9109701-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1037/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accesses a protected computer without authorization, and intentionally initiates the transmission of multiple commercial electronic mail messages from or through such computer,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9109702-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1037/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses a protected computer to relay or retransmit multiple commercial electronic mail messages, with the intent to deceive or mislead recipients, or any Internet access service, as to the origin of such messages,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9109703-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1037/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" materially falsifies header information in multiple commercial electronic mail messages and intentionally initiates the transmission of such messages,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9109704-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1037/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" registers, using information that materially falsifies the identity of the actual registrant, for five or more electronic mail accounts or online user accounts or two or more domain names, and intentionally initiates the transmission of multiple commercial electronic mail messages from any combination of such accounts or domain names, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9109705-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1037/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" falsely represents oneself to be the registrant or the legitimate successor in interest to the registrant of 5 or more Internet Protocol addresses, and intentionally initiates the transmission of multiple commercial electronic mail messages from such addresses,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"or conspires to do so, shall be punished as provided in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9109706-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1037/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The punishment for an offense under subsection (a) is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9109707-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1037/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a fine under this title, imprisonment for not more than 5 years, or both, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9109708-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1037/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense is committed in furtherance of any felony under the laws of the United States or of any State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9109709-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1037/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the defendant has previously been convicted under this section or section 1030, or under the law of any State for conduct involving the transmission of multiple commercial electronic mail messages or unauthorized access to a computer system;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb910970a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1037/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a fine under this title, imprisonment for not more than 3 years, or both, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb910970b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1037/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense is an offense under subsection (a)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb910970c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1037/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense is an offense under subsection (a)(4) and involved 20 or more falsified electronic mail or online user account registrations, or 10 or more falsified domain name registrations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb910970d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1037/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the volume of electronic mail messages transmitted in furtherance of the offense exceeded 2,500 during any 24-hour period, 25,000 during any 30-day period, or 250,000 during any 1-year period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb910970e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1037/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense caused loss to one or more persons aggregating $5,000 or more in value during any 1-year period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb910970f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1037/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a result of the offense any individual committing the offense obtained anything of value aggregating $5,000 or more during any 1-year period; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9109710-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1037/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense was undertaken by the defendant in concert with three or more other persons with respect to whom the defendant occupied a position of organizer or leader; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9109711-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1037/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fine under this title or imprisonment for not more than 1 year, or both, in any other case.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9109712-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1037/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Forfeiture.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9109713-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1037/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The court, in imposing sentence on a person who is convicted of an offense under this section, shall order that the defendant forfeit to the United States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9109714-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1037/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any property, real or personal, constituting or traceable to gross proceeds obtained from such offense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9109715-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1037/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any equipment, software, or other technology used or intended to be used to commit or to facilitate the commission of such offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9109716-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1037/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The procedures set forth in section 413 of the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s853"},"text":"21 U.S.C. 853","children":[],"tail":"), other than subsection (d) of that section, and in Rule 32.2 of the Federal Rules of Criminal Procedure, shall apply to all stages of a criminal forfeiture proceeding under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9109717-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1037/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9109718-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1037/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Loss","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “loss” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1030/e"},"text":"section 1030(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9109719-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1037/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Materially","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of paragraphs (3) and (4) of subsection (a), header information or registration information is materially falsified if it is altered or concealed in a manner that would impair the ability of a recipient of the message, an Internet access service processing the message on behalf of a recipient, a person alleging a violation of this section, or a law enforcement agency to identify, locate, or respond to a person who initiated the electronic mail message or to investigate the alleged violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb910971a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1037/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Multiple","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “multiple” means more than 100 electronic mail messages during a 24-hour period, more than 1,000 electronic mail messages during a 30-day period, or more than 10,000 electronic mail messages during a 1-year period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb910971b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1037/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other terms","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any other term has the meaning given that term by section 3 of the CAN-SPAM Act of 2003.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb910971c-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/187/s4/a/1"},"text":"Pub. L. 108–187, § 4(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-16"},"text":"Dec. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2703"},"text":"117 Stat. 2703","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb910971d-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb910971e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb910971f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Criminal Procedure, referred to in subsec. (c)(2), are set out in the Appendix to this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3 of the CAN-SPAM Act of 2003, referred to in subsec. (d)(4), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7702"},"text":"section 7702 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9109720-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9109721-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2004-01-01"},"text":"Jan. 1, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/187/s16"},"text":"section 16 of Pub. L. 108–187","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7701"},"text":"section 7701 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
