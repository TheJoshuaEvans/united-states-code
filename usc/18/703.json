{"tag":"section","attrib":{"id":"idb8dc1971-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s703"},"text":null,"children":[{"tag":"num","attrib":{"value":"703"},"text":"§ 703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniform of friendly nation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, within the jurisdiction of the United States, with intent to deceive or mislead, wears any naval, military, police, or other official uniform, decoration, or regalia of any foreign state, nation, or government with which the United States is at peace, or anything so nearly resembling the same as to be calculated to deceive, shall be fined under this title or imprisoned not more than six months, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8dc1972-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/732"},"text":"62 Stat. 732","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/E"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2146"},"text":"108 Stat. 2146","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8dc1973-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8dc1974-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s246"},"text":"section 246 of title 22","children":[],"tail":", U.S.C., 1940 ed., Foreign Relations and Intercourse ("},{"tag":"ref","attrib":{"href":"/us/act/1918-07-08/ch138"},"text":"July 8, 1918, ch. 138","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/821"},"text":"40 Stat. 821","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “upon conviction” were deleted as surplusage, since punishment cannot be imposed until a conviction is secured.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to territories or places subject to jurisdiction of the United States was omitted in view of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s5"},"text":"section 5 of this title","children":[],"tail":" defining the term “United States.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Fine of “$250” was substituted for “$300” as being more consonant with the penalties provided for similar offenses in this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “unless such wearing thereof be authorized by such state, nation, or government” were deleted as unnecessary and undesirable since it is unthinkable that a friendly power would authorize such deceit.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8dc1975-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8dc1976-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $250”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
