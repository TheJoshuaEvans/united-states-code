{"tag":"section","attrib":{"id":"idb9a6bc50-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3556"},"text":null,"children":[{"tag":"num","attrib":{"value":"3556"},"text":"§ 3556.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Order of restitution","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The court, in imposing a sentence on a defendant who has been found guilty of an offense shall order restitution in accordance with section 3663A, and may order restitution in accordance with section 3663. The procedures under section 3664 shall apply to all orders of restitution under this section.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9a6bc51-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s212/a/2"},"text":"Pub. L. 98–473, title II, § 212(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1991"},"text":"98 Stat. 1991","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/646/s20/b"},"text":"Pub. L. 99–646, § 20(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3596"},"text":"100 Stat. 3596","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tII/s202"},"text":"Pub. L. 104–132, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1227"},"text":"110 Stat. 1227","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9a6bc52-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9a6bc53-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9a6bc54-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132"},"text":"Pub. L. 104–132","children":[],"tail":" substituted “shall order restitution” for “may order restitution” and “section 3663A, and may order restitution in accordance with section 3663. The procedures under section 3664 shall apply to all orders of restitution under this section” for “sections 3663 and 3664”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646"},"text":"Pub. L. 99–646","children":[],"tail":" substituted “may order restitution in accordance with sections 3663 and 3664” for “under this title, or an offense under section 902(h), (i), (j), or (n) of the Federal Aviation Act of 1958 ("},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1472"},"text":"49 U.S.C. 1472","children":[],"tail":"), may order, in addition to the sentence that is imposed pursuant to the provisions of section 3551, that the defendant make restitution to any victim of the offense in accordance with the provisions of sections 3663 and 3664”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9a6bc55-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb9a6bc56-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children"