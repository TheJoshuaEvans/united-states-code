{"tag":"section","attrib":{"id":"idb9796a7b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702"},"text":null,"children":[{"tag":"num","attrib":{"value":"2702"},"text":"§ 2702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary disclosure of customer communications or records","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9796a7c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b) or (c)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9796a7d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person or entity providing an electronic communication service to the public shall not knowingly divulge to any person or entity the contents of a communication while in electronic storage by that service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9796a7e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a person or entity providing remote computing service to the public shall not knowingly divulge to any person or entity the contents of any communication which is carried or maintained on that service—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9796a7f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on behalf of, and received by means of electronic transmission from (or created by means of computer processing of communications received by means of electronic transmission from), a subscriber or customer of such service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9796a80-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solely for the purpose of providing storage or computer processing services to such subscriber or customer, if the provider is not authorized to access the contents of any such communications for purposes of providing any services other than storage or computer processing; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9796a81-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a provider of remote computing service or electronic communication service to the public shall not knowingly divulge a record or other information pertaining to a subscriber to or customer of such service (not including the contents of communications covered by paragraph (1) or (2)) to any governmental entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9796a82-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions for disclosure of communications","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A provider described in subsection (a) may divulge the contents of a communication—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9796a83-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to an addressee or intended recipient of such communication or an agent of such addressee or intended recipient;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9796a84-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as otherwise authorized in section 2517, 2511(2)(a), or 2703 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9796a85-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the lawful consent of the originator or an addressee or intended recipient of such communication, or the subscriber in the case of remote computing service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9796a86-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a person employed or authorized or whose facilities are used to forward such communication to its destination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9796a87-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as may be necessarily incident to the rendition of the service or to the protection of the rights or property of the provider of that service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9796a88-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the National Center for Missing and Exploited Children, in connection with a report submitted thereto under section 2258A;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9796a89-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to a law enforcement agency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9796a8a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the contents—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9796a8b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/b/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were inadvertently obtained by the service provider; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9796a8c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/b/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appear to pertain to the commission of a crime; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"status":"repealed","id":"idb9796a8d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"[(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21/tV/s508/b/1/A"},"text":"Pub. L. 108–21, title V, § 508(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-30"},"text":"Apr. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/684"},"text":"117 Stat. 684","children":[],"tail":"]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9796a8e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a governmental entity, if the provider, in good faith, believes that an emergency involving danger of death or serious physical injury to any person requires disclosure without delay of communications relating to the emergency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9796a8f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a foreign government pursuant to an order from a foreign government that is subject to an executive agreement that the Attorney General has determined and certified to Congress satisfies section 2523.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9796a90-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions for Disclosure of Customer Records","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A provider described in subsection (a) may divulge a record or other information pertaining to a subscriber to or customer of such service (not including the contents of communications covered by subsection (a)(1) or (a)(2))—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9796a91-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as otherwise authorized in section 2703;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9796a92-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the lawful consent of the customer or subscriber;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9796a93-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as may be necessarily incident to the rendition of the service or to the protection of the rights or property of the provider of that service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9796a94-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a governmental entity, if the provider, in good faith, believes that an emergency involving danger of death or serious physical injury to any person requires disclosure without delay of information relating to the emergency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9796a95-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the National Center for Missing and Exploited Children, in connection with a report submitted thereto under section 2258A;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9796a96-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any person other than a governmental entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9796a97-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a foreign government pursuant to an order from a foreign government that is subject to an executive agreement that the Attorney General has determined and certified to Congress satisfies section 2523.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9796a98-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting of Emergency Disclosures","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"On an annual basis, the Attorney General shall submit to the Committee on the Judiciary of the House of Representatives and the Committee on the Judiciary of the Senate a report containing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9796a99-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of accounts from which the Department of Justice has received voluntary disclosures under subsection (b)(8);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9796a9a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a summary of the basis for disclosure in those instances where—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9796a9b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" voluntary disclosures under subsection (b)(8) were made to the Department of Justice; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9796a9c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the investigation pertaining to those disclosures was closed without the filing of criminal charges; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9796a9d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2702/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of accounts from which the Department of Justice has received voluntary disclosures under subsection (c)(4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9796a9e-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/508/tII/s201"},"text":"Pub. L. 99–508, title II, § 201[(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1860"},"text":"100 Stat. 1860","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7037"},"text":"Pub. L. 100–690, title VII, § 7037","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4399"},"text":"102 Stat. 4399","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/314/tVI/s604/b"},"text":"Pub. L. 105–314, title VI, § 604(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2984"},"text":"112 Stat. 2984","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tII/s212/a/1"},"text":"Pub. L. 107–56, title II, § 212(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/284"},"text":"115 Stat. 284","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXXII/s2207/d/1"},"text":"Pub. L. 107–296, title XXII, § 2207(d)(1)","children":[],"tail":", formerly title II, § 225(d)(1), "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2157"},"text":"116 Stat. 2157","children":[],"tail":", renumbered § 2207(d)(1), "},{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/g/2/I"},"text":"Pub. L. 115–278, § 2(g)(2)(I)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-11-16"},"text":"Nov. 16, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4178"},"text":"132 Stat. 4178","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/21/tV/s508/b"},"text":"Pub. L. 108–21, title V, § 508(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-30"},"text":"Apr. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/684"},"text":"117 Stat. 684","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/tI/s107/a"},"text":"Pub. L. 109–177, title I, § 107(a)","children":[],"tail":", (b)(1), (c), "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/202"},"text":"120 Stat. 202","children":[],"tail":", 203; "},{"tag":"ref","attrib":{"href":"/us/pl/110/401/tV/s501/b/2"},"text":"Pub. L. 110–401, title V, § 501(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4251"},"text":"122 Stat. 4251","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/23/tVI/s602/d"},"text":"Pub. L. 114–23, title VI, § 602(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-02"},"text":"June 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/295"},"text":"129 Stat. 295","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dV/s104/2/A"},"text":"Pub. L. 115–141, div. V, § 104(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1216"},"text":"132 Stat. 1216","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb97bdb9f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb97bdba0-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb97bdba1-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s104/2/A/i"},"text":"Pub. L. 115–141, § 104(2)(A)(i)","children":[],"tail":", added par. (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s104/2/A/ii"},"text":"Pub. L. 115–141, § 104(2)(A)(ii)","children":[],"tail":", added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23"},"text":"Pub. L. 114–23","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsecs. (b)(6), (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/401"},"text":"Pub. L. 110–401","children":[],"tail":" substituted “section 2258A” for “section 227 of the Victims of Child Abuse Act of 1990 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13032"},"text":"42 U.S.C. 13032","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s107/c"},"text":"Pub. L. 109–177, § 107(c)","children":[],"tail":", inserted “or (c)” after “Except as provided in subsection (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s107/b/1/A"},"text":"Pub. L. 109–177, § 107(b)(1)(A)","children":[],"tail":", struck out “Federal, State, or local” before “governmental entity”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s107/b/1/B"},"text":"Pub. L. 109–177, § 107(b)(1)(B)","children":[],"tail":", added par. (4) and struck out former par. (4) which read as follows: “to a 