{"tag":"section","attrib":{"id":"idb917c2d9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1165"},"text":null,"children":[{"tag":"num","attrib":{"value":"1165"},"text":"§ 1165.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hunting, trapping, or fishing on Indian land","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, without lawful authority or permission, willfully and knowingly goes upon any land that belongs to any Indian or Indian tribe, band, or group and either are held by the United States in trust or are subject to a restriction against alienation imposed by the United States, or upon any lands of the United States that are reserved for Indian use, for the purpose of hunting, trapping, or fishing thereon, or for the removal of game, peltries, or fish therefrom, shall be fined under this title or imprisoned not more than ninety days, or both, and all game, fish, and peltries in his possession shall be forfeited.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb917c2da-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/634/s2"},"text":"Pub. L. 86–634, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-12"},"text":"July 12, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/469"},"text":"74 Stat. 469","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/D"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2146"},"text":"108 Stat. 2146","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb917c2db-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb917c2dc-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb917c2dd-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $200”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
