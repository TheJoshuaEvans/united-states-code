{"tag":"section","attrib":{"id":"idb949cec4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2246"},"text":null,"children":[{"tag":"num","attrib":{"value":"2246"},"text":"§ 2246.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions for chapter","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb949cec5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2246/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “prison” means a correctional, detention, or penal facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb949cec6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2246/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “sexual act” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb949cec7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2246/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contact between the penis and the vulva or the penis and the anus, and for purposes of this subparagraph contact involving the penis occurs upon penetration, however slight;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb949cec8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2246/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contact between the mouth and the penis, the mouth and the vulva, or the mouth and the anus;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb949cec9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2246/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the penetration, however slight, of the anal or genital opening of another by a hand or finger or by any object, with an intent to abuse, humiliate, harass, degrade, or arouse or gratify the sexual desire of any person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb949ceca-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2246/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the intentional touching, not through the clothing, of the genitalia of another person who has not attained the age of 16 years with an intent to abuse, humiliate, harass, degrade, or arouse or gratify the sexual desire of any person;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb949cecb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2246/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “sexual contact” means the intentional touching, either directly or through the clothing, of the genitalia, anus, groin, breast, inner thigh, or buttocks of any person with an intent to abuse, humiliate, harass, degrade, or arouse or gratify the sexual desire of any person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb949cecc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2246/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “serious bodily injury” means bodily injury that involves a substantial risk of death, unconsciousness, extreme physical pain, protracted and obvious disfigurement, or protracted loss or impairment of the function of a bodily member, organ, or mental faculty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb949cecd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2246/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “official detention” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb949cece-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2246/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detention by a Federal officer or employee, or under the direction of a Federal officer or employee, following arrest for an offense; following surrender in lieu of arrest for an offense; following a charge or conviction of an offense, or an allegation or finding of juvenile delinquency; following commitment as a material witness; following civil commitment in lieu of criminal proceedings or pending resumption of criminal proceedings that are being held in abeyance, or pending extradition, deportation, or exclusion; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb949cecf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2246/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" custody by a Federal officer or employee, or under the direction of a Federal officer or employee, for purposes incident to any detention described in subparagraph (A) of this paragraph, including transportation, medical diagnosis or treatment, court appearance, work, and recreation;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"but does not include supervision or other control (other than custody during specified hours or days) after release on bail, probation, or parole, or after release following a finding of juvenile delinquency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb949ced0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2246/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” means a State of the United States, the District of Columbia, and any commonwealth, possession, or territory of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb949ced1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2246/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Federal law enforcement officer” has the meaning given the term in section 115.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb949ced2-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646/s87/b"},"text":"Pub. L. 99–646, § 87(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3622"},"text":"100 Stat. 3622","children":[],"tail":", § 2245, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/654/s2"},"text":"Pub. L. 99–654, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3662"},"text":"100 Stat. 3662","children":[],"tail":", § 2245; renumbered § 2246 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s40502"},"text":"Pub. L. 103–322, title IV, § 40502","children":[],"tail":", title VI, § 60010(a)(1), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1945"},"text":"108 Stat. 1945","children":[],"tail":", 1972; "},{"tag":"ref","attrib":{"href":"/us/pl/105/314/tIII/s301/c"},"text":"Pub. L. 105–314, title III, § 301(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2979"},"text":"112 Stat. 2979","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tXII/s1202/e"},"text":"Pub. L. 117–103, div. W, title XII, § 1202(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/925"},"text":"136 Stat. 925","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb949ced3-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb949ced4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb949ced5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646"},"text":"Pub. L. 99–646","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/99/654"},"text":"Pub. L. 99–654","children":[],"tail":" added identical sections."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb949ced6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","