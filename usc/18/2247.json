{"tag":"section","attrib":{"id":"idb949ced9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2247"},"text":null,"children":[{"tag":"num","attrib":{"value":"2247"},"text":"§ 2247.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repeat offenders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb949ceda-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2247/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Term of Imprisonment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The maximum term of imprisonment for a violation of this chapter after a prior sex offense conviction shall be twice the term otherwise provided by this chapter, unless section 3559(e) applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb949cedb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2247/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prior Sex Offense Conviction Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “prior sex offense conviction” has the meaning given that term in section 2426(b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb949cedc-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s40111/a"},"text":"Pub. L. 103–322, title IV, § 40111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1903"},"text":"108 Stat. 1903","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/314/tIII/s303"},"text":"Pub. L. 105–314, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2979"},"text":"112 Stat. 2979","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/21/tI/s106/b"},"text":"Pub. L. 108–21, title I, § 106(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-30"},"text":"Apr. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/655"},"text":"117 Stat. 655","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb949cedd-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb949cede-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb949cedf-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21"},"text":"Pub. L. 108–21","children":[],"tail":" inserted “, unless section 3559(e) applies” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/314"},"text":"Pub. L. 105–314","children":[],"tail":" reenacted section catchline without change and amended text generally. Prior to amendment, text read as follows: “Any person who violates a provision of this chapter, after one or more prior convictions for an offense punishable under this chapter, or after one or more prior convictions under the laws of any State relating to aggravated sexual abuse, sexual abuse, or abusive sexual contact have become final, is punishable by a term of imprisonment up to twice that otherwise authorized.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
