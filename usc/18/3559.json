{"tag":"section","attrib":{"id":"idb9a6bc63-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559"},"text":null,"children":[{"tag":"num","attrib":{"value":"3559"},"text":"§ 3559.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sentencing classification of offenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9a6bc64-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Classification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An offense that is not specifically classified by a letter grade in the section defining it, is classified if the maximum term of imprisonment authorized is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9a6bc65-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" life imprisonment, or if the maximum penalty is death, as a Class A felony;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a6bc66-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" twenty-five years or more, as a Class B felony;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a6bc67-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" less than twenty-five years but ten or more years, as a Class C felony;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a6bc68-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" less than ten years but five or more years, as a Class D felony;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a6bc69-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" less than five years but more than one year, as a Class E felony;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a6bc6a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one year or less but more than six months, as a Class A misdemeanor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a6bc6b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" six months or less but more than thirty days, as a Class B misdemeanor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a6bc6c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" thirty days or less but more than five days, as a Class C misdemeanor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a6bc6d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" five days or less, or if no imprisonment is authorized, as an infraction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9a6bc6e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of Classification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (c), an offense classified under subsection (a) carries all the incidents assigned to the applicable letter designation, except that the maximum term of imprisonment is the term authorized by the law describing the offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9a6bc6f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Imprisonment of Certain Violent Felons.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9a6bc70-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mandatory life imprisonment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, a person who is convicted in a court of the United States of a serious violent felony shall be sentenced to life imprisonment if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9a6bc71-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the person has been convicted (and those convictions have become final) on separate prior occasions in a court of the United States or of a State of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9a6bc72-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 or more serious violent felonies; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9a6bc73-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more serious violent felonies and one or more serious drug offenses; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9a6bc74-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each serious violent felony or serious drug offense used as a basis for sentencing under this subsection, other than the first, was committed after the defendant’s conviction of the preceding serious violent felony or serious drug offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a6bc75-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9a6bc76-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “assault with intent to commit rape” means an offense that has as its elements engaging in physical contact with another person or using or brandishing a weapon against another person with intent to commit aggravated sexual abuse or sexual abuse (as described in sections 2241 and 2242);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9a6bc77-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “arson” means an offense that has as its elements maliciously damaging or destroying any building, inhabited structure, vehicle, vessel, or real property by means of fire or an explosive;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9a6bc78-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “extortion” means an offense that has as its elements the extraction of anything of value from another person by threatening or placing that person in fear of injury to any person or kidnapping of any person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9a6bc79-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “firearms use” means an offense that has as its elements those described in section 924(c) or 929(a), if the firearm was brandished, discharged, or otherwise used as a weapon and the crime of violence or drug trafficking crime during and relation to which the firearm was used was subject to prosecution in a court of the United States or a court of a State, or both;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9a6bc7a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “kidnapping” means an offense that has as its elements the abduction, restraining, confining, or carrying away of another person by force or threat of force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9a6bc7b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “serious violent felony” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9a6bc7c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal or State offense, by whatever designation and wherever committed, consisting of murder (as described in section 1111); manslaughter other than involuntary manslaughter (as described in section 1112); assault with intent to commit murder (as described in section 113(a)); assault with intent to commit rape; aggravated sexual abuse and sexual abuse (as described in sections 2241 and 2242); abusive sexual contact (as described in sections 2244(a)(1) and (a)(2)); kidnapping; aircraft piracy (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s46502"},"text":"section 46502 of Title 49","children":[],"tail":"); robbery (as described in section 2111, 2113, or 2118); carjacking (as described in section 2119); extortion; arson; firearms use; firearms possession (as described in section 924(c)); or attempt, conspiracy, or solicitation to commit any of the above offenses; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9a6bc7d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other offense punishable by a maximum term of imprisonment of 10 years or more that has as an element the use, attempted use, or threatened use of physical force against the person of another or that, by its nature, involves a substantial risk that physical force against the person of another may be used in the course of committing the offense;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9a6bc7e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” means a State of the United States, the District of Columbia, and a commonwealth, territory, or possession of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9a6bc7f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “serious drug offense” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9a6bc80-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c/2/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an offense that is punishable under section 401(b)(1)(A) or 408 of the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s841/b/1/A"},"text":"21 U.S.C. 841(b)(1)(A)","children":[],"tail":", 848) or section 1010(b)(1)(A) of the Controlled Substances Import and Export Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s960/b/1/A"},"text":"21 U.S.C. 960(b)(1)(A)","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9a6bc81-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c/2/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an offense under State law that, had the offense been prosecuted in a court of the United States, would have been punishable under section 401(b)(1)(A) or 408 of the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s841/b/1/A"},"text":"21 U.S.C. 841(b)(1)(A)","children":[],"tail":", 848) or section 1010(b)(1)(A) of the Controlled Substances Import and Export Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s960/b/1/A"},"text":"21 U.S.C. 960(b)(1)(A)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a6bc82-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonqualifying felonies.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9a6bc83-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Robbery in certain cases","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Robbery, an attempt, conspiracy, or solicitation to commit robbery; or an offense described in paragraph (2)(F)(ii) shall not serve as a basis for sentencing under this subsection if the defendant establishes by clear and convincing evidence that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9a6bc84-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no firearm or other dangerous weapon was used in the offense and no threat of use of a firearm or other dangerous weapon was involved in the offense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9a6bc85-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense did not result in death or serious bodily injury (as defined in section 1365) to any person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9a6bc86-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Arson in certain cases","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Arson shall not serve as a basis for sentencing under this subsection if the defendant establishes by clear and convincing evidence that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9a6bc87-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense posed no threat to human life; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9a6bc88-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the defendant reasonably believed the offense posed no threat to human life.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a6bc89-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information filed by united states attorney","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The provisions of section 411(a) of the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s851/a"},"text":"21 U.S.C. 851(a)","children":[],"tail":") shall apply to the imposition of sentence under this subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a6bc8a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection shall not be construed to preclude imposition of the death penalty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a6bc8b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special provision for indian country","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No person subject to the criminal jurisdiction of an Indian tribal government shall be subject to this subsection for any offense for which Federal jurisdiction is solely predicated on Indian country (as defined in section 1151) and which occurs within the boundaries of such Indian country unless the governing body of the tribe has elected that this subsection have effect over land and persons subject to the criminal jurisdiction of the tribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a6bc8c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Resentencing upon overturning of prior conviction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the conviction for a serious violent felony or serious drug offense that was a basis for sentencing under this subsection is found, pursuant to any appropriate State or Federal procedure, to be unconstitutional or is vitiated on the explicit basis of innocence, or if the convicted person is pardoned on the explicit basis of innocence, the person serving a sentence imposed under this subsection shall be resentenced to any sentence that was available at the time of the original sentencing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9a6bc8d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Death or Imprisonment for Crimes Against Children.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9a6bc8e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2) and notwithstanding any other provision of law, a person who is convicted of a Federal offense that is a serious violent felony (as defined in subsection (c)) or a violation of section 2422, 2423, or 2251 shall, unless the sentence of death is imposed, be sentenced to imprisonment for life, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9a6bc8f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the victim of the offense has not attained the age of 14 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9a6bc90-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the victim dies as a result of the offense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9a6bc91-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the defendant, in the course of the offense, engages in conduct described in section 3591(a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a6bc92-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to a person convicted of a Federal offense described in paragraph (1), the court may impose any lesser sentence that is authorized by law to take into account any substantial assistance provided by the defendant in the investigation or prosecution of another person who has committed an offense, in accordance with the Federal Sentencing Guidelines and the policy statements of the Federal Sentencing Commission pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s994/p"},"text":"section 994(p) of title 28","children":[],"tail":", or for other good cause."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9a6bc93-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mandatory Life Imprisonment for Repeated Sex Offenses Against Children.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9a6bc94-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person who is convicted of a Federal sex offense in which a minor is the victim shall be sentenced to life imprisonment if the person has a prior sex conviction in which a minor was the victim, unless the sentence of death is imposed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a6bc95-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9a6bc96-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Federal sex offense” means an offense under section 1591 (relating to sex trafficking of children), 2241 (relating to aggravated sexual abuse), 2242 (relating to sexual abuse), 2244(a)(1) (relating to abusive sexual contact), 2245 (relating to sexual abuse resulting in death), 2251 (relating to sexual exploitation of children), 2251A (relating to selling or buying of children), 2422(b) (relating to coercion and enticement of a minor into prostitution), or 2423(a) (relating to transportation of minors);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9a6bc97-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “State or Military sex offense” means an offense under State law or the Uniform Code of Military Justice that is punishable by more than one year in prison and consists of conduct that would be a Federal sex offense if, to the extent or in the manner specified in the applicable provision of this title—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9a6bc98-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense involved interstate or foreign commerce, or the use of the mails; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9a6bc99-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct occurred in any commonwealth, territory, or possession of the United States, within the special maritime and territorial jurisdiction of the United States, in a Federal prison, on any land or building owned by, leased to, or otherwise used by or under the control of the Government of the United States, or in the Indian country (as defined in section 1151);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9a6bc9a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “prior sex conviction” means a conviction for which the sentence was imposed before the conduct occurred constituting the subsequent Federal sex offense, and which was for a Federal sex offense or a State or Military sex offense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9a92c9b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “minor” means an individual who has not attained the age of 17 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9a92c9c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” has the meaning given that term in subsection (c)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a92c9d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonqualifying Felonies","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An offense described in section 2422(b) or 2423(a) shall not serve as a basis for sentencing under this subsection if the defendant establishes by clear and convincing evidence that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9a92c9e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sexual act or activity was consensual and not for the purpose of commercial or pecuniary gain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9a92c9f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sexual act or activity would not be punishable by more than one year in prison under the law of the State in which it occurred; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9a92ca0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no sexual act or activity occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9a92ca1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mandatory Minimum Terms of Imprisonment for Violent Crimes Against Children","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person who is convicted of a Federal offense that is a crime of violence against the person of an individual who has not attained the age of 18 years shall, unless a greater mandatory minimum sentence of imprisonment is otherwise provided by law and regardless of any maximum term of imprisonment otherwise provided for the offense—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9a92ca2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the crime of violence is murder, be imprisoned for life or for any term of years not less than 30, except that such person shall be punished by death or life imprisonment if the circumstances satisfy any of subparagraphs (A) through (D) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3591/a/2"},"text":"section 3591(a)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a92ca3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the crime of violence is kidnapping (as defined in section 1201) or maiming (as defined in section 114), be imprisoned for life or any term of years not less than 25; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a92ca4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the crime of violence results in serious bodily injury (as defined in section 1365), or if a dangerous weapon was used during and in relation to the crime of violence, be imprisoned for life or for any term of years not less than 10.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9a92ca5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9a92ca6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a defendant who is convicted of a felony offense (other than offense of which an element is the false registration of a domain name) knowingly falsely registered a domain name and knowingly used that domain name in the course of that offense, the maximum imprisonment otherwise provided by law for that offense shall be doubled or increased by 7 years, whichever is less.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a92ca7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9a92ca8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “falsely registers” means registers in a manner that prevents the effective identification of or contact with the person who registers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9a92ca9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3559/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “domain name” has the meaning given that term is ","children":[{"tag":"ref","attrib":{"idref":"fn002247"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002247"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “in”."}],"tail":" section 45 of the Act entitled “An Act to provide for the registration and protection of trademarks used in commerce, to carry out the provisions of certain international conventions, and for other purposes” approved "},{"tag":"date","attrib":{"date":"1946-07-05"},"text":"July 5, 1946","children":[],"tail":" (commonly referred to as the “Trademark Act of 1946”) ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1127"},"text":"15 U.S.C. 1127","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9a92caa-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s212/a/2"},"text":"Pub. L. 98–473, title II, § 212(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1991"},"text":"98 Stat. 1991","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/185/s5"},"text":"Pub. L. 100–185, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-11"},"text":"Dec. 11, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1279"},"text":"101 Stat. 1279","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7041"},"text":"Pub. L. 100–690, title VII, § 7041","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4399"},"text":"102 Stat. 4399","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tVII/s70001"},"text":"Pub. L. 103–322, title VII, § 70001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1982"},"text":"108 Stat. 1982","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/314/tV/s501"},"text":"Pub. L. 105–314, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2980"},"text":"112 Stat. 2980","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/386/s1/b"},"text":"Pub. L. 105–386, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3470"},"text":"112 Stat. 3470","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/21/tI/s106/a"},"text":"Pub. L. 108–21, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-30"},"text":"Apr. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/654"},"text":"117 Stat. 654","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/482/tII/s204/a"},"text":"Pub. L. 108–482, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3917"},"text":"118 Stat. 3917","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/248/tII"},"text":"Pub. L. 109–248, title II","children":[],"tail":", §§ 202, 206(c), "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/612"},"text":"120 Stat. 612","children":[],"tail":", 614; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s569/6"},"text":"Pub. L. 118–159, div. A, title V, § 569(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1906"},"text":"138 Stat. 1906","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9a92cab-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9a92cac-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9a92cad-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (e)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s569/6/A"},"text":"Pub. L. 118–159, § 569(6)(A)","children":[],"tail":", substituted “State or Military sex offense” for “State sex offense” and inserted “or the Uniform Code of Military Justice” after “State law” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s569/6/B"},"text":"Pub. L. 118–159, § 569(6)(B)","children":[],"tail":", inserted “or Military” after “State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (e)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/s206/c"},"text":"Pub. L. 109–248, § 206(c)","children":[],"tail":", inserted “1591 (relating to sex trafficking of children),” after “under section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/s202"},"text":"Pub. L. 109–248, § 202","children":[],"tail":", added subsec. (f) and redesignated former subsec. (f) as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/482"},"text":"Pub. L. 108–482","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21"},"text":"Pub. L. 108–21","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (c)(2)(F)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/386"},"text":"Pub. L. 105–386","children":[],"tail":" inserted “firearms possession (as described in section 924(c));” after “firearms use;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/314"},"text":"Pub. L. 105–314","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s70001/1"},"text":"Pub. L. 103–322, § 70001(1)","children":[],"tail":", substituted “Except as provided in subsection (c), an” for “An”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s70001/2"},"text":"Pub. L. 103–322, § 70001(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7041/a/1"},"text":"Pub. L. 100–690, § 7041(a)(1)","children":[],"tail":", substituted “classified if the maximum term of imprisonment authorized is—” for “classified—"}],"tail":"\n"},{"tag":"p","attrib":{},