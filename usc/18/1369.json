{"tag":"section","attrib":{"id":"idb91c7dd0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1369"},"text":null,"children":[{"tag":"num","attrib":{"value":"1369"},"text":"§ 1369.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Destruction of veterans’ memorials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb91c7dd1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1369/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever, in a circumstance described in subsection (b), willfully injures or destroys, or attempts to injure or destroy, any structure, plaque, statue, or other monument on public property commemorating the service of any person or persons in the armed forces of the United States shall be fined under this title, imprisoned not more than 10 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91c7dd2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1369/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A circumstance described in this subsection is that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91c7dd3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1369/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in committing the offense described in subsection (a), the defendant travels or causes another to travel in interstate or foreign commerce, or uses the mail or an instrumentality of interstate or foreign commerce; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91c7dd4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1369/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the structure, plaque, statue, or other monument described in subsection (a) is located on property owned by, or under the jurisdiction of, the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb91c7dd5-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/29/s2/a"},"text":"Pub. L. 108–29, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-05-29"},"text":"May 29, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/772"},"text":"117 Stat. 772","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91c7dd6-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb91c7dd7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb91c7dd8-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/29/s1"},"text":"Pub. L. 108–29, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-05-29"},"text":"May 29, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/772"},"text":"117 Stat. 772","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/29/s1"},"text":"“This Act [enacting this section and provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s109"},"text":"section 109 of Title 23","children":[],"tail":", Highways] may be cited as the ‘Veterans’ Memorial Preservation and Recognition Act of 2003’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
