{"tag":"section","attrib":{"id":"idb9392d06-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1917"},"text":null,"children":[{"tag":"num","attrib":{"value":"1917"},"text":"§ 1917.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interference with civil service examinations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Whoever, being a member or employee of the United States Office of Personnel Management or an individual in the public service, willfully and corruptly—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9392d07-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1917/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defeats, deceives, or obstructs an individual in respect of his right of examination according to the rules prescribed by the President under title 5 for the administration of the competitive service and the regulations prescribed by such Office under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1302/a"},"text":"section 1302(a) of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9392d08-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1917/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" falsely marks, grades, estimates, or reports on the examination or proper standing of an individual examined;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9392d09-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1917/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes a false representation concerning the mark, grade, estimate, or report on the examination or proper standing of an individual examined, or concerning the individual examined; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9392d0a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1917/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnishes to an individual any special or secret information for the purpose of improving or injuring the prospects or chances of an individual examined, or to be examined, being appointed, employed, or promoted;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall, for each offense, be fined under this title not less than $100 or imprisoned not less than ten days nor more than one year, or both.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9392d0b-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s3/d"},"text":"Pub. L. 89–554, § 3(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/609"},"text":"80 Stat. 609","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330010/2"},"text":"Pub. L. 103–322, title XXXIII, § 330010(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2143"},"text":"108 Stat. 2143","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s601/a/9"},"text":"Pub. L. 104–294, title VI, § 601(a)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3498"},"text":"110 Stat. 3498","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9392d0c-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9392d0d-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb9392d0e-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s637"},"text":"5 U.S.C. 637","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1883-01-16/ch27/s5"},"text":"Jan. 16, 1883, ch. 27, § 5","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/22/405"},"text":"22 Stat. 405","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The section is rewritten to conform to the style of title 18. The words “a member or employee of the United States Civil Service Commission” are coextensive with and substituted for “Civil Service Commissioner, examiner, copyist, or messenger”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The references to actions in concert with others to violate this section are omitted in view of the crime of conspiracy contained in chapter 19 of title 18.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (1), the words “the rules prescribed by the President under title 5 for the administration of the competitive service and the regulations prescribed by the Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1302/a"},"text":"section 1302(a) of title 5","children":[],"tail":"” are substituted for “any such rules or regulations” to provide the basis of reference."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “be deemed guilty of a misdemeanor” are omitted as unnecessary in view of the definitive ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1"},"text":"section 1 of this title","children":[],"tail":". (See reviser’s note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s212"},"text":"18 U.S.C. 212","children":[],"tail":", 1964 ed.)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “and upon conviction thereof” are omitted as unnecessary because punishment can be imposed only after conviction.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “or both” are substituted for “or by both such fine and imprisonment”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9392d0f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9392d10-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" substituted “fined under this title not less than $100” for “fined not less than $100 nor more than $1,000” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “Office of Personnel Management” for “Civil Service Commission” in introductory provisions and “such Office” for “the Commission” in par. (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
