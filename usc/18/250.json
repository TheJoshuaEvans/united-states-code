{"tag":"section","attrib":{"id":"idb8c44b0e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s250"},"text":null,"children":[{"tag":"num","attrib":{"value":"250"},"text":"§ 250.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties for civil rights offenses involving sexual misconduct","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8c44b0f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s250/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offense","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It shall be unlawful for any person to, in the course of committing an offense under this chapter or under section 901 of the Fair Housing Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3631"},"text":"42 U.S.C. 3631","children":[],"tail":"), engage in, or cause another to engage in, sexual misconduct."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c44b10-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s250/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who violates subsection (a) shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c44b11-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s250/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an offense involving aggravated sexual abuse, as defined in section 2241, or if the offense involved sexual abuse, as defined in section 2242, or if the offense involved an attempt to commit such aggravated sexual abuse or sexual abuse, fined under this title and imprisoned for any term of years or for life;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c44b12-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s250/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an offense involving abusive sexual contact of a child who has not attained the age of 16, of the type prohibited by section 2244(a)(5), fined under this title and imprisoned for any term of years or for life;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c44b13-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s250/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an offense involving a sexual act, as defined in section 2246, with another person without the other person’s permission, and it does not amount to sexual abuse or aggravated sexual abuse, be fined under this title and imprisoned for not more than 40 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c44b14-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s250/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an offense involving abusive sexual contact of the type prohibited by subsection (a)(1) or (b) of section 2244, but excluding abusive sexual contact through the clothing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8c44b15-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s250/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fined under this title and imprisoned for not more than 10 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c44b16-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s250/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the offense involves a child who has not attained the age of 12 years, imprisoned for not more than 30 years;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c44b17-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s250/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an offense involving abusive sexual contact of the type prohibited by section 2244(a)(2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8c44b18-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s250/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fined under this title and imprisoned for not more than 3 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c44b19-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s250/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the offense involves a child under the age of 12, imprisoned for not more than 20 years; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c44b1a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s250/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an offense involving abusive sexual contact through the clothing of the type prohibited by subsection (a)(3), (a)(4), or (b) of section 2244—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8c44b1b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s250/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fined under this title and imprisoned for not more than 2 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c44b1c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s250/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the offense involves a child under the age of 12, imprisoned for not more than 10 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8c44b1d-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tXII/s1202/a/1"},"text":"Pub. L. 117–103, div. W, title XII, § 1202(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/923"},"text":"136 Stat. 923","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c44b1e-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8c44b1f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8c44b20-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section not effective until Oct. 1 of the first fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s4/a"},"text":"section 4(a) of div. W of Pub. L. 117–103","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6851"},"text":"section 6851 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
