{"tag":"section","attrib":{"id":"idb92863cf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1583"},"text":null,"children":[{"tag":"num","attrib":{"value":"1583"},"text":"§ 1583.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enticement into slavery","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb92863d0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1583/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whoever—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92863d1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1583/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" kidnaps or carries away any other person, with the intent that such other person be sold into involuntary servitude, or held as a slave;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92863d2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1583/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entices, persuades, or induces any other person to go on board any vessel or to any other place with the intent that he or she may be made or held as a slave, or sent out of the country to be so made or held; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92863d3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1583/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obstructs, or attempts to obstruct, or in any way interferes with or prevents the enforcement of this section,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title, imprisoned not more than 30 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92863d4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1583/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whoever violates this section shall be fined under this title, imprisoned for any term of years or for life, or both if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92863d5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1583/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the violation results in the death of the victim; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92863d6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1583/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the violation includes kidnaping, an attempt to kidnap, aggravated sexual abuse, an attempt to commit aggravated sexual abuse, or an attempt to kill.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb92863d7-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/772"},"text":"62 Stat. 772","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tII/s218/a"},"text":"Pub. L. 104–208, div. C, title II, § 218(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-573"},"text":"110 Stat. 3009–573","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/386/dA/s112/a/1"},"text":"Pub. L. 106–386, div. A, § 112(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1486"},"text":"114 Stat. 1486","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/457/tII/s222/b/1"},"text":"Pub. L. 110–457, title II, § 222(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-12-23"},"text":"Dec. 23, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/5067"},"text":"122 Stat. 5067","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/392/s11/1/A"},"text":"Pub. L. 115–392, § 11(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5255"},"text":"132 Stat. 5255","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92863d8-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb92863d9-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 443 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s268"},"text":"Mar. 4, 1909, ch. 321, § 268","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1141"},"text":"35 Stat. 1141","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to persons causing or procuring was omitted as unnecessary in view of definition of “principal” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in paragraphing of section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92863da-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92863db-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/392"},"text":"Pub. L. 115–392","children":[],"tail":" substituted “not more than 30 years” for “not more than 20 years” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/457"},"text":"Pub. L. 110–457","children":[],"tail":" amended section generally. Prior to amendment, section provided penalties for kidnapping or enticement of a person with intent to sell or hold such person as a slave."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386"},"text":"Pub. L. 106–386","children":[],"tail":", in last par., substituted “20 years” for “10 years” and inserted at end “If death results from the violation of this section, or if the violation includes kidnapping or an attempt to kidnap, aggravated sexual abuse or the attempt to commit aggravated sexual abuse, or an attempt to kill, the defendant shall be fined under this title or imprisoned for any term of years or life, or both.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" substituted “10 years” for “five years” in last par."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $5,000” in last par."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb92863dc-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb92863dd-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" applicable with respect to offenses occurring on or after "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/s218/d"},"text":"section 218(d) of Pub. L. 104–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1581"},"text":"section 1581 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
