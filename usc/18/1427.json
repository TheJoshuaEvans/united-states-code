{"tag":"section","attrib":{"id":"idb91eee90-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1427"},"text":null,"children":[{"tag":"num","attrib":{"value":"1427"},"text":"§ 1427.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of naturalization or citizenship papers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever unlawfully sells or disposes of a declaration of intention to become a citizen, certificate of naturalization, certificate of citizenship or copies or duplicates or other documentary evidence of naturalization or citizenship, shall be fined under this title or imprisoned not more than 25 years (if the offense was committed to facilitate an act of international terrorism (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2331"},"text":"section 2331 of this title","children":[],"tail":")), 20 years (if the offense was committed to facilitate a drug trafficking crime (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s929/a"},"text":"section 929(a) of this title","children":[],"tail":")), 10 years (in the case of the first or second such offense, if the offense was not committed to facilitate such an act of international terrorism or a drug trafficking crime), or 15 years (in the case of any other offense), or both."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb91eee91-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/767"},"text":"62 Stat. 767","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tII/s211/a/2"},"text":"Pub. L. 104–208, div. C, title II, § 211(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-569"},"text":"110 Stat. 3009–569","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dB/tIV/s4002/a/3"},"text":"Pub. L. 107–273, div. B, title IV, § 4002(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1806"},"text":"116 Stat. 1806","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91eee92-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb91eee93-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on subsections (a) par. (13), (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s746"},"text":"section 746 of title 8","children":[],"tail":", U.S.C., 1940 ed., Aliens and Nationality ("},{"tag":"ref","attrib":{"href":"/us/act/1940-10-14/ch876/s346/a/13"},"text":"Oct. 14, 1940, ch. 876, § 346(a)(13)","children":[],"tail":", (d), "},{"tag":"ref","attrib":{"href":"/us/stat/54/1165"},"text":"54 Stat. 1165","children":[],"tail":", 1167)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb91eee94-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb91eee95-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" substituted “to facilitate” for “to facility”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" substituted “imprisoned not more than 25 years (if the offense was committed to facilitate an act of international terrorism (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2331"},"text":"section 2331 of this title","children":[],"tail":")), 20 years (if the offense was committed to facilitate a drug trafficking crime (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s929/a"},"text":"section 929(a) of this title","children":[],"tail":")), 10 years (in the case of the first or second such offense, if the offense was not committed to facility such an act of international terrorism or a drug trafficking crime), or 15 years (in the case of any other offense)” for “imprisoned not more than five years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $5,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb91eee96-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb91eee97-47c4-11f1-9a61-b1559996dfe