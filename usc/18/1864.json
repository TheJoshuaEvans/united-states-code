{"tag":"section","attrib":{"id":"idb936bb6a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1864"},"text":null,"children":[{"tag":"num","attrib":{"value":"1864"},"text":"§ 1864.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hazardous or injurious devices on Federal lands","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb936bb6b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1864/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whoever—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb936bb6c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1864/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the intent to violate the Controlled Substances Act,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb936bb6d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1864/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the intent to obstruct or harass the harvesting of timber, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb936bb6e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1864/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with reckless disregard to the risk that another person will be placed in danger of death or bodily injury and under circumstances manifesting extreme indifference to such risk,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"uses a hazardous or injurious device on Federal land, on an Indian reservation, or on an Indian allotment while the title to such allotment is held in trust by the United States or while such allotment remains inalienable by the allottee without the consent of the United States shall be punished under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb936bb6f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1864/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An individual who violates subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb936bb70-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1864/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if death of an individual results, be fined under this title or imprisoned for any term of years or for life, or both;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb936bb71-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1864/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if serious bodily injury to any individual results, be fined under this title or imprisoned for not more than 40 years, or both;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb936bb72-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1864/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if bodily injury to any individual results, be fined under this title or imprisoned for not more than 20 years, or both;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb936bb73-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1864/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if damage to the property of any individual results or if avoidance costs have been incurred exceeding $10,000, in the aggregate, be fined under this title or imprisoned for not more than 20 years, or both; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb936bb74-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1864/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any other case, be fined under this title or imprisoned for not more than one year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb936bb75-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1864/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any individual who is punished under subsection (b)(5) after one or more prior convictions under any such subsection shall be fined under this title or imprisoned for not more than 20 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb936bb76-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1864/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb936bb77-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1864/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “serious bodily injury” means bodily injury which involves—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb936bb78-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1864/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a substantial risk of death;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb936bb79-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1864/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extreme physical pain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb936bb7a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1864/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protracted and obvious disfigurement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb936bb7b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1864/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protracted loss or impairment of the function of bodily member, organ, or mental faculty;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb936bb7c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1864/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “bodily injury” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb936bb7d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1864/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a cut, abrasion, bruise, burn, or disfigurement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb936bb7e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1864/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical pain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb936bb7f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1864/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" illness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb936bb80-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1864/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impairment of the function of a bodily member, organ, or mental faculty; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb936bb81-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1864/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other injury to the body, no matter how temporary;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb936bb82-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1864/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “hazardous or injurious device” means a device, which when assembled or placed, is capable of causing bodily injury, or damage to property, by the action of any person making contact with such device subsequent to the assembly or placement. Such term includes guns attached to trip wires or other triggering mechanisms, ammunition attached to trip wires or other triggering mechanisms, or explosive devices attached to trip wires or other triggering mechanisms, sharpened stakes, lines or wires, lines or wires with hooks attached, nails placed so that the sharpened ends are positioned in an upright manner, or tree spiking devices including spikes, nails, or other objects hammered, driven, fastened, or otherwise placed into or on any timber, whether or not severed from the stump; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb936bb83-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1864/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “avoidance costs” means costs incurred by any individual for the purpose of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb936bb84-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1864/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detecting a hazardous or injurious device; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb936bb85-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1864/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preventing death, serious bodily injury, bodily injury, or property damage likely to result from the use of a hazardous or injurious device in violation of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb936bb86-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1864/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person injured as the result of a violation of subsection (a) may commence a civil action on his own behalf against any person who is alleged to be in violation of subsection (a). The district courts shall have jurisdiction, without regard to the amount in controversy or the citizenship of the parties, in such civil actions. The court may award, in addition to monetary damages for any injury resulting from an alleged violation of subsection (a), costs of litigation, including reasonable attorney and expert witness fees, to any prevailing or substantially prevailing party, whenever the court determines such award is appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb936bb87-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI/s6254/f"},"text":"Pub. L. 100–690, title VI, § 6254(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4366"},"text":"102 Stat. 4366","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXV/s3555"},"text":"Pub. L. 101–647, title XXXV, § 3555","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4927"},"text":"104 Stat. 4927","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330007"},"text":"Pub. L. 103–322, title XXXIII, § 330007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2142"},"text":"108 Stat. 2142","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/134/tI/s101/c/tIII/s330"},"text":"Pub. L. 104–134, title I, § 101(c) [title III, § 330]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321-156"},"text":"110 Stat. 1321–156","children":[],"tail":", 1321–208; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/104/140/s1/a"},"text":"Pub. L. 104–140, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-02"},"text":"May 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1327"},"text":"110 Stat. 1327","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb936bb88-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb936bb89-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb936bb8a-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Controlled Substances Act, referred to in subsec. (a)(1), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513"},"text":"Pub. L. 91–513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1242"},"text":"84 Stat. 1242","children":[],"tail":", which is classified principally to subchapter I (§ 801 et seq.) of chapter 13 of Title 21, Food and Drugs. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"section 801 of Title 21","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb936bb8b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/s101/c/tIII/s330/1/A"},"text":"Pub. L. 104–134, § 101(c) [title III, § 330(1)(A)]","children":[],"tail":", substituted “40” for “twenty”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/s101/c/tIII/s330/1/B"},"text":"Pub. L. 104–134, § 101(c) [title III, § 330(1)(B)]","children":[],"tail":", substituted “20” for “ten”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/s101/c/tIII/s330/1/C"},"text":"Pub. L. 104–134, § 101(c) [title III, § 330(1)(C), (D)]","children":[],"tail":", substituted “if damage to the property of any individual results or if avoidance costs have been incurred exceeding $10,000, in the aggregate,” for “if damage exceeding $10,000 to the property of any individual results,” and “20” for “ten”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/s101/c/tIII/s330/2"},"text":"Pub. L. 104–134, § 101(c) [title III, § 330(2)]","children":[],"tail":", substituted “20” for “ten”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/s101/c/tIII/s330/3"},"text":"Pub. L. 104–134, § 101(c) [title III, § 330(3)]","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/s101/c/tIII/s330/4"},"text":"Pub. L. 104–134, § 101(c) [title III, § 330(4)]","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “(b)(5)” for “(b)(3), (4), or (5)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (d)(1)(D), (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":" struck out “and” at end of subpar. (D) and substituted “; and” for period at end of subpar. (E)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
