{"tag":"section","attrib":{"id":"idb96b3935-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2341"},"text":null,"children":[{"tag":"num","attrib":{"value":"2341"},"text":"§ 2341.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96b3936-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2341/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “cigarette” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb96b3937-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2341/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any roll of tobacco wrapped in paper or in any substance not containing tobacco; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96b3938-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2341/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any roll of tobacco wrapped in any substance containing tobacco which, because of its appearance, the type of tobacco used in the filler, or its packaging and labeling, is likely to be offered to, or purchased by, consumers as a cigarette described in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96b3939-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2341/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “contraband cigarettes” means a quantity in excess of 10,000 cigarettes, which bear no evidence of the payment of applicable State or local cigarette taxes in the State or locality where such cigarettes are found, if the State or local government requires a stamp, impression, or other indication to be placed on packages or other containers of cigarettes to evidence payment of cigarette taxes, and which are in the possession of any person other than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb96b393a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2341/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person holding a permit issued pursuant to chapter 52 of the Internal Revenue Code of 1986 as a manufacturer of tobacco products or as an export warehouse proprietor, or a person operating a customs bonded warehouse pursuant to section 311 or 555 of the Tariff Act of 1930 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1311"},"text":"19 U.S.C. 1311","children":[],"tail":" or 1555) or an agent of such person;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96b393b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2341/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a common or contract carrier transporting the cigarettes involved under a proper bill of lading or freight bill which states the quantity, source, and destination of such cigarettes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96b393c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2341/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a person—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb96b393d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2341/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is licensed or otherwise authorized by the State where the cigarettes are found to account for and pay cigarette taxes imposed by such State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb96b393e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2341/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has complied with the accounting and payment requirements relating to such license or authorization with respect to the cigarettes involved; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96b393f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2341/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer, employee, or other agent of the United States or a State, or any department, agency, or instrumentality of the United States or a State (including any political subdivision of a State) having possession of such cigarettes in connection with the performance of official duties;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96b3940-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2341/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “common or contract carrier” means a carrier holding a certificate of convenience and necessity, a permit for contract carrier by motor vehicle, or other valid operating authority under subtitle IV of title 49, or under equivalent operating authority from a regulatory agency of the United States or of any State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96b3941-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2341/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” means a State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, or the Virgin Islands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96b3942-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2341/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Attorney General” means the Attorney General of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96b3943-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2341/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “smokeless tobacco” means any finely cut, ground, powdered, or leaf tobacco that is intended to be placed in the oral or nasal cavity or otherwise consumed without being combusted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96b3944-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2341/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “contraband smokeless tobacco” means a quantity in excess of 500 single-unit consumer-sized cans or packages of smokeless tobacco, or their equivalent, that are in the possession of any person other than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb96b3945-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2341/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person holding a permit issued pursuant to chapter 52 of the Internal Revenue Code of 1986 as manufacturer ","children":[{"tag":"ref","attrib":{"idref":"fn002196"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002196"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “a manufacturer”."}],"tail":" of tobacco products or as an export warehouse proprietor, a person operating a customs bonded warehouse pursuant to section 311 or 555 of the Tariff Act of 1930 ("},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1311"},"text":"19 U.S.C. 1311","children":[],"tail":", 1555), or an agent of such person;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96b3946-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2341/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a common carrier transporting such smokeless tobacco under a proper bill of lading or freight bill which states the quantity, source, and designation of such smokeless tobacco;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96b3947-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2341/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a person who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb96b3948-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2341/7/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is licensed or otherwise authorized by the State where such smokeless tobacco is found to engage in the business of selling or distributing tobacco products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb96b3949-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2341/7/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has complied with the accounting, tax, and payment requirements relating to such license or authorization with respect to such smokeless tobacco; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96b394a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2341/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer, employee, or agent of the United States or a State, or any department, agency, or instrumentality of the United States or a State (including any political subdivision of a State), having possession of such smokeless tobacco in connection with the performance of official duties; ","children":[{"tag":"ref","attrib":{"idref":"fn002197"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002197"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The semicolon probably should be a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb96b394b-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/575/s1"},"text":"Pub. L. 95–575, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-02"},"text":"Nov. 2, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2463"},"text":"92 Stat. 2463","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/449/s5/c"},"text":"Pub. L. 97–449, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2442"},"text":"96 Stat. 2442","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXI/s1112/i/1"},"text":"Pub. L. 107–296, title XI, § 1112(i)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2277"},"text":"116 Stat. 2277","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/tI/s121/a/1"},"text":"Pub. L. 109–177, title I, § 121(a)(1)","children":[],"tail":", (b)(1), (6), "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/221"},"text":"120 Stat. 221","children":[],"tail":", 222.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb96b394c-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb96b394d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb96b394e-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Chapter 52 of the Internal Revenue Code of 1986, referred to in pars. (2)(A) and (7)(A), is classified generally to chapter 52 (§ 5701 et seq.) of Title 26, Internal Revenue Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb96b394f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s121/b/6"},"text":"Pub. L. 109–177, § 121(b)(6)","children":[],"tail":", which directed amendment of par. (2) by substituting “State or local cigarette taxes in the State or locality where such cigarettes are found, if the State or local government” for “State cigarette taxes in the State where such cigarettes are found, if the State” in introductory provisions, was executed by making the substitution for “State cigarette taxes in the State where such cigarettes are found, if such State”, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s121/a/1"},"text":"Pub. L. 109–177, § 121(a)(1)","children":[],"tail":", substituted “10,000 cigarettes” for “60,000 cigarettes” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s121/b/1"},"text":"Pub. L. 109–177, § 121(b)(1)","children":[],"tail":", added pars. (6) and (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" added par. (5) and struck out former par. (5) which read as follows: “the term ‘Secretary’ means the Secretary of the Treasury.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Par. (2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/449"},"text":"Pub. L. 97–449","children":[],"tail":" substituted “subtitle IV of title 49” for “the Interstate Commerce Act”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb96b3950-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb96b3951-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s4"},"text":"section 4 of Pub. L. 107–296","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb96b3952-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/575/s4"},"text":"Pub. L. 95–575, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-02"},"text":"Nov. 2, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2466"},"text":"92 Stat. 2466","children":[],"tail":", provided:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/575/s4"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b), this Act [enacting this chapter, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1961"},"text":"section 1961 of this title","children":[],"tail":" and sections 781 and 787 of former Title 49, Transportation, and enacting provisions set out as a note under this section] shall take effect on the date of its enactment ["},{"tag":"date","attrib":{"date":"1978-11-02"},"text":"Nov. 2, 1978","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 2342(b) and 2343 of title 18, United States Code as enacted by the first section of this Act, shall take effect on the first day of the first month beginning more than 120 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1978-11-02"},"text":"Nov. 2, 1978","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb96b3953-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/575/s5"},"text":"Pub. L. 95–575, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-02"},"text":"Nov. 2, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2466"},"text":"92 Stat. 2466","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/575/s5"},"text":"“There are hereby authorized to be appropriated such sums as may be necessary to carry out the provisions of chapter 114 of title 18, United States Code, added by the first section of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
