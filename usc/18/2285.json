{"tag":"section","attrib":{"id":"idb95a70f9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2285"},"text":null,"children":[{"tag":"num","attrib":{"value":"2285"},"text":"§ 2285.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation of submersible vessel or semi-submersible vessel without nationality","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb95a70fa-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2285/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offense","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever knowingly operates, or attempts or conspires to operate, by any means, or embarks in any submersible vessel or semi-submersible vessel that is without nationality and that is navigating or has navigated into, through, or from waters beyond the outer limit of the territorial sea of a single country or a lateral limit of that country’s territorial sea with an adjacent country, with the intent to evade detection, shall be fined under this title, imprisoned not more than 15 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95a70fb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2285/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evidence of Intent To Evade Detection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of subsection (a), the presence of any of the indicia described in paragraph (1)(A), (E), (F), or (G), or in paragraph (4), (5), or (6), of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70507/b"},"text":"section 70507(b) of title 46","children":[],"tail":" may be considered, in the totality of the circumstances, to be prima facie evidence of intent to evade detection."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95a70fc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2285/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extraterritorial Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is extraterritorial Federal jurisdiction over an offense under this section, including an attempt or conspiracy to commit such an offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95a70fd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2285/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Claim of Nationality or Registry","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A claim of nationality or registry under this section includes only—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95a70fe-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2285/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" possession on board the vessel and production of documents evidencing the vessel’s nationality as provided in article 5 of the 1958 Convention on the High Seas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95a70ff-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2285/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flying its nation’s ensign or flag; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95a7100-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2285/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a verbal claim of nationality or registry by the master or individual in charge of the vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95a7101-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2285/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Affirmative Defenses.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95a7102-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2285/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is an affirmative defense to a prosecution for a violation of subsection (a), which the defendant has the burden to prove by a preponderance of the evidence, that the submersible vessel or semi-submersible vessel involved was, at the time of the offense—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95a7103-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2285/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel of the United States or lawfully registered in a foreign nation as claimed by the master or individual in charge of the vessel when requested to make a claim by an officer of the United States authorized to enforce applicable provisions of United States law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95a7104-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2285/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" classed by and designed in accordance with the rules of a classification society;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95a7105-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2285/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lawfully operated in government-regulated or licensed activity, including commerce, research, or exploration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95a7106-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2285/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equipped with and using an operable automatic identification system, vessel monitoring system, or long range identification and tracking system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95a7107-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2285/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Production of documents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The affirmative defenses provided by this subsection are proved conclusively by the production of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95a7108-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2285/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" government documents evidencing the vessel’s nationality at the time of the offense, as provided in article 5 of the 1958 Convention on the High Seas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95a7109-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2285/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certificate of classification issued by the vessel’s classification society upon completion of relevant classification surveys and valid at the time of the offense; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95a710a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2285/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" government documents evidencing licensure, regulation, or registration for commerce, research, or exploration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95a710b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2285/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Activities Excepted","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section applies to lawfully authorized activities carried out by or at the direction of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95a710c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2285/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Other Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Sections 70504 and 70505 of title 46 apply to offenses under this section in the same manner as they apply to offenses under section 70503 of such title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95a710d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2285/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the terms “submersible vessel”, “semi-submersible vessel”, “vessel of the United States”, and “vessel without nationality” have the meaning given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70502"},"text":"section 70502 of title 46","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb95a710e-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/407/tI/s102/a"},"text":"Pub. L. 110–407, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4296"},"text":"122 Stat. 4296","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb95a710f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb95a7110-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb95a7111-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings and Declarations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/407/tI/s101"},"text":"Pub. L. 110–407, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4296"},"text":"122 Stat. 4296","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/407/tI/s101"},"text":"“Congress finds and declares that operating or embarking in a submersible vessel or semi-submersible vessel without nationality and on an international voyage is a serious international problem, facilitates transnational crime, including drug trafficking, and terrorism, and presents a specific threat to the safety of maritime navigation and the security of the United States.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
