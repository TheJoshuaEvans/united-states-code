{"tag":"section","attrib":{"id":"idb8ea70e5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s916"},"text":null,"children":[{"tag":"num","attrib":{"value":"916"},"text":"§ 916.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 4–H Club members or agents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, falsely and with intent to defraud, holds himself out as or represents or pretends himself to be a member of, associated with, or an agent or representative for the 4–H clubs, an organization established by the Extension Service of the United States Department of Agriculture and the land grant colleges, shall be fined under this title or imprisoned not more than six months, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8ea70e6-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/743"},"text":"62 Stat. 743","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/F"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8ea70e7-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8ea70e8-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 76c (","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-06-05/ch184/s1"},"text":"June 5, 1939, ch. 184, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/809"},"text":"53 Stat. 809","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s76c"},"text":"Section 76c of title 18","children":[],"tail":", U.S.C., 1940 ed., was incorporated in this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s707"},"text":"section 707 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to offense as a misdemeanor was omitted in view of definitive ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1"},"text":"section 1 of this title","children":[],"tail":". Words “upon conviction thereof” were omitted, since criminal punishment can follow only after conviction."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8ea70e9-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8ea70ea-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $300”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
