{"tag":"section","attrib":{"id":"idb92137de-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A"},"text":null,"children":[{"tag":"num","attrib":{"value":"1466A"},"text":"§ 1466A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obscene visual representations of the sexual abuse of children","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb92137df-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who, in a circumstance described in subsection (d), knowingly produces, distributes, receives, or possesses with intent to distribute, a visual depiction of any kind, including a drawing, cartoon, sculpture, or painting, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92137e0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb92137e1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" depicts a minor engaging in sexually explicit conduct; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb92137e2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is obscene; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92137e3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb92137e4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" depicts an image that is, or appears to be, of a minor engaging in graphic bestiality, sadistic or masochistic abuse, or sexual intercourse, including genital-genital, oral-genital, anal-genital, or oral-anal, whether between persons of the same or opposite sex; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb92137e5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lacks serious literary, artistic, political, or scientific value;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"or attempts or conspires to do so, shall be subject to the penalties provided in section 2252A(b)(1), including the penalties provided for cases involving a prior conviction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92137e6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Offenses","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who, in a circumstance described in subsection (d), knowingly possesses a visual depiction of any kind, including a drawing, cartoon, sculpture, or painting, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92137e7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb92137e8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" depicts a minor engaging in sexually explicit conduct; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb92137e9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is obscene; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92137ea-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb92137eb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" depicts an image that is, or appears to be, of a minor engaging in graphic bestiality, sadistic or masochistic abuse, or sexual intercourse, including genital-genital, oral-genital, anal-genital, or oral-anal, whether between persons of the same or opposite sex; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb92137ec-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lacks serious literary, artistic, political, or scientific value;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"or attempts or conspires to do so, shall be subject to the penalties provided in section 2252A(b)(2), including the penalties provided for cases involving a prior conviction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92137ed-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonrequired Element of Offense","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It is not a required element of any offense under this section that the minor depicted actually exist.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92137ee-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Circumstances","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The circumstance referred to in subsections (a) and (b) is that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92137ef-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any communication involved in or made in furtherance of the offense is communicated or transported by the mail, or in interstate or foreign commerce by any means, including by computer, or any means or instrumentality of interstate or foreign commerce is otherwise used in committing or in furtherance of the commission of the offense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92137f0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any communication involved in or made in furtherance of the offense contemplates the transmission or transportation of a visual depiction by the mail, or in interstate or foreign commerce by any means, including by computer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92137f1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person travels or is transported in interstate or foreign commerce in the course of the commission or in furtherance of the commission of the offense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92137f2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any visual depiction involved in the offense has been mailed, or has been shipped or transported in interstate or foreign commerce by any means, including by computer, or was produced using materials that have been mailed, or that have been shipped or transported in interstate or foreign commerce by any means, including by computer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92137f3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense is committed in the special maritime and territorial jurisdiction of the United States or in any territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92137f4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Affirmative Defense","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be an affirmative defense to a charge of violating subsection (b) that the defendant—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92137f5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" possessed less than 3 such visual depictions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92137f6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" promptly and in good faith, and without retaining or allowing any person, other than a law enforcement agency, to access any such visual depiction—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb92137f7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" took reasonable steps to destroy each such visual depiction; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb92137f8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reported the matter to a law enforcement agency and afforded that agency access to each such visual depiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92137f9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92137fa-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “visual depiction” includes undeveloped film and videotape, and data stored on a computer disk or by electronic means which is capable of conversion into a visual image, and also includes any photograph, film, video, picture, digital image or picture, computer image or picture, or computer generated image or picture, whether made or produced by electronic, mechanical, or other means;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92137fb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “sexually explicit conduct” has the meaning given the term in section 2256(2)(A) or 2256(2)(B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92137fc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1466A/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “graphic”, when used with respect to a depiction of sexually explicit conduct, means that a viewer can observe any part of the genitals or pubic area of any depicted person or animal during any part of the time that the sexually explicit conduct is being depicted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb92137fd-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21/tV/s504/a"},"text":"Pub. L. 108–21, title V, § 504(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-30"},"text":"Apr. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/680"},"text":"117 Stat. 680","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92137fe-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb92137ff-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb9213800-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Sentencing Guidelines","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21/tV/s504/c"},"text":"Pub. L. 108–21, title V, § 504(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-30"},"text":"Apr. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/682"},"text":"117 Stat. 682","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/21/tV/s504/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Category","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the applicable category of offense to be used in determining the sentencing range referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3553/a/4"},"text":"section 3553(a)(4) of title 18","children":[],"tail":", United States Code, with respect to any person convicted under section 1466A of such title, shall be the category of offenses described in section 2G2.2 of the Sentencing Guidelines."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ranges","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Sentencing Commission may promulgate guidelines specifically governing offenses under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1466A"},"text":"section 1466A of title 18","children":[],"tail":", United States Code, if such guidelines do not result in sentencing ranges that are lower than those that would have applied under paragraph (1).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb9213801-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report to Congressional Committees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21/tV/s513/b"},"text":"Pub. L. 108–21, title V, § 513(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-30"},"text":"Apr. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/685"},"text":"117 Stat. 685","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/21/tV/s513/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 9 months after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2003-04-30"},"text":"Apr. 30, 2003","children":[],"tail":"], and every 2 years thereafter, the Attorney General shall report to the Chairpersons and Ranking Members of the Committees on the Judiciary of the Senate and the House of Representatives on the Federal enforcement actions under chapter 110 or "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1466A"},"text":"section 1466A of title 18","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the prosecutions brought under chapter 110 or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1466A"},"text":"section 1466A of title 18","children":[],"tail":", United States Code;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an outcome-based measurement of performance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the technology being used by the child pornography industry.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
