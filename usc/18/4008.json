{"tag":"section","attrib":{"id":"idb9c36b9d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4008"},"text":null,"children":[{"tag":"num","attrib":{"value":"4008"},"text":"§ 4008.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Prisoners shall be transported by agents designated by the Attorney General or his authorized representative.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The reasonable expense of transportation, necessary subsistence, and hire and transportation of guards and agents shall be paid by the Attorney General from such appropriation for the Department of Justice as he shall direct.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Upon conviction by a consular court or court martial the prisoner shall be transported from the court to the place of confinement by agents of the Department of State, the Army, Navy, or Air Force, as the case may be, the expense to be paid out of the Treasury of the United States in the manner provided by law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9c36b9e-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/849"},"text":"62 Stat. 849","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-05-24/ch139/s61"},"text":"May 24, 1949, ch. 139, § 61","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/98"},"text":"63 Stat. 98","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9c36b9f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9c36ba0-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9c36ba1-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1948 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 753g (","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-05-14/ch274/s8"},"text":"May 14, 1930, ch. 274, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/327"},"text":"46 Stat. 327","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The second paragraph was originally a proviso.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes of phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9c36ba2-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1949 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This section [section 61] corrects the third paragraph of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s4008"},"text":"section 4008 of title 18","children":[],"tail":", U.S.C., by redesignating the “War Department” as the “Department of the Army”, to conform to such redesignation by act of "},{"tag":"date","attrib":{"date":"1947-07-26"},"text":"July 26, 1947","children":[],"tail":" (ch. 343, title II, § 205(a), "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":"), and by inserting a reference to the Department of the Air Force, in view of the creation of such Department by the same act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9c36ba3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9c36ba4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1949—Act ","children":[{"tag":"date","attrib":{"date":"1949-05-24"},"text":"May 24, 1949","children":[],"tail":", substituted “the Army, Navy, or Air Force” for “War, or the Navy”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
