{"tag":"section","attrib":{"id":"idb8fd83b0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s954"},"text":null,"children":[{"tag":"num","attrib":{"value":"954"},"text":"§ 954.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False statements influencing foreign government","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, in relation to any dispute or controversy between a foreign government and the United States, willfully and knowingly makes any untrue statement, either orally or in writing, under oath before any person authorized and empowered to administer oaths, which the affiant has knowledge or reason to believe will, or may be used to influence the measures or conduct of any foreign government, or of any officer or agent of any foreign government, to the injury of the United States, or with a view or intent to influence any measure of or action by the United States or any department or agency thereof, to the injury of the United States, shall be fined under this title or imprisoned not more than ten years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8fd83b1-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/744"},"text":"62 Stat. 744","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8fd83b2-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8fd83b3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s231"},"text":"section 231 of title 22","children":[],"tail":", U.S.C., 1940 ed., Foreign Relations and Intercourse ("},{"tag":"ref","attrib":{"href":"/us/act/1917-06-15/ch30"},"text":"June 15, 1917, ch. 30","children":[],"tail":", title VIII, § 1, "},{"tag":"ref","attrib":{"href":"/us/stat/40/226"},"text":"40 Stat. 226","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1940-03-28/ch72/s6"},"text":"Mar. 28, 1940, ch. 72, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/80"},"text":"54 Stat. 80","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Mandatory punishment provision was rephrased in the alternative.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “department or agency” were added to eliminate any possible ambiguity as to scope of section. (See definitive ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s6"},"text":"section 6 of this title","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8fd83b4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8fd83b5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $5,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
