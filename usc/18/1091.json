{"tag":"section","attrib":{"id":"idb91307a5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1091"},"text":null,"children":[{"tag":"num","attrib":{"value":"1091"},"text":"§ 1091.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Genocide","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb91307a6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1091/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Basic Offense","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever, whether in time of peace or in time of war and with the specific intent to destroy, in whole or in substantial part, a national, ethnic, racial, or religious group as such—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91307a7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1091/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" kills members of that group;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91307a8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1091/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" causes serious bodily injury to members of that group;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91307a9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1091/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" causes the permanent impairment of the mental faculties of members of the group through drugs, torture, or similar techniques;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91307aa-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1091/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subjects the group to conditions of life that are intended to cause the physical destruction of the group in whole or in part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91307ab-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1091/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imposes measures intended to prevent births within the group; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91307ac-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1091/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfers by force children of the group to another group;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished as provided in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91307ad-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1091/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Punishment for Basic Offense","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The punishment for an offense under subsection (a) is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91307ae-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1091/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an offense under subsection (a)(1), where death results, by death or imprisonment for life and a fine of not more than $1,000,000, or both; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91307af-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1091/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fine of not more than $1,000,000 or imprisonment for not more than twenty years, or both, in any other case.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91307b0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1091/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incitement Offense","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever directly and publicly incites another to violate subsection (a) shall be fined not more than $500,000 or imprisoned not more than five years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91307b1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1091/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Attempt and Conspiracy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person who attempts or conspires to commit an offense under this section shall be punished in the same manner as a person who completes the offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91307b2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1091/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is jurisdiction over the offenses described in subsections (a), (c), and (d) if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91307b3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1091/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense is committed in whole or in part within the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91307b4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1091/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" regardless of where the offense is committed, the alleged offender is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb91307b5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1091/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national of the United States (as that term is defined in section 101 of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"8 U.S.C. 1101","children":[],"tail":"));"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91307b6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1091/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an alien lawfully admitted for permanent residence in the United States (as that term is defined in section 101 of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"8 U.S.C. 1101","children":[],"tail":"));"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91307b7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1091/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a stateless person whose habitual residence is in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91307b8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1091/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" present in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91307b9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1091/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplicability of Certain Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 3282, in the case of an offense under this section, an indictment may be found, or information instituted, at any time without limitation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb91307ba-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/606/s2/a"},"text":"Pub. L. 100–606, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3045"},"text":"102 Stat. 3045","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tVI/s60003/a/13"},"text":"Pub. L. 103–322, title VI, § 60003(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1970"},"text":"108 Stat. 1970","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dB/tIV/s4002/a/4"},"text":"Pub. L. 107–273, div. B, title IV, § 4002(a)(4)","children":[],"tail":", (b)(7), "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1806"},"text":"116 Stat. 1806","children":[],"tail":", 1808; "},{"tag":"ref","attrib":{"href":"/us/pl/110/151/s2"},"text":"Pub. L. 110–151, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-21"},"text":"Dec. 21, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1821"},"text":"121 Stat. 1821","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/122/s3/a"},"text":"Pub. L. 111–122, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-12-22"},"text":"Dec. 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/3481"},"text":"123 Stat. 3481","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91307bb-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb91307bc-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb91307bd-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/122/s3/a/1"},"text":"Pub. L. 111–122, § 3(a)(1)","children":[],"tail":", struck out “, in a circumstance described in subsection (d)” before “and with the specific” in introductory provisions and “or attempts to do so,” before “shall be punished” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/122/s3/a/2"},"text":"Pub. L. 111–122, § 3(a)(2)","children":[],"tail":", struck out “in a circumstance described in subsection (d)” before “directly”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/122/s3/a/3"},"text":"Pub. L. 111–122, § 3(a)(3)","children":[],"tail":", (4), added subsecs. (d) to (f) and struck out former subsecs. (d) and (e) which related to the required circumstance for offenses referred to in subsecs. (a) and (c) and nonapplicability of certain limitations, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/151"},"text":"Pub. L. 110–151","children":[],"tail":" added subsec. (d) and struck out former subsec. (d). Text of former subsec. (d) read as follows: “The circumstance referred to in subsections (a) and (c) is that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the offense is committed within the United States; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the alleged offender is a national of the United States (as defined in section 101 of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"8 U.S.C. 1101","children":[],"tail":")).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s4002/b/7"},"text":"Pub. L. 107–273, § 4002(b)(7)","children":[],"tail":", substituted “subsection (a)(1),” for “subsection (a)(1),,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s4002/a/4"},"text":"Pub. L. 107–273, § 4002(a)(4)","children":[],"tail":", made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":". See 1994 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/s4002/a/4"},"text":"Pub. L. 107–273, § 4002(a)(4)","children":[],"tail":", substituted “, where death results, by death or imprisonment for life and a fine of not more than $1,000,000, or both;” for “a fine of not more than $1,000,000 and imprisonment for life,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb91307be-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb91307bf-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/dB/tIV/s4002/a/4"},"text":"Pub. L. 107–273, div. B, title IV, § 4002(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1806"},"text":"116 Stat. 1806","children":[],"tail":", provided that the amendment made by section 4002(a)(4) is effective "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idb91307c0-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/606/s1"},"text":"Pub. L. 100–606, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3045"},"text":"102 Stat. 3045","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/606/s1"},"text":"“This Act [enacting this chapter] may be cited as the ‘Genocide Convention Implementation Act of 1987 (the Proxmire Act)’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
