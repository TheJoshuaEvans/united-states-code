{"tag":"section","attrib":{"id":"idb9451405-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2193"},"text":null,"children":[{"tag":"num","attrib":{"value":"2193"},"text":"§ 2193.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revolt or mutiny of seamen","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being of the crew of a vessel of the United States, on the high seas, or on any other waters within the admiralty and maritime jurisdiction of the United States, unlawfully and with force, or by fraud, or intimidation, usurps the command of such vessel from the master or other lawful officer in command thereof, or deprives him of authority and command on board, or resists or prevents him in the free and lawful exercise thereof, or transfers such authority and command to another not lawfully entitled thereto, is guilty of a revolt and mutiny, and shall be fined under this title or imprisoned not more than ten years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9451406-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/800"},"text":"62 Stat. 800","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/I"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(I)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9451407-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9451408-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 484 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s293"},"text":"Mar. 4, 1909, ch. 321, § 293","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1146"},"text":"35 Stat. 1146","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Punishment provision for mandatory fine and imprisonment was rephrased in the alternative so as to vest power in the court to impose either a fine, or imprisonment, or both, in its discretion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9451409-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb945140a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $2,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
