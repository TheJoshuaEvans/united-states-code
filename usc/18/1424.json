{"tag":"section","attrib":{"id":"idb91eee6d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1424"},"text":null,"children":[{"tag":"num","attrib":{"value":"1424"},"text":"§ 1424.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personation or misuse of papers in naturalization proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, whether as applicant, declarant, petitioner, witness or otherwise, in any naturalization or citizenship proceeding, knowingly personates another or appears falsely in the name of a deceased person or in an assumed or fictitious name; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever knowingly and unlawfully uses or attempts to use, as showing naturalization or citizenship of any person, any order, certificate, certificate of naturalization, certificate of citizenship, judgment, decree, or exemplification, or copies or duplicates thereof, issued to another person, or in a fictitious name or in the name of a deceased person—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Shall be fined under this title or imprisoned not more than five years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb91eee6e-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/766"},"text":"62 Stat. 766","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91eee6f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb91eee70-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on subsection (a) pars. (6)(a), (b), (15), (b), (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s746"},"text":"section 746 of title 8","children":[],"tail":", U.S.C., 1940 ed., Aliens and Nationality ("},{"tag":"ref","attrib":{"href":"/us/act/1940-10-14/ch876/s346/a"},"text":"Oct. 14, 1940, ch. 876, § 346(a)","children":[],"tail":", pars. (6), (15), (b), (d), "},{"tag":"ref","attrib":{"href":"/us/stat/54/1164"},"text":"54 Stat. 1164","children":[],"tail":", 1165, 1167)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section consolidates, with minor verbal changes, subsections (a), pars. (6)(a), (b), (15), (b), (d), and the general punishment provision of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s746"},"text":"section 746 of title 8","children":[],"tail":", U.S.C., 1940 ed., Aliens and Nationality."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb91eee71-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb91eee72-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $5,000” in last par."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
