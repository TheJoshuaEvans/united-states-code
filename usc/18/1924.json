{"tag":"section","attrib":{"id":"idb9392d3b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1924"},"text":null,"children":[{"tag":"num","attrib":{"value":"1924"},"text":"§ 1924.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unauthorized removal and retention of classified documents or material","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9392d3c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1924/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever, being an officer, employee, contractor, or consultant of the United States, and, by virtue of his office, employment, position, or contract, becomes possessed of documents or materials containing classified information of the United States, knowingly removes such documents or materials without authority and with the intent to retain such documents or materials at an unauthorized location shall be fined under this title or imprisoned for not more than five years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9392d3d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1924/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this section, the provision of documents and materials to the Congress shall not constitute an offense under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9392d3e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1924/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this section, the term “classified information of the United States” means information originated, owned, or possessed by the United States Government concerning the national defense or foreign relations of the United States that has been determined pursuant to law or Executive order to require protection against unauthorized disclosure in the interests of national security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9392d3f-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/359/tVIII/s808/a"},"text":"Pub. L. 103–359, title VIII, § 808(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-14"},"text":"Oct. 14, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3453"},"text":"108 Stat. 3453","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dB/tIV/s4002/d/1/C/i"},"text":"Pub. L. 107–273, div. B, title IV, § 4002(d)(1)(C)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1809"},"text":"116 Stat. 1809","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/118/tII/s202"},"text":"Pub. L. 115–118, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-01-19"},"text":"Jan. 19, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/19"},"text":"132 Stat. 19","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9392d40-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9392d41-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9392d42-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/118"},"text":"Pub. L. 115–118","children":[],"tail":" substituted “five years” for “one year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" substituted “under this title” for “not more than $1,000,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
