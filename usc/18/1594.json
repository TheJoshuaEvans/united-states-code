{"tag":"section","attrib":{"id":"idb92ad550-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1594"},"text":null,"children":[{"tag":"num","attrib":{"value":"1594"},"text":"§ 1594.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb92ad551-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1594/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever attempts to violate section 1581, 1583, 1584, 1589, 1590, or 1591 shall be punishable in the same manner as a completed violation of that section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92ad552-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1594/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever conspires with another to violate section 1581, 1583, 1589, 1590, or 1592 shall be punished in the same manner as a completed violation of such section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92ad553-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1594/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever conspires with another to violate section 1591 shall be fined under this title, imprisoned for any term of years or for life, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92ad554-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1594/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The court, in imposing sentence on any person convicted of a violation of this chapter, shall order, in addition to any other sentence imposed and irrespective of any provision of State law, that such person shall forfeit to the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92ad555-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1594/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such person’s interest in any property, real or personal, that was involved in, used, or intended to be used to commit or to facilitate the commission of such violation, and any property traceable to such property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92ad556-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1594/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any property, real or personal, constituting or derived from, any proceeds that such person obtained, directly or indirectly, as a result of such violation, or any property traceable to such property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92ad557-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1594/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92ad558-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1594/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following shall be subject to forfeiture to the United States and no property right shall exist in them:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb92ad559-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1594/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any property, real or personal, involved in, used, or intended to be used to commit or to facilitate the commission of any violation of this chapter, and any property traceable to such property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb92ad55a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1594/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any property, real or personal, which constitutes or is derived from proceeds traceable to any violation of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92ad55b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1594/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of chapter 46 of this title relating to civil forfeitures shall extend to any seizure or civil forfeiture under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92ad55c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1594/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of Forfeited Assets.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92ad55d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1594/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, the Attorney General shall transfer assets forfeited pursuant to this section, or the proceeds derived from the sale thereof, to satisfy victim restitution orders arising from violations of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92ad55e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1594/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Priority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Transfers pursuant to paragraph (1) shall have priority over any other claims to the assets or their proceeds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92ad55f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1594/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of nonforfeited assets","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Transfers pursuant to paragraph (1) shall not reduce or otherwise mitigate the obligation of a person convicted of a violation of this chapter to satisfy the full amount of a restitution order through the use of non-forfeited assets or to reimburse the Attorney General for the value of assets or proceeds transferred under this subsection through the use of nonforfeited assets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92ad560-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1594/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Witness Protection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any violation of this chapter shall be considered an organized criminal activity or other serious offense for the purposes of application of chapter 224 (relating to witness protection).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb92ad561-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386/dA/s112/a/2"},"text":"Pub. L. 106–386, div. A, § 112(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1489"},"text":"114 Stat. 1489","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/457/tII/s222/c"},"text":"Pub. L. 110–457, title II, § 222(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-12-23"},"text":"Dec. 23, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/5070"},"text":"122 Stat. 5070","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/22/tI/s105/a"},"text":"Pub. L. 114–22, title I, § 105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-05-29"},"text":"May 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/236"},"text":"129 Stat. 236","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92ad562-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92ad563-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92ad564-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22/s105/a/1/A"},"text":"Pub. L. 114–22, § 105(a)(1)(A)","children":[],"tail":", substituted “that was involved in, used, or” for “that was used or” and inserted “, and any property traceable to such property” after “such violation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22/s105/a/1/B"},"text":"Pub. L. 114–22, § 105(a)(1)(B)","children":[],"tail":", inserted “, or any property traceable to such property” after “such violation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22/s105/a/2"},"text":"Pub. L. 114–22, § 105(a)(2)","children":[],"tail":", substituted “involved in, used, or” for “used or” and inserted “, and any property traceable to such property” after “any violation of this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22/s105/a/3"},"text":"Pub. L. 114–22, § 105(a)(3)","children":[],"tail":", (4), added subsec. (f) and redesignated former subsec. (f) as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsecs. (b) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/457"},"text":"Pub. L. 110–457","children":[],"tail":" added subsecs. (b) and (c) and redesignated former subsecs. (b) to (d) as (d) to (f), respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
