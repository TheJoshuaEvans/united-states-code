{"tag":"section","attrib":{"id":"idb92ad61d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1698"},"text":null,"children":[{"tag":"num","attrib":{"value":"1698"},"text":"§ 1698.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prompt delivery of mail from vessel","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, having charge or control of any vessel passing between ports or places in the United States, and arriving at any such port or place where there is a post office, fails to deliver to the postmaster or at the post office, within three hours after his arrival, if in the daytime, and if at night, within two hours after the next sunrise, all letters and packages brought by him or within his power or control and not relating to the cargo, addressed to or destined for such port or place, shall be fined under this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb92ad61e-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/777"},"text":"62 Stat. 777","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII"},"text":"Pub. L. 103–322, title XXXIII","children":[],"tail":", §§ 330004(10), 330016(1)(C), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2141"},"text":"108 Stat. 2141","children":[],"tail":", 2146.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92ad61f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb92ad620-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed. § 323 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s200"},"text":"Mar. 4, 1909, ch. 321, § 200","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1126"},"text":"35 Stat. 1126","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92ad621-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92ad622-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/1/C"},"text":"Pub. L. 103–322, § 330016(1)(C)","children":[],"tail":", substituted “fined under this title” for “fined not more than $150”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330004/10"},"text":"Pub. L. 103–322, § 330004(10)","children":[],"tail":", struck out second par. which read as follows: “For each letter or package so delivered he shall receive two cents unless the same is carried under contract.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
