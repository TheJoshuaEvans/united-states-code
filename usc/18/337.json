{"tag":"section","attrib":{"id":"idb8c69590-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s337"},"text":null,"children":[{"tag":"num","attrib":{"value":"337"},"text":"§ 337.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coins as security for loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever lends or borrows money or credit upon the security of such coins of the United States as the Secretary of the Treasury may from time to time designate by proclamation published in the Federal Register, during any period designated in such a proclamation, shall be fined under this title or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8c69591-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/81/tII/s212/a"},"text":"Pub. L. 89–81, title II, § 212(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-23"},"text":"July 23, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/257"},"text":"79 Stat. 257","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/L"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(L)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c69592-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8c69593-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8c69594-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $10,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8c69595-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8c69596-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/81/tII/s212/c"},"text":"Pub. L. 89–81, title II, § 212(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-23"},"text":"July 23, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/257"},"text":"79 Stat. 257","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/81/tII/s212/c"},"text":"“The amendments made by this section [enacting this section] shall apply only with respect to loans made, renewed, or increased on or after the 31st day after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1965-07-23"},"text":"July 23, 1965","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
