{"tag":"section","attrib":{"id":"idb8d03236-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s548"},"text":null,"children":[{"tag":"num","attrib":{"value":"548"},"text":"§ 548.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removing or repacking goods in warehouses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever fraudulently conceals, removes, or repacks merchandise in any bonded warehouse or fraudulently alters, defaces or obliterates any marks or numbers placed upon packages deposited in such warehouse, shall be fined under this title or imprisoned not more than two years, or both.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Merchandise so concealed, removed, or repacked, or packages upon which any marks or numbers have been so altered, defaced, or obliterated, shall be forfeited to the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8d2a337-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/717"},"text":"62 Stat. 717","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8d2a338-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8d2a339-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1597"},"text":"section 1597 of title 19","children":[],"tail":", U.S.C., 1940 ed., Customs Duties ("},{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 597, "},{"tag":"ref","attrib":{"href":"/us/stat/46/752"},"text":"46 Stat. 752","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section was rewritten to place the criminal provisions ahead of the forfeiture provisions. This did not require any substantive changes except omission of reference to persons aiding. Such persons are made principals by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The punishment prescribed by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s545"},"text":"section 545 of this title","children":[],"tail":" was inserted to make this section complete without reference to another section. In doing so it was necessary to rephrase the punishment provision of "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s545"},"text":"section 545 of this title","children":[],"tail":", as originally enacted, without change of substance."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Forfeiture provision was rephrased to make it clear that forfeiture was not dependent upon conviction.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8d2a33a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8d2a33b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $5,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
