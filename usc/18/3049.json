{"tag":"section","attrib":{"id":"idb985780d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3049"},"text":null,"children":[{"tag":"num","attrib":{"value":"3049"},"text":"§ 3049.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Warrant for removal","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Only one writ or warrant is necessary to remove a prisoner from one district to another. One copy thereof may be delivered to the sheriff or jailer from whose custody the prisoner is taken, and another to the sheriff or jailer to whose custody he is committed, and the original writ, with the marshal’s return thereon, shall be returned to the clerk of the district to which he is removed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb985780e-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/817"},"text":"62 Stat. 817","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb985780f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9857810-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 604 (R.S. § 1029).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
