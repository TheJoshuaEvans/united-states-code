{"tag":"section","attrib":{"id":"idb949cefa-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2250"},"text":null,"children":[{"tag":"num","attrib":{"value":"2250"},"text":"§ 2250.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to register","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb949cefb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2250/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb949cefc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2250/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is required to register under the Sex Offender Registration and Notification Act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb949cefd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2250/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb949cefe-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2250/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a sex offender as defined for the purposes of the Sex Offender Registration and Notification Act by reason of a conviction under Federal law (including the Uniform Code of Military Justice), the law of the District of Columbia, Indian tribal law, or the law of any territory or possession of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb949ceff-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2250/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" travels in interstate or foreign commerce, or enters or leaves, or resides in, Indian country; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb949cf00-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2250/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly fails to register or update a registration as required by the Sex Offender Registration and Notification Act;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title or imprisoned not more than 10 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb949cf01-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2250/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"International Travel Reporting Violations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb949cf02-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2250/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is required to register under the Sex Offender Registration and Notification Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16901"},"text":"42 U.S.C. 16901","children":[],"tail":" et seq.); "},{"tag":"ref","attrib":{"idref":"fn002144"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002144"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb949cf03-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2250/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly fails to provide information required by the Sex Offender Registration and Notification Act relating to intended travel in foreign commerce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb949cf04-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2250/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engages or attempts to engage in the intended travel in foreign commerce;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title, imprisoned not more than 10 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb949cf05-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2250/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Affirmative Defense","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In a prosecution for a violation under subsection (a) or (b), it is an affirmative defense that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb949cf06-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2250/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uncontrollable circumstances prevented the individual from complying;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb949cf07-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2250/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual did not contribute to the creation of such circumstances in reckless disregard of the requirement to comply; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb949cf08-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2250/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual complied as soon as such circumstances ceased to exist.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb949cf09-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2250/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Crime of Violence.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb949cf0a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2250/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual described in subsection (a) or (b) who commits a crime of violence under Federal law (including the Uniform Code of Military Justice), the law of the District of Columbia, Indian tribal law, or the law of any territory or possession of the United States shall be imprisoned for not less than 5 years and not more than 30 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb949cf0b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2250/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional punishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The punishment provided in paragraph (1) shall be in addition and consecutive to the punishment provided for the violation described in subsection (a) or (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb949cf0c-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/tI/s141/a/1"},"text":"Pub. L. 109–248, title I, § 141(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/602"},"text":"120 Stat. 602","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/119/s6/b"},"text":"Pub. L. 114–119, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/23"},"text":"130 Stat. 23","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb949cf0d-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb949cf0e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb949cf0f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Sex Offender Registration and Notification Act, referred to in subsecs. (a)(1), (2)(A), (3) and (b)(1), (2), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248"},"text":"Pub. L. 109–248","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/590"},"text":"120 Stat. 590","children":[],"tail":", which was classified principally to subchapter I (§ 16901 et seq.) of chapter 151 of Title 42, The Public Health and Welfare, prior to editorial reclassification as chapter 209 (§ 20901 et seq.) of Title 34, Crime Control and Law Enforcement. For complete classification of this Act to the Code, see Short Title of 2006 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of Title 34","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Uniform Code of Military Justice, referred to in subsecs. (a)(2)(A) and (d)(1), is classified generally to chapter 47 (§ 801 et seq.) of Title 10, Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb949cf10-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/119"},"text":"Pub. L. 114–119","children":[],"tail":" added subsec. (b), redesignated former subsecs. (b) and (c) as (c) and (d), respectively, and in subsecs. (c) and (d), substituted “subsection (a) or (b)” for “subsection (a)” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
