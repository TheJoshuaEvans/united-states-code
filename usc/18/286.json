{"tag":"section","attrib":{"id":"idb8c44b42-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s286"},"text":null,"children":[{"tag":"num","attrib":{"value":"286"},"text":"§ 286.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conspiracy to defraud the Government with respect to claims","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever enters into any agreement, combination, or conspiracy to defraud the United States, or any department or agency thereof, by obtaining or aiding to obtain the payment or allowance of any false, fictitious or fraudulent claim, shall be fined under this title or imprisoned not more than ten years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8c44b43-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/698"},"text":"62 Stat. 698","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/L"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(L)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c44b44-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8c44b45-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 83 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s35"},"text":"Mar. 4, 1909, ch. 321, § 35","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1095"},"text":"35 Stat. 1095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1918-10-23/ch194"},"text":"Oct. 23, 1918, ch. 194","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/1015"},"text":"40 Stat. 1015","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1934-06-18/ch587"},"text":"June 18, 1934, ch. 587","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/996"},"text":"48 Stat. 996","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1938-04-04/ch69"},"text":"Apr. 4, 1938, ch. 69","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/197"},"text":"52 Stat. 197","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"To clarify meaning of “department” the word “agency” was inserted after it. (See definitions of “department” and “agency” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s6"},"text":"section 6 of this title","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “or any corporation in which the United States of America is a stockholder” were omitted as unnecessary in view of definition of “agency” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s6"},"text":"section 6 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes in phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8c44b46-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8c44b47-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $10,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
