{"tag":"section","attrib":{"id":"idb92ad5b8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1653"},"text":null,"children":[{"tag":"num","attrib":{"value":"1653"},"text":"§ 1653.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aliens as pirates","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being a citizen or subject of any foreign state, is found and taken on the sea making war upon the United States, or cruising against the vessels and property thereof, or of the citizens of the same, contrary to the provisions of any treaty existing between the United States and the state of which the offender is a citizen or subject, when by such treaty such acts are declared to be piracy, is a pirate, and shall be imprisoned for life.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb92ad5b9-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/774"},"text":"62 Stat. 774","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92ad5ba-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb92ad5bb-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 496 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s305"},"text":"Mar. 4, 1909, ch. 321, § 305","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1147"},"text":"35 Stat. 1147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor change was made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
