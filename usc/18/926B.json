{"tag":"section","attrib":{"id":"idb8fb12df-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s926B"},"text":null,"children":[{"tag":"num","attrib":{"value":"926B"},"text":"§ 926B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carrying of concealed firearms by qualified law enforcement officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8fb12e0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s926B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of the law of any State or any political subdivision thereof, an individual who is a qualified law enforcement officer and who is carrying the identification required by subsection (d) may carry a concealed firearm that has been shipped or transported in interstate or foreign commerce, subject to subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fb12e1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s926B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This section shall not be construed to supersede or limit the laws of any State that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fb12e2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s926B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit private persons or entities to prohibit or restrict the possession of concealed firearms on their property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fb12e3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s926B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibit or restrict the possession of firearms on any State or local government property, installation, building, base, or park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fb12e4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s926B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in this section, the term “qualified law enforcement officer” means an employee of a governmental agency who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fb12e5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s926B/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is authorized by law to engage in or supervise the prevention, detection, investigation, or prosecution of, or the incarceration of any person for, any violation of law, and has statutory powers of arrest or apprehension under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s807/b"},"text":"section 807(b) of title 10","children":[],"tail":", United States Code (article 7(b) of the Uniform Code of Military Justice);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fb12e6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s926B/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is authorized by the agency to carry a firearm;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fb12e7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s926B/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not the subject of any disciplinary action by the agency which could result in suspension or loss of police powers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fb12e8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s926B/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets standards, if any, established by the agency which require the employee to regularly qualify in the use of a firearm;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fb12e9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s926B/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not under the influence of alcohol or another intoxicating or hallucinatory drug or substance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fb12ea-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s926B/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not prohibited by Federal law from receiving a firearm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fb12eb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s926B/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The identification required by this subsection is the photographic identification issued by the governmental agency for which the individual is employed that identifies the employee as a police officer or law enforcement officer of the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fb12ec-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s926B/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in this section, the term “firearm”—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fb12ed-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s926B/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in this subsection, has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s921"},"text":"section 921 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fb12ee-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s926B/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes ammunition not expressly prohibited by Federal law or subject to the provisions of the National Firearms Act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fb12ef-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s926B/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8fb12f0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s926B/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any machinegun (as defined in section 5845 of the National Firearms Act);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fb12f1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s926B/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any firearm silencer (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s921"},"text":"section 921 of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fb12f2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s926B/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any destructive device (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s921"},"text":"section 921 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fb12f3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s926B/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this section, a law enforcement officer of the Amtrak Police Department, a law enforcement officer of the Federal Reserve, or a law enforcement or police officer of the executive branch of the Federal Government qualifies as an employee of a governmental agency who is authorized by law to engage in or supervise the prevention, detection, investigation, or prosecution of, or the incarceration of any person for, any violation of law, and has statutory powers of arrest or apprehension under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s807/b"},"text":"section 807(b) of title 10","children":[],"tail":", United States Code (article 7(b) of the Uniform Code of Military Justice)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8fb12f4-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/277/s2/a"},"text":"Pub. L. 108–277, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-22"},"text":"July 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/865"},"text":"118 Stat. 865","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/272/s2/a"},"text":"Pub. L. 111–272, § 2(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2010-10-12"},"text":"Oct. 12, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2855"},"text":"124 Stat. 2855","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1089/1"},"text":"Pub. L. 112–239, div. A, title X, § 1089(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1970"},"text":"126 Stat. 1970","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8fb12f5-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8fb12f6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8fb12f7-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Firearms Act, referred to in subsec. (e), is classified generally to chapter 53 (§ 5801 et seq.) of Title 26, Internal Revenue Code. See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s5849"},"text":"section 5849 of Title 26","children":[],"tail":". Section 5845 of the Act is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5845"},"text":"section 5845 of Title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8fb12f8-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1089/1/A"},"text":"Pub. L. 112–239, § 1089(1)(A)","children":[],"tail":", inserted “or apprehension under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s807/b"},"text":"section 807(b) of title 10","children":[],"tail":", United States Code (article 7(b) of the Uniform Code of Military Justice)” after “arrest”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1089/1/B"},"text":"Pub. L. 112–239, § 1089(1)(B)","children":[],"tail":", substituted “that identifies the employee as a police officer or law enforcement officer of the agency” for “as a law enforcement officer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1089/1/C"},"text":"Pub. L. 112–239, § 1089(1)(C)","children":[],"tail":", inserted “or apprehension under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s807/b"},"text":"section 807(b) of title 10","children":[],"tail":", United States Code (article 7(b) of the Uniform Code of Military Justice)” after “arrest”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/272/s2/a/1"},"text":"Pub. L. 111–272, § 2(a)(1)","children":[],"tail":", inserted “which could result in suspension or loss of police powers” after “agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/272/s2/b"},"text":"Pub. L. 111–272, § 2(b)","children":[],"tail":", added subsec. (e) and struck out former subsec. (e) which read as follows: “As used in this section, the term ‘firearm’ does not include—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) any machinegun (as defined in section 5845 of the National Firearms Act);","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) any firearm silencer (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s921"},"text":"section 921 of this title","children":[],"tail":"); and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) any destructive device (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s921"},"text":"section 921 of this title","children":[],"tail":").”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/272/s2/a/2"},"text":"Pub. L. 111–272, § 2(a)(2)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8fb12f9-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8fb12fa-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Federal Law Enforcement Self-Defense and Protection","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/180"},"text":"Pub. L. 114–180","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/445"},"text":"130 Stat. 445","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/180"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“SECTION 1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This Act may be cited as the ‘Federal Law Enforcement Self-Defense and Protection Act of 2015’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“SEC. 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FINDINGS.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“Congress finds the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Too often, Federal law enforcement officers encounter potentially violent criminals, placing officers in danger of grave physical harm.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In 2012 alone, 1,857 Federal law enforcement officers were assaulted, with 206 sustaining serious injuries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" From 2008 through 2011, an additional 8,587 Federal law enforcement officers were assaulted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal law enforcement officers remain a target even when they are off-duty. Over the past 3 years, 27 law enforcement officers have been killed off-duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is essential that law enforcement officers are able to defend themselves, so they can carry out their critical missions and ensure their own personal safety and the safety of their families whether on-duty or off-duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" These dangers to law enforcement officers continue to exist during a covered furlough.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“SEC. 3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" DEFINITIONS.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“In this Act—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘agency’ means each authority of the executive, legislative, or judicial branch of the Government of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term ‘covered Federal law enforcement officer’ means any individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an employee of an agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the authority to make arrests or apprehensions for, or prosecute, violations of Federal law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the day before the date on which the applicable covered furlough begins, is authorized by the agency employing the individual to carry a firearm in the course of official duties;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘covered furlough’ means a planned event by an agency during which employees are involuntarily furloughed due to downsizing, reduced funding, lack of work, or any budget situation including a lapse in appropriations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘firearm’ has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s921"},"text":"section 921 of title 18","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“SEC. 4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" PROTECTING FEDERAL LAW ENFORCEMENT OFFICERS WHO ARE SUBJECTED TO A COVERED FURLOUGH.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“During a covered furlough, a covered Federal law enforcement officer shall have the same rights to carry a firearm issued by the Federal Government as if the covered furlough was not in effect, including, if authorized on the day before the date on which the covered furlough begins, the right to carry a concealed firearm, if the sole reason the covered Federal law enforcement officer was placed on leave was due to the covered furlough.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
