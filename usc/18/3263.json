{"tag":"section","attrib":{"id":"idb9988b00-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3263"},"text":null,"children":[{"tag":"num","attrib":{"value":"3263"},"text":"§ 3263.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delivery to authorities of foreign countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9988b01-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3263/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any person designated and authorized under section 3262(a) may deliver a person described in section 3261(a) to the appropriate authorities of a foreign country in which such person is alleged to have violated section 3261(a) if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9988b02-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3263/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate authorities of that country request the delivery of the person to such country for trial for such conduct as an offense under the laws of that country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9988b03-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3263/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the delivery of such person to that country is authorized by a treaty or other international agreement to which the United States is a party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9988b04-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3263/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense, in consultation with the Secretary of State, shall determine which officials of a foreign country constitute appropriate authorities for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9988b05-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/523/s2/a"},"text":"Pub. L. 106–523, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2489"},"text":"114 Stat. 2489","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
