{"tag":"section","attrib":{"id":"idb92ad5f1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1692"},"text":null,"children":[{"tag":"num","attrib":{"value":"1692"},"text":"§ 1692.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign mail as United States mail","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every foreign mail, while being transported across the territory of the United States under authority of law, is mail of the United States, and any depredation thereon, or offense in respect thereto, shall be punishable as though it were United States mail.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb92ad5f2-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/776"},"text":"62 Stat. 776","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92ad5f3-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb92ad5f4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 359 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s229"},"text":"Mar. 4, 1909, ch. 321, § 229","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1134"},"text":"35 Stat. 1134","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology and obvious surplusage omitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
