{"tag":"section","attrib":{"id":"idb8d03216-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s544"},"text":null,"children":[{"tag":"num","attrib":{"value":"544"},"text":"§ 544.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relanding of goods","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any merchandise entered or withdrawn for exportation without payment of the duties thereon, or with intent to obtain a drawback of the duties paid, or of any other allowances given by law on the exportation thereof, is relanded at any place in the United States without entry having been made, such merchandise shall be considered as having been imported into the United States contrary to law, and each person concerned shall be fined under this title or imprisoned not more than two years, or both; and such merchandise shall be forfeited.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The term “any place in the United States”, as used in this section, shall not include the Virgin Islands, American Samoa, Wake Island, Midway Islands, Kingman Reef, Johnston Island, or Guam.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8d03217-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/716"},"text":"62 Stat. 716","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1955-06-30/ch258/s2/c"},"text":"June 30, 1955, ch. 258, § 2(c)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/242"},"text":"69 Stat. 242","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII"},"text":"Pub. L. 103–322, title XXXIII","children":[],"tail":", §§ 330004(18), 330016(1)(K), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2142"},"text":"108 Stat. 2142","children":[],"tail":", 2147; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s604/b/23"},"text":"Pub. L. 104–294, title VI, § 604(b)(23)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3508"},"text":"110 Stat. 3508","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8d03218-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8d03219-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1589"},"text":"section 1589 of title 19","children":[],"tail":", U.S.C., 1940 ed., Customs Duties ("},{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 589, "},{"tag":"ref","attrib":{"href":"/us/stat/46/750"},"text":"46 Stat. 750","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The final paragraph was added to conform with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1709"},"text":"section 1709 of title 19","children":[],"tail":", U.S.C., 1940 ed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8d0321a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8d0321b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"chil