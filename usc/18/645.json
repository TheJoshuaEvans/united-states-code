{"tag":"section","attrib":{"id":"idb8d4ed57-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s645"},"text":null,"children":[{"tag":"num","attrib":{"value":"645"},"text":"§ 645.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Court officers generally","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being a United States marshal, clerk, receiver, referee, trustee, or other officer of a United States court, or any deputy, assistant, or employee of any such officer, retains or converts to his own use or to the use of another or after demand by the party entitled thereto, unlawfully retains any money coming into his hands by virtue of his official relation, position or employment, is guilty of embezzlement and shall, where the offense is not otherwise punishable by enactment of Congress, be fined under this title or not more than double the value of the money so embezzled, whichever is greater, or imprisoned not more than ten years, or both; but if the amount embezzled does not exceed $1,000, he shall be fined under this title or imprisoned not more than one year, or both.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"It shall not be a defense that the accused person had any interest in such moneys or fund.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8d4ed58-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/726"},"text":"62 Stat. 726","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", (2)(G), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":", 2148; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s606/a"},"text":"Pub. L. 104–294, title VI, § 606(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3511"},"text":"110 Stat. 3511","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8d4ed59-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8d4ed5a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 186 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-05-29/ch212"},"text":"May 29, 1920, ch. 212","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/630"},"text":"41 Stat. 630","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The smaller punishment for an offense involving $100 or less was inserted to conform to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s641"},"text":"section 641 of this title","children":[],"tail":" which represents a later expression of congressional intent."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8d4ed5b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8d4ed5c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" substituted “$1,000” for “$100”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/2/G"},"text":"Pub. L. 103–322, § 330016(2)(G)","children":[],"tail":", substituted “be fined under this title or not more than double the value of the money so embezzled, whichever is greater, or imprisoned” for “be fined not more than double the value of the money so embezzled or imprisoned”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/1/H"},"text":"Pub. L. 103–322, § 330016(1)(H)","children":[],"tail":", substituted “fined under this title” for “fined not more than $1,000” after “he shall be”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
