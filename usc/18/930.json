{"tag":"section","attrib":{"id":"idb8fd833d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s930"},"text":null,"children":[{"tag":"num","attrib":{"value":"930"},"text":"§ 930.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Possession of firearms and dangerous weapons in Federal facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8fd833e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s930/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (d), whoever knowingly possesses or causes to be present a firearm or other dangerous weapon in a Federal facility (other than a Federal court facility), or attempts to do so, shall be fined under this title or imprisoned not more than 1 year, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fd833f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s930/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever, with intent that a firearm or other dangerous weapon be used in the commission of a crime, knowingly possesses or causes to be present such firearm or dangerous weapon in a Federal facility, or attempts to do so, shall be fined under this title or imprisoned not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fd8340-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s930/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who kills any person in the course of a violation of subsection (a) or (b), or in the course of an attack on a Federal facility involving the use of a firearm or other dangerous weapon, or attempts or conspires to do such an act, shall be punished as provided in sections 1111, 1112, 1113, and 1117.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fd8341-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s930/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subsection (a) shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fd8342-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s930/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lawful performance of official duties by an officer, agent, or employee of the United States, a State, or a political subdivision thereof, who is authorized by law to engage in or supervise the prevention, detection, investigation, or prosecution of any violation of law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fd8343-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s930/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the possession of a firearm or other dangerous weapon by a Federal official or a member of the Armed Forces if such possession is authorized by law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fd8344-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s930/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lawful carrying of firearms or other dangerous weapons in a Federal facility incident to hunting or other lawful purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fd8345-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s930/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fd8346-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s930/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), whoever knowingly possesses or causes to be present a firearm or other dangerous weapon in a Federal court facility, or attempts to do so, shall be fined under this title, imprisoned not more than 2 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fd8347-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s930/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) shall not apply to conduct which is described in paragraph (1) or (2) of subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fd8348-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s930/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section limits the power of a court of the United States to punish for contempt or to promulgate rules or orders regulating, restricting, or prohibiting the possession of weapons within any building housing such court or any of its proceedings, or upon any grounds appurtenant to such building.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fd8349-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s930/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fd834a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s930/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Federal facility” means a building or part thereof owned or leased by the Federal Government, where Federal employees are regularly present for the purpose of performing their official duties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fd834b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s930/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “dangerous weapon” means a weapon, device, instrument, material, or substance, animate or inanimate, that is used for, or is readily capable of, causing death or serious bodily injury, except that such term does not include a pocket knife with a blade of less than 2½ inches in length.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fd834c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s930/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Federal court facility” means the courtroom, judges’ chambers, witness rooms, jury deliberation rooms, attorney conference rooms, prisoner holding cells, offices of the court clerks, the United States attorney, and the United States marshal, probation and parole offices, and adjoining corridors of any court of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fd834d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s930/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notice of the provisions of subsections (a) and (b) shall be posted conspicuously at each public entrance to each Federal facility, and notice of subsection (e) shall be posted conspicuously at each public entrance to each Federal court facility, and no person shall be convicted of an offense under subsection (a) or (e) with respect to a Federal facility if such notice is not so posted at such facility, unless such person had actual notice of subsection (a) or (e), as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8fd834e-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI/s6215/a"},"text":"Pub. L. 100–690, title VI, § 6215(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4361"},"text":"102 Stat. 4361","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXII/s2205/a"},"text":"Pub. L. 101–647, title XXII, § 2205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4857"},"text":"104 Stat. 4857","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tVI/s60014"},"text":"Pub. L. 103–322, title VI, § 60014","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1973"},"text":"108 Stat. 1973","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s603/t"},"text":"Pub. L. 104–294, title VI, § 603(t)","children":[],"tail":", (u), "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3506"},"text":"110 Stat. 3506","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tVIII/s811/b"},"text":"Pub. L. 107–56, title VIII, § 811(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/381"},"text":"115 Stat. 381","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/177/tII/s203"},"text":"Pub. L. 110–177, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-07"},"text":"Jan. 7, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2537"},"text":"121 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8fd834f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8fd8350-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8fd8351-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/177"},"text":"Pub. L. 110–177","children":[],"tail":" inserted “or other dangerous weapon” after “firearm”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56"},"text":"Pub. L. 107–56","children":[],"tail":" struck out “or attempts to kill” after “A person who kills”, inserted “or attempts or conspires to do such an act,” before “shall be punished”, and substituted “1113, and 1117” for “and 1113”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294/s603/t"},"text":"Pub. L. 104–294, § 603(t)","children":[],"tail":", substituted “subsection (d)” for “subsection (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294/s603/u/1"},"text":"Pub. L. 104–294, § 603(u)(1)","children":[],"tail":", redesignated subsec. (g), related to posting notice in Federal facilities, as (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294/s603/u/2"},"text":"Pub. L. 104–294, § 603(u)(2)","children":[],"tail":", substituted “(e)” for “(d)” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294/s603/u/1"},"text":"Pub. L. 104–294, § 603(u)(1)","children":[],"tail":", redesignated subsec. (g), related to posting notice in Federal facilities, as (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s60014/2"},"text":"Pub. L. 103–322, § 60014(2)","children":[],"tail":", substituted “(d)” for “(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s60014/1"},"text":"Pub. L. 103–322, § 60014(1)","children":[],"tail":", (3), added subsec. (c) and redesignated former subsecs. (c) to (f) as (d) to (g), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/s2205/a/1"},"text":"Pub. L. 101–647, § 2205(a)(1)","children":[],"tail":", inserted “(other than a Federal court facility)” after “Federal facility”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/s2205/a/2"},"text":"Pub. L. 101–647, § 2205(a)(2)","children":[],"tail":", (3), added subsec. (d) and redesignated former subsec. (d) as (e). Former subsec. (e) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/s2205/a/2"},"text":"Pub. L. 101–647, § 2205(a)(2)","children":[],"tail":", redesignated subsec. (e) as (f). Former subsec. (f) redesignated (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/s2205/a/4"},"text":"Pub. L. 101–647, § 2205(a)(4)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/s2205/a/5"},"text":"Pub. L. 101–647, § 2205(a)(5)","children":[],"tail":", inserted “and notice of subsection (d) shall be posted conspicuously at each public entrance to each Federal court facility,” after “each Federal facility,”, “or (d)” before “with respect to”, and “or (d), as the case may be” before the period."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/s2205/a/2"},"text":"Pub. L. 101–647, § 2205(a)(2)","children":[],"tail":", redesignated subsec. (f) as (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8fd8352-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8fd8353-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXII/s2205/b"},"text":"Pub. L. 101–647, title XXII, § 2205(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4858"},"text":"104 Stat. 4858","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/647/tXXII/s2205/b"},"text":"“The amendments made by subsection (a) [amending this section] shall apply to conduct engaged in after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
