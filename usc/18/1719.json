{"tag":"section","attrib":{"id":"idb92f9032-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1719"},"text":null,"children":[{"tag":"num","attrib":{"value":"1719"},"text":"§ 1719.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Franking privilege","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever makes use of any official envelope, label, or indorsement authorized by law, to avoid the payment of postage or registry fee on his private letter, packet, package, or other matter in the mail, shall be fined under this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb92f9033-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/stat/62/783"},"text":"62 Stat. 783","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/F"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92f9034-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb92f9035-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 357 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s227"},"text":"Mar. 4, 1909, ch. 321, § 227","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1134"},"text":"35 Stat. 1134","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor verbal change was made. ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s746/f"},"text":"Section 746(f) of title 8","children":[],"tail":", U.S.C., 1940 ed., Aliens and Nationality, providing same penalty for misuse of franking privilege in naturalization service, should be repealed as covered by this section. The proviso in "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s337"},"text":"section 337 of title 39","children":[],"tail":", U.S.C., 1940 ed., The Postal Service, should also be repealed for the same reason."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92f9036-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92f9037-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $300”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
