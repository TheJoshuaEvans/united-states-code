{"tag":"section","attrib":{"id":"idb8b38263-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s176"},"text":null,"children":[{"tag":"num","attrib":{"value":"176"},"text":"§ 176.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seizure, forfeiture, and destruction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8b38264-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s176/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b38265-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s176/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (2), the Attorney General may request the issuance, in the same manner as provided for a search warrant, of a warrant authorizing the seizure of any biological agent, toxin, or delivery system that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8b38266-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s176/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pertains to conduct prohibited under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s175"},"text":"section 175 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8b38267-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s176/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is of a type or in a quantity that under the circumstances has no apparent justification for prophylactic, protective, or other peaceful purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b38268-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s176/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In exigent circumstances, seizure and destruction of any biological agent, toxin, or delivery system described in subparagraphs (A) and (B) of paragraph (1) may be made upon probable cause without the necessity for a warrant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b38269-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s176/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Property seized pursuant to subsection (a) shall be forfeited to the United States after notice to potential claimants and an opportunity for a hearing. At such hearing, the Government shall bear the burden of persuasion by a preponderance of the evidence. Except as inconsistent herewith, the same procedures and provisions of law relating to a forfeiture under the customs laws shall extend to a seizure or forfeiture under this section. The Attorney General may provide for the destruction or other appropriate disposition of any biological agent, toxin, or delivery system seized and forfeited pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b3826a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s176/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Affirmative Defense","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is an affirmative defense against a forfeiture under subsection (a)(1)(B) of this section that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b3826b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s176/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such biological agent, toxin, or delivery system is for a prophylactic, protective, or other peaceful purpose; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b3826c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s176/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such biological agent, toxin, or delivery system, is of a type and quantity reasonable for that purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8b3826d-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/298/s3/a"},"text":"Pub. L. 101–298, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-05-22"},"text":"May 22, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/202"},"text":"104 Stat. 202","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330010/16"},"text":"Pub. L. 103–322, title XXXIII, § 330010(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2144"},"text":"108 Stat. 2144","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/188/tII/s231/c/3"},"text":"Pub. L. 107–188, title II, § 231(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-12"},"text":"June 12, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/661"},"text":"116 Stat. 661","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8b3826e-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8b3826f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8b38270-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/188"},"text":"Pub. L. 107–188","children":[],"tail":" substituted “pertains to” for “exists by reason of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “the Government” for “the government”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
