{"tag":"section","attrib":{"id":"idb8d2a3ba-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s599"},"text":null,"children":[{"tag":"num","attrib":{"value":"599"},"text":"§ 599.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promise of appointment by candidate","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being a candidate, directly or indirectly promises or pledges the appointment, or the use of his influence or support for the appointment of any person to any public or private position or employment, for the purpose of procuring support in his candidacy shall be fined under this title or imprisoned not more than one year, or both; and if the violation was willful, shall be fined under this title or imprisoned not more than two years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8d2a3bb-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/721"},"text":"62 Stat. 721","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", (L), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8d2a3bc-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8d2a3bd-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on sections 249, 252, of title 2, U.S.C., 1940 ed., The Congress (","children":[{"tag":"ref","attrib":{"href":"/us/act/1925-02-28/ch368"},"text":"Feb. 28, 1925, ch. 368","children":[],"tail":", title III, §§ 310, 314, "},{"tag":"ref","attrib":{"href":"/us/stat/43/1073"},"text":"43 Stat. 1073","children":[],"tail":", 1074)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section consolidates the provisions of sections 249 and 252 of title 2, U.S.C., 1940 ed., The Congress, with changes in arrangement and phraseology necessary to effect consolidation.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “or both” were added to conform to the almost universal formula of the punishment provisions of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8d2a3be-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8d2a3bf-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $1,000” after “candidacy shall be” and for “fined not more than $10,000” after “willful, shall be”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
