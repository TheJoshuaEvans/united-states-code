{"tag":"section","attrib":{"id":"idb8a2e07d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"§ 17.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insanity defense","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8a2e07e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s17/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Affirmative Defense","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It is an affirmative defense to a prosecution under any Federal statute that, at the time of the commission of the acts constituting the offense, the defendant, as a result of a severe mental disease or defect, was unable to appreciate the nature and quality or the wrongfulness of his acts. Mental disease or defect does not otherwise constitute a defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a2e07f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s17/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Burden of Proof","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The defendant has the burden of proving the defense of insanity by clear and convincing evidence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8a2e080-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s402/a"},"text":"Pub. L. 98–473, title II, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2057"},"text":"98 Stat. 2057","children":[],"tail":", § 20; renumbered § 17, "},{"tag":"ref","attrib":{"href":"/us/pl/99/646/s34/a"},"text":"Pub. L. 99–646, § 34(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3599"},"text":"100 Stat. 3599","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
