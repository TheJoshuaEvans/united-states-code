{"tag":"section","attrib":{"id":"idb8d9a807-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s667"},"text":null,"children":[{"tag":"num","attrib":{"value":"667"},"text":"§ 667.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Theft of livestock","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever obtains or uses the property of another which has a value of $10,000 or more in connection with the marketing of livestock in interstate or foreign commerce with intent to deprive the other of a right to the property or a benefit of the property or to appropriate the property to his own use or the use of another shall be fined under this title or imprisoned not more than five years, or both. The term “livestock” has the meaning set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2311"},"text":"section 2311 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8d9a808-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s1111"},"text":"Pub. L. 98–473, title II, § 1111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2149"},"text":"98 Stat. 2149","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII"},"text":"Pub. L. 103–322, title XXXIII","children":[],"tail":", §§ 330009(b), 330016(1)(L), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2143"},"text":"108 Stat. 2143","children":[],"tail":", 2147.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8d9a809-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8d9a80a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8d9a80b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $10,000” and inserted at end “The term ‘livestock’ has the meaning set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2311"},"text":"section 2311 of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
