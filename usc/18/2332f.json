{"tag":"section","attrib":{"id":"idb9640d67-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f"},"text":null,"children":[{"tag":"num","attrib":{"value":"2332f"},"text":"§ 2332f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bombings of places of public use, government facilities, public transportation systems and infrastructure facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9640d68-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offenses.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9640d69-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever unlawfully delivers, places, discharges, or detonates an explosive or other lethal device in, into, or against a place of public use, a state or government facility, a public transportation system, or an infrastructure facility—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9640d6a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the intent to cause death or serious bodily injury, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9640d6b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the intent to cause extensive destruction of such a place, facility, or system, where such destruction results in or is likely to result in major economic loss,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished as prescribed in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9640d6c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Attempts and conspiracies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever attempts or conspires to commit an offense under paragraph (1) shall be punished as prescribed in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9640d6d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is jurisdiction over the offenses in subsection (a) if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9640d6e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the offense takes place in the United States and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9640d6f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense is committed against another state or a government facility of such state, including its embassy or other diplomatic or consular premises of that state;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9640d70-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense is committed in an attempt to compel another state or the United States to do or abstain from doing any act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9640d71-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at the time the offense is committed, it is committed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9640d72-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on board a vessel flying the flag of another state;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9640d73-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on board an aircraft which is registered under the laws of another state; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9640d74-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/b/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on board an aircraft which is operated by the government of another state;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9640d75-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a perpetrator is found outside the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9640d76-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a perpetrator is a national of another state or a stateless person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9640d77-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a victim is a national of another state or a stateless person;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9640d78-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the offense takes place outside the United States and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9640d79-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a perpetrator is a national of the United States or is a stateless person whose habitual residence is in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9640d7a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a victim is a national of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9640d7b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a perpetrator is found in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9640d7c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense is committed in an attempt to compel the United States to do or abstain from doing any act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9640d7d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense is committed against a state or government facility of the United States, including an embassy or other diplomatic or consular premises of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9640d7e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense is committed on board a vessel flying the flag of the United States or an aircraft which is registered under the laws of the United States at the time the offense is committed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9640d7f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense is committed on board an aircraft which is operated by the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9640d80-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever violates this section shall be punished as provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2332a/a"},"text":"section 2332a(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9640d81-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemptions to Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section does not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9640d82-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities of armed forces during an armed conflict, as those terms are understood under the law of war, which are governed by that law,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9640d83-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities undertaken by military forces of a state in the exercise of their official duties; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9640d84-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offenses committed within the United States, where the alleged offender and the victims are United States citizens and the alleged offender is found in the United States, or where jurisdiction is predicated solely on the nationality of the victims or the alleged offender and the offense has no substantial effect on interstate or foreign commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9640d85-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9640d86-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “serious bodily injury” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1365/g/3"},"text":"section 1365(g)(3) of this title","children":[],"tail":"; "},{"tag":"ref","attrib":{"idref":"fn002191"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002191"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9640d87-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “national of the United States” has the meaning given that term in section 101(a)(22) of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/22"},"text":"8 U.S.C. 1101(a)(22)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9640d88-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “state or government facility” includes any permanent or temporary facility or conveyance that is used or occupied by representatives of a state, members of Government, the legislature or the judiciary or by officials or employees of a state or any other public authority or entity or by employees or officials of an intergovernmental organization in connection with their official duties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9640d89-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “intergovernmental organization” includes international organization (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1116/b/5"},"text":"section 1116(b)(5) of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9640d8a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “infrastructure facility” means any publicly or privately owned facility providing or distributing services for the benefit of the public, such as water, sewage, energy, fuel, or communications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9640d8b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “place of public use” means those parts of any building, land, street, waterway, or other location that are accessible or open to members of the public, whether continuously, periodically, or occasionally, and encompasses any commercial, business, cultural, historical, educational, religious, governmental, entertainment, recreational, or similar place that is so accessible or open to the public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9640d8c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “public transportation system” means all facilities, conveyances, and instrumentalities, whether publicly or privately owned, that are used in or for publicly available services for the transportation of persons or cargo;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9640d8d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/e/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “explosive” has the meaning given in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s844/j"},"text":"section 844(j) of this title","children":[],"tail":" insofar that it is designed, or has the capability, to cause death, serious bodily injury, or substantial material damage;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9640d8e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/e/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “other lethal device” means any weapon or device that is designed or has the capability to cause death, serious bodily injury, or substantial damage to property through the release, dissemination, or impact of toxic chemicals, biological agents, or toxins (as those terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s178"},"text":"section 178 of this title","children":[],"tail":") or radiation or radioactive material;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9640d8f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/e/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “military forces of a state” means the armed forces of a state which are organized, trained, and equipped under its internal law for the primary purpose of national defense or security, and persons acting in support of those armed forces who are under their formal command, control, and responsibility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9640d90-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/e/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “armed conflict” does not include internal disturbances and tensions, such as riots, isolated and sporadic acts of violence, and other acts of a similar nature; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9640d91-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332f/e/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “state” has the same meaning as that term has under international law, and includes all political subdivisions thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9640d92-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/197/tI/s102/a"},"text":"Pub. L. 107–197, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-25"},"text":"June 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/721"},"text":"116 Stat. 721","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9640d93-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9640d94-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9640d95-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1365(g)(3), referred to in subsec. (e)(1), was redesignated section 1365(h)(3) by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/307/s2/1"},"text":"Pub. L. 107–307, § 2(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2445"},"text":"116 Stat. 2445","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9640d96-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9640d97-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/197/tI/s103"},"text":"Pub. L. 107–197, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-25"},"text":"June 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/724"},"text":"116 Stat. 724","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/197/tI/s103"},"text":"“Section 102 [enacting this section and provisions set out as a note below] shall take effect on the date that the International Convention for the Suppression of Terrorist Bombings enters into force for the United States [","children":[{"tag":"date","attrib":{"date":"2002-07-26"},"text":"July 26, 2002","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb9640d98-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Disclaimer","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/197/tI/s102/c"},"text":"Pub. L. 107–197, title I, § 102(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-25"},"text":"June 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/724"},"text":"116 Stat. 724","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/197/tI/s102/c"},"text":"“Nothing contained in this section [enacting this section and provisions set out as a note above] is intended to affect the applicability of any other Federal or State law which might pertain to the underlying conduct.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
