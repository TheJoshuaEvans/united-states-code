{"tag":"section","attrib":{"id":"idb92f90a2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1735"},"text":null,"children":[{"tag":"num","attrib":{"value":"1735"},"text":"§ 1735.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sexually oriented advertisements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb92f90a3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1735/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whoever—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92f90a4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1735/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully uses the mails for the mailing, carriage in the mails, or delivery of any sexually oriented advertisement in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3010"},"text":"section 3010 of title 39","children":[],"tail":", or willfully violates any regulations of the Board of Governors issued under such section; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92f90a5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1735/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sells, leases, rents, lends, exchanges, or licenses the use of, or, except for the purpose expressly authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3010"},"text":"section 3010 of title 39","children":[],"tail":", uses a mailing list maintained by the Board of Governors under such section;"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title or imprisoned not more than five years, or both, for the first offense, and shall be fined under this title or imprisoned not more than ten years, or both, for any second or subsequent offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92f90a6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1735/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this section, the term “sexually oriented advertisement” shall have the same meaning as given it in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3010/d"},"text":"section 3010(d) of title 39","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb93200a7-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375/s6/j/37/A"},"text":"Pub. L. 91–375, § 6(j)(37)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/781"},"text":"84 Stat. 781","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", (L), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb93200a8-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb93200a9-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb93200aa-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":", in concluding provisions, substituted “fined under this title” for “fined not more than $5,000” after “shall be” and for “fined not more than $10,000” after “and shall be”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb93200ab-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb93200ac-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on first day of sixth month which begins after ","children":[{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/b"},"text":"section 15(b) of Pub. L. 91–375","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of Title 39","children":[],"tail":", Postal Service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
