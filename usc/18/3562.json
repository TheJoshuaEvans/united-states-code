{"tag":"section","attrib":{"id":"idb9a92cc9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3562"},"text":null,"children":[{"tag":"num","attrib":{"value":"3562"},"text":"§ 3562.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of a sentence of probation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9a92cca-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3562/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Factors To Be Considered in Imposing a Term of Probation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The court, in determining whether to impose a term of probation, and, if a term of probation is to be imposed, in determining the length of the term and the conditions of probation, shall consider the factors set forth in section 3553(a) to the extent that they are applicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9a92ccb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3562/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of Finality of Judgment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding the fact that a sentence of probation can subsequently be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9a92ccc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3562/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modified or revoked pursuant to the provisions of section 3564 or 3565;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a92ccd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3562/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" corrected pursuant to the provisions of rule 35 of the Federal Rules of Criminal Procedure and section 3742; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a92cce-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3562/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appealed and modified, if outside the guideline range, pursuant to the provisions of section 3742;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"a judgment of conviction that includes such a sentence constitutes a final judgment for all other purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9a92ccf-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s212/a/2"},"text":"Pub. L. 98–473, title II, § 212(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1992"},"text":"98 Stat. 1992","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXV/s3583"},"text":"Pub. L. 101–647, title XXXV, § 3583","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4930"},"text":"104 Stat. 4930","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9a92cd0-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9a92cd1-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9a92cd2-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Criminal Procedure, referred to in subsec. (b)(2), are set out in the Appendix to this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb9a92cd3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For a prior section 3562, applicable to offenses committed prior to ","children":[{"tag":"date","attrib":{"date":"1987-11-01"},"text":"Nov. 1, 1987","children":[],"tail":", see note set out preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3551"},"text":"section 3551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9a92cd4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":" inserted “of the Federal Rules of Criminal Procedure” after “rule 35”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9a92cd5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9a92cd6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1987-11-01"},"text":"Nov. 1, 1987","children":[],"tail":", and applicable only to offenses committed after the taking effect of this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/s235/a/1"},"text":"section 235(a)(1) of Pub. L. 98–473","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3551"},"text":"section 3551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
