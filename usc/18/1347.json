{"tag":"section","attrib":{"id":"idb91c7d2a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1347"},"text":null,"children":[{"tag":"num","attrib":{"value":"1347"},"text":"§ 1347.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care fraud","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb91c7d2b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1347/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whoever knowingly and willfully executes, or attempts to execute, a scheme or artifice—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91c7d2c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1347/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to defraud any health care benefit program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91c7d2d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1347/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain, by means of false or fraudulent pretenses, representations, or promises, any of the money or property owned by, or under the custody or control of, any health care benefit program,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"in connection with the delivery of or payment for health care benefits, items, or services, shall be fined under this title or imprisoned not more than 10 years, or both. If the violation results in serious bodily injury (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1365"},"text":"section 1365 of this title","children":[],"tail":"), such person shall be fined under this title or imprisoned not more than 20 years, or both; and if the violation results in death, such person shall be fined under this title, or imprisoned for any term of years or for life, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91c7d2e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1347/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to violations of this section, a person need not have actual knowledge of this section or specific intent to commit a violation of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb91c7d2f-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/tII/s242/a/1"},"text":"Pub. L. 104–191, title II, § 242(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2016"},"text":"110 Stat. 2016","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10606/b"},"text":"Pub. L. 111–148, title X, § 10606(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1008"},"text":"124 Stat. 1008","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91c7d30-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb91c7d31-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb91c7d32-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
