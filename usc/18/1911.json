{"tag":"section","attrib":{"id":"idb936bbe0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1911"},"text":null,"children":[{"tag":"num","attrib":{"value":"1911"},"text":"§ 1911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receiver mismanaging property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being a receiver, trustee, or manager in possession of any property in any cause pending in any court of the United States, willfully fails to manage and operate such property according to the requirements of the valid laws of the State in which such property shall be situated, in the same manner that the owner or possessor thereof would be bound to do if in possession thereof, shall be fined under this title or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb936bbe1-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/792"},"text":"62 Stat. 792","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/J"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(J)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb936bbe2-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb936bbe3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based upon ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s124"},"text":"section 124 of title 28","children":[],"tail":", U.S.C., 1940 ed., Judicial Code and Judiciary ("},{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s65"},"text":"Mar. 3, 1911, ch. 231, § 65","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1104"},"text":"36 Stat. 1104","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Word “trustee” was inserted after “receiver” so as to make it clear that persons holding such office are included in the enumeration of court officers who are subject to the provisions of this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology and arrangement, but without change of substance or meaning.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Other provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s124"},"text":"section 124 of title 28","children":[],"tail":", U.S.C., 1940 ed., were retained in that title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb936bbe4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb936bbe5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $3,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
