{"tag":"section","attrib":{"id":"idb8cb77e1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s489"},"text":null,"children":[{"tag":"num","attrib":{"value":"489"},"text":"§ 489.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Making or possessing likeness of coins","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, within the United States, makes or brings therein from any foreign country, or possesses with intent to sell, give away, or in any other manner uses the same, except under authority of the Secretary of the Treasury or other proper officer of the United States, any token, disk, or device in the likeness or similitude as to design, color, or the inscription thereon of any of the coins of the United States or of any foreign country issued as money, either under the authority of the United States or under the authority of any foreign government shall be fined under this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8cb77e2-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/709"},"text":"62 Stat. 709","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1951-07-16/ch226/s3"},"text":"July 16, 1951, ch. 226, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/122"},"text":"65 Stat. 122","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/B"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2146"},"text":"108 Stat. 2146","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8cb77e3-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8cb77e4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 285 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s171"},"text":"Mar. 4, 1909, ch. 321, § 171","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1121"},"text":"35 Stat. 1121","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1912-02-15/ch38"},"text":"Feb. 15, 1912, ch. 38","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/64"},"text":"37 Stat. 64","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to persons causing or procuring was omitted as unnecessary in view of definition of “principal” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8cb77e5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8cb77e6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $100”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1951—Act ","children":[{"tag":"date","attrib":{"date":"1951-07-16"},"text":"July 16, 1951","children":[],"tail":", struck out “publisher’s illustrations excepted” in section catchline, struck out from text all language which could be interpreted to prohibit or restrict the making and printing of coin illustrations in magazines and other publications, and gave the Secretary of the Treasury the authority to make exceptions to the application of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
