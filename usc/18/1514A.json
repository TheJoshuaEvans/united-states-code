{"tag":"section","attrib":{"id":"idb9261a0c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1514A"},"text":null,"children":[{"tag":"num","attrib":{"value":"1514A"},"text":"§ 1514A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil action to protect against retaliation in fraud cases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9261a0d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1514A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Whistleblower Protection for Employees of Publicly Traded Companies","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No company with a class of securities registered under section 12 of the Securities Exchange Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78"},"text":"15 U.S.C. 78","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), or that is required to file reports under section 15(d) of the Securities Exchange Act of 1934 ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78"},"text":"15 U.S.C. 78","children":[],"tail":null},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(d)) including any subsidiary or affiliate whose financial information is included in the consolidated financial statements of such company, or nationally recognized statistical rating organization (as defined in section 3(a) of the Securities Exchange Act of 1934 ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c"},"text":"15 U.S.C. 78c","children":[],"tail":"),"},{"tag":"ref","attrib":{"idref":"fn002117"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002117"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Another closing parenthesis probably should precede the comma."}],"tail":" or any officer, employee, contractor, subcontractor, or agent of such company or nationally recognized statistical rating organization, may discharge, demote, suspend, threaten, harass, or in any other manner discriminate against an employee in the terms and conditions of employment because of any lawful act done by the employee—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9261a0e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1514A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to provide information, cause information to be provided, or otherwise assist in an investigation regarding any conduct which the employee reasonably believes constitutes a violation of section 1341, 1343, 1344, or 1348, any rule or regulation of the Securities and Exchange Commission, or any provision of Federal law relating to fraud against shareholders, when the information or assistance is provided to or the investigation is conducted by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9261a0f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1514A/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal regulatory or law enforcement agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9261a10-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1514A/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Member of Congress or any committee of Congress; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9261a11-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1514A/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person with supervisory authority over the employee (or such other person working for the employer who has the authority to investigate, discover, or terminate misconduct); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9261a12-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1514A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to file, cause to be filed, testify, participate in, or otherwise assist in a proceeding filed or about to be filed (with any knowledge of the employer) relating to an alleged violation of section 1341, 1343, 1344, or 1348, any rule or regulation of the Securities and Exchange Commission, or any provision of Federal law relating to fraud against shareholders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9261a13-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1514A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enforcement Action.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9261a14-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1514A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person who alleges discharge or other discrimination by any person in violation of subsection (a) may seek relief under subsection (c), by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9261a15-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1514A/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" filing a complaint with the Secretary of Labor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9261a16-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1514A/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary has not issued a final decision within 180 days of the filing of the complaint and there is no showing that such delay is due to the bad faith of the claimant, bringing an action at law or equity for de novo review in the appropriate district court of the United States, which shall have jurisdiction over such an action without regard to the amount in controversy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9261a17-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1514A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedure.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9261a18-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1514A/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An action under paragraph (1)(A) shall be governed under the rules and procedures set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s42121/b"},"text":"section 42121(b) of title 49","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9261a19-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1514A/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notification made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s42121/b/1"},"text":"section 42121(b)(1) of title 49","children":[],"tail":", United States Code, shall be made to the person named in the complaint and to the employer."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9261a1a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1514A/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Burdens of proof","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An action brought under paragraph (1)(B) shall be governed by the legal burdens of proof set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s42121/b"},"text":"section 42121(b) of title 49","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9261a1b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1514A/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statute of limitations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An action under paragraph (1) shall be commenced not later than 180 days after the date on which the violation occurs, or after the date on which the employee became aware of the violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9261a1c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1514A/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Jury trial","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A party to an action brought under paragraph (1)(B) shall be entitled to trial by jury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9261a1d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1514A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remedies.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9261a1e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1514A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An employee prevailing in any action under subsection (b)(1) shall be entitled to all relief necessary to make the employee whole.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9261a1f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1514A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensatory damages","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Relief for any action under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9261a20-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1514A/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reinstatement with the same seniority status that the employee would have had, but for the discrimination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9261a21-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1514A/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of back pay, with interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9261a22-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1514A/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compensation for any special damages sustained as a result of the discrimination, including litigation costs, expert witness fees, and reasonable attorney fees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9261a23-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1514A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rights Retained by Employee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be deemed to diminish the rights, privileges, or remedies of any employee under any Federal or State law, or under any collective bargaining agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9261a24-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1514A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonenforceability of Certain Provisions Waiving Rights and Remedies or Requiring Arbitration of Disputes.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9261a25-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1514A/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver of rights and remedies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The rights and remedies provided for in this section may not be waived by any agreement, policy form, or condition of employment, including by a predispute arbitration agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9261a26-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1514A/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Predispute arbitration agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No predispute arbitration agreement shall be valid or enforceable, if the agreement requires arbitration of a dispute arising under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9261a27-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204/tVIII/s806/a"},"text":"Pub. L. 107–204, title VIII, § 806(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/802"},"text":"116 Stat. 802","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIX"},"text":"Pub. L. 111–203, title IX","children":[],"tail":", §§ 922(b), (c), 929A, "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1848"},"text":"124 Stat. 1848","children":[],"tail":", 1852.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9261a28-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9261a29-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9261a2a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s929A"},"text":"Pub. L. 111–203, § 929A","children":[],"tail":", in introductory provisions, inserted “including any subsidiary or affiliate whose financial information is included in the consolidated financial statements of such company” after “the Securities Exchange Act of 1934 ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78"},"text":"15 U.S.C. 78","children":[],"tail":null},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(d))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s922/b"},"text":"Pub. L. 111–203, § 922(b)","children":[],"tail":", in introductory provisions, inserted “or nationally recognized statistical rating organization (as defined in section 3(a) of the Securities Exchange Act of 1934 ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c"},"text":"15 U.S.C. 78c","children":[],"tail":"),” before “or any officer,” and “or nationally recognized statistical rating organization” before “, may discharge,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s922/c/1/A"},"text":"Pub. L. 111–203, § 922(c)(1)(A)","children":[],"tail":", substituted “180” for “90” and inserted “, or after the date on which the employee became aware of the violation” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s922/c/1/B"},"text":"Pub. L. 111–203, § 922(c)(1)(B)","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s922/c/2"},"text":"Pub. L. 111–203, § 922(c)(2)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9261a2b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb9261a2c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective 1 day after "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s4"},"text":"section 4 of Pub. L. 111–203","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
