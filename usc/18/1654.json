{"tag":"section","attrib":{"id":"idb92ad5bc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1654"},"text":null,"children":[{"tag":"num","attrib":{"value":"1654"},"text":"§ 1654.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arming or serving on privateers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being a citizen of the United States, without the limits thereof, fits out and arms, or attempts to fit out and arm or is concerned in furnishing, fitting out, or arming any private vessel of war or privateer, with intent that such vessel shall be employed to cruise or commit hostilities upon the citizens of the United States or their property; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever takes the command of or enters on board of any such vessel with such intent; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever purchases any interest in any such vessel with a view to share in the profits thereof—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Shall be fined under this title or imprisoned not more than ten years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb92ad5bd-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/774"},"text":"62 Stat. 774","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/L"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(L)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92ad5be-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb92ad5bf-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 494 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s303"},"text":"Mar. 4, 1909, ch. 321, § 303","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1147"},"text":"35 Stat. 1147","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to persons procuring or aiding was omitted as unnecessary in view of definition of “principal” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Mandatory punishment provisions were rephrased in the alternative.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The last sentence relating to venue was omitted as unnecessary in view of the general provision to the same effect in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3238"},"text":"section 3238 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology and arrangement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92ad5c0-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92ad5c1-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $10,000” in last par."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
