{"tag":"section","attrib":{"id":"idb92ad532-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1592"},"text":null,"children":[{"tag":"num","attrib":{"value":"1592"},"text":"§ 1592.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful conduct with respect to documents in furtherance of trafficking, peonage, slavery, involuntary servitude, or forced labor","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb92ad533-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1592/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whoever knowingly destroys, conceals, removes, confiscates, or possesses any actual or purported passport or other immigration document, or any other actual or purported government identification document, of another person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92ad534-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1592/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the course of a violation of section 1581, 1583, 1584, 1589, 1590, 1591, or 1594(a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92ad535-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1592/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with intent to violate section 1581, 1583, 1584, 1589, 1590, or 1591; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92ad536-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1592/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent or restrict or to attempt to prevent or restrict, without lawful authority, the person’s liberty to move or travel, in order to maintain the labor or services of that person, when the person is or has been a victim of a severe form of trafficking in persons, as defined in section 103 of the Trafficking Victims Protection Act of 2000,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title or imprisoned for not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92ad537-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1592/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) does not apply to the conduct of a person who is or has been a victim of a severe form of trafficking in persons, as defined in section 103 of the Trafficking Victims Protection Act of 2000, if that conduct is caused by, or incident to, that trafficking.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92ad538-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1592/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever obstructs, attempts to obstruct, or in any way interferes with or prevents the enforcement of this section, shall be subject to the penalties described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb92ad539-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386/dA/s112/a/2"},"text":"Pub. L. 106–386, div. A, § 112(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1488"},"text":"114 Stat. 1488","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/457/tII/s222/b/6"},"text":"Pub. L. 110–457, title II, § 222(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-12-23"},"text":"Dec. 23, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/5070"},"text":"122 Stat. 5070","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92ad53a-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92ad53b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb92ad53c-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 103 of the Trafficking Victims Protection Act of 2000, referred to in subsecs. (a)(3) and (b), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102"},"text":"section 7102 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92ad53d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/457"},"text":"Pub. L. 110–457","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
