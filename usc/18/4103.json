{"tag":"section","attrib":{"id":"idb9c8272a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4103"},"text":null,"children":[{"tag":"num","attrib":{"value":"4103"},"text":"§ 4103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of United States laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All laws of the United States, as appropriate, pertaining to prisoners, probationers, parolees, and juvenile offenders shall be applicable to offenders transferred to the United States, unless a treaty or this chapter provides otherwise.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9c8272b-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/144/s1"},"text":"Pub. L. 95–144, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-28"},"text":"Oct. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1215"},"text":"91 Stat. 1215","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
