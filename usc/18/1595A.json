{"tag":"section","attrib":{"id":"idb92ad572-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1595A"},"text":null,"children":[{"tag":"num","attrib":{"value":"1595A"},"text":"§ 1595A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil injunctions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb92ad573-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1595A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whenever it shall appear that any person is engaged or is about to engage in any act that constitutes or will constitute a violation of this chapter, chapter 110, or chapter 117, or a conspiracy under section 371 to commit a violation of this chapter, chapter 110, or chapter 117, the Attorney General may bring a civil action in a district court of the United States seeking an order to enjoin such act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92ad574-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1595A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Action by Court","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The court shall proceed as soon as practicable to the hearing and determination of a civil action brought under subsection (a), and may, at any time before final determination, enter such a restraining order or prohibition, or take such other action, as is warranted to prevent a continuing and substantial injury to the United States or to any person or class of persons for whose protection the civil action is brought.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92ad575-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1595A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedure.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92ad576-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1595A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A proceeding under this section shall be governed by the Federal Rules of Civil Procedure, except that, if an indictment has been returned against the respondent, discovery shall be governed by the Federal Rules of Criminal Procedure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92ad577-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1595A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sealed proceedings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a civil action is brought under subsection (a) before an indictment is returned against the respondent or while an indictment against the respondent is under seal—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb92ad578-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1595A/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the court shall place the civil action under seal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb92ad579-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1595A/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when the indictment is unsealed, the court shall unseal the civil action unless good cause exists to keep the civil action under seal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92ad57a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1595A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed or applied so as to abridge the exercise of rights guaranteed under the First Amendment to the Constitution of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb92ad57b-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/393/tII/s201/a"},"text":"Pub. L. 115–393, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5266"},"text":"132 Stat. 5266","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92ad57c-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92ad57d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb92ad57e-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Civil Procedure, referred to in subsec. (c)(1), are set out in the Appendix to Title 28, Judiciary and Judicial Procedure.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Rules of Criminal Procedure, referred to in subsec. (c)(1), are set out in the Appendix to this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
