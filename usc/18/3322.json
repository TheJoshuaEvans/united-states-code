{"tag":"section","attrib":{"id":"idb99ad4fe-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3322"},"text":null,"children":[{"tag":"num","attrib":{"value":"3322"},"text":"§ 3322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of certain matters occurring before grand jury","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb99ad4ff-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3322/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person who is privy to grand jury information—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb99ad500-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3322/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" received in the course of duty as an attorney for the government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb99ad501-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3322/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disclosed under rule 6(e)(3)(A)(ii) of the Federal Rules of Criminal Procedure;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"may disclose that information to an attorney for the government for use in enforcing section 951 of the Financial Institutions Reform, Recovery and Enforcement Act of 1989 or for use in connection with any civil forfeiture provision of Federal law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb99ad502-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3322/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb99ad503-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3322/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Upon motion of an attorney for the government, a court may direct disclosure of matters occurring before a grand jury during an investigation of a banking law violation to identified personnel of a Federal or State financial institution regulatory agency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb99ad504-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3322/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for use in relation to any matter within the jurisdiction of such regulatory agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb99ad505-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3322/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist an attorney for the government to whom matters have been disclosed under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb99ad506-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3322/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A court may issue an order under paragraph (1) at any time during or after the completion of the investigation of the grand jury, upon a finding of a substantial need.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb99ad507-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3322/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person to whom matter has been disclosed under this section shall not use such matter other than for the purpose for which such disclosure was authorized.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb99ad508-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3322/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb99ad509-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3322/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “banking law violation” means a violation of, or a conspiracy to violate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb99ad50a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3322/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 215, 656, 657, 1005, 1006, 1007, 1014, 1344, 1956, or 1957;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb99ad50b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3322/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 1341 or 1343 affecting a financial institution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb99ad50c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3322/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any provision of subchapter II of chapter 53 of title 31, United States Code;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb99ad50d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3322/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “attorney for the government” has the meaning given such term in the Federal Rules of Criminal Procedure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb99ad50e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3322/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “grand jury information” means matters occurring before a grand jury other than the deliberations of the grand jury or the vote of any grand juror.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb99ad50f-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/tIX/s964/a"},"text":"Pub. L. 101–73, title IX, § 964(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/505"},"text":"103 Stat. 505","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/tVII/s740"},"text":"Pub. L. 106–102, title VII, § 740","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1480"},"text":"113 Stat. 1480","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/185/s10"},"text":"Pub. L. 106–185, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-25"},"text":"Apr. 25, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/217"},"text":"114 Stat. 217","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tI/s11002"},"text":"Pub. L. 107–273, div. C, title I, § 11002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1816"},"text":"116 Stat. 1816","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb99ad510-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb99ad511-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb99ad512-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 951 of the Financial Institutions Reform, Recovery and Enforcement Act of 1989, referred to in subsec. (a), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1833a"},"text":"section 1833a of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Rules of Criminal Procedure, referred to in subsecs. (a)(2) and (d)(2), are set out in the Appendix to this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb99ad513-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3322, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"act June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/829"},"text":"62 Stat. 829","children":[],"tail":", related to the summoning of and number of grand jurors, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/s964/a"},"text":"Pub. L. 101–73, § 964(a)","children":[],"tail":". See Rule 6(a) of the Federal Rules of Criminal Procedure, set out in the Appendix to this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb99ad514-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s11002/1"},"text":"Pub. L. 107–273, § 11002(1)","children":[],"tail":", substituted “1344, 1956, or 1957;” for “or 1344; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s11002/2"},"text":"Pub. L. 107–273, § 11002(2)","children":[],"tail":", (3), added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/185"},"text":"Pub. L. 106–185","children":[],"tail":" struck out “concerning a banking law violation” after “grand jury information” in introductory provisions and substituted “any civil forfeiture provision of Federal law” for “civil forfeiture under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s981"},"text":"section 981 of title 18","children":[],"tail":", United States Code, of property described in section 981(a)(1)(C) of such title” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102/s740/1"},"text":"Pub. L. 106–102, § 740(1)","children":[],"tail":", inserted “Federal or State” before “financial institution” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102/s740/2"},"text":"Pub. L. 106–102, § 740(2)","children":[],"tail":", inserted “at any time during or after the completion of the investigation of the grand jury,” after “paragraph (1)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb99ad515-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb99ad516-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/185"},"text":"Pub. L. 106–185","children":[],"tail":" applicable to any forfeiture proceeding commenced on or after the date that is 120 days after "},{"tag":"date","attrib":{"date":"2000-04-25"},"text":"Apr. 25, 2000","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/185/s21"},"text":"section 21 of Pub. L. 106–185","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1324"},"text":"section 1324 of Title 8","children":[],"tail":", Aliens and Nationality."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
