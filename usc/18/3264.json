{"tag":"section","attrib":{"id":"idb9988b06-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3264"},"text":null,"children":[{"tag":"num","attrib":{"value":"3264"},"text":"§ 3264.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on removal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9988b07-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3264/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subsection (b), and except for a person delivered to authorities of a foreign country under section 3263, a person arrested for or charged with a violation of section 3261(a) shall not be removed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9988b08-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3264/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9988b09-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3264/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any foreign country other than a country in which such person is believed to have violated section 3261(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9988b0a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3264/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The limitation in subsection (a) does not apply if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9988b0b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3264/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal magistrate judge orders the person to be removed to the United States to be present at a detention hearing held pursuant to section 3142(f);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9988b0c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3264/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal magistrate judge orders the detention of the person before trial pursuant to section 3142(e), in which case the person shall be promptly removed to the United States for purposes of such detention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9988b0d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3264/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person is entitled to, and does not waive, a preliminary examination under the Federal Rules of Criminal Procedure, in which case the person shall be removed to the United States in time for such examination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9988b0e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3264/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal magistrate judge otherwise orders the person to be removed to the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9988b0f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3264/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense determines that military necessity requires that the limitations in subsection (a) be waived, in which case the person shall be removed to the nearest United States military installation outside the United States adequate to detain the person and to facilitate the initial appearance described in section 3265(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9988b10-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/523/s2/a"},"text":"Pub. L. 106–523, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2489"},"text":"114 Stat. 2489","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9988b11-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9988b12-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9988b13-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Criminal Procedure, referred to in subsec. (b)(3), are set out in the Appendix to this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
