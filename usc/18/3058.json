{"tag":"section","attrib":{"id":"idb987c2a3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3058"},"text":null,"children":[{"tag":"num","attrib":{"value":"3058"},"text":"§ 3058.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interned belligerent nationals","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, belonging to the armed land or naval forces of a belligerent nation or belligerent faction and being interned in the United States, in accordance with the law of nations, leaves or attempts to leave said jurisdiction, or leaves or attempts to leave the limits of internment without permission from the proper official of the United States in charge, or willfully overstays a leave of absence granted by such official, shall be subject to arrest by any marshal or deputy marshal of the United States, or by the military or naval authorities thereof, and shall be returned to the place of internment and there confined and safely kept for such period of time as the official of the United States in charge shall direct.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb987c2a4-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/818"},"text":"62 Stat. 818","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXV/s3571"},"text":"Pub. L. 101–647, title XXXV, § 3571","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4928"},"text":"104 Stat. 4928","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb987c2a5-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb987c2a6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 37 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-06-15/ch30"},"text":"June 15, 1917, ch. 30","children":[],"tail":", title V, § 7, "},{"tag":"ref","attrib":{"href":"/us/stat/40/223"},"text":"40 Stat. 223","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Said section 37 was incorporated in this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s756"},"text":"section 756 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor verbal changes were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb987c2a7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb987c2a8-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":" substituted “belligerent” for “beligerent” before “nation”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
