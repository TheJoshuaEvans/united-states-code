{"tag":"section","attrib":{"id":"idb96b3978-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2344"},"text":null,"children":[{"tag":"num","attrib":{"value":"2344"},"text":"§ 2344.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb96b3979-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2344/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever knowingly violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2342/a"},"text":"section 2342(a) of this title","children":[],"tail":" shall be fined under this title or imprisoned not more than five years, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96b397a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2344/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever knowingly violates any rule or regulation promulgated under section 2343(a) or 2346 of this title or violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2342/b"},"text":"section 2342(b) of this title","children":[],"tail":" shall be fined under this title or imprisoned not more than three years, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96b397b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2344/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any contraband cigarettes or contraband smokeless tobacco involved in any violation of the provisions of this chapter shall be subject to seizure and forfeiture. The provisions of chapter 46 of title 18 relating to civil forfeitures shall extend to any seizure or civil forfeiture under this section. Any cigarettes or smokeless tobacco so seized and forfeited shall be either—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96b397c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2344/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" destroyed and not resold; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96b397d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2344/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used for undercover investigative operations for the detection and prosecution of crimes, and then destroyed and not resold.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb96b397e-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/575/s1"},"text":"Pub. L. 95–575, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-02"},"text":"Nov. 2, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2464"},"text":"92 Stat. 2464","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", (S), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":", 2148; "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/tI/s121/b/4"},"text":"Pub. L. 109–177, title I, § 121(b)(4)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/222"},"text":"120 Stat. 222","children":[],"tail":", 223.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb96b397f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb96b3980-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb96b3981-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177"},"text":"Pub. L. 109–177","children":[],"tail":" inserted “or contraband smokeless tobacco” after “contraband cigarettes”, substituted “seizure and forfeiture. The provisions of chapter 46 of title 18 relating to civil forfeitures shall extend to any seizure or civil forfeiture under this section. Any cigarettes or smokeless tobacco so seized and forfeited shall be either—” for “seizure and forfeiture, and all provisions of the Internal Revenue Code of 1986 relating to the seizure, forfeiture, and disposition of firearms, as defined in section 5845(a) of such Code, shall, so far as applicable, extend to seizures and forfeitures under the provisions of this chapter.”, and added pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/1/S"},"text":"Pub. L. 103–322, § 330016(1)(S)","children":[],"tail":", substituted “fined under this title” for “fined not more than $100,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/1/K"},"text":"Pub. L. 103–322, § 330016(1)(K)","children":[],"tail":", substituted “fined under this title” for “fined not more than $5,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
