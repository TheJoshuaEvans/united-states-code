{"tag":"section","attrib":{"id":"idb95a70f5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2284"},"text":null,"children":[{"tag":"num","attrib":{"value":"2284"},"text":"§ 2284.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation of terrorists","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb95a70f6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2284/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever knowingly and intentionally transports any terrorist aboard any vessel within the United States and on waters subject to the jurisdiction of the United States or any vessel outside the United States and on the high seas or having United States nationality, knowing that the transported person is a terrorist, shall be fined under this title or imprisoned for any term of years or for life, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95a70f7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2284/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defined Term","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “terrorist” means any person who intends to commit, or is avoiding apprehension after having committed, an offense listed under section 2332b(g)(5)(B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb95a70f8-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/tIII/s305/a"},"text":"Pub. L. 109–177, title III, § 305(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/237"},"text":"120 Stat. 237","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
