{"tag":"section","attrib":{"id":"idb92d1f4b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1706"},"text":null,"children":[{"tag":"num","attrib":{"value":"1706"},"text":"§ 1706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injury to mail bags","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever tears, cuts, or otherwise injures any mail bag, pouch, or other thing used or designed for use in the conveyance of the mail, or draws or breaks any staple or loosens any part of any lock, chain, or strap attached thereto, with intent to rob or steal any such mail, or to render the same insecure, shall be fined under this title or imprisoned not more than three years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb92d1f4c-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/779"},"text":"62 Stat. 779","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92d1f4d-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb92d1f4e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 312 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s189"},"text":"Mar. 4, 1909, ch. 321, § 189","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1124"},"text":"35 Stat. 1124","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A fine of “$1,000” was substituted for “$500” thus increasing the maximum to correspond with other comparable sections. (See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1705"},"text":"section 1705 of this title","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor verbal changes were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92d1f4f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92d1f50-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $1,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
