{"tag":"section","attrib":{"id":"idb9213840-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1504"},"text":null,"children":[{"tag":"num","attrib":{"value":"1504"},"text":"§ 1504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Influencing juror by writing","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever attempts to influence the action or decision of any grand or petit juror of any court of the United States upon any issue or matter pending before such juror, or before the jury of which he is a member, or pertaining to his duties, by writing or sending to him any written communication, in relation to such issue or matter, shall be fined under this title or imprisoned not more than six months, or both.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to prohibit the communication of a request to appear before the grand jury.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9213841-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/770"},"text":"62 Stat. 770","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9213842-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9213843-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 243 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s137"},"text":"Mar. 4, 1909, ch. 321, § 137","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1113"},"text":"35 Stat. 1113","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Last paragraph was added to remove the possibility that a proper request to appear before a grand jury might be construed as a technical violation of this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9213844-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9213845-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $1,000” in first par."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
