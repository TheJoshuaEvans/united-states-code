{"tag":"section","attrib":{"id":"idb92ad5d2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1658"},"text":null,"children":[{"tag":"num","attrib":{"value":"1658"},"text":"§ 1658.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plunder of distressed vessel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb92ad5d3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1658/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever plunders, steals, or destroys any money, goods, merchandise, or other effects from or belonging to any vessel in distress, or wrecked, lost, stranded, or cast away, upon the sea, or upon any reef, shoal, bank, or rocks of the sea, or in any other place within the admiralty and maritime jurisdiction of the United States, shall be fined under this title or imprisoned not more than ten years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92ad5d4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1658/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever willfully obstructs the escape of any person endeavoring to save his life from such vessel, or the wreck thereof; or","children":[{"tag":"p","attrib":{},"text":"Whoever holds out or shows any false light, or extinguishes any true light, with intent to bring any vessel sailing upon the sea into danger or distress or shipwreck—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Shall be imprisoned not less than ten years and may be imprisoned for life.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb92ad5d5-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/775"},"text":"62 Stat. 775","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92ad5d6-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb92ad5d7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 488 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s297"},"text":"Mar. 4, 1909, ch. 321, § 297","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1146"},"text":"35 Stat. 1146","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Mandatory punishment provision in subsection (a) was rephrased in the alternative.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92ad5d8-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92ad5d9-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $5,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
