{"tag":"section","attrib":{"id":"idb9988b52-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3272"},"text":null,"children":[{"tag":"num","attrib":{"value":"3272"},"text":"§ 3272.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9988b53-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3272/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “employed by the Federal Government outside the United States” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9988b54-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3272/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employed as a civilian employee of the Federal Government, as a Federal contractor (including a subcontractor at any tier), or as an employee of a Federal contractor (including a subcontractor at any tier);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9988b55-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3272/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" present or residing outside the United States in connection with such employment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9988b56-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3272/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not a national of or ordinarily resident in the host nation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9988b57-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3272/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “accompanying the Federal Government outside the United States” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9988b58-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3272/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a dependant of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9988b59-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3272/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a civilian employee of the Federal Government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9988b5a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3272/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal contractor (including a subcontractor at any tier) or an employee of a Federal contractor (including a subcontractor at any tier);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9988b5b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3272/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" residing with such civilian employee, contractor, or contractor employee outside the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9988b5c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3272/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not a national of or ordinarily resident in the host nation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9988b5d-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/164/tI/s103/a/1"},"text":"Pub. L. 109–164, title I, § 103(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-10"},"text":"Jan. 10, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3562"},"text":"119 Stat. 3562","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
