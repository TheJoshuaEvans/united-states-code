{"tag":"section","attrib":{"id":"idb955b598-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2264"},"text":null,"children":[{"tag":"num","attrib":{"value":"2264"},"text":"§ 2264.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restitution","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb955b599-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2264/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 3663 or 3663A, and in addition to any other civil or criminal penalty authorized by law, the court shall order restitution for any offense under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb955b59a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2264/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope and Nature of Order.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb955b59b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2264/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Directions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The order of restitution under this section shall direct the defendant to pay the victim (through the appropriate court mechanism) the full amount of the victim’s losses as determined by the court pursuant to paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb955b59c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2264/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enforcement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An order of restitution under this section shall be issued and enforced in accordance with section 3664 in the same manner as an order under section 3663A.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb955b59d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2264/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “full amount of the victim’s losses” includes any costs incurred by the victim for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb955b59e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2264/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical services relating to physical, psychiatric, or psychological care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb955b59f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2264/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical and occupational therapy or rehabilitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb955b5a0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2264/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary transportation, temporary housing, and child care expenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb955b5a1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2264/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lost income;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb955b5a2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2264/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attorneys’ fees, plus any costs incurred in obtaining a civil protection order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb955b5a3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2264/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veterinary services relating to physical care for the victim’s pet, service animal, emotional support animal, or horse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb955b5a4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2264/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other losses suffered by the victim as a proximate result of the offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb955b5a5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2264/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Order mandatory","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb955b5a6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2264/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The issuance of a restitution order under this section is mandatory.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb955b5a7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2264/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A court may not decline to issue an order under this section because of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb955b5a8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2264/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economic circumstances of the defendant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb955b5a9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2264/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fact that a victim has, or is entitled to, receive compensation for his or her injuries from the proceeds of insurance or any other source.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb955b5aa-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2264/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Victim Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, the term “victim” means the individual harmed as a result of a commission of a crime under this chapter, including, in the case of a victim who is under 18 years of age, incompetent, incapacitated, or deceased, the legal guardian of the victim or representative of the victim’s estate, another family member, or any other person appointed as suitable by the court, but in no event shall the defendant be named as such representative or guardian.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb955b5ab-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s40221/a"},"text":"Pub. L. 103–322, title IV, § 40221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1928"},"text":"108 Stat. 1928","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tII/s205/d"},"text":"Pub. L. 104–132, title II, § 205(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1231"},"text":"110 Stat. 1231","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12502/a/3"},"text":"Pub. L. 115–334, title XII, § 12502(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4983"},"text":"132 Stat. 4983","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb955b5ac-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb955b5ad-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb955b5ae-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(3)(F), (G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" added subpar. (F) and redesignated former subpar. (F) as (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s205/d/1"},"text":"Pub. L. 104–132, § 205(d)(1)","children":[],"tail":", inserted “or 3663A” after “3663”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s205/d/2/A"},"text":"Pub. L. 104–132, § 205(d)(2)(A)","children":[],"tail":", reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “The order of restitution under this section shall direct that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the defendant pay to the victim (through the appropriate court mechanism) the full amount of the victim’s losses as determined by the court, pursuant to paragraph (3); and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the United States Attorney enforce the restitution order by all available and reasonable means.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s205/d/2/B"},"text":"Pub. L. 104–132, § 205(d)(2)(B)","children":[],"tail":", struck out “by victim” after “Enforcement” in heading and amended text generally. Prior to amendment, text read as follows: “An order of restitution also may be enforced by a victim named in the order to receive the restitution in the same manner as a judgment in a civil action.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(C), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s205/d/2/C"},"text":"Pub. L. 104–132, § 205(d)(2)(C)","children":[],"tail":", struck out subpars. (C) and (D), which related to court’s consideration of economic circumstances of defendant in determining schedule of payment of restitution orders, and court’s entry of nominal restitution awards where economic circumstances of defendant do not allow for payment of restitution, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5) to (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s205/d/2/D"},"text":"Pub. L. 104–132, § 205(d)(2)(D)","children":[],"tail":", struck out pars. (5) to (10), which related, respectively, to more than 1 offender, more than 1 victim, payment schedule, setoff, effect on other sources of compensation, and condition of probation or supervised release."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s205/d/3"},"text":"Pub. L. 104–132, § 205(d)(3)","children":[],"tail":", (4), added subsec. (c) and struck out former subsec. (c) which read as follows: “"},{"tag":"inline","attrib":{},"text":"Affidavit","children":[],"tail":".—Within 60 days after conviction and, in any event, not later than 10 days before sentencing, the United States Attorney (or such Attorney’s delegate), after consulting with the victim, shall prepare and file an affidavit with the court listing the amounts subject to restitution under this section. The affidavit shall be signed by the United States Attorney (or the delegate) and the victim. Should the victim object to any of the information included in the affidavit, the United States Attorney (or the delegate) shall advise the victim that the victim may file a separate affidavit and assist the victim in the preparation of the affidavit.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s205/d/3"},"text":"Pub. L. 104–132, § 205(d)(3)","children":[],"tail":", struck out subsecs. (d) to (g), which related, respectively, to objection, additional documentation and testimony, final determination of losses, and restitution in addition to punishment."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb955b5af-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb955b5b0-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132"},"text":"Pub. L. 104–132","children":[],"tail":" effective, to extent constitutionally permissible, for sentencing proceedings in cases in which defendant is convicted on or after "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/s211"},"text":"section 211 of Pub. L. 104–132","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2248"},"text":"section 2248 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
