{"tag":"section","attrib":{"id":"idb942a322-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2073"},"text":null,"children":[{"tag":"num","attrib":{"value":"2073"},"text":"§ 2073.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False entries and reports of moneys or securities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being an officer, clerk, agent, or other employee of the United States or any of its agencies, charged with the duty of keeping accounts or records of any kind, with intent to deceive, mislead, injure, or defraud, makes in any such account or record any false or fictitious entry or record of any matter relating to or connected with his duties; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever, being an officer, clerk, agent, or other employee of the United States or any of its agencies, charged with the duty of receiving, holding, or paying over moneys or securities to, for, or on behalf of the United States, or of receiving or holding in trust for any person any moneys or securities, with like intent, makes a false report of such moneys or securities—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Shall be fined under this title or imprisoned not more than ten years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb942a323-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/795"},"text":"62 Stat. 795","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb942a324-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb942a325-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 189 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-04/ch270"},"text":"Mar. 4, 1911, ch. 270","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1355"},"text":"36 Stat. 1355","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “or any of its agencies” were inserted after “United States” so as to eliminate any possible ambiguity as to scope of section. (See definitive ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s6"},"text":"section 6 of this title","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"References to persons aiding and abetting were omitted. Such persons are principals under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor verbal changes were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb942a326-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb942a327-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $5,000” in last par."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
