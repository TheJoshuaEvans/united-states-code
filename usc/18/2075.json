{"tag":"section","attrib":{"id":"idb942a331-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2075"},"text":null,"children":[{"tag":"num","attrib":{"value":"2075"},"text":"§ 2075.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officer failing to make returns or reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every officer who neglects or refuses to make any return or report which he is required to make at stated times by any Act of Congress or regulation of the Department of the Treasury, other than his accounts, within the time prescribed by such Act or regulation, shall be fined under this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb942a332-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/796"},"text":"62 Stat. 796","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dB/tIV/s4002/d/1/C/ii"},"text":"Pub. L. 107–273, div. B, title IV, § 4002(d)(1)(C)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1809"},"text":"116 Stat. 1809","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb942a333-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb942a334-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 188, (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s101"},"text":"Mar. 4, 1909, ch. 321, § 101","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1107"},"text":"35 Stat. 1107","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb942a335-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb942a336-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" substituted “under this title” for “not more than $1,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
