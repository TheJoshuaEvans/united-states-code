{"tag":"section","attrib":{"id":"idb8cb7799-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s477"},"text":null,"children":[{"tag":"num","attrib":{"value":"477"},"text":"§ 477.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Possessing or selling impressions of tools used for obligations or securities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, with intent to defraud, possesses, keeps, safeguards, or controls, without authority from the United States, any imprint, stamp, analog, digital, or electronic image, or impression, taken or made upon any substance or material whatsoever, of any tool, implement, instrument or thing, used, fitted or intended to be used, for any of the purposes mentioned in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s476"},"text":"section 476 of this title","children":[],"tail":"; or"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever, with intent to defraud, sells, gives, or delivers any such imprint, stamp, analog, digital, or electronic image, or impression to any other person—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Shall be fined under this title or imprisoned not more than 25 years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8cb779a-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/707"},"text":"62 Stat. 707","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tIII/s374/g"},"text":"Pub. L. 107–56, title III, § 374(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/341"},"text":"115 Stat. 341","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8cb779b-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8cb779c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 267 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s153"},"text":"Mar. 4, 1909, ch. 321, § 153","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1117"},"text":"35 Stat. 1117","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8cb779d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8cb779e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56"},"text":"Pub. L. 107–56","children":[],"tail":" inserted “analog, digital, or electronic image,” after “imprint, stamp,” in first and second pars. and substituted “25 years” for “ten years” in third par."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $5,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
