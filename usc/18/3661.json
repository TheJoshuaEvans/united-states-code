{"tag":"section","attrib":{"id":"idb9b9cef3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3661"},"text":null,"children":[{"tag":"num","attrib":{"value":"3661"},"text":"§ 3661.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of information for sentencing","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No limitation shall be placed on the information concerning the background, character, and conduct of a person convicted of an offense which a court of the United States may receive and consider for the purpose of imposing an appropriate sentence.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9b9cef4-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/452/tX/s1001/a"},"text":"Pub. L. 91–452, title X, § 1001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-15"},"text":"Oct. 15, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/951"},"text":"84 Stat. 951","children":[],"tail":", § 3577; renumbered § 3661, "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s212/a/1"},"text":"Pub. L. 98–473, title II, § 212(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1987"},"text":"98 Stat. 1987","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9b9cef5-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9b9cef6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb9b9cef7-47c