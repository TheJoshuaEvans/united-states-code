{"tag":"section","attrib":{"id":"idb8aec7c3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s151"},"text":null,"children":[{"tag":"num","attrib":{"value":"151"},"text":"§ 151.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As used in this chapter, the term “debtor” means a debtor concerning whom a petition has been filed under title 11.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8aec7c4-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/689"},"text":"62 Stat. 689","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/tIII/s314/b/1"},"text":"Pub. L. 95–598, title III, § 314(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2676"},"text":"92 Stat. 2676","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330008/5"},"text":"Pub. L. 103–322, title XXXIII, § 330008(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2143"},"text":"108 Stat. 2143","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8aec7c5-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8aec7c6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s52/f"},"text":"section 52(f) of t