{"tag":"section","attrib":{"id":"idb98a3388-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3116"},"text":null,"children":[{"tag":"num","attrib":{"value":"3116"},"text":"§ 3116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records of examining magistrate judge; return to clerk of court—(Rule)","children":[],"tail":null},{"tag":"note","attrib":{"id":"idb98a3389-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"See Federal Rules of Criminal Procedure","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Magistrate judges and clerks of court to keep records as prescribed by Director of the Administrative Office of the United States Courts, Rule 55.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Return or filing of records with clerk, Rule 41(f).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb98a338a-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/821"},"text":"62 Stat. 821","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/578/tIII/s301/a/4"},"text":"Pub. L. 90–578, title III, § 301(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-17"},"text":"Oct. 17, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1115"},"text":"82 Stat. 1115","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/650/tIII/s321"},"text":"Pub. L. 101–650, title III, § 321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5117"},"text":"104 Stat. 5117","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb98a338b-47c4-11