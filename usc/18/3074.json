{"tag":"section","attrib":{"id":"idb98a3307-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3074"},"text":null,"children":[{"tag":"num","attrib":{"value":"3074"},"text":"§ 3074.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception of governmental officials","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No officer or employee of any governmental entity who, while in the performance of his or her official duties, furnishes the information described in section 3071 shall be eligible for any monetary reward under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb98a3308-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/533/tI/s101/a"},"text":"Pub. L. 98–533, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2707"},"text":"98 Stat. 2707","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
