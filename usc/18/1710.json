{"tag":"section","attrib":{"id":"idb92d1f69-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1710"},"text":null,"children":[{"tag":"num","attrib":{"value":"1710"},"text":"§ 1710.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Theft of newspapers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being a Postal Service officer or employee, takes or steals any newspaper or package of newspapers from any post office or from any person having custody thereof, shall be fined under this title or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb92d1f6a-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/780"},"text":"62 Stat. 780","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s6/j/20"},"text":"Pub. L. 91–375, § 6(j)(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/778"},"text":"84 Stat. 778","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/B"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2146"},"text":"108 Stat. 2146","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92d1f6b-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb92d1f6c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 319 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s196"},"text":"Mar. 4, 1909, ch. 321, § 196","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1126"},"text":"35 Stat. 1126","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Theft provisions alone are retained in this section. Those relating to other offenses were incorporated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1703"},"text":"section 1703 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “mail or” following “steals any” were omitted as covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1709"},"text":"section 1709 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92d1f6d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92d1f6e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $100”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":" substituted “Postal Service officer or employee” for “postmaster or Postal Service employee”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":