{"tag":"section","attrib":{"id":"idb993a884-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3163"},"text":null,"children":[{"tag":"num","attrib":{"value":"3163"},"text":"§ 3163.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective dates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb993a885-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3163/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The time limitation in section 3161(b) of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb993a886-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3163/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall apply to all individuals who are arrested or served with a summons on or after the date of expiration of the twelve-calendar-month period following ","children":[{"tag":"date","attrib":{"date":"1975-07-01"},"text":"July 1, 1975","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb993a887-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3163/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall commence to run on such date of expiration to all individuals who are arrested or served with a summons prior to the date of expiration of such twelve-calendar-month period, in connection with the commission of an offense, and with respect to which offense no information or indictment has been filed prior to such date of expiration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb993a888-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3163/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The time limitation in section 3161(c) of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb993a889-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3163/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall apply to all offenses charged in informations or indictments filed on or after the date of expiration of the twelve-calendar-month period following ","children":[{"tag":"date","attrib":{"date":"1975-07-01"},"text":"July 1, 1975","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb993a88a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3163/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall commence to run on such date of expiration as to all offenses charged in informations or indictments filed prior to that date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb993a88b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3163/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the provisions of section 3174(c), section 3162 of this chapter shall become effective and apply to all cases commenced by arrest or summons, and all informations or indictments filed, on or after ","children":[{"tag":"date","attrib":{"date":"1980-07-01"},"text":"July 1, 1980","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb993a88c-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/619/tI/s101"},"text":"Pub. L. 93–619, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2080"},"text":"88 Stat. 2080","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/43/s6"},"text":"Pub. L. 96–43, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-02"},"text":"Aug. 2, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/328"},"text":"93 Stat. 328","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb993a88d-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb993a88e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb993a88f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1979—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/43"},"text":"Pub. L. 96–43","children":[],"tail":" substituted provision that "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3162"},"text":"section 3162 of this title","children":[],"tail":" was to become effective and apply to all cases commenced by arrest or summons, and all informations and indictments filed, on or after "},{"tag":"date","attrib":{"date":"1980-07-01"},"text":"July 1, 1980","children":[],"tail":", subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3174/c"},"text":"section 3174(c) of this title","children":[],"tail":", for provision that such section was to become effective after the date of expiration of the fourth twelve-calendar-month period following "},{"tag":"date","attrib":{"date":"1975-07-01"},"text":"July 1, 1975","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
