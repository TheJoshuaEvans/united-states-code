{"tag":"section","attrib":{"id":"idb98307a0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3013"},"text":null,"children":[{"tag":"num","attrib":{"value":"3013"},"text":"§ 3013.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special assessment on convicted persons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb98307a1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3013/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The court shall assess on any person convicted of an offense against the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb98307a2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3013/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an infraction or a misdemeanor—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb98307a3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3013/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the defendant is an individual—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb98307a4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3013/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of $5 in the case of an infraction or a class C misdemeanor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb98307a5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3013/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of $10 in the case of a class B misdemeanor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb98307a6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3013/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of $25 in the case of a class A misdemeanor; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb98307a7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3013/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the defendant is a person other than an individual—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb98307a8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3013/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of $25 in the case of an infraction or a class C misdemeanor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb98307a9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3013/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of $50 in the case of a class B misdemeanor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb98307aa-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3013/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of $125 in the case of a class A misdemeanor;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb98307ab-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3013/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a felony—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb98307ac-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3013/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of $100 if the defendant is an individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb98307ad-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3013/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of $400 if the defendant is a person other than an individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb98307ae-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3013/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such amount so assessed shall be collected in the manner that fines are collected in criminal cases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb98307af-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3013/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The obligation to pay an assessment ceases five years after the date of the judgment. This subsection shall apply to all assessments irrespective of the date of imposition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb98307b0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3013/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this section, an offense under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s13"},"text":"section 13 of this title","children":[],"tail":" is an offense against the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb98307b1-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s1405/a"},"text":"Pub. L. 98–473, title II, § 1405(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2174"},"text":"98 Stat. 2174","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/185/s3"},"text":"Pub. L. 100–185, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-11"},"text":"Dec. 11, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1279"},"text":"101 Stat. 1279","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII"},"text":"Pub. L. 100–690, title VII","children":[],"tail":", §§ 7082(b), 7085, "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4407"},"text":"102 Stat. 4407","children":[],"tail":", 4408; "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXV/s3569"},"text":"Pub. L. 101–647, title XXXV, § 3569","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4928"},"text":"104 Stat. 4928","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tII/s210"},"text":"Pub. L. 104–132, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1240"},"text":"110 Stat. 1240","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s601/r/4"},"text":"Pub. L. 104–294, title VI, § 601(r)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3502"},"text":"110 Stat. 3502","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb98307b2-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb98307b3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb98307b4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" struck out “not less than” before “$100” in subpar. (A) and before “$400” in subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132"},"text":"Pub. L. 104–132","children":[],"tail":" substituted “not less than $100” for “$50” in subpar. (A) and “not less than $400” for “$200” in subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":" substituted “an infraction” for “a infraction” in cl. (i) and a semicolon for a period at end of cl. (iii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7085"},"text":"Pub. L. 100–690, § 7085","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “in the case of a misdemeanor—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the amount of $25 if the defendant is an individual; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the amount of $100 if the defendant is a person other than an individual; and”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7082/b"},"text":"Pub. L. 100–690, § 7082(b)","children":[],"tail":", inserted at end “This subsection shall apply to all assessments irrespective of the date of imposition.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/185"},"text":"Pub. L. 100–185","children":[],"tail":" added subsecs. (c) and (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb98307b5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb98307b6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132"},"text":"Pub. L. 104–132","children":[],"tail":" effective, to extent constitutionally permissible, for sentencing proceedings in cases in which defendant is convicted on or after "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/s211"},"text":"section 211 of Pub. L. 104–132","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2248"},"text":"section 2248 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb98307b7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 30 days after ","children":[{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/s1409/a"},"text":"section 1409(a) of Pub. L. 98–473","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s20101"},"text":"section 20101 of Title 34","children":[],"tail":", Crime Control and Law Enforcement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
