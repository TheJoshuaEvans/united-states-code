{"tag":"section","attrib":{"id":"idb9b2c9c4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3614"},"text":null,"children":[{"tag":"num","attrib":{"value":"3614"},"text":"§ 3614.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resentencing upon failure to pay a fine or restitution","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9b2c9c5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3614/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Resentencing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the provisions of subsection (b), if a defendant knowingly fails to pay a delinquent fine or restitution the court may resentence the defendant to any sentence which might originally have been imposed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9b2c9c6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3614/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Imprisonment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The defendant may be sentenced to a term of imprisonment under subsection (a) only if the court determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9b2c9c7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3614/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the defendant willfully refused to pay the delinquent fine or had failed to make sufficient bona fide efforts to pay the fine; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9b2c9c8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3614/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in light of the nature of the offense and the characteristics of the person, alternatives to imprisonment are not adequate to serve the purposes of punishment and deterrence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9b2c9c9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3614/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of Indigency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In no event shall a defendant be incarcerated under this section solely on the basis of inability to make payments because the defendant is indigent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9b2c9ca-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s212/a/2"},"text":"Pub. L. 98–473, title II, § 212(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2006"},"text":"98 Stat. 2006","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tII/s207/c/5"},"text":"Pub. L. 104–132, title II, § 207(c)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1240"},"text":"110 Stat. 1240","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9b2c9cb-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9b2c9cc-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb9b2c9cd-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For a prior section 3614, applicable to offenses committed prior to ","children":[{"tag":"date","attrib":{"date":"1987-11-01"},"text":"Nov. 1, 1987","children":[],"tail":", see note set out preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3601"},"text":"section 3601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9b2c9ce-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/232/s207/c/5/A"},"text":"Pub. L. 104–232, § 207(c)(5)(A)","children":[],"tail":", inserted “or restitution” after “fine” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/232/s207/c/5/B"},"text":"Pub. L. 104–232, § 207(c)(5)(B)","children":[],"tail":", inserted “or restitution” after “fine”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/232/s207/c/5/C"},"text":"Pub. L. 104–232, § 207(c)(5)(C)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9b2c9cf-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb9b2c9d0-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132"},"text":"Pub. L. 104–132","children":[],"tail":" to be effective, to extent constitutionally permissible, for sentencing proceedings in cases in which defendant is convicted on or after "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/s211"},"text":"section 211 of Pub. L. 104–132","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2248"},"text":"section 2248 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9b2c9d1-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1987-11-01"},"text":"Nov. 1, 1987","children":[],"tail":", and applicable only to offenses committed after the taking effect of this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/s235/a/1"},"text":"section 235(a)(1) of Pub. L. 98–473","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3551"},"text":"section 3551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
