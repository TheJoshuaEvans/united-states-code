{"tag":"section","attrib":{"id":"idb8b1381b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s158"},"text":null,"children":[{"tag":"num","attrib":{"value":"158"},"text":"§ 158.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of United States attorneys and agents of the Federal Bureau of Investigation to address abusive reaffirmations of debt and materially fraudulent statements in bankruptcy schedules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8b1381c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s158/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Attorney General of the United States shall designate the individuals described in subsection (b) to have primary responsibility in carrying out enforcement activities in addressing violations of section 152 or 157 relating to abusive reaffirmations of debt. In addition to addressing the violations referred to in the preceding sentence, the individuals described under subsection (b) shall address violations of section 152 or 157 relating to materially fraudulent statements in bankruptcy schedules that are intentionally false or intentionally misleading.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b1381d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s158/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"United States Attorneys and Agents of the Federal Bureau of Investigation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The individuals referred to in subsection (a) are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b1381e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s158/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States attorney for each judicial district of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b1381f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s158/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agent of the Federal Bureau of Investigation for each field office of the Federal Bureau of Investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b13820-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s158/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bankruptcy Investigations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each United States attorney designated under this section shall, in addition to any other responsibilities, have primary responsibility for carrying out the duties of a United States attorney under section 3057.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b13821-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s158/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bankruptcy Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The bankruptcy courts shall establish procedures for referring any case that may contain a materially fraudulent statement in a bankruptcy schedule to the individuals designated under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8b13822-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/tII/s203/b/1"},"text":"Pub. L. 109–8, title II, § 203(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/49"},"text":"119 Stat. 49","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8b13823-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8b13824-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8b13825-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", and not applicable with respect to cases commenced under Title 11, Bankruptcy, before such effective date, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1501"},"text":"section 1501 of Pub. L. 109–8","children":[],"tail":", set out as an Effective Date of 2005 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of Title 11","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
