{"tag":"section","attrib":{"id":"idb98a32e0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3063"},"text":null,"children":[{"tag":"num","attrib":{"value":"3063"},"text":"§ 3063.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of Environmental Protection Agency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb98a32e1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3063/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Upon designation by the Administrator of the Environmental Protection Agency, any law enforcement officer of the Environmental Protection Agency with responsibility for the investigation of criminal violations of a law administered by the Environmental Protection Agency, may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb98a32e2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3063/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry firearms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb98a32e3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3063/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" execute and serve any warrant or other processes issued under the authority of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb98a32e4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3063/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make arrests without warrant for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb98a32e5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3063/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any offense against the United States committed in such officer’s presence; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb98a32e6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3063/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any felony offense against the United States if such officer has probable cause to believe that the person to be arrested has committed or is committing that felony offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb98a32e7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3063/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The powers granted under subsection (a) of this section shall be exercised in accordance with guidelines approved by the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb98a32e8-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/582/s4/a"},"text":"Pub. L. 100–582, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-01"},"text":"Nov. 1, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2958"},"text":"102 Stat. 2958","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
