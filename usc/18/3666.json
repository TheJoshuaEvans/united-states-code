{"tag":"section","attrib":{"id":"idb9bc3fad-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3666"},"text":null,"children":[{"tag":"num","attrib":{"value":"3666"},"text":"§ 3666.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bribe moneys","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Moneys received or tendered in evidence in any United States Court, or before any officer thereof, which have been paid to or received by any official as a bribe, shall, after the final disposition of the case, proceeding or investigation, be deposited in the registry of the court to be disposed of in accordance with the order of the court, to be subject, however, to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2042"},"text":"section 2042 of Title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9bc3fae-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/840"},"text":"62 Stat. 840","children":[],"tail":", § 3612; "},{"tag":"ref","attrib":{"href":"/us/act/1949-05-24/ch139/s55"},"text":"May 24, 1949, ch. 139, § 55","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/96"},"text":"63 Stat. 96","children":[],"tail":"; renumbered § 3666, "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s212/a/1"},"text":"Pub. L. 98–473, title II, § 212(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1987"},"text":"98 Stat. 1987","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9bc3faf-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id"