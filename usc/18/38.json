{"tag":"section","attrib":{"id":"idb8a79b22-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38"},"text":null,"children":[{"tag":"num","attrib":{"value":"38"},"text":"§ 38.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraud involving aircraft or space vehicle parts in interstate or foreign commerce","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8a79b23-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offenses","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever, in or affecting interstate or foreign commerce, knowingly and with the intent to defraud—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a79b24-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a79b25-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" falsifies or conceals a material fact concerning any aircraft or space vehicle part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a79b26-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes any materially fraudulent representation concerning any aircraft or space vehicle part; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a79b27-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes or uses any materially false writing, entry, certification, document, record, data plate, label, or electronic communication concerning any aircraft or space vehicle part;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a79b28-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exports from or imports or introduces into the United States, sells, trades, installs on or in any aircraft or space vehicle any aircraft or space vehicle part using or by means of a fraudulent representation, document, record, certification, depiction, data plate, label, or electronic communication; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a79b29-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attempts or conspires to commit an offense described in paragraph (1) or (2),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished as provided in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a79b2a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The punishment for an offense under subsection (a) is as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a79b2b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aviation quality","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the offense relates to the aviation quality of a part and the part is installed in an aircraft or space vehicle, a fine of not more than $500,000, imprisonment for not more than 15 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a79b2c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Failure to operate as represented","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If, by reason of the failure of the part to operate as represented, the part to which the offense is related is the proximate cause of a malfunction or failure that results in serious bodily injury (as defined in section 1365), a fine of not more than $1,000,000, imprisonment for not more than 20 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a79b2d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Failure resulting in death","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If, by reason of the failure of the part to operate as represented, the part to which the offense is related is the proximate cause of a malfunction or failure that results in the death of any person, a fine of not more than $1,000,000, imprisonment for any term of years or life, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a79b2e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other circumstances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of an offense under subsection (a) not described in paragraph (1), (2), or (3) of this subsection, a fine under this title, imprisonment for not more than 10 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a79b2f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Organizations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the offense is committed by an organization, a fine of not more than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a79b30-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 in the case of an offense described in paragraph (1) or (4); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a79b31-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 in the case of an offense described in paragraph (2) or (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a79b32-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Remedies.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a79b33-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The district courts of the United States shall have jurisdiction to prevent and restrain violations of this section by issuing appropriate orders, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a79b34-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ordering a person (convicted of an offense under this section) to divest any interest, direct or indirect, in any enterprise used to commit or facilitate the commission of the offense, or to destroy, or to mutilate and sell as scrap, aircraft material or part inventories or stocks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a79b35-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imposing reasonable restrictions on the future activities or investments of any such person, including prohibiting engagement in the same type of endeavor as used to commit the offense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a79b36-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ordering the dissolution or reorganization of any enterprise knowingly used to commit or facilitate the commission of an offense under this section making due provisions for the rights and interests of innocent persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a79b37-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restraining orders and prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Pending final determination of a proceeding brought under this section, the court may enter such restraining orders or prohibitions, or take such other actions (including the acceptance of satisfactory performance bonds) as the court deems proper.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a79b38-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Estoppel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A final judgment rendered in favor of the United States in any criminal proceeding brought under this section shall stop the defendant from denying the essential allegations of the criminal offense in any subsequent civil proceeding brought by the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a79b39-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criminal Forfeiture.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a79b3a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The court, in imposing sentence on any person convicted of an offense under this section, shall order, in addition to any other sentence and irrespective of any provision of State law, that the person forfeit to the United States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a79b3b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any property constituting, or derived from, any proceeds that the person obtained, directly or indirectly, as a result of the offense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a79b3c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any property used, or intended to be used in any manner, to commit or facilitate the commission of the offense, if the court in its discretion so determines, taking into consideration the nature, scope, and proportionality of the use of the property on the offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a79b3d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of other law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The forfeiture of property under this section, including any seizure and disposition of the property, and any proceedings relating to the property, shall be governed by section 413 of the Comprehensive Drug Abuse and Prevention Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s853"},"text":"21 U.S.C. 853","children":[],"tail":") (not including subsection (d) of that section)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a79b3e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction With Other Law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not preempt or displace any other remedy, civil or criminal, provided by Federal or State law for the fraudulent importation, sale, trade, installation, or introduction into commerce of an aircraft or space vehicle part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a79b3f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Territorial Scope","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section also applies to conduct occurring outside the United States if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a79b40-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offender is a natural person who is a citizen or permanent resident alien of the United States, or an organization organized under the laws of the United States or political subdivision thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a79b41-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aircraft or spacecraft part as to which the violation relates was installed in an aircraft or space vehicle owned or operated at the time of the offense by a citizen or permanent resident alien of the United States, or by an organization thereof; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a79b42-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s38/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an act in furtherance of the offense was committed in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8a79b43-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/tV/s506/c/1"},"text":"Pub. L. 106–181, title V, § 506(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/137"},"text":"114 Stat. 137","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8a79b44-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8a79b45-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8a79b46-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable only to fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"1999-09-30"},"text":"Sept. 30, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/s3"},"text":"section 3 of Pub. L. 106–181","children":[],"tail":", set out as an Effective Date of 2000 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of Title 49","children":[],"tail":", Transportation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
