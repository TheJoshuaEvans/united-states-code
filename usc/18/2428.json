{"tag":"section","attrib":{"id":"idb96ff436-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2428"},"text":null,"children":[{"tag":"num","attrib":{"value":"2428"},"text":"§ 2428.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeitures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb96ff437-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2428/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The court, in imposing sentence on any person convicted of a violation of this chapter, shall order, in addition to any other sentence imposed and irrespective of any provision of State law, that such person shall forfeit to the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96ff438-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2428/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such person’s interest in any property, real or personal, that was used or intended to be used to commit or to facilitate the commission of such violation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96ff439-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2428/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any property, real or personal, constituting or derived from any proceeds that such person obtained, directly or indirectly, as a result of such violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96ff43a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2428/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Property Subject to Forfeiture.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96ff43b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2428/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following shall be subject to forfeiture to the United States and no property right shall exist in them:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb96ff43c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2428/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any property, real or personal, used or intended to be used to commit or to facilitate the commission of any violation of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96ff43d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2428/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any property, real or personal, that constitutes or is derived from proceeds traceable to any violation of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96ff43e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2428/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of chapter 46","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The provisions of chapter 46 of this title relating to civil forfeitures shall apply to any seizure or civil forfeiture under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb96ff43f-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/164/tI/s103/d/1"},"text":"Pub. L. 109–164, title I, § 103(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-10"},"text":"Jan. 10, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3563"},"text":"119 Stat. 3563","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
