{"tag":"section","attrib":{"id":"idb96657b4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i"},"text":null,"children":[{"tag":"num","attrib":{"value":"2332i"},"text":"§ 2332i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acts of nuclear terrorism","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb96657b5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offenses.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96657b6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever knowingly and unlawfully—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb96657b7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" possesses radioactive material or makes or possesses a device—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb96657b8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the intent to cause death or serious bodily injury; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb96657b9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the intent to cause substantial damage to property or the environment; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96657ba-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" uses in any way radioactive material or a device, or uses or damages or interferes with the operation of a nuclear facility in a manner that causes the release of or increases the risk of the release of radioactive material, or causes radioactive contamination or exposure to radiation—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb96657bb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the intent to cause death or serious bodily injury or with the knowledge that such act is likely to cause death or serious bodily injury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb96657bc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the intent to cause substantial damage to property or the environment or with the knowledge that such act is likely to cause substantial damage to property or the environment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb96657bd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the intent to compel a person, an international organization or a country to do or refrain from doing an act,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished as prescribed in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96657be-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Threats","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever, under circumstances in which the threat may reasonably be believed, threatens to commit an offense under paragraph (1) shall be punished as prescribed in subsection (c). Whoever demands possession of or access to radioactive material, a device or a nuclear facility by threat or by use of force shall be punished as prescribed in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96657bf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Attempts and conspiracies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever attempts to commit an offense under paragraph (1) or conspires to commit an offense under paragraph (1) or (2) shall be punished as prescribed in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96657c0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Conduct prohibited by subsection (a) is within the jurisdiction of the United States if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96657c1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prohibited conduct takes place in the United States or the special aircraft jurisdiction of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96657c2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the prohibited conduct takes place outside of the United States and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb96657c3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is committed by a national of the United States, a United States corporation or legal entity or a stateless person whose habitual residence is in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96657c4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is committed on board a vessel of the United States or a vessel subject to the jurisdiction of the United States (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70502"},"text":"section 70502 of title 46","children":[],"tail":") or on board an aircraft that is registered under United States law, at the time the offense is committed; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96657c5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is committed in an attempt to compel the United States to do or abstain from doing any act, or constitutes a threat directed at the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96657c6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prohibited conduct takes place outside of the United States and a victim or an intended victim is a national of the United States or a United States corporation or legal entity, or the offense is committed against any state or government facility of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96657c7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a perpetrator of the prohibited conduct is found in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96657c8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever violates this section shall be fined not more than $2,000,000 and shall be imprisoned for any term of years or for life.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96657c9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplicability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section does not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96657ca-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities of armed forces during an armed conflict, as those terms are understood under the law of war, which are governed by that law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96657cb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities undertaken by military forces of a state in the exercise of their official duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96657cc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96657cd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “armed conflict” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2332f/e/11"},"text":"section 2332f(e)(11) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96657ce-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “device” means:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb96657cf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any nuclear explosive device; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96657d0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any radioactive material dispersal or radiation-emitting device that may, owing to its radiological properties, cause death, serious bodily injury or substantial damage to property or the environment;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96657d1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “international organization” has the meaning given that term in section 831(f)(3) ","children":[{"tag":"ref","attrib":{"idref":"fn002192"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002192"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96657d2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “military forces of a state” means the armed forces of a country that are organized, trained and equipped under its internal law for the primary purpose of national defense or security and persons acting in support of those armed forces who are under their formal command, control and responsibility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96657d3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “national of the United States” has the meaning given that term in section 101(a)(22) of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/22"},"text":"8 U.S.C. 1101(a)(22)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96657d4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “nuclear facility” means:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb96657d5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/e/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any nuclear reactor, including reactors on vessels, vehicles, aircraft or space objects for use as an energy source in order to propel such vessels, vehicles, aircraft or space objects or for any other purpose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96657d6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/e/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any plant or conveyance being used for the production, storage, processing or transport of radioactive material; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96657d7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/e/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a facility (including associated buildings and equipment) in which nuclear material is produced, processed, used, handled, stored or disposed of, if damage to or interference with such facility could lead to the release of significant amounts of radiation or radioactive material;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96657d8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “nuclear material” has the meaning given that term in section 831(f)(1) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96657d9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/e/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “radioactive material” means nuclear material and other radioactive substances that contain nuclides that undergo spontaneous disintegration (a process accompanied by emission of one or more types of ionizing radiation, such as alpha-, beta-, neutron particles and gamma rays) and that may, owing to their radiological or fissile properties, cause death, serious bodily injury or substantial damage to property or to the environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96657da-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/e/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “serious bodily injury” has the meaning given that term in section 831(f)(4) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96657db-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/e/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “state” has the same meaning as that term has under international law, and includes all political subdivisions thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96657dc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/e/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “state or government facility” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2332f/e/3"},"text":"section 2332f(e)(3) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96657dd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/e/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “United States corporation or legal entity” means any corporation or other entity organized under the laws of the United States or any State, Commonwealth, territory, possession or district of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96657de-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/e/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “vessel” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1502/19"},"text":"section 1502(19) of title 33","children":[],"tail":"; "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96657df-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332i/e/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “vessel of the United States” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70502"},"text":"section 70502 of title 46","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb96657e0-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/tVIII/s811/a"},"text":"Pub. L. 114–23, title VIII, § 811(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-02"},"text":"June 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/309"},"text":"129 Stat. 309","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb96657e1-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb96657e2-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb96657e3-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s831/f"},"text":"Section 831(f) of this title","children":[],"tail":", referred to in subsec. (e)(3), (7), (9), was redesignated section 831(g) by "},{"tag":"ref","attrib":{"href":"/us/pl/114/23/tVIII/s812/d"},"text":"Pub. L. 114–23, title VIII, § 812(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-02"},"text":"June 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/312"},"text":"129 Stat. 312","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1502/19"},"text":"Section 1502(19) of title 33","children":[],"tail":", referred to in subsec. (e)(13), probably should be a reference to section 3(19) of the Deepwater Port Act of 1974, which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1502/19"},"text":"section 1502(19) of Title 33","children":[],"tail":", Navigation and Navigable Waters."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
