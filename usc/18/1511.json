{"tag":"section","attrib":{"id":"idb923a981-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1511"},"text":null,"children":[{"tag":"num","attrib":{"value":"1511"},"text":"§ 1511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obstruction of State or local law enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb923a982-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" It shall be unlawful for two or more persons to conspire to obstruct the enforcement of the criminal laws of a State or political subdivision thereof, with the intent to facilitate an illegal gambling business if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb923a983-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1511/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more of such persons does any act to effect the object of such a conspiracy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb923a984-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1511/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more of such persons is an official or employee, elected, appointed, or otherwise, of such State or political subdivision; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb923a985-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1511/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more of such persons conducts, finances, manages, supervises, directs, or owns all or part of an illegal gambling business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb923a986-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb923a987-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1511/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “illegal gambling business” means a gambling business which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb923a988-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1511/b/1/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a violation of the law of a State or political subdivision in which it is conducted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb923a989-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1511/b/1/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involves five or more persons who conduct, finance, manage, supervise, direct, or own all or part of such business; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb923a98a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1511/b/1/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been or remains in substantially continuous operation for a period in excess of thirty days or has a gross revenue of $2,000 in any single day.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb923a98b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1511/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “gambling” includes but is not limited to pool-selling, bookmaking, maintaining slot machines, roulette wheels, or dice tables, and conducting lotteries, policy, bolita or numbers games, or selling chances therein.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb923a98c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1511/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means any State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, and any territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb923a98d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1511/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall not apply to any bingo game, lottery, or similar game of chance conducted by an organization exempt from tax under paragraph (3) of subsection (c) of section 501 of the Internal Revenue Code of 1986, as amended, if no part of the gross receipts derived from such activity inures to the benefit of any private shareholder, member, or employee of such organization, except as compensation for actual expenses incurred by him in the conduct of such activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb923a98e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1511/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever violates this section shall be punished by a fine under this title or imprisonment for not more than five years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb923a98f-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/452/tVIII/s802/a"},"text":"Pub. L. 91–452, title VIII, § 802(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-15"},"text":"Oct. 15, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/936"},"text":"84 Stat. 936","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/2/C"},"text":"Pub. L. 103–322, title XXXIII, § 330016(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2148"},"text":"108 Stat. 2148","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb923a990-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb923a991-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb923a992-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Paragraph (3) of subsection (c) of section 501 of the Internal Revenue Code of 1986, referred to in subsec. (c), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb923a993-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fine under this title” for “fine of not more than $20,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb923a994-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb923a995-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Statement of Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/452/tVIII/s801"},"text":"Pub. L. 91–452, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-15"},"text":"Oct. 15, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/936"},"text":"84 Stat. 936","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/452/tVIII/s801"},"text":"“The Congress finds that illegal gambling involves widespread use of, and has an effect upon, interstate commerce and the facilities thereof.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb923a996-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Priority of State Laws","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/452/tVIII/s811"},"text":"Pub. L. 91–452, title VIII, § 811","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-15"},"text":"Oct. 15, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/940"},"text":"84 Stat. 940","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/452/tVIII/s811"},"text":"“No provision of this title [enacting this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1955"},"text":"section 1955 of this title","children":[],"tail":", amending "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2516"},"text":"section 2516 of this title","children":[],"tail":", and enacting provisions set out as notes under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1955"},"text":"section 1955 of this title","children":[],"tail":"] indicates an intent on the part of the Congress to occupy the field in which such provision operates to the exclusion of the law of a state or possession, or a political subdivision of a State or possession, on the same subject matter, or to relieve any person of any obligation imposed by any law of any State or possession, or political subdivision of a State or possession.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
