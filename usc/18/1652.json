{"tag":"section","attrib":{"id":"idb92ad5b4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1652"},"text":null,"children":[{"tag":"num","attrib":{"value":"1652"},"text":"§ 1652.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Citizens as pirates","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being a citizen of the United States, commits any murder or robbery, or any act of hostility against the United States, or against any citizen thereof, on the high seas, under color of any commission from any foreign prince, or state, or on pretense of authority from any person, is a pirate, and shall be imprisoned for life.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb92ad5b5-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/774"},"text":"62 Stat. 774","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92ad5b6-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb92ad5b7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 495 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s304"},"text":"Mar. 4, 1909, ch. 321, § 304","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1147"},"text":"35 Stat. 1147","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “Notwithstanding the pretense of such authority,” were omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
