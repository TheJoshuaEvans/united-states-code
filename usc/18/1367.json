{"tag":"section","attrib":{"id":"idb91c7dc0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1367"},"text":null,"children":[{"tag":"num","attrib":{"value":"1367"},"text":"§ 1367.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interference with the operation of a satellite","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb91c7dc1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1367/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever, without the authority of the satellite operator, intentionally or maliciously interferes with the authorized operation of a communications or weather satellite or obstructs or hinders any satellite transmission shall be fined in accordance with this title or imprisoned not more than ten years or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91c7dc2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1367/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not prohibit any lawfully authorized investigative, protective, or intelligence activity of a law enforcement agency or of an intelligence agency of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb91c7dc3-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/508/tIII/s303/a"},"text":"Pub. L. 99–508, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1872"},"text":"100 Stat. 1872","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91c7dc4-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb91c7dc5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb91c7dc6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", and, in case of conduct pursuant to court order or extension, applicable only with respect to court orders and extensions made after such date, with special rule for State authorizations of interceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/508/s302"},"text":"section 302 of Pub. L. 99–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3121"},"text":"section 3121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
