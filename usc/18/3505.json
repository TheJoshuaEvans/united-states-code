{"tag":"section","attrib":{"id":"idb99fb784-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3505"},"text":null,"children":[{"tag":"num","attrib":{"value":"3505"},"text":"§ 3505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign records of regularly conducted ac­tivity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb99fb785-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb99fb786-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3505/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In a criminal proceeding in a court of the United States, a foreign record of regularly conducted activity, or a copy of such record, shall not be excluded as evidence by the hearsay rule if a foreign certification attests that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb99fb787-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3505/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such record was made, at or near the time of the occurrence of the matters set forth, by (or from information transmitted by) a person with knowledge of those matters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb99fb788-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3505/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such record was kept in the course of a regularly conducted business activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb99fb789-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3505/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the business activity made such a record as a regular practice; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb99fb78a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3505/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such record is not the original, such record is a duplicate of the original;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"unless the source of information or the method or circumstances of preparation indicate lack of trustworthiness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb99fb78b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3505/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A foreign certification under this section shall authenticate such record or duplicate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb99fb78c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At the arraignment or as soon after the arraignment as practicable, a party intending to offer in evidence under this section a foreign record of regularly conducted activity shall provide written notice of that intention to each other party. A motion opposing admission in evidence of such record shall be made by the opposing party and determined by the court before trial. Failure by a party to file such motion before trial shall constitute a waiver of objection to such record or duplicate, but the court for cause shown may grant relief from the waiver.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb99fb78d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3505/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in this section, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb99fb78e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3505/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “foreign record of regularly conducted activity” means a memorandum, report, record, or data compilation, in any form, of acts, events, conditions, opinions, or diagnoses, maintained in a foreign country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb99fb78f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3505/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “foreign certification” means a written declaration made and signed in a foreign country by the custodian of a foreign record of regularly conducted activity or another qualified person that, if falsely made, would subject the maker to criminal penalty under the laws of that country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb99fb790-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3505/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “business” includes business, institution, association, profession, occupation, and calling of every kind, whether or not conducted for profit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb99fb791-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s1217/a"},"text":"Pub. L. 98–473, title II, § 1217(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2165"},"text":"98 Stat. 2165","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb99fb792-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb99fb793-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb99fb794-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s1220"},"text":"Pub. L. 98–473, title II, § 1220","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2167"},"text":"98 Stat. 2167","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/473/tII/s1220"},"text":"“This part [part K (§§ 1217–1220) of chapter XII of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":", enacting this section and sections 3292, 3506, and 3507 of this title and amending "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3161"},"text":"section 3161 of this title","children":[],"tail":"] and the amendments made by this part shall take effect thirty days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
