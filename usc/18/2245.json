{"tag":"section","attrib":{"id":"idb949cebd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2245"},"text":null,"children":[{"tag":"num","attrib":{"value":"2245"},"text":"§ 2245.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offenses resulting in death","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb949cebe-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2245/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002143"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002143"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No subsec. (b) has been enacted."}],"tail":" "},{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person who, in the course of an offense under this chapter, or section 1591, 2251, 2251A, 2260, 2421, 2422, 2423, or 2425, murders an individual, shall be punished by death or imprisoned for any term of years or for life.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb949cebf-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tVI/s60010/a/2"},"text":"Pub. L. 103–322, title VI, § 60010(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1972"},"text":"108 Stat. 1972","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/248/tII/s206/a/3"},"text":"Pub. L. 109–248, title II, § 206(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/613"},"text":"120 Stat. 613","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb949cec0-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb949cec1-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb949cec2-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2245 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2246"},"text":"section 2246 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb949cec3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248"},"text":"Pub. L. 109–248","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text read as follows: “A person who, in the course of an offense under this chapter, engages in conduct that results in the death of a person, shall be punished by death or imprisoned for any term of years or for life.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
