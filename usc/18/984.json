{"tag":"section","attrib":{"id":"idb904b074-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s984"},"text":null,"children":[{"tag":"num","attrib":{"value":"984"},"text":"§ 984.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil forfeiture of fungible property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb904b075-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s984/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb904b076-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s984/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In any forfeiture action in rem in which the subject property is cash, monetary instruments in bearer form, funds deposited in an account in a financial institution (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s20"},"text":"section 20 of this title","children":[],"tail":"), or precious metals—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb904b077-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s984/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it shall not be necessary for the Government to identify the specific property involved in the offense that is the basis for the forfeiture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb904b078-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s984/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it shall not be a defense that the property involved in such an offense has been removed and replaced by identical property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb904b079-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s984/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b), any identical property found in the same place or account as the property involved in the offense that is the basis for the forfeiture shall be subject to forfeiture under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb904b07a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s984/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No action pursuant to this section to forfeit property not traceable directly to the offense that is the basis for the forfeiture may be commenced more than 1 year from the date of the offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb904b07b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s984/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb904b07c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s984/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) does not apply to an action against funds held by a financial institution in an interbank account unless the account holder knowingly engaged in the offense that is the basis for the forfeiture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb904b07d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s984/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb904b07e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s984/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “financial institution” includes a foreign bank (as defined in section 1(b)(7) of the International Banking Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3101/b/7"},"text":"12 U.S.C. 3101(b)(7)","children":[],"tail":")); "},{"tag":"ref","attrib":{"idref":"fn002084"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002084"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb904b07f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s984/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “interbank account” means an account held by one financial institution at another financial institution primarily for the purpose of facilitating customer transactions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb904b080-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s984/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section may be construed to limit the ability of the Government to forfeit property under any provision of law if the property involved in the offense giving rise to the forfeiture or property traceable thereto is available for forfeiture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb904b081-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXV/s1522/a"},"text":"Pub. L. 102–550, title XV, § 1522(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4063"},"text":"106 Stat. 4063","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/325/tIV/s411/c/2/E"},"text":"Pub. L. 103–325, title IV, § 411(c)(2)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2253"},"text":"108 Stat. 2253","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/185/s13/a"},"text":"Pub. L. 106–185, § 13(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-25"},"text":"Apr. 25, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/218"},"text":"114 Stat. 218","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb904b082-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb904b083-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb904b084-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1(b)(7) of the International Banking Act of 1978, referred to in subsec. (c)(2)(A), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3101/7"},"text":"section 3101(7) of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb904b085-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/185/s13/a/1"},"text":"Pub. L. 106–185, § 13(a)(1)","children":[],"tail":", (2), redesignated subsec. (b) as (a), substituted “or precious metals” for “or other fungible property” in introductory provisions of par. (1) and “subsection (b)” for “subsection (c)” in par. (2), and struck out former subsec. (a) which read as follows: “This section shall apply to any action for forfeiture brought by the Government in connection with any offense under section 1956, 1957, or 1960 of this title or section 5322 or 5324 of title 31, United States Code.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/185/s13/a/1"},"text":"Pub. L. 106–185, § 13(a)(1)","children":[],"tail":", redesignated subsec. (c) as (b). Former subsec. (b) redesignated (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/185/s13/a/1"},"text":"Pub. L. 106–185, § 13(a)(1)","children":[],"tail":", redesignated subsec. (d) as (c). Former subsec. (c) redesignated (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/185/s13/a/3/A"},"text":"Pub. L. 106–185, § 13(a)(3)(A)","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “No action pursuant to this section to forfeit property not traceable directly to the offense that is the basis for the forfeiture may be taken against funds held by a financial institution in an interbank account, unless the financial institution holding the account knowingly engaged in the offense.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/185/s13/a/3/B"},"text":"Pub. L. 106–185, § 13(a)(3)(B)","children":[],"tail":", substituted “In this subsection—” for “As used in this section, the term”, added subpar. (A), and inserted “(B) the term” before “ ‘interbank account’ means”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/185/s13/a/4"},"text":"Pub. L. 106–185, § 13(a)(4)","children":[],"tail":", added subsec. (d). Former subsec. (d) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325"},"text":"Pub. L. 103–325","children":[],"tail":" substituted “section 5322 or 5324 of title 31” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5322"},"text":"section 5322 of title 31","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb904b086-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb904b087-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/185"},"text":"Pub. L. 106–185","children":[],"tail":" applicable to any forfeiture proceeding commenced on or after the date that is 120 days after "},{"tag":"date","attrib":{"date":"2000-04-25"},"text":"Apr. 25, 2000","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/185/s21"},"text":"section 21 of Pub. L. 106–185","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1324"},"text":"section 1324 of Title 8","children":[],"tail":", Aliens and Nationality."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
