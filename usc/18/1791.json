{"tag":"section","attrib":{"id":"idb9320119-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1791"},"text":null,"children":[{"tag":"num","attrib":{"value":"1791"},"text":"§ 1791.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Providing or possessing contraband in prison","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb932011a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1791/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offense","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb932011b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1791/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in violation of a statute or a rule or order issued under a statute, provides to an inmate of a prison a prohibited object, or attempts to do so; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb932011c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1791/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" being an inmate of a prison, makes, possesses, or obtains, or attempts to make or obtain, a prohibited object;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished as provided in subsection (b) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb932011d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1791/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Punishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The punishment for an offense under this section is a fine under this title or—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb932011e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1791/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imprisonment for not more than 20 years, or both, if the object is specified in subsection (d)(1)(C) of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb932011f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1791/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imprisonment for not more than 10 years, or both, if the object is specified in subsection (d)(1)(A) of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9320120-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1791/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imprisonment for not more than 5 years, or both, if the object is specified in subsection (d)(1)(B) of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9320121-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1791/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imprisonment for not more than one year, or both, if the object is specified in subsection (d)(1)(D), (d)(1)(E), or (d)(1)(F) of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9320122-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1791/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imprisonment for not more than 6 months, or both, if the object is specified in subsection (d)(1)(G) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9320123-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1791/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consecutive Punishment Required in Certain Cases","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any punishment imposed under subsection (b) for a violation of this section involving a controlled substance shall be consecutive to any other sentence imposed by any court for an offense involving such a controlled substance. Any punishment imposed under subsection (b) for a violation of this section by an inmate of a prison shall be consecutive to the sentence being served by such inmate at the time the inmate commits such violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9320124-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1791/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9320125-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1791/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “prohibited object” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9320126-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1791/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a firearm or destructive device or a controlled substance in schedule I or II, other than marijuana or a controlled substance referred to in subparagraph (C) of this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9320127-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1791/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marijuana or a controlled substance in schedule III, other than a controlled substance referred to in subparagraph (C) of this subsection, ammunition, a weapon (other than a firearm or destructive device), or an object that is designed or intended to be used as a weapon or to facilitate escape from a prison;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9320128-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1791/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a narcotic drug, methamphetamine, its salts, isomers, and salts of its isomers, lysergic acid diethylamide, or phencyclidine;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9320129-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1791/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a controlled substance (other than a controlled substance referred to in subparagraph (A), (B), or (C) of this subsection) or an alcoholic beverage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb932012a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1791/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any United States or foreign currency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb932012b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1791/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a phone or other device used by a user of commercial mobile service (as defined in section 332(d) of the Communications Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s332/d"},"text":"47 U.S.C. 332(d)","children":[],"tail":")) in connection with such service; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb932012c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1791/d/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other object that threatens the order, discipline, or security of a prison, or the life, health, or safety of an individual;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb932012d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1791/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “ammunition”, “firearm”, and “destructive device” have, respectively, the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s921"},"text":"section 921 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb932012e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1791/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “controlled substance” and “narcotic drug” have, respectively, the meanings given those terms in section 102 of the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"21 U.S.C. 802","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb932012f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1791/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “prison” means a Federal correctional, detention, or penal facility or any prison, institution, or facility in which persons are held in custody by direction of or pursuant to a contract or agreement with the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9320130-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/786"},"text":"62 Stat. 786","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s1109/a"},"text":"Pub. L. 98–473, title II, § 1109(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2147"},"text":"98 Stat. 2147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/646/s52/a"},"text":"Pub. L. 99–646, § 52(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3606"},"text":"100 Stat. 3606","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI/s6468/a"},"text":"Pub. L. 100–690, title VI, § 6468(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4376"},"text":"102 Stat. 4376","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIX/s90101"},"text":"Pub. L. 103–322, title IX, § 90101","children":[],"tail":", title XXXIII, § 330003(a), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":","},{"tag":"ref","attrib":{"href":"/us/stat/108/1986"},"text":"108 Stat. 1986","children":[],"tail":", 2140; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s601/m"},"text":"Pub. L. 104–294, title VI, § 601(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3502"},"text":"110 Stat. 3502","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1178"},"text":"Pub. L. 109–162, title XI, § 1178","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3126"},"text":"119 Stat. 3126","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/225/s2"},"text":"Pub. L. 111–225, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-08-10"},"text":"Aug. 10, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2387"},"text":"124 Stat. 2387","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9320131-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9320132-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., §§ 753j, 908 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-05-14/ch274/s11"},"text":"May 14, 1930, ch. 274, § 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/327"},"text":"46 Stat. 327","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1930-05-27/ch339/s8"},"text":"May 27, 1930, ch. 339, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/390"},"text":"46 Stat. 390","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section consolidates sections 753j and 908 of title 18, U.S.C., 1940 ed. The section was broadened to include the taking or sending out of contraband from the institution. This was suggested by representatives of the Federal Bureau of Prisons and the Criminal Division of the Department of Justice. In other respects the section was rewritten without change of substance.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “narcotic”, “drug”, “weapon” and “contraband” were omitted, since the insertion of the words “contrary to any rule or regulation promulgated by the attorney general” preserves the intent of the original statutes.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “guilty of a felony” were deleted as unnecessary in view of definitive ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1"},"text":"section 1 of this title","children":[],"tail":". (See also reviser’s note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s550"},"text":"section 550 of this title","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor verbal changes also were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9320133-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9320134-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Schedules I, II, and III, referred to in subsec. (d)(1)(A), (B), probably mean schedules I to III of the schedules of controlled substances, which are set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s812/c"},"text":"section 812(c) of Title 21","children":[],"tail":", Food and Drugs."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9320135-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/225/s2/1/A"},"text":"Pub. L. 111–225, § 2(1)(A)","children":[],"tail":", substituted “, (d)(1)(E), or (d)(1)(F)” for “or (d)(1)(E)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/225/s2/1/B"},"text":"Pub. L. 111–225, § 2(1)(B)","children":[],"tail":", substituted “(d)(1)(G)” for “(d)(1)(F)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(F), (G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/225/s2/2"},"text":"Pub. L. 111–225, § 2(2)","children":[],"tail":", added subpar. (F) and redesignated former subpar. (F) as (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":" inserted “or any prison, institution, or facility in which persons are held in custody by direction of or pursuant to a contract or agreement with the Attorney General” after “penal facility”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(2) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":", §§ 90101(6), 330003(a), amended subsec. (b) identically, substituting “(d)” for “(c)” wherever appearing in pars. (2) to (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s90101/1"},"text":"Pub. L. 103–322, § 90101(1)","children":[],"tail":", inserted at beginning “Any punishment imposed under subsection (b) for a violation of this section involving a controlled substance shall be consecutive to any other sentence imposed by any court for an offense involving such a controlled substance.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s90101/2"},"text":"Pub. L. 103–322, § 90101(2)","children":[],"tail":", inserted before semicolon at end “or a controlled substance in schedule I or II, other than marijuana or a controlled substance referred to in subparagraph (C) of this subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s90101/3"},"text":"Pub. L. 103–322, § 90101(3)","children":[],"tail":", inserted “marijuana or a controlled substance in schedule III, other than a controlled substance referred to in subparagraph (C) of this subsection,” before “ammunition,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s90101/4"},"text":"Pub. L. 103–322, § 90101(4)","children":[],"tail":", inserted “methamphetamine, its salts, isomers, and salts of its isomers,” after “narcotic drug,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s90101/5"},"text":"Pub. L. 103–322, § 90101(5)","children":[],"tail":", inserted “(A), (B), or” before “(C)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s6468/a"},"text":"Pub. L. 100–690, § 6468(a)","children":[],"tail":", added par. (1), redesignated former pars. (1) to (4) as (2) to (5), respectively, and struck out “or (c)(1)(C)” after “subsection (c)(1)(B)” in par. (3) as redesignated."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s6468/b"},"text":"Pub. L. 100–690, § 6468(b)","children":[],"tail":", added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646"},"text":"Pub. L. 99–646","children":[],"tail":" amended section generally. Prior to amendment, section read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"Offense","children":[],"tail":".—A person commits an offense if, in violation of a statute, or a regulation, rule, or order issued pursuant thereto—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) he provides, or attempts to provide, to an inmate of a Federal penal or correctional facility—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) a firearm or destructive device;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) any other weapon or object that may be used as a weapon or as a means of facilitating escape;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) a narcotic drug as defined in section 102 of the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"21 U.S.C. 802","children":[],"tail":");"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) a controlled substance, other than a narcotic drug, as defined in section 102 of the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"21 U.S.C. 802","children":[],"tail":"), or an alcoholic beverage;"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(E) United States currency; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(F) any other object; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) being an inmate of a Federal penal or correctional facility, he makes, possesses, procures, or otherwise provides himself with, or attempts to make, possess, procure, or otherwise provide himself with, anything described in paragraph (1).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Grading","children":[],"tail":".—An offense described in this section is punishable by—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) imprisonment for not more than ten years, a fine of not more than $25,000, or both, if the object is anything set forth in paragraph (1)(A);","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) imprisonment for not more than five years, a fine of not more than $10,000, or both, if the object is anything set forth in paragraph (1)(B) or (1)(C);","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) imprisonment for not more than one year, a fine of not more than $5,000, or both, if the object is anything set forth in paragraph (1)(D) or (1)(E); and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) imprisonment for not more than six months, a fine of not more than $1,000, or both, if the object is any other object.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—As used in this section, ‘firearm’ and ‘destructive device’ have the meaning given those terms, respectively, in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s921/a/3"},"text":"18 U.S.C. 921(a)(3)","children":[],"tail":" and (4).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":" substituted provisions relating to providing or possessing contraband in prison, grading of offenses and definitions of “firearm” and “destructive device” for former provisions relating to traffic in contraband articles."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9320136-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb9320137-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646/s52/b"},"text":"Pub. L. 99–646, § 52(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3607"},"text":"100 Stat. 3607","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/646/s52/b"},"text":"“The amendment made by this section [amending this section] shall take effect 30 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
