{"tag":"section","attrib":{"id":"idb96b39a3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2382"},"text":null,"children":[{"tag":"num","attrib":{"value":"2382"},"text":"§ 2382.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Misprision of treason","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, owing allegiance to the United States and having knowledge of the commission of any treason against them, conceals and does not, as soon as may be, disclose and make known the same to the President or to some judge of the United States, or to the governor or to some judge or justice of a particular State, is guilty of misprision of treason and shall be fined under this title or imprisoned not more than seven years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb96b39a4-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/807"},"text":"62 Stat. 807","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb96b39a5-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb96b39a6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 3 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s3"},"text":"Mar. 4, 1909, ch. 321, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1088"},"text":"35 Stat. 1088","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Mandatory punishment provision was rephrased in the alternative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb96b39a7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb96b39a8-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $1,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
