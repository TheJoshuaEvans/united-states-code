{"tag":"section","attrib":{"id":"idb96ff48f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2442"},"text":null,"children":[{"tag":"num","attrib":{"value":"2442"},"text":"§ 2442.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recruitment or use of child soldiers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb96ff490-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2442/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offense","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever knowingly—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96ff491-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2442/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruits, enlists, or conscripts a person to serve while such person is under 15 years of age in an armed force or group; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96ff492-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2442/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses a person under 15 years of age to participate actively in hostilities;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"knowing such person is under 15 years of age, shall be punished as provided in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96ff493-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2442/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever violates, or attempts or conspires to violate, subsection (a) shall be fined under this title or imprisoned not more than 20 years, or both and, if death of any person results, shall be fined under this title and imprisoned for any term of years or for life.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96ff494-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2442/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is jurisdiction over an offense described in subsection (a), and any attempt or conspiracy to commit such offense, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96ff495-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2442/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the alleged offender is a national of the United States (as defined in section 101(a)(22) of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/22"},"text":"8 U.S.C. 1101(a)(22)","children":[],"tail":")) or an alien lawfully admitted for permanent residence in the United States (as defined in section 101(a)(20) of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/20"},"text":"8 U.S.C. 1101(a)(20)","children":[],"tail":"); "},{"tag":"ref","attrib":{"idref":"fn002202"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002202"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. An additional closing parenthesis probably should precede the semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96ff496-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2442/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the alleged offender is a stateless person whose habitual residence is in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96ff497-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2442/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the alleged offender is present in the United States, irrespective of the nationality of the alleged offender; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96ff498-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2442/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense occurs in whole or in part within the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96ff499-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2442/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96ff49a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2442/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participate actively in hostilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “participate actively in hostilities” means taking part in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb96ff49b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2442/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" combat or military activities related to combat, including sabotage and serving as a decoy, a courier, or at a military checkpoint; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96ff49c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2442/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct support functions related to combat, including transporting supplies or providing other services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96ff49d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2442/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Armed force or group","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “armed force or group” means any army, militia, or other military organization, whether or not it is state-sponsored, excluding any group assembled solely for nonviolent political association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb96ff49e-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/340/s2/a/1"},"text":"Pub. L. 110–340, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3735"},"text":"122 Stat. 3735","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
