{"tag":"section","attrib":{"id":"idb8d03173-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s508"},"text":null,"children":[{"tag":"num","attrib":{"value":"508"},"text":"§ 508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation requests of Government","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever falsely makes, forges, or counterfeits in whole or in part, any form or request in similitude of the form or request provided by the Government for requesting a common carrier to furnish transportation on account of the United States or any department or agency thereof, or knowingly alters any form or request provided by the Government for requesting a common carrier to furnish transportation on account of the United States or any department or agency thereof; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever knowingly passes, utters, publishes, or sells, or attempts to pass, utter, publish, or sell, any such false, forged, counterfeited, or altered form or request—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Shall be fined under this title or imprisoned not more than ten years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8d03174-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/715"},"text":"62 Stat. 715","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8d03175-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8d03176-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 146 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-12-11/ch2/s1"},"text":"Dec. 11, 1926, ch. 2, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/917"},"text":"44 Stat. 917","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"References to persons causing, procuring, aiding or assisting were omitted as unnecessary as such persons are made principals by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Also, in first paragraph, word “agency” was substituted for “branch”, in view of definitions of department and agency in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s6"},"text":"section 6 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “upon conviction” in last paragraph were omitted as surplusage since punishment cannot be imposed until a conviction is secured.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes of phraseology were also made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8d03177-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8d03178-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $5,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
