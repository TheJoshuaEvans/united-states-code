{"tag":"section","attrib":{"id":"idb8a5510c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s35"},"text":null,"children":[{"tag":"num","attrib":{"value":"35"},"text":"§ 35.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imparting or conveying false information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8a5510d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s35/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever imparts or conveys or causes to be imparted or conveyed false information, knowing the information to be false, concerning an attempt or alleged attempt being made or to be made, to do any act which would be a crime prohibited by this chapter or chapter 97 or chapter 111 of this title shall be subject to a civil penalty of not more than $1,000 which shall be recoverable in a civil action brought in the name of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a5510e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s35/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever willfully and maliciously, or with reckless disregard for the safety of human life, imparts or conveys or causes to be imparted or conveyed false information, knowing the information to be false, concerning an attempt or alleged attempt being made or to be made, to do any act which would be a crime prohibited by this chapter or chapter 97 or chapter 111 of this title—shall be fined under this title, or imprisoned not more than five years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8a5510f-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-07-14/ch595/s1"},"text":"July 14, 1956, ch. 595, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/540"},"text":"70 Stat. 540","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/87/338"},"text":"Pub. L. 87–338","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-10-03"},"text":"Oct. 3, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/751"},"text":"75 Stat. 751","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/64"},"text":"Pub. L. 89–64","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-07"},"text":"July 7, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/210"},"text":"79 Stat. 210","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8a55110-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8a55111-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8a55112-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $5,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/64"},"text":"Pub. L. 89–64","children":[],"tail":" substituted “subject to a civil penalty of not more than $1,000 which shall be recoverable in a civil action brought in the name of the United States” for “fined not more than $1,000, or imprisoned not more than one year, or both”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1961—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/338"},"text":"Pub. L. 87–338","children":[],"tail":" designated existing provisions as subsec. (a), struck out “willfully” before “imparts or conveys”, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
