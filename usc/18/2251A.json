{"tag":"section","attrib":{"id":"idb94c3f37-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2251A"},"text":null,"children":[{"tag":"num","attrib":{"value":"2251A"},"text":"§ 2251A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selling or buying of children","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb94c3f38-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2251A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any parent, legal guardian, or other person having custody or control of a minor who sells or otherwise transfers custody or control of such minor, or offers to sell or otherwise transfer custody of such minor either—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb94c3f39-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2251A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with knowledge that, as a consequence of the sale or transfer, the minor will be portrayed in a visual depiction engaging in, or assisting another person to engage in, sexually explicit conduct; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94c3f3a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2251A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with intent to promote either—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb94c3f3b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2251A/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the engaging in of sexually explicit conduct by such minor for the purpose of producing any visual depiction of such conduct; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb94c3f3c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2251A/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rendering of assistance by the minor to any other person to engage in sexually explicit conduct for the purpose of producing any visual depiction of such conduct;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished by imprisonment for not less than 30 years or for life and by a fine under this title, if any of the circumstances described in subsection (c) of this section exist.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb94c3f3d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2251A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whoever purchases or otherwise obtains custody or control of a minor, or offers to purchase or otherwise obtain custody or control of a minor either—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb94c3f3e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2251A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with knowledge that, as a consequence of the purchase or obtaining of custody, the minor will be portrayed in a visual depiction engaging in, or assisting another person to engage in, sexually explicit conduct; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94c3f3f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2251A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with intent to promote either—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb94c3f40-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2251A/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the engaging in of sexually explicit conduct by such minor for the purpose of producing any visual depiction of such conduct; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb94c3f41-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2251A/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rendering of assistance by the minor to any other person to engage in sexually explicit conduct for the purpose of producing any visual depiction of such conduct;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished by imprisonment for not less than 30 years or for life and by a fine under this title, if any of the circumstances described in subsection (c) of this section exist.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb94c3f42-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2251A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The circumstances referred to in subsections (a) and (b) are that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb94c3f43-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2251A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the course of the conduct described in such subsections the minor or the actor traveled in or was transported in or affecting interstate or foreign commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94c3f44-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2251A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any offer described in such subsections was communicated or transported using any means or facility of interstate or foreign commerce or in or affecting interstate or foreign commerce by any means including by computer or mail; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94c3f45-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2251A/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct described in such subsections took place in any territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb94c3f46-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7512/a"},"text":"Pub. L. 100–690, title VII, § 7512(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4486"},"text":"102 Stat. 4486","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/21/tI/s103/b/1/B"},"text":"Pub. L. 108–21, title I, § 103(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-30"},"text":"Apr. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/653"},"text":"117 Stat. 653","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/358/tI/s103/a/2"},"text":"Pub. L. 110–358, title I, § 103(a)(2)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2008-10-08"},"text":"Oct. 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4002"},"text":"122 Stat. 4002","children":[],"tail":", 4003.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb94c3f47-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb94c3f48-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb94c3f49-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/358/s103/b"},"text":"Pub. L. 110–358, § 103(b)","children":[],"tail":", substituted “in or affecting interstate” for “in interstate” in pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/358/s103/a/2"},"text":"Pub. L. 110–358, § 103(a)(2)","children":[],"tail":", inserted “using any means or facility of interstate or foreign commerce or” after “or transported”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21"},"text":"Pub. L. 108–21","children":[],"tail":" substituted “30 years” for “20 years” in concluding provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
