{"tag":"section","attrib":{"id":"idb8bd1f31-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s213"},"text":null,"children":[{"tag":"num","attrib":{"value":"213"},"text":"§ 213.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of loan or gratuity by financial institution examiner","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8bd1f32-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s213/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever, being an examiner or assistant examiner, accepts a loan or gratuity from any bank, branch, agency, organization, corporation, association, or institution examined by the examiner or from any person connected with it, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8bd1f33-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s213/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be fined under this title, imprisoned not more than 1 year, or both;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bd1f34-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s213/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be fined a further sum equal to the money so loaned or gratuity given; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bd1f35-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s213/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be disqualified from holding office as an examiner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8bd1f36-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s213/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the terms “examiner”, “Federal financial institution regulatory agency”, “financial institution”, and “loan” have the same meanings as in section 212.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8bf9037-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/198/s2/a"},"text":"Pub. L. 108–198, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2900"},"text":"117 Stat. 2900","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8bf9038-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8bf9039-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb8bf903a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 213, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/695"},"text":"62 Stat. 695","childr