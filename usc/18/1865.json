l:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/94/429/s13/d"},"text":"Pub. L. 94–429, § 13(d)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Sept. 28, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/1345"},"text":"90 Stat. 1345","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1865(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s413"},"text":"16 U.S.C. 413","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1897-03-03/ch372"},"text":"Mar. 3, 1897, ch. 372","children":[],"tail":", §§ 1, 2, 5, "},{"tag":"html:a","attrib":{"href":"/us/stat/29/621"},"text":"29 Stat. 621","children":[],"tail":", 622."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1865(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t16/s414"},"text":"16 U.S.C. 414","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “fined under this title” are substituted for “punished by a fine of not more than $500” for consistency with chapter 227.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “fined under this title” are substituted for “fined not more than $2,500” for consistency with chapter 227.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “fined under this title but not less than $10” are substituted for “deemed guilty of a misdemeanor, punishable by a fine of not less than $10 nor more than $1,000” for consistency with chapter 227.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “fined under this title” are substituted for “guilty of a misdemeanor, punishable by a fine of not more than $1,000” for consistency with chapter 227.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
