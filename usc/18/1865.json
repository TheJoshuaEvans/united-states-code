{"tag":"section","attrib":{"id":"idb936bb8c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1865"},"text":null,"children":[{"tag":"num","attrib":{"value":"1865"},"text":"§ 1865.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Park Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb936bb8d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1865/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Violation of Regulations Relating to Use and Management of National Park System Units","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person that violates any regulation authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s100751/a"},"text":"section 100751(a) of title 54","children":[],"tail":" shall be imprisoned not more than 6 months, fined under this title, or both, and be adjudged to pay all cost of the proceedings."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb936bb8e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1865/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Financial Disclosure by Officers or Employees Performing Functions or Duties Under Subchapter III of Chapter ","children":[],"tail":"1007"},{"tag":"inline","attrib":{},"text":" of Title ","children":[],"tail":"54.—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer or employee of the Department of the Interior who is subject to, and knowingly violates, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s100737"},"text":"section 100737 of title 54","children":[],"tail":" or any regulation prescribed under that section shall be imprisoned not more than one year, fined under this title, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb936bb8f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1865/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offenses Relating to Structures and Vegetation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person that willfully destroys, mutilates, defaces, injures, or removes any monument, statue, marker, guidepost, or other structure, or that willfully destroys, cuts, breaks, injures, or removes any tree, shrub, or plant within a national military park shall be imprisoned not less than 15 days nor more than one year, fined under this title but not less than $10 for each monument, statue, marker, guidepost, or other structure, tree, shrub, or plant that is destroyed, defaced, injured, cut, or removed, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb936bb90-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1865/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Trespassing in a National Military Park To Hunt or Shoot","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual who trespasses in a national military park to hunt or shoot, or hunts game of any kind in a national military park with a gun or dog, or sets a trap or net or other device in a national military park to hunt or catch game of any kind, shall be imprisoned not less than 5 nor more than 30 days, fined under this title, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb936bb91-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s4/a/1"},"text":"Pub. L. 113–287, § 4(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3260"},"text":"128 Stat. 3260","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb936bb92-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb936bb93-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb936bb94-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":