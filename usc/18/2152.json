{"tag":"section","attrib":{"id":"idb94513c5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2152"},"text":null,"children":[{"tag":"num","attrib":{"value":"2152"},"text":"§ 2152.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fortifications, harbor defenses, or defensive sea areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever willfully trespasses upon, injures, or destroys any of the works or property or material of any submarine mine or torpedo or fortification or harbor-defense system owned or constructed or in process of construction by the United States; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever willfully interferes with the operation or use of any such submarine mine, torpedo, fortification, or harbor-defense system; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever knowingly, willfully, or wantonly violates any duly authorized and promulgated order or regulation of the President governing persons or vessels within the limits of defensive sea areas, which the President, for purposes of national defense, may from time to time establish by executive order—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Shall be fined under this title or imprisoned not more than five years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb94513c6-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/799"},"text":"62 Stat. 799","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb94513c7-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb94513c8-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 96 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s44"},"text":"Mar. 4, 1909, ch. 321, § 44","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1097"},"text":"35 Stat. 1097","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1917-03-04/ch180"},"text":"Mar. 4, 1917, ch. 180","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/1194"},"text":"39 Stat. 1194","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1917-05-22/ch20/s19"},"text":"May 22, 1917, ch. 20, § 19","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/89"},"text":"40 Stat. 89","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Jurisdiction and venue provisions were omitted as unnecessary and inconsistent with Rule 18 of the Federal Rules of Criminal Procedure providing for prosecution where the offense is committed, and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3238"},"text":"section 3238 of this title","children":[],"tail":" providing that trial of offenses committed outside any district shall be in the district where the offender is found, or into which he is first brought."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “on conviction thereof” were omitted as surplusage as punishment cannot be imposed until conviction is had.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb94513c9-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb94513ca-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $5,000” in last par."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb94513cb-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"idb94513cc-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Executive Order No. 10361","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 10361, ","children":[{"tag":"date","attrib":{"date":"1952-06-12"},"text":"June 12, 1952","children":[],"tail":", 17 F.R. 5357, formerly set out under this section, which established the Whittier Defensive Sea Area, Alaska, was revoked by Ex. Ord. No. 11549, "},{"tag":"date","attrib":{"date":"1970-07-28"},"text":"July 28, 1970","children":[],"tail":", 35 F.R. 12191."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
