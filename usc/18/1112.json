{"tag":"section","attrib":{"id":"idb91307e5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1112"},"text":null,"children":[{"tag":"num","attrib":{"value":"1112"},"text":"§ 1112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manslaughter","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb91307e6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Manslaughter is the unlawful killing of a human being without malice. It is of two kinds:","children":[{"tag":"p","attrib":{"role":"listItem"},"text":"Voluntary—Upon a sudden quarrel or heat of passion.","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"Involuntary—In the commission of an unlawful act not amounting to a felony, or in the commission in an unlawful manner, or without due caution and circumspection, of a lawful act which might produce death.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91307e7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within the special maritime and territorial jurisdiction of the United States,","children":[{"tag":"p","attrib":{},"text":"Whoever is guilty of voluntary manslaughter, shall be fined under this title or imprisoned not more than 15 years, or both;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever is guilty of involuntary manslaughter, shall be fined under this title or imprisoned not more than 8 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb91307e8-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/756"},"text":"62 Stat. 756","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXII/s320102"},"text":"Pub. L. 103–322, title XXXII, § 320102","children":[],"tail":", title XXXIII, § 330016(1)(H), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2109"},"text":"108 Stat. 2109","children":[],"tail":", 2147; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s604/b/13"},"text":"Pub. L. 104–294, title VI, § 604(b)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3507"},"text":"110 Stat. 3507","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/177/tII/s207"},"text":"Pub. L. 110–177, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-07"},"text":"Jan. 7, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2538"},"text":"121 Stat. 2538","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91307e9-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb91307ea-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., §§ 453, 454 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321"},"text":"Mar. 4, 1909, ch. 321","children":[],"tail":", §§ 274, 275, "},{"tag":"ref","attrib":{"href":"/us/stat/35/1143"},"text":"35 Stat. 1143","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section consolidates punishment provisions of sections 453 and 454 of title 18, U.S.C., 1940 ed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The special maritime and territorial jurisdiction provision was added in view of definitive section 7 this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb91307eb-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb91307ec-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/177"},"text":"Pub. L. 110–177","children":[],"tail":" substituted “15 years” for “ten years” in second par. and “8 years” for “six years” in last par."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/s320102/2"},"text":"Pub. L. 103–322, § 320102(2)","children":[],"tail":". See 1994 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/1/H"},"text":"Pub. L. 103–322, § 330016(1)(H)","children":[],"tail":", substituted “fined under this title” for “fined not more than $1,000” in last par."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s320102/3"},"text":"Pub. L. 103–322, § 320102(3)","children":[],"tail":", substituted “six years” for “three years” in last par."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s320102/2"},"text":"Pub. L. 103–322, § 320102(2)","children":[],"tail":", which provided for amendment identical to "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/1/H"},"text":"Pub. L. 103–322, § 330016(1)(H)","children":[],"tail":", above, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/s604/b/13"},"text":"Pub. L. 104–294, § 604(b)(13)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s320102/1/B"},"text":"Pub. L. 103–322, § 320102(1)(B)","children":[],"tail":", which directed the amendment of subsec. (b) by inserting “, or both” after “years”, was executed by inserting the material after “years” in second par., which was the first place the word appeared in text, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s320102/1/A"},"text":"Pub. L. 103–322, § 320102(1)(A)","children":[],"tail":", inserted “fined under this title or” after “shall be” in second par."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb91307ed-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb91307ee-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/s604/d"},"text":"section 604(d) of Pub. L. 104–294","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s13"},"text":"section 13 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
