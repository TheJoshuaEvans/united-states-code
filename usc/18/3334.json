{"tag":"section","attrib":{"id":"idb99ad543-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3334"},"text":null,"children":[{"tag":"num","attrib":{"value":"3334"},"text":"§ 3334.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of chapter 215, title 18, United States Code, and the Federal Rules of Criminal Procedure applicable to regular grand juries shall apply to special grand juries to the extent not inconsistent with sections 3331, 3332, or 3333 of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb99ad544-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/452/tI/s101/a"},"text":"Pub. L. 91–452, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-15"},"text":"Oct. 15, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/926"},"text":"84 Stat. 926","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
