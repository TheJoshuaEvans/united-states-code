{"tag":"section","attrib":{"id":"idb955b596-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2263"},"text":null,"children":[{"tag":"num","attrib":{"value":"2263"},"text":"§ 2263.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pretrial release of defendant","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In any proceeding pursuant to section 3142 for the purpose of determining whether a defendant charged under this chapter shall be released pending trial, or for the purpose of determining conditions of such release, the alleged victim shall be given an opportunity to be heard regarding the danger posed by the defendant.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb955b597-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s40221/a"},"text":"Pub. L. 103–322, title IV, § 40221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1928"},"text":"108 Stat. 1928","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
