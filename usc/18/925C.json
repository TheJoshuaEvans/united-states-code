{"tag":"section","attrib":{"id":"idb8fb12a8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s925C"},"text":null,"children":[{"tag":"num","attrib":{"value":"925C"},"text":"§ 925C.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report to Congress","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of enactment of this section, and annually thereafter, the Attorney General shall submit to Congress a report detailing the following, broken down by Federal judicial district:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fb12a9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s925C/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to each category of persons prohibited by subsection (g) or (n) of section 922 or State law from receiving or possessing a firearm who are so denied a firearm—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8fb12aa-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s925C/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of denials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fb12ab-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s925C/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of denials referred to the Bureau of Alcohol, Tobacco, Firearms, and Explosives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fb12ac-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s925C/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of denials for which the Bureau of Alcohol, Tobacco, Firearms, and Explosives determines that the person denied was not prohibited by subsection (g) or (n) of section 922 or State law from receiving or possessing a firearm;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fb12ad-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s925C/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of denials overturned through the appeals process of the national instant criminal background check system established under section 103 of the Brady Handgun Violence Prevention Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s40901"},"text":"34 U.S.C. 40901","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fb12ae-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s925C/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of denials with respect to which an investigation was opened by a field division of the Bureau of Alcohol, Tobacco, Firearms, and Explosives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fb12af-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s925C/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of persons charged with a Federal criminal offense in connection with a denial; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fb12b0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s925C/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of convictions obtained by Federal authorities in connection with a denial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fb12b1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s925C/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of background check notices reported pursuant to section 925B (including the number of the notices that would have been so reported but for section 925B(c)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8fb12b2-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tXI/s1102/a"},"text":"Pub. L. 117–103, div. W, title XI, § 1102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/920"},"text":"136 Stat. 920","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8fb12b3-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8fb12b4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8fb12b5-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in text, is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8fb12b6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8fb12b7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section not effective until Oct. 1 of the first fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s4/a"},"text":"section 4(a) of div. W of Pub. L. 117–103","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6851"},"text":"section 6851 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
