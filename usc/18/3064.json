{"tag":"section","attrib":{"id":"idb98a32e9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3064"},"text":null,"children":[{"tag":"num","attrib":{"value":"3064"},"text":"§ 3064.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of Federal Motor Carrier Safety Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Authorized employees of the Federal Motor Carrier Safety Administration may direct a driver of a commercial motor vehicle (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s31132"},"text":"section 31132 of title 49","children":[],"tail":") to stop for inspection of the vehicle, driver, cargo, and required records at or in the vicinity of an inspection site."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb98a32ea-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIV/s4143/b"},"text":"Pub. L. 109–59, title IV, § 4143(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1748"},"text":"119 Stat. 1748","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
