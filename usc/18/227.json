{"tag":"section","attrib":{"id":"idb8bf90bd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s227"},"text":null,"children":[{"tag":"num","attrib":{"value":"227"},"text":"§ 227.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wrongfully influencing a private entity’s employment decisions by a Member of Congress or an officer or employee of the legislative or executive branch","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8bf90be-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s227/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whoever, being a covered government person, with the intent to influence, solely on the basis of partisan political affiliation, an employment decision or employment practice of any private entity—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8bf90bf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s227/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" takes or withholds, or offers or threatens to take or withhold, an official act, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf90c0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s227/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" influences, or offers or threatens to influence, the official act of another,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title or imprisoned for not more than 15 years, or both, and may be disqualified from holding any office of honor, trust, or profit under the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8bf90c1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s227/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section, the term “covered government person” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8bf90c2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s227/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Senator or Representative in, or a Delegate or Resident Commissioner to, the Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf90c3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s227/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee of either House of Congress; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf90c4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s227/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President, Vice President, an employee of the United States Postal Service or the Postal Regulatory Commission, or any other executive branch employee (as such term is defined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of title 5","children":[],"tail":", United States Code)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8bf90c5-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/tI/s102/a"},"text":"Pub. L. 110–81, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/739"},"text":"121 Stat. 739","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/105/s18/a"},"text":"Pub. L. 112–105, § 18(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-04-04"},"text":"Apr. 4, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/304"},"text":"126 Stat. 304","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8bf90c6-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8bf90c7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8bf90c8-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/105"},"text":"Pub. L. 112–105","children":[],"tail":" inserted “or an officer or employee of the legislative or executive branch” after “Congress” in section catchline, designated existing provisions as subsec. (a), substituted “a covered government person” for “a Senator or Representative in, or a Delegate or Resident Commissioner to, the Congress or an employee of either House of Congress” in introductory provisions, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8bf90c9-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8bf90ca-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},