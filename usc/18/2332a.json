{"tag":"section","attrib":{"id":"idb9640cfe-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2332a"},"text":"§ 2332a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of weapons of mass destruction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9640cff-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offense Against a National of the United States or Within the United States","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person who, without lawful authority, uses, threatens, or attempts or conspires to use, a weapon of mass destruction—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9640d00-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" against a national of the United States while such national is outside of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9640d01-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" against any person or property within the United States, and","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9640d02-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the mail or any facility of interstate or foreign commerce is used in furtherance of the offense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9640d03-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such property is used in interstate or foreign commerce or in an activity that affects interstate or foreign commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9640d04-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any perpetrator travels in or causes another to travel in interstate or foreign commerce in furtherance of the offense; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9640d05-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332a/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense, or the results of the offense, affect interstate or foreign commerce, or, in the case of a threat, attempt, or conspiracy, would have affected interstate or foreign commerce;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9640d06-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" against any property that is owned, leased or used by the United States or by any department or agency of the United States, whether the property is within or outside of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9640d07-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" against any property within the United States that is owned, leased, or used by a foreign government,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be imprisoned for any term of years or for life, and if death results, shall be punished by death or imprisoned for any term of years or for life.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9640d08-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offense by National of the United States Outside of the United States","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any national of the United States who, without lawful authority, uses, or threatens, attempts, or conspires to use, a weapon of mass destruction outside of the United States shall be imprisoned for any term of years or for life, and if death results, shall be punished by death, or by imprisonment for any term of years or for life.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9640d09-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9640d0a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “national of the United States” has the meaning given in section 101(a)(22) of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/22"},"text":"8 U.S.C. 1101(a)(22)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9640d0b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “weapon of mass destruction” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9640d0c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any destructive device as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s921"},"text":"section 921 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9640d0d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any weapon that is designed or intended to cause death or serious bodily injury through the release, dissemination, or impact of toxic or poisonous chemicals, or their precursors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9640d0e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any weapon involving a biological agent, toxin, or vector (as those terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s178"},"text":"section 178 of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9640d0f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332a/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any weapon that is designed to release radiation or radioactivity at a level dangerous to human life; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9640d10-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “property” includes all real and personal property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9640d11-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tVI/s60023/a"},"text":"Pub. L. 103–322, title VI, § 60023(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1980"},"text":"108 Stat. 1980","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tV/s511/c"},"text":"Pub. L. 104–132, title V, § 511(c)","children":[],"tail":", title VII, § 725, "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1284"},"text":"110 Stat. 1284","children":[],"tail":", 1300; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s605/m"},"text":"Pub. L. 104–294, title VI, § 605(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3510"},"text":"110 Stat. 3510","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dI/tII/s201/b/1"},"text":"Pub. L. 105–277, div. I, title II, § 201(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-871"},"text":"112 Stat. 2681–871","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/188/tII/s231/d"},"text":"Pub. L. 107–188, title II, § 231(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-12"},"text":"June 12, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/661"},"text":"116 Stat. 661","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tVI/s6802/a"},"text":"Pub. L. 108–458, title VI, § 6802(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3766"},"text":"118 Stat. 3766","children":[],"tail":", 3767.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9640d12-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9640d13-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9640d14-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s6802/b/1"},"text":"Pub. L. 108–458, § 6802(b)(1)","children":[],"tail":", struck out “certain” before “weapons” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s6802/b/2"},"text":"Pub. L. 108–458, § 6802(b)(2)","children":[],"tail":", struck out “(other than a chemical weapon as that term is defined in section 229F)” after “mass destruction” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s6802/a/1"},"text":"Pub. L. 108–458, § 6802(a)(1)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “against any person within the United States, and the results of such use affect interstate or foreign commerce or, in the case of a threat, attempt, or conspiracy, would have affected interstate or foreign commerce; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s6802/a/2"},"text":"Pub. L. 108–458, § 6802(a)(2)","children":[],"tail":", (3), added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s6802/b/3"},"text":"Pub. L. 108–458, § 6802(b)(3)","children":[],"tail":", struck out “(other than a chemical weapon (as that term is defined in section 229F))” after “mass destruction”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s6802/a/4"},"text":"Pub. L. 108–458, § 6802(a)(4)","children":[],"tail":"–(6), added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/188/s231/d/1"},"text":"Pub. L. 107–188, § 231(d)(1)","children":[],"tail":", substituted “section 229F)—” for “section 229F), including any biological agent, toxin, or vector (as those terms are defined in section 178)—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/188/s231/d/2"},"text":"Pub. L. 107–188, § 231(d)(2)","children":[],"tail":", substituted “a biological agent, toxin, or vector (as those terms are defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s178"},"text":"section 178 of this title","children":[],"tail":")” for “a disease organism”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s201/b/1/A"},"text":"Pub. L. 105–277, § 201(b)(1)(A)","children":[],"tail":", inserted “certain” before “weapons” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s201/b/1/B"},"text":"Pub. L. 105–277, § 201(b)(1)(B)","children":[],"tail":", inserted “(other than a chemical weapon as that term is defined in section 229F)” after “weapon of mass destruction” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s201/b/1/C"},"text":"Pub. L. 105–277, § 201(b)(1)(C)","children":[],"tail":", inserted “(other than a chemical weapon (as that term is defined in section 229F))” after “weapon of mass destruction”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132"},"text":"Pub. L. 104–132","children":[],"tail":", §§ 511(c), 725(1)(A), (B), in heading, inserted “"},{"tag":"inline","attrib":{},"text":"Against a National of the United States or Within the United States","children":[],"tail":"” after “"},{"tag":"inline","attrib":{},"text":"Offense","children":[],"tail":"”, and in introductory provisions, substituted “, without lawful authority, uses, threatens, or attempts” for “uses, or attempts” and inserted “, including any biological agent, toxin, or vector (as those terms are defined in section 178)” after “mass destruction”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s725/1/C"},"text":"Pub. L. 104–132, § 725(1)(C)","children":[],"tail":", inserted before semicolon at end “, and the results of such use affect interstate or foreign commerce or, in the case of a threat, attempt, or conspiracy, would have affected interstate or foreign commerce”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s725/4"},"text":"Pub. L. 104–132, § 725(4)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s725/2"},"text":"Pub. L. 104–132, § 725(2)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/s605/m"},"text":"Pub. L. 104–294, § 605(m)","children":[],"tail":", added subpar. (B) and struck out former subpar. (B) which read as follows: “poison gas;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s725/3"},"text":"Pub. L. 104–132, § 725(3)","children":[],"tail":", redesignated subsec. (b) as (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
