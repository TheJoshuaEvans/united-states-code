{"tag":"section","attrib":{"id":"idb8bd1f14-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s212"},"text":null,"children":[{"tag":"num","attrib":{"value":"212"},"text":"§ 212.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offer of loan or gratuity to financial institution examiner","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8bd1f15-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s212/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), whoever, being an officer, director, or employee of a financial institution, makes or grants any loan or gratuity, to any examiner or assistant examiner who examines or has authority to examine such bank, branch, agency, organization, corporation, association, or institution—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8bd1f16-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s212/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be fined under this title, imprisoned not more than 1 year, or both; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bd1f17-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s212/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be fined a further sum equal to the money so loaned or gratuity given.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8bd1f18-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s212/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Federal financial institution regulatory agency may prescribe regulations establishing additional limitations on the application for and receipt of credit under this section and on the application and receipt of residential mortgage loans under this section, after consulting with each other Federal financial institution regulatory agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8bd1f19-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s212/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8bd1f1a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s212/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Examiner","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “examiner” means any person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8bd1f1b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s212/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appointed by a Federal financial institution regulatory agency or pursuant to the laws of any State to examine a financial institution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8bd1f1c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s212/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elected under the law of any State to conduct examinations of any financial institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bd1f1d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s212/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal financial institution regulatory agency","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal financial institution regulatory agency” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8bd1f1e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s212/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of the Comptroller of the Currency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8bd1f1f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s212/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board of Governors of the Federal Reserve System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8bd1f20-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s212/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Deposit Insurance Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8bd1f21-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s212/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Housing Finance Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8bd1f22-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s212/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Farm Credit Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8bd1f23-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s212/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Farm Credit System Insurance Corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8bd1f24-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s212/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Small Business Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bd1f25-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s212/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Financial institution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “financial institution” does not include a credit union, a Federal Reserve Bank, a Federal home loan bank, or a depository institution holding company.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bd1f26-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s212/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Loan","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “loan” does not include any credit card account established under an open end consumer credit plan or a loan secured by residential real property that is the principal residence of the examiner, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8bd1f27-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s212/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant satisfies any financial requirements for the credit card account or residential real property loan that are generally applicable to all applicants for the same type of credit card account or residential real property loan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8bd1f28-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s212/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms and conditions applicable with respect to such account or residential real property loan, and any credit extended to the examiner under such account or residential real property loan, are no more favorable generally to the examiner than the terms and conditions that are generally applicable to credit card accounts or residential real property loans offered by the same financial institution to other borrowers cardholders ","children":[{"tag":"ref","attrib":{"idref":"fn002028"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002028"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" in comparable circumstances under open end consumer credit plans or for residential real property loans; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8bd1f29-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s212/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to residential real property loans, the loan is with respect to the primary residence of the applicant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8bd1f2a-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/198/s2/a"},"text":"Pub. L. 108–198, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2899"},"text":"117 Stat. 2899","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tII/s1216/c"},"text":"Pub. L. 110–289, div. A, title II, § 1216(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2792"},"text":"122 Stat. 2792","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIII/s377/1"},"text":"Pub. L. 111–203, title III, § 377(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1569"},"text":"124 Stat. 1569","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8bd1f2b-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8bd1f2c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb8bd1f2d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 212, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/694"},"text":"62 Stat. 694","children":[],"tail":", § 212, formerly § 217; "},{"tag":"ref","attrib":{"href":"/us/pl/85/699/tVII/s701/a"},"text":"Pub. L. 85–699, title VII, § 701(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-21"},"text":"Aug. 21, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/698"},"text":"72 Stat. 698","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/168/tI/s104/h"},"text":"Pub. L. 86–168, title I, § 104(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-08-18"},"text":"Aug. 18, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/387"},"text":"73 Stat. 387","children":[],"tail":"; renumbered § 212, "},{"tag":"ref","attrib":{"href":"/us/pl/87/849/s1/d"},"text":"Pub. L. 87–849, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-23"},"text":"Oct. 23, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1125"},"text":"76 Stat. 1125","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tIX/s962/a/1"},"text":"Pub. L. 101–73, title IX, § 962(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/501"},"text":"103 Stat. 501","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV/s2597/b"},"text":"Pub. L. 101–647, title XXV, § 2597(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4908"},"text":"104 Stat. 4908","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII"},"text":"Pub. L. 103–322, title XXXIII","children":[],"tail":", §§ 330004(1), 330010(1), 330016(1)(K), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2141"},"text":"108 Stat. 2141","children":[],"tail":", 2143, 2147, related to offer of loan or gratuity to bank examiner, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/108/198/s2/a"},"text":"Pub. L. 108–198, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2899"},"text":"117 Stat. 2899","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 212, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"act June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/693"},"text":"62 Stat. 693","children":[],"tail":", related to an offer or threat to a customs officer or employee, prior to the general amendment to this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/87/849"},"text":"Pub. L. 87–849","children":[],"tail":" and is substantially covered by revised section 201."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8bd1f2e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (c)(2)(C) to (H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" redesignated subpars. (D) to (H) as (C) to (G), respectively, and struck out former subpar. (C) which read as follows: “the Office of Thrift Supervision;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (c)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289"},"text":"Pub. L. 110–289","children":[],"tail":" substituted “Federal Housing Finance Agency” for “Federal Housing Finance Board”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8bd1f2f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8bd1f30-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s351"},"text":"section 351 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s906"},"text":"section 906 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
