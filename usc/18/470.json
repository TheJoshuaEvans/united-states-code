{"tag":"section","attrib":{"id":"idb8cb7759-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s470"},"text":null,"children":[{"tag":"num","attrib":{"value":"470"},"text":"§ 470.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counterfeit acts committed outside the United States","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A person who, outside the United States, engages in the act of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8cb775a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s470/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making, dealing, or possessing any counterfeit obligation or other security of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8cb775b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s470/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making, dealing, or possessing any plate, stone, analog, digital, or electronic image, or other thing, or any part thereof, used to counterfeit such obligation or security,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"if such act would constitute a violation of section 471, 473, or 474 if committed within the United States, shall be punished as is provided for the like offense within the United States.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8cb775c-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXII/s120003/a"},"text":"Pub. L. 103–322, title XII, § 120003(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2021"},"text":"108 Stat. 2021","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tIII/s374/a"},"text":"Pub. L. 107–56, title III, § 374(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/340"},"text":"115 Stat. 340","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8cb775d-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8cb775e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8cb775f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/s374/a/2"},"text":"Pub. L. 107–56, § 374(a)(2)","children":[],"tail":", in concluding provisions, substituted “shall be punished as is provided for the like offense within the United States” for “shall be fined under this title, imprisoned not more than 20 years, or both”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/s374/a/1"},"text":"Pub. L. 107–56, § 374(a)(1)","children":[],"tail":", inserted “analog, digital, or electronic image,” after “plate, stone,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8cb7760-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb8cb7761-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXV/s1551"},"text":"Pub. L. 102–550, title XV, § 1551","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4070"},"text":"106 Stat. 4070","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/550/tXV/s1551"},"text":"“This subtitle [subtitle E (§§ 1551–1554) of title XV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":", enacting "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s474A"},"text":"section 474A of this title","children":[],"tail":" and amending sections 474 and 504 of this title] may be cited as the ‘Counterfeit Deterrence Act of 1992’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8cb7762-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Combatting International Counterfeiting of United States Currency","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/tVIII/s807"},"text":"Pub. L. 104–132, title VIII, § 807","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1308"},"text":"110 Stat. 1308","children":[],"tail":", which directed the Secretary of the Treasury, in consultation with the advanced counterfeit deterrence steering committee, to study the use and counterfeiting of United States currency abroad, develop an evaluation audit plan, and submit written reports to Congress, ceased to be effective on "},{"tag":"date","attrib":{"date":"2006-04-24"},"text":"Apr. 24, 2006","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
