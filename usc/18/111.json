{"tag":"section","attrib":{"id":"idb8ac7d2a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s111"},"text":null,"children":[{"tag":"num","attrib":{"value":"111"},"text":"§ 111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assaulting, resisting, or impeding certain officers or employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8ac7d2b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8ac7d2c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s111/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forcibly assaults, resists, opposes, impedes, intimidates, or interferes with any person designated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1114"},"text":"section 1114 of this title","children":[],"tail":" while engaged in or on account of the performance of official duties; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8ac7d2d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s111/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forcibly assaults or intimidates any person who formerly served as a person designated in section 1114 on account of the performance of official duties during such person’s term of service,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall, where the acts in violation of this section constitute only simple assault, be fined under this title or imprisoned not more than one year, or both, and where such acts involve physical contact with the victim of that assault or the intent to commit another felony, be fined under this title or imprisoned not more than 8 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8ac7d2e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enhanced Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever, in the commission of any acts described in subsection (a), uses a deadly or dangerous weapon (including a weapon intended to cause death or danger but that fails to do so by reason of a defective component) or inflicts bodily injury, shall be fined under this title or imprisoned not more than 20 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8ac7d2f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s111/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extraterritorial Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is extraterritorial jurisdiction over the conduct prohibited by this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8ac7d30-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/688"},"text":"62 Stat. 688","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI/s6487/a"},"text":"Pub. L. 100–690, title VI, § 6487(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4386"},"text":"102 Stat. 4386","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXII/s320101/a"},"text":"Pub. L. 103–322, title XXXII, § 320101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2108"},"text":"108 Stat. 2108","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tVII/s727/c"},"text":"Pub. L. 104–132, title VII, § 727(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1302"},"text":"110 Stat. 1302","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tI/s11008/b"},"text":"Pub. L. 107–273, div. C, title I, § 11008(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1818"},"text":"116 Stat. 1818","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/177/tII/s208/b"},"text":"Pub. L. 110–177, title II, § 208(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-07"},"text":"Jan. 7, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2538"},"text":"121 Stat. 2538","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/59/s3/1"},"text":"Pub. L. 117–59, § 3(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-18"},"text":"Nov. 18, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1469"},"text":"135 Stat. 1469","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8ac7d31-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8ac7d32-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., §§ 118, 254 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s62"},"text":"Mar. 4, 1909, ch. 321, § 62","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1100"},"text":"35 Stat. 1100","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1934-05-18/ch299/s2"},"text":"May 18, 1934, ch. 299, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/781"},"text":"48 Stat. 781","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section consolidates sections 118 and 254 with changes in phraseology and substance necessary to effect the consolidation.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Also the words “Bureau of Animal Industry of the Department of Agriculture” appearing in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s118"},"text":"section 118 of title 18","children":[],"tail":", U.S.C., 1940 ed., were inserted in enumeration of Federal officers and employees in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1114"},"text":"section 1114 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The punishment provision of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s254"},"text":"section 254 of title 18","children":[],"tail":", U.S.C., 1940 ed., was adopted as the latest expression of Congressional intent. This consolidation eliminates a serious incongruity in punishment and application."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8ac7d33-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8ac7d34-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/59"},"text":"Pub. L. 117–59","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/177"},"text":"Pub. L. 110–177","children":[],"tail":" substituted “where such acts involve physical contact with the victim of that assault or the intent to commit another felony” for “in all other cases” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s11008/b/1"},"text":"Pub. L. 107–273, § 11008(b)(1)","children":[],"tail":", substituted “8” for “three” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s11008/b/2"},"text":"Pub. L. 107–273, § 11008(b)(2)","children":[],"tail":", substituted “20” for “ten”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132"},"text":"Pub. L. 104–132","children":[],"tail":" inserted “(including a weapon intended to cause death or danger but that fails to do so by reason of a defective component)” after “deadly or dangerous weapon”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s320101/a/1"},"text":"Pub. L. 103–322, § 320101(a)(1)","children":[],"tail":", inserted “, where the acts in violation of this section constitute only simple assault, be fined under this title or imprisoned not more than one year, or both, and in all other cases,” after “shall” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s320101/a/2"},"text":"Pub. L. 103–322, § 320101(a)(2)","children":[],"tail":", inserted “or inflicts bodily injury” after “weapon”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" amended text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Whoever forcibly assaults, resists, opposes, impedes, intimidates, or interferes with any person designated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1114"},"text":"section 1114 of this title","children":[],"tail":" while engaged in or on account of the performance of his official duties, shall be fined not more than $5,000 or imprisoned not more than three years, or both."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Whoever, in the commission of any such acts uses a deadly or dangerous weapon, shall be fined not more than $10,000 or imprisoned not more than ten years, or both.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8ac7d35-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb8ac7d36-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tI/s11008/a"},"text":"Pub. L. 107–273, div. C, title I, § 11008(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1818"},"text":"116 Stat. 1818","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/273/dC/tI/s11008/a"},"text":"“This section [amending this section, sections 115 and 876 of this title, and provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s994"},"text":"section 994 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure] may be cited as the ‘Federal Judiciary Protection Act of 2002’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8ac7d37-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Sense of Congress Regarding Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/59"},"text":"Pub. L. 117–59","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"For sense of Congress regarding amendment to this section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/59"},"text":"Pub. L. 117–59","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/59/s2/6"},"text":"section 2(6) of Pub. L. 117–59","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1114"},"text":"section 1114 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
