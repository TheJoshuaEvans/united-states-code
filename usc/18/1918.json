{"tag":"section","attrib":{"id":"idb9392d11-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1918"},"text":null,"children":[{"tag":"num","attrib":{"value":"1918"},"text":"§ 1918.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disloyalty and asserting the right to strike against the Government","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Whoever violates the provision of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7311"},"text":"section 7311 of title 5","children":[],"tail":" that an individual may not accept or hold a position in the Government of the United States or the government of the District of Columbia if he—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9392d12-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1918/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advocates the overthrow of our constitutional form of government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9392d13-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1918/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a member of an organization that he knows advocates the overthrow of our constitutional form of government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9392d14-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1918/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participates in a strike, or asserts the right to strike, against the Government of the United States or the government of the District of Columbia; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9392d15-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1918/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a member of an organization of employees of the Government of the United States or of individuals employed by the government of the District of Columbia that he knows asserts the right to strike against the Government of the United States or the government of the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title or imprisoned not more than one year and a day, or both.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9392d16-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s3/d"},"text":"Pub. L. 89–554, § 3(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/609"},"text":"80 Stat. 609","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s601/a/8"},"text":"Pub. L. 104–294, title VI, § 601(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3498"},"text":"110 Stat. 3498","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9392d17-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9392d18-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb9392d19-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":n