"children":[],"tail":", are omitted as executed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “shall be guilty of a felony” are omitted as unnecessary in view of the definitive ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1"},"text":"section 1 of this title","children":[],"tail":". (See reviser’s note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s550"},"text":"section 550 of this title","children":[],"tail":".)"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9392d1a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9392d1b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" substituted “fined under this title” for “fined not more than $1,000” in concluding provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
