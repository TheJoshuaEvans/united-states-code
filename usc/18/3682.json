{"tag":"section","attrib":{"id":"idb9beb103-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3682"},"text":null,"children":[{"tag":"num","attrib":{"value":"3682"},"text":"§ 3682.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to victims of order of special forfeiture","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The United States attorney shall, within thirty days after the imposition of an order under this chapter and at such other times as the Attorney General may require, publish in a newspaper of general circulation in the district in which the offense for which a defendant was convicted occurred, a notice that states—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9beb104-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3682/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of, and other identifying information about, the defendant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9beb105-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3682/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense for which the defendant was convicted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9beb106-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3682/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the court has ordered a special forfeiture of certain proceeds that may be used to satisfy a judgment obtained against the defendant by a victim of an offense for which the defendant has been convicted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9beb107-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s1406/a"},"text":"Pub. L. 98–473, title II, § 1406(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2176"},"text":"98 Stat. 2176","children":[],"tail":", § 3672; renumbered § 3682, "},{"tag":"ref","attrib":{"href":"/us/pl/99/646/s41/a"},"text":"Pub. L. 99–646, § 41(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3600"},"text":"100 Stat. 3600","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
