{"tag":"section","attrib":{"id":"idb98a3313-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3077"},"text":null,"children":[{"tag":"num","attrib":{"value":"3077"},"text":"§ 3077.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb98a3314-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3077/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “act of terrorism” means an act of domestic or international terrorism as defined in section 2331;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb98a3315-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3077/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “United States person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb98a3316-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3077/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national of the United States as defined in section 101(a)(22) of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/22"},"text":"8 U.S.C. 1101(a)(22)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb98a3317-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3077/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an alien lawfully admitted for permanent residence in the United States as defined in section 101(a)(20) of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/20"},"text":"8 U.S.C. 1101(a)(20)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb98a3318-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3077/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person within the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb98a3319-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3077/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any employee or contractor of the United States Government, regardless of nationality, who is the victim or intended victim of an act of terrorism by virtue of that employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb98a331a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3077/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sole proprietorship, partnership, company, or association composed principally of nationals or permanent resident aliens of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb98a331b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3077/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation organized under the laws of the United States, any State, the District of Columbia, or any territory or possession of the United States, and a foreign subsidiary of such corporation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb98a331c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3077/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “United States property” means any real or personal property which is within the United States or, if outside the United States, the actual or beneficial ownership of which rests in a United States person or any Federal or State governmental entity of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb98a331d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3077/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “United States”, when used in a geographical sense, includes Puerto Rico and all territories and possessions of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb98a331e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3077/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” includes any State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, and any other possession or territory of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb98a331f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3077/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “government entity” includes the Government of the United States, any State or political subdivision thereof, any foreign country, and any state, provincial, municipal, or other political subdivision of a foreign country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb98a3320-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3077/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Attorney General” means the Attorney General of the United States or that official designated by the Attorney General to perform the Attorney General’s responsibilities under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb98a3321-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3077/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “act of espionage” means an activity that is a violation of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb98a3322-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3077/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 793, 794, or 798 of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb98a3323-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3077/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 4 of the Subversive Activities Control Act of 1950.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb98a3324-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/533/tI/s101/a"},"text":"Pub. L. 98–533, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2707"},"text":"98 Stat. 2707","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7051"},"text":"Pub. L. 100–690, title VII, § 7051","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4401"},"text":"102 Stat. 4401","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXV/s3572"},"text":"Pub. L. 101–647, title XXXV, § 3572","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4929"},"text":"104 Stat. 4929","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330021/1"},"text":"Pub. L. 103–322, title XXXIII, § 330021(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2150"},"text":"108 Stat. 2150","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/359/tVIII/s803/b"},"text":"Pub. L. 103–359, title VIII, § 803(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-14"},"text":"Oct. 14, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3439"},"text":"108 Stat. 3439","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s605/g"},"text":"Pub. L. 104–294, title VI, § 605(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3510"},"text":"110 Stat. 3510","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tVIII/s802/b"},"text":"Pub. L. 107–56, title VIII, § 802(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/376"},"text":"115 Stat. 376","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb98a3325-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb98a3326-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb98a3327-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 4 of the Subversive Activities Control Act of 1950, referred to in par. (8)(B), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s783"},"text":"section 783 of Title 50","children":[],"tail":", War and National Defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb98a3328-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56"},"text":"Pub. L. 107–56","children":[],"tail":" amended par. (1) generally. Prior to amendment, par. (1) read as follows: “ ‘act of terrorism’ means an activity that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) involves a violent act or an act dangerous to human life that is a violation of the criminal laws of the United States or of any State, or that would be a criminal violation if committed within the jurisdiction of the United States or of any State; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) appears to be intended—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) to intimidate or coerce a civilian population;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) to influence the policy of a government by intimidation or coercion; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iii) to affect the conduct of a government by assassination or kidnapping;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Par. (8)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" substituted “this title” for “title 18, United States Code”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Par. (1)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “kidnapping” for “kidnaping”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/359"},"text":"Pub. L. 103–359","children":[],"tail":" added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":" substituted a semicolon for a period at end of pars. (1) to (3), moved the comma from before the close quotation mark to after that mark in par. (4), substituted a semicolon for a period at end of par. (5), and substituted “; and” for period at end of par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" amended par. (4) generally. Prior to amendment, par. (4) read as follows: “ ‘United States’—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) when used in a geographical sense, includes Puerto Rico and all territories and possessions of the United States; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) when used in the context of section 3073 shall have the meaning given to it in the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"8 U.S.C. 1101","children":[],"tail":" et seq.).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
