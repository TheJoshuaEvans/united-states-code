{"tag":"section","attrib":{"id":"idb8cb778d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s475"},"text":null,"children":[{"tag":"num","attrib":{"value":"475"},"text":"§ 475.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imitating obligations or securities; advertisements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever designs, engraves, prints, makes, or executes, or utters, issues, distributes, circulates, or uses any business or professional card, notice, placard, circular, handbill, or advertisement in the likeness or similitude of any obligation or security of the United States issued under or authorized by any Act of Congress or writes, prints, or otherwise impresses upon or attaches to any such instrument, obligation, or security, or any coin of the United States, any business or professional card, notice, or advertisement, or any notice or advertisement whatever, shall be fined under this title. Nothing in this section applies to evidence of postage payment approved by the United States Postal Service.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8cb778e-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/706"},"text":"62 Stat. 706","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1951-07-16/ch226/s2"},"text":"July 16, 1951, ch. 226, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/122"},"text":"65 Stat. 122","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/G"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(G)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1192"},"text":"Pub. L. 109–162, title XI, § 1192","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3129"},"text":"119 Stat. 3129","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8cb778f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8cb7790-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 292 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s177"},"text":"Mar. 4, 1909, ch. 321, § 177","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1122"},"text":"35 Stat. 1122","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Enumeration of obligations of the United States was omitted in view of definition in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s8"},"text":"section 8 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in phraseology were also made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8cb7791-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8cb7792-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":" inserted at end “Nothing in this section applies to evidence of postage payment approved by the United States Postal Service.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $500”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1951—Act ","children":[{"tag":"date","attrib":{"date":"1951-07-16"},"text":"July 16, 1951","children":[],"tail":", prohibited use of notices or advertising prints or labels on United States coins."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
