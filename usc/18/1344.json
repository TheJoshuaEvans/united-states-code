{"tag":"section","attrib":{"id":"idb91c7d0d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1344"},"text":null,"children":[{"tag":"num","attrib":{"value":"1344"},"text":"§ 1344.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bank fraud","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Whoever knowingly executes, or attempts to execute, a scheme or artifice—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91c7d0e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1344/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to defraud a financial institution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91c7d0f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1344/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain any of the moneys, funds, credits, assets, securities, or other property owned by, or under the custody or control of, a financial institution, by means of false or fraudulent pretenses, representations, or promises;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined not more than $1,000,000 or imprisoned not more than 30 years, or both.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb91c7d10-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s1108/a"},"text":"Pub. L. 98–473, title II, § 1108(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2147"},"text":"98 Stat. 2147","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tIX/s961/k"},"text":"Pub. L. 101–73, title IX, § 961(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/500"},"text":"103 Stat. 500","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV/s2504/j"},"text":"Pub. L. 101–647, title XXV, § 2504(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4861"},"text":"104 Stat. 4861","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91c7d11-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb91c7d12-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb91c7d13-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":" substituted “30” for “20” before “years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73"},"text":"Pub. L. 101–73","children":[],"tail":" amended section generally, restating former subsec. (a) and striking out former subsec. (b) which defined “federally chartered or insured financial institution”. Prior to amendment, subsec. (a) read as follows: “Whoever knowingly executes, or attempts to execute, a scheme or artifice—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) to defraud a federally chartered or insured financial institution; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) to obtain any of the moneys, funds, credits, assets, securities or other property owned by or under the custody or control of a federally chartered or insured financial institution by means of false or fraudulent pretenses, representations, or promises, shall be fined not more than $10,000, or imprisoned not more than five years, or both.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
