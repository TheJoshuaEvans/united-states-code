{"tag":"section","attrib":{"id":"idb8a2e0a2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s23"},"text":null,"children":[{"tag":"num","attrib":{"value":"23"},"text":"§ 23.","children":[{"tag":"ref","attrib":{"idref":"fn002008"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002008"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No section 22 has been enacted."}],"tail":null}],"tail":null},{"tag":"heading","attrib":{},"text":" Court of the United States defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As used in this title, except where otherwise expressly provided ","children":[{"tag":"ref","attrib":{"idref":"fn002009"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002009"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" the term “court of the United States” includes the District Court of Guam, the District Court for the Northern Mariana Islands, and the District Court of the Virgin Islands."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8a2e0a3-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXII/s320914/a"},"text":"Pub. L. 103–322, title XXXII, § 320914(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2128"},"text":"108 Stat. 2128","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
