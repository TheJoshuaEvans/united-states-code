{"tag":"section","attrib":{"id":"idb96ff431-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2427"},"text":null,"children":[{"tag":"num","attrib":{"value":"2427"},"text":"§ 2427.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of offenses relating to child pornography in definition of sexual activity for which any person can be charged with a criminal offense","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In this chapter, the term “sexual activity for which any person can be charged with a criminal offense” does not require interpersonal physical contact, and includes the production of child pornography, as defined in section 2256(8).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb96ff432-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/314/tI/s105/a"},"text":"Pub. L. 105–314, title I, § 105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2977"},"text":"112 Stat. 2977","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dE/tLI/s5102/e"},"text":"Pub. L. 118–31, div. E, title LI, § 5102(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/935"},"text":"137 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb96ff433-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb96ff434-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb96ff435-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" inserted “does not require interpersonal physical contact, and” before “includes”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
