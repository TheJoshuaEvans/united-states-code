{"tag":"section","attrib":{"id":"idb8cdc155-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s506"},"text":null,"children":[{"tag":"num","attrib":{"value":"506"},"text":"§ 506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seals of departments or agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8cdc156-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whoever—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8cdc157-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s506/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" falsely makes, forges, counterfeits, mutilates, or alters the seal of any department or agency of the United States, or any facsimile thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8cdc158-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s506/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly uses, affixes, or impresses any such fraudulently made, forged, counterfeited, mutilated, or altered seal or facsimile thereof to or upon any certificate, instrument, commission, document, or paper of any description; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8cdc159-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s506/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with fraudulent intent, possesses, sells, offers for sale, furnishes, offers to furnish, gives away, offers to give away, transports, offers to transport, imports, or offers to import any such seal or facsimile thereof, knowing the same to have been so falsely made, forged, counterfeited, mutilated, or altered,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title, or imprisoned not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8cdc15a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding subsection (a) or any other provision of law, if a forged, counterfeited, mutilated, or altered seal of a department or agency of the United States, or any facsimile thereof, is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8cdc15b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s506/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" so forged, counterfeited, mutilated, or altered;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8cdc15c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s506/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used, affixed, or impressed to or upon any certificate, instrument, commission, document, or paper of any description; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8cdc15d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s506/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with fraudulent intent, possessed, sold, offered for sale, furnished, offered to furnish, given away, offered to give away, transported, offered to transport, imported, or offered to import,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"with the intent or effect of facilitating an alien’s application for, or receipt of, a Federal benefit to which the alien is not entitled, the penalties which may be imposed for each offense under subsection (a) shall be two times the maximum fine, and 3 times the maximum term of imprisonment, or both, that would otherwise be imposed for an offense under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8cdc15e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s506/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8cdc15f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s506/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “Federal benefit” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8cdc160-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s506/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issuance of any grant, contract, loan, professional license, or commercial license provided by any agency of the United States or by appropriated funds of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8cdc161-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s506/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any retirement, welfare, Social Security, health (including treatment of an emergency medical condition in accordance with section 1903(v) of the Social Security Act (19 ","children":[{"tag":"ref","attrib":{"idref":"fn002045"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002045"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “42”."}],"tail":" U.S.C. 1396b(v))), disability, veterans, public housing, education, supplemental nutrition assistance program benefits,"},{"tag":"ref","attrib":{"idref":"fn002046"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002046"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The word “benefits” probably should not appear."}],"tail":" or unemployment benefit, or any similar benefit for which payments or assistance are provided by an agency of the United States or by appropriated funds of the United States; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8cdc162-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s506/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each instance of forgery, counterfeiting, mutilation, or alteration shall constitute a separate offense under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8cdc163-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/714"},"text":"62 Stat. 714","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tV/s561"},"text":"Pub. L. 104–208, div. C, title V, § 561","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-681"},"text":"110 Stat. 3009–681","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tIV/s4002/b/1/E"},"text":"Pub. L. 110–234, title IV, § 4002(b)(1)(E)","children":[],"tail":", (2)(M), "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1096"},"text":"122 Stat. 1096","children":[],"tail":", 1097; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title IV, § 4002(b)(1)(E), (2)(M), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1857, 1858.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8cdc164-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8cdc165-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 131 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-06-15/ch30"},"text":"June 15, 1917, ch. 30","children":[],"tail":", title X, § 2, "},{"tag":"ref","attrib":{"href":"/us/stat/40/228"},"text":"40 Stat. 228","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to persons causing, procuring, aiding or assisting was omitted as unnecessary as such persons are made principals by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In view of definitions of department and agency in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s6"},"text":"section 6 of this title","children":[],"tail":", words “department or agency” in first paragraph were substituted for “executive department, or any bureau, commission, or office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provision for 10 years’ imprisonment was reduced to 5 years to conform to punishment provision in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s505"},"text":"section 505 of this title","children":[],"tail":", covering an offense of like gravity."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes in phraseology were also made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8cdc166-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb8cdc167-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8cdc168-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4002/b/1/E"},"text":"Pub. L. 110–246, § 4002(b)(1)(E)","children":[],"tail":", (2)(M), substituted “supplemental nutrition assistance program benefits” for “food stamps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" reenacted section catchline without change and amended text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Whoever falsely makes, forges, counterfeits, mutilates, or alters the seal of any department or agency of the United States; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Whoever knowingly uses, affixes, or impresses any such fraudulently made, forged, counterfeited, mutilated, or altered seal to or upon any certificate, instrument, commission, document, or paper, of any description; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Whoever, with fraudulent intent, possesses any such seal, knowing the same to have been so falsely made, forged, counterfeited, mutilated, or altered—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Shall be fined under this title or imprisoned not more than five years, or both.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $5,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8cdc169-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8cdc16a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by section 4002(b)(1)(E), (2)(M) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-10-01"},"text":"Oct. 1, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4407"},"text":"section 4407 of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1161"},"text":"section 1161 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
