{"tag":"section","attrib":{"id":"idb91eee3c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1389"},"text":null,"children":[{"tag":"num","attrib":{"value":"1389"},"text":"§ 1389.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on attacks on United States servicemen on account of service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb91eee3d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1389/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever knowingly assaults or batters a United States serviceman or an immediate family member of a United States serviceman, or who knowingly destroys or injures the property of such serviceman or immediate family member, on account of the military service of that serviceman or status of that individual as a United States serviceman, or who attempts or conspires to do so, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91eee3e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1389/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a simple assault, or destruction or injury to property in which the damage or attempted damage to such property is not more than $500, be fined under this title in an amount not less than $500 nor more than $10,000 and imprisoned not more than 2 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91eee3f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1389/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of destruction or injury to property in which the damage or attempted damage to such property is more than $500, be fined under this title in an amount not less than $1000 nor more than $100,000 and imprisoned not more than 5 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91eee40-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1389/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a battery, or an assault resulting in bodily injury, be fined under this title in an amount not less than $2500 and imprisoned not less than 6 months nor more than 10 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91eee41-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1389/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall not apply to conduct by a person who is subject to the Uniform Code of Military Justice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91eee42-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1389/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91eee43-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1389/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Armed Forces” has the meaning given that term in section 1388;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91eee44-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1389/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “immediate family member” has the meaning given that term in section 115; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91eee45-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1389/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “United States serviceman”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb91eee46-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1389/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a member of the Armed Forces; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91eee47-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1389/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a former member of the Armed Forces during the 5-year period beginning on the date of the discharge from the Armed Forces of that member of the Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb91eee48-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dE/s4712/a"},"text":"Pub. L. 111–84, div. E, § 4712(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2842"},"text":"123 Stat. 2842","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91eee49-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb91eee4a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb91eee4b-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Uniform Code of Military Justice, referred to in subsec. (b), is classified generally to chapter 47 (§ 801 et seq.) of Title 10, Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
