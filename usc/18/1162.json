{"tag":"section","attrib":{"id":"idb917c2c1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1162"},"text":null,"children":[{"tag":"num","attrib":{"value":"1162"},"text":"§ 1162.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State jurisdiction over offenses committed by or against Indians in the Indian country","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb917c2c2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1162/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each of the States or Territories listed in the following table shall have jurisdiction over offenses committed by or against Indians in the areas of Indian country listed opposite the name of the State or Territory to the same extent that such State or Territory has jurisdiction over offenses committed elsewhere within the State or Territory, and the criminal laws of such State or Territory shall have the same force and effect within such Indian country as they have elsewhere within the State or Territory:","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb917c2c3-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"State or Territory of","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Indian country affected","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Alaska","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"All Indian country within the State, except that on Annette Islands, the Metlakatla Indian community may exercise jurisdiction over offenses committed by Indians in the same manner in which such jurisdiction may be exercised by Indian tribes in Indian country over which State jurisdiction has not been extended.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"California","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"All Indian country within the State.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Minnesota","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"All Indian country within the State, except the Red Lake Reservation.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Nebraska","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"All Indian country within the State.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oregon","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"All Indian country within the State, except the Warm Springs Reservation.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Wisconsin","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"All Indian country within the State.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb917c2c4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1162/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section shall authorize the alienation, encumbrance, or taxation of any real or personal property, including water rights, belonging to any Indian or any Indian tribe, band, or community that is held in trust by the United States or is subject to a restriction against alienation imposed by the United States; or shall authorize regulation of the use of such property in a manner inconsistent with any Federal treaty, agreement, or statute or with any regulation made pursuant thereto; or shall deprive any Indian or any Indian tribe, band, or community of any right, privilege, or immunity afforded under Federal treaty, agreement, or statute with respect to hunting, trapping, or fishing or the control, licensing, or regulation thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb917c2c5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1162/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of sections 1152 and 1153 of this chapter shall not be applicable within the areas of Indian country listed in subsection (a) of this section as areas over which the several States have exclusive jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb917c2c6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1162/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding subsection (c), at the request of an Indian tribe, and after consultation with and consent by the Attorney General—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb917c2c7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1162/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 1152 and 1153 shall apply in the areas of the Indian country of the Indian tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb917c2c8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1162/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" jurisdiction over those areas shall be concurrent among the Federal Government, State governments, and, where applicable, tribal governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb917c2c9-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1953-08-15/ch505/s2"},"text":"Aug. 15, 1953, ch. 505, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/588"},"text":"67 Stat. 588","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-24/ch910/s1"},"text":"Aug. 24, 1954, ch. 910, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/795"},"text":"68 Stat. 795","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/615/s1"},"text":"Pub. L. 85–615, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-08"},"text":"Aug. 8, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/545"},"text":"72 Stat. 545","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/523"},"text":"Pub. L. 91–523","children":[],"tail":", §§ 1, 2, "},{"tag":"date","attrib":{"date":"1970-11-25"},"text":"Nov. 25, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1358"},"text":"84 Stat. 1358","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s221/b"},"text":"Pub. L. 111–211, title II, § 221(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2272"},"text":"124 Stat. 2272","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb917c2ca-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb917c2cb-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb917c2cc-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211"},"text":"Pub. L. 111–211","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/523/s1"},"text":"Pub. L. 91–523, § 1","children":[],"tail":", substituted provisions relating to the jurisdiction of the State of Alaska over offenses by or against Indians in the Indian country, and certain excepted areas, for provisions relating to the jurisdiction of the Territory of Alaska over offenses by or against Indians in the Indian country."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/523/s2"},"text":"Pub. L. 91–523, § 2","children":[],"tail":", inserted “as areas over which the several States have exclusive jurisdiction” after “subsection (a) of this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/615"},"text":"Pub. L. 85–615","children":[],"tail":" gave Alaska jurisdiction over offenses committed by or against Indians in all Indian country within the Territory of Alaska."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Subsec. (a). Act ","children":[{"tag":"date","attrib":{"date":"1954-08-24"},"text":"Aug. 24, 1954","children":[],"tail":", brought the Menominee Tribe within the provisions of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb917c2cd-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb917c2ce-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Admission of Alaska as State","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Admission of Alaska into the Union was accomplished ","children":[{"tag":"date","attrib":{"date":"1959-01-03"},"text":"Jan. 3, 1959","children":[],"tail":", on issuance of Proc. No. 3269, "},{"tag":"date","attrib":{"date":"1959-01-03"},"text":"Jan. 3, 1959","children":[],"tail":" 24 F.R. 81, 73 Stat. c16, as required by sections 1 and 8(c) of "},{"tag":"ref","attrib":{"href":"/us/pl/85/508"},"text":"Pub. L. 85–508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-07-07"},"text":"July 7, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/339"},"text":"72 Stat. 339","children":[],"tail":", set out as notes preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s21"},"text":"section 21 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
