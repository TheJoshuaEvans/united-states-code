{"tag":"section","attrib":{"id":"idb8a55107-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s34"},"text":null,"children":[{"tag":"num","attrib":{"value":"34"},"text":"§ 34.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty when death results","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever is convicted of any crime prohibited by this chapter, which has resulted in the death of any person, shall be subject also to the death penalty or to imprisonment for life.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8a55108-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-07-14/ch595/s1"},"text":"July 14, 1956, ch. 595, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/540"},"text":"70 Stat. 540","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tVI/s60003/a/1"},"text":"Pub. L. 103–322, title VI, § 60003(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1968"},"text":"108 Stat. 1968","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8a55109-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8a5510a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8a5510b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “imprisonment for life.” for “imprisonment for life, if the jury shall in its discretion so direct, or, in the case of a plea of guilty, or a plea of not guilty where the defendant has waived a trial by jury, if the court in its discretion shall so order.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
