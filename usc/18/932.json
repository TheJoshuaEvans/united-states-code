{"tag":"section","attrib":{"id":"idb8fd835e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s932"},"text":null,"children":[{"tag":"num","attrib":{"value":"932"},"text":"§ 932.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Straw purchasing of firearms","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8fd835f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s932/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fd8360-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s932/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “drug trafficking crime”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8fd8361-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s932/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the meaning given that term in section 924(c)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fd8362-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s932/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a felony punishable under the law of a State for which the conduct constituting the offense would constitute a felony punishable under the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"21 U.S.C. 801","children":[],"tail":" et seq.), the Controlled Substances Import and Export Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s951"},"text":"21 U.S.C. 951","children":[],"tail":" et seq.), or chapter 705 of title 46;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fd8363-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s932/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Federal crime of terrorism” has the meaning given that term in section 2332b(g)(5); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fd8364-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s932/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “felony” means any offense under Federal or State law punishable by imprisonment for a term exceeding 1 year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fd8365-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s932/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Violation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be unlawful for any person to knowingly purchase, or conspire to purchase, any firearm in or otherwise affecting interstate or foreign commerce for, on behalf of, or at the request or demand of any other person, knowing or having reasonable cause to believe that such other person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fd8366-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s932/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the criteria of 1 or more paragraphs of section 922(d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fd8367-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s932/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intends to use, carry, possess, or sell or otherwise dispose of the firearm in furtherance of a felony, a Federal crime of terrorism, or a drug trafficking crime; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fd8368-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s932/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intends to sell or otherwise dispose of the firearm to a person described in paragraph (1) or (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fd8369-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s932/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fd836a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s932/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), any person who violates subsection (b) shall be fined under this title, imprisoned for not more than 15 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fd836b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s932/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use in felonies, crimes of terrorism, or drug trafficking crimes","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a violation of subsection (b) is committed knowing or with reasonable cause to believe that any firearm involved will be used to commit a felony, a Federal crime of terrorism, or a drug trafficking crime, the person shall be sentenced to a term of imprisonment of not more than 25 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8fd836c-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/159/dA/tII/s12004/a/1"},"text":"Pub. L. 117–159, div. A, title II, § 12004(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-06-25"},"text":"June 25, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1326"},"text":"136 Stat. 1326","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8fd836d-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8fd836e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8fd836f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Controlled Substances Act, referred to in subsec. (a)(1)(B), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513"},"text":"Pub. L. 91–513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1242"},"text":"84 Stat. 1242","children":[],"tail":", which is classified principally to subchapter I (§ 801 et seq.) of chapter 13 of Title 21, Food and Drugs. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"section 801 of Title 21","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Controlled Substances Import and Export Act, referred to in subsec. (a)(1)(B), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513"},"text":"Pub. L. 91–513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1285"},"text":"84 Stat. 1285","children":[],"tail":", which is classified principally to subchapter II (§ 951 et seq.) of chapter 13 of Title 21, Food and Drugs. For complete classification of the Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s951"},"text":"section 951 of Title 21","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8fd8370-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8fd8371-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/159/s12004/a/1"},"text":"section 12004(a)(1) of Pub. L. 117–159","children":[],"tail":", which enacted this section, to be construed to allow the establishment of a Federal system of registration of firearms, firearms owners, or firearms transactions or dispositions, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/159/s12004/k"},"text":"section 12004(k) of Pub. L. 117–159","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s922"},"text":"section 922 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
