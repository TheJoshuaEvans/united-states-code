{"tag":"section","attrib":{"id":"idb93de824-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1960"},"text":null,"children":[{"tag":"num","attrib":{"value":"1960"},"text":"§ 1960.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of unlicensed money transmitting businesses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb93de825-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1960/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever knowingly conducts, controls, manages, supervises, directs, or owns all or part of an unlicensed money transmitting business, shall be fined in accordance with this title or imprisoned not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb93de826-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1960/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb93de827-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1960/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “unlicensed money transmitting business” means a money transmitting business which affects interstate or foreign commerce in any manner or degree and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb93de828-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1960/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is operated without an appropriate money transmitting license in a State where such operation is punishable as a misdemeanor or a felony under State law, whether or not the defendant knew that the operation was required to be licensed or that the operation was so punishable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb93de829-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1960/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to comply with the money transmitting business registration requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5330"},"text":"section 5330 of title 31","children":[],"tail":", United States Code, or regulations prescribed under such section; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb93de82a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1960/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise involves the transportation or transmission of funds that are known to the defendant to have been derived from a criminal offense or are intended to be used to promote or support unlawful activity;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb93de82b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1960/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “money transmitting” includes transferring funds on behalf of the public by any and all means including but not limited to transfers within this country or to locations abroad by wire, check, draft, facsimile, or courier; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb93de82c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1960/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” means any State of the United States, the District of Columbia, the Northern Mariana Islands, and any commonwealth, territory, or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb93de82d-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXV/s1512/a"},"text":"Pub. L. 102–550, title XV, § 1512(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4057"},"text":"106 Stat. 4057","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/325/tIV/s408/c"},"text":"Pub. L. 103–325, title IV, § 408(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2252"},"text":"108 Stat. 2252","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tIII/s373/a"},"text":"Pub. L. 107–56, title III, § 373(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/339"},"text":"115 Stat. 339","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1171/a/2"},"text":"Pub. L. 109–162, title XI, § 1171(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3123"},"text":"119 Stat. 3123","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb93de82e-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb93de82f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb93de830-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":" substituted “to be used” for “to be used to be used”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56"},"text":"Pub. L. 107–56","children":[],"tail":" amended section catchline and text generally, substituting provisions relating to prohibition of unlicensed money transmitting businesses for similar provisions relating to prohibition of illegal money transmitting businesses."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325"},"text":"Pub. L. 103–325","children":[],"tail":" amended par. (1) generally. Prior to amendment, par. (1) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the term ‘illegal money transmitting business’ means a money transmitting business that affects interstate or foreign commerce in any manner or degree and which is knowingly operated in a State—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) without the appropriate money transmitting State license; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) where such operation is punishable as a misdemeanor or a felony under State law;”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
