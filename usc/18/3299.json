{"tag":"section","attrib":{"id":"idb99ad4e4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3299"},"text":null,"children":[{"tag":"num","attrib":{"value":"3299"},"text":"§ 3299.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child abduction and sex offenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other law, an indictment may be found or an information instituted at any time without limitation for any offense under section 1201 involving a minor victim, and for any felony under chapter 109A, 110 (except for section ","children":[{"tag":"ref","attrib":{"idref":"fn002236"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002236"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “sections”."}],"tail":" 2257 and 2257A), or 117, or section 1591."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb99ad4e5-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/tII/s211/1"},"text":"Pub. L. 109–248, title II, § 211(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/616"},"text":"120 Stat. 616","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
