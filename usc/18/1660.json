{"tag":"section","attrib":{"id":"idb92ad5e0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1660"},"text":null,"children":[{"tag":"num","attrib":{"value":"1660"},"text":"§ 1660.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receipt of pirate property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, without lawful authority, receives or takes into custody any vessel, goods, or other property, feloniously taken by any robber or pirate against the laws of the United States, knowing the same to have been feloniously taken, shall be imprisoned not more than ten years.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb92ad5e1-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/775"},"text":"62 Stat. 775","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92ad5e2-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb92ad5e3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 552 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s334"},"text":"Mar. 4, 1909, ch. 321, § 334","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1152"},"text":"35 Stat. 1152","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provision relating to concealment of pirate and words “is an accessory after the fact to such robbery or piracy” were omitted in view of definitive ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3"},"text":"section 3 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
