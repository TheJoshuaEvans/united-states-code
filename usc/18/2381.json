{"tag":"section","attrib":{"id":"idb96b399d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2381"},"text":null,"children":[{"tag":"num","attrib":{"value":"2381"},"text":"§ 2381.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treason","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, owing allegiance to the United States, levies war against them or adheres to their enemies, giving them aid and comfort within the United States or elsewhere, is guilty of treason and shall suffer death, or shall be imprisoned not less than five years and fined under this title but not less than $10,000; and shall be incapable of holding any office under the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb96b399e-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/807"},"text":"62 Stat. 807","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/2/J"},"text":"Pub. L. 103–322, title XXXIII, § 330016(2)(J)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2148"},"text":"108 Stat. 2148","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb96b399f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb96b39a0-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., §§ 1, 2 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321"},"text":"Mar. 4, 1909, ch. 321","children":[],"tail":", §§ 1, 2, "},{"tag":"ref","attrib":{"href":"/us/stat/35/1088"},"text":"35 Stat. 1088","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section consolidates sections 1 and 2 of title 18, U.S.C., 1940 ed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The language referring to collection of the fine was omitted as obsolete and repugnant to the more humane policy of modern law which does not impose criminal consequences on the innocent.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “every person so convicted of treason” were omitted as redundant.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor change was made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb96b39a1-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb96b39a2-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" inserted “under this title but” before “not less than $10,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
