{"tag":"section","attrib":{"id":"idb9619cb7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2328"},"text":null,"children":[{"tag":"num","attrib":{"value":"2328"},"text":"§ 2328.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory forfeiture","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9619cb8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2328/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The court, in imposing sentence on a person who is convicted of any offense for which an enhanced penalty is provided under section 2326, shall order that the defendant forfeit to the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9619cb9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2328/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any property, real or personal, constituting or traceable to gross proceeds obtained from such offense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9619cba-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2328/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any equipment, software, or other technology used or intended to be used to commit or to facilitate the commission of such offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9619cbb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2328/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The procedures set forth in section 413 of the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s853"},"text":"21 U.S.C. 853","children":[],"tail":"), other than subsection (d) of that section, and in Rule 32.2 of the Federal Rules of Criminal Procedure, shall apply to all stages of a criminal forfeiture proceeding under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9619cbc-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/70/tIV/s402/a/4"},"text":"Pub. L. 115–70, title IV, § 402(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-10-18"},"text":"Oct. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1214"},"text":"131 Stat. 1214","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9619cbd-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9619cbe-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9619cbf-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Criminal Procedure, referred to in subsec. (b), are set out in the Appendix to this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
