{"tag":"section","attrib":{"id":"idb9b2c96a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612"},"text":null,"children":[{"tag":"num","attrib":{"value":"3612"},"text":"§ 3612.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of unpaid fine or restitution","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9b2c96b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of Receipt and Related Matters","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The clerk or the person designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s604/a/18"},"text":"section 604(a)(18) of title 28","children":[],"tail":" shall notify the Attorney General of each receipt of a payment with respect to which a certification is made under subsection (b), together with other appropriate information relating to such payment. The notification shall be provided—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9b2c96c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in such manner as may be agreed upon by the Attorney General and the Director of the Administrative Office of the United States Courts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9b2c96d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within 15 days after the receipt or at such other time as may be determined jointly by the Attorney General and the Director of the Administrative Office of the United States Courts.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"If the fifteenth day under paragraph (2) is a Saturday, Sunday, or legal public holiday, the clerk, or the person designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s604/a/18"},"text":"section 604(a)(18) of title 28","children":[],"tail":", shall provide notification not later than the next day that is not a Saturday, Sunday, or legal public holiday."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9b2c96e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information to be Included in Judgment; Judgment to be Transmitted to Attorney General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9b2c96f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A judgment or order imposing, modifying, or remitting a fine or restitution order of more than $100 shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9b2c970-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, social security account number, mailing address, and residence address of the defendant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9b2c971-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the docket number of the case;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9b2c972-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the original amount of the fine or restitution order and the amount that is due and unpaid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9b2c973-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the schedule of payments (if other than immediate payment is permitted under section 3572(d));","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9b2c974-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any modification or remission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9b2c975-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if other than immediate payment is permitted, a requirement that, until the fine or restitution order is paid in full, the defendant notify the Attorney General of any change in the mailing address or residence address of the defendant not later than thirty days after the change occurs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9b2c976-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a restitution order, information sufficient to identify each victim to whom restitution is owed. It shall be the responsibility of each victim to notify the Attorney General, or the appropriate entity of the court, by means of a form to be provided by the Attorney General or the court, of any change in the victim’s mailing address while restitution is still owed the victim. The confidentiality of any information relating to a victim shall be maintained.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9b2c977-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than ten days after entry of the judgment or order, the court shall transmit a certified copy of the judgment or order to the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9b2c978-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibility for Collection","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall be responsible for collection of an unpaid fine or restitution concerning which a certification has been issued as provided in subsection (b). An order of restitution, pursuant to section 3556, does not create any right of action against the United States by the person to whom restitution is ordered to be paid. Any money received from a defendant shall be disbursed so that each of the following obligations is paid in full in the following sequence:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9b2c979-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A penalty assessment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3013"},"text":"section 3013 of title 18","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9b2c97a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Restitution of all victims.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9b2c97b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All other fines, penalties, costs, and other payments required under the sentence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9b2c97c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of Delinquency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Within ten working days after a fine or restitution is determined to be delinquent as provided in section 3572(h), the Attorney General shall notify the person whose fine or restitution is delinquent, to inform the person of the delinquency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9b2c97d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of Default","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Within ten working days after a fine or restitution is determined to be in default as provided in section 3572(i), the Attorney General shall notify the person defaulting to inform the person that the fine or restitution is in default and the entire unpaid balance, including interest and penalties, is due within thirty days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9b2c97e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interest on Fines and restitution.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9b2c97f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The defendant shall pay interest on any fine or restitution of more than $2,500, unless the fine is paid in full before the fifteenth day after the date of the judgment. If that day is a Saturday, Sunday, or legal public holiday, the defendant shall be liable for interest beginning with the next day that is not a Saturday, Sunday, or legal public holiday.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9b2c980-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Computation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Interest on a fine shall be computed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9b2c981-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" daily (from the first day on which the defendant is liable for interest under paragraph (1)); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9b2c982-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a rate equal to the weekly average 1-year constant maturity Treasury yield, as published by the Board of Governors of the Federal Reserve System, for the calendar week preceding the first day on which the defendant is liable for interest under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9b2c983-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Modification of interest by court","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the court determines that the defendant does not have the ability to pay interest under this subsection, the court may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9b2c984-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" waive the requirement for interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9b2c985-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit the total of interest payable to a specific dollar amount; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9b2c986-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit the length of the period during which interest accrues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9b2c987-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty for Delinquent Fine","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a fine or restitution becomes delinquent, the defendant shall pay, as a penalty, an amount equal to 10 percent of the principal amount that is delinquent. If a fine or restitution becomes in default, the defendant shall pay, as a penalty, an additional amount equal to 15 percent of the principal amount that is in default.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9b2c988-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver of Interest or Penalty by Attorney General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Attorney General may waive all or part of any interest or penalty under this section or any interest or penalty relating to a fine imposed under any prior law if, as determined by the Attorney General, reasonable efforts to collect the interest or penalty are not likely to be effective.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9b2c989-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of Payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Payments relating to fines and restitution shall be applied in the following order: (1) to principal; (2) to costs; (3) to interest; and (4) to penalties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9b2c98a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evaluation of Offices of the United States Attorney and Department Components.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9b2c98b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Attorney General shall, as part of the regular evaluation process, evaluate each office of the United States attorney and each component of the Department of Justice on the performance of the office or the component, as the case may be, in seeking and recovering restitution for victims under each provision of this title and the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"21 U.S.C. 801","children":[],"tail":" et seq.) that authorizes restitution."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9b2c98c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Following an evaluation under paragraph (1), each office of the United States attorney and each component of the Department of Justice shall work to improve the practices of the office or component, as the case may be, with respect to seeking and recovering restitution for victims under each provision of this title and the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"21 U.S.C. 801","children":[],"tail":" et seq.) that authorizes restitution."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9b2c98d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"GAO Reports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9b2c98e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of enactment of this subsection, the Comptroller General of the United States shall prepare and submit to the Committee on the Judiciary of the House of Representatives and the Committee on the Judiciary of the Senate a report on restitution sought by the Attorney General under each provision of this title and the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"21 U.S.C. 801","children":[],"tail":" et seq.) that authorizes restitution during the 3-year period preceding the report."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9b2c98f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required under paragraph (1) shall include statistically valid estimates of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9b2c990-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/k/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of cases in which a defendant was convicted and the Attorney General could seek restitution under this title or the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"21 U.S.C. 801","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9b2c991-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/k/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of cases in which the Attorney General sought restitution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9b2c992-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/k/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the cases in which the Attorney General sought restitution, the number of times restitution was ordered by the district courts of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9b2c993-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/k/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of restitution ordered by the district courts of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9b2c994-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/k/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of restitution collected pursuant to the restitution orders described in subparagraph (D);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9b2c995-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/k/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of restitution orders for which the full amount of restitution has not been collected; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9b2c996-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/k/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other measurement the Comptroller General determines would assist in evaluating how to improve the restitution process in Federal criminal cases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9b2c997-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/k/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required under paragraph (1) shall include recommendations on the best practices for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9b2c998-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/k/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requesting restitution in cases in which restitution may be sought under each provision of this title and the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"21 U.S.C. 801","children":[],"tail":" et seq.) that authorizes restitution;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9b2c999-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/k/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtaining restitution orders from the district courts of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9b2c99a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/k/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collecting restitution ordered by the district courts of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9b2c99b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3612/k/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 3 years after the date on which the report required under paragraph (1) is submitted, the Comptroller General of the United States shall prepare and submit to the Committee on the Judiciary of the House of Representatives and the Committee on the Judiciary of the Senate a report on the implementation by the Attorney General of the best practices recommended under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9b2c99c-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s212/a/2"},"text":"Pub. L. 98–473, title II, § 212(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2004"},"text":"98 Stat. 2004","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/185/s11"},"text":"Pub. L. 100–185, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-11"},"text":"Dec. 11, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1283"},"text":"101 Stat. 1283","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7082/c"},"text":"Pub. L. 100–690, title VII, § 7082(c)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4408"},"text":"102 Stat. 4408","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXV/s3592"},"text":"Pub. L. 101–647, title XXXV, § 3592","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4931"},"text":"104 Stat. 4931","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tII/s207/c/2"},"text":"Pub. L. 104–132, title II, § 207(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1237"},"text":"110 Stat. 1237","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s307/b"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 307(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–635; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dB/tIV/s4002/b/15"},"text":"Pub. L. 107–273, div. B, title IV, § 4002(b)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1808"},"text":"116 Stat. 1808","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/324/s18"},"text":"Pub. L. 114–324, § 18","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1962"},"text":"130 Stat. 1962","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9b2c99d-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9b2c99e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9b2c99f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Controlled Substances Act, referred to in subsecs. (j) and (k), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513"},"text":"Pub. L. 91–513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1242"},"text":"84 Stat. 1242","children":[],"tail":", which is classified principally to subchapter I (§ 801 et seq.) of chapter 13 of Title 21, Food and Drugs. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"section 801 of Title 21","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of this subsection, referred to in subsec. (k)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/324"},"text":"Pub. L. 114–324","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb9b2c9a0-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For a prior section 3612, applicable to offenses committed prior to ","children":[{"tag":"date","attrib":{"date":"1987-11-01"},"text":"Nov. 1, 1987","children":[],"tail":", see note set out preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3601"},"text":"section 3601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9b2c9a1-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsecs. (j), (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/324"},"text":"Pub. L. 114–324","children":[],"tail":" added subsecs. (j) and (k)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (f)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" substituted “preceding the first day” for “preceding. the first day”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (f)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":" substituted “the weekly average 1-year constant maturity Treasury yield, as published by the Board of Governors of the Federal Reserve System, for the calendar week preceding.” for “the coupon issue yield equivalent (as determined by the Secretary of the Treasury) of the average accepted auction price for the last auction of fifty-two week United States Treasury bills settled before”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s207/c/2/A"},"text":"Pub. L. 104–132, § 207(c)(2)(A)","children":[],"tail":", substituted “Collection of unpaid fine or restitution” for “Collection of an unpaid fine” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s207/c/2/B/i"},"text":"Pub. L. 104–132, § 207(c)(2)(B)(i)","children":[],"tail":", inserted “or restitution order” after “fine” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s207/c/2/B/ii"},"text":"Pub. L. 104–132, § 207(c)(2)(B)(ii)","children":[],"tail":", inserted “or restitution order” after “fine”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s207/c/2/B/iii"},"text":"Pub. L. 104–132, § 207(c)(2)(B)(iii)","children":[],"tail":", struck out “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s207/c/2/B/iv"},"text":"Pub. L. 104–132, § 207(c)(2)(B)(iv)","children":[],"tail":", inserted “or restitution order” after “fine” and substituted “; and” for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s207/c/2/B/v"},"text":"Pub. L. 104–132, § 207(c)(2)(B)(v)","children":[],"tail":", added subpar. (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s207/c/2/C"},"text":"Pub. L. 104–132, § 207(c)(2)(C)","children":[],"tail":", inserted “or restitution” after “unpaid fine” in first sentence and inserted at end “Any money received from a defendant shall be disbursed so that each of the following obligations is paid in full in the following sequence:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) A penalty assessment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3013"},"text":"section 3013 of title 18","children":[],"tail":", United States Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Restitution of all victims.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) All other fines, penalties, costs, and other payments required under the sentence.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s207/c/2/D/ii"},"text":"Pub. L. 104–132, § 207(c)(2)(D)(ii)","children":[],"tail":", which directed substitution of “or restitution is delinquent, to inform the person of the delinquency” for “is delinquent, to inform him that the fine is delinquent”, was executed by making the substitution for “is delinquent to inform him that the fine is delinquent” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s207/c/2/D/i"},"text":"Pub. L. 104–132, § 207(c)(2)(D)(i)","children":[],"tail":", inserted “or restitution” after “Within ten working days after a fine”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s207/c/2/E"},"text":"Pub. L. 104–132, § 207(c)(2)(E)","children":[],"tail":", inserted “or restitution” after “days after a fine” and substituted “the person that the fine or restitution is in default” for “him that the fine is in default”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s207/c/2/F/i"},"text":"Pub. L. 104–132, § 207(c)(2)(F)(i)","children":[],"tail":", which directed amendment of heading by inserting “and restitution” after “on fines”, was executed by inserting the material after “on fines” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s207/c/2/F/ii"},"text":"Pub. L. 104–132, § 207(c)(2)(F)(ii)","children":[],"tail":", inserted “or restitution” after “any fine”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s207/c/2/G"},"text":"Pub. L. 104–132, § 207(c)(2)(G)","children":[],"tail":", inserted “or restitution” after “fine” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s207/c/2/H"},"text":"Pub. L. 104–132, § 207(c)(2)(H)","children":[],"tail":", inserted “and restitution” after “fines”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":" substituted “604(a)(18)” for “604(a)(17)” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7082/d"},"text":"Pub. L. 100–690, § 7082(d)","children":[],"tail":", struck out “, by certified mail,” after “fine is delinquent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7082/d"},"text":"Pub. L. 100–690, § 7082(d)","children":[],"tail":", struck out “, by certified mail,” after “the person defaulting”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7082/c"},"text":"Pub. L. 100–690, § 7082(c)","children":[],"tail":", inserted “or any interest or penalty relating to a fine imposed under any prior law” after “under this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/185/s11/a"},"text":"Pub. L. 100–185, § 11(a)","children":[],"tail":", substituted “Notification of receipt and related matters” for “Disposition of payment” in heading and amended text generally. Prior to amendment, text read as follows: “The clerk shall forward each fine payment to the United States Treasury and shall notify the Attorney General of its receipt within ten working days.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/185/s11/b"},"text":"Pub. L. 100–185, § 11(b)","children":[],"tail":", substituted “Information to be included in judgment; judgment to be transmitted to Attorney General” for “Certification of imposition” in heading and amended text generally. Prior to amendment, text read as follows: “If a fine exceeding $100 is imposed, modified, or remitted, the sentencing court shall incorporate in the order imposing, remitting, or modifying such fine, and promptly certify to the Attorney General—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the name of the person fined;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) his current address;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) the docket number of the case;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) the amount of the fine imposed;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) any installment schedule;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(6) the nature of any modification or remission of the fine or installment schedule; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(7) the amount of the fine that is due and unpaid.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/185/s11/c/1"},"text":"Pub. L. 100–185, § 11(c)(1)","children":[],"tail":", substituted “section 3572(h)” for “section 3572(i)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/185/s11/c/2"},"text":"Pub. L. 100–185, § 11(c)(2)","children":[],"tail":", substituted “section 3572(i)” for “section 3572(j)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/185/s11/d"},"text":"Pub. L. 100–185, § 11(d)","children":[],"tail":", amended subsec. (f) generally, substituting provisions relating to interest on fines, computation of interest, and modification of interest by court, for provisions relating to interest and monetary penalties for delinquent fines."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g) to (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/185/s11/e"},"text":"Pub. L. 100–185, § 11(e)","children":[],"tail":", added subsecs. (g) to (i)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9b2c9a2-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb9b2c9a3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132"},"text":"Pub. L. 104–132","children":[],"tail":" to be effective, to extent constitutionally permissible, for sentencing proceedings in cases in which defendant is convicted on or after "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/s211"},"text":"section 211 of Pub. L. 104–132","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2248"},"text":"section 2248 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9b2c9a4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1987-11-01"},"text":"Nov. 1, 1987","children":[],"tail":", and applicable only to offenses committed after the taking effect of this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/s235/a/1"},"text":"section 235(a)(1) of Pub. L. 98–473","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3551"},"text":"section 3551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb9b2c9a5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Collection of Outstanding Fines","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s237"},"text":"Pub. L. 98–473, title II, § 237","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2033"},"text":"98 Stat. 2033","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/473/tII/s237"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (2), for each criminal fine for which the unpaid balance exceeds $100 as of the effective date of this Act [see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/s235"},"text":"section 235 of Pub. L. 98–473","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3551"},"text":"section 3551 of this title","children":[],"tail":"], the Attorney General shall, within one hundred and twenty days, notify the person by certified mail of his obligation, within thirty days after notification, to—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay the fine in full;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify, and demonstrate compliance with, an installment schedule established by a court before enactment of the amendments made by this Act [","children":[{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":"], specifying the dates on which designated partial payments will be made; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish with the concurrence of the Attorney General, a new installment schedule of a duration not exceeding two years, except in special circumstances, and specifying the dates on which designated partial payments will be made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This subsection shall not apply in cases in which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General believes the likelihood of collection is remote; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" criminal fines have been stayed pending appeal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General shall, within one hundred and eighty days after the effective date of this Act, declare all fines for which this obligation is unfulfilled to be in criminal default, subject to the civil and criminal remedies established by amendments made by this Act [see Short Title note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3551"},"text":"section 3551 of this title","children":[],"tail":"]. No interest or monetary penalties shall be charged on any fines subject to this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than one year following the effective date of this Act, the Attorney General shall include in the annual crime report steps taken to implement this Act and the progress achieved in criminal fine collection, including collection data for each judicial district.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
