{"tag":"section","attrib":{"id":"idb921382d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1502"},"text":null,"children":[{"tag":"num","attrib":{"value":"1502"},"text":"§ 1502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resistance to extradition agent","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever knowingly and willfully obstructs, resists, or opposes an extradition agent of the United States in the execution of his duties, shall be fined under this title or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb921382e-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-24/ch645"},"text":"June 24, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/769"},"text":"62 Stat. 769","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/F"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb921382f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9213830-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 661 (R.S. 5277).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Said ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s661"},"text":"section 661 of title 18","children":[],"tail":", U.S.C., 1940 ed., was incorporated in this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s752"},"text":"section 752 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “an extradition agent of the United States” were substituted for “such agent” which was referred to in sections 3182 et seq. of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"A fine of “$300” was substituted for “$1,000” as the mandatory maximum to harmonize with similar offenses in this chapter. (See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1501"},"text":"section 1501 of this title","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Punishment provision was rephrased in the alternative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9213831-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9213832-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $300”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
