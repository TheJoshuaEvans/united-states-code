{"tag":"section","attrib":{"id":"idb9261a2d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1515"},"text":null,"children":[{"tag":"num","attrib":{"value":"1515"},"text":"§ 1515.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions for certain provisions; general provision","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9261a2e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1515/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in sections 1512 and 1513 of this title and in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9261a2f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1515/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “official proceeding” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9261a30-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1515/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proceeding before a judge or court of the United States, a United States magistrate judge, a bankruptcy judge, a judge of the United States Tax Court, a special trial judge of the Tax Court, a judge of the United States Court of Federal Claims, or a Federal grand jury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9261a31-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1515/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proceeding before the Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9261a32-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1515/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proceeding before a Federal Government agency which is authorized by law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9261a33-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1515/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proceeding involving the business of insurance whose activities affect interstate commerce before any insurance regulatory official or agency or any agent or examiner appointed by such official or agency to examine the affairs of any person engaged in the business of insurance whose activities affect interstate commerce;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9261a34-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1515/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “physical force” means physical action against another, and includes confinement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9261a35-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1515/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “misleading conduct” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9261a36-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1515/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly making a false statement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9261a37-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1515/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intentionally omitting information from a statement and thereby causing a portion of such statement to be misleading, or intentionally concealing a material fact, and thereby creating a false impression by such statement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9261a38-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1515/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with intent to mislead, knowingly submitting or inviting reliance on a writing or recording that is false, forged, altered, or otherwise lacking in authenticity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9261a39-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1515/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with intent to mislead, knowingly submitting or inviting reliance on a sample, specimen, map, photograph, boundary mark, or other object that is misleading in a material respect; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9261a3a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1515/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly using a trick, scheme, or device with intent to mislead;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9261a3b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1515/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “law enforcement officer” means an officer or employee of the Federal Government, or a person authorized to act for or on behalf of the Federal Government or serving the Federal Government as an adviser or consultant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9261a3c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1515/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorized under law to engage in or supervise the prevention, detection, investigation, or prosecution of an offense; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9261a3d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1515/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serving as a probation or pretrial services officer under this title;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9261a3e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1515/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “bodily injury” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9261a3f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1515/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a cut, abrasion, bruise, burn, or disfigurement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9261a40-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1515/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical pain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9261a41-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1515/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" illness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9261a42-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1515/a/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impairment of the function of a bodily member, organ, or mental faculty; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9261a43-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1515/a/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other injury to the body, no matter how temporary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9261a44-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1515/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “corruptly persuades” does not include conduct which would be misleading conduct but for a lack of a state of mind.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9261a45-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1515/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As used in section 1505, the term “corruptly” means acting with an improper purpose, personally or by influencing another, including making a false or misleading statement, or withholding, concealing, altering, or destroying a document or other information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9261a46-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1515/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This chapter does not prohibit or punish the providing of lawful, bona fide, legal representation services in connection with or anticipation of an official proceeding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9261a47-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/291/s4/a"},"text":"Pub. L. 97–291, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1252"},"text":"96 Stat. 1252","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/646/s50/b"},"text":"Pub. L. 99–646, § 50(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3605"},"text":"100 Stat. 3605","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7029/b"},"text":"Pub. L. 100–690, title VII, § 7029(b)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4398"},"text":"102 Stat. 4398","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/650/tIII/s321"},"text":"Pub. L. 101–650, title III, § 321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5117"},"text":"104 Stat. 5117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/