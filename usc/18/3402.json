{"tag":"section","attrib":{"id":"idb99d4578-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3402"},"text":null,"children":[{"tag":"num","attrib":{"value":"3402"},"text":"§ 3402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of procedure, practice and appeal ","children":[{"tag":"ref","attrib":{"idref":"fn002237"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002237"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" Section catchline was not amended to conform to change made in text by "},{"tag":"ref","attrib":{"href":"/us/pl/100/702"},"text":"Pub. L. 100–702","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In all cases of conviction by a United States magistrate judge an appeal of right shall lie from the judgment of the magistrate judge to a judge of the district court of the district in which the offense was committed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb99d4579-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/831"},"text":"62 Stat. 831","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/578/tIII/s302/b"},"text":"Pub. L. 90–578, title III, § 302(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-17"},"text":"Oct. 17, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1116"},"text":"82 Stat. 1116","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/702/tIV/s404/b/2"},"text":"Pub. L. 100–702, title IV, § 404(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4651"},"text":"102 Stat. 4651","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/650/tIII/s321"},"text":"Pub. L. 101–650, title III, § 321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5117"},"text":"104 Stat. 5117","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb99d457a-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb99d457b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18 U.S.C., 1940 ed., § 576a (","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-09/ch685/s2"},"text":"Oct. 9, 1940, ch. 685, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/1059"},"text":"54 Stat. 1059","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb99d457c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb99d457d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/702"},"text":"Pub. L. 100–702","children":[],"tail":" struck out second par. which read as follows: “The Supreme Court shall prescribe rules of procedure and practice for the trial of cases before magistrates and for taking and hearing of appeals to the judges of the district courts of the United States.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/578"},"text":"Pub. L. 90–578","children":[],"tail":" provided that the appeal shall be of right, substituted “a United States magistrate”, “magistrate”, and “magistrates” for “United States commissioners”, “commissioner”, and “commissioners”, respectively, and provided that the appeals be to the judge of the district court and not to the district court and that the rules of the Supreme Court relate to appeals to the judges of the district courts rather than to the district courts."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb99d457e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb99d457f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“United States magistrate judge” and “magistrate judge” substituted for “United States magistrate” and “magistrate”, respectively, in text pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/650/s321"},"text":"section 321 of Pub. L. 101–650","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s631"},"text":"section 631 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb99d4580-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/702"},"text":"Pub. L. 100–702","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1988-12-01"},"text":"Dec. 1, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/702/s407"},"text":"section 407 of Pub. L. 100–702","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2071"},"text":"section 2071 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb99d4581-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1968 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/578"},"text":"Pub. L. 90–578","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1968-10-17"},"text":"Oct. 17, 1968","children":[],"tail":", except when a later effective date is applicable, which is the earlier of date when implementation of amendment by appointment of magistrates [now United States magistrate judges] and assumption of office takes place or third anniversary of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/90/578"},"text":"Pub. L. 90–578","children":[],"tail":" on "},{"tag":"date","attrib":{"date":"1968-10-17"},"text":"Oct. 17, 1968","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/578/s403"},"text":"section 403 of Pub. L. 90–578","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s631"},"text":"section 631 of title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
