{"tag":"section","attrib":{"id":"idb8b38271-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s177"},"text":null,"children":[{"tag":"num","attrib":{"value":"177"},"text":"§ 177.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunctions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8b38272-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s177/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The United States may obtain in a civil action an injunction against—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b38273-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s177/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct prohibited under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s175"},"text":"section 175 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b38274-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s177/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preparation, solicitation, attempt, threat, or conspiracy to engage in conduct prohibited under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s175"},"text":"section 175 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b38275-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s177/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development, production, stockpiling, transferring, acquisition, retention, or possession, or the attempted development, production, stockpiling, transferring, acquisition, retention, or possession of any biological agent, toxin, or delivery system of a type or in a quantity that under the circumstances has no apparent justification for prophylactic, protective, or other peaceful purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b38276-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s177/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Affirmative Defense","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is an affirmative defense against an injunction under subsection (a)(3) of this section that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b38277-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s177/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct sought to be enjoined is for a prophylactic, protective, or other peaceful purpose; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b38278-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s177/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such biological agent, toxin, or delivery system is of a type and quantity reasonable for that purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8b38279-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/298/s3/a"},"text":"Pub. L. 101–298, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-05-22"},"text":"May 22, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/202"},"text":"104 Stat. 202","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tV/s511/b/2"},"text":"Pub. L. 104–132, title V, § 511(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1284"},"text":"110 Stat. 1284","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8b3827a-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8b3827b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8b3827c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132"},"text":"Pub. L. 104–132","children":[],"tail":" inserted “threat,” after “attempt,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
