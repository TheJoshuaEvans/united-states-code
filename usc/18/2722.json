{"tag":"section","attrib":{"id":"idb97e4ce2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2722"},"text":null,"children":[{"tag":"num","attrib":{"value":"2722"},"text":"§ 2722.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional unlawful acts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb97e4ce3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2722/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procurement for Unlawful Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It shall be unlawful for any person knowingly to obtain or disclose personal information, from a motor vehicle record, for any use not permitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2721/b"},"text":"section 2721(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb97e4ce4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2722/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"False Representation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It shall be unlawful for any person to make false representation to obtain any personal information from an individual’s motor vehicle record.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb97e4ce5-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXX/s300002/a"},"text":"Pub. L. 103–322, title XXX, § 300002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2101"},"text":"108 Stat. 2101","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb97e4ce6-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb97e4ce7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb97e4ce8-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 3 years after ","children":[{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", with provisions relating to release of personal information before the effective date and compliance after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/s300003"},"text":"section 300003 of Pub. L. 103–322","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2721"},"text":"section 2721 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
