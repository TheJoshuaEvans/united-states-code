{"tag":"section","attrib":{"id":"idb96657fb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334"},"text":null,"children":[{"tag":"num","attrib":{"value":"2334"},"text":"§ 2334.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction and venue","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb96657fc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Venue","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any civil action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2333"},"text":"section 2333 of this title","children":[],"tail":" against any person may be instituted in the district court of the United States for any district where any plaintiff resides or where any defendant resides or is served, or has an agent. Process in such a civil action may be served in any district where the defendant resides, is found, or has an agent."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96657fd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Maritime or Territorial Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the actions giving rise to the claim occurred within the special maritime and territorial jurisdiction of the United States, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s7"},"text":"section 7 of this title","children":[],"tail":", then any civil action under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2333"},"text":"section 2333 of this title","children":[],"tail":" against any person may be instituted in the district court of the United States for any district in which any plaintiff resides or the defendant resides, is served, or has an agent."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96657fe-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service on Witnesses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A witness in a civil action brought under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2333"},"text":"section 2333 of this title","children":[],"tail":" may be served in any other district where the defendant resides, is found, or has an agent."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96657ff-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Convenience of the Forum","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The district court shall not dismiss any action brought under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2333"},"text":"section 2333 of this title","children":[],"tail":" on the grounds of the inconvenience or inappropriateness of the forum chosen, unless—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9665800-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the action may be maintained in a foreign court that has jurisdiction over the subject matter and over all the defendants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9665801-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that foreign court is significantly more convenient and appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9665802-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that foreign court offers a remedy which is substantially the same as the one available in the courts of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9665803-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consent of Certain Parties to Personal Jurisdiction.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9665804-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), for purposes of any civil action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2333"},"text":"section 2333 of this title","children":[],"tail":", a defendant shall be deemed to have consented to personal jurisdiction in such civil action if, regardless of the date of the occurrence of the act of international terrorism upon which such civil action was filed, the defendant—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9665805-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" after the date that is 120 days after the date of the enactment of the Promoting Security and Justice for Victims of Terrorism Act of 2019, makes any payment, directly or indirectly—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9665806-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any payee designated by any individual who, after being fairly tried or pleading guilty, has been imprisoned for committing any act of terrorism that injured or killed a national of the United States, if such payment is made by reason of such imprisonment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9665807-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any family member of any individual, following such individual’s death while committing an act of terrorism that injured or killed a national of the United States, if such payment is made by reason of the death of such individual; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9665808-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" after 15 days after the date of enactment of the Promoting Security and Justice for Victims of Terrorism Act of 2019—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9665809-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continues to maintain any office, headquarters, premises, or other facilities or establishments in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb966580a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishes or procures any office, headquarters, premises, or other facilities or establishments in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb966580b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/e/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducts any activity while physically present in the United States on behalf of the Palestine Liberation Organization or the Palestinian Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb966580c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1) shall not apply to any defendant who ceases to engage in the conduct described in paragraphs (1)(A) and (1)(B) for 5 consecutive calendar years. Except with respect to payments described in paragraph (1)(A), no court may consider the receipt of any assistance by a nongovernmental organization, whether direct or indirect, as a basis for consent to jurisdiction by a defendant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb966580d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for certain activities and locations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether a defendant shall be deemed to have consented to personal jurisdiction under paragraph (1)(B), no court may consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb966580e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any office, headquarters, premises, or other facility or establishment used exclusively for the purpose of conducting official business of the United Nations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb966580f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any activity undertaken exclusively for the purpose of conducting official business of the United Nations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9665810-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any activity involving officials of the United States that the Secretary of State determines is in the national interest of the United States if the Secretary reports to the appropriate congressional committees annually on the use of the authority under this subparagraph;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9665811-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any activity undertaken exclusively for the purpose of meetings with officials of the United States or other foreign governments, or participation in training and related activities funded or arranged by the United States Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9665812-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/e/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any activity related to legal representation—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9665813-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/e/3/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for matters related to activities described in this paragraph;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9665814-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/e/3/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the purpose of adjudicating or resolving claims filed in courts of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9665815-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/e/3/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to comply with this subsection; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9665816-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/e/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any personal or official activities conducted ancillary to activities listed under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9665817-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other law (including any treaty), any office, headquarters, premises, or other facility or establishment within the territory of the United States that is not specifically exempted by paragraph (3)(A) shall be considered to be in the United States for purposes of paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9665818-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defined term","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “defendant” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9665819-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Palestinian Authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb966581a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Palestine Liberation Organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb966581b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/e/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any organization or other entity that is a successor to or affiliated with the Palestinian Authority or the Palestine Liberation Organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb966581c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/e/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any organization or other entity that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb966581d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/e/5/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is identified in subparagraph (A), (B), or (C); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb966581e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2334/e/5/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" self identifies as, holds itself out to be, or carries out conduct in the name of, the “State of Palestine” or “Palestine” in connection with official business of the United Nations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb966581f-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572/tX/s1003/a/4"},"text":"Pub. L. 102–572, title X, § 1003(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4522"},"text":"106 Stat. 4522","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/253/s4/a"},"text":"Pub. L. 115–253, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-03"},"text":"Oct. 3, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3184"},"text":"132 Stat. 3184","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dJ/tIX/s903/c/1"},"text":"Pub. L. 116–94, div. J, title IX, § 903(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3083"},"text":"133 Stat. 3083","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9665820-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9665821-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9665822-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Promoting Security and Justice for Victims of Terrorism Act of 2019, referred to in subsec. (e)(1)(A), (B), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dJ/s903"},"text":"section 903 of div. J of Pub. L. 116–94","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9665823-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s903/c/1/A"},"text":"Pub. L. 116–94, § 903(c)(1)(A)","children":[],"tail":", added par. (1) and struck out former par. (1). Prior to amendment, text read as follows: “Except as provided in paragraph (2), for purposes of any civil action under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2333"},"text":"section 2333 of this title","children":[],"tail":", a defendant shall be deemed to have consented to personal jurisdiction in such civil action if, regardless of the date of the occurrence of the act of international terrorism upon which such civil action was filed, the defendant—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) after the date that is 120 days after the date of enactment of this subsection, accepts—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) any form of assistance, however provided, under chapter 4 of part II of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2346"},"text":"22 U.S.C. 2346","children":[],"tail":" et seq.);"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) any form of assistance, however provided, under section 481 of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2291"},"text":"22 U.S.C. 2291","children":[],"tail":") for international narcotics control and law enforcement; or"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iii) any form of assistance, however provided, under chapter 9 of part II of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2349bb"},"text":"22 U.S.C. 2349bb","children":[],"tail":" et seq.); or"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) in the case of a defendant benefiting from a waiver or suspension of section 1003 of the Anti-Terrorism Act of 1987 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s5202"},"text":"22 U.S.C. 5202","children":[],"tail":") after the date that is 120 days after the date of enactment of this subsection—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) continues to maintain any office, headquarters, premises, or other facilities or establishments within the jurisdiction of the United States; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) establishes or procures any office, headquarters, premises, or other facilities or establishments within the jurisdiction of the United States.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s903/c/1/B"},"text":"Pub. L. 116–94, § 903(c)(1)(B)","children":[],"tail":", inserted at end “Except with respect to payments described in paragraph (1)(A), no court may consider the receipt of any assistance by a nongovernmental organization, whether direct or indirect, as a basis for consent to jurisdiction by a defendant.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s903/c/1/C"},"text":"Pub. L. 116–94, § 903(c)(1)(C)","children":[],"tail":", added pars. (3) to (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/253"},"text":"Pub. L. 115–253","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9665824-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb9665825-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment; Abrogation; Construction; Severability","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" applicable to any case pending on or after "},{"tag":"date","attrib":{"date":"2016-08-30"},"text":"Aug. 30, 2016","children":[],"tail":", with additional rules of construction and abrogation and severability provisions, see section 903(c)(2) and (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":", set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2333"},"text":"section 2333 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb9665826-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/253/s4/b"},"text":"Pub. L. 115–253, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-03"},"text":"Oct. 3, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3185"},"text":"132 Stat. 3185","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/253/s4/b"},"text":"“The amendments made by this section [amending this section] shall take effect on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-10-03"},"text":"Oct. 3, 2018","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9665827-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to any pending case or any cause of action arising on or after 4 years before ","children":[{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/s1003/c"},"text":"section 1003(c) of Pub. L. 102–572","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2331"},"text":"section 2331 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
