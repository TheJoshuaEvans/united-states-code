{"tag":"section","attrib":{"id":"idb8c69540-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s288"},"text":null,"children":[{"tag":"num","attrib":{"value":"288"},"text":"§ 288.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False claims for postal losses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever makes, alleges, or presents any claim or application for indemnity for the loss of any registered or insured letter, parcel, package, or other article or matter, or the contents thereof, knowing such claim or application to be false, fictitious, or fraudulent; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever for the purpose of obtaining or aiding to obtain the payment or approval of any such claim or application, makes or uses any false statement, certificate, affidavit, or deposition; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever knowingly and willfully misrepresents, or misstates, or, for the purpose aforesaid, knowingly and willfully conceals any material fact or circumstance in respect of any such claim or application for indemnity—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Shall be fined under this title or imprisoned not more than one year, or both.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Where the amount of such claim or application for indemnity is less than $1,000 only a fine shall be imposed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8c69541-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/698"},"text":"62 Stat. 698","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/G"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(G)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s606/a"},"text":"Pub. L. 104–294, title VI, § 606(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3511"},"text":"110 Stat. 3511","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c69542-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8c69543-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 354 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s224"},"text":"Mar. 4, 1909, ch. 321, § 224","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1133"},"text":"35 Stat. 1133","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1939-08-05/ch429"},"text":"Aug. 5, 1939, ch. 429","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1203"},"text":"53 Stat. 1203","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to persons causing, assisting, aiding, or abetting, was omitted as such persons are made principals by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8c69544-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8c69545-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" substituted “$1,000” for “$100” in fifth par."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $500” in fourth par."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
