{"tag":"section","attrib":{"id":"idb8dc195e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s701"},"text":null,"children":[{"tag":"num","attrib":{"value":"701"},"text":"§ 701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Official badges, identification cards, other insignia","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever manufactures, sells, or possesses any badge, identification card, or other insignia, of the design prescribed by the head of any department or agency of the United States for use by any officer or employee thereof, or any colorable imitation thereof, or photographs, prints, or in any other manner makes or executes any engraving, photograph, print, or impression in the likeness of any such badge, identification card, or other insignia, or any colorable imitation thereof, except as authorized under regulations made pursuant to law, shall be fined under this title or imprisoned not more than six months, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8dc195f-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/731"},"text":"62 Stat. 731","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/E"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2146"},"text":"108 Stat. 2146","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8dc1960-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8dc1961-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., §§ 76a, 76b (","children":[{"tag":"ref","attrib":{"href":"/us/act/1932-06-29/ch306"},"text":"June 29, 1932, ch. 306","children":[],"tail":", §§ 1, 2, "},{"tag":"ref","attrib":{"href":"/us/stat/47/342"},"text":"47 Stat. 342","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1939-05-22/ch141"},"text":"May 22, 1939, ch. 141","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/752"},"text":"53 Stat. 752","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections were consolidated.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The term “department or agency” was substituted for “department or independent office” in two places to embrace all properly constituted agencies as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s6"},"text":"section 6 of this title","children":[],"tail":" and to eliminate any possible ambiguity as to scope of section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8dc1962-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8dc1963-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $250”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
