{"tag":"section","attrib":{"id":"idb9857801-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3047"},"text":null,"children":[{"tag":"num","attrib":{"value":"3047"},"text":"§ 3047.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple warrants unnecessary","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When two or more charges are made, or two or more indictments are found against any person, only one writ or warrant shall be necessary to commit him for trial. It shall be sufficient to state in the writ the name or general character of the offenses, or to refer to them only in general terms.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9857802-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/816"},"text":"62 Stat. 816","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9857803-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9857804-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 602 (R.S. § 1027).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
