{"tag":"section","attrib":{"id":"idb917c2e9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1167"},"text":null,"children":[{"tag":"num","attrib":{"value":"1167"},"text":"§ 1167.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Theft from gaming establishments on Indian lands","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb917c2ea-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1167/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever abstracts, purloins, willfully misapplies, or takes and carries away with intent to steal, any money, funds, or other property of a value of $1,000 or less belonging to an establishment operated by or for or licensed by an Indian tribe pursuant to an ordinance or resolution approved by the National Indian Gaming Commission shall be fined under this title or be imprisoned for not more than one year, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb917c2eb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1167/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever abstracts, purloins, willfully misapplies, or takes and carries away with intent to steal, any money, funds, or other property of a value in excess of $1,000 belonging to a gaming establishment operated by or for or licensed by an Indian tribe pursuant to an ordinance or resolution approved by the National Indian Gaming Commission shall be fined under this title, or imprisoned for not more than ten years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb917c2ec-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/497/s23"},"text":"Pub. L. 100–497, § 23","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-17"},"text":"Oct. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2487"},"text":"102 Stat. 2487","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/S"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(S)","children":[],"tail":", (U), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2148"},"text":"108 Stat. 2148","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb917c2ed-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb917c2ee-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb917c2ef-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/1/S"},"text":"Pub. L. 103–322, § 330016(1)(S)","children":[],"tail":", substituted “fined under this title” for “fined not more than $100,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/1/U"},"text":"Pub. L. 103–322, § 330016(1)(U)","children":[],"tail":", substituted “fined under this title” for “fined not more than $250,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
