{"tag":"section","attrib":{"id":"idb91096e9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1035"},"text":null,"children":[{"tag":"num","attrib":{"value":"1035"},"text":"§ 1035.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False statements relating to health care matters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb91096ea-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1035/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whoever, in any matter involving a health care benefit program, knowingly and willfully—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91096eb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1035/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" falsifies, conceals, or covers up by any trick, scheme, or device a material fact; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91096ec-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1035/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes any materially false, fictitious, or fraudulent statements or representations, or makes or uses any materially false writing or document knowing the same to contain any materially false, fictitious, or fraudulent statement or entry,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"in connection with the delivery of or payment for health care benefits, items, or services, shall be fined under this title or imprisoned not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91096ed-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1035/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As used in this section, the term “health care benefit program” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s24/b"},"text":"section 24(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb91096ee-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/tII/s244/a"},"text":"Pub. L. 104–191, title II, § 244(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2017"},"text":"110 Stat. 2017","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
