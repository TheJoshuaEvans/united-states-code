{"tag":"section","attrib":{"id":"idb936bbe6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1912"},"text":null,"children":[{"tag":"num","attrib":{"value":"1912"},"text":"§ 1912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unauthorized fees for inspection of vessels","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being an officer, employee, or agent of the United States or any agency thereof, engaged in inspection of vessels, upon any pretense, receives any fee or reward for his services, except what is allowed to him by law, shall be fined under this title or imprisoned not more than six months, or both; and shall forfeit his office.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb936bbe7-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/792"},"text":"62 Stat. 792","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/G"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(G)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb936bbe8-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb936bbe9-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 196 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s107"},"text":"Mar. 4, 1909, ch. 321, § 107","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1107"},"text":"35 Stat. 1107","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The phrase “officer or employee of the United States or any agency thereof” was substituted for the phrase “inspector of steamboats” in view of 1946 Reorganization Plan No. 3, eff. ","children":[{"tag":"date","attrib":{"date":"1946-07-16"},"text":"July 16, 1946","children":[],"tail":", 11 F.R. 7875, "},{"tag":"ref","attrib":{"href":"/us/stat/60/1097"},"text":"60 Stat. 1097","children":[],"tail":", abolishing inspectors and transferring their functions to the Coast Guard."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb936bbea-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb936bbeb-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $500”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
