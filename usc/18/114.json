{"tag":"section","attrib":{"id":"idb8aec75d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s114"},"text":null,"children":[{"tag":"num","attrib":{"value":"114"},"text":"§ 114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maiming within maritime and territorial jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, within the special maritime and territorial jurisdiction of the United States, and with intent to torture (as defined in section 2340), maim, or disfigure, cuts, bites, or slits the nose, ear, or lip, or cuts out or disables the tongue, or puts out or destroys an eye, or cuts off or disables a limb or any member of another person; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever, within the special maritime and territorial jurisdiction of the United States, and with like intent, throws or pours upon another person, any scalding water, corrosive acid, or caustic substance—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Shall be fined under this title or imprisoned not more than twenty years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8aec75e-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/689"},"text":"62 Stat. 689","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-05-24/ch139/s3"},"text":"May 24, 1949, ch. 139, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/90"},"text":"63 Stat. 90","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s1009A"},"text":"Pub. L. 98–473, title II, § 1009A","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2141"},"text":"98 Stat. 2141","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXV/s3507"},"text":"Pub. L. 101–647, title XXXV, § 3507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4922"},"text":"104 Stat. 4922","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/O"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(O)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2148"},"text":"108 Stat. 2148","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tVII/s705/a/1"},"text":"Pub. L. 104–132, title VII, § 705(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1295"},"text":"110 Stat. 1295","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8aec75f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8aec760-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8aec761-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1948 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 462 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s283"},"text":"Mar. 4, 1909, ch. 321, § 283","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1144"},"text":"35 Stat. 1144","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “within the special maritime and territorial jurisdiction of the United States, and” were added to preserve jurisdictional limitation provided for by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s451"},"text":"section 451 of title 18","children":[],"tail":", U.S.C., 1940 ed., now "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s7"},"text":"section 7 of this title","children":[],"tail":". (See reviser’s note thereunder.)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8aec762-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1949 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This section [section 3] corrects a typographical error in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s114"},"text":"section 114 of title 18","children":[],"tail":", U.S.C."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8aec763-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8aec764-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132"},"text":"Pub. L. 104–132","children":[],"tail":" substituted “torture (as defined in section 2340), maim, or disfigure” for “maim or disfigure”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $25,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":" substituted “or imprisoned” for “and imprisoned”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":" substituted “and imprisoned” for “or imprisoned” and provisions raising maximum fine from $1,000 to $25,000 and raising maximum term of imprisonment from seven years to twenty years."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1949—Act ","children":[{"tag":"date","attrib":{"date":"1949-05-24"},"text":"May 24, 1949","children":[],"tail":", corrected spelling of “maim”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
