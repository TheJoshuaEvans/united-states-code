{"tag":"section","attrib":{"id":"idb9cce118-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4130"},"text":null,"children":[{"tag":"num","attrib":{"value":"4130"},"text":"§ 4130.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional markets","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9cce119-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4130/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), notwithstanding any other provision of law, Federal Prison Industries may sell products to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9cce11a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4130/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public entities for use in penal or correctional institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9cce11b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4130/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public entities for use in disaster relief or emergency response;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9cce11c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4130/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the government of the District of Columbia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9cce11d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4130/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any organization described in subsection (c)(3), (c)(4), or (d) of section 501 of the Internal Revenue Code of 1986 that is exempt from taxation under section 501(a) of such Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9cce11e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4130/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Office Furniture","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Federal Prison Industries may not sell office furniture to the organizations described in subsection (a)(4).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9cce11f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4130/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9cce120-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4130/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “office furniture” means any product or service offering intended to meet the furnishing needs of the workplace, including office, healthcare, educational, and hospitality environments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9cce121-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4130/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “public entity” means a State, a subdivision of a State, an Indian tribe, and an agency or governmental corporation or business of any of the foregoing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9cce122-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4130/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” means a State, the District of Columbia, the Commonwealth of Puerto Rico, Guam, American Samoa, the Northern Mariana Islands, and the United States Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9cce123-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/391/tVI/s605/a"},"text":"Pub. L. 115–391, title VI, § 605(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5242"},"text":"132 Stat. 5242","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9cce124-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9cce125-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9cce126-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 501 of the Internal Revenue Code of 1986, referred to in subsec. (a)(4), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501"},"text":"section 501 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
