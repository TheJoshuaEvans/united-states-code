{"tag":"section","attrib":{"id":"idb932015f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1831"},"text":null,"children":[{"tag":"num","attrib":{"value":"1831"},"text":"§ 1831.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Economic espionage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9320160-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1831/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever, intending or knowing that the offense will benefit any foreign government, foreign instrumentality, or foreign agent, knowingly—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9320161-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1831/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" steals, or without authorization appropriates, takes, carries away, or conceals, or by fraud, artifice, or deception obtains a trade secret;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9320162-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1831/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without authorization copies, duplicates, sketches, draws, photographs, downloads, uploads, alters, destroys, photocopies, replicates, transmits, delivers, sends, mails, communicates, or conveys a trade secret;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9320163-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1831/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receives, buys, or possesses a trade secret, knowing the same to have been stolen or appropriated, obtained, or converted without authorization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9320164-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1831/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attempts to commit any offense described in any of paragraphs (1) through (3); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9320165-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1831/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conspires with one or more other persons to commit any offense described in any of paragraphs (1) through (3), and one or more of such persons do any act to effect the object of the conspiracy,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall, except as provided in subsection (b), be fined not more than $5,000,000 or imprisoned not more than 15 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9320166-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1831/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Organizations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any organization that commits any offense described in subsection (a) shall be fined not more than the greater of $10,000,000 or 3 times the value of the stolen trade secret to the organization, including expenses for research and design and other costs of reproducing the trade secret that the organization has thereby avoided.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9320167-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294/tI/s101/a"},"text":"Pub. L. 104–294, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3488"},"text":"110 Stat. 3488","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/269/s2"},"text":"Pub. L. 112–269, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-14"},"text":"Jan. 14, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2442"},"text":"126 Stat. 2442","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9320168-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9320169-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb932016a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/269/s2/a"},"text":"Pub. L. 112–269, § 2(a)","children":[],"tail":", substituted “not more than $5,000,000” for “not more than $500,000” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/269/s2/b"},"text":"Pub. L. 112–269, § 2(b)","children":[],"tail":", substituted “not more than the greater of $10,000,000 or 3 times the value of the stolen trade secret to the organization, including expenses for research and design and other costs of reproducing the trade secret that the organization has thereby avoided” for “not more than $10,000,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
