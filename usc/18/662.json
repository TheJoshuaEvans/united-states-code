{"tag":"section","attrib":{"id":"idb8d9a7d0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s662"},"text":null,"children":[{"tag":"num","attrib":{"value":"662"},"text":"§ 662.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receiving stolen property within special maritime and territorial jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, within the special maritime and territorial jurisdiction of the United States, buys, receives, or conceals any money, goods, bank notes, or other thing which may be the subject of larceny, which has been feloniously taken, stolen, or embezzled, from any other person, knowing the same to have been so taken, stolen, or embezzled, shall be fined under this title or imprisoned not more than three years, or both; but if the amount or value of thing so taken, stolen or embezzled does not exceed $1,000, he shall be fined under this title or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8d9a7d1-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/731"},"text":"62 Stat. 731","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s606/a"},"text":"Pub. L. 104–294, title VI, § 606(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3511"},"text":"110 Stat. 3511","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8d9a7d2-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8d9a7d3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 467 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s288"},"text":"Mar. 4, 1909, ch. 321, § 288","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1145"},"text":"35 Stat. 1145","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Same language was inserted as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s661"},"text":"section 661 of this title","children":[],"tail":" for the same reason."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Mandatory punishment provision was rephrased in the alternative.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The smaller punishment for an offense involving $100 or less was added. (See reviser’s notes under sections 641 and 645 of this title.)","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This accords with the recommendation of United States Attorney P. F. Herrick of Puerto Rico.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Language as to order of trial was omitted and incorporated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3435"},"text":"section 3435 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8d9a7d4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8d9a7d5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" substituted “$1,000” for “$100”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $1,000” in two places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
