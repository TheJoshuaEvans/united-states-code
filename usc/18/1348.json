{"tag":"section","attrib":{"id":"idb91c7d33-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1348"},"text":null,"children":[{"tag":"num","attrib":{"value":"1348"},"text":"§ 1348.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Securities and commodities fraud","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Whoever knowingly executes, or attempts to execute, a scheme or artifice—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91c7d34-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1348/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to defraud any person in connection with any commodity for future delivery, or any option on a commodity for future delivery, or any security of an issuer with a class of securities registered under section 12 of the Securities Exchange Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78"},"text":"15 U.S.C. 78","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") or that is required to file reports under section 15(d) of the Securities Exchange Act of 1934 ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78"},"text":"15 U.S.C. 78","children":[],"tail":null},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(d)); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91c7d35-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1348/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain, by means of false or fraudulent pretenses, representations, or promises, any money or property in connection with the purchase or sale of any commodity for future delivery, or any option on a commodity for future delivery, or any security of an issuer with a class of securities registered under section 12 of the Securities Exchange Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78"},"text":"15 U.S.C. 78","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") or that is required to file reports under section 15(d) of the Securities Exchange Act of 1934 ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78"},"text":"15 U.S.C. 78","children":[],"tail":null},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(d));"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title, or imprisoned not more than 25 years, or both.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb91c7d36-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204/tVIII/s807/a"},"text":"Pub. L. 107–204, title VIII, § 807(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/804"},"text":"116 Stat. 804","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/21/s2/e/1"},"text":"Pub. L. 111–21, § 2(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1618"},"text":"123 Stat. 1618","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91c7d37-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb91c7d38-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb91c7d39-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/21/s2/e/1/A"},"text":"Pub. L. 111–21, § 2(e)(1)(A)","children":[],"tail":", inserted “and commodities” before “fraud” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/21/s2/e/1/B"},"text":"Pub. L. 111–21, § 2(e)(1)(B)","children":[],"tail":", (C), inserted “any commodity for future delivery, or any option on a commodity for future delivery, or” before “any security”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
