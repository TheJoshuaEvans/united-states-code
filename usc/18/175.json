{"tag":"section","attrib":{"id":"idb8b1382b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s175"},"text":null,"children":[{"tag":"num","attrib":{"value":"175"},"text":"§ 175.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions with respect to biological weapons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8b1382c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s175/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever knowingly develops, produces, stockpiles, transfers, acquires, retains, or possesses any biological agent, toxin, or delivery system for use as a weapon, or knowingly assists a foreign state or any organization to do so, or attempts, threatens, or conspires to do the same, shall be fined under this title or imprisoned for life or any term of years, or both. There is extraterritorial Federal jurisdiction over an offense under this section committed by or against a national of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b1382d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s175/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Offense","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever knowingly possesses any biological agent, toxin, or delivery system of a type or in a quantity that, under the circumstances, is not reasonably justified by a prophylactic, protective, bona fide research, or other peaceful purpose, shall be fined under this title, imprisoned not more than 10 years, or both. In this subsection, the terms “biological agent” and “toxin” do not encompass any biological agent or toxin that is in its naturally occurring environment, if the biological agent or toxin has not been cultivated, collected, or otherwise extracted from its natural source.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b1382e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s175/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, the term “for use as a weapon” includes the development, production, transfer, acquisition, retention, or possession of any biological agent, toxin, or delivery system for other than prophylactic, protective, bona fide research, or other peaceful purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8b1382f-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/298/s3/a"},"text":"Pub. L. 101–298, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-05-22"},"text":"May 22, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/201"},"text":"104 Stat. 201","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tV/s511/b/1"},"text":"Pub. L. 104–132, title V, § 511(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1284"},"text":"110 Stat. 1284","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tVIII/s817/1"},"text":"Pub. L. 107–56, title VIII, § 817(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/385"},"text":"115 Stat. 385","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/188/tII/s231/c/1"},"text":"Pub. L. 107–188, title II, § 231(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-12"},"text":"June 12, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/661"},"text":"116 Stat. 661","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8b13830-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8b13831-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8b13832-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/188"},"text":"Pub. L. 107–188","children":[],"tail":" substituted “protective, bona fide research, or other peaceful purposes” for “protective bona fide research, or other peaceful purposes”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/s817/1/C"},"text":"Pub. L. 107–56, § 817(1)(C)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/s817/1/A"},"text":"Pub. L. 107–56, § 817(1)(A)","children":[],"tail":", substituted “includes” for “does not include” and inserted “other than” after “delivery system for” and “bona fide research” after “protective”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/s817/1/B"},"text":"Pub. L. 107–56, § 817(1)(B)","children":[],"tail":", redesignated subsec. (b) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132"},"text":"Pub. L. 104–132","children":[],"tail":" inserted “or attempts, threatens, or conspires to do the same,” before “shall be fined under this title”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8b13833-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idb8b13834-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/298/s1"},"text":"Pub. L. 101–298, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-05-22"},"text":"May 22, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/201"},"text":"104 Stat. 201","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/298/s1"},"text":"“This Act [enacting this chapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2516"},"text":"section 2516 of this title","children":[],"tail":"] may be cited as the ‘Biological Weapons Anti-Terrorism Act of 1989’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8b13835-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purpose and Intent","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/298/s2"},"text":"Pub. L. 101–298, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-05-22"},"text":"May 22, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/201"},"text":"104 Stat. 201","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/298/s2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of this Act [see Short Title note above] is to—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement the Biological Weapons Convention, an international agreement unanimously ratified by the United States Senate in 1974 and signed by more than 100 other nations, including the Soviet Union; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect the United States against the threat of biological terrorism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Intent of Act","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this Act is intended to restrain or restrict peaceful scientific research or development.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
