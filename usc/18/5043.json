{"tag":"section","attrib":{"id":"idb9d67e67-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043"},"text":null,"children":[{"tag":"num","attrib":{"value":"5043"},"text":"§ 5043.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Juvenile solitary confinement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9d67e68-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9d67e69-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “covered juvenile” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9d67e6a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a juvenile who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9d67e6b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is being proceeded against under this chapter for an alleged act of juvenile delinquency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9d67e6c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been adjudicated delinquent under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9d67e6d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a juvenile who is being proceeded against as an adult in a district court of the United States for an alleged criminal offense;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9d67e6e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “juvenile facility” means any facility where covered juveniles are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9d67e6f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" committed pursuant to an adjudication of delinquency under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9d67e70-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detained prior to disposition or conviction; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9d67e71-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “room confinement” means the involuntary placement of a covered juvenile alone in a cell, room, or other area for any reason.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9d67e72-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Room Confinement in Juvenile Facilities.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9d67e73-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The use of room confinement at a juvenile facility for discipline, punishment, retaliation, or any reason other than as a temporary response to a covered juvenile’s behavior that poses a serious and immediate risk of physical harm to any individual, including the covered juvenile, is prohibited.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9d67e74-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Juveniles posing risk of harm.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9d67e75-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement to use least restrictive techniques.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idb9d67e76-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before a staff member of a juvenile facility places a covered juvenile in room confinement, the staff member shall attempt to use less restrictive techniques, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb9d67e77-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/b/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" talking with the covered juvenile in an attempt to de-escalate the situation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb9d67e78-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/b/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permitting a qualified mental health professional to talk to the covered juvenile.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9d67e79-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Explanation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, after attempting to use less restrictive techniques as required under clause (i), a staff member of a juvenile facility decides to place a covered juvenile in room confinement, the staff member shall first—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb9d67e7a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/b/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explain to the covered juvenile the reasons for the room confinement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb9d67e7b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/b/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" inform the covered juvenile that release from room confinement will occur—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idb9d67e7c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/b/2/A/ii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immediately when the covered juvenile regains self-control, as described in subparagraph (B)(i); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idb9d67e7d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/b/2/A/ii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than after the expiration of the time period described in subclause (I) or (II) of subparagraph (B)(ii), as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9d67e7e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum period of confinement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a covered juvenile is placed in room confinement because the covered juvenile poses a serious and immediate risk of physical harm to himself or herself, or to others, the covered juvenile shall be released—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9d67e7f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immediately when the covered juvenile has sufficiently gained control so as to no longer engage in behavior that threatens serious and immediate risk of physical harm to himself or herself, or to others; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9d67e80-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if a covered juvenile does not sufficiently gain control as described in clause (i), not later than—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb9d67e81-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/b/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 hours after being placed in room confinement, in the case of a covered juvenile who poses a serious and immediate risk of physical harm to others; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb9d67e82-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/b/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 30 minutes after being placed in room confinement, in the case of a covered juvenile who poses a serious and immediate risk of physical harm only to himself or herself.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9d67e83-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Risk of harm after maximum period of confinement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, after the applicable maximum period of confinement under subclause (I) or (II) of subparagraph (B)(ii) has expired, a covered juvenile continues to pose a serious and immediate risk of physical harm described in that subclause—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9d67e84-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the covered juvenile shall be transferred to another juvenile facility or internal location where services can be provided to the covered juvenile without relying on room confinement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9d67e85-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a qualified mental health professional believes the level of crisis service needed is not currently available, a staff member of the juvenile facility shall initiate a referral to a location that can meet the needs of the covered juvenile.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9d67e86-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5043/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Spirit and purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The use of consecutive periods of room confinement to evade the spirit and purpose of this subsection shall be prohibited.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9d67e87-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/391/tVI/s613/a"},"text":"Pub. L. 115–391, title VI, § 613(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5247"},"text":"132 Stat. 5247","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
