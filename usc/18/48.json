{"tag":"section","attrib":{"id":"idb8aa0ce8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48"},"text":null,"children":[{"tag":"num","attrib":{"value":"48"},"text":"§ 48.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Animal crushing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8aa0ce9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offenses.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8aa0cea-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Crushing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It shall be unlawful for any person to purposely engage in animal crushing in or affecting interstate or foreign commerce or within the special maritime and territorial jurisdiction of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8aa0ceb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Creation of animal crush videos","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be unlawful for any person to knowingly create an animal crush video, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8aa0cec-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person intends or has reason to know that the animal crush video will be distributed in, or using a means or facility of, interstate or foreign commerce; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8aa0ced-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the animal crush video is distributed in, or using a means or facility of, interstate or foreign commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8aa0cee-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribution of animal crush videos","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It shall be unlawful for any person to knowingly sell, market, advertise, exchange, or distribute an animal crush video in, or using a means or facility of, interstate or foreign commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8aa0cef-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extraterritorial Application","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section applies to the knowing sale, marketing, advertising, exchange, distribution, or creation of an animal crush video outside of the United States, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8aa0cf0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person engaging in such conduct intends or has reason to know that the animal crush video will be transported into the United States or its territories or possessions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8aa0cf1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the animal crush video is transported into the United States or its territories or possessions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8aa0cf2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever violates this section shall be fined under this title, imprisoned for not more than 7 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8aa0cf3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8aa0cf4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section does not apply with regard to any conduct, or a visual depiction of that conduct, that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8aa0cf5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a customary and normal veterinary, agricultural husbandry, or other animal management practice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8aa0cf6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the slaughter of animals for food;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8aa0cf7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hunting, trapping, fishing, a sporting activity not otherwise prohibited by Federal law, predator control, or pest control;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8aa0cf8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical or scientific research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8aa0cf9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary to protect the life or property of a person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8aa0cfa-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performed as part of euthanizing an animal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8ac7cfb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Good-faith distribution","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section does not apply to the good-faith distribution of an animal crush video to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8ac7cfc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a law enforcement agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8ac7cfd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a third party for the sole purpose of analysis to determine if referral to a law enforcement agency is appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8ac7cfe-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unintentional conduct","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not apply to unintentional conduct that injures or kills an animal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8ac7cff-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consistency with rfra","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall be enforced in a manner that is consistent with section 3 of the Religious Freedom Restoration Act of 1993 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000bb–1"},"text":"42 U.S.C. 2000bb–1","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8ac7d00-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Preemption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to preempt the law of any State or local subdivision thereof to protect animals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8ac7d01-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8ac7d02-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “animal crushing” means actual conduct in which one or more living non-human mammals, birds, reptiles, or amphibians is purposely crushed, burned, drowned, suffocated, impaled, or otherwise subjected to serious bodily injury (as defined in section 1365 and including conduct that, if committed against a person and in the special maritime and territorial jurisdiction of the United States, would violate section 2241 or 2242);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8ac7d03-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “animal crush video” means any photograph, motion-picture film, video or digital recording, or electronic image that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8ac7d04-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" depicts animal crushing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8ac7d05-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is obscene; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8ac7d06-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “euthanizing an animal” means the humane destruction of an animal accomplished by a method that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8ac7d07-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produces rapid unconsciousness and subsequent death without evidence of pain or distress; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8ac7d08-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s48/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses anesthesia produced by an agent that causes painless loss of consciousness and subsequent death.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8ac7d09-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/152/s1/a"},"text":"Pub. L. 106–152, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1732"},"text":"113 Stat. 1732","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/294/s3/a"},"text":"Pub. L. 111–294, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-09"},"text":"Dec. 9, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3178"},"text":"124 Stat. 3178","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/72/s2/a"},"text":"Pub. L. 116–72, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-11-25"},"text":"Nov. 25, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1151"},"text":"133 Stat. 1151","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8ac7d0a-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8ac7d0b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8ac7d0c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/72"},"text":"Pub. L. 116–72","children":[],"tail":" amended section generally. Prior to amendment, section related to animal crush videos."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/294"},"text":"Pub. L. 111–294","children":[],"tail":" amended section generally. Prior to amendment, section related to depiction of animal cruelty."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8ac7d0d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"separability","id":"idb8ac7d0e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Severability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/294/s3/c"},"text":"Pub. L. 111–294, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-09"},"text":"Dec. 9, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3179"},"text":"124 Stat. 3179","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/294/s3/c"},"text":"“If any provision of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s48"},"text":"section 48 of title 18","children":[],"tail":", United States Code (as amended by this section), or the application of the provision to any person or circumstance, is held to be unconstitutional, the provision and the application of the provision to other persons or circumstances shall not be affected thereby.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8ac7d0f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/294/s2"},"text":"Pub. L. 111–294, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-09"},"text":"Dec. 9, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3177"},"text":"124 Stat. 3177","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/294/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Congress finds the following:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States has a long history of prohibiting the interstate sale, marketing, advertising, exchange, and distribution of obscene material and speech that is integral to criminal conduct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal Government and the States have a compelling interest in preventing intentional acts of extreme animal cruelty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each of the several States and the District of Columbia criminalize intentional acts of extreme animal cruelty, such as the intentional crushing, burning, drowning, suffocating, or impaling of animals for no socially redeeming purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are certain extreme acts of animal cruelty that appeal to a specific sexual fetish. These acts of extreme animal cruelty are videotaped, and the resulting video tapes are commonly referred to as ‘animal crush videos’.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Supreme Court of the United States has long held that obscenity is an exception to speech protected under the First Amendment to the Constitution of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the judgment of Congress, many animal crush videos are obscene in the sense that the depictions, taken as a whole—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appeal to the prurient interest in sex;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are patently offensive; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lack serious literary, artistic, political, or scientific value.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Serious criminal acts of extreme animal cruelty are integral to the creation, sale, distribution, advertising, marketing, and exchange of animal crush videos.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The creation, sale, distribution, advertising, marketing, and exchange of animal crush videos is intrinsically related and integral to creating an incentive for, directly causing, and perpetuating demand for the serious acts of extreme animal cruelty the videos depict. The primary reason for those criminal acts is the creation, sale, distribution, advertising, marketing, and exchange of the animal crush video image.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"“(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The serious acts of extreme animal cruelty necessary to make animal crush videos are committed in a clandestine manner that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allows the perpetrators of such crimes to remain anonymous;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes it extraordinarily difficult to establish the jurisdiction within which the underlying criminal acts of extreme animal cruelty occurred; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" often precludes proof that the criminal acts occurred within the statute of limitations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"“(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each of the difficulties described in paragraph (9) seriously frustrates and impedes the ability of State authorities to enforce the criminal statutes prohibiting such behavior.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
