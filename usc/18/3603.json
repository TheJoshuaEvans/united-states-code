{"tag":"section","attrib":{"id":"idb9b05925-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3603"},"text":null,"children":[{"tag":"num","attrib":{"value":"3603"},"text":"§ 3603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of probation officers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A probation officer shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9b05926-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3603/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" instruct a probationer or a person on supervised release, who is under his supervision, as to the conditions specified by the sentencing court, and provide him with a written statement clearly setting forth all such conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9b05927-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3603/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" keep informed, to the degree required by the conditions specified by the sentencing court, as to the conduct and condition of a probationer or a person on supervised release, who is under his supervision, and report his conduct and condition to the sentencing court;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9b05928-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3603/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use all suitable methods, not inconsistent with the conditions specified by the court, to aid a probationer or a person on supervised release who is under his supervision, and to bring about improvements in his conduct and condition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9b05929-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3603/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be responsible for the supervision of any probationer or a person on supervised release who is known to be within the judicial district;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9b0592a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3603/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" keep a record of his work, and make such reports to the Director of the Administrative Office of the United States Courts as the Director may require;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9b0592b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3603/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon request of the Attorney General or his designee, assist in the supervision of and furnish information about, a person within the custody of the Attorney General while on work release, furlough, or other authorized release from his regular place of confinement, or while in prerelease custody pursuant to the provisions of section 3624(c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9b0592c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3603/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" keep informed concerning the conduct, condition, and compliance with any condition of probation, including the payment of a fine or restitution of each probationer under his supervision and report thereon to the court placing such person on probation and report to the court any failure of a probationer under his supervision to pay a fine in default within thirty days after notification that it is in default so that the court may determine whether probation should be revoked;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9b0592d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3603/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9b0592e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3603/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when directed by the court, and to the degree required by the regimen of care or treatment ordered by the court as a condition of release, keep informed as to the conduct and provide supervision of a person conditionally released under the provisions of section 4243, 4246, or 4248 of this title, and report such person’s conduct and condition to the court ordering release and to the Attorney General or his designee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9b0592f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3603/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immediately report any violation of the conditions of release to the court and the Attorney General or his designee;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9b05930-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3603/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if approved by the district court, be authorized to carry firearms under such rules and regulations as the Director of the Administrative Office of the United States Courts may prescribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9b05931-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3603/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform any other duty that the court may designate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9b05932-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s212/a/2"},"text":"Pub. L. 98–473, title II, § 212(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2002"},"text":"98 Stat. 2002","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/646/s15/a"},"text":"Pub. L. 99–646, § 15(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3595"},"text":"100 Stat. 3595","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tVII/s701/a"},"text":"Pub. L. 102–572, title VII, § 701(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4514"},"text":"106 Stat. 4514","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/317/tI/s101/a"},"text":"Pub. L. 104–317, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3848"},"text":"110 Stat. 3848","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/391/tVI/s609/a"},"text":"Pub. L. 115–391, title VI, § 609(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5245"},"text":"132 Stat. 5245","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9b05933-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9b05934-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9b05935-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Par. (8)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/391"},"text":"Pub. L. 115–391","children":[],"tail":" substituted “, 4246, or 4248” for “or 4246”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Pars. (9), (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/317"},"text":"Pub. L. 104–317","children":[],"tail":" added par. (9) and redesignated former par. (9) as (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Pars. (8), (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" added par. (8) and redesignated former par. (8) as (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646"},"text":"Pub. L. 99–646","children":[],"tail":" redesignated pars. (a) to (h) as (1) to (8), respectively, and in par. (6) substituted “assist in the supervision of” for “supervise” and inserted a comma after “about”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9b05936-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb9b05937-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-01-01"},"text":"Jan. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/s1101"},"text":"section 1101 of Pub. L. 102–572","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s905"},"text":"section 905 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb9b05938-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646/s15/b"},"text":"Pub. L. 99–646, § 15(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3595"},"text":"100 Stat. 3595","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/646/s15/b"},"text":"“The amendments made by this section [amending this section] shall take effect on the date of the taking effect of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3603"},"text":"section 3603 of title 18","children":[],"tail":", United States Code ["},{"tag":"date","attrib":{"date":"1987-11-01"},"text":"Nov. 1, 1987","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9b05939-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1987-11-01"},"text":"Nov. 1, 1987","children":[],"tail":", and applicable only to offenses committed after the taking effect of this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/s235/a/1"},"text":"section 235(a)(1) of Pub. L. 98–473","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3551"},"text":"section 3551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
