{"tag":"section","attrib":{"id":"idb8d2a398-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s594"},"text":null,"children":[{"tag":"num","attrib":{"value":"594"},"text":"§ 594.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intimidation of voters","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever intimidates, threatens, coerces, or attempts to intimidate, threaten, or coerce, any other person for the purpose of interfering with the right of such other person to vote or to vote as he may choose, or of causing such other person to vote for, or not to vote for, any candidate for the office of President, Vice President, Presidential elector, Member of the Senate, Member of the House of Representatives, Delegate from the District of Columbia, or Resident Commissioner, at any election held solely or in part for the purpose of electing such candidate, shall be fined under this title or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8d2a399-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/720"},"text":"62 Stat. 720","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/405/tII/s204/d/5"},"text":"Pub. L. 91–405, title II, § 204(d)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-09-22"},"text":"Sept. 22, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/853"},"text":"84 Stat. 853","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8d2a39a-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8d2a39b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., §§ 61, 61g (","children":[{"tag":"date","attrib":{"date":"1939-08-02"},"text":"Aug. 2, 1939","children":[],"tail":", 11:50 a.m. E.S.T., ch. 410, §§ 1, 8, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1147"},"text":"53 Stat. 1147","children":[],"tail":", 1148)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section consolidates sections 61 and 61g of title 18, U.S.C., 1940 ed., with changes in phraseology only.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8d2a39c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8d2a39d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $1,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/405"},"text":"Pub. L. 91–405","children":[],"tail":" substituted “Delegate from the District of Columbia, or Resident Commissioner” for “Delegates or Commissioners from the Territories and possessions”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8d2a39e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8d2a39f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/405"},"text":"Pub. L. 91–405","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1970-09-22"},"text":"Sept. 22, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/405/s206/b"},"text":"section 206(b) of Pub. L. 91–405","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s25a"},"text":"section 25a of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
