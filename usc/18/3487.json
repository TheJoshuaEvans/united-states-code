{"tag":"section","attrib":{"id":"idb99d460f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3487"},"text":null,"children":[{"tag":"num","attrib":{"value":"3487"},"text":"§ 3487.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refusal to pay as evidence of embezzlement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The refusal of any person, whether in or out of office, charged with the safe-keeping, transfer, or disbursement of the public money to pay any draft, order, or warrant, drawn upon him by the Government Accountability Office, for any public money in his hands belonging to the United States, no matter in what capacity the same may have been received, or may be held, or to transfer or disburse any such money, promptly, upon the legal requirement of any authorized officer, shall be deemed, upon the trial of any indictment against such person for embezzlement, prima facie evidence of such embezzlement.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb99d4610-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/833"},"text":"62 Stat. 833","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb99d4611-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb99d4612-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 180 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s94"},"text":"Mar. 4, 1909, ch. 321, § 94","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1106"},"text":"35 Stat. 1106","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1921-06-10/ch18/s304"},"text":"June 10, 1921, ch. 18, § 304","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/24"},"text":"42 Stat. 24","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“General Accounting Office” was substituted for “proper accounting officer of the Treasury”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb99d4613-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb99d4614-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
