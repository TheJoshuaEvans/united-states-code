{"tag":"section","attrib":{"id":"idb8ac7d53-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s113"},"text":null,"children":[{"tag":"num","attrib":{"value":"113"},"text":"§ 113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assaults within maritime and territorial jurisdiction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8ac7d54-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whoever, within the special maritime and territorial jurisdiction of the United States, is guilty of an assault shall be punished as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8ac7d55-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s113/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assault with intent to commit murder or a violation of section 2241 or 2242, by a fine under this title, imprisonment for not more than 20 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8ac7d56-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s113/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assault with intent to commit any felony, except murder or a violation of section 2241 or 2242, by a fine under this title or imprisonment for not more than ten years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8ac7d57-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s113/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assault with a dangerous weapon, with intent to do bodily harm, by a fine under this title or imprisonment for not more than ten years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8ac7d58-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s113/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assault by striking, beating, or wounding, by a fine under this title or imprisonment for not more than 1 year, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8ac7d59-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s113/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Simple assault, by a fine under this title or imprisonment for not more than six months, or both, or if the victim of the assault is an individual who has not attained the age of 16 years, by fine under this title or imprisonment for not more than 1 year, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8ac7d5a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s113/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assault resulting in serious bodily injury, by a fine under this title or imprisonment for not more than ten years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8ac7d5b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s113/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assault resulting in substantial bodily injury to a spouse or intimate partner, a dating partner, or an individual who has not attained the age of 16 years, by a fine under this title or imprisonment for not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8ac7d5c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s113/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assault of a spouse, intimate partner, or dating partner by strangling, suffocating, or attempting to strangle or suffocate, by a fine under this title, imprisonment for not more than 10 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8ac7d5d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8ac7d5e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s113/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “substantial bodily injury” means bodily injury which involves—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8ac7d5f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s113/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a temporary but substantial disfigurement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8ac7d60-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s113/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a temporary but substantial loss or impairment of the function of any bodily member, organ, or mental faculty;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8ac7d61-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s113/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “serious bodily injury” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1365"},"text":"section 1365 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8ac7d62-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s113/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “dating partner” and “spouse or intimate partner” have the meanings ","children":[{"tag":"ref","attrib":{"idref":"fn002021"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002021"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “meaning”."}],"tail":" given those terms in section 2266;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8ac7d63-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s113/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “strangling” means intentionally, knowingly, or recklessly impeding the normal breathing or circulation of the blood of a person by applying pressure to the throat or neck, regardless of whether that conduct results in any visible injury or whether there is any intent to kill or protractedly injure the victim; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8ac7d64-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s113/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “suffocating” means intentionally, knowingly, or recklessly impeding the normal breathing of a person by covering the mouth of the person, the nose of the person, or both, regardless of whether that conduct results in any visible injury or whether there is any intent to kill or protractedly injure the victim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8ac7d65-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/689"},"text":"62 Stat. 689","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/297/s3"},"text":"Pub. L. 94–297, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-29"},"text":"May 29, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/585"},"text":"90 Stat. 585","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/646/s87/c/2"},"text":"Pub. L. 99–646, § 87(c)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3623"},"text":"100 Stat. 3623","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/654/s3/a/2"},"text":"Pub. L. 99–654, § 3(a)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3663"},"text":"100 Stat. 3663","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXVII/s170201/a"},"text":"Pub. L. 103–322, title XVII, § 170201(a)","children":[],"tail":"–(d), title XXXII, § 320101(c), title XXXIII, § 330016(2)(B), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2042"},"text":"108 Stat. 2042","children":[],"tail":", 2043, 2108, 2148; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s604/b/7"},"text":"Pub. L. 104–294, title VI, § 604(b)(7)","children":[],"tail":", (12)(B), "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3507"},"text":"110 Stat. 3507","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/tIX/s906/a"},"text":"Pub. L. 113–4, title IX, § 906(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/124"},"text":"127 Stat. 124","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8ac7d66-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8ac7d67-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 455 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s276"},"text":"Mar. 4, 1909, ch. 321, § 276","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1143"},"text":"35 Stat. 1143","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Opening paragraph was added to preserve the jurisdictional limitation provided for by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s451"},"text":"section 451 of title 18","children":[],"tail":", U.S.C., 1940 ed., now "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s7"},"text":"section 7 of this title","children":[],"tail":". (See reviser’s note thereunder.)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Phraseology was simplified.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8ac7d68-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8ac7d69-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s906/a/1/A"},"text":"Pub. L. 113–4, § 906(a)(1)(A)","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “Assault with intent to commit murder, by imprisonment for not more than twenty years.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s906/a/1/B"},"text":"Pub. L. 113–4, § 906(a)(1)(B)","children":[],"tail":", substituted “violation of section 2241 or 2242” for “felony under chapter 109A”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s906/a/1/C"},"text":"Pub. L. 113–4, § 906(a)(1)(C)","children":[],"tail":", struck out “and without just cause or excuse,” after “bodily harm,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s906/a/1/D"},"text":"Pub. L. 113–4, § 906(a)(1)(D)","children":[],"tail":", substituted “1 year” for “six months”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s906/a/1/E"},"text":"Pub. L. 113–4, § 906(a)(1)(E)","children":[],"tail":", substituted “substantial bodily injury to a spouse or intimate partner, a dating partner, or an individual who has not attained the age of 16 years” for “substantial bodily injury to an individual who has not attained the age of 16 years” and “a fine” for “fine”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s906/a/1/F"},"text":"Pub. L. 113–4, § 906(a)(1)(F)","children":[],"tail":", added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s906/a/2"},"text":"Pub. L. 113–4, § 906(a)(2)","children":[],"tail":", inserted heading, substituted “In this section—” for “As used in this subsection—”, and added pars. (3) to (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294/s604/b/12/B"},"text":"Pub. L. 104–294, § 604(b)(12)(B)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/s320101/c/1/A"},"text":"Pub. L. 103–322, § 320101(c)(1)(A)","children":[],"tail":", (2)(A). See 1994 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294/s604/b/7"},"text":"Pub. L. 104–294, § 604(b)(7)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/s170201/c/1"},"text":"Pub. L. 103–322, § 170201(c)(1)","children":[],"tail":"–(3). See 1994 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/2/B"},"text":"Pub. L. 103–322, § 330016(2)(B)","children":[],"tail":", substituted “a fine under this title” for “fine of not more than” through the immediately following dollar amount wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s320101/c"},"text":"Pub. L. 103–322, § 320101(c)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/s604/b/12/B"},"text":"Pub. L. 104–294, § 604(b)(12)(B)","children":[],"tail":", which directed the amendment of subsec. (c) by substituting “ten years” for “five years” and the amendment of subsec. (e) by substituting “six months” for “three months”, were executed by making the substitutions in subsecs. (a)(3) and (a)(5), respectively, to reflect the probable intent of Congress and the redesignation of subsecs. (c) and (e) as subsecs. (a)(3) and (a)(5), respectively. See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s170201/a"},"text":"Pub. L. 103–322, § 170201(a)","children":[],"tail":"–(d), as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/s604/b/7"},"text":"Pub. L. 104–294, § 604(b)(7)","children":[],"tail":", designated existing provisions as subsec. (a), redesignated former subsecs. (a) to (f) as pars. (1) to (6), respectively of subsec. (a) and realigned margins, inserted before period at end of par. (5) “, or if the victim of the assault is an individual who has not attained the age of 16 years, by fine under this title or imprisonment for not more than 1 year, or both”, and added subsecs. (a)(7) and (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646/s87/c/2"},"text":"Pub. L. 99–646, § 87(c)(2)","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/99/654/s3/a/2"},"text":"Pub. L. 99–654, § 3(a)(2)","children":[],"tail":", amended subsec. (a) identically, striking out “or rape” after “murder”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646/s87/c/3"},"text":"Pub. L. 99–646, § 87(c)(3)","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/99/654/s3/a/3"},"text":"Pub. L. 99–654, § 3(a)(3)","children":[],"tail":", amended subsec. (b) identically, substituting “a felony under chapter 109A” for “rape”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/297"},"text":"Pub. L. 94–297","children":[],"tail":" added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8aec75a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8aec75b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/s604/d"},"text":"section 604(d) of Pub. L. 104–294","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s13"},"text":"section 13 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8aec75c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646"},"text":"Pub. L. 99–646","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/99/654"},"text":"Pub. L. 99–654","children":[],"tail":" effective respectively 30 days after "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", and 30 days after "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/646/s87/e"},"text":"section 87(e) of Pub. L. 99–646","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/99/654/s4"},"text":"section 4 of Pub. L. 99–654","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2241"},"text":"section 2241 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
