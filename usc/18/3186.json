{"tag":"section","attrib":{"id":"idb9961a57-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3186"},"text":null,"children":[{"tag":"num","attrib":{"value":"3186"},"text":"§ 3186.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of State to surrender fugitive","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of State may order the person committed under sections 3184 or 3185 of this title to be delivered to any authorized agent of such foreign government, to be tried for the offense of which charged.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Such agent may hold such person in custody, and take him to the territory of such foreign government, pursuant to such treaty.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"A person so accused who escapes may be retaken in the same manner as any person accused of any offense.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9961a58-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/824"},"text":"62 Stat. 824","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9961a59-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9961a5a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 653 (R.S. § 5272).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology and surplusage was deleted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
