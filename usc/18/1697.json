{"tag":"section","attrib":{"id":"idb92ad617-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1697"},"text":null,"children":[{"tag":"num","attrib":{"value":"1697"},"text":"§ 1697.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation of persons acting as private express","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, having charge or control of any conveyance operating by land, air, or water, knowingly conveys or knowingly permits the conveyance of any person acting or employed as a private express for the conveyance of letters or packets, and actually in possession of the same for the purpose of conveying them contrary to law, shall be fined under this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb92ad618-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/777"},"text":"62 Stat. 777","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/C"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2146"},"text":"108 Stat. 2146","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92ad619-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb92ad61a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 305 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s182"},"text":"Mar. 4, 1909, ch. 321, § 182","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1124"},"text":"35 Stat. 1124","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Same changes were made as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1694"},"text":"section 1694 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92ad61b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92ad61c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $150”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
