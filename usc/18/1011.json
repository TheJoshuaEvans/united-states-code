{"tag":"section","attrib":{"id":"idb9096a18-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1011"},"text":null,"children":[{"tag":"num","attrib":{"value":"1011"},"text":"§ 1011.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal land bank mortgage transactions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being a mortgagee, knowingly makes any false statement in any paper, proposal, or letter, relating to the sale of any mortgage, to any Federal land bank; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever, being an appraiser, willfully over-values any land securing such mortgage—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Shall be fined under this title or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9096a19-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/751"},"text":"62 Stat. 751","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9096a1a-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9096a1b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s987"},"text":"section 987 of title 12","children":[],"tail":", U.S.C., 1940 ed., Banks and Banking ("},{"tag":"ref","attrib":{"href":"/us/act/1916-07-17/ch245/s31"},"text":"July 17, 1916, ch. 245, § 31","children":[],"tail":", seventh paragraph, as added "},{"tag":"ref","attrib":{"href":"/us/act/1933-06-16/ch98/s78"},"text":"June 16, 1933, ch. 98, § 78","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/272"},"text":"48 Stat. 272","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9096a1c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9096a1d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $5,000” in last par."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
