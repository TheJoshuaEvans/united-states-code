{"tag":"section","attrib":{"id":"idb8de89c3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s710"},"text":null,"children":[{"tag":"num","attrib":{"value":"710"},"text":"§ 710.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cremation urns for military use","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever knowingly uses, manufactures, or sells any cremation urn of a design approved by the Secretary of Defense for use to retain the cremated remains of deceased members of the armed forces or an urn which is a colorable imitation of the approved design, except when authorized under regulation made pursuant to law, shall be fined under this title or imprisoned for not more than six months, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8de89c4-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-28/ch1092/s1/b"},"text":"Sept. 28, 1950, ch. 1092, § 1(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/1077"},"text":"64 Stat. 1077","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/E"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2146"},"text":"108 Stat. 2146","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8de89c5-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8de89c6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8de89c7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $250”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
