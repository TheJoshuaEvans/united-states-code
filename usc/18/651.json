{"tag":"section","attrib":{"id":"idb8d75d84-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s651"},"text":null,"children":[{"tag":"num","attrib":{"value":"651"},"text":"§ 651.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disbursing officer falsely certifying full payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being an officer charged with the disbursement of the public moneys, accepts, receives, or transmits to the Government Accountability Office to be allowed in his favor any receipt or voucher from a creditor of the United States without having paid the full amount specified therein to such creditor in such funds as the officer received for disbursement, or in such funds as he may be authorized by law to take in exchange, shall be fined under this title or in double the amount so withheld, whichever is greater, or imprisoned not more than two years, or both; but if the amount withheld does not exceed $1,000, he shall be fined under this title or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8d75d85-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/727"},"text":"62 Stat. 727","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", (2)(G), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":", 2148; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s606/a"},"text":"Pub. L. 104–294, title VI, § 606(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3511"},"text":"110 Stat. 3511","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8d75d86-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8d75d87-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 181 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s95"},"text":"Mar. 4, 1909, ch. 321, § 95","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1106"},"text":"35 Stat. 1106","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1921-06-10/ch18/s304"},"text":"June 10, 1921, ch. 18, § 304","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/24"},"text":"42 Stat. 24","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The penalty provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s652"},"text":"section 652 of this title","children":[],"tail":", a similar section, was incorporated in this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(For explanation of the smaller penalty for an offense involving $100 or less, see reviser’s notes under sections 641 and 645 of this title.)","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8d75d88-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8d75d89-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" substituted “$1,000” for “$100”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/2/G"},"text":"Pub. L. 103–322, § 330016(2)(G)","children":[],"tail":", substituted “shall be fined under this title or in double the amount so withheld, whichever is greater, or imprisoned” for “shall be fined in double the amount so withheld or imprisoned”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/1/H"},"text":"Pub. L. 103–322, § 330016(1)(H)","children":[],"tail":", substituted “fined under this title” for “fined not more than $1,000” after “he shall be”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
