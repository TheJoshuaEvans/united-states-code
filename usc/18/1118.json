{"tag":"section","attrib":{"id":"idb915511d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1118"},"text":null,"children":[{"tag":"num","attrib":{"value":"1118"},"text":"§ 1118.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Murder by a Federal prisoner","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb915511e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1118/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offense","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person who, while confined in a Federal correctional institution under a sentence for a term of life imprisonment, commits the murder of another shall be punished by death or by life imprisonment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb915511f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1118/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section—","children":[{"tag":"p","attrib":{"role":"listItem"},"text":"“Federal correctional institution” means any Federal prison, Federal correctional facility, Federal community program center, or Federal halfway house.","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"“murder” means a first degree or second degree murder (as defined in section 1111).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“term of life imprisonment” means a sentence for the term of natural life, a sentence commuted to natural life, an indeterminate term of a minimum of at least fifteen years and a maximum of life, or an unexecuted sentence of death.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9155120-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tVI/s60005/a"},"text":"Pub. L. 103–322, title VI, § 60005(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1970"},"text":"108 Stat. 1970","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9155121-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9155122-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb9155123-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 1118 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1122"},"text":"section 1122 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
