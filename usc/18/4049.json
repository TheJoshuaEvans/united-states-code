{"tag":"section","attrib":{"id":"idb9c5dc8d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4049"},"text":null,"children":[{"tag":"num","attrib":{"value":"4049"},"text":"§ 4049.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers and employees of the Bureau of Prisons authorized to carry oleoresin capsicum spray","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9c5dc8e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4049/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Bureau of Prisons shall issue, on a routine basis, oleoresin capsicum spray to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c5dc8f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4049/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any officer or employee of the Bureau of Prisons who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c5dc90-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4049/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is employed in a prison that is not a minimum or low security prison; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c5dc91-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4049/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may respond to an emergency situation in such a prison; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c5dc92-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4049/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to such additional officers and employees of prisons as the Director determines appropriate, in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c5dc93-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4049/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training Requirement.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c5dc94-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4049/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In order for an officer or employee of the Bureau of Prisons, including a correctional officer, to be eligible to receive and carry oleoresin capsicum spray pursuant to this section, the officer or employee shall complete a training course before being issued such spray, and annually thereafter, on the use of oleoresin capsicum spray.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c5dc95-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4049/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transferability of training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer or employee of the Bureau of Prisons who completes a training course pursuant to paragraph (1) and subsequently transfers to employment at a different prison, shall not be required to complete an additional training course solely due such transfer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c5dc96-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4049/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training conducted during regular employment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer or employee of the Bureau of Prisons who completes a training course required under paragraph (1) shall do so during the course of that officer or employee’s regular employment, and shall be compensated at the same rate that the officer or employee would be compensated for conducting the officer or employee’s regular duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c5dc97-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4049/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Oleoresin Capsicum Spray","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Officers and employees of the Bureau of Prisons issued oleoresin capsicum spray pursuant to subsection (a) may use such spray to reduce acts of violence—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c5dc98-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4049/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" committed by prisoners against themselves, other prisoners, prison visitors, and officers and employees of the Bureau of Prisons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c5dc99-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4049/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" committed by prison visitors against themselves, prisoners, other visitors, and officers and employees of the Bureau of Prisons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9c5dc9a-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/133/s2/a"},"text":"Pub. L. 114–133, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-03-09"},"text":"Mar. 9, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/296"},"text":"130 Stat. 296","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
