{"tag":"section","attrib":{"id":"idb9ab9d92-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3581"},"text":null,"children":[{"tag":"num","attrib":{"value":"3581"},"text":"§ 3581.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sentence of imprisonment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9ab9d93-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3581/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A defendant who has been found guilty of an offense may be sentenced to a term of imprisonment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9ab9d94-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3581/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Terms","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The authorized terms of imprisonment are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9ab9d95-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3581/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a Class A felony, the duration of the defendant’s life or any period of time;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9ab9d96-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3581/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a Class B felony, not more than twenty-five years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9ab9d97-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3581/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a Class C felony, not more than twelve years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9ab9d98-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3581/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a Class D felony, not more than six years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9ab9d99-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3581/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a Class E felony, not more than three years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9ab9d9a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3581/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a Class A misdemeanor, not more than one year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9ab9d9b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3581/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a Class B misdemeanor, not more than six months;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9ab9d9c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3581/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a Class C misdemeanor, not more than thirty days; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9ab9d9d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3581/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for an infraction, not more than five days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9ab9d9e-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s212/a/2"},"text":"Pub. L. 98–473, title II, § 212(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1998"},"text":"98 Stat. 1998","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9ab9d9f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9ab9da0-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9ab9da1-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1987-11-01"},"text":"Nov. 1, 1987","children":[],"tail":", and applicable only to offenses committed after the taking effect of this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/s235/a/1"},"text":"section 235(a)(1) of Pub. L. 98–473","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3551"},"text":"section 3551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
