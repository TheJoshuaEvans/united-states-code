{"tag":"section","attrib":{"id":"idb98ca428-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3141"},"text":null,"children":[{"tag":"num","attrib":{"value":"3141"},"text":"§ 3141.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Release and detention authority generally","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb98ca429-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3141/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pending Trial","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A judicial officer authorized to order the arrest of a person under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3041"},"text":"section 3041 of this title","children":[],"tail":" before whom an arrested person is brought shall order that such person be released or detained, pending judicial proceedings, under this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb98ca42a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3141/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pending Sentence or Appeal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A judicial officer of a court of original jurisdiction over an offense, or a judicial officer of a Federal appellate court, shall order that, pending imposition or execution of sentence, or pending appeal of conviction or sentence, a person be released or detained under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb98ca42b-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s203/a"},"text":"Pub. L. 98–473, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1976"},"text":"98 Stat. 1976","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/646/s55/a"},"text":"Pub. L. 99–646, § 55(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3607"},"text":"100 Stat. 3607","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb98ca42c-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb98ca42d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb98ca42e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3141, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/821"},"text":"62 Stat. 821","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1966-06-22"},"text":"June 22, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/89/465/s5/b"},"text":"Pub. L. 89–465, § 5(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/217"},"text":"80 Stat. 217","children":[],"tail":", related to powers of courts and magistrates with respect to release on bail or otherwise, prior to repeal in the revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/s203/a"},"text":"section 203(a) of Pub. L. 98–473","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb98ca42f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646/s55/a"},"text":"Pub. L. 99–646, § 55(a)","children":[],"tail":", (b), substituted “authorized to order the arrest of a person under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3041"},"text":"section 3041 of this title","children":[],"tail":" before whom an arrested person is brought shall order that such person be released” for “who is authorized to order the arrest of a person pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3041"},"text":"section 3041 of this title","children":[],"tail":" shall order that an arrested person who is brought before him be released” and “under this chapter” for “pursuant to the provisions of this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646/s55/a"},"text":"Pub. L. 99–646, § 55(a)","children":[],"tail":", substituted “under this chapter” for “pursuant to the provisions of this chapter”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb98ca430-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb98ca431-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646/s55/j"},"text":"Pub. L. 99–646, § 55(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3611"},"text":"100 Stat. 3611","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/646/s55/j"},"text":"“The amendments made by this section [amending this section and sections 3142 to 3144, 3146 to 3148, and 3156 of this title] shall take effect 30 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb98ca432-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/tVI/s6951"},"text":"Pub. L. 108–458, title VI, § 6951","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3775"},"text":"118 Stat. 3775","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/458/tVI/s6951"},"text":"“This subtitle [subtitle K (§§ 6951, 6952) of title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":", amending "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3142"},"text":"section 3142 of this title","children":[],"tail":"] may be cited as the ‘Pretrial Detention of Terrorists Act of 2004’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb98ca433-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tIX/s901"},"text":"Pub. L. 101–647, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4826"},"text":"104 Stat. 4826","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/647/tIX/s901"},"text":"“This title [amending sections 3143 and 3145 of this title] may be cited as the ‘Mandatory Detention for Offenders Convicted of Serious Crimes Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb98ca434-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s202"},"text":"Pub. L. 98–473, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1976"},"text":"98 Stat. 1976","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/473/tII/s202"},"text":"“This chapter [chapter I (§§ 202–210) of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":", enacting sections 3062 and 3141 to 3150 of this title, amending sections 3041, 3042, 3154, 3156, 3731, 3772, and 4282 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s636"},"text":"section 636 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure, repealing sections 3043 and 3141 to 3151 of this title, and amending rules 5, 15, 40, 46, and 54 of the Federal Rules of Criminal Procedure, set out in the Appendix to this title, and rule 9 of the Federal Rules of Appellate Procedure, set out in the Appendix to Title 28] may be cited as the ‘Bail Reform Act of 1984’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb98ca435-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/267/s1"},"text":"Pub. L. 97–267, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-27"},"text":"Sept. 27, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1136"},"text":"96 Stat. 1136","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/267/s1"},"text":"“That this Act [amending sections 3152 to 3155 of this title and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s604"},"text":"section 604 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure, and enacting provisions set out as notes under sections 3141 and 3152 of this title] may be cited as the ‘Pretrial Services Act of 1982’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idb98ca436-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/465/s1"},"text":"Pub. L. 89–465, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-06-22"},"text":"June 22, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/214"},"text":"80 Stat. 214","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/465/s1"},"text":"“That this Act [enacting sections 3146 to 3152 of this title, amending sections 3041, 3141 to 3143, and 3568 of this title, and enacting provisions set out as a note below] may be cited as the ‘Bail Reform Act of 1966’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb98ca437-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purpose of Bail Reform Act of 1966","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/465/s2"},"text":"Pub. L. 89–465, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-06-22"},"text":"June 22, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/214"},"text":"80 Stat. 214","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/465/s2"},"text":"“The purpose of this Act [enacting sections 3146 to 3152 of this title, amending sections 3041, 3141 to 3143, and 3568 of this title and enacting provisions set out as a note above] is to revise the practices relating to bail to assure that all persons, regardless of their financial status, shall not needlessly be detained pending their appearance to answer charges, to testify, or pending appeal, when detention serves neither the ends of justice nor the public interest.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
