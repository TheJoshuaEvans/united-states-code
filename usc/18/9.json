{"tag":"section","attrib":{"id":"idb8a06f48-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"§ 9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vessel of the United States defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The term “vessel of the United States”, as used in this title, means a vessel belonging in whole or in part to the United States, or any citizen thereof, or any corporation created by or under the laws of the United States, or of any State, Territory, District, or possession thereof.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8a06f49-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/685"},"text":"62 Stat. 685","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8a06f4a-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8a06f4b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 501 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s310"},"text":"Mar. 4, 1909, ch. 321, § 310","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1148"},"text":"35 Stat. 1148","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is made applicable to the entire title rather than to sections 481 et seq. of title 18, U.S.C., 1940 ed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes in phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
