{"tag":"section","attrib":{"id":"idb8e0d47a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s796"},"text":null,"children":[{"tag":"num","attrib":{"value":"796"},"text":"§ 796.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of aircraft for photographing defense installations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever uses or permits the use of an aircraft or any contrivance used, or designed for navigation or flight in the air, for the purpose of making a photograph, sketch, picture, drawing, map, or graphical representation of vital military or naval installations or equipment, in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s795"},"text":"section 795 of this title","children":[],"tail":", shall be fined under this title or imprisoned not more than one year, or both."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8e0d47b-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/738"},"text":"62 Stat. 738","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8e0d47c-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8e0d47d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on sections 45, 45a, and 45c of title 50, U.S.C., 1940 ed., War and National Defense (","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-01-12/ch2"},"text":"Jan. 12, 1938, ch. 2","children":[],"tail":", §§ 1, 2, 4, "},{"tag":"ref","attrib":{"href":"/us/stat/52/3"},"text":"52 Stat. 3","children":[],"tail":", 4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to persons causing or procuring was omitted as unnecessary in view of definition of “principal” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Punishment provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s795"},"text":"section 795 of this title","children":[],"tail":" is repeated, and is from said "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s45"},"text":"section 45 of title 50","children":[],"tail":", U.S.C., 1940 ed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8e0d47e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8e0d47f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $1,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
