{"tag":"section","attrib":{"id":"idb93200ad-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1736"},"text":null,"children":[{"tag":"num","attrib":{"value":"1736"},"text":"§ 1736.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictive use of information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb93200ae-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1736/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No information or evidence obtained by reason of compliance by a natural person with any provision of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3010"},"text":"section 3010 of title 39","children":[],"tail":", or regulations issued thereunder, shall, except as provided in subsection (c) of this section, be used, directly or indirectly, as evidence against that person in a criminal proceeding."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb93200af-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1736/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The fact of the performance of any act by an individual in compliance with any provision of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3010"},"text":"section 3010 of title 39","children":[],"tail":", or regulations issued thereunder, shall not be deemed the admission of any fact, or otherwise be used, directly or indirectly, as evidence against that person in a criminal proceeding, except as provided in subsection (c) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb93200b0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1736/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsections (a) and (b) of this section shall not preclude the use of any such information or evidence in a prosecution or other action under any applicable provision of law with respect to the furnishing of false information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb93200b1-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375/s6/j/37/A"},"text":"Pub. L. 91–375, § 6(j)(37)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/781"},"text":"84 Stat. 781","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb93200b2-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb93200b3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb93200b4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on first day of sixth month which begins after ","children":[{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/b"},"text":"section 15(b) of Pub. L. 91–375","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of Title 39","children":[],"tail":", Postal Service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
