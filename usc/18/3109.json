{"tag":"section","attrib":{"id":"idb98a336c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3109"},"text":null,"children":[{"tag":"num","attrib":{"value":"3109"},"text":"§ 3109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Breaking doors or windows for entry or exit","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The officer may break open any outer or inner door or window of a house, or any part of a house, or anything therein, to execute a search warrant, if, after notice of his authority and purpose, he is refused admittance or when necessary to liberate himself or a person aiding him in the execution of the warrant.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb98a336d-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/820"},"text":"62 Stat. 820","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb98a336e-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb98a336f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., §§ 618, 619 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-06-15/ch30"},"text":"June 15, 1917, ch. 30","children":[],"tail":", title XI, §§ 8, 9, "},{"tag":"ref","attrib":{"href":"/us/stat/40/229"},"text":"40 Stat. 229","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Said sections 618 and 619 were consolidated with minor changes in phraseology but without change of substance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
