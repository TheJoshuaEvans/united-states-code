{"tag":"section","attrib":{"id":"idb8a550cc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s31"},"text":null,"children":[{"tag":"num","attrib":{"value":"31"},"text":"§ 31.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8a550cd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s31/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this chapter, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a550ce-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s31/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aircraft","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “aircraft” means a civil, military, or public contrivance invented, used, or designed to navigate, fly, or travel in the air.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a550cf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s31/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aviation quality","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “aviation quality”, with respect to a part of an aircraft or space vehicle, means the quality of having been manufactured, constructed, produced, maintained, repaired, overhauled, rebuilt, reconditioned, or restored in conformity with applicable standards specified by law (including applicable regulations).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a550d0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s31/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Destructive substance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “destructive substance” means an explosive substance, flammable material, infernal machine, or other chemical, mechanical, or radioactive device or matter of a combustible, contaminative, corrosive, or explosive nature.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a550d1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s31/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In flight","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “in flight” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a550d2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s31/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any time from the moment at which all the external doors of an aircraft are closed following embarkation until the moment when any such door is opened for disembarkation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a550d3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s31/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a forced landing, until competent authorities take over the responsibility for the aircraft and the persons and property on board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a550d4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s31/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In service","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “in service” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a550d5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s31/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any time from the beginning of preflight preparation of an aircraft by ground personnel or by the crew for a specific flight until 24 hours after any landing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a550d6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s31/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any event includes the entire period during which the aircraft is in flight.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a550d7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s31/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Motor vehicle","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “motor vehicle” means every description of carriage or other contrivance propelled or drawn by mechanical power and used for commercial purposes on the highways in the transportation of passengers, passengers and property, or property or cargo.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a550d8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s31/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Part","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “part” means a frame, assembly, component, appliance, engine, propeller, material, part, spare part, piece, section, or related integral or auxiliary equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a550d9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s31/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Space vehicle","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “space vehicle” means a man-made device, either manned or unmanned, designed for operation beyond the Earth’s atmosphere.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a550da-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s31/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “State” means a State of the United States, the District of Columbia, and any commonwealth, territory, or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a550db-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s31/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Used for commercial purposes","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “used for commercial purposes” means the carriage of persons or property for any fare, fee, rate, charge or other consideration, or directly or indirectly in connection with any business, or other undertaking intended for profit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a550dc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s31/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms Defined in Other Law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this chapter, the terms “aircraft engine”, “air navigation facility”, “appliance”, “civil aircraft”, “foreign air commerce”, “interstate air commerce”, “landing area”, “overseas air commerce”, “propeller”, “spare part”, and “special aircraft jurisdiction of the United States” have the meanings given those terms in sections 40102(a) and 46501 of title 49.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8a550dd-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-07-14/ch595/s1"},"text":"July 14, 1956, ch. 595, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/538"},"text":"70 Stat. 538","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII"},"text":"Pub. L. 98–473, title II","children":[],"tail":", §§ 1010, 2013(a), "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2141"},"text":"98 Stat. 2141","children":[],"tail":", 2187; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7015"},"text":"Pub. L. 100–690, title VII, § 7015","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4395"},"text":"102 Stat. 4395","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s5/e/1"},"text":"Pub. L. 103–272, § 5(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1373"},"text":"108 Stat. 1373","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/tV/s506/b"},"text":"Pub. L. 106–181, title V, § 506(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/136"},"text":"114 Stat. 136","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8a550de-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8a550df-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8a550e0-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181"},"text":"Pub. L. 106–181","children":[],"tail":" added subsecs. (a) and (b) and struck out former text which read as follows: “When used in this chapter the term—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“ ‘Aircraft engine’, ‘air navigation facility’, ‘appliance’, ‘civil aircraft’, ‘foreign air commerce’, ‘interstate air commerce’, ‘landing area’, ‘overseas air commerce’, ‘propeller’, ‘spare part’ and ‘special aircraft jurisdiction of the United States’ shall have the meaning ascribed to those terms in sections 40102(a) and 46501 of title 49.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“ ‘Motor vehicle’ means every description of carriage or other contrivance propelled or drawn by mechanical power and used for commercial purposes on the highways in the transportation of passengers, passengers and property, or property or cargo;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“ ‘Destructive substance’ means any explosive substance, flammable material, infernal machine, or other chemical, mechanical, or radioactive device or matter of a combustible, contaminative, corrosive, or explosive nature;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“ ‘Used for commercial purposes’ means the carriage of persons or property for any fare, fee, rate, charge or other consideration, or directly or indirectly in connection with any business, or other undertaking intended for profit;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“ ‘In flight’ means any time from the moment all the external doors of an aircraft are closed following embarkation until the moment when any such door is opened for disembarkation. In the case of a forced landing the flight shall be deemed to continue until competent authorities take over the responsibility for the aircraft and the persons and property on board; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“ ‘In service’ means any time from the beginning of preflight preparation of the aircraft by ground personnel or by the crew for a specific flight until twenty-four hours after any landing; the period of service shall, in any event, extend for the entire period during which the aircraft is in flight.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Pub. L. 103–272","children":[],"tail":" substituted “sections 40102(a) and 46501 of title 49” for “the Federal Aviation Act of 1958, as amended” in par. beginning with definition of “Aircraft engine”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" substituted “door is opened” for “door in opened” in definition of “in flight”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/s2013/a/1"},"text":"Pub. L. 98–473, § 2013(a)(1)","children":[],"tail":", in first par. struck out “and” before “spare part”, inserted “and ‘special aircraft jurisdiction of the United States’ ”, and substituted “Federal Aviation Act of 1958” for “Civil Aeronautics Act of 1938”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/s1010"},"text":"Pub. L. 98–473, § 1010","children":[],"tail":", substituted “passengers and property, or property or cargo” for “or passengers and property” in definition of motor vehicle."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/s2013/a/2"},"text":"Pub. L. 98–473, § 2013(a)(2)","children":[],"tail":"–(4), inserted definitions of “in flight” and “in service”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8a550e1-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8a550e2-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181"},"text":"Pub. L. 106–181","children":[],"tail":" applicable only to fiscal years beginning after "},{"tag":"date","attrib":{"date":"1999-09-30"},"text":"Sept. 30, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/s3"},"text":"section 3 of Pub. L. 106–181","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of Title 49","children":[],"tail":", Transportation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8a550e3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s2015"},"text":"Pub. L. 98–473, title II, § 2015","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2190"},"text":"98 Stat. 2190","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/473/tII/s2015"},"text":"“This part [part B (§§ 2011–2015) of chapter XX of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":", see Short Title of 1984 Amendment note below] shall become effective on the date of the enactment of this joint resolution ["},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb8a550e4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/tV/s506/a"},"text":"Pub. L. 106–181, title V, § 506(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/136"},"text":"114 Stat. 136","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/181/tV/s506/a"},"text":"“This section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s38"},"text":"section 38 of this title","children":[],"tail":" and amending this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2516"},"text":"section 2516 of this title","children":[],"tail":"] may be cited as the ‘Aircraft Safety Act of 2000’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb8a550e5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s2011"},"text":"Pub. L. 98–473, title II, § 2011","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2187"},"text":"98 Stat. 2187","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/473/tII/s2011"},"text":"“This part [part B (§§ 2011–2015) of chapter XX of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":", amending this section, "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s32"},"text":"section 32 of this title","children":[],"tail":", and sections 1301, 1471, and 1472 of former Title 49, Transportation, and enacting provisions set out as notes under this section] may be cited as the ‘Aircraft Sabotage Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8a550e6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Statement of Findings and Purpose for 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s2012"},"text":"Pub. L. 98–473, title II, § 2012","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2187"},"text":"98 Stat. 2187","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/473/tII/s2012"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Congress hereby finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Convention for the Suppression of Unlawful Acts Against the Safety of Civil Aviation (ratified by the United States on ","children":[{"tag":"date","attrib":{"date":"1972-11-01"},"text":"November 1, 1972","children":[],"tail":") requires each contracting State to establish its jurisdiction over certain offenses affecting the safety of civil aviation;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such offenses place innocent lives in jeopardy, endanger national security, affect domestic tranquility, gravely affect interstate and foreign commerce, and are offenses against the law of nations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purpose of this subtitle [probably means part B (§§ 2011–2015) of chapter XX of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":", see Short Title of 1984 Amendment note above] is to implement fully the Convention for the Suppression of Unlawful Acts Against the Safety of Civil Aviation and to expand the protection accorded to aircraft and related facilities.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
