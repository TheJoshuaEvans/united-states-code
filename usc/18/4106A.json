{"tag":"section","attrib":{"id":"idb9c82751-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4106A"},"text":null,"children":[{"tag":"num","attrib":{"value":"4106A"},"text":"§ 4106A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of offenders on parole; parole of offenders transferred","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9c82752-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4106A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon the receipt of an offender who is on parole from the authorities of a foreign country, the Attorney General shall assign the offender to the United States Parole Commission for supervision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c82753-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4106A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c82754-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4106A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c82755-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4106A/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Parole Commission shall, without unnecessary delay, determine a release date and a period and conditions of supervised release for an offender transferred to the United States to serve a sentence of imprisonment, as though the offender were convicted in a United States district court of a similar offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c82756-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4106A/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In making such determination, the United States Parole Commission shall consider—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9c82757-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4106A/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendation of the United States Probation Service, including any recommendation as to the applicable guideline range; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9c82758-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4106A/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any documents provided by the transferring country;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"relating to that offender.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c82759-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4106A/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The combined periods of imprisonment and supervised release that result from such determination shall not exceed the term of imprisonment imposed by the foreign court on that offender.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c8275a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4106A/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The duties conferred on a United States probation officer with respect to a defendant by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3552"},"text":"section 3552 of this title","children":[],"tail":" shall, with respect to an offender so transferred, be carried out by the United States Probation Service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c8275b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4106A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c8275c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4106A/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A determination by the United States Parole Commission under this subsection may be appealed to the United States court of appeals for the circuit in which the offender is imprisoned at the time of the determination of such Commission. Notice of appeal must be filed not later than 45 days after receipt of notice of such determination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c8275d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4106A/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The court of appeals shall decide and dispose of the appeal in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3742"},"text":"section 3742 of this title","children":[],"tail":" as though the determination appealed had been a sentence imposed by a United States district court."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c8275e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4106A/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During the supervised release of an offender under this subsection, the United States district court for the district in which the offender resides shall supervise the offender.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c8275f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4106A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall apply only to offenses committed on or after ","children":[{"tag":"date","attrib":{"date":"1987-11-01"},"text":"November 1, 1987","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9c82760-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7101/a"},"text":"Pub. L. 100–690, title VII, § 7101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4415"},"text":"102 Stat. 4415","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXV"},"text":"Pub. L. 101–647, title XXXV","children":[],"tail":", §§ 3599B, 3599C, "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4931"},"text":"104 Stat. 4931","children":[],"tail":", 4932.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9c82761-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9c82762-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9c82763-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/s3599B"},"text":"Pub. L. 101–647, § 3599B","children":[],"tail":", inserted “of” before second reference to “offenders” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/s3599C"},"text":"Pub. L. 101–647, § 3599C","children":[],"tail":", inserted period at end."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
