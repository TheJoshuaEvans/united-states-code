{"tag":"section","attrib":{"id":"idb8fd838e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s951"},"text":null,"children":[{"tag":"num","attrib":{"value":"951"},"text":"§ 951.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agents of foreign governments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8fd838f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s951/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever, other than a diplomatic or consular officer or attaché, acts in the United States as an agent of a foreign government without prior notification to the Attorney General if required in subsection (b), shall be fined under this title or imprisoned not more than ten years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fd8390-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s951/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General shall promulgate rules and regulations establishing requirements for notification.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fd8391-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s951/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General shall, upon receipt, promptly transmit one copy of each notification statement filed under this section to the Secretary of State for such comment and use as the Secretary of State may determine to be appropriate from the point of view of the foreign relations of the United States. Failure of the Attorney General to do so shall not be a bar to prosecution under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fd8392-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s951/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section, the term “agent of a foreign government” means an individual who agrees to operate within the United States subject to the direction or control of a foreign government or official, except that such term does not include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fd8393-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s951/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a duly accredited diplomatic or consular officer of a foreign government, who is so recognized by the Department of State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fd8394-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s951/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any officially and publicly acknowledged and sponsored official or representative of a foreign government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fd8395-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s951/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any officially and publicly acknowledged and sponsored member of the staff of, or employee of, an officer, official, or representative described in paragraph (1) or (2), who is not a United States citizen; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fd8396-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s951/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person engaged in a legal commercial transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fd8397-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s951/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding paragraph (d)(4), any person engaged in a legal commercial transaction shall be considered to be an agent of a foreign government for purposes of this section if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fd8398-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s951/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such person agrees to operate within the United States subject to the direction or control of a foreign government or official; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fd8399-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s951/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8fd839a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s951/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an agent of Cuba or any other country that the President determines (and so reports to the Congress) poses a threat to the national security interest of the United States for purposes of this section, unless the Attorney General, after consultation with the Secretary of State, determines and so reports to the Congress that the national security or foreign policy interests of the United States require that the provisions of this section do not apply in specific circumstances to agents of such country; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fd839b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s951/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been convicted of, or has entered a plea of nolo contendere with respect to, any offense under section 792 through 799, 831, or 2381 of this title or under section 11 ","children":[{"tag":"ref","attrib":{"idref":"fn002077"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002077"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Export Administration Act of 1979, except that the provisions of this subsection shall not apply to a person described in this clause for a period of more than five years beginning on the date of the conviction or the date of entry of the plea of nolo contendere, as the case may be."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8fd839c-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/743"},"text":"62 Stat. 743","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/462/s6"},"text":"Pub. L. 97–462, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2530"},"text":"96 Stat. 2530","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s1209"},"text":"Pub. L. 98–473, title II, § 1209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2164"},"text":"98 Stat. 2164","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/569/tVII/s703"},"text":"Pub. L. 99–569, title VII, § 703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3205"},"text":"100 Stat. 3205","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/199/tII/s202"},"text":"Pub. L. 103–199, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-17"},"text":"Dec. 17, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2321"},"text":"107 Stat. 2321","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/R"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(R)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2148"},"text":"108 Stat. 2148","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8fd839d-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8fd839e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s601"},"text":"section 601 of title 22","children":[],"tail":", U.S.C., 1940 ed., Foreign Relations and Intercourse ("},{"tag":"ref","attrib":{"href":"/us/act/1917-06-15/ch30"},"text":"June 15, 1917, ch. 30","children":[],"tail":", title VIII, § 3, "},{"tag":"ref","attrib":{"href":"/us/stat/40/226"},"text":"40 Stat. 226","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1940-03-28/ch72/s6"},"text":"Mar. 28, 1940, ch. 72, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/80"},"text":"54 Stat. 80","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Mandatory punishment provision was rephrased in the alternative.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes in phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8fd839f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8fd83a0-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 11 of the Export Administration Act of 1979, referred to in subsec. (e)(2)(B), was classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4610"},"text":"section 4610 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVII/s1766/a"},"text":"Pub. L. 115–232, div. A, title XVII, § 1766(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2232"},"text":"132 Stat. 2232","children":[],"tail":". Provisions relating to penalties are covered generally in "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4819"},"text":"section 4819 of Title 50","children":[],"tail":", as enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8fd83a1-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $75,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (e)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/199"},"text":"Pub. L. 103–199","children":[],"tail":" substituted “Cuba or any other country that the President determines (and so reports to the Congress) poses a threat to the national security interest of the United States for purposes of this section” for “the Soviet Union, the German Democratic Republic, Hungary, Czechoslovakia, Poland, Bulgaria, Romania, or Cuba”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/569"},"text":"Pub. L. 99–569","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":" designated existing provisions as subsec. (a), substituted “Attorney General if required in subsection (b)” for “Secretary of State”, and added subsecs. (b) to (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/462"},"text":"Pub. L. 97–462","children":[],"tail":" increased limitation on fines to $75,000 from $5,000."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8fd83a2-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8fd83a3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/462"},"text":"Pub. L. 97–462","children":[],"tail":" effective 45 days after "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/462/s4"},"text":"section 4 of Pub. L. 97–462","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2071"},"text":"section 2071 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
