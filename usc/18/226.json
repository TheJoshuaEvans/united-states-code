{"tag":"section","attrib":{"id":"idb8bf90b3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s226"},"text":null,"children":[{"tag":"num","attrib":{"value":"226"},"text":"§ 226.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bribery affecting port security","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8bf90b4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s226/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever knowingly—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8bf90b5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s226/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" directly or indirectly, corruptly gives, offers, or promises anything of value to any public or private person, with intent to commit international terrorism or domestic terrorism (as those terms are defined under section 2331), to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8bf90b6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s226/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" influence any action or any person to commit or aid in committing, or collude in, or allow, any fraud, or make opportunity for the commission of any fraud affecting any secure or restricted area or seaport; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8bf90b7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s226/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" induce any official or person to do or omit to do any act in violation of the lawful duty of such official or person that affects any secure or restricted area or seaport; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf90b8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s226/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" directly or indirectly, corruptly demands, seeks, receives, accepts, or agrees to receive or accept anything of value personally or for any other person or entity in return for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8bf90b9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s226/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" being influenced in the performance of any official act affecting any secure or restricted area or seaport; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8bf90ba-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s226/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowing that such influence will be used to commit, or plan to commit, international or domestic terrorism,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title or imprisoned not more than 15 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8bf90bb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s226/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “secure or restricted area” means an area of a vessel or facility designated as secure in an approved security plan, as required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70103"},"text":"section 70103 of title 46","children":[],"tail":", United States Code, and the rules and regulations promulgated under that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8bf90bc-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/tIII/s309/a"},"text":"Pub. L. 109–177, title III, § 309(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/241"},"text":"120 Stat. 241","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
