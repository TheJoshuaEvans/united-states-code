{"tag":"section","attrib":{"id":"idb985781c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3051"},"text":null,"children":[{"tag":"num","attrib":{"value":"3051"},"text":"§ 3051.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of Special Agents ","children":[{"tag":"ref","attrib":{"idref":"fn002223"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002223"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The words “Special Agents” probably should not be capitalized."}],"tail":" of Bureau of Alcohol, Tobacco, Firearms, and Explosives"}],"tail":null},{"tag":"subsection","attrib":{"id":"idb985781d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3051/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Special agents of the Bureau of Alcohol, Tobacco, Firearms, and Explosives, as well as any other investigator or officer charged by the Attorney General with the duty of enforcing any of the criminal, seizure, or forfeiture provisions of the laws of the United States, may carry firearms, serve warrants and subpoenas issued under the authority of the United States and make arrests without warrant for any offense against the United States committed in their presence, or for any felony cognizable under the laws of the United States if they have reasonable grounds to believe that the person to be arrested has committed or is committing such felony.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb985781e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3051/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any special agent of the Bureau of Alcohol, Tobacco, Firearms, and Explosives may, in respect to the performance of his or her duties, make seizures of property subject to forfeiture to the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb985781f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3051/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9857820-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3051/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraphs (2) and (3), and except to the extent that such provisions conflict with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s983"},"text":"section 983 of title 18","children":[],"tail":", United States Code, insofar as section 983 applies, the provisions of the Customs laws relating to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9857821-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3051/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the seizure, summary and judicial forfeiture, and condemnation of property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9857822-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3051/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disposition of such property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9857823-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3051/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the remission or mitigation of such forfeiture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9857824-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3051/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the compromise of claims,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall apply to seizures and forfeitures incurred, or alleged to have been incurred, under any applicable provision of law enforced or administered by the Bureau of Alcohol, Tobacco, Firearms, and Explosives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9857825-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3051/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of paragraph (1), duties that are imposed upon a customs officer or any other person with respect to the seizure and forfeiture of property under the customs laws of the United States shall be performed with respect to seizures and forfeitures of property under this section by such officers, agents, or any other person as may be authorized or designated for that purpose by the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9857826-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3051/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, the disposition of firearms forfeited by reason of a violation of any law of the United States shall be governed by the provisions of section 5872(b) of the Internal Revenue Code of 1986.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9857827-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXI/s1113"},"text":"Pub. L. 107–296, title XI, § 1113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2279"},"text":"116 Stat. 2279","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9857828-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9857829-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb985782a-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 5872(b) of the Internal Revenue Code of 1986, referred to in subsec. (c)(3), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s5872/b"},"text":"section 5872(b) of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb985782b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3051, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645/s1"},"text":"act June 25, 1948, ch. 645, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/817"},"text":"62 Stat. 817","children":[],"tail":", related to powers of extradition agents, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/act/1951-10-31/ch655/s56/f"},"text":"act Oct. 31, 1951, ch. 655, § 56(f)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/729"},"text":"65 Stat. 729","children":[],"tail":". Substantially identical provisions are contained in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3193"},"text":"section 3193 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb985782c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb985782d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 60 days after ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s4"},"text":"section 4 of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
