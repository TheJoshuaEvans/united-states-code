{"tag":"section","attrib":{"id":"idb92f909b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1734"},"text":null,"children":[{"tag":"num","attrib":{"value":"1734"},"text":"§ 1734.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Editorials and other matter as “advertisements”","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being an editor or publisher, prints in a publication entered as second class mail, editorial or other reading matter for which he has been paid or promised a valuable consideration, without plainly marking the same “advertisement” shall be fined under this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb92f909c-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/682/s7"},"text":"Pub. L. 86–682, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-02"},"text":"Sept. 2, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/706"},"text":"74 Stat. 706","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/G"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(G)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92f909d-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92f909e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92f909f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $500”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb92f90a0-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb92f90a1-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1960-09-01"},"text":"Sept. 1, 1960","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/86/682/s11"},"text":"section 11 of Pub. L. 86–682","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-02"},"text":"Sept. 2, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/708"},"text":"74 Stat. 708","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
