{"tag":"section","attrib":{"id":"idb92ad565-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1595"},"text":null,"children":[{"tag":"num","attrib":{"value":"1595"},"text":"§ 1595.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil remedy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb92ad566-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1595/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual who is a victim of a violation of this chapter may bring a civil action against the perpetrator (or whoever knowingly benefits, or attempts or conspires to benefit, financially or by receiving anything of value from participation in a venture which that person knew or should have known has engaged in an act in violation of this chapter) in an appropriate district court of the United States and may recover damages and reasonable attorneys fees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92ad567-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1595/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92ad568-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1595/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any civil action filed under subsection (a) shall be stayed during the pendency of any criminal action arising out of the same occurrence in which the claimant is the victim.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92ad569-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1595/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this subsection, a “criminal action” includes investigation and prosecution and is pending until final adjudication in the trial court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92ad56a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1595/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No action may be maintained under subsection (a) unless it is commenced not later than the later of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92ad56b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1595/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 years after the cause of action arose; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92ad56c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1595/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 years after the victim reaches 18 years of age, if the victim was a minor at the time of the alleged offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92ad56d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1595/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case in which the attorney general of a State has reason to believe that an interest of the residents of that State has been or is threatened or adversely affected by any person who violates section 1591, the attorney general of the State, as parens patriae, may bring a civil action against such person on behalf of the residents of the State in an appropriate district court of the United States to obtain appropriate relief.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb92ad56e-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/193/s4/a/4/A"},"text":"Pub. L. 108–193, § 4(a)(4)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2878"},"text":"117 Stat. 2878","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/457/tII/s221/2"},"text":"Pub. L. 110–457, title II, § 221(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-12-23"},"text":"Dec. 23, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/5067"},"text":"122 Stat. 5067","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/22/tI/s120"},"text":"Pub. L. 114–22, title I, § 120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-05-29"},"text":"May 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/247"},"text":"129 Stat. 247","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/164/s6"},"text":"Pub. L. 115–164, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-04-11"},"text":"Apr. 11, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1255"},"text":"132 Stat. 1255","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/347/tI/s102"},"text":"Pub. L. 117–347, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6200"},"text":"136 Stat. 6200","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92ad56f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92ad570-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92ad571-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/347"},"text":"Pub. L. 117–347","children":[],"tail":" inserted “or attempts or conspires to benefit,” after “whoever knowingly benefits,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsecs. (b)(1), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/164/s6/b"},"text":"Pub. L. 115–164, § 6(b)","children":[],"tail":", substituted “subsection (a)” for “this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/164/s6/a"},"text":"Pub. L. 115–164, § 6(a)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22"},"text":"Pub. L. 114–22","children":[],"tail":" substituted “not later than the later of—” for “not later than 10 years after the cause of action arose.” and added pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/457/s221/2/A"},"text":"Pub. L. 110–457, § 221(2)(A)","children":[],"tail":", struck out “of section 1589, 1590, or 1591” after “victim of a violation” and inserted “(or whoever knowingly benefits, financially or by receiving anything of value from participation in a venture which that person knew or should have known has engaged in an act in violation of this chapter)” after “perpetrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/457/s221/2/B"},"text":"Pub. L. 110–457, § 221(2)(B)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
