{"tag":"section","attrib":{"id":"idb950fb55-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258"},"text":null,"children":[{"tag":"num","attrib":{"value":"2258"},"text":"§ 2258.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to report child abuse","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A person who, while engaged in a professional capacity or activity described in subsection (b) of section 226 of the Victims of Child Abuse Act of 1990 on Federal land or in a federally operated (or contracted) facility, or a covered individual as described in subsection (a)(2) of such section 226 who, learns of facts that give reason to suspect that a child has suffered an incident of child abuse, as defined in subsection (c) of that section, and fails to make a timely report as required by subsection (a) of that section, shall be fined under this title or imprisoned not more than 1 year or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb950fb56-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tII/s226/g/1"},"text":"Pub. L. 101–647, title II, § 226(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4808"},"text":"104 Stat. 4808","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/248/tII/s209"},"text":"Pub. L. 109–248, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/615"},"text":"120 Stat. 615","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/126/tI/s101/b"},"text":"Pub. L. 115–126, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-14"},"text":"Feb. 14, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/319"},"text":"132 Stat. 319","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb950fb57-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb950fb58-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb950fb59-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 226 of the Victims of Child Abuse Act of 1990, referred to in text, is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20341"},"text":"section 20341 of Title 34","children":[],"tail":", Crime Control and Law Enforcement."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb950fb5a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 2258 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2260"},"text":"section 2260 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb950fb5b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/126"},"text":"Pub. L. 115–126","children":[],"tail":" inserted “or a covered individual as described in subsection (a)(2) of such section 226 who,” after “facility,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248"},"text":"Pub. L. 109–248","children":[],"tail":" substituted “fined under this title or imprisoned not more than 1 year or both” for “guilty of a Class B misdemeanor”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
