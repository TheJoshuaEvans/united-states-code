{"tag":"section","attrib":{"id":"idb8c695de-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s401"},"text":null,"children":[{"tag":"num","attrib":{"value":"401"},"text":"§ 401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Power of court","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A court of the United States shall have power to punish by fine or imprisonment, or both, at its discretion, such contempt of its authority, and none other, as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c695df-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s401/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Misbehavior of any person in its presence or so near thereto as to obstruct the administration of justice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c695e0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s401/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Misbehavior of any of its officers in their official transactions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c695e1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s401/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Disobedience or resistance to its lawful writ, process, order, rule, decree, or command.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8c695e2-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/701"},"text":"62 Stat. 701","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dB/tIII/s3002/a/1"},"text":"Pub. L. 107–273, div. B, title III, § 3002(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1805"},"text":"116 Stat. 1805","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c695e3-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8c695e4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s385"},"text":"section 385 of title 28","children":[],"tail":", U.S.C., 1940 ed., Judicial Code and Judiciary ("},{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s268"},"text":"Mar. 3, 1911, ch. 231, § 268","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1163"},"text":"36 Stat. 1163","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Said section 385 conferred two powers. The first part authorizing courts of the United States to impose and administer oaths will remain in title 28, U.S.C., 1940 ed., Judicial Code and Judiciary. The second part relating to contempt of court constitutes this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in phraseology and arrangement were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8c695e5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8c695e6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" inserted “or both,” after “fine or imprisonment,” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
