{"tag":"section","attrib":{"id":"idb92f9066-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1726"},"text":null,"children":[{"tag":"num","attrib":{"value":"1726"},"text":"§ 1726.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Postage collected unlawfully","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being a postmaster or other person authorized to receive the postage of mail matter, fraudulently demands or receives any rate of postage or gratuity or reward other than is provided by law for the postage of such mail matter, shall be fined under this title or imprisoned not more than six months, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb92f9067-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/784"},"text":"62 Stat. 784","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/B"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2146"},"text":"108 Stat. 2146","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92f9068-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb92f9069-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 330 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s207"},"text":"Mar. 4, 1909, ch. 321, § 207","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1128"},"text":"35 Stat. 1128","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor verbal changes were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92f906a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92f906b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $100”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
