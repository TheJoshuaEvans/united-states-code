{"tag":"section","attrib":{"id":"idb95a7114-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2290"},"text":null,"children":[{"tag":"num","attrib":{"value":"2290"},"text":"§ 2290.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction and scope","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb95a7115-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2290/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is jurisdiction, including extraterritorial jurisdiction, over an offense under this chapter if the prohibited activity takes place—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95a7116-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2290/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the United States and within waters subject to the jurisdiction of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95a7117-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2290/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" outside United States and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95a7118-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2290/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an offender or a victim is a national of the United States (as that term is defined under section 101(a)(22) of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/22"},"text":"8 U.S.C. 1101(a)(22)","children":[],"tail":"); "},{"tag":"ref","attrib":{"idref":"fn002177"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002177"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. There probably should be an additional closing parenthesis."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95a7119-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2290/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activity involves a vessel in which a national of the United States was on board; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95a711a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2290/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activity involves a vessel of the United States (as that term is defined under section 2 ","children":[{"tag":"ref","attrib":{"idref":"fn002178"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002178"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of the Maritime Drug Law Enforcement Act (46 U.S.C. App. 1903)."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95a711b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2290/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this chapter shall apply to otherwise lawful activities carried out by or at the direction of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb95a711c-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/tIII/s306/a"},"text":"Pub. L. 109–177, title III, § 306(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/237"},"text":"120 Stat. 237","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb95a711d-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb95a711e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb95a711f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 2 of the Maritime Drug Law Enforcement Act, referred to in subsec. (a)(2)(C), probably means section 3 of the Maritime Drug Law Enforcement Act, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/350"},"text":"Pub. L. 96–350","children":[],"tail":", which was classified to section 1903 of former Title 46, Appendix, Shipping, and was repealed and restated in sections 70502 to 70506 of Title 46, Shipping, by "},{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Pub. L. 109–304","children":[],"tail":", §§ 10(2), 19, "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1683"},"text":"120 Stat. 1683","children":[],"tail":", 1710. "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s70502/b"},"text":"Section 70502(b) of Title 46","children":[],"tail":" defines “vessel of the United States”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
