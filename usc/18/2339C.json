tle II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-25"},"text":"June 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/727"},"text":"116 Stat. 727","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/197/tII/s203"},"text":"“Except for paragraphs (1)(D) and (2)(B) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2339C/b"},"text":"section 2339C(b) of title 18","children":[],"tail":", United States Code, which shall become effective on the date that the International Convention for the Suppression of the Financing of Terrorism enters into force for the United States ["},{"tag":"date","attrib":{"date":"2002-07-26"},"text":"July 26, 2002","children":[],"tail":"], and for the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2339C/e/7/I"},"text":"section 2339C(e)(7)(I) of title 18","children":[],"tail":", United States Code, which shall become effective on the date that the International Convention for the Suppression of Terrorist Bombing enters into force for the United States ["},{"tag":"date","attrib":{"date":"2002-07-26"},"text":"July 26, 2002","children":[],"tail":"], section 202 [enacting this section and provisions set out as a note below] shall take effect on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2002-06-25"},"text":"June 25, 2002","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb968c8f9-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Disclaimer","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/197/tII/s202/c"},"text":"Pub. L. 107–197, title II, § 202(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-25"},"text":"June 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/727"},"text":"116 Stat. 727","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/197/tII/s202/c"},"text":"“Nothing contained in this section [enacting this section] is intended to affect the scope or applicability of any other Federal or State law.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
