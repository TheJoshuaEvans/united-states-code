{"tag":"section","attrib":{"id":"idb968c8af-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C"},"text":null,"children":[{"tag":"num","attrib":{"value":"2339C"},"text":"§ 2339C.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions against the financing of terrorism","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb968c8b0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offenses.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb968c8b1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever, in a circumstance described in subsection (b), by any means, directly or indirectly, unlawfully and willfully provides or collects funds with the intention that such funds be used, or with the knowledge that such funds are to be used, in full or in part, in order to carry out—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb968c8b2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an act which constitutes an offense within the scope of a treaty specified in subsection (e)(7), as implemented by the United States, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb968c8b3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other act intended to cause death or serious bodily injury to a civilian, or to any other person not taking an active part in the hostilities in a situation of armed conflict, when the purpose of such act, by its nature or context, is to intimidate a population, or to compel a government or an international organization to do or to abstain from doing any act,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished as prescribed in subsection (d)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb968c8b4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Attempts and conspiracies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever attempts or conspires to commit an offense under paragraph (1) shall be punished as prescribed in subsection (d)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb968c8b5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to predicate act","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For an act to constitute an offense set forth in this subsection, it shall not be necessary that the funds were actually used to carry out a predicate act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb968c8b6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is jurisdiction over the offenses in subsection (a) in the following circumstances—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb968c8b7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the offense takes place in the United States and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb968c8b8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a perpetrator was a national of another state or a stateless person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb968c8b9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on board a vessel flying the flag of another state or an aircraft which is registered under the laws of another state at the time the offense is committed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb968c8ba-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on board an aircraft which is operated by the government of another state;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb968c8bb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a perpetrator is found outside the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb968c8bc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" was directed toward or resulted in the carrying out of a predicate act against—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb968c8bd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/b/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national of another state; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb968c8be-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/b/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another state or a government facility of such state, including its embassy or other diplomatic or consular premises of that state;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb968c8bf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was directed toward or resulted in the carrying out of a predicate act committed in an attempt to compel another state or international organization to do or abstain from doing any act; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb968c8c0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" was directed toward or resulted in the carrying out of a predicate act—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb968c8c1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/b/1/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outside the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb968c8c2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/b/1/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the United States, and either the offense or the predicate act was conducted in, or the results thereof affected, interstate or foreign commerce;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb968c8c3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the offense takes place outside the United States and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb968c8c4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a perpetrator is a national of the United States or is a stateless person whose habitual residence is in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb968c8c5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a perpetrator is found in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb968c8c6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" was directed toward or resulted in the carrying out of a predicate act against—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb968c8c7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any property that is owned, leased, or used by the United States or by any department or agency of the United States, including an embassy or other diplomatic or consular premises of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb968c8c8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person or property within the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb968c8c9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any national of the United States or the property of such national; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb968c8ca-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/b/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any property of any legal entity organized under the laws of the United States, including any of its States, districts, commonwealths, territories, or possessions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb968c8cb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense is committed on board a vessel flying the flag of the United States or an aircraft which is registered under the laws of the United States at the time the offense is committed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb968c8cc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense is committed on board an aircraft which is operated by the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb968c8cd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense was directed toward or resulted in the carrying out of a predicate act committed in an attempt to compel the United States to do or abstain from doing any act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb968c8ce-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Concealment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb968c8cf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb968c8d0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb968c8d1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is outside the United States and is a national of the United States or a legal entity organized under the laws of the United States (including any of its States, districts, commonwealths, territories, or possessions); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb968c8d2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" knowingly conceals or disguises the nature, location, source, ownership, or control of any material support or resources, or any funds or proceeds of such funds—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb968c8d3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowing or intending that the support or resources are to be provided, or knowing that the support or resources were provided, in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2339B"},"text":"section 2339B of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb968c8d4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowing or intending that any such funds are to be provided or collected, or knowing that the funds were provided or collected, in violation of subsection (a),","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished as prescribed in subsection (d)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb968c8d5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb968c8d6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subsection","children":[],"tail":" (a).—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever violates subsection (a) shall be fined under this title, imprisoned for not more than 20 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb968c8d7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subsection","children":[],"tail":" (c).—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever violates subsection (c) shall be fined under this title, imprisoned for not more than 10 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb968c8d8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb968c8d9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “funds” means assets of every kind, whether tangible or intangible, movable or immovable, however acquired, and legal documents or instruments in any form, including electronic or digital, evidencing title to, or interest in, such assets, including coin, currency, bank credits, travelers checks, bank checks, money orders, shares, securities, bonds, drafts, and letters of credit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb968c8da-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “government facility” means any permanent or temporary facility or conveyance that is used or occupied by representatives of a state, members of a government, the legislature, or the judiciary, or by officials or employees of a state or any other public authority or entity or by employees or officials of an intergovernmental organization in connection with their official duties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb968c8db-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “proceeds” means any funds derived from or obtained, directly or indirectly, through the commission of an offense set forth in subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb968c8dc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “provides” includes giving, donating, and transmitting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb968c8dd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “collects” includes raising and receiving;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb968c8de-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “predicate act” means any act referred to in subparagraph (A) or (B) of subsection (a)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb968c8df-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “treaty” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb968c8e0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/e/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Convention for the Suppression of Unlawful Seizure of Aircraft, done at The Hague on ","children":[{"tag":"date","attrib":{"date":"1970-12-16"},"text":"December 16, 1970","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb968c8e1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/e/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Convention for the Suppression of Unlawful Acts against the Safety of Civil Aviation, done at Montreal on ","children":[{"tag":"date","attrib":{"date":"1971-09-23"},"text":"September 23, 1971","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb968c8e2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/e/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Convention on the Prevention and Punishment of Crimes against Internationally Protected Persons, including Diplomatic Agents, adopted by the General Assembly of the United Nations on ","children":[{"tag":"date","attrib":{"date":"1973-12-14"},"text":"December 14, 1973","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb968c8e3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/e/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the International Convention against the Taking of Hostages, adopted by the General Assembly of the United Nations on ","children":[{"tag":"date","attrib":{"date":"1979-12-17"},"text":"December 17, 1979","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb968c8e4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/e/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Convention on the Physical Protection of Nuclear Material, adopted at Vienna on ","children":[{"tag":"date","attrib":{"date":"1980-03-03"},"text":"March 3, 1980","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb968c8e5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/e/7/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Protocol for the Suppression of Unlawful Acts of Violence at Airports Serving International Civil Aviation, supplementary to the Convention for the Suppression of Unlawful Acts against the Safety of Civil Aviation, done at Montreal on ","children":[{"tag":"date","attrib":{"date":"1988-02-24"},"text":"February 24, 1988","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb968c8e6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/e/7/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Convention for the Suppression of Unlawful Acts against the Safety of Maritime Navigation, done at Rome on ","children":[{"tag":"date","attrib":{"date":"1988-03-10"},"text":"March 10, 1988","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb968c8e7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/e/7/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Protocol for the Suppression of Unlawful Acts against the Safety of Fixed Platforms located on the Continental Shelf, done at Rome on ","children":[{"tag":"date","attrib":{"date":"1988-03-10"},"text":"March 10, 1988","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb968c8e8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/e/7/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the International Convention for the Suppression of Terrorist Bombings, adopted by the General Assembly of the United Nations on ","children":[{"tag":"date","attrib":{"date":"1997-12-15"},"text":"December 15, 1997","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb968c8e9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/e/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “intergovernmental organization” includes international organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb968c8ea-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/e/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “international organization” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1116/b/5"},"text":"section 1116(b)(5) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb968c8eb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/e/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “armed conflict” does not include internal disturbances and tensions, such as riots, isolated and sporadic acts of violence, and other acts of a similar nature;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb968c8ec-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/e/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “serious bodily injury” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1365/g/3"},"text":"section 1365(g)(3) of this title","children":[],"tail":"; "},{"tag":"ref","attrib":{"idref":"fn002193"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002193"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb968c8ed-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/e/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “national of the United States” has the meaning given that term in section 101(a)(22) of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/22"},"text":"8 U.S.C. 1101(a)(22)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb968c8ee-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/e/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “material support or resources” has the same meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2339B/g/4"},"text":"section 2339B(g)(4) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb968c8ef-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/e/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “state” has the same meaning as that term has under international law, and includes all political subdivisions thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb968c8f0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2339C/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to any other criminal, civil, or administrative liability or penalty, any legal entity located within the United States or organized under the laws of the United States, including any of the laws of its States, districts, commonwealths, territories, or possessions, shall be liable to the United States for the sum of at least $10,000, if a person responsible for the management or control of that legal entity has, in that capacity, committed an offense set forth in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb968c8f1-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/197/tII/s202/a"},"text":"Pub. L. 107–197, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-25"},"text":"June 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/724"},"text":"116 Stat. 724","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dB/tIV/s4006"},"text":"Pub. L. 107–273, div. B, title IV, § 4006","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1813"},"text":"116 Stat. 1813","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tVI/s6604"},"text":"Pub. L. 108–458, title VI, § 6604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3764"},"text":"118 Stat. 3764","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/tIV/s408"},"text":"Pub. L. 109–177, title IV, § 408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/245"},"text":"120 Stat. 245","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb968c8f2-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb968c8f3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb968c8f4-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1365(g)(3), referred to in subsec. (e)(11), was redesignated section 1365(h)(3) by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/307/s2/1"},"text":"Pub. L. 107–307, § 2(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2445"},"text":"116 Stat. 2445","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb968c8f5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177"},"text":"Pub. L. 109–177","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/s6604"},"text":"Pub. L. 108–458, § 6604","children":[],"tail":". See 2004 Amendment notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s6604/a/1"},"text":"Pub. L. 108–458, § 6604(a)(1)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/s408/1"},"text":"Pub. L. 109–177, § 408(1)","children":[],"tail":", substituted “or resources, or any funds or proceeds of such funds” for “, resources, or funds” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s6604/a/2"},"text":"Pub. L. 108–458, § 6604(a)(2)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/s408/1"},"text":"Pub. L. 109–177, § 408(1)","children":[],"tail":", substituted “are to be provided, or knowing that the support or resources were provided,” for “were provided”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s6604/a/3"},"text":"Pub. L. 108–458, § 6604(a)(3)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/s408/1"},"text":"Pub. L. 109–177, § 408(1)","children":[],"tail":", struck out “or any proceeds of such funds” after “any such funds” and substituted “are to be provided or collected, or knowing that the funds were provided or collected,” for “were provided or collected”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(13), (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s6604/b"},"text":"Pub. L. 108–458, § 6604(b)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/s408/2"},"text":"Pub. L. 109–177, § 408(2)","children":[],"tail":", added par. (13) and redesignated former par. (13) as (14)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(1). ","chil