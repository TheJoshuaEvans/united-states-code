{"tag":"section","attrib":{"id":"idb98a330d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3076"},"text":null,"children":[{"tag":"num","attrib":{"value":"3076"},"text":"§ 3076.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for witness security program","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any individual (and the immediate family of such individual) who furnishes information which would justify a reward by the Attorney General under this chapter or by the Secretary of State under section 36 of the State Department Basic Authorities Act of 1956 may, in the discretion of the Attorney General, participate in the Attorney General’s witness security program authorized under chapter 224 of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb98a330e-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/533/tI/s101/a"},"text":"Pub. L. 98–533, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2707"},"text":"98 Stat. 2707","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/646/s45"},"text":"Pub. L. 99–646, § 45","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3601"},"text":"100 Stat. 3601","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb98a330f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb98a3310-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb98a3311-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 36 of the State Department Basic Authorities Act of 1956, referred to in text, is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2708"},"text":"section 2708 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb98a3312-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646"},"text":"Pub. L. 99–646","children":[],"tail":" substituted “chapter 224 of this title” for “title V of the Organized Crime Control Act of 1970”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
