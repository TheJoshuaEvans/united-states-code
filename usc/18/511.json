{"tag":"section","attrib":{"id":"idb8d03189-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s511"},"text":null,"children":[{"tag":"num","attrib":{"value":"511"},"text":"§ 511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Altering or removing motor vehicle identification numbers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8d0318a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8d0318b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s511/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly removes, obliterates, tampers with, or alters an identification number for a motor vehicle or motor vehicle part; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d0318c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s511/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with intent to further the theft of a motor vehicle, knowingly removes, obliterates, tampers with, or alters a decal or device affixed to a motor vehicle pursuant to the Motor Vehicle Theft Prevention Act,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title, imprisoned not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8d0318d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8d0318e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s511/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) of this section does not apply to a removal, obliteration, tampering, or alteration by a person specified in paragraph (2) of this subsection (unless such person knows that the vehicle or part involved is stolen).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d0318f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s511/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The persons referred to in paragraph (1) of this subsection are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8d03190-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s511/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a motor vehicle scrap processor or a motor vehicle demolisher who complies with applicable State law with respect to such vehicle or part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8d03191-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s511/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person who repairs such vehicle or part, if the removal, obliteration, tampering, or alteration is reasonably necessary for the repair;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8d03192-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s511/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person who restores or replaces an identification number for such vehicle or part in accordance with applicable State law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8d03193-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s511/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a person who removes, obliterates, tampers with, or alters a decal or device affixed to a motor vehicle pursuant to the Motor Vehicle Theft Prevention Act, if that person is the owner of the motor vehicle, or is authorized to remove, obliterate, tamper with or alter the decal or device by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8d03194-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s511/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner or his authorized agent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8d03195-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s511/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicable State or local law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8d03196-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s511/b/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulations promulgated by the Attorney General to implement the Motor Vehicle Theft Prevention Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8d03197-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s511/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in this section, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8d03198-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s511/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “identification number” means a number or symbol that is inscribed or affixed for purposes of identification under chapter 301 and part C of subtitle VI of title 49;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d03199-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s511/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “motor vehicle” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32101"},"text":"section 32101 of title 49","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d0319a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s511/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “motor vehicle demolisher” means a person, including any motor vehicle dismantler or motor vehicle recycler, who is engaged in the business of reducing motor vehicles or motor vehicle parts to metallic scrap that is unsuitable for use as either a motor vehicle or a motor vehicle part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d0319b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s511/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “motor vehicle scrap processor” means a person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8d0319c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s511/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is engaged in the business of purchasing motor vehicles or motor vehicle parts for reduction to metallic scrap for recycling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8d0319d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s511/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, from a fixed location, uses machinery to process metallic scrap into prepared grades; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8d0319e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s511/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose principal product is metallic scrap for recycling;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"but such term does not include any activity of any such person relating to the recycling of a motor vehicle or a motor vehicle part as a used motor vehicle or a used motor vehicle part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8d0319f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s511/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of subsection (a) of this section, the term “tampers with” includes covering a program decal or device affixed to a motor vehicle pursuant to the Motor Vehicle Theft Prevention Act for the purpose of obstructing its visibility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8d031a0-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/547/tII/s201/a"},"text":"Pub. L. 98–547, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-25"},"text":"Oct. 25, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2768"},"text":"98 Stat. 2768","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s5/e/3"},"text":"Pub. L. 103–272, § 5(e)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1373"},"text":"108 Stat. 1373","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXII/s220003/a"},"text":"Pub. L. 103–322, title XXII, § 220003(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2076"},"text":"108 Stat. 2076","children":[],"tail":", 2077; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s604/b/8"},"text":"Pub. L. 104–294, title VI, § 604(b)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3507"},"text":"110 Stat. 3507","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8d031a1-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8d031a2-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8d031a3-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Motor Vehicle Theft Prevention Act, referred to in subsecs. (a)(2), (b)(2)(D), and (d), is title XXII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2074"},"text":"108 Stat. 2074","children":[],"tail":", which enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s511A"},"text":"section 511A of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s12611"},"text":"section 12611 of Title 34","children":[],"tail":", Crime Control and Law Enforcement, amended this section, and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of Title 34","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1994 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of Title 34","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb8d031a4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 511 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s513"},"text":"section 513 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8d031a5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s220003/a"},"text":"Pub. L. 103–322, § 220003(a)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “Whoever knowingly removes, obliterates, tampers with, or alters an identification number for a motor vehicle, or motor vehicle part, shall be fined not more than $10,000 or imprisoned not more than five years, or both.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s220003/b"},"text":"Pub. L. 103–322, § 220003(b)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s5/e/3/A"},"text":"Pub. L. 103–272, § 5(e)(3)(A)","children":[],"tail":", substituted “chapter 301 and part C of subtitle VI of title 49” for “the National Traffic and Motor Vehicle Safety Act of 1966, or the Motor Vehicle Information and Cost Savings Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s5/e/3/B"},"text":"Pub. L. 103–272, § 5(e)(3)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t49/s32101"},"text":"section 32101 of title 49","children":[],"tail":"” for “section 2 of the Motor Vehicle Information and Cost Savings Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s220003/c"},"text":"Pub. L. 103–322, § 220003(c)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8d031a6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8d031a7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/s604/d"},"text":"section 604(d) of Pub. L. 104–294","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s13"},"text":"section 13 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
