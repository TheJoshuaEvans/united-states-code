{"tag":"section","attrib":{"id":"idb8fb12b8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s925D"},"text":null,"children":[{"tag":"num","attrib":{"value":"925D"},"text":"§ 925D.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special assistant U.S. attorneys and cross-deputized attorneys","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8fb12b9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s925D/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to improve the enforcement of paragraphs (8) and (9) of section 922(g), the Attorney General may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fb12ba-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s925D/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s543"},"text":"section 543 of title 28","children":[],"tail":", qualified State, Tribal, territorial and local prosecutors and qualified attorneys working for the United States government to serve as special assistant United States attorneys for the purpose of prosecuting violations of such paragraphs; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fb12bb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s925D/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deputize State, Tribal, territorial and local law enforcement officers for the purpose of enhancing the capacity of the agents of the Bureau of Alcohol, Tobacco, Firearms, and Explosives in responding to and investigating violations of such paragraphs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fb12bc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s925D/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Improve Intimate Partner and Public Safety","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fb12bd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s925D/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify not fewer than 75 jurisdictions among States, territories and Tribes where there are high rates of firearms violence and threats of firearms violence against intimate partners and other persons protected under paragraphs (8) and (9) of section 922(g) and where local authorities lack the resources to address such violence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fb12be-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s925D/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make such appointments as described in subsection (a) in jurisdictions where enhanced enforcement of such paragraphs is necessary to reduce firearms homicide and injury rates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fb12bf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s925D/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish, in order to receive and expedite requests for assistance from State, Tribal, territorial, and local law enforcement agencies responding to intimate partner violence cases where such agencies have probable cause to believe that the offenders may be in violation of such paragraphs, points of contact within—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8fb12c0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s925D/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each Field Division of the Bureau of Alcohol, Tobacco, Firearms, and Explosives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fb12c1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s925D/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each District Office of the United States Attorneys.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fb12c2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s925D/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualified Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, the term “qualified” means, with respect to an attorney, that the attorney is a licensed attorney in good standing with any relevant licensing authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8fb12c3-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tXI/s1103/a"},"text":"Pub. L. 117–103, div. W, title XI, § 1103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/921"},"text":"136 Stat. 921","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8fb12c4-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8fb12c5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8fb12c6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section not effective until Oct. 1 of the first fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s4/a"},"text":"section 4(a) of div. W of Pub. L. 117–103","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6851"},"text":"section 6851 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
