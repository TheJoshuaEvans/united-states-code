{"tag":"section","attrib":{"id":"idb94e89ba-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2255"},"text":null,"children":[{"tag":"num","attrib":{"value":"2255"},"text":"§ 2255.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil remedy for personal injuries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb94e89bb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2255/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person who, while a minor, was a victim of a violation of section 1589, 1590, 1591, 2241(c), 2242, 2243, 2251, 2251A, 2252, 2252A, 2260, 2421, 2422, or 2423 of this title and who suffers personal injury as a result of such violation, regardless of whether the injury occurred while such person was a minor, may sue in any appropriate United States District Court and shall recover the actual damages such person sustains or liquidated damages in the amount of $150,000, and the cost of the action, including reasonable attorney’s fees and other litigation costs reasonably incurred. The court may also award punitive damages and such other preliminary and equitable relief as the court determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb94e89bc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2255/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statute of Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There shall be no time limit for the filing of a complaint commencing an action under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb94e89bd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2255/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Venue; Service of Process.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb94e89be-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2255/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Venue","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any action brought under subsection (a) may be brought in the district court of the United States that meets applicable requirements relating to venue under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1391"},"text":"section 1391 of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94e89bf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2255/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service of process","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In an action brought under subsection (a), process may be served in any district in which the defendant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb94e89c0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2255/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an inhabitant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb94e89c1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2255/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be found.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb94e89c2-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/b/tVII/s703/a"},"text":"Pub. L. 99–500, § 101(b) [title VII, § 703(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-39"},"text":"100 Stat. 1783–39","children":[],"tail":", 1783–74, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/b/tVII/s703/a"},"text":"Pub. L. 99–591, § 101(b) [title VII, § 703(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-39"},"text":"100 Stat. 3341–39","children":[],"tail":", 3341–74; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/314/tVI/s605"},"text":"Pub. L. 105–314, title VI, § 605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2984"},"text":"112 Stat. 2984","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/248/tVII/s707/b"},"text":"Pub. L. 109–248, title VII, § 707(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/650"},"text":"120 Stat. 650","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/tXII/s1212/a"},"text":"Pub. L. 113–4, title XII, § 1212(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/143"},"text":"127 Stat. 143","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/126/tI/s102"},"text":"Pub. L. 115–126, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-14"},"text":"Feb. 14, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/319"},"text":"132 Stat. 319","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/176/s2"},"text":"Pub. L. 117–176, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-09-16"},"text":"Sept. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2108"},"text":"136 Stat. 2108","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb94e89c3-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb94e89c4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb94e89c5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":" is a corrected version of "},{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb94e89c6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2255 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2256"},"text":"section 2256 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb94e89c7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/176"},"text":"Pub. L. 117–176","children":[],"tail":" added subsec. (b) and struck out former subsec. (b). Prior to amendment, text read as follows: “Any action commenced under this section shall be barred unless the complaint is filed—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) not later than 10 years after the date on which the plaintiff reasonably discovers the later of—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the violation that forms the basis for the claim; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the injury that forms the basis for the claim; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) not later than 10 years after the date on which the victim reaches 18 years of age.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/126/s102/1"},"text":"Pub. L. 115–126, § 102(1)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a) which related to civil remedy for personal injuries in general."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/126/s102/2"},"text":"Pub. L. 115–126, § 102(2)","children":[],"tail":", substituted “filed—” for “filed within 10 years after the right of action first accrues or in the case of a person under a legal disability, not later than three years after the disability.” and added pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/126/s102/3"},"text":"Pub. L. 115–126, § 102(3)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s1212/a/1"},"text":"Pub. L. 113–4, § 1212(a)(1)","children":[],"tail":", substituted “section 1589, 1590, 1591, 2241(c)” for “section 2241(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s1212/a/2"},"text":"Pub. L. 113–4, § 1212(a)(2)","children":[],"tail":", substituted “10 years” for “six years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/s707/b"},"text":"Pub. L. 109–248, § 707(b)","children":[],"tail":", inserted heading, inserted “, regardless of whether the injury occurred while such person was a minor,” after “such violation”, and substituted “Any person who, while a minor, was” for “Any minor who is”, “such person” for “such minor”, “Any person as described” for “Any minor as described”, and “$150,000” for “$50,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/s707/c"},"text":"Pub. L. 109–248, § 707(c)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/314"},"text":"Pub. L. 105–314","children":[],"tail":" substituted “2241(c), 2242, 2243, 2251, 2251A, 2252, 2252A, 2260, 2421, 2422, or 2423” for “2251 or 2252”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb94e89c8-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb94e89c9-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/176/s3"},"text":"Pub. L. 117–176, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-09-16"},"text":"Sept. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2108"},"text":"136 Stat. 2108","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/176/s3"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“This Act [see Short Title of 2022 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1"},"text":"section 1 of this title","children":[],"tail":"] and the amendments made by this Act shall—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take effect on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-09-16"},"text":"Sept. 16, 2022","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any claim or action that, as of the date described in paragraph (1), would not have been barred under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2255/b"},"text":"section 2255(b) of title 18","children":[],"tail":", United States Code, as it read on the day before the date of enactment of this Act; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any claim or action arising after the date of enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
