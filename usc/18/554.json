{"tag":"section","attrib":{"id":"idb8d2a36d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s554"},"text":null,"children":[{"tag":"num","attrib":{"value":"554"},"text":"§ 554.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Smuggling goods from the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8d2a36e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s554/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever fraudulently or knowingly exports or sends from the United States, or attempts to export or send from the United States, any merchandise, article, or object contrary to any law or regulation of the United States, or receives, conceals, buys, sells, or in any manner facilitates the transportation, concealment, or sale of such merchandise, article or object, prior to exportation, knowing the same to be intended for exportation contrary to any law or regulation of the United States, shall be fined under this title, imprisoned not more than 10 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8d2a36f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s554/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “United States” has the meaning given that term in section 545.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8d2a370-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/tIII/s311/a"},"text":"Pub. L. 109–177, title III, § 311(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/242"},"text":"120 Stat. 242","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8d2a371-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8d2a372-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb8d2a373-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 554 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s555"},"text":"section 555 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
