{"tag":"section","attrib":{"id":"idb906f9c2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1001"},"text":null,"children":[{"tag":"num","attrib":{"value":"1001"},"text":"§ 1001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statements or entries generally","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb906f9c3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1001/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as otherwise provided in this section, whoever, in any matter within the jurisdiction of the executive, legislative, or judicial branch of the Government of the United States, knowingly and willfully—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb906f9c4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1001/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" falsifies, conceals, or covers up by any trick, scheme, or device a material fact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb906f9c5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1001/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes any materially false, fictitious, or fraudulent statement or representation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb906f9c6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1001/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes or uses any false writing or document knowing the same to contain any materially false, fictitious, or fraudulent statement or entry;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title, imprisoned not more than 5 years or, if the offense involves international or domestic terrorism (as defined in section 2331), imprisoned not more than 8 years, or both. If the matter relates to an offense under chapter 109A, 109B, 110, or 117, or section 1591, then the term of imprisonment imposed under this section shall be not more than 8 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb906f9c7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1001/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) does not apply to a party to a judicial proceeding, or that party’s counsel, for statements, representations, writings or documents submitted by such party or counsel to a judge or magistrate in that proceeding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb906f9c8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1001/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to any matter within the jurisdiction of the legislative branch, subsection (a) shall apply only to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb906f9c9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1001/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative matters, including a claim for payment, a matter related to the procurement of property or services, personnel or employment practices, or support services, or a document required by law, rule, or regulation to be submitted to the Congress or any office or officer within the legislative branch; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb906f9ca-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1001/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any investigation or review, conducted pursuant to the authority of any committee, subcommittee, commission or office of the Congress, consistent with applicable rules of the House or Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb906f9cb-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/749"},"text":"62 Stat. 749","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/L"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(L)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/292/s2"},"text":"Pub. L. 104–292, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3459"},"text":"110 Stat. 3459","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tVI/s6703/a"},"text":"Pub. L. 108–458, title VI, § 6703(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3766"},"text":"118 Stat. 3766","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/248/tI/s141/c"},"text":"Pub. L. 109–248, title I, § 141(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/603"},"text":"120 Stat. 603","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb906f9cc-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb906f9cd-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 80 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s35"},"text":"Mar. 4, 1909, ch. 321, § 35","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1095"},"text":"35 Stat. 1095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1918-10-23/ch194"},"text":"Oct. 23, 1918, ch. 194","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/1015"},"text":"40 Stat. 1015","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1934-06-18/ch587"},"text":"June 18, 1934, ch. 587","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/996"},"text":"48 Stat. 996","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1938-04-04/ch69"},"text":"Apr. 4, 1938, ch. 69","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/197"},"text":"52 Stat. 197","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s80"},"text":"Section 80 of title 18","children":[],"tail":", U.S.C., 1940 ed., was divided into two parts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The provision relating to false claims was incorporated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s287"},"text":"section 287 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to persons causing or procuring was omitted as unnecessary in view of definition of “principal” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “or any corporation in which the United States of America is a stockholder” in said section 80 were omitted as unnecessary in view of definition of “agency” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s6"},"text":"section 6 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In addition to minor changes of phraseology, the maximum term of imprisonment was changed from 10 to 5 years to be consistent with comparable sections. (See reviser’s note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s287"},"text":"section 287 of this title","children":[],"tail":".)"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb906f9ce-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb906f9cf-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248"},"text":"Pub. L. 109–248","children":[],"tail":" inserted last sentence in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" substituted “be fined under this title, imprisoned not more than 5 years or, if the offense involves international or domestic terrorism (as defined in section 2331), imprisoned not more than 8 years, or both” for “be fined under this title or imprisoned not more than 5 years, or both” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/292"},"text":"Pub. L. 104–292","children":[],"tail":" reenacted section catchline without change and amended text generally. Prior to amendment, text read as follows: “Whoever, in any matter within the jurisdiction of any department or agency of the United States knowingly and willfully falsifies, conceals or covers up by any trick, scheme, or device a material fact, or makes any false, fictitious or fraudulent statements or representations, or makes or uses any false writing or document knowing the same to contain any false, fictitious or fraudulent statement or entry, shall be fined under this title or imprisoned not more than five years, or both.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $10,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb906f9d0-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb906f9d1-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to United States magistrate or to magistrate deemed to refer to United States magistrate judge pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/650/s321"},"text":"section 321 of Pub. L. 101–650","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s631"},"text":"section 631 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb906f9d2-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/275/s1"},"text":"Pub. L. 108–275, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-15"},"text":"July 15, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/831"},"text":"118 Stat. 831","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/275/s1"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1028A"},"text":"section 1028A of this title","children":[],"tail":", amending sections 641 and 1028 of this title, and enacting provisions listed in a table relating to sentencing guidelines set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s994"},"text":"section 994 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure] may be cited as the ‘Identity Theft Penalty Enhancement Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb906f9d3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21/tVI/s607/a"},"text":"Pub. L. 108–21, title VI, § 607(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-30"},"text":"Apr. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/689"},"text":"117 Stat. 689","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/21/tVI/s607/a"},"text":"“This section [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1028"},"text":"section 1028 of this title","children":[],"tail":"] may be cited as the ‘Secure Authentication Feature and Enhanced Identification Defense Act of 2003’ or ‘SAFE ID Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb906f9d4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/578/s1"},"text":"Pub. L. 106–578, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-28"},"text":"Dec. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/3075"},"text":"114 Stat. 3075","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/578/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1028"},"text":"section 1028 of this title","children":[],"tail":", repealing "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1738"},"text":"section 1738 of this title","children":[],"tail":", and enacting provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1028"},"text":"section 1028 of this title","children":[],"tail":"] may be cited as the ‘Internet False Identification Prevention Act of 2000’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb906f9d5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1998 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/318/s1"},"text":"Pub. L. 105–318, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3007"},"text":"112 Stat. 3007","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/318/s1"},"text":"“This Act [amending sections 982, 1028, and 2516 of this title and section 105 of the Ethics in Government Act of 1978, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/521"},"text":"Pub. L. 95–521","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees, and enacting provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1028"},"text":"section 1028 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s994"},"text":"section 994 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure] may be cited as the ‘Identity Theft and Assumption Deterrence Act of 1998’.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/172/s1"},"text":"Pub. L. 105–172, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-04-24"},"text":"Apr. 24, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/53"},"text":"112 Stat. 53","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/172/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1029"},"text":"section 1029 of this title","children":[],"tail":" and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s994"},"text":"section 994 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure] may be cited as the ‘Wireless Telephone Protection Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb906f9d6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/292/s1"},"text":"Pub. L. 104–292, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3459"},"text":"110 Stat. 3459","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/292/s1"},"text":"“This Act [amending this section, sections 1515 and 6005 of this title, and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1365"},"text":"section 1365 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure] may be cited as the ‘False Statements Accountability Act of 1996’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb906f9d7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXIX/s290001/a"},"text":"Pub. L. 103–322, title XXIX, § 290001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2097"},"text":"108 Stat. 2097","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s604/b/34"},"text":"Pub. L. 104–294, title VI, § 604(b)(34)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3508"},"text":"110 Stat. 3508","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/294/tVI/s604/b/34"},"text":"“This section [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1030"},"text":"section 1030 of this title","children":[],"tail":"] may be cited as the ‘Computer Abuse Amendments Act of 1994’.”"}],"tail":"\n"}],"tai