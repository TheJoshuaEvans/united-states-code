{"tag":"section","attrib":{"id":"idb95826fd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2273"},"text":null,"children":[{"tag":"num","attrib":{"value":"2273"},"text":"§ 2273.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Destruction of vessel by nonowner","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, not being an owner, upon the high seas or on any other waters within the admiralty and maritime jurisdiction of the United States, willfully and corruptly casts away or otherwise destroys any vessel of the United States to which he belongs, or willfully attempts the destruction thereof, shall be imprisoned not more than ten years.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb95826fe-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/804"},"text":"62 Stat. 804","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb95826ff-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9582700-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 492 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s301"},"text":"Mar. 4, 1909, ch. 321, § 301","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1147"},"text":"35 Stat. 1147","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “with intent to destroy the same, sets fire to any such vessel, or otherwise” following “willfully” and preceding “attempts” were omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
