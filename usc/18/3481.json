{"tag":"section","attrib":{"id":"idb99d45c4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3481"},"text":null,"children":[{"tag":"num","attrib":{"value":"3481"},"text":"§ 3481.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competency of accused","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In trial of all persons charged with the commission of offenses against the United States and in all proceedings in courts martial and courts of inquiry in any State, District, Possession or Territory, the person charged shall, at his own request, be a competent witness. His failure to make such request shall not create any presumption against him.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb99d45c5-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/833"},"text":"62 Stat. 833","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb99d45c6-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb99d45c7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s632"},"text":"section 632 of title 28","children":[],"tail":", U.S.C., 1940 ed., Judicial Code and Judiciary, and section 1200, Art. 42(a), of Title 34, Navy. ("},{"tag":"ref","attrib":{"href":"/us/act/1878-03-16/ch37"},"text":"Mar. 16, 1878, ch. 37","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/20/30"},"text":"20 Stat. 30","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was rewritten without change of substance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb99d45c8-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb99d45c9-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/6/s1"},"text":"Pub. L. 105–6, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-03-19"},"text":"Mar. 19, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/12"},"text":"111 Stat. 12","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/6/s1"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3510"},"text":"section 3510 of this title","children":[],"tail":", amending "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3593"},"text":"section 3593 of this title","children":[],"tail":", and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3510"},"text":"section 3510 of this title","children":[],"tail":"] may be cited as the ‘Victim Rights Clarification Act of 1997’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
