{"tag":"section","attrib":{"id":"idb97e4c92-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2711"},"text":null,"children":[{"tag":"num","attrib":{"value":"2711"},"text":"§ 2711.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions for chapter","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb97e4c93-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2711/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2510"},"text":"section 2510 of this title","children":[],"tail":" have, respectively, the definitions given such terms in that section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97e4c94-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2711/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “remote computing service” means the provision to the public of computer storage or processing services by means of an electronic communications system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97e4c95-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2711/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “court of competent jurisdiction” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb97e4c96-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2711/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any district court of the United States (including a magistrate judge of such a court) or any United States court of appeals that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb97e4c97-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2711/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has jurisdiction over the offense being investigated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb97e4c98-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2711/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in or for a district in which the provider of a wire or electronic communication service is located or in which the wire or electronic communications, records, or other information are stored; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb97e4c99-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2711/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is acting on a request for foreign assistance pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3512"},"text":"section 3512 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb97e4c9a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2711/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a court of general criminal jurisdiction of a State authorized by the law of that State to issue search warrants; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb97e4c9b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2711/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a court-martial or other proceeding under chapter 47 of title 10 (the Uniform Code of Military Justice) to which a military judge has been detailed; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97e4c9c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2711/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “governmental entity” means a department or agency of the United States or any State or political subdivision thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb97e4c9d-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/508/tII/s201"},"text":"Pub. L. 99–508, title II, § 201[(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1868"},"text":"100 Stat. 1868","children":[],"tail":", § 2710; renumbered § 2711, "},{"tag":"ref","attrib":{"href":"/us/pl/100/618/s2/a/1"},"text":"Pub. L. 100–618, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-05"},"text":"Nov. 5, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3195"},"text":"102 Stat. 3195","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tII/s220/a/2"},"text":"Pub. L. 107–56, title II, § 220(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/292"},"text":"115 Stat. 292","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/tI/s107/b/2"},"text":"Pub. L. 109–177, title I, § 107(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":