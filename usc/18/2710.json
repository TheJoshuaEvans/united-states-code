{"tag":"section","attrib":{"id":"idb97e4c67-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710"},"text":null,"children":[{"tag":"num","attrib":{"value":"2710"},"text":"§ 2710.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wrongful disclosure of video tape rental or sale records","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb97e4c68-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb97e4c69-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “consumer” means any renter, purchaser, or subscriber of goods or services from a video tape service provider;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97e4c6a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “ordinary course of business” means only debt collection activities, order fulfillment, request processing, and the transfer of ownership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97e4c6b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “personally identifiable information” includes information which identifies a person as having requested or obtained specific video materials or services from a video tape service provider; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97e4c6c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “video tape service provider” means any person, engaged in the business, in or affecting interstate or foreign commerce, of rental, sale, or delivery of prerecorded video cassette tapes or similar audio visual materials, or any person or other entity to whom a disclosure is made under subparagraph (D) or (E) of subsection (b)(2), but only with respect to the information contained in the disclosure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb97e4c6d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Video Tape Rental and Sale Records","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb97e4c6e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A video tape service provider who knowingly discloses, to any person, personally identifiable information concerning any consumer of such provider shall be liable to the aggrieved person for the relief provided in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97e4c6f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A video tape service provider may disclose personally identifiable information concerning any consumer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb97e4c70-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the consumer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb97e4c71-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to any person with the informed, written consent (including through an electronic means using the Internet) of the consumer that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb97e4c72-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in a form distinct and separate from any form setting forth other legal or financial obligations of the consumer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb97e4c73-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at the election of the consumer—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb97e4c74-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/b/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is given at the time the disclosure is sought; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb97e4c75-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/b/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is given in advance for a set period of time, not to exceed 2 years or until consent is withdrawn by the consumer, whichever is sooner; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb97e4c76-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the video tape service provider has provided an opportunity, in a clear and conspicuous manner, for the consumer to withdraw on a case-by-case basis or to withdraw from ongoing disclosures, at the consumer’s election;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb97e4c77-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a law enforcement agency pursuant to a warrant issued under the Federal Rules of Criminal Procedure, an equivalent State warrant, a grand jury subpoena, or a court order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb97e4c78-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to any person if the disclosure is solely of the names and addresses of consumers and if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb97e4c79-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the video tape service provider has provided the consumer with the opportunity, in a clear and conspicuous manner, to prohibit such disclosure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb97e4c7a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disclosure does not identify the title, description, or subject matter of any video tapes or other audio visual material; however, the subject matter of such materials may be disclosed if the disclosure is for the exclusive use of marketing goods and services directly to the consumer;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb97e4c7b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any person if the disclosure is incident to the ordinary course of business of the video tape service provider; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb97e4c7c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" pursuant to a court order, in a civil proceeding upon a showing of compelling need for the information that cannot be accommodated by any other means, if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb97e4c7d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/b/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consumer is given reasonable notice, by the person seeking the disclosure, of the court proceeding relevant to the issuance of the court order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb97e4c7e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/b/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consumer is afforded the opportunity to appear and contest the claim of the person seeking the disclosure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"If an order is granted pursuant to subparagraph (C) or (F), the court shall impose appropriate safeguards against unauthorized disclosure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97e4c7f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Court orders authorizing disclosure under subparagraph (C) shall issue only with prior notice to the consumer and only if the law enforcement agency shows that there is probable cause to believe that the records or other information sought are relevant to a legitimate law enforcement inquiry. In the case of a State government authority, such a court order shall not issue if prohibited by the law of such State. A court issuing an order pursuant to this section, on a motion made promptly by the video tape service provider, may quash or modify such order if the information or records requested are unreasonably voluminous in nature or if compliance with such order otherwise would cause an unreasonable burden on such provider.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb97e4c80-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Action","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb97e4c81-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person aggrieved by any act of a person in violation of this section may bring a civil action in a United States district court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97e4c82-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The court may award—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb97e4c83-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actual damages but not less than liquidated damages in an amount of $2,500;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb97e4c84-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" punitive damages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb97e4c85-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable attorneys’ fees and other litigation costs reasonably incurred; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb97e4c86-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other preliminary and equitable relief as the court determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97e4c87-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No action may be brought under this subsection unless such action is begun within 2 years from the date of the act complained of or the date of discovery.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97e4c88-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No liability shall result from lawful disclosure permitted by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb97e4c89-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Personally Identifiable Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Personally identifiable information obtained in any manner other than as provided in this section shall not be received in evidence in any trial, hearing, arbitration, or other proceeding in or before any court, grand jury, department, officer, agency, regulatory body, legislative committee, or other authority of the United States, a State, or a political subdivision of a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb97e4c8a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Destruction of Old Records","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person subject to this section shall destroy personally identifiable information as soon as practicable, but no later than one year from the date the information is no longer necessary for the purpose for which it was collected and there are no pending requests or orders for access to such information under subsection (b)(2) or (c)(2) or pursuant to a court order.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb97e4c8b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2710/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preemption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The provisions of this section preempt only the provisions of State or local law that require disclosure prohibited by this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb97e4c8c-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/618/s2/a/2"},"text":"Pub. L. 100–618, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-05"},"text":"Nov. 5, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3195"},"text":"102 Stat. 3195","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/258/s2"},"text":"Pub. L. 112–258, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-10"},"text":"Jan. 10, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2414"},"text":"126 Stat. 2414","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb97e4c8d-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb97e4c8e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb97e4c8f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Criminal Procedure, referred to in subsec. (b)(2)(C), are set out in the Appendix to this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb97e4c90-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2710 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2711"},"text":"section 2711 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb97e4c91-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/258"},"text":"Pub. L. 112–258","children":[],"tail":" added subpar. (B) and struck out former subpar. (B) which read as follows: “to any person with the informed, written consent of the consumer given at the time the disclosure is sought;”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
