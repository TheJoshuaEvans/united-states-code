{"tag":"section","attrib":{"id":"idb949ceac-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2244"},"text":null,"children":[{"tag":"num","attrib":{"value":"2244"},"text":"§ 2244.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abusive sexual contact","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb949cead-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2244/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sexual Conduct in Circumstances Where Sexual Acts Are Punished by This Chapter","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever, in the special maritime and territorial jurisdiction of the United States or in a Federal prison, or in any prison, institution, or facility in which persons are held in custody by direction of or pursuant to a contract or agreement with the head of any Federal department or agency, knowingly engages in or causes sexual contact with or by another person, if so to do would violate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb949ceae-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2244/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (a) or (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2241"},"text":"section 2241 of this title","children":[],"tail":" had the sexual contact been a sexual act, shall be fined under this title, imprisoned not more than ten years, or both;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb949ceaf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2244/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2242"},"text":"section 2242 of this title","children":[],"tail":" had the sexual contact been a sexual act, shall be fined under this title, imprisoned not more than three years, or both;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb949ceb0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2244/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2243"},"text":"section 2243 of this title","children":[],"tail":" had the sexual contact been a sexual act, shall be fined under this title, imprisoned not more than two years, or both;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb949ceb1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2244/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2243"},"text":"section 2243 of this title","children":[],"tail":" had the sexual contact been a sexual act, shall be fined under this title, imprisoned not more than two years, or both;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb949ceb2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2244/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2241"},"text":"section 2241 of this title","children":[],"tail":" had the sexual contact been a sexual act, shall be fined under this title and imprisoned for any term of years or for life; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb949ceb3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2244/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2243"},"text":"section 2243 of this title","children":[],"tail":" had the sexual contact been a sexual act, shall be fined under this title, imprisoned not more than two years, or both; "},{"tag":"ref","attrib":{"idref":"fn002142"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002142"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The semicolon probably should be a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb949ceb4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2244/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In Other Circumstances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever, in the special maritime and territorial jurisdiction of the United States or in a Federal prison, or in any prison, institution, or facility in which persons are held in custody by direction of or pursuant to a contract or agreement with the head of any Federal department or agency, knowingly engages in sexual contact with another person without that other person’s permission shall be fined under this title, imprisoned not more than two years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb949ceb5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2244/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offenses Involving Young Children","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the sexual contact that violates this section (other than subsection (a)(5)) is with an individual who has not attained the age of 12 years, the maximum term of imprisonment that may be imposed for the offense shall be twice that otherwise provided in this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb949ceb6-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646/s87/b"},"text":"Pub. L. 99–646, § 87(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3622"},"text":"100 Stat. 3622","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/99/654/s2"},"text":"Pub. L. 99–654, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3661"},"text":"100 Stat. 3661","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7058/a"},"text":"Pub. L. 100–690, title VII, § 7058(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4403"},"text":"102 Stat. 4403","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/314/tIII/s302"},"text":"Pub. L. 105–314, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2979"},"text":"112 Stat. 2979","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1177/a/5"},"text":"Pub. L. 109–162, title XI, § 1177(a)(5)","children":[],"tail":", (b)(2), "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3125"},"text":"119 Stat. 3125","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/248/tII"},"text":"Pub. L. 109–248, title II","children":[],"tail":", §§ 206(a)(2), 207(2), "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/613"},"text":"120 Stat. 613","children":[],"tail":", 615; "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dE/tV/s554"},"text":"Pub. L. 110–161, div. E, title V, § 554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2082"},"text":"121 Stat. 2082","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tXII/s1202/d"},"text":"Pub. L. 117–103, div. W, title XII, § 1202(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/925"},"text":"136 Stat. 925","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb949ceb7-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb949ceb8-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb949ceb9-47c4-11f1-9a61-b1559996dfe8"},"text":