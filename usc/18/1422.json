{"tag":"section","attrib":{"id":"idb91eee61-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1422"},"text":null,"children":[{"tag":"num","attrib":{"value":"1422"},"text":"§ 1422.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees in naturalization proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever knowingly demands, charges, solicits, collects, or receives, or agrees to charge, solicit, collect, or receive any other or additional fees or moneys in proceedings relating to naturalization or citizenship or the registry of aliens beyond the fees and moneys authorized by law, shall be fined under this title or imprisoned not more than five years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb91eee62-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/766"},"text":"62 Stat. 766","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91eee63-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb91eee64-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on subsections (a)(33), (d), (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s746"},"text":"section 746 of title 8","children":[],"tail":", U.S.C., 1940 ed., Aliens and Nationality ("},{"tag":"ref","attrib":{"href":"/us/act/1940-10-14/ch876/s346/a/33"},"text":"Oct. 14, 1940, ch. 876, § 346(a)(33)","children":[],"tail":", (d), ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"ref","attrib":{"href":"/us/stat/54/1167"},"text":"54 Stat. 1167","children":[],"tail":", 1168)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes in phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb91eee65-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb91eee66-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $5,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
