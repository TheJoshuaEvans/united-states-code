{"tag":"section","attrib":{"id":"idb9d67ea9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s6003"},"text":null,"children":[{"tag":"num","attrib":{"value":"6003"},"text":"§ 6003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Court and grand jury proceedings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9d67eaa-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s6003/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of any individual who has been or may be called to testify or provide other information at any proceeding before or ancillary to a court of the United States or a grand jury of the United States, the United States district court for the judicial district in which the proceeding is or may be held shall issue, in accordance with subsection (b) of this section, upon the request of the United States attorney for such district, an order requiring such individual to give testimony or provide other information which he refuses to give or provide on the basis of his privilege against self-incrimination, such order to become effective as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s6002"},"text":"section 6002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9d67eab-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s6003/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A United States attorney may, with the approval of the Attorney General, the Deputy Attorney General, the Associate Attorney General, or any designated Assistant Attorney General or Deputy Assistant Attorney General, request an order under subsection (a) of this section when in his judgment—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9d67eac-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s6003/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the testimony or other information from such individual may be necessary to the public interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9d67ead-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s6003/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such individual has refused or is likely to refuse to testify or provide other information on the basis of his privilege against self-incrimination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9d67eae-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/452/tII/s201/a"},"text":"Pub. L. 91–452, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-15"},"text":"Oct. 15, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/927"},"text":"84 Stat. 927","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7020/e"},"text":"Pub. L. 100–690, title VII, § 7020(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4396"},"text":"102 Stat. 4396","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330013/4"},"text":"Pub. L. 103–322, title XXXIII, § 330013(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2146"},"text":"108 Stat. 2146","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9d67eaf-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9d67eb0-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9d67eb1-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “title” for “part” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" inserted “, the Associate Attorney General” after “Deputy Attorney General”, and “or Deputy Assistant Attorney General” after “Assistant Attorney General”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
