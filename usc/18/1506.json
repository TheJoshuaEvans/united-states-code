{"tag":"section","attrib":{"id":"idb923a950-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1506"},"text":null,"children":[{"tag":"num","attrib":{"value":"1506"},"text":"§ 1506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Theft or alteration of record or process; false bail","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever feloniously steals, takes away, alters, falsifies, or otherwise avoids any record, writ, process, or other proceeding, in any court of the United States, whereby any judgment is reversed, made void, or does not take effect; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever acknowledges, or procures to be acknowledged in any such court, any recognizance, bail, or judgment, in the name of any other person not privy or consenting to the same—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Shall be fined under this title or imprisoned not more than five years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb923a951-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/770"},"text":"62 Stat. 770","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb923a952-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb923a953-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 233 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s127"},"text":"Mar. 4, 1909, ch. 321, § 127","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1111"},"text":"35 Stat. 1111","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The term of imprisonment was reduced from 7 to 5 years, to conform the punishment with like ones for similar offenses. (See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1503"},"text":"section 1503 of this title","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb923a954-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb923a955-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $5,000” in last par."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
