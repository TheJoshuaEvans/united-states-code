{"tag":"section","attrib":{"id":"idb95ce17c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318"},"text":null,"children":[{"tag":"num","attrib":{"value":"2318"},"text":"§ 2318.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trafficking in counterfeit labels, illicit labels, or counterfeit documentation or packaging","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb95ce17d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95ce17e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002183"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002183"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No par. (2) has been enacted."}],"tail":" Whoever, in any of the circumstances described in subsection (c), knowingly traffics in—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95ce17f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a counterfeit label or illicit label affixed to, enclosing, or accompanying, or designed to be affixed to, enclose, or accompany—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb95ce180-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a phonorecord;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95ce181-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of a computer program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95ce182-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of a motion picture or other audiovisual work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95ce183-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of a literary work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95ce184-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/a/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of a pictorial, graphic, or sculptural work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95ce185-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/a/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a work of visual art; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95ce186-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/a/1/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documentation or packaging; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95ce187-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" counterfeit documentation or packaging,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title or imprisoned for not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95ce188-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95ce189-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “counterfeit label” means an identifying label or container that appears to be genuine, but is not;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95ce18a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “traffic” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2320/f"},"text":"section 2320(f) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95ce18b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “copy”, “phonorecord”, “motion picture”, “computer program”, “audiovisual work”, “literary work”, “pictorial, graphic, or sculptural work”, “sound recording”, “work of visual art”, and “copyright owner” have, respectively, the meanings given those terms in section 101 (relating to definitions) of title 17;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95ce18c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “illicit label” means a genuine certificate, licensing document, registration card, or similar labeling component—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95ce18d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is used by the copyright owner to verify that a phonorecord, a copy of a computer program, a copy of a motion picture or other audiovisual work, a copy of a literary work, a copy of a pictorial, graphic, or sculptural work, a work of visual art, or documentation or packaging is not counterfeit or infringing of any copyright; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95ce18e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that is, without the authorization of the copyright owner—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb95ce18f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distributed or intended for distribution not in connection with the copy, phonorecord, or work of visual art to which such labeling component was intended to be affixed by the respective copyright owner; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95ce190-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in connection with a genuine certificate or licensing document, knowingly falsified in order to designate a higher number of licensed users or copies than authorized by the copyright owner, unless that certificate or document is used by the copyright owner solely for the purpose of monitoring or tracking the copyright owner’s distribution channel and not for the purpose of verifying that a copy or phonorecord is noninfringing;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95ce191-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “documentation or packaging” means documentation or packaging, in physical form, for a phonorecord, copy of a computer program, copy of a motion picture or other audiovisual work, copy of a literary work, copy of a pictorial, graphic, or sculptural work, or work of visual art; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95ce192-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “counterfeit documentation or packaging” means documentation or packaging that appears to be genuine, but is not.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95ce193-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The circumstances referred to in subsection (a) of this section are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95ce194-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense is committed within the special maritime and territorial jurisdiction of the United States; or within the special aircraft jurisdiction of the United States (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s46501"},"text":"section 46501 of title 49","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95ce195-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the mail or a facility of interstate or foreign commerce is used or intended to be used in the commission of the offense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95ce196-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the counterfeit label or illicit label is affixed to, encloses, or accompanies, or is designed to be affixed to, enclose, or accompany—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95ce197-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a phonorecord of a copyrighted sound recording or copyrighted musical work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95ce198-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of a copyrighted computer program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95ce199-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of a copyrighted motion picture or other audiovisual work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95ce19a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of a literary work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95ce19b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of a pictorial, graphic, or sculptural work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95ce19c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a work of visual art; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95ce19d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/c/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" copyrighted documentation or packaging; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95ce19e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the counterfeited documentation or packaging is copyrighted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95ce19f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Forfeiture and Destruction of Property; Restitution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Forfeiture, destruction, and restitution relating to this section shall be subject to section 2323, to the extent provided in that section, in addition to any other similar remedies provided by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95ce1a0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Remedies.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95ce1a1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any copyright owner who is injured, or is threatened with injury, by a violation of subsection (a) may bring a civil action in an appropriate United States district court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95ce1a2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Discretion of court","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any action brought under paragraph (1), the court—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95ce1a3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may grant 1 or more temporary or permanent injunctions on such terms as the court determines to be reasonable to prevent or restrain a violation of subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95ce1a4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at any time while the action is pending, may order the impounding, on such terms as the court determines to be reasonable, of any article that is in the custody or control of the alleged violator and that the court has reasonable cause to believe was involved in a violation of subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95ce1a5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may award to the injured party—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb95ce1a6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/e/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable attorney fees and costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95ce1a7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/e/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb95ce1a8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/e/2/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actual damages and any additional profits of the violator, as provided in paragraph (3); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb95ce1a9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/e/2/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" statutory damages, as provided in paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95ce1aa-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actual damages and profits.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95ce1ab-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The injured party is entitled to recover—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb95ce1ac-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/e/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual damages suffered by the injured party as a result of a violation of subsection (a), as provided in subparagraph (B) of this paragraph; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95ce1ad-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/e/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any profits of the violator that are attributable to a violation of subsection (a) and are not taken into account in computing the actual damages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95ce1ae-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Calculation of damages","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The court shall calculate actual damages by multiplying—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb95ce1af-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of the phonorecords, copies, or works of visual art which are, or are intended to be, affixed with, enclosed in, or accompanied by any counterfeit labels, illicit labels, or counterfeit documentation or packaging, by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95ce1b0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of phonorecords, copies, or works of visual art which are, or are intended to be, affixed with, enclosed in, or accompanied by any counterfeit labels, illicit labels, or counterfeit documentation or packaging.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95ce1b1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this paragraph, the “value” of a phonorecord, copy, or work of visual art is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb95ce1b2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/e/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a copyrighted sound recording or copyrighted musical work, the retail value of an authorized phonorecord of that sound recording or musical work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95ce1b3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/e/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a copyrighted computer program, the retail value of an authorized copy of that computer program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95ce1b4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/e/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a copyrighted motion picture or other audiovisual work, the retail value of an authorized copy of that motion picture or audiovisual work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95ce1b5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/e/3/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a copyrighted literary work, the retail value of an authorized copy of that literary work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95ce1b6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/e/3/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a pictorial, graphic, or sculptural work, the retail value of an authorized copy of that work; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95ce1b7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/e/3/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a work of visual art, the retail value of that work.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95ce1b8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statutory damages","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The injured party may elect, at any time before final judgment is rendered, to recover, instead of actual damages and profits, an award of statutory damages for each violation of subsection (a) in a sum of not less than $2,500 or more than $25,000, as the court considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95ce1b9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subsequent violation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The court may increase an award of damages under this subsection by 3 times the amount that would otherwise be awarded, as the court considers appropriate, if the court finds that a person has subsequently violated subsection (a) within 3 years after a final judgment was entered against that person for a violation of that subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95ce1ba-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2318/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on actions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A civil action may not be commenced under this subsection unless it is commenced within 3 years after the date on which the claimant discovers the violation of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb95ce1bb-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/773/s1"},"text":"Pub. L. 87–773, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-09"},"text":"Oct. 9, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/775"},"text":"76 Stat. 775","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/573/tI/s103"},"text":"Pub. L. 93–573, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-31"},"text":"Dec. 31, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1873"},"text":"88 Stat. 1873","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/553/tI/s111"},"text":"Pub. L. 94–553, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-19"},"text":"Oct. 19, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2600"},"text":"90 Stat. 2600","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/180/s2"},"text":"Pub. L. 97–180, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-05-24"},"text":"May 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/91"},"text":"96 Stat. 91","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXV/s3567"},"text":"Pub. L. 101–647, title XXXV, § 3567","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4928"},"text":"104 Stat. 4928","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s5/e/10"},"text":"Pub. L. 103–272, § 5(e)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1374"},"text":"108 Stat. 1374","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/U"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(U)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2148"},"text":"108 Stat. 2148","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/153/s4/a"},"text":"Pub. L. 104–153, § 4(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1996-07-02"},"text":"July 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1386"},"text":"110 Stat. 1386","children":[],"tail":", 1387; "},{"tag":"ref","attrib":{"href":"/us/pl/108/482/tI/s102/a"},"text":"Pub. L. 108–482, title I, § 102(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3912"},"text":"118 Stat. 3912","children":[],"tail":", 3914; "},{"tag":"ref","attrib":{"href":"/us/pl/109/181/s2/c/2"},"text":"Pub. L. 109–181, § 2(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-16"},"text":"Mar. 16, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/288"},"text":"120 Stat. 288","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/403/tII/s202"},"text":"Pub. L. 110–403, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4260"},"text":"122 Stat. 4260","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/295/s6/i"},"text":"Pub. L. 111–295, § 6(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-09"},"text":"Dec. 9, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3182"},"text":"124 Stat. 3182","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/154/s3/1"},"text":"Pub. L. 114–154, § 3(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-05-16"},"text":"May 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/387"},"text":"130 Stat. 387","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb95ce1bc-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb95ce1bd-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb95ce1be-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/154"},"text":"Pub. L. 114–154","children":[],"tail":" substituted “section 2320(f)” for “section 2320(e)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (e)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/295"},"text":"Pub. L. 111–295","children":[],"tail":" substituted “under this subsection” for “under section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/403/s202/1"},"text":"Pub. L. 110–403, § 202(1)","children":[],"tail":", designated existing provisions as par. (1) and redesignated former pars. (1) and (2) as subpars. (A) and (B), respectively, of par. (1), and former subpars. (A) to (G) as cls. (i) to (vii), respectively, of subpar. (A)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/403/s202/2"},"text":"Pub. L. 110–403, § 202(2)","children":[],"tail":", amended subsec. (d) generally. Prior to amendment, subsec. (d) read as follows: “When any person is convicted of any violation of subsection (a), the court in its judgment of conviction shall in addition to the penalty therein prescribed, order the forfeiture and destruction or other disposition of all counterfeit labels or illicit labels and all articles to which counterfeit labels or illicit labels have been affixed or which were intended to have had such labels affixed, and of any equipment, device, or material used to manufacture, reproduce, or assemble the counterfeit labels or illicit labels.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/403/s202/3"},"text":"Pub. L. 110–403, § 202(3)","children":[],"tail":", redesignated subsec. (f) as (e) and struck out former subsec. (e) which read as follows: “Except to the extent they are inconsistent with the provisions of this title, all provisions of section 509, title 17, United States Code, are applicable to violations of subsection (a).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/181"},"text":"Pub. L. 109–181","children":[],"tail":" added par. (2) and struck out former par. (2) which read as follows: “the term ‘traffic’ means to transport, transfer or otherwise dispose of, to another, as consideration for anything of value or to make or obtain control of with intent to so transport, transfer or dispose of;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/482/s102/a/1"},"text":"Pub. L. 108–482, § 102(a)(1)","children":[],"tail":", substituted “Trafficking in counterfeit labels, illicit labels, or counterfeit documentation or packaging” for “Trafficking in counterfeit labels for phonorecords, copies of computer programs or computer program documentation or packaging, and copies of motion pictures or other audio visual works, and trafficking in counterfeit computer program documentation or packaging” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/482/s102/a/2"},"text":"Pub. L. 108–482, § 102(a)(2)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a) which read as follows: “Whoever, in any of the circumstances described in subsection (c) of this section, knowingly traffics in a counterfeit label affixed or designed to be affixed to a phonorecord, or a copy of a computer program or documentation or packaging for a computer program, or a copy of a motion picture or other audiovisual work, and whoever, in any of the circumstances described in subsection (c) of this section, knowingly traffics in counterfeit documentation or packaging for a computer program, shall be fined under this title or imprisoned for not more than five years, or both.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/482/s102/a/3/A"},"text":"Pub. L. 108–482, § 102(a)(3)(A)","children":[],"tail":", struck out “and” after the semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/482/s102/a/3/B"},"text":"Pub. L. 108–482, § 102(a)(3)(B)","children":[],"tail":", substituted “ ‘audiovisual work’, ‘literary work’, ‘pictorial, graphic, or sculptural work’, ‘sound recording’, ‘work of visual art’, and ‘copyright owner’ have” for “and ‘audiovisual work’ have” and a semicolon for the period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/482/s102/a/3/C"},"text":"Pub. L. 108–482, § 102(a)(3)(C)","children":[],"tail":", added pars. (4) to (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/482/s102/a/4/A"},"text":"Pub. L. 108–482, § 102(a)(4)(A)","children":[],"tail":", added par. (3) and struck former par. (3) which read as follows: “the counterfeit label is affixed to or encloses, or is designed to be affixed to or enclose, a copy of a copyrighted computer program or copyrighted documentation or packaging for a computer program, a copyrighted motion picture or other audiovisual work, or a phonorecord of a copyrighted sound recording; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/482/s102/a/4/B"},"text":"Pub. L. 108–482, § 102(a)(4)(B)","children":[],"tail":", struck out “for a computer program” after “packaging”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/482/s102/a/5"},"text":"Pub. L. 108–482, § 102(a)(5)","children":[],"tail":", inserted “or illicit labels” after “counterfeit labels” in two places and inserted “, and of any equipment, device, or material used to manufacture, reproduce, or assemble the counterfeit labels or illicit labels” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/482/s102/b"},"text":"Pub. L. 108–482, § 102(b)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/153/s4/b/1"},"text":"Pub. L. 104–153, § 4(b)(1)","children":[],"tail":", substituted “Trafficking in counterfeit labels for phonorecords, copies of computer programs or computer program documentation or packaging, and copies of motion pictures or other audio visual works, and trafficking in counterfeit computer program documentation or packaging” for “Trafficking in counterfeit labels for phonorecords and copies of motion pictures or other audiovisual works” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/153/s4/a/1"},"text":"Pub. L. 104–153, § 4(a)(1)","children":[],"tail":", substituted “a computer program or documentation or packaging for a computer program, or a copy of a motion picture or other audiovisual work, and whoever, in any of the circumstances described in subsection (c) of this section, knowingly traffics in counterfeit documentation or packaging for a computer program,” for “a motion picture or other audiovisual work,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/153/s4/a/2"},"text":"Pub. L. 104–153, § 4(a)(2)","children":[],"tail":", inserted “ ‘computer program’,” after “ ‘motion picture’,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/153/s4/a/3/A"},"text":"Pub. L. 104–153, § 4(a)(3)(A)","children":[],"tail":", struck out “or” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/153/s4/a/3/B"},"text":"Pub. L. 104–153, § 4(a)(3)(B)","children":[],"tail":", inserted “a copy of a copyrighted computer program or copyrighted documentation or packaging for a computer program,” after “enclose,” and substituted “; or” for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/153/s4/a/3/C"},"text":"Pub. L. 104–153, § 4(a)(3)(C)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $250,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Pub. L. 103–272","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t49/s46501"},"text":"section 46501 of title 49","children":[],"tail":"” for “section 101 of the Federal Aviation Act of 1958”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":" struck out comma after “phonorecords” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/180"},"text":"Pub. L. 97–180","children":[],"tail":" substituted “Trafficking in counterfeit labels for phonorecords, and copies of motion pictures or other audiovisual works” for “Transportation, sale or receipt of phonograph records bearing forged or counterfeit labels” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/180"},"text":"Pub. L. 97–180","children":[],"tail":" substituted provision that violators of this section shall be fined not more than $250,000 or imprisoned for not more than five years or both for provision that whoever knowingly and with fraudulent intent transported, caused to be transported, received, sold, or offered for sale in interstate or foreign commerce any phonograph record, disk, wire, tape, film, or other article on which sounds were recorded, to which or upon which was stamped, pasted, or affixed any forged or counterfeited label, knowing the label to have been falsely made, forged, or counterfeited would be fined not more than $10,000 or imprisoned for not more than one year, or both, for the first such offense and would be fined not more than $25,000 or imprisoned for not more than two years, or both, for any subsequent offense."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/180"},"text":"Pub. L. 97–180","children":[],"tail":" added subsecs. (b) and (c), redesignated former subsecs. (b) and (c) as (d) and (e), respectively, and in subsec. (d) as so redesignated struck out the comma after “judgment of conviction shall”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/553"},"text":"Pub. L. 94–553","children":[],"tail":" designated 