{"tag":"section","attrib":{"id":"idb8d2a348-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s551"},"text":null,"children":[{"tag":"num","attrib":{"value":"551"},"text":"§ 551.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concealing or destroying invoices or other papers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever willfully conceals or destroys any invoice, book, or paper relating to any merchandise imported into the United States, after an inspection thereof has been demanded by the collector of any collection district; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever conceals or destroys at any time any such invoice, book, or paper for the purpose of suppressing any evidence of fraud therein contained—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Shall be fined under this title or imprisoned not more than two years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8d2a349-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/718"},"text":"62 Stat. 718","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8d2a34a-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8d2a34b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 120 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s64"},"text":"Mar. 4, 1909, ch. 321, § 64","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1100"},"text":"35 Stat. 1100","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8d2a34c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8d2a34d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $5,000” in last par."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb8d2a34e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idb8d2a34f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"All offices of collector of customs, comptroller of customs, surveyor of customs, and appraiser of merchandise in Bureau of Customs of Department of the Treasury to which appointments were required to be made by President with advice and consent of Senate ordered abolished, with such offices to be terminated not later than ","children":[{"tag":"date","attrib":{"date":"1966-12-31"},"text":"Dec. 31, 1966","children":[],"tail":", by Reorg. Plan No. 1 of 1965, eff. "},{"tag":"date","attrib":{"date":"1965-05-25"},"text":"May 25, 1965","children":[],"tail":", 30 F.R. 7035, "},{"tag":"ref","attrib":{"href":"/us/stat/79/1317"},"text":"79 Stat. 1317","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees. All functions of offices eliminated were already vested in Secretary of the Treasury by Reorg. Plan No. 26 of 1950, eff. "},{"tag":"date","attrib":{"date":"1950-07-31"},"text":"July 31, 1950","children":[],"tail":", 15 F.R. 4935, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1280"},"text":"64 Stat. 1280","children":[],"tail":", set out in the Appendix to Title 5."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
