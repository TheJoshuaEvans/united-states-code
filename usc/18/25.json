{"tag":"section","attrib":{"id":"idb8a2e0ae-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s25"},"text":null,"children":[{"tag":"num","attrib":{"value":"25"},"text":"§ 25.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of minors in crimes of violence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8a2e0af-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s25/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a2e0b0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s25/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Crime of violence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “crime of violence” has the meaning set forth in section 16.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a2e0b1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s25/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minor","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “minor” means a person who has not reached 18 years of age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a2e0b2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s25/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Uses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “uses” means employs, hires, persuades, induces, entices, or coerces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a2e0b3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s25/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who is 18 years of age or older, who intentionally uses a minor to commit a crime of violence for which such person may be prosecuted in a court of the United States, or to assist in avoiding detection or apprehension for such an offense, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a2e0b4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s25/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the first conviction, be subject to twice the maximum term of imprisonment and twice the maximum fine that would otherwise be authorized for the offense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a2e0b5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s25/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each subsequent conviction, be subject to 3 times the maximum term of imprisonment and 3 times the maximum fine that would otherwise be authorized for the offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8a2e0b6-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21/tVI/s601"},"text":"Pub. L. 108–21, title VI, § 601[(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-30"},"text":"Apr. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/686"},"text":"117 Stat. 686","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
