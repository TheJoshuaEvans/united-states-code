{"tag":"section","attrib":{"id":"idb9392cfd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1916"},"text":null,"children":[{"tag":"num","attrib":{"value":"1916"},"text":"§ 1916.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unauthorized employment and disposition of lapsed appropriations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Whoever—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9392cfe-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1916/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" violates the provision of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3103"},"text":"section 3103 of title 5","children":[],"tail":" that an individual may be employed in the civil service in an Executive department at the seat of Government only for services actually rendered in connection with and for the purposes of the appropriation from which he is paid; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9392cff-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1916/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" violates the provision of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5501"},"text":"section 5501 of title 5","children":[],"tail":" that money accruing from lapsed salaries or from unused appropriations for salaries shall be covered into the Treasury of the United States;"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title or imprisoned not more than one year, or both.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9392d00-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s3/d"},"text":"Pub. L. 89–554, § 3(d)","children":[],"