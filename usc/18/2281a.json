{"tag":"section","attrib":{"id":"idb95a70b9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2281a"},"text":"§ 2281a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional offenses against maritime fixed platforms","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb95a70ba-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offenses.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95a70bb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person who unlawfully and intentionally—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95a70bc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" when the purpose of the act, by its nature or context, is to intimidate a population, or to compel a government or an international organization to do or to abstain from doing any act—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb95a70bd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281a/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses against or on a fixed platform or discharges from a fixed platform any explosive or radioactive material, biological, chemical, or nuclear weapon in a manner that causes or is likely to cause death or serious injury or damage; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95a70be-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281a/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discharges from a fixed platform oil, liquefied natural gas, or another hazardous or noxious substance that is not covered by clause (i), in such quantity or concentration that causes or is likely to cause death or serious injury or damage;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95a70bf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" injures or kills any person in connection with the commission or the attempted commission of any of the offenses set forth in subparagraph (A); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95a70c0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attempts or conspires to do anything prohibited under subparagraph (A) or (B),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title, imprisoned not more than 20 years, or both; and if death results to any person from conduct prohibited by this paragraph, shall be imprisoned for any term of years or for life.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95a70c1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Threat to safety","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person who threatens, with apparent determination and will to carry the threat into execution, to do any act prohibited under paragraph (1)(A), shall be fined under this title, imprisoned not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95a70c2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is jurisdiction over the activity prohibited in subsection (a) if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95a70c3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such activity is committed against or on board a fixed platform—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95a70c4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is located on the continental shelf of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95a70c5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is located on the continental shelf of another country, by a national of the United States or by a stateless person whose habitual residence is in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95a70c6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an attempt to compel the United States to do or abstain from doing any act;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95a70c7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the commission of such activity against or on board a fixed platform located on a continental shelf, a national of the United States is seized, threatened, injured, or killed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95a70c8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such activity is committed against or on board a fixed platform located outside the United States and beyond the continental shelf of the United States and the offender is later found in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95a70c9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section does not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95a70ca-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities of armed forces during an armed conflict, as those terms are understood under the law of war, which are governed by that law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95a70cb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities undertaken by military forces of a state in the exercise of their official duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95a70cc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95a70cd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “continental shelf” means the sea-bed and subsoil of the submarine areas that extend beyond a country’s territorial sea to the limits provided by customary international law as reflected in Article 76 of the 1982 Convention on the Law of the Sea; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95a70ce-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2281a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “fixed platform” means an artificial island, installation, or structure permanently attached to the sea-bed for the purpose of exploration or exploitation of resources or for other economic purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb95a70cf-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/tVIII/s804/a"},"text":"Pub. L. 114–23, title VIII, § 804(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-02"},"text":"June 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/307"},"text":"129 Stat. 307","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb95a70d0-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb95a70d1-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idb95a70d2-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2280/d"},"text":"section 2280(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
