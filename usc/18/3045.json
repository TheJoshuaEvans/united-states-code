{"tag":"section","attrib":{"id":"idb98577f3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3045"},"text":null,"children":[{"tag":"num","attrib":{"value":"3045"},"text":"§ 3045.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internal revenue violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Warrants of arrest for violations of internal revenue laws may be issued by United States magistrate judges upon the complaint of a United States attorney, assistant United States attorney, collector, or deputy collector of internal revenue or revenue agent, or private citizen; but no such warrant of arrest shall be issued upon the complaint of a private citizen unless first approved in writing by a United States attorney.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb98577f4-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/816"},"text":"62 Stat. 816","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/578/tIII/s301/a/2"},"text":"Pub. L. 90–578, title III, § 301(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-17"},"text":"Oct. 17, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1115"},"text":"82 Stat. 1115","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/650/tIII/s321"},"text":"Pub. L. 101–650, title III, § 321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5117"},"text":"104 Stat. 5117","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb98577f5-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"histori