{"tag":"section","attrib":{"id":"idb9d67ea1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s6002"},"text":null,"children":[{"tag":"num","attrib":{"value":"6002"},"text":"§ 6002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immunity generally","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Whenever a witness refuses, on the basis of his privilege against self-incrimination, to testify or provide other information in a proceeding before or ancillary to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9d67ea2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s6002/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a court or grand jury of the United States,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9d67ea3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s6002/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agency of the United States, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9d67ea4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s6002/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" either House of Congress, a joint committee of the two Houses, or a committee or a subcommittee of either House,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"and the person presiding over the proceeding communicates to the witness an order issued under this title, the witness may not refuse to comply with the order on the basis of his privilege against self-incrimination; but no testimony or other information compelled under the order (or any information directly or indirectly derived from such testimony or other information) may be used against the witness in any criminal case, except a prosecution for perjury, giving a false statement, or otherwise failing to comply with the order.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9d67ea5-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/452/tII/s201/a"},"text":"Pub. L. 91–452, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-15"},"text":"Oct. 15, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/927"},"text":"84 Stat. 927","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330013/4"},"text":"Pub. L. 103–322, title XXXIII, § 330013(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2146"},"text":"108 Stat. 2146","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9d67ea6-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9d67ea7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9d67ea8-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “under this title” for “under this part” in concluding provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
