{"tag":"section","attrib":{"id":"idb8b13836-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s175a"},"text":null,"children":[{"tag":"num","attrib":{"value":"175a"},"text":"§ 175a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests for military assistance to enforce prohibition in certain emergencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Attorney General may request the Secretary of Defense to provide assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s382"},"text":"section 382 of title 10","children":[],"tail":" "},{"tag":"ref","attrib":{"idref":"fn002024"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002024"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" in support of Department of Justice activities relating to the enforcement of "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s175"},"text":"section 175 of this title","children":[],"tail":" in an emergency situation involving a biological weapon of mass destruction. The authority to make such a request may be exercised by another official of the Department of Justice in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s382/f/2"},"text":"section 382(f)(2) of title 10","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn002024"},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8b13837-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXIV/s1416/c/1/A"},"text":"Pub. L. 104–201, div. A, title XIV, § 1416(c)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2723"},"text":"110 Stat. 2723","children":[],"tail":".)