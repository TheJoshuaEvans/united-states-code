{"tag":"section","attrib":{"id":"idb97e4cf0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2724"},"text":null,"children":[{"tag":"num","attrib":{"value":"2724"},"text":"§ 2724.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil action","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb97e4cf1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2724/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cause of Action","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person who knowingly obtains, discloses or uses personal information, from a motor vehicle record, for a purpose not permitted under this chapter shall be liable to the individual to whom the information pertains, who may bring a civil action in a United States district court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb97e4cf2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2724/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remedies","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The court may award—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb97e4cf3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2724/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actual damages, but not less than liquidated damages in the amount of $2,500;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97e4cf4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2724/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" punitive damages upon proof of willful or reckless disregard of the law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97e4cf5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2724/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable attorneys’ fees and other litigation costs reasonably incurred; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97e4cf6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2724/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other preliminary and equitable relief as the court determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb97e4cf7-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXX/s300002/a"},"text":"Pub. L. 103–322, title XXX, § 300002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2101"},"text":"108 Stat. 2101","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb97e4cf8-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb97e4cf9-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb97e4cfa-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 3 years after ","children":[{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", with provisions relating to release of personal information before the effective date and compliance after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/s300003"},"text":"section 300003 of Pub. L. 103–322","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2721"},"text":"section 2721 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
