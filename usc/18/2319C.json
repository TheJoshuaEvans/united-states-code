{"tag":"section","attrib":{"id":"idb95f5311-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319C"},"text":null,"children":[{"tag":"num","attrib":{"value":"2319C"},"text":"§ 2319C.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Illicit digital transmission services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb95f5312-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319C/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95f5313-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319C/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “audiovisual work”, “computer program”, “copies”, “copyright owner”, “digital transmission”, “financial gain”, “motion picture”, “motion picture exhibition facility”, “perform”, “phonorecords”, “publicly” (with respect to performing a work), “sound recording”, and “transmit” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t17/s101"},"text":"section 101 of title 17","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95f5314-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319C/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “digital transmission service” means a service that has the primary purpose of publicly performing works by digital transmission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95f5315-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319C/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “publicly perform” and “public performance” refer to the exclusive rights of a copyright owner under paragraphs (4) and (6) of section 106 (relating to exclusive rights in copyrighted works) of title 17, as limited by sections 107 through 122 of title 17; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95f5316-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319C/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “work being prepared for commercial public performance” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95f5317-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319C/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a computer program, a musical work, a motion picture or other audiovisual work, or a sound recording, if, at the time of unauthorized public performance—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb95f5318-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319C/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the copyright owner has a reasonable expectation of commercial public performance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95f5319-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319C/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the copies or phonorecords of the work have not been commercially publicly performed in the United States by or with the authorization of the copyright owner; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95f531a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319C/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a motion picture, if, at the time of unauthorized public performance, the motion picture—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb95f531b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319C/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb95f531c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319C/a/4/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been made available for viewing in a motion picture exhibition facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb95f531d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319C/a/4/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not been made available in copies for sale to the general public in the United States by or with the authorization of the copyright owner in a format intended to permit viewing outside a motion picture exhibition facility; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95f531e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319C/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" had not been commercially publicly performed in the United States by or with the authorization of the copyright owner more than 24 hours before the unauthorized public performance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95f531f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319C/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibited Act","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be unlawful for a person to willfully, and for purposes of commercial advantage or private financial gain, offer or provide to the public a digital transmission service that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95f5320-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319C/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is primarily designed or provided for the purpose of publicly performing works protected under title 17 by means of a digital transmission without the authority of the copyright owner or the law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95f5321-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319C/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has no commercially significant purpose or use other than to publicly perform works protected under title 17 by means of a digital transmission without the authority of the copyright owner or the law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95f5322-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319C/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is intentionally marketed by or at the direction of that person to promote its use in publicly performing works protected under title 17 by means of a digital transmission without the authority of the copyright owner or the law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95f5323-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319C/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who violates subsection (b) shall be, in addition to any penalties provided for under title 17 or any other law—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95f5324-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319C/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fined under this title, imprisoned not more than 3 years, or both;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95f5325-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319C/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" fined under this title, imprisoned not more than 5 years, or both, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95f5326-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319C/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense was committed in connection with 1 or more works being prepared for commercial public performance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95f5327-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319C/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person knew or should have known that the work was being prepared for commercial public performance; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95f5328-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319C/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fined under this title, imprisoned not more than 10 years, or both, if the offense is a second or subsequent offense under this section or section 2319(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95f5329-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319C/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95f532a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319C/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affect the interpretation of any other provision of civil copyright law, including the limitations of liability set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t17/s512"},"text":"section 512 of title 17","children":[],"tail":", or principles of secondary liability; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95f532b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319C/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent any Federal or State authority from enforcing cable theft or theft of service laws that are not subject to preemption under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t17/s301"},"text":"section 301 of title 17","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb95f532c-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dQ/tII/s211/a"},"text":"Pub. L. 116–260, div. Q, title II, § 211(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2175"},"text":"134 Stat. 2175","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
