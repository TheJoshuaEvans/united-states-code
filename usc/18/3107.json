{"tag":"section","attrib":{"id":"idb98a3361-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3107"},"text":null,"children":[{"tag":"num","attrib":{"value":"3107"},"text":"§ 3107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of warrants and seizures by Federal Bureau of Investigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director, Associate Director, Assistant to the Director, Assistant Directors, agents, and inspectors of the Federal Bureau of Investigation of the Department of Justice are empowered to make seizures under warrant for violation of the laws of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb98a3362-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/819"},"text":"62 Stat. 819","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1951-01-10/ch1221/s2"},"text":"Jan. 10, 1951, ch. 1221, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/1239"},"text":"64 Stat. 1239","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb98a3363-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb98a3364-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s300a"},"text":"section 300a of title 5","children":[],"tail":", U.S.C., 1940 ed., Executive Departments and Government Officers and Employees ("},{"tag":"ref","attrib":{"href":"/us/act/1934-06-18/ch595"},"text":"June 18, 1934, ch. 595","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1008"},"text":"48 Stat. 1008","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1935-03-22/ch39"},"text":"Mar. 22, 1935, ch. 39","children":[],"tail":", title II, "},{"tag":"ref","attrib":{"href":"/us/stat/49/77"},"text":"49 Stat. 77","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s300a"},"text":"Section 300a of title 5","children":[],"tail":", U.S.C., 1940 ed., Executive Departments and Government Officers and Employees, was used as the basis for this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3052"},"text":"section 3052 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb98a3365-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb98a3366-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1951—Act ","children":[{"tag":"date","attrib":{"date":"1951-01-10"},"text":"Jan. 10, 1951","children":[],"tail":", included within its provisions the Associate Director and the Assistant to the Director."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb98a3367-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idb98a3368-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"ta