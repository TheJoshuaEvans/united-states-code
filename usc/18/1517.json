{"tag":"section","attrib":{"id":"idb9261a5c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1517"},"text":null,"children":[{"tag":"num","attrib":{"value":"1517"},"text":"§ 1517.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obstructing examination of financial institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever corruptly obstructs or attempts to obstruct any examination of a financial institution by an agency of the United States with jurisdiction to conduct an examination of such financial institution shall be fined under this title, imprisoned not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9261a5d-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV/s2503/a"},"text":"Pub. L. 101–647, title XXV, § 2503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4861"},"text":"104 Stat. 4861","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
