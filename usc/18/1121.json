{"tag":"section","attrib":{"id":"idb9155132-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1121"},"text":null,"children":[{"tag":"num","attrib":{"value":"1121"},"text":"§ 1121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Killing persons aiding Federal investigations or State correctional officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9155133-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1121/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whoever intentionally kills—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9155134-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1121/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a State or local official, law enforcement officer, or other officer or employee while working with Federal law enforcement officials in furtherance of a Federal criminal investigation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9155135-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1121/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while the victim is engaged in the performance of official duties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9155136-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1121/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because of the performance of the victim’s official duties; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9155137-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1121/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because of the victim’s status as a public servant; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9155138-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1121/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person assisting a Federal criminal investigation, while that assistance is being rendered and because of it,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be sentenced according to the terms of section 1111, including by sentence of death or by imprisonment for life.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9155139-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1121/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb915513a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1121/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever, in a circumstance described in paragraph (3) of this subsection, while incarcerated, intentionally kills any State correctional officer engaged in, or on account of the performance of such officer’s official duties, shall be sentenced to a term of imprisonment which shall not be less than 20 years, and may be sentenced to life imprisonment or death.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb915513b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1121/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As used in this section, the term, “State correctional officer” includes any officer or employee of any prison, jail, or other detention facility, operated by, or under contract to, either a State or local governmental agency, whose job responsibilities include providing for the custody of incarcerated individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb915513c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1121/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The circumstance referred to in paragraph (1) is that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb915513d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1121/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the correctional officer is engaged in transporting the incarcerated person interstate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb915513e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1121/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the incarcerated person is incarcerated pursuant to a conviction for an offense against the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb915513f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1121/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this section, the term “State” means a State of the United States, the District of Columbia, and any commonwealth, territory, or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9155140-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tVI/s60015/a"},"text":"Pub. L. 103–322, title VI, § 60015(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1974"},"text":"108 Stat. 1974","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s607/k"},"text":"Pub. L. 104–294, title VI, § 607(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3512"},"text":"110 Stat. 3512","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9155141-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9155142-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9155143-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
