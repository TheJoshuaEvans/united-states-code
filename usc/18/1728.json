{"tag":"section","attrib":{"id":"idb92f9071-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1728"},"text":null,"children":[{"tag":"num","attrib":{"value":"1728"},"text":"§ 1728.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Weight of mail increased fraudulently","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever places any matter in the mails during the regular weighing period, for the purpose of increasing the weight of the mail, with intent to cause an increase in the compensation of the railroad mail carrier over whose route such mail may pass, shall be fined under this title or imprisoned not more than five years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb92f9072-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/785"},"text":"62 Stat. 785","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/N"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(N)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2148"},"text":"108 Stat. 2148","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92f9073-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb92f9074-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 358 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s228"},"text":"Mar. 4, 1909, ch. 321, § 228","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1134"},"text":"35 Stat. 1134","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to persons causing or procuring was omitted as unnecessary in view of definition of “principal” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor verbal changes were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92f9075-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92f9076-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $20,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
