{"tag":"section","attrib":{"id":"idb8aa0cde-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s47"},"text":null,"children":[{"tag":"num","attrib":{"value":"47"},"text":"§ 47.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of aircraft or motor vehicles to hunt certain wild horses or burros; pollution of watering holes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8aa0cdf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s47/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever uses an aircraft or a motor vehicle to hunt, for the purpose of capturing or killing, any wild unbranded horse, mare, colt, or burro running at large on any of the public land or ranges shall be fined under this title, or imprisoned not more than six months, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8aa0ce0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s47/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever pollutes or causes the pollution of any watering hole on any of the public land or ranges for the purpose of trapping, killing, wounding, or maiming any of the animals referred to in subsection (a) of this section shall be fined under this title, or imprisoned not more than six months, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8aa0ce1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s47/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in subsection (a) of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8aa0ce2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s47/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “aircraft” means any contrivance used for flight in the air; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8aa0ce3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s47/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “motor vehicle” includes an automobile, automobile truck, automobile wagon, motorcycle, or any other self-propelled vehicle designed for running on land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8aa0ce4-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/234/s1/a"},"text":"Pub. L. 86–234, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-08"},"text":"Sept. 8, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/470"},"text":"73 Stat. 470","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/G"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(G)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8aa0ce5-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8aa0ce6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8aa0ce7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $500”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
