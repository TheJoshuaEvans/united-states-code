{"tag":"section","attrib":{"id":"idb8aec7cc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s152"},"text":null,"children":[{"tag":"num","attrib":{"value":"152"},"text":"§ 152.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concealment of assets; false oaths and claims; bribery","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A person who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8aec7cd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s152/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly and fraudulently conceals from a custodian, trustee, marshal, or other officer of the court charged with the control or custody of property, or, in connection with a case under title 11, from creditors or the United States Trustee, any property belonging to the estate of a debtor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8aec7ce-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s152/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly and fraudulently makes a false oath or account in or in relation to any case under title 11;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8aec7cf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s152/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly and fraudulently makes a false declaration, certificate, verification, or statement under penalty of perjury as permitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1746"},"text":"section 1746 of title 28","children":[],"tail":", in or in relation to any case under title 11;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8aec7d0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s152/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly and fraudulently presents any false claim for proof against the estate of a debtor, or uses any such claim in any case under title 11, in a personal capacity or as or through an agent, proxy, or attorney;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8aec7d1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s152/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly and fraudulently receives any material amount of property from a debtor after the filing of a case under title 11, with intent to defeat the provisions of title 11;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8aec7d2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s152/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly and fraudulently gives, offers, receives, or attempts to obtain any money or property, remuneration, compensation, reward, advantage, or promise thereof for acting or forbearing to act in any case under title 11;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8aec7d3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s152/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a personal capacity or as an agent or officer of any person or corporation, in contemplation of a case under title 11 by or against the person or any other person or corporation, or with intent to defeat the provisions of title 11, knowingly and fraudulently transfers or conceals any of his property or the property of such other person or corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b137d4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s152/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the filing of a case under title 11 or in contemplation thereof, knowingly and fraudulently conceals, destroys, mutilates, falsifies, or makes a false entry in any recorded information (including books, documents, records, and papers) relating to the property or financial affairs of a debtor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b137d5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s152/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the filing of a case under title 11, knowingly and fraudulently withholds from a custodian, trustee, marshal, or other officer of the court or a United States Trustee entitled to its possession, any recorded information (including books, documents, records, and papers) relating to the property or financial affairs of a debtor,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title, imprisoned not more than 5 years, or both.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8b137d6-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/689"},"text":"62 Stat. 689","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/519/s2"},"text":"Pub. L. 86–519, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-06-12"},"text":"June 12, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/217"},"text":"74 Stat. 217","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/701"},"text":"Pub. L. 86–701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-02"},"text":"Sept. 2, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/753"},"text":"74 Stat. 753","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/550/s4"},"text":"Pub. L. 94–550, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-18"},"text":"Oct. 18, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2535"},"text":"90 Stat. 2535","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/tIII/s314/a"},"text":"Pub. L. 95–598, title III, § 314(a)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2676"},"text":"92 Stat. 2676","children":[],"tail":", 2677; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7017"},"text":"Pub. L. 100–690, title VII, § 7017","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4395"},"text":"102 Stat. 4395","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/394/tIII/s312/a/1/A"},"text":"Pub. L. 103–394, title III, § 312(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4138"},"text":"108 Stat. 4138","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s601/a/1"},"text":"Pub. L. 104–294, title VI, § 601(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3497"},"text":"110 Stat. 3497","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8b137d7-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8b137d8-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s52/b"},"text":"section 52(b) of title 11","children":[],"tail":", U.S.C., 1940 ed., Bankruptcy ("},{"tag":"ref","attrib":{"href":"/us/act/1898-07-01/ch541/s29b"},"text":"July 1, 1898, ch. 541, § 29b","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/554"},"text":"30 Stat. 554","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1926-05-27/ch406/s11"},"text":"May 27, 1926, ch. 406, § 11","children":[],"tail":" (part), "},{"tag":"ref","attrib":{"href":"/us/stat/44/665"},"text":"44 Stat. 665","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1938-06-22/ch575/s1"},"text":"June 22, 1938, ch. 575, § 1","children":[],"tail":" (part), "},{"tag":"ref","attrib":{"href":"/us/stat/52/855"},"text":"52 Stat. 855","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was broadened to apply to one who gives or offers a bribe.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8b137d9-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8b137da-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" substituted “fined under this title” for “fined not more than $5,000” in closing provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/394"},"text":"Pub. L. 103–394","children":[],"tail":" amended section generally, designating undesignated pars. as opening provisions, pars. (1) to (9), and closing provisions, and in pars. (1) and (9) inserting reference to United States Trustee."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $5,000” in last par."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" substituted “penalty of perjury” for “penalty or perjury” in third par."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":" substituted, wherever appearing, “debtor” for “bankrupt”, “case under title 11” for “bankruptcy proceeding”, and “provisions of title 11” for “bankruptcy law”; and substituted “a custodian” for “the receiver, custodian”, wherever appearing, and “recorded information, including books, documents, records, and papers, relating to the property or financial affairs” for “document affecting or relating to the property or affairs”, in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/550"},"text":"Pub. L. 94–550","children":[],"tail":" inserted paragraph covering the knowing and fraudulent making of a false declaration, certificate, verification, or statement under penalty of perjury as permitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1746"},"text":"section 1746 of title 28","children":[],"tail":" or in relation to any bankruptcy proceeding."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/701"},"text":"Pub. L. 86–701","children":[],"tail":" included fraudulent transfers and concealment of property by persons in their individual capacity in sixth par."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/86/519"},"text":"Pub. L. 86–519","children":[],"tail":" struck out “under oath” after “knowingly and fraudulently presents” in third par."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8b137db-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8b137dc-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/394"},"text":"Pub. L. 103–394","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", and not applicable with respect to cases commenced under Title 11, Bankruptcy, before "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/394/s702"},"text":"section 702 of Pub. L. 103–394","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of Title 11","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8b137dd-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/s402/a"},"text":"section 402(a) of Pub. L. 95–598","children":[],"tail":", set out as an Effective Date note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of Title 11","children":[],"tail":", Bankruptcy."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idb8b137de-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598/s314"},"text":"section 314 of Pub. L. 95–598","children":[],"tail":" not to affect the application of chapter 9 (§ 151 et seq.), chapter 96 (§ 1961 et seq.), or section 2516, 3057, or 3284 of this title to any act of any person (1) committed before "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", or (2) committed after "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", in connection with a case commenced before such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/s403/d"},"text":"section 403(d) of Pub. L. 95–598","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of Title 11","children":[],"tail":", Bankruptcy."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
