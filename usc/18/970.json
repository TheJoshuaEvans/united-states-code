{"tag":"section","attrib":{"id":"idb8fff52a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s970"},"text":null,"children":[{"tag":"num","attrib":{"value":"970"},"text":"§ 970.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of property occupied by foreign governments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8fff52b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s970/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever willfully injures, damages, or destroys, or attempts to injure, damage, or destroy, any property, real or personal, located within the United States and belonging to or utilized or occupied by any foreign government or international organization, by a foreign official or official guest, shall be fined under this title, or imprisoned not more than five years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fff52c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s970/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whoever, willfully with intent to intimidate, coerce, threaten, or harass—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fff52d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s970/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" forcibly thrusts any part of himself or any object within or upon that portion of any building or premises located within the United States, which portion is used or occupied for official business or for diplomatic, consular, or residential purposes by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8fff52e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s970/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a foreign government, including such use as a mission to an international organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fff52f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s970/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an international organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fff530-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s970/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a foreign official; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fff531-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s970/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an official guest; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fff532-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s970/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" refuses to depart from such portion of such building or premises after a request—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8fff533-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s970/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by an employee of a foreign government or of an international organization, if such employee is authorized to make such request by the senior official of the unit of such government or organization which occupies such portion of such building or premises;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fff534-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s970/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a foreign official or any member of the foreign official’s staff who is authorized by the foreign official to make such request;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fff535-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s970/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by an official guest or any member of the official guest’s staff who is authorized by the official guest to make such request; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fff536-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s970/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by any person present having law enforcement powers;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title or imprisoned not more than six months, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fff537-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s970/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of this section “foreign government”, “foreign official”, “international organization”, and “official guest” shall have the same meanings as those provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1116/b"},"text":"section 1116(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8fff538-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/539/tIV/s401"},"text":"Pub. L. 92–539, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1073"},"text":"86 Stat. 1073","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/467/s7"},"text":"Pub. L. 94–467, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-08"},"text":"Oct. 8, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2000"},"text":"90 Stat. 2000","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/L"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(L)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s601/a/2"},"text":"Pub. L. 104–294, title VI, § 601(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3498"},"text":"110 Stat. 3498","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8fff539-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8fff53a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8fff53b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" substituted “fined under this title” for “fined not more than $500” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $10,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/467"},"text":"Pub. L. 94–467","children":[],"tail":" added subsec. (b), redesignated former subsec. (b) as (c), and struck out reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1116/c"},"text":"section 1116(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
