{"tag":"section","attrib":{"id":"idb94e89ca-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256"},"text":null,"children":[{"tag":"num","attrib":{"value":"2256"},"text":"§ 2256.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions for chapter","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb94e89cb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “minor” means any person under the age of eighteen years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94e89cc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb94e89cd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subparagraph (B), “sexually explicit conduct” means actual or simulated—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb94e89ce-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sexual intercourse, including genital-genital, oral-genital, anal-genital, or oral-anal, whether between persons of the same or opposite sex;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb94e89cf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bestiality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb94e89d0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" masturbation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb94e89d1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sadistic or masochistic abuse; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb94e89d2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lascivious exhibition of the anus, genitals, or pubic area of any person;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb94e89d3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of subsection 8(B) ","children":[{"tag":"ref","attrib":{"idref":"fn002151"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002151"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “(8)(B)”."}],"tail":" of this section, “sexually explicit conduct” means—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb94e89d4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" graphic sexual intercourse, including genital-genital, oral-genital, anal-genital, or oral-anal, whether between persons of the same or opposite sex, or lascivious simulated sexual intercourse where the genitals, breast, or pubic area of any person is exhibited;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb94e89d5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" graphic or lascivious simulated;","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb94e89d6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bestiality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb94e89d7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" masturbation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb94e89d8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/2/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sadistic or masochistic abuse; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb94e89d9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" graphic or simulated lascivious exhibition of the anus, genitals, or pubic area of any person;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94e89da-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “producing” means producing, directing, manufacturing, issuing, publishing, or advertising;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94e89db-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “organization” means a person other than an individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94e89dc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “visual depiction” includes undeveloped film and videotape, data stored on computer disk or by electronic means which is capable of conversion into a visual image, and data which is capable of conversion into a visual image that has been transmitted by any means, whether or not stored in a permanent format;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94e89dd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “computer” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1030"},"text":"section 1030 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94e89de-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “custody or control” includes temporary supervision over or responsibility for a minor whether legally or illegally obtained;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94e89df-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “child pornography” means any visual depiction, including any photograph, film, video, picture, or computer or computer-generated image or picture, whether made or produced by electronic, mechanical, or other means, of sexually explicit conduct, where—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb94e89e0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the production of such visual depiction involves the use of a minor engaging in sexually explicit conduct;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb94e89e1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such visual depiction is a digital image, computer image, or computer-generated image that is, or is indistinguishable from, that of a minor engaging in sexually explicit conduct; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb94e89e2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such visual depiction has been created, adapted, or modified to appear that an identifiable minor is engaging in sexually explicit conduct.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94e89e3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “identifiable minor”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb94e89e4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means a person—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb94e89e5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/9/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb94e89e6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/9/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who was a minor at the time the visual depiction was created, adapted, or modified; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb94e89e7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/9/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose image as a minor was used in creating, adapting, or modifying the visual depiction; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb94e89e8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/9/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is recognizable as an actual person by the person’s face, likeness, or other distinguishing characteristic, such as a unique birthmark or other recognizable feature; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb94e89e9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be construed to require proof of the actual identity of the identifiable minor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94e89ea-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “graphic”, when used with respect to a depiction of sexually explicit conduct, means that a viewer can observe any part of the genitals or pubic area of any depicted person or animal during any part of the time that the sexually explicit conduct is being depicted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94e89eb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2256/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “indistinguishable” used with respect to a depiction, means virtually indistinguishable, in that the depiction is such that an ordinary person viewing the depiction would conclude that the depiction is of an actual minor engaged in sexually explicit conduct. This definition does not apply to depictions that are drawings, cartoons, sculptures, or paintings depicting minors or adults.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb94e89ec-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/225/s2/a"},"text":"Pub. L. 95–225, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-02-06"},"text":"Feb. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/8"},"text":"92 Stat. 8","children":[],"tail":", § 2253; renumbered § 2255 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/292/s5"},"text":"Pub. L. 98–292, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-05-21"},"text":"May 21, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/205"},"text":"98 Stat. 205","children":[],"tail":"; renumbered § 2256, "},{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/b/tVII/s703/a"},"text":"Pub. L. 99–500, § 101(b) [title VII, § 703(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-39"},"text":"100 Stat. 1783–39","children":[],"tail":", 1783–74, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/b/tVII/s703/a"},"text":"Pub. L. 99–591, § 101(b) [title VII, § 703(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-39"},"text":"100 Stat. 3341–39","children":[],"tail":", 3341–74; "},{"tag":"ref","attrib":{"href":"/us/pl/99/628/s4"},"text":"Pub. L. 99–628, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-07"},"text":"Nov. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3510"},"text":"100 Stat. 3510","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII"},"text":"Pub. L. 100–690, title VII","children":[],"tail":", §§ 7511(c), 7512(b), "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4485"},"text":"102 Stat. 4485","children":[],"tail":", 4486; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/a/tI/s121"},"text":"Pub. L. 104–208, div. A, title I, § 101(a) [title I, § 121[2]","children":[],"tail":"], "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009"},"text":"110 Stat. 3009","children":[],"tail":", 3009–26, 3009–27; "},{"tag":"ref","attrib":{"href":"/us/pl/108/21/tV/s502/a"},"text":"Pub. L. 108–21, title V, § 502(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"2003-04-30"},"text":"Apr. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/678"},"text":"117 Stat. 678","children":[],"tail":", 679; "},{"tag":"ref","attrib":{"href":"/us/pl/110/401/tIII/s302"},"text":"Pub. L. 110–401, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4242"},"text":"122 Stat. 4242","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/299/s7/c"},"text":"Pub. L. 115–299, § 7(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-07"},"text":"Dec. 7, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4389"},"text":"132 Stat. 4389","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb94e89ed-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb94e89ee-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb94e89ef-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":" is a corrected version of "},{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb94e89f0-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Par. (2)(A)(v), (B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/299"},"text":"Pub. L. 115–299","children":[],"tail":" substituted “anus, genitals, or” for “genitals or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/401"},"text":"Pub. L. 110–401","children":[],"tail":" struck out “and” before “data stored” and inserted “, and data which is capable of conversion into a visual image that has been transmitted by any means, whether or not stored in a permanent format” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21/s502/b"},"text":"Pub. L. 108–21, § 502(b)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ‘sexually explicit conduct’ means actual or simulated—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) sexual intercourse, including genital-genital, oral-genital, anal-genital, or oral-anal, whether between persons of the same or opposite sex;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) bestiality;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) masturbation;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) sadistic or masochistic abuse; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(E) lascivious exhibition of the genitals or pubic area of any person;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21/s502/a/1"},"text":"Pub. L. 108–21, § 502(a)(1)","children":[],"tail":", amended subpar. (B) generally. Prior to amendment, subpar. (B) read as follows: “such visual depiction is, or appears to be, of a minor engaging in sexually explicit conduct;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21/s502/a/2"},"text":"Pub. L. 108–21, § 502(a)(2)","children":[],"tail":", substituted a period for “; or” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21/s502/a/3"},"text":"Pub. L. 108–21, § 502(a)(3)","children":[],"tail":", struck out subpar. (D) which read as follows: “such visual depiction is advertised, promoted, presented, described, or distributed in such a manner that conveys the impression that the material is or contains a visual depiction of a minor engaging in sexually explicit conduct; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (10), (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21/s502/c"},"text":"Pub. L. 108–21, § 502(c)","children":[],"tail":", added pars. (10) and (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s101/a/tI/s121"},"text":"Pub. L. 104–208, § 101(a) [title I, § 121[2(1)]","children":[],"tail":"], inserted “, and data stored on computer disk or by electronic means which is capable of conversion into a visual image” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (8), (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s101/a/tI/s121"},"text":"Pub. L. 104–208, § 101(a) [title I, § 121[2(2)–(4)]","children":[],"tail":"], added pars. (8) and (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7511/c"},"text":"Pub. L. 100–690, § 7511(c)","children":[],"tail":", added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7512/b"},"text":"Pub. L. 100–690, § 7512(b)","children":[],"tail":", added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2255"},"text":"section 2255 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/628"},"text":"Pub. L. 99–628","children":[],"tail":", which directed that par. (5) be added to "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2255"},"text":"section 2255 of this title","children":[],"tail":", was executed by adding par. (5) to "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2256"},"text":"section 2256 of this title","children":[],"tail":" to reflect the probable intent of Congress and the renumbering of section 2255 as 2256 by "},{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/292/s5/b"},"text":"Pub. L. 98–292, § 5(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2253"},"text":"section 2253 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/292/s5/a/1"},"text":"Pub. L. 98–292, § 5(a)(1)","children":[],"tail":", substituted “eighteen” for “sixteen”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/292/s5/a/2"},"text":"Pub. L. 98–292, § 5(a)(2)","children":[],"tail":", (3), substituted “sadistic or masochistic” for “sado-masochistic” and struck out “(for the purpose of sexual stimulation)” after “abuse”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/292/s5/a/4"},"text":"Pub. L. 98–292, § 5(a)(4)","children":[],"tail":", substituted “lascivious” for “lewd”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/292/s5/a/5"},"text":"Pub. L. 98–292, § 5(a)(5)","children":[],"tail":", struck out “, for pecuniary profit” after “advertising”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/292/s5/a/6"},"text":"Pub. L. 98–292, § 5(a)(6)","children":[],"tail":", substituted “ ‘organization’ means a person other than an individual” for “ ‘visual or print medium’ means any film, photograph, negative, slide, book, magazine, or other visual or print medium”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb950faf1-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb950faf2-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Confirmation of Intent of Congress in Enacting Sections 2252 and 2256 of This Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions declaring and confirming intent of Congress in enacting this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s160003/a"},"text":"section 160003(a) of Pub. L. 103–322","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2252"},"text":"section 2252 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
