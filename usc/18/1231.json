{"tag":"section","attrib":{"id":"idb91a0c6b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1231"},"text":null,"children":[{"tag":"num","attrib":{"value":"1231"},"text":"§ 1231.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation of strikebreakers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever willfully transports in interstate or foreign commerce any person who is employed or is to be employed for the purpose of obstructing or interfering by force or threats with (1) peaceful picketing by employees during any labor controversy affecting wages, hours, or conditions of labor, or (2) the exercise by employees of any of the rights of self-organization or collective bargaining; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever is knowingly transported or travels in interstate or foreign commerce for any of the purposes enumerated in this section—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Shall be fined under this title or imprisoned not more than two years, or both.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section shall not apply to common carriers.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb91a0c6c-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/760"},"text":"62 Stat. 760","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-05-24/ch139/s30"},"text":"May 24, 1949, ch. 139, § 30","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/94"},"text":"63 Stat. 94","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91a0c6d-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb91a0c6e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb91a0c6f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1948 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 407a (","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-24/ch746"},"text":"June 24, 1936, ch. 746","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1899"},"text":"49 Stat. 1899","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1938-06-29/ch813"},"text":"June 29, 1938, ch. 813","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1242"},"text":"52 Stat. 1242","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Language designating offense as felony was omitted in uniformity with definitive ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1"},"text":"section 1 of this title","children":[],"tail":". (See reviser’s note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s550"},"text":"section 550 of this title","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “and shall, upon conviction” were omitted as surplusage since punishment cannot be imposed until a conviction is secured.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to persons aiding, abetting or causing was omitted as such persons are made principals by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology and arrangement, but without change of substance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb91a0c70-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1949 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This section [section 30] corrects a typographical error in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1231"},"text":"section 1231 of title 18","children":[],"tail":", U.S.C."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb91a0c71-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb91a0c72-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $5,000” in third par."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1949—Act ","children":[{"tag":"date","attrib":{"date":"1949-05-24"},"text":"May 24, 1949","children":[],"tail":", substituted “or travels in” for “in or travels” in second par."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
