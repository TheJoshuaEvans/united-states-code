{"tag":"section","attrib":{"id":"idb91a0ce3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1308"},"text":null,"children":[{"tag":"num","attrib":{"value":"1308"},"text":"§ 1308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation of applicability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb91a0ce4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1308/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation of Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Sections 1301, 1302, 1303, 1304, and 1306 shall not apply—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91a0ce5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1308/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a savings promotion raffle conducted by an insured depository institution or an insured credit union; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91a0ce6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1308/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to any activity conducted in connection with any such savings promotion raffle, including, without limitation, to the—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb91a0ce7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1308/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transmission of any advertisement, list of prizes, or other information concerning the savings promotion raffle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91a0ce8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1308/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offering, facilitation, and acceptance of deposits, withdrawals, or other transactions in connection with the savings promotion raffle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91a0ce9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1308/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transmission of any information relating to the savings promotion raffle, including account balance and transaction information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91a0cea-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1308/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deposit or transmission of prizes awarded in the savings promotion raffle as well as notification or publication thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91a0ceb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1308/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91a0cec-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1308/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “insured credit union” shall have the meaning given the term in section 101 of the Federal Credit Union Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1752"},"text":"12 U.S.C. 1752","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91a0ced-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1308/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “insured depository institution” shall have the meaning given the term in section 3 of the Federal Deposit Insurance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"12 U.S.C. 1813","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91a0cee-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1308/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “savings promotion raffle” means a contest in which the sole consideration required for a chance of winning designated prizes is obtained by the deposit of a specified amount of money in a savings account or other savings program, where each ticket or entry has an equal chance of being drawn, such contest being subject to regulations that may from time to time be promulgated by the appropriate prudential regulator (as defined in section 1002 of the Consumer Financial Protection Act of 2010 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5481"},"text":"12 U.S.C. 5481","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb91a0cef-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/251/s4/a"},"text":"Pub. L. 113–251, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2890"},"text":"128 Stat. 2890","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
