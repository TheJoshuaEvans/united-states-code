{"tag":"section","attrib":{"id":"idb90bdb8d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1026"},"text":null,"children":[{"tag":"num","attrib":{"value":"1026"},"text":"§ 1026.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compromise, adjustment, or cancellation of farm indebtedness","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever knowingly makes any false statement for the purpose of influencing in any way the action of the Secretary of Agriculture, or of any person acting under his authority, in connection with any compromise, adjustment, or cancellation of any farm indebtedness as provided by sections 1150, 1150a, and 1150b of Title 12, shall be fined under this title or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb90bdb8e-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/755"},"text":"62 Stat. 755","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb90bdb8f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb90bdb90-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1150c/a"},"text":"section 1150c(a) of title 12","children":[],"tail":", U.S.C., 1940 ed., Banks and Banking ("},{"tag":"ref","attrib":{"href":"/us/act/1944-12-20/ch623/s4/a"},"text":"Dec. 20, 1944, ch. 623, § 4(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/837"},"text":"58 Stat. 837","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “of Agriculture” were inserted after “Secretary” for reasons of identification.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “upon conviction thereof” were omitted as surplusage, since punishment can not be imposed until after conviction.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Other changes were made in phraseology without change of substance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb90bdb91-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb90bdb92-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $1,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
