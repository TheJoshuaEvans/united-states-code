{"tag":"section","attrib":{"id":"idb9344ae2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1839"},"text":null,"children":[{"tag":"num","attrib":{"value":"1839"},"text":"§ 1839.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9344ae3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1839/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “foreign instrumentality” means any agency, bureau, ministry, component, institution, association, or any legal, commercial, or business organization, corporation, firm, or entity that is substantially owned, controlled, sponsored, commanded, managed, or dominated by a foreign government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9344ae4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1839/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “foreign agent” means any officer, employee, proxy, servant, delegate, or representative of a foreign government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9344ae5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1839/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “trade secret” means all forms and types of financial, business, scientific, technical, economic, or engineering information, including patterns, plans, compilations, program devices, formulas, designs, prototypes, methods, techniques, processes, procedures, programs, or codes, whether tangible or intangible, and whether or how stored, compiled, or memorialized physically, electronically, graphically, photographically, or in writing if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9344ae6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1839/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner thereof has taken reasonable measures to keep such information secret; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9344ae7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1839/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information derives independent economic value, actual or potential, from not being generally known to, and not being readily ascertainable through proper means by, another person who can obtain economic value from the disclosure or use of the information;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9344ae8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1839/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “owner”, with respect to a trade secret, means the person or entity in whom or in which rightful legal or equitable title to, or license in, the trade secret is reposed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9344ae9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1839/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “misappropriation” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9344aea-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1839/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquisition of a trade secret of another by a person who knows or has reason to know that the trade secret was acquired by improper means; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9344aeb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1839/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" disclosure or use of a trade secret of another without express or implied consent by a person who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9344aec-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1839/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used improper means to acquire knowledge of the trade secret;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9344aed-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1839/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at the time of disclosure or use, knew or had reason to know that the knowledge of the trade secret was—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb9344aee-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1839/5/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" derived from or through a person who had used improper means to acquire the trade secret;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb9344aef-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1839/5/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquired under circumstances giving rise to a duty to maintain the secrecy of the trade secret or limit the use of the trade secret; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb9344af0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1839/5/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" derived from or through a person who owed a duty to the person seeking relief to maintain the secrecy of the trade secret or limit the use of the trade secret; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9344af1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1839/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" before a material change of the position of the person, knew or had reason to know that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb9344af2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1839/5/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trade secret was a trade secret; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb9344af3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1839/5/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowledge of the trade secret had been acquired by accident or mistake;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9344af4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1839/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “improper means”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9344af5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1839/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes theft, bribery, misrepresentation, breach or inducement of a breach of a duty to maintain secrecy, or espionage through electronic or other means; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9344af6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1839/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include reverse engineering, independent derivation, or any other lawful means of acquisition; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9344af7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1839/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Trademark Act of 1946” means the Act entitled “An Act to provide for the registration and protection of trademarks used in commerce, to carry out the provisions of certain international conventions, and for other purposes ","children":[{"tag":"ref","attrib":{"idref":"fn002124"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002124"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The closing quotation marks probably should follow “purposes” instead of “ ‘Lanham Act’)”."}],"tail":", approved "},{"tag":"date","attrib":{"date":"1946-07-05"},"text":"July 5, 1946","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1051"},"text":"15 U.S.C. 1051","children":[],"tail":" et seq.) (commonly referred to as the ‘Trademark Act of 1946’ or the ‘Lanham Act’)” "},{"tag":"ref","attrib":{"idref":"fn002124"},"text":"1","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9344af8-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294/tI/s101/a"},"text":"Pub. L. 104–294, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3490"},"text":"110 Stat. 3490","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/153/s2/b"},"text":"Pub. L. 114–153, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-05-11"},"text":"May 11, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/380"},"text":"130 Stat. 380","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9344af9-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9344afa-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9344afb-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Trademark Act of 1946, referred to in par. (7), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-07-05/ch540"},"text":"act July 5, 1946, ch. 540","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/427"},"text":"60 Stat. 427","children":[],"tail":", also popularly known as the Lanham Act, which is classified generally to chapter 22 (§ 1051 et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1051"},"text":"section 1051 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9344afc-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Par. (3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/153/s2/b/1/A"},"text":"Pub. L. 114–153, § 2(b)(1)(A)","children":[],"tail":", substituted “another person who can obtain economic value from the disclosure or use of the information” for “the public”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (5) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/153/s2/b/1/B"},"text":"Pub. L. 114–153, § 2(b)(1)(B)","children":[],"tail":"–(3), added pars. (5) to (7)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9344afd-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb9344afe-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/153"},"text":"Pub. L. 114–153","children":[],"tail":" applicable with respect to any misappropriation of a trade secret (as defined in this section) for which any act occurs on or after "},{"tag":"date","attrib":{"date":"2016-05-11"},"text":"May 11, 2016","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/153/s2/e"},"text":"section 2(e) of Pub. L. 114–153","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1833"},"text":"section 1833 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
