{"tag":"section","attrib":{"id":"idb9344b43-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1857"},"text":null,"children":[{"tag":"num","attrib":{"value":"1857"},"text":"§ 1857.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fences destroyed; livestock entering","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever knowingly and unlawfully breaks, opens, or destroys any gate, fence, hedge, or wall inclosing any lands of the United States reserved or purchased for any public use; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever drives any cattle, horses, hogs, or other livestock upon any such lands for the purposes of destroying the grass or trees on said lands, or where they may destroy the said grass or trees; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever knowingly permits his cattle, horses, hogs, or other livestock to enter through any such inclosure upon any such lands of the United States, where such cattle, horses, hogs, or other livestock may or can destroy the grass or trees or other property of the United States on the said lands—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Shall be fined under this title or imprisoned not more than one year, or both.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section shall not apply to unreserved public lands.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9344b44-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/788"},"text":"62 Stat. 788","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/G"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(G)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9344b45-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9344b46-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 111 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s56"},"text":"Mar. 4, 1909, ch. 321, § 56","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1099"},"text":"35 Stat. 1099","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9344b47-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9344b48-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $500” in fourth par."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
