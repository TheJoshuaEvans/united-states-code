{"tag":"section","attrib":{"id":"idb8e0d439-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s792"},"text":null,"children":[{"tag":"num","attrib":{"value":"792"},"text":"§ 792.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Harboring or concealing persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever harbors or conceals any person who he knows, or has reasonable grounds to believe or suspect, has committed, or is about to commit, an offense under sections 793 or 794 of this title, shall be fined under this title or imprisoned not more than ten years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8e0d43a-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/736"},"text":"62 Stat. 736","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/L"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(L)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8e0d43b-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8e0d43c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s35"},"text":"section 35 of title 50","children":[],"tail":", U.S.C., 1940 ed., War and National Defense ("},{"tag":"ref","attrib":{"href":"/us/act/1917-06-15/ch30"},"text":"June 15, 1917, ch. 30","children":[],"tail":", title I, § 5, "},{"tag":"ref","attrib":{"href":"/us/stat/40/219"},"text":"40 Stat. 219","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1940-03-28/ch72/s2"},"text":"Mar. 28, 1940, ch. 72, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/79"},"text":"54 Stat. 79","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar harboring and concealing language was added to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2388"},"text":"section 2388 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Mandatory punishment provision was rephrased in the alternative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8e0d43d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8e0d43e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $10,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8e0d43f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8e0d440-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Indictment for Violating This Section and Sections 793, 794; Limitation Period","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-23/ch1024/s19"},"text":"Act Sept. 23, 1950, ch. 1024, § 19","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/1005"},"text":"64 Stat. 1005","children":[],"tail":", provided that an indictment for any violation of this section and sections 793 and 794 of this title, other than a violation constituting a capital offense, may be found at any time within ten years next after such violation shall have been committed, but that such section 19 shall not authorize prosecution, trial, or punishment for any offense “now” barred by the provisions of existing law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
