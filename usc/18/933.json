{"tag":"section","attrib":{"id":"idb8fd8372-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s933"},"text":null,"children":[{"tag":"num","attrib":{"value":"933"},"text":"§ 933.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trafficking in firearms","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8fd8373-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s933/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be unlawful for any person to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fd8374-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s933/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ship, transport, transfer, cause to be transported, or otherwise dispose of any firearm to another person in or otherwise affecting interstate or foreign commerce, if such person knows or has reasonable cause to believe that the use, carrying, or possession of a firearm by the recipient would constitute a felony (as defined in section 932(a));","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fd8375-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s933/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive from another person any firearm in or otherwise affecting interstate or foreign commerce, if the recipient knows or has reasonable cause to believe that such receipt would constitute a felony; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fd8376-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s933/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attempt or conspire to commit the conduct described in paragraph (1) or (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fd8377-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s933/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person who violates subsection (a) shall be fined under this title, imprisoned for not more than 15 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8fd8378-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/159/dA/tII/s12004/a/1"},"text":"Pub. L. 117–159, div. A, title II, § 12004(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-06-25"},"text":"June 25, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1327"},"text":"136 Stat. 1327","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8fd8379-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8fd837a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8fd837b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/159/s12004/a/1"},"text":"section 12004(a)(1) of Pub. L. 117–159","children":[],"tail":", which enacted this section, to be construed to allow the establishment of a Federal system of registration of firearms, firearms owners, or firearms transactions or dispositions, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/159/s12004/k"},"text":"section 12004(k) of Pub. L. 117–159","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s922"},"text":"section 922 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
