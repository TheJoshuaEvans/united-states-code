{"tag":"section","attrib":{"id":"idb9c8272c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4104"},"text":null,"children":[{"tag":"num","attrib":{"value":"4104"},"text":"§ 4104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of offenders on probation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9c8272d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prior to consenting to the transfer to the United States of an offender who is on probation, the Attorney General shall determine that the appropriate United States district court is willing to undertake the supervision of the offender.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c8272e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon the receipt of an offender on probation from the authorities of a foreign country, the Attorney General shall cause the offender to be brought before the United States district court which is to exercise supervision over the offender.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c8272f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The court shall place the offender under supervision of the probation officer of the court. The offender shall be supervised by a probation officer, under such conditions as are deemed appropriate by the court as though probation had been imposed by the United States district court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c82730-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The probation may be revoked in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3565"},"text":"section 3565 of this title","children":[],"tail":" and the applicable provisions of the Federal Rules of Criminal Procedure. A violation of the conditions of probation shall constitute grounds for revocation. If probation is revoked the suspended sentence imposed by the sentencing court shall be executed."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c82731-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4104/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of sections 4105 and 4106 of this title shall be applicable following a revocation of probation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c82732-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4104/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prior to consenting to the transfer from the United States of an offender who is on probation, the Attorney General shall obtain the assent of the court exercising jurisdiction over the probationer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9c82733-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/144/s1"},"text":"Pub. L. 95–144, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-28"},"text":"Oct. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1215"},"text":"91 Stat. 1215","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dB/tIV/s4002/e/6"},"text":"Pub. L. 107–273, div. B, title IV, § 4002(e)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1810"},"text":"116 Stat. 1810","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9c82734-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9c82735-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9c82736-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3565"},"text":"section 3565 of this title","children":[],"tail":" and the applicable provisions of” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3653"},"text":"section 3653 of this title","children":[],"tail":" and rule 32(f) of”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
