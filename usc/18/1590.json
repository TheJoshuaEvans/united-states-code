{"tag":"section","attrib":{"id":"idb9286411-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1590"},"text":null,"children":[{"tag":"num","attrib":{"value":"1590"},"text":"§ 1590.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trafficking with respect to peonage, slavery, involuntary servitude, or forced labor","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9286412-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1590/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever knowingly recruits, harbors, transports, provides, or obtains by any means, any person for labor or services in violation of this chapter shall be fined under this title or imprisoned not more than 20 years, or both. If death results from the violation of this section, or if the violation includes kidnapping or an attempt to kidnap, aggravated sexual abuse, or the attempt to commit aggravated sexual abuse, or an attempt to kill, the defendant shall be fined under this title or imprisoned for any term of years or life, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9286413-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1590/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever obstructs, attempts to obstruct, or in any way interferes with or prevents the enforcement of this section, shall be subject to the penalties under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9286414-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386/dA/s112/a/2"},"text":"Pub. L. 106–386, div. A, § 112(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1487"},"text":"114 Stat. 1487","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/457/tII/s222/b/4"},"text":"Pub. L. 110–457, title II, § 222(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-12-23"},"text":"Dec. 23, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/5069"},"text":"122 Stat. 5069","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9286415-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9286416-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9286417-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/457"},"text":"Pub. L. 110–457","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
