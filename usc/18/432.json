{"tag":"section","attrib":{"id":"idb8c905fe-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s432"},"text":null,"children":[{"tag":"num","attrib":{"value":"432"},"text":"§ 432.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officer or employee contracting with Member of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being an officer or employee of the United States, on behalf of the United States or any agency thereof, directly or indirectly makes or enters into any contract, bargain, or agreement, with any Member of or Delegate to Congress, or any Resident Commissioner, either before or after he has qualified, shall be fined under this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8c905ff-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/702"},"text":"62 Stat. 702","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/J"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(J)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c90600-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8c90601-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 205 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s115"},"text":"Mar. 4, 1909, ch. 321, § 115","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1109"},"text":"35 Stat. 1109","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “agency” and “employee” were inserted to eliminate any ambiguity as to scope of section. (See definition of agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s6"},"text":"section 6 of this title","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8c90602-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8c90603-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $3,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
