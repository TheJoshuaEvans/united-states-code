{"tag":"section","attrib":{"id":"idb8b863fe-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s204"},"text":null,"children":[{"tag":"num","attrib":{"value":"204"},"text":"§ 204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Practice in United States Court of Federal Claims or the United States Court of Appeals for the Federal Circuit by Members of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being a Member of Congress or Member of Congress Elect, practices in the United States Court of Federal Claims or the United States Court of Appeals for the Federal Circuit shall be subject to the penalties set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s216"},"text":"section 216 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8b863ff-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/849/s1/a"},"text":"Pub. L. 87–849, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-23"},"text":"Oct. 23, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1122"},"text":"76 Stat. 1122","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/405/tII/s204/d/2"},"text":"Pub. L. 91–405, title II, § 204(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-09-22"},"text":"Sept. 22, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/853"},"text":"84 Stat. 853","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s147"},"text":"Pub. L. 97–164, title I, § 147","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/45"},"text":"96 Stat. 45","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/194/tIV/s403"},"te