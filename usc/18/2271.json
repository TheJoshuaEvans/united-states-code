{"tag":"section","attrib":{"id":"idb95826f3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2271"},"text":null,"children":[{"tag":"num","attrib":{"value":"2271"},"text":"§ 2271.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conspiracy to destroy vessels","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, on the high seas, or within the United States, willfully and corruptly conspires, combines, and confederates with any other person, such other person being either within or without the United States, to cast away or otherwise destroy any vessel, with intent to injure any person that may have underwritten or may thereafter underwrite any policy of insurance thereon or on goods on board thereof, or with intent to injure any person that has lent or advanced, or may lend or advance, any money on such vessel on bottomry or respondentia; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever, within the United States, builds, or fits out any vessel to be cast away or destroyed, with like intent—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Shall be fined under this title or imprisoned not more than ten years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb95826f4-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/803"},"text":"62 Stat. 803","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/L"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(L)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb95826f5-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb95826f6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 487 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s296"},"text":"Mar. 4, 1909, ch. 321, § 296","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1146"},"text":"35 Stat. 1146","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Mandatory punishment provision was rephrased in the alternative.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to a person who “aids in building or fitting out any vessel” was omitted as unnecessary in view of section 2 making all aiders guilty as principal.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb95826f7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb95826f8-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $10,000” in last par."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
