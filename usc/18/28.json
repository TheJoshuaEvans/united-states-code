{"tag":"section","attrib":{"id":"idb8a2e0bb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s28"},"text":null,"children":[{"tag":"num","attrib":{"value":"28"},"text":"§ 28.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Human trafficking defense","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8a2e0bc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s28/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a2e0bd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s28/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “covered Federal offense” means a level A offense or level B offense, as those terms are defined in section 3771A; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a2e0be-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s28/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “victim of trafficking” has the meaning given the term in section 103 of the Trafficking Victims Protection Act of 2000 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102"},"text":"22 U.S.C. 7102","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a2e0bf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s28/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In a prosecution for a covered Federal offense, a defendant may establish duress by demonstrating that the defendant was a victim of trafficking at the time at which the defendant committed the offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a2e0c0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s28/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Record or Proceeding Under Seal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In any proceeding in which a defense under subsection (b) is raised, any record or part of the proceeding related to the defense shall, on motion, be placed under seal until such time as a conviction is entered for the offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a2e0c1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s28/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Post-Conviction Relief","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A failure to assert, or failed assertion of, a defense under subsection (b) by an individual who is convicted of a covered Federal offense may not preclude the individual from asserting as a mitigating factor, at sentencing or in a proceeding for any post-conviction relief, that at the time of the commission of the offense, the defendant was a victim of trafficking and committed the offense under duress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a2e0c2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s28/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Aid","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A failure to assert, or failed assertion of, a defense under subsection (b) by an individual who is convicted of a covered Federal offense may not be used for the purpose of disqualifying the individual from participating in any federally funded program that aids victims of trafficking.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8a2e0c3-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/73/s6/a"},"text":"Pub. L. 119–73, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-01-23"},"text":"Jan. 23, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/2009"},"text":"139 Stat. 2009","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8a2e0c4-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8a2e0c5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8a2e0c6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/73/s8"},"text":"Pub. L. 119–73, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-01-23"},"text":"Jan. 23, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/2010"},"text":"139 Stat. 2010","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/73/s8"},"text":"“Nothing in this Act [see Short Title of 2026 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1"},"text":"section 1 of this title","children":[],"tail":"], or the amendments made by this Act, may be construed to conflict with any of the crime victims’ rights described in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3771"},"text":"section 3771 of title 18","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
