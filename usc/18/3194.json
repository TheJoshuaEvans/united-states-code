{"tag":"section","attrib":{"id":"idb9961a7e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3194"},"text":null,"children":[{"tag":"num","attrib":{"value":"3194"},"text":"§ 3194.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation of fugitive by receiving agent","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any agent appointed as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3182"},"text":"section 3182 of this title","children":[],"tail":" who receives the fugitive into his custody is empowered to transport him to the State or Territory from which he has fled."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9961a7f-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/825"},"text":"62 Stat. 825","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9961a80-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9961a81-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 663 (R.S. § 5279).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Last sentence of said section 663, relating to rescue of such fugitive, was omitted as covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s752"},"text":"section 752 of this title","children":[],"tail":", the punishment provision of which is based on later statutes. (See reviser’s note under that section.)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
