{"tag":"section","attrib":{"id":"idb9a92d1d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3565"},"text":null,"children":[{"tag":"num","attrib":{"value":"3565"},"text":"§ 3565.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation of probation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9a92d1e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3565/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuation or Revocation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the defendant violates a condition of probation at any time prior to the expiration or termination of the term of probation, the court may, after a hearing pursuant to Rule 32.1 of the Federal Rules of Criminal Procedure, and after considering the factors set forth in section 3553(a) to the extent that they are applicable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9a92d1f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3565/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue him on probation, with or without extending the term or modifying or enlarging the conditions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a92d20-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3565/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revoke the sentence of probation and resentence the defendant under subchapter A.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9a92d21-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3565/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mandatory Revocation for Possession of Controlled Substance or Firearm or Refusal To Comply With Drug Testing","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the defendant—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9a92d22-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3565/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" possesses a controlled substance in violation of the condition set forth in section 3563(a)(3);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a92d23-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3565/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" possesses a firearm, as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s921"},"text":"section 921 of this title","children":[],"tail":", in violation of Federal law, or otherwise violates a condition of probation prohibiting the defendant from possessing a firearm;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a92d24-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3565/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refuses to comply with drug testing, thereby violating the condition imposed by section 3563(a)(4); ","children":[{"tag":"ref","attrib":{"idref":"fn002250"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002250"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a92d25-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3565/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a part of drug testing, tests positive for illegal controlled substances more than 3 times over the course of 1 year;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the court shall revoke the sentence of probation and resentence the defendant under subchapter A to a sentence that includes a term of imprisonment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9a92d26-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3565/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delayed Revocation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The power of the court to revoke a sentence of probation for violation of a condition of probation, and to impose another sentence, extends beyond the expiration of the term of probation for any period reasonably necessary for the adjudication of matters arising before its expiration if, prior to its expiration, a warrant or summons has been issued on the basis of an allegation of such a violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9a92d27-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s212/a/2"},"text":"Pub. L. 98–473, title II, § 212(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1995"},"text":"98 Stat. 1995","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI/s6214"},"text":"Pub. L. 100–690, title VI, § 6214","children":[],"tail":", title VII, § 7303(a)(2), "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4361"},"text":"102 Stat. 4361","children":[],"tail":", 4464; "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXV/s3585"},"text":"Pub. L. 101–647, title XXXV, § 3585","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4930"},"text":"104 Stat. 4930","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXI/s110506"},"text":"Pub. L. 103–322, title XI, § 110506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2017"},"text":"108 Stat. 2017","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dB/tII/s2103/a"},"text":"Pub. L. 107–273, div. B, title II, § 2103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1793"},"text":"116 Stat. 1793","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9a92d28-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9a92d29-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9a92d2a-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Criminal Procedure, referred to in subsec. (a), are set out in the Appendix to this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3563(a)(4), referred to in subsec. (b)(3), probably means the par. (4) of section 3563(a) added by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s20414/b/3"},"text":"section 20414(b)(3) of Pub. L. 103–322","children":[],"tail":", which was renumbered par. (5) by "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tII/s203/1/C"},"text":"Pub. L. 104–132, title II, § 203(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1227"},"text":"110 Stat. 1227","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb9a92d2b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For a prior section 3565, applicable to offenses committed prior to ","children":[{"tag":"date","attrib":{"date":"1987-11-01"},"text":"Nov. 1, 1987","children":[],"tail":", see note set out preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3551"},"text":"section 3551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9a92d2c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s110506/a/2"},"text":"Pub. L. 103–322, § 110506(a)(2)","children":[],"tail":", struck out concluding sentence which read as follows: “Notwithstanding any other provision of this section, if a defendant is found by the court to be in possession of a controlled substance, thereby violating the condition imposed by section 3563(a)(3), the court shall revoke the sentence of probation and sentence the defendant to not less than one-third of the original sentence.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s110506/a/1"},"text":"Pub. L. 103–322, § 110506(a)(1)","children":[],"tail":", substituted “resentence the defendant under subchapter A” for “impose any other sentence that was available under subchapter A at the time of the initial sentencing”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s110506/b"},"text":"Pub. L. 103–322, § 110506(b)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Mandatory Revocation for Possession of a Firearm","children":[],"tail":".—If the defendant is in actual possession of a firearm, as that term is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s921"},"text":"section 921 of this title","children":[],"tail":", at any time prior to the expiration or termination of the term of probation, the court shall, after a hearing pursuant to Rule 32.1 of the Federal Rules of Criminal Procedure, revoke the sentence of probation and impose any other sentence that was available under subchapter A at the time of the initial sentencing.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":" substituted “or modifying” for “of modifying”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7303/a/2"},"text":"Pub. L. 100–690, § 7303(a)(2)","children":[],"tail":", inserted at end “Notwithstanding any other provision of this section, if a defendant is found by the court to be in possession of a controlled substance, thereby violating the condition imposed by section 3563(a)(3), the court shall revoke the sentence of probation and sentence the defendant to not less than one-third of the original sentence.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s6214"},"text":"Pub. L. 100–690, § 6214","children":[],"tail":", added subsec. (b) and redesignated former subsec. (b) as (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9a92d2d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb9a92d2e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7303/a/2"},"text":"section 7303(a)(2) of Pub. L. 100–690","children":[],"tail":" applicable with respect to persons whose probation, supervised release, or parole begins after "},{"tag":"date","attrib":{"date":"1988-12-31"},"text":"Dec. 31, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7303/d"},"text":"section 7303(d) of Pub. L. 100–690","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3563"},"text":"section 3563 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9a92d2f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1987-11-01"},"text":"Nov. 1, 1987","children":[],"tail":", and applicable only to offenses committed after the taking effect of this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/s235/a/1"},"text":"section 235(a)(1) of Pub. L. 98–473","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3551"},"text":"section 3551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
