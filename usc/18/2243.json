{"tag":"section","attrib":{"id":"idb9475e99-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2243"},"text":null,"children":[{"tag":"num","attrib":{"value":"2243"},"text":"§ 2243.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sexual abuse of a minor, a ward, or an individual in Federal custody","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9475e9a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2243/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Of a Minor","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever, in the special maritime and territorial jurisdiction of the United States or in a Federal prison, or in any prison, institution, or facility in which persons are held in custody by direction of or pursuant to a contract or agreement with the head of any Federal department or agency, knowingly engages in a sexual act with another person who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9475e9b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2243/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has attained the age of 12 years but has not attained the age of 16 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9475e9c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2243/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is at least four years younger than the person so engaging;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"or attempts to do so, shall be fined under this title, imprisoned not more than 15 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9475e9d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2243/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Of a Ward","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever, in the special maritime and territorial jurisdiction of the United States or in a Federal prison, or in any prison, institution, or facility in which persons are held in custody by direction of or pursuant to a contract or agreement with the head of any Federal department or agency, knowingly engages in a sexual act with another person who is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9475e9e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2243/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in official detention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9475e9f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2243/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the custodial, supervisory, or disciplinary authority of the person so engaging;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"or attempts to do so, shall be fined under this title, imprisoned not more than 15 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9475ea0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2243/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Of an Individual in Federal Custody","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever, while acting in their capacity as a Federal law enforcement officer, knowingly engages in a sexual act with an individual who is under arrest, under supervision, in detention, or in Federal custody, shall be fined under this title, imprisoned not more than 15 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9475ea1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2243/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In a prosecution under subsection (a) of this section, it is a defense, which the defendant must establish by a preponderance of the evidence, that the defendant reasonably believed that the other person had attained the age of 16 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9475ea2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2243/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State of Mind Proof Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In a prosecution under subsection (a) of this section, the Government need not prove that the defendant knew—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9475ea3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2243/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the age of the other person engaging in the sexual act; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb949cea4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2243/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the requisite age difference existed between the persons so engaging.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb949cea5-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646/s87/b"},"text":"Pub. L. 99–646, § 87(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3621"},"text":"100 Stat. 3621","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/99/654/s2"},"text":"Pub. L. 99–654, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3661"},"text":"100 Stat. 3661","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tIII/s322"},"text":"Pub. L. 101–647, title III, § 322","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4818"},"text":"104 Stat. 4818","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/a/tI/s121"},"text":"Pub. L. 104–208, div. A, title I, § 101(a) [title I, § 121[7(c)]","children":[],"tail":"], "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009"},"text":"110 Stat. 3009","children":[],"tail":", 3009–26, 3009–31; "},{"tag":"ref","attrib":{"href":"/us/pl/105/314/tIII/s301/b"},"text":"Pub. L. 105–314, title III, § 301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2979"},"text":"112 Stat. 2979","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1177/a/4"},"text":"Pub. L. 109–162, title XI, § 1177(a)(4)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3125"},"text":"119 Stat. 3125","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/248/tII/s207"},"text":"Pub. L. 109–248, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/615"},"text":"120 Stat. 615","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dE/tV/s554"},"text":"Pub. L. 110–161, div. E, title V, § 554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2082"},"text":"121 Stat. 2082","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tXII/s1202/c/1"},"text":"Pub. L. 117–103, div. W, title XII, § 1202(c)(1)","children":[],"tail":", title XIII, § 1312, "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/924"},"text":"136 Stat. 924","children":[],"tail":", 935.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb949cea6-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb949cea7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb949cea8-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646"},"text":"Pub. L. 99–646","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/99/654"},"text":"Pub. L. 99–654","children":[],"tail":" added identical sections 2243."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb949cea9-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s1202/c/1/A"},"text":"Pub. L. 117–103, § 1202(c)(1)(A)","children":[],"tail":", substituted “Sexual abuse of a minor, a ward, or an individual in Federal custody” for “Sexual abuse of a minor or ward” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s1202/c/1/C"},"text":"Pub. L. 117–103, § 1202(c)(1)(C)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s1312"},"text":"Pub. L. 117–103, § 1312","children":[],"tail":", struck out par. (1) designation before “In a prosecution” and struck out par. (2) which read as follows: “In a prosecution under this section, it is a defense, which the defendant must establish by a preponderance of the evidence, that the persons engaging in the sexual act were at that time married to each other.” Amendment was directed to subsec. (c) but executed to subsec. (d) to reflect the probable intent of Congress and the intervening redesignation of subsec. (c) as (d) by "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/s1202/c/1/B"},"text":"Pub. L. 117–103, § 1202(c)(1)(B)","children":[],"tail":". See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s1202/c/1/B"},"text":"Pub. L. 117–103, § 1202(c)(1)(B)","children":[],"tail":", redesignated subsec. (c) as (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s1202/c/1/B"},"text":"Pub. L. 117–103, § 1202(c)(1)(B)","children":[],"tail":", redesignated subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161"},"text":"Pub. L. 110–161","children":[],"tail":" substituted “the head of any Federal department or agency” for “the Attorney General” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/s207/2"},"text":"Pub. L. 109–248, § 207(2)","children":[],"tail":", inserted comma after “Attorney General” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/s1177/a/4"},"text":"Pub. L. 109–162, § 1177(a)(4)","children":[],"tail":", inserted “or in any prison, institution, or facility in which persons are held in custody by direction of or pursuant to a contract or agreement with the Attorney General” after “in a Federal prison,” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248"},"text":"Pub. L. 109–248","children":[],"tail":" inserted comma after “Attorney General” in introductory provisions and substituted “15 years” for “five years” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/s1177/a/4"},"text":"Pub. L. 109–162, § 1177(a)(4)","children":[],"tail":", (b)(1), inserted “or in any prison, institution, or facility in which persons are held in custody by direction of or pursuant to a contract or agreement with the Attorney General” after “in a Federal prison,” in introductory provisions and substituted “five years” for “one year” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/314"},"text":"Pub. L. 105–314","children":[],"tail":" struck out “crosses a State line with intent to engage in a sexual act with a person who has not attained the age of 12 years, or” after “Whoever” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" inserted “crosses a State line with intent to engage in a sexual act with a person who has not attained the age of 12 years, or” after “Whoever” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":" substituted “15 years” for “five years” in concluding provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb949ceaa-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb949ceab-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":" not effective until Oct. 1 of the first fiscal year beginning after "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s4/a"},"text":"section 4(a) of div. W of Pub. L. 117–103","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6851"},"text":"section 6851 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
