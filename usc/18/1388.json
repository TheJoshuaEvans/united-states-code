{"tag":"section","attrib":{"id":"idb91eee12-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388"},"text":null,"children":[{"tag":"num","attrib":{"value":"1388"},"text":"§ 1388.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on disruptions of funerals of members or former members of the Armed Forces","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb91eee13-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For any funeral of a member or former member of the Armed Forces that is not located at a cemetery under the control of the National Cemetery Administration or part of Arlington National Cemetery, it shall be unlawful for any person to engage in an activity during the period beginning 120 minutes before and ending 120 minutes after such funeral, any part of which activity—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91eee14-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb91eee15-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" takes place within the boundaries of the location of such funeral or takes place within 300 feet of the point of the intersection between—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb91eee16-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the boundary of the location of such funeral; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb91eee17-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a road, pathway, or other route of ingress to or egress from the location of such funeral; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91eee18-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes any individual willfully making or assisting in the making of any noise or diversion—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb91eee19-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is not part of such funeral and that disturbs or tends to disturb the peace or good order of such funeral; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb91eee1a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the intent of disturbing the peace or good order of such funeral;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91eee1b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb91eee1c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is within 500 feet of the boundary of the location of such funeral; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91eee1d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes any individual—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb91eee1e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully and without proper authorization impeding or tending to impede the access to or egress from such location; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb91eee1f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the intent to impede the access to or egress from such location; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91eee20-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is on or near the boundary of the residence, home, or domicile of any surviving member of the deceased person’s immediate family and includes any individual willfully making or assisting in the making of any noise or diversion—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb91eee21-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that disturbs or tends to disturb the peace of the persons located at such location; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91eee22-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the intent of disturbing such peace.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91eee23-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person who violates subsection (a) shall be fined under this title or imprisoned for not more than 1 year, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91eee24-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Remedies.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91eee25-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"District courts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The district courts of the United States shall have jurisdiction—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb91eee26-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent and restrain violations of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91eee27-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the adjudication of any claims for relief under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91eee28-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Attorney general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Attorney General may institute proceedings under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91eee29-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Claims","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person, including a surviving member of the deceased person’s immediate family, who suffers injury as a result of conduct that violates this section may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb91eee2a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sue therefor in any appropriate United States district court or in any court of competent jurisdiction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91eee2b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recover damages as provided in subsection (d) and the cost of the suit, including reasonable attorneys’ fees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91eee2c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Estoppel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A final judgment or decree rendered in favor of the United States in any criminal proceeding brought by the United States under this section shall estop the defendant from denying the essential allegations of the criminal offense in any subsequent civil proceeding brought by a person or by the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91eee2d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actual and Statutory Damages.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91eee2e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to any penalty imposed under subsection (b), a violator of this section is liable in an action under subsection (c) for actual or statutory damages as provided in this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91eee2f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions by private persons","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person bringing an action under subsection (c)(3) may elect, at any time before final judgment is rendered, to recover the actual damages suffered by him or her as a result of the violation or, instead of actual damages, an award of statutory damages for each violation involved in the action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91eee30-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions by attorney general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In any action under subsection (c)(2), the Attorney General is entitled to recover an award of statutory damages for each violation involved in the action notwithstanding any recovery under subsection (c)(3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91eee31-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statutory damages","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A court may award, as the court considers just, statutory damages in a sum of not less than $25,000 or more than $50,000 per violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91eee32-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rebuttable Presumption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It shall be a rebuttable presumption that the violation was committed willfully for purposes of determining relief under this section if the violator, or a person acting in concert with the violator, did not have reasonable grounds to believe, either from the attention or publicity sought by the violator or other circumstance, that the conduct of such violator or person would not disturb or tend to disturb the peace or good order of such funeral, impede or tend to impede the access to or egress from such funeral, or disturb or tend to disturb the peace of any surviving member of the deceased person’s immediate family who may be found on or near the residence, home, or domicile of the deceased person’s immediate family on the date of the service or ceremony.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91eee33-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91eee34-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Armed Forces” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of title 10","children":[],"tail":" and includes members and former members of the National Guard who were employed in the service of the United States; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91eee35-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1388/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “immediate family” means, with respect to a person, the immediate family members of such person, as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s115"},"text":"section 115 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb91eee36-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/464/s1/a"},"text":"Pub. L. 109–464, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3480"},"text":"120 Stat. 3480","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/154/tVI/s601/b"},"text":"Pub. L. 112–154, title VI, § 601(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1196"},"text":"126 Stat. 1196","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91eee37-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb91eee38-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb91eee39-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154"},"text":"Pub. L. 112–154","children":[],"tail":" amended section generally. Prior to amendment, section prohibited disruptions of funerals of members or former members of the Armed Forces during period beginning 60 minutes before and ending 60 minutes after such funerals within funeral boundaries, within 150 feet of certain intersections or within 300 feet of funeral boundaries and provided criminal penalties and definitions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb91eee3a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb91eee3b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purpose and Authority","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154/tVI/s601/a"},"text":"Pub. L. 112–154, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1195"},"text":"126 Stat. 1195","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/154/tVI/s601/a"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purpose of this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2413"},"text":"section 2413 of Title 38","children":[],"tail":", Veterans’ Benefits] is to provide necessary and proper support for the recruitment and retention of the Armed Forces and militia employed in the service of the United States by protecting the dignity of the service of the members of such Forces and militia, and by protecting the privacy of their immediate family members and other attendees during funeral services for such members."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Constitutional authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Congress finds that this section is a necessary and proper exercise of its powers under the Constitution, article I, section 8, paragraphs 1, 12, 13, 14, 16, and 18, to provide for the common defense, raise and support armies, provide and maintain a navy, make rules for the government and regulation of the land and naval forces, and provide for organizing and governing such part of the militia as may be employed in the service of the United States.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
