{"tag":"section","attrib":{"id":"idb9c36b97-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4007"},"text":null,"children":[{"tag":"num","attrib":{"value":"4007"},"text":"§ 4007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses of prisoners","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The expenses attendant upon the confinement of persons arrested or committed under the laws of the United States, as well as upon the execution of any sentence of a court thereof respecting them, shall be paid out of the Treasury of the United States in the manner provided by law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9c36b98-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/848"},"text":"62 Stat. 848","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9c36b99-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9c36b9a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 701 (R.S. § 5536).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provision authorizing expenses for transportation was omitted as covered by similar provision in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s4008"},"text":"section 4008 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes of phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9c36b9b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb9c36b9c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Payment of Costs of Incarceration by Federal Prisoners","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7301"},"text":"Pub. L. 100–690, title VII, § 7301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4463"},"text":"102 Stat. 4463","children":[],"tail":", provided that not later than 1 year after "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", the United States Sentencing Commission would study the feasibility of requiring prisoners incarcerated in Federal correctional institutions to pay some or all of the costs incident to the prisoner’s confinement, including, but not limited to, the costs of food, housing, and shelter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
