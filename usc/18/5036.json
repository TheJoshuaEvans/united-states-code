{"tag":"section","attrib":{"id":"idb9d67e07-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s5036"},"text":null,"children":[{"tag":"num","attrib":{"value":"5036"},"text":"§ 5036.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Speedy trial","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If an alleged delinquent who is in detention pending trial is not brought to trial within thirty days from the date upon which such detention was begun, the information shall be dismissed on motion of the alleged delinquent or at the direction of the court, unless the Attorney General shows that additional delay was caused by the juvenile or his counsel, or consented to by the juvenile and his counsel, or would be in the interest of justice in the particular case. Delays attributable solely to court calendar congestion may not be considered in the interest of justice. Except in extraordinary circumstances, an information dismissed under this section may not be reinstituted.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9d67e08-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/858"},"text":"62 Stat. 858","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/415/tV/s506"},"text":"Pub. L. 93–415, title V, § 506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1136"},"text":"88 Stat. 1136","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9d67e09-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9d67e0a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 926 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-16/ch486/s6"},"text":"June 16, 1938, ch. 486, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/766"},"text":"52 Stat. 766","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “foster homes” were inserted to remove any doubt as to the authority to commit to such foster homes in accordance with past and present administrative practice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9d67e0b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9d67e0c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415"},"text":"Pub. L. 93–415","children":[],"tail":" amended section generally, substituting “Speedy trial” for “Contracts for support; payment” in section catchline, and substituting provisions relating to dismissal of information due to delay, for provisions relating to contracts with public or private agencies for custody and care of juvenile delinquents."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9d67e0d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"repeals","id":"idb9d67e0e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeals","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tV/s506"},"text":"Pub. L. 93–415, title V, § 506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1136"},"text":"88 Stat. 1136","children":[],"tail":", cited as a credit to this section, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/385/tIII/s307"},"text":"Pub. L. 115–385, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5152"},"text":"132 Stat. 5152","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
