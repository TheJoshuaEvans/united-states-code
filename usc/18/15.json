{"tag":"section","attrib":{"id":"idb8a2e074-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"§ 15.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligation or other security of foreign government defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The term “obligation or other security of any foreign government” includes, but is not limited to, uncanceled stamps, whether or not demonetized.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8a2e075-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/921/s3"},"text":"Pub. L. 85–921, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1771"},"text":"72 Stat. 1771","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
