{"tag":"section","attrib":{"id":"idb8fd837c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s934"},"text":null,"children":[{"tag":"num","attrib":{"value":"934"},"text":"§ 934.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeiture and fines","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8fd837d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s934/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Forfeiture.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fd837e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s934/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person convicted of a violation of section 932 or 933 shall forfeit to the United States, irrespective of any provision of State law—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8fd837f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s934/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any property constituting, or derived from, any proceeds the person obtained, directly or indirectly, as the result of such violation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fd8380-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s934/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any of the person’s property used, or intended to be used, in any manner or part, to commit, or to facilitate the commission of, such violation, except that for any forfeiture of any firearm or ammunition pursuant to this section, section 924(d) shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fd8381-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s934/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Imposition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The court, in imposing sentence on a person convicted of a violation of section 932 or 933, shall order, in addition to any other sentence imposed pursuant to section 932 or 933, that the person forfeit to the United States all property described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fd8382-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s934/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fines","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A defendant who derives profits or other proceeds from an offense under section 932 or 933 may be fined not more than the greater of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fd8383-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s934/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fine otherwise authorized by this part; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fd8384-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s934/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount equal to twice the gross profits or other proceeds of the offense under section 932 or 933.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8fd8385-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/159/dA/tII/s12004/a/1"},"text":"Pub. L. 117–159, div. A, title II, § 12004(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-06-25"},"text":"June 25, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1327"},"text":"136 Stat. 1327","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8fd8386-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8fd8387-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8fd8388-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/159/s12004/a/1"},"text":"section 12004(a)(1) of Pub. L. 117–159","children":[],"tail":", which enacted this section, to be construed to allow the establishment of a Federal system of registration of firearms, firearms owners, or firearms transactions or dispositions, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/159/s12004/k"},"text":"section 12004(k) of Pub. L. 117–159","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s922"},"text":"section 922 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
