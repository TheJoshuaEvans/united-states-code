{"tag":"section","attrib":{"id":"idb99ad4ab-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3290"},"text":null,"children":[{"tag":"num","attrib":{"value":"3290"},"text":"§ 3290.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fugitives from justice","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No statute of limitations shall extend to any person fleeing from justice.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb99ad4ac-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/829"},"text":"62 Stat. 829","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb99ad4ad-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb99ad4ae-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on Title 18, U.S.C., 1940 ed., § 583 (R.S. § 1045).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Said section 583 was rephrased and made applicable to all statutes of limitation and is merely declaratory of the generally accepted rule of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
