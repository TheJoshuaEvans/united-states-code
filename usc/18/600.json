{"tag":"section","attrib":{"id":"idb8d2a3c0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s600"},"text":null,"children":[{"tag":"num","attrib":{"value":"600"},"text":"§ 600.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promise of employment or other benefit for political activity","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, directly or indirectly, promises any employment, position, compensation, contract, appointment, or other benefit, provided for or made possible in whole or in part by any Act of Congress, or any special consideration in obtaining any such benefit, to any person as consideration, favor, or reward for any political activity or for the support of or opposition to any candidate or any political party in connection with any general or special election to any political office, or in connection with any primary election or political convention or caucus held to select candidates for any political office, shall be fined under this title or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8d2a3c1-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/721"},"text":"62 Stat. 721","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/225/tII/s202"},"text":"Pub. L. 92–225, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-02-07"},"text":"Feb. 7, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/9"},"text":"86 Stat. 9","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/453/s3"},"text":"Pub. L. 94–453, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-02"},"text":"Oct. 2, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1517"},"text":"90 Stat. 1517","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/L"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(L)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8d2a3c2-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8d2a3c3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., §§ 61b, 61g (","children":[{"tag":"date","attrib":{"date":"1939-08-02"},"text":"Aug. 2, 1939","children":[],"tail":", 11:50 a.m., E.S.T., ch. 410, §§ 3, 8, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1147"},"text":"53 Stat. 1147","children":[],"tail":", 1148)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section consolidates sections 61b and 61g of title 18, U.S.C., 1940 ed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8d2a3c4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8d2a3c5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $10,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/453"},"text":"Pub. L. 94–453","children":[],"tail":" substituted $10,000 for $1,000 maximum allowable fine."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/225"},"text":"Pub. L. 92–225","children":[],"tail":" struck out “work,” after “position,”, inserted “contract, appointment,” after “compensation,” and “or any special consideration in obtaining any such benefit,” after “Act of Congress,”, and substituted “in connection with any general or special election to any political office, or in connection with any primary election or political convention or caucus held to select candidates for any political office” for “in any election”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8d2a3c6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8d2a3c7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1972 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/225"},"text":"Pub. L. 92–225","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1971-12-31"},"text":"Dec. 31, 1971","children":[],"tail":", or sixty days after date of enactment ["},{"tag":"date","attrib":{"date":"1972-02-07"},"text":"Feb. 7, 1972","children":[],"tail":"], whichever is later, see "},{"tag":"ref","attrib":{"href":"/us/pl/92/225/s408"},"text":"section 408 of Pub. L. 92–225","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"section 30101 of Title 52","children":[],"tail":", Voting and Elections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
