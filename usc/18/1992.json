{"tag":"section","attrib":{"id":"idb942a2d8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992"},"text":null,"children":[{"tag":"num","attrib":{"value":"1992"},"text":"§ 1992.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terrorist attacks and other violence against railroad carriers and against mass transportation systems on land, on water, or through the air","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb942a2d9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Prohibitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever, in a circumstance described in subsection (c), knowingly and without lawful authority or permission—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb942a2da-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wrecks, derails, sets fire to, or disables railroad on-track equipment or a mass transportation vehicle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb942a2db-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" places any biological agent or toxin, destructive substance, or destructive device in, upon, or near railroad on-track equipment or a mass transportation vehicle with intent to endanger the safety of any person, or with a reckless disregard for the safety of human life;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb942a2dc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" places or releases a hazardous material or a biological agent or toxin on or near any property described in subparagraph (A) or (B) of paragraph (4), with intent to endanger the safety of any person, or with reckless disregard for the safety of human life;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb942a2dd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" sets fire to, undermines, makes unworkable, unusable, or hazardous to work on or use, or places any biological agent or toxin, destructive substance, or destructive device in, upon, or near any—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb942a2de-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tunnel, bridge, viaduct, trestle, track, electromagnetic guideway, signal, station, depot, warehouse, terminal, or any other way, structure, property, or appurtenance used in the operation of, or in support of the operation of, a railroad carrier, and with intent to, or knowing or having reason to know,","children":[{"tag":"ref","attrib":{"idref":"fn002133"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002133"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" such activity would likely, derail, disable, or wreck railroad on-track equipment; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb942a2df-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" garage, terminal, structure, track, electromagnetic guideway, supply, or facility used in the operation of, or in support of the operation of, a mass transportation vehicle, and with intent to, or knowing or having reason to know,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" such activity would likely, derail, disable, or wreck a mass transportation vehicle used, operated, or employed by a mass transportation provider;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb942a2e0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" removes an appurtenance from, damages, or otherwise impairs the operation of a railroad signal system or mass transportation signal or dispatching system, including a train control system, centralized dispatching system, or highway-railroad grade crossing warning signal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb942a2e1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with intent to endanger the safety of any person, or with a reckless disregard for the safety of human life, interferes with, disables, or incapacitates any dispatcher, driver, captain, locomotive engineer, railroad conductor, or other person while the person is employed in dispatching, operating, controlling, or maintaining railroad on-track equipment or a mass transportation vehicle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb942a2e2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commits an act, including the use of a dangerous weapon, with the intent to cause death or serious bodily injury to any person who is on property described in subparagraph (A) or (B) of paragraph (4);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb942a2e3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" surveils, photographs, videotapes, diagrams, or otherwise collects information with the intent to plan or assist in planning any of the acts described in paragraphs (1) through (6);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb942a2e4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conveys false information, knowing the information to be false, concerning an attempt or alleged attempt to engage in a violation of this subsection; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb942a2e5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attempts, threatens, or conspires to engage in any violation of any of paragraphs (1) through (9),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title or imprisoned not more than 20 years, or both, and if the offense results in the death of any person, shall be imprisoned for any term of years or for life, or subject to death, except in the case of a violation of paragraph (8), (9), or (10).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb942a2e6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aggravated Offense","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever commits an offense under subsection (a) of this section in a circumstance in which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb942a2e7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the railroad on-track equipment or mass transportation vehicle was carrying a passenger or employee at the time of the offense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb942a2e8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the railroad on-track equipment or mass transportation vehicle was carrying high-level radioactive waste or spent nuclear fuel at the time of the offense; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb942a2e9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the offense was committed with the intent to endanger the safety of any person, or with a reckless disregard for the safety of any person, and the railroad on-track equipment or mass transportation vehicle was carrying a hazardous material at the time of the offense that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb942a2ea-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was required to be placarded under subpart F of part 172 of title 49, Code of Federal Regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb942a2eb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is identified as class number 3, 4, 5, 6.1, or 8 and packing group I or packing group II, or class number 1, 2, or 7 under the hazardous materials table of section 172.101 of title 49, Code of Federal Regulations,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title or imprisoned for any term of years or life, or both, and if the offense resulted in the death of any person, the person may be sentenced to death.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb942a2ec-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Circumstances Required for Offense","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A circumstance referred to in subsection (a) is any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb942a2ed-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any of the conduct required for the offense is, or, in the case of an attempt, threat, or conspiracy to engage in conduct, the conduct required for the completed offense would be, engaged in, on, against, or affecting a mass transportation provider, or a railroad carrier engaged in interstate or foreign commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb942a2ee-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person travels or communicates across a State line in order to commit the offense, or transports materials across a State line in aid of the commission of the offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb942a2ef-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb942a2f0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “biological agent” has the meaning given to that term in section 178(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb942a2f1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “dangerous weapon” means a weapon, device, instrument, material, or substance, animate or inanimate, that is used for, or is readily capable of, causing death or serious bodily injury, including a pocket knife with a blade of less than 2½ inches in length and a box cutter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb942a2f2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “destructive device” has the meaning given to that term in section 921(a)(4);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb942a2f3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “destructive substance” means an explosive substance, flammable material, infernal machine, or other chemical, mechanical, or radioactive device or material, or matter of a combustible, contaminative, corrosive, or explosive nature, except that the term “radioactive device” does not include any radioactive device or material used solely for medical, industrial, research, or other peaceful purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb942a2f4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “hazardous material” has the meaning given to that term in chapter 51 of title 49;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb942a2f5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “high-level radioactive waste” has the meaning given to that term in section 2(12) of the Nuclear Waste Policy Act of 1982 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10101/12"},"text":"42 U.S.C. 10101(12)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb942a2f6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “mass transportation” has the meaning given to that term in section 5302(a)(7) ","children":[{"tag":"ref","attrib":{"idref":"fn002134"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002134"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of title 49, except that the term includes intercity bus transportation "},{"tag":"ref","attrib":{"idref":"fn002135"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002135"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" school bus, charter, and sightseeing transportation and passenger vessel as that term is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s2101"},"text":"section 2101 of title 46","children":[],"tail":", United States Code;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb942a2f7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “on-track equipment” means a carriage or other contrivance that runs on rails or electromagnetic guideways;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb942a2f8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “railroad on-track equipment” means a train, locomotive, tender, motor unit, freight or passenger car, or other on-track equipment used, operated, or employed by a railroad carrier;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb942a2f9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “railroad” has the meaning given to that term in chapter 201 of title 49;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb942a2fa-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/d/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “railroad carrier” has the meaning given to that term in chapter 201 of title 49;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb942a2fb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/d/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “serious bodily injury” has the meaning given to that term in section 1365;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb942a2fc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/d/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “spent nuclear fuel” has the meaning given to that term in section 2(23) of the Nuclear Waste Policy Act of 1982 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10101/23"},"text":"42 U.S.C. 10101(23)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb942a2fd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/d/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” has the meaning given to that term in section 2266;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb942a2fe-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/d/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “toxin” has the meaning given to that term in section 178(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb942a2ff-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1992/d/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “vehicle” means any carriage or other contrivance used, or capable of being used, as a means of transportation on land, on water, or through the air.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb942a300-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/tI/s110/a"},"text":"Pub. L. 109–177, title I, § 110(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/205"},"text":"120 Stat. 205","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXV/s1539"},"text":"Pub. L. 110–53, title XV, § 1539","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/468"},"text":"121 Stat. 468","children":[],"tail":