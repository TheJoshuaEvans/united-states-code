{"tag":"section","attrib":{"id":"idb91c7d4c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352"},"text":null,"children":[{"tag":"num","attrib":{"value":"1352"},"text":"§ 1352.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demands by foreign officials for bribes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb91c7d4d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91c7d4e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign official","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “foreign official” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb91c7d4f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb91c7d50-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any official or employee of a foreign government or any department, agency, or instrumentality thereof; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb91c7d51-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any senior foreign political figure, as defined in section 1010.605 of title 31, Code of Federal Regulations, or any successor regulation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91c7d52-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any official or employee of a public international organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91c7d53-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any person acting in an official capacity for or on behalf of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb91c7d54-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a government, department, agency, or instrumentality described in subparagraph (A)(i); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb91c7d55-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public international organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91c7d56-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public international organization","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “public international organization” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb91c7d57-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization that is designated by Executive order pursuant to section 1 of the International Organizations Immunities Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s288"},"text":"22 U.S.C. 288","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91c7d58-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other international organization that is designated by the President by Executive order for the purposes of this section, effective as of the date of publication of the order in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91c7d59-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition of Demand for a Bribe.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91c7d5a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offense","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be unlawful for any foreign official or person selected to be a foreign official to corruptly demand, seek, receive, accept, or agree to receive or accept, directly or indirectly, anything of value personally or for any other person or nongovernmental entity, by making use of the mails or any means or instrumentality of interstate commerce—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb91c7d5b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" from—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb91c7d5c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person (as defined in section 104A of the Foreign Corrupt Practices Act of 1977 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78dd–3"},"text":"15 U.S.C. 78dd–3","children":[],"tail":"), except that that definition shall be applied without regard to whether the person is an offender) while the foreign official or person selected to be a foreign official, or a person acting on behalf of the foreign official or person selected to be a foreign official, is in the territory of the United States;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb91c7d5d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an issuer (as defined in section 3(a) of the Securities Exchange Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a"},"text":"15 U.S.C. 78c(a)","children":[],"tail":")), or any officer, director, employee, or agent of an issuer or any stockholder thereof acting on behalf of the issuer; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb91c7d5e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a domestic concern (as defined in section 104 of the Foreign Corrupt Practices Act of 1977 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78dd–2"},"text":"15 U.S.C. 78dd–2","children":[],"tail":")), or any officer, director, employee, or agent of a domestic concern or any stockholder thereof acting on behalf of the domestic concern; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91c7d5f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in return for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb91c7d60-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" being influenced in the performance of any act or decision of the foreign official or person selected to be a foreign official in the official capacity of the foreign official or person selected to be a foreign official;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb91c7d61-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" being induced to do or omit to do any act in violation of the lawful duty of the foreign official or person selected to be a foreign official;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb91c7d62-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conferring any improper advantage; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb91c7d63-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using the influence of the foreign official or person selected to be a foreign official with a foreign government or instrumentality thereof to affect or influence any act or decision of that government or instrumentality,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"in connection with obtaining or retaining business for or with, or directing business to, any person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91c7d64-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person who violates paragraph (1) shall be fined not more than $250,000 or 3 times the monetary equivalent of the thing of value, imprisoned for not more than 15 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91c7d65-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An offense under paragraph (1) shall be subject to extraterritorial Federal jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91c7d66-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of enactment of this section, and annually thereafter, the Attorney General, in consultation with the Secretary of State as relevant, shall submit to the Committee on the Judiciary and the Committee on Foreign Relations of the Senate and the Committee on the Judiciary and the Committee on Foreign Affairs of the House of Representatives, and post on the publicly available website of the Department of Justice, a report—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb91c7d67-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" focusing, in part, on demands by foreign officials for bribes from entities domiciled or incorporated in the United States, and the efforts of foreign governments to prosecute such cases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91c7d68-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addressing United States diplomatic efforts to protect entities domiciled or incorporated in the United States from foreign bribery, and the effectiveness of those efforts in protecting such entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91c7d69-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" summarizing major actions taken under this section in the previous year, including enforcement actions taken and penalties imposed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91c7d6a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating the effectiveness of the Department of Justice in enforcing this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91c7d6b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detailing what resources or legislative action the Department of Justice needs to ensure adequate enforcement of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91c7d6c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1352/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection shall not be construed as encompassing conduct that would violate section 30A of the Securities Exchange Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78dd–1"},"text":"15 U.S.C. 78dd–1","children":[],"tail":") or section 104 or 104A of the Foreign Corrupt Practices Act of 1977 ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78dd–2"},"text":"15 U.S.C. 78dd–2","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78dd–3"},"text":"15 U.S.C. 78dd–3","children":[],"tail":") whether pursuant to a theory of direct liability, conspiracy, complicity, or otherwise."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb91c7d6d-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/78/s2/b/1"},"text":"Pub. L. 118–78, § 2(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-07-30"},"text":"July 30, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1512"},"text":"138 Stat. 1512","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91c7d6e-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb91c7d6f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb91c7d70-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (b)(4), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/78"},"text":"Pub. L. 118–78","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2024-07-30"},"text":"July 30, 2024","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
