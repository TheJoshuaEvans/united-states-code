{"tag":"section","attrib":{"id":"idb92ad5c2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1655"},"text":null,"children":[{"tag":"num","attrib":{"value":"1655"},"text":"§ 1655.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assault on commander as piracy","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being a seaman, lays violent hands upon his commander, to hinder and prevent his fighting in defense of his vessel or the goods intrusted to him, is a pirate, and shall be imprisoned for life.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb92ad5c3-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/774"},"text":"62 Stat. 774","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92ad5c4-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb92ad5c5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 485 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s294"},"text":"Mar. 4, 1909, ch. 321, § 294","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1146"},"text":"35 Stat. 1146","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A minor verbal change was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
