{"tag":"section","attrib":{"id":"idb955b56d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2261A"},"text":null,"children":[{"tag":"num","attrib":{"value":"2261A"},"text":"§ 2261A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stalking","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Whoever—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb955b56e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2261A/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" travels in interstate or foreign commerce or is present within the special maritime and territorial jurisdiction of the United States, or enters or leaves Indian country, with the intent to kill, injure, harass, intimidate, or place under surveillance with intent to kill, injure, harass, or intimidate another person, and in the course of, or as a result of, such travel or presence engages in conduct that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb955b56f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2261A/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" places that person in reasonable fear of the death of, or serious bodily injury to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb955b570-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2261A/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb955b571-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2261A/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an immediate family member (as defined in section 115) of that person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb955b572-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2261A/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a spouse or intimate partner of that person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb955b573-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2261A/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the pet, service animal, emotional support animal, or horse of that person; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb955b574-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2261A/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" causes, attempts to cause, or would be reasonably expected to cause substantial emotional distress to a person described in clause (i), (ii), or (iii) of subparagraph (A); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb955b575-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2261A/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with the intent to kill, injure, harass, intimidate, or place under surveillance with intent to kill, injure, harass, or intimidate another person, uses the mail, any interactive computer service or electronic communication service or electronic communication system of interstate commerce, or any other facility of interstate or foreign commerce to engage in a course of conduct that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb955b576-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2261A/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" places that person in reasonable fear of the death of or serious bodily injury to a person, a pet, a service animal, an emotional support animal, or a horse described in clause (i), (ii), (iii), or (iv) of paragraph (1)(A); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb955b577-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2261A/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" causes, attempts to cause, or would be reasonably expected to cause substantial emotional distress to a person described in clause (i), (ii), or (iii) of paragraph (1)(A),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished as provided in section 2261(b) or section 2261B, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb955b578-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tX/s1069/a"},"text":"Pub. L. 104–201, div. A, title X, § 1069(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2655"},"text":"110 Stat. 2655","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/386/dB/tI/s1107/b/1"},"text":"Pub. L. 106–386, div. B, title I, § 1107(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1498"},"text":"114 Stat. 1498","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tI/s114/a"},"text":"Pub. L. 109–162, title I, § 114(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2987"},"text":"119 Stat. 2987","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/tI/s107/b"},"text":"Pub. L. 113–4, title I, § 107(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/77"},"text":"127 Stat. 77","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12502/a/1"},"text":"Pub. L. 115–334, title XII, § 12502(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4982"},"text":"132 Stat. 4982","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/249/s2/c"},"text":"Pub. L. 116–249, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-22"},"text":"Dec. 22, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1126"},"text":"134 Stat. 1126","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb955b579-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb955b57a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb955b57b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/249"},"text":"Pub. L. 116–249","children":[],"tail":" substituted “section 2261(b) or section 2261B, as the case may be” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2261/b"},"text":"section 2261(b) of this title","children":[],"tail":"” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Par. (1)(A)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12502/a/1/A"},"text":"Pub. L. 115–334, § 12502(a)(1)(A)","children":[],"tail":", added cl. (iv)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12502/a/1/B"},"text":"Pub. L. 115–334, § 12502(a)(1)(B)","children":[],"tail":", inserted “, a pet, a service animal, an emotional support animal, or a horse” after “to a person” and substituted “(iii), or (iv)” for “or (iii)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4"},"text":"Pub. L. 113–4","children":[],"tail":" amended section generally. Prior to amendment, section related to stalking."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":" amended section catchline and text generally, revising and restating former provisions relating to stalking so as to include surveillance with intent to kill, injure, harass, or intimidate which results in substantial emotional distress to a person within the purview of the offense proscribed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386"},"text":"Pub. L. 106–386","children":[],"tail":" reenacted section catchline without change and amended text generally. Prior to amendment, text read as follows: “Whoever travels across a State line or within the special maritime and territorial jurisdiction of the United States with the intent to injure or harass another person, and in the course of, or as a result of, such travel places that person in reasonable fear of the death of, or serious bodily injury (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1365/g/3"},"text":"section 1365(g)(3) of this title","children":[],"tail":") to, that person or a member of that person’s immediate family (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s115"},"text":"section 115 of this title","children":[],"tail":") shall be punished as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2261"},"text":"section 2261 of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb955b57c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb955b57d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4"},"text":"Pub. L. 113–4","children":[],"tail":" not effective until the beginning of the fiscal year following "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/s4"},"text":"section 4 of Pub. L. 113–4","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2261"},"text":"section 2261 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
