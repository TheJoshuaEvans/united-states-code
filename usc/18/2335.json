{"tag":"section","attrib":{"id":"idb9665828-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2335"},"text":null,"children":[{"tag":"num","attrib":{"value":"2335"},"text":"§ 2335.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation of actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9665829-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2335/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (b), a suit for recovery of damages under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2333"},"text":"section 2333 of this title","children":[],"tail":" shall not be maintained unless commenced within 10 years after the date the cause of action accrued."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb966582a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2335/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Calculation of Period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The time of the absence of the defendant from the United States or from any jurisdiction in which the same or a similar action arising from the same facts may be maintained by the plaintiff, or of any concealment of the defendant’s whereabouts, shall not be included in the 10-year period set forth in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb966582b-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572/tX/s1003/a/4"},"text":"Pub. L. 102–572, title X, § 1003(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4523"},"text":"106 Stat. 4523","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tXII/s1251/a"},"text":"Pub. L. 112–239, div. A, title XII, § 1251(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2017"},"text":"126 Stat. 2017","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb966582c-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb966582d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb966582e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1251/a/1"},"text":"Pub. L. 112–239, § 1251(a)(1)","children":[],"tail":", substituted “10 years” for “4 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1251/a/2"},"text":"Pub. L. 112–239, § 1251(a)(2)","children":[],"tail":", substituted “10-year period” for “4-year period”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb966582f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb9665830-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tXII/s1251/b"},"text":"Pub. L. 112–239, div. A, title XII, § 1251(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2017"},"text":"126 Stat. 2017","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/239/dA/tXII/s1251/b"},"text":"“The amendments made by this section [amending this section] shall apply to any civil action arising under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2333"},"text":"section 2333 of title 18","children":[],"tail":", United States Code, that is pending on, or commenced on or after, the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9665831-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to any pending case or any cause of action arising on or after 4 years before ","children":[{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/s1003/c"},"text":"section 1003(c) of Pub. L. 102–572","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2331"},"text":"section 2331 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
