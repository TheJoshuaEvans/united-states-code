{"tag":"section","attrib":{"id":"idb9a92cb5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3561"},"text":null,"children":[{"tag":"num","attrib":{"value":"3561"},"text":"§ 3561.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sentence of probation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9a92cb6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3561/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A defendant who has been found guilty of an offense may be sentenced to a term of probation unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9a92cb7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3561/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense is a Class A or Class B felony and the defendant is an individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a92cb8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3561/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense is an offense for which probation has been expressly precluded; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a92cb9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3561/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the defendant is sentenced at the same time to a term of imprisonment for the same or a different offense that is not a petty offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9a92cba-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3561/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Domestic Violence Offenders","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A defendant who has been convicted for the first time of a domestic violence crime shall be sentenced to a term of probation if not sentenced to a term of imprisonment. The term “domestic violence crime” means a crime of violence for which the defendant may be prosecuted in a court of the United States in which the victim or intended victim is the spouse, former spouse, intimate partner, former intimate partner, child, or former child of the defendant, or any other relative of the defendant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9a92cbb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3561/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Terms","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The authorized terms of probation are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9a92cbc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3561/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a felony, not less than one nor more than five years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a92cbd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3561/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a misdemeanor, not more than five years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9a92cbe-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3561/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for an infraction, not more than one year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9a92cbf-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s212/a/2"},"text":"Pub. L. 98–473, title II, § 212(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1992"},"text":"98 Stat. 1992","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/646/s10/a"},"text":"Pub. L. 99–646, § 10(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3593"},"text":"100 Stat. 3593","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/182/s7"},"text":"Pub. L. 100–182, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-07"},"text":"Dec. 7, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1267"},"text":"101 Stat. 1267","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXVIII/s280004"},"text":"Pub. L. 103–322, title XXVIII, § 280004","children":[],"tail":", title XXXII, § 320921(a), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2096"},"text":"108 Stat. 2096","children":[],"tail":", 2130; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s604/c/1"},"text":"Pub. L. 104–294, title VI, § 604(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3509"},"text":"110 Stat. 3509","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9a92cc0-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9a92cc1-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb9a92cc2-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For a prior section 3561, applicable to offenses committed prior to ","children":[{"tag":"date","attrib":{"date":"1987-11-01"},"text":"Nov. 1, 1987","children":[],"tail":", see note set out preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3551"},"text":"section 3551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9a92cc3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" struck out “or any relative defendant, child, or former child of the defendant,” before “or any other relative of the defendant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s280004"},"text":"Pub. L. 103–322, § 280004","children":[],"tail":", inserted before period at end “that is not a petty offense”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s320921/a"},"text":"Pub. L. 103–322, § 320921(a)","children":[],"tail":", added subsec. (b) and redesignated former subsec. (b) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/182"},"text":"Pub. L. 100–182","children":[],"tail":" inserted “and the defendant is an individual” after “Class B felony”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646"},"text":"Pub. L. 99–646","children":[],"tail":" struck out at end “The liability of a defendant for any unexecuted fine or other punishment imposed as to which probation is granted shall be fully discharged by the fulfillment of the terms and conditions of probation.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9a92cc4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb9a92cc5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/s604/d"},"text":"section 604(d) of Pub. L. 104–294","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s13"},"text":"section 13 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},