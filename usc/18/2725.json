{"tag":"section","attrib":{"id":"idb97e4cfb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2725"},"text":null,"children":[{"tag":"num","attrib":{"value":"2725"},"text":"§ 2725.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb97e4cfc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2725/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “motor vehicle record” means any record that pertains to a motor vehicle operator’s permit, motor vehicle title, motor vehicle registration, or identification card issued by a department of motor vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97e4cfd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2725/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “person” means an individual, organization or entity, but does not include a State or agency thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97e4cfe-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2725/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “personal information” means information that identifies an individual, including an individual’s photograph, social security number, driver identification number, name, address (but not the 5-digit zip code), telephone number, and medical or disability information, but does not include information on vehicular accidents, driving violations, and driver’s status.","children":[{"tag":"ref","attrib":{"idref":"fn002208"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002208"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should be a semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97e4cff-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2725/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “highly restricted personal information” means an individual’s photograph or image, social security number, medical or disability information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb97e4d00-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2725/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “express consent” means consent in writing, including consent conveyed electronically that bears an electronic signature as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/229/s106/5"},"text":"section 106(5) of Public Law 106–229","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb97e4d01-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXX/s300002/a"},"text":"Pub. L. 103–322, title XXX, § 300002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2102"},"text":"108 Stat. 2102","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/346/s101/a/tIII/s309/b"},"text":"Pub. L. 106–346, § 101(a) [title III, § 309(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-23"},"text":"Oct. 23, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1356"},"text":"114 Stat. 1356","children":[],"tai