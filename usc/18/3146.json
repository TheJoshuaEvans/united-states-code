{"tag":"section","attrib":{"id":"idb98eeeb1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3146"},"text":null,"children":[{"tag":"num","attrib":{"value":"3146"},"text":"§ 3146.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for failure to appear","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb98eeeb2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3146/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offense","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever, having been released under this chapter knowingly—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb98eeeb3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3146/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to appear before a court as required by the conditions of release; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb98eeeb4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3146/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to surrender for service of sentence pursuant to a court order;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished as provided in subsection (b) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb98eeeb5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3146/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Punishment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb98eeeb6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3146/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The punishment for an offense under this section is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb98eeeb7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3146/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the person was released in connection with a charge of, or while awaiting sentence, surrender for service of sentence, or appeal or certiorari after conviction for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb98eeeb8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3146/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an offense punishable by death, life imprisonment, or imprisonment for a term of 15 years or more, a fine under this title or imprisonment for not more than ten years, or both;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb98eeeb9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3146/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an offense punishable by imprisonment for a term of five years or more, a fine under this title or imprisonment for not more than five years, or both;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb98eeeba-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3146/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other felony, a fine under this title or imprisonment for not more than two years, or both; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb98eeebb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3146/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a misdemeanor, a fine under this title or imprisonment for not more than one year, or both; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb98eeebc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3146/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the person was released for appearance as a material witness, a fine under this chapter or imprisonment for not more than one year, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb98eeebd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3146/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A term of imprisonment imposed under this section shall be consecutive to the sentence of imprisonment for any other offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb98eeebe-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3146/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Affirmative Defense","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It is an affirmative defense to a prosecution under this section that uncontrollable circumstances prevented the person from appearing or surrendering, and that the person did not contribute to the creation of such circumstances in reckless disregard of the requirement to appear or surrender, and that the person appeared or surrendered as soon as such circumstances ceased to exist.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb98eeebf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3146/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Declaration of Forfeiture","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a person fails to appear before a court as required, and the person executed an appearance bond pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3142/b"},"text":"section 3142(b) of this title","children":[],"tail":" or is subject to the release condition set forth in clause (xi) or (xii) of "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3142/c/1/B"},"text":"section 3142(c)(1)(B) of this title","children":[],"tail":", the judicial officer may, regardless of whether the person has been charged with an offense under this section, declare any property designated pursuant to that section to be forfeited to the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb98eeec0-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s203/a"},"text":"Pub. L. 98–473, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1982"},"text":"98 Stat. 1982","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/646/s55/f"},"text":"Pub. L. 99–646, § 55(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3609"},"text":"100 Stat. 3609","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/2/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(2)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2148"},"text":"108 Stat. 2148","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s601/a/4"},"text":"Pub. L. 104–294, title VI, § 601(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3498"},"text":"110 Stat. 3498","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb98eeec1-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb98eeec2-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb98eeec3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3146, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/465/s3/a"},"text":"Pub. L. 89–465, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-06-22"},"text":"June 22, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/214"},"text":"80 Stat. 214","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/291/s8"},"text":"Pub. L. 97–291, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1257"},"text":"96 Stat. 1257","children":[],"tail":", related to release in noncapital cases prior to trial, prior to repeal in the revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/s203/a"},"text":"section 203(a) of Pub. L. 98–473","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 3146, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-20/ch772/s1"},"text":"act Aug. 20, 1954, ch. 772, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/747"},"text":"68 Stat. 747","children":[],"tail":", which prescribed penalties for jumping bail, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/89/465/s3/a"},"text":"Pub. L. 89–465, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-06-22"},"text":"June 22, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/214"},"text":"80 Stat. 214","children":[],"tail":", and covered by former sections 3150 and 3151 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb98eeec4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(1)(A)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" substituted “a fine under this title” for “a fined under this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(1)(A)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fine under this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646/s55/f/1"},"text":"Pub. L. 99–646, § 55(f)(1)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a) which read as follows: “A person commits an offense if, after having been released pursuant to this chapter—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) he knowingly fails to appear before a court as required by the conditions of his release; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) he knowingly fails to surrender for service of sentence pursuant to a court order.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646/s55/f/1"},"text":"Pub. L. 99–646, § 55(f)(1)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b) which was captioned “Grading”, and which read as follows: “If the person was released—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) in connection with a charge of, or while awaiting sentence, surrender for service of sentence, or appeal or certiorari after conviction, for—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) an offense punishable by death, life imprisonment, or imprisonment for a term of fifteen years or more, he shall be fined not more than $25,000 or imprisoned for not more than ten years, or both;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) an offense punishable by imprisonment for a term of five or more years, but less than fifteen years, he shall be fined not more than $10,000 or imprisoned for not more than five years, or both;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) any other felony, he shall be fined not more than $5,000 or imprisoned for not more than two years, or both; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) a misdemeanor, he shall be fined not more than $2,000 or imprisoned for not more than one year, or both; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) for appearance as a material witness, he shall be fined not more than $1,000 or imprisoned for not more than one year, or both.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"A term of imprisonment imposed pursuant to this section shall be consecutive to the sentence of imprisonment for any other offense.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646/s55/f/2"},"text":"Pub. L. 99–646, § 55(f)(2)","children":[],"tail":", substituted “requirement to appear” for “requirement that he appear” and “the person appeared” for “he appeared”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646/s55/f/3"},"text":"Pub. L. 99–646, § 55(f)(3)","children":[],"tail":", inserted “of this title” after “3142(b)” and substituted “clause (xi) or (xii) of "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3142/c/1/B"},"text":"section 3142(c)(1)(B) of this title","children":[],"tail":"” for “section 3142(c)(2)(K) or (c)(2)(L)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb98eeec5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb98eeec6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646"},"text":"Pub. L. 99–646","children":[],"tail":" effective 30 days after "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/646/s55/j"},"text":"section 55(j) of Pub. L. 99–646","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3141"},"text":"section 3141 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
