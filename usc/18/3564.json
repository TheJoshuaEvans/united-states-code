{"tag":"section","attrib":{"id":"idb9a92d0d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3564"},"text":null,"children":[{"tag":"num","attrib":{"value":"3564"},"text":"§ 3564.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Running of a term of probation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9a92d0e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3564/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commencement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A term of probation commences on the day that the sentence of probation is imposed, unless otherwise ordered by the court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9a92d0f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3564/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Concurrence With Other Sentences","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Multiple terms of probation, whether imposed at the same time or at different times, run concurrently with each other. A term of probation runs concurrently with any Federal, State, or local term of probation, supervised release, or parole for another offense to which the defendant is subject or becomes subject during the term of probation. A term of probation does not run while the defendant is imprisoned in connection with a conviction for a Federal, State, or local crime unless the imprisonment is for a period of less than thirty consecutive days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9a92d10-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3564/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Early Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The court, after considering the factors set forth in section 3553(a) to the extent that they are applicable, may, pursuant to the provisions of the Federal Rules of Criminal Procedure relating to the modification of probation, terminate a term of probation previously ordered and discharge the defendant at any time in the case of a misdemeanor or an infraction or at any time after the expiration of one year of probation in the case of a felony, if it is satisfied that such action is warranted by the conduct of the defendant and the interest of justice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9a92d11-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3564/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extension","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The court may, after a hearing, extend a term of probation, if less than the maximum authorized term was previously imposed, at any time prior to the expiration or termination of the term of probation, pursuant to the provisions applicable to the initial setting of the term of probation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9a92d12-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3564/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subject to Revocation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A sentence of probation remains conditional and subject to revocation until its expiration or termination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9a92d13-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s212/a/2"},"text":"Pub. L. 98–473, title II, § 212(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1994"},"text":"98 Stat. 1994","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/646/s13/a"},"text":"Pub. L. 99–646, § 13(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3594"},"text":"100 Stat. 3594","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/182/s11"},"text":"Pub. L. 100–182, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-07"},"text":"Dec. 7, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1268"},"text":"101 Stat. 1268","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9a92d14-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9a92d15-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9a92d16-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Criminal Procedure, referred to in subsec. (c), are set out in the Appendix to this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb9a92d17-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For a prior section 3564, applicable to offenses committed prior to ","children":[{"tag":"date","attrib":{"date":"1987-11-01"},"text":"Nov. 1, 1987","children":[],"tail":", see note set out preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3551"},"text":"section 3551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9a92d18-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/182"},"text":"Pub. L. 100–182","children":[],"tail":" inserted “, pursuant to the provisions of the Federal Rules of Criminal Procedure relating to the modification of probation,” after “may”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646"},"text":"Pub. L. 99–646","children":[],"tail":" substituted provision that the term of probation does not run while the defendant is imprisoned in connection with a conviction for a Federal, State, or local crime unless the imprisonment is for a period of less than thirty consecutive days, for provision that the term of probation does not run during any period in which the defendant is imprisoned for a period of at least thirty consecutive days in connection with a conviction for a Federal, State, or local crime."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9a92d19-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb9a92d1a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/182"},"text":"Pub. L. 100–182","children":[],"tail":" applicable with respect to offenses committed after "},{"tag":"date","attrib":{"date":"1987-12-07"},"text":"Dec. 7, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/182/s26"},"text":"section 26 of Pub. L. 100–182","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3006A"},"text":"section 3006A of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb9a92d1b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646/s13/b"},"text":"Pub. L. 99–646, § 13(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3594"},"text":"100 Stat. 3594","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/646/s13/b"},"text":"“The amendments made by this section [amending this section] shall take effect on the date of the taking effect of such section 3564 [","children":[{"tag":"date","attrib":{"date":"1987-11-01"},"text":"Nov. 1, 1987","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9a92d1c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1987-11-01"},"text":"Nov. 1, 1987","children":[],"tail":", and applicable only to offenses committed after the taking effect of this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/s235/a/1"},"text":"section 235(a)(1) of Pub. L. 98–473","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3551"},"text":"section 3551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
