{"tag":"section","attrib":{"id":"idb91c7dc7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1368"},"text":null,"children":[{"tag":"num","attrib":{"value":"1368"},"text":"§ 1368.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Harming animals used in law enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb91c7dc8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1368/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever willfully and maliciously harms any police animal, or attempts or conspires to do so, shall be fined under this title and imprisoned not more than 1 year. If the offense permanently disables or disfigures the animal, or causes serious bodily injury to or the death of the animal, the maximum term of imprisonment shall be 10 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91c7dc9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1368/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this section, the term “police animal” means a dog or horse employed by a Federal agency (whether in the executive, legislative, or judicial branch) for the principal purpose of aiding in the detection of criminal activity, enforcement of laws, or apprehension of criminal offenders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb91c7dca-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/254/s2/a"},"text":"Pub. L. 106–254, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-08-02"},"text":"Aug. 2, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/638"},"text":"114 Stat. 638","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dB/tIV/s4003/a/4"},"text":"Pub. L. 107–273, div. B, title IV, § 4003(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1811"},"text":"116 Stat. 1811","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91c7dcb-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb91c7dcc-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb91c7dcd-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" inserted “to” after “serious bodily injury”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb91c7dce-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb91c7dcf-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/254/s1"},"text":"Pub. L. 106–254, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-08-02"},"text":"Aug. 2, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/638"},"text":"114 Stat. 638","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/254/s1"},"text":"“This Act [enacting this section] may be cited as the ‘Federal Law Enforcement Animal Protection Act of 2000’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
