{"tag":"section","attrib":{"id":"idb96ff426-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2426"},"text":null,"children":[{"tag":"num","attrib":{"value":"2426"},"text":"§ 2426.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repeat offenders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb96ff427-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2426/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Term of Imprisonment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The maximum term of imprisonment for a violation of this chapter after a prior sex offense conviction shall be 3 times the term of imprisonment otherwise provided by this chapter, unless section 3559(e) applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96ff428-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2426/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96ff429-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2426/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “prior sex offense conviction” means a conviction for an offense—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb96ff42a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2426/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under this chapter, chapter 109A, chapter 110, or section 1591; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96ff42b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2426/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under State law or the Uniform Code of Military Justice for an offense consisting of conduct that would have been an offense under a chapter referred to in subparagraph (A) if the conduct had occurred within the special maritime and territorial jurisdiction of the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96ff42c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2426/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” means a State of the United States, the District of Columbia, and any commonwealth, territory, or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb96ff42d-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/314/tI/s104/a"},"text":"Pub. L. 105–314, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2976"},"text":"112 Stat. 2976","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/21/tI/s106/b"},"text":"Pub. L. 108–21, title I, § 106(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-30"},"text":"Apr. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/655"},"text":"117 Stat. 655","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/457/tII/s224/c"},"text":"Pub. L. 110–457, title II, § 224(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-12-23"},"text":"Dec. 23, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/5072"},"text":"122 Stat. 5072","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/392/s11/2"},"text":"Pub. L. 115–392, § 11(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5255"},"text":"132 Stat. 5255","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s569/5"},"text":"Pub. L. 118–159, div. A, title V, § 569(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1906"},"text":"138 Stat. 1906","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb96ff42e-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb96ff42f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb96ff430-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" inserted “or the Uniform Code of Military Justice” after “State law”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/392/s11/2/A"},"text":"Pub. L. 115–392, § 11(2)(A)","children":[],"tail":", substituted “3 times” for “twice”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/392/s11/2/B"},"text":"Pub. L. 115–392, § 11(2)(B)","children":[],"tail":", substituted “subparagraph (A)” for “paragraph (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/457"},"text":"Pub. L. 110–457","children":[],"tail":" substituted “chapter 110, or section 1591” for “or chapter 110”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21"},"text":"Pub. L. 108–21","children":[],"tail":" inserted “, unless section 3559(e) applies” before period at end."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
