{"tag":"section","attrib":{"id":"idb9344b2b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1853"},"text":null,"children":[{"tag":"num","attrib":{"value":"1853"},"text":"§ 1853.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trees cut or injured","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever unlawfully cuts, or wantonly injures or destroys any tree growing, standing, or being upon any land of the United States which, in pursuance of law, has been reserved or purchased by the United States for any public use, or upon any Indian reservation, or lands belonging to or occupied by any tribe of Indians under the authority of the United States, or any Indian allotment while the title to the same shall be held in trust by the Government, or while the same shall remain inalienable by the allottee without the consent of the United States, shall be fined under this title or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9344b2c-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/787"},"text":"62 Stat. 787","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s601/a/8"},"text":"Pub. L. 104–294, title VI, § 601(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3498"},"text":"110 Stat. 3498","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9344b2d-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9344b2e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 104 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s50"},"text":"Mar. 4, 1909, ch. 321, § 50","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1098"},"text":"35 Stat. 1098","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1910-06-25/ch431/s6"},"text":"June 25, 1910, ch. 431, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/857"},"text":"36 Stat. 857","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to persons aiding or procuring was deleted as unnecessary since such persons are made principals by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Maximum fine was increased from $500 to $1,000 to conform to other comparable sections of this chapter. (See sections 1851 and 1852 of this title.)","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were also made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9344b2f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9344b30-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" substituted “fined under this title” for “fined not more than $1,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
