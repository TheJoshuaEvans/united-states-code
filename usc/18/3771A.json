{"tag":"section","attrib":{"id":"idb9c0facc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A"},"text":null,"children":[{"tag":"num","attrib":{"value":"3771A"},"text":"§ 3771A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motion to vacate; expungement; mitigating factors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9c0facd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c0face-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “child” means an individual who has not attained 18 years of age;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0facf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “covered prisoner” means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c0fad0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was convicted of a level A offense or level B offense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0fad1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was sentenced to a term of imprisonment for the offense described in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0fad2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is, or was previously, imprisoned or incarcerated under such sentence for a term of imprisonment;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fad3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “employee” and “officer” have the meanings given the terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fad4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Federal offense” means an offense that is punishable under Federal law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fad5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “level A offense” means a Federal offense that is not a violent crime;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fad6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “level B offense”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c0fad7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a Federal offense that is a violent crime; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0fad8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include a Federal offense that is a violent crime of which a child was a victim;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fad9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “victim of trafficking” has the meaning given that term in section 103 of the Trafficking Victims Protection Act of 2000 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102"},"text":"22 U.S.C. 7102","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fada-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “violent crime” has the meaning given the term “crime of violence” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s16/a"},"text":"section 16(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c0fadb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Motions To Vacate Convictions or Expunge Arrests.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c0fadc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c0fadd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Convictions of level a offenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person convicted of any level A offense (or an attorney representing such a person) may move the court that imposed the sentence for the level A offense to vacate the judgment of conviction if the level A offense was committed as a direct result of the person having been a victim of trafficking.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0fade-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Arrests for level a offenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person arrested for any level A offense (or an attorney representing such a person) may move the district court of the United States for the district and division embracing the place where the person was arrested to expunge all records of the arrest if the conduct or alleged conduct of the person that resulted in the arrest was directly related to the person having been a victim of trafficking.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0fadf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Arrests for level b offenses","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person arrested for any level B offense (or an attorney representing such a person) may move the district court of the United States for the district and division embracing the place where the person was arrested to expunge all records of the arrest if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9c0fae0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct or alleged conduct of the movant that resulted in the arrest was directly related to the movant having been a victim of trafficking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9c0fae1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb9c0fae2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/1/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the movant was acquitted of the level B offense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb9c0fae3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/1/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Government did not pursue, or the Government moved to dismiss, criminal charges against the movant for the level B offense; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb9c0fae4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/1/C/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"item","attrib":{"id":"idb9c0fae5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/1/C/ii/III/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the charges against the movant for the level B offense were reduced to an offense that is a level A offense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idb9c0fae6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/1/C/ii/III/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the movant was acquitted of the level A offense, the Government did not pursue, or the Government moved to dismiss, criminal charges against the movant for the level A offense, or any subsequent conviction of the level A offense was vacated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fae7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of motion","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A motion described in paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c0fae8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be in writing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0fae9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe any supporting evidence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0faea-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state the offense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0faeb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include copies of any documents showing that the movant is entitled to relief under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0faec-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hearing.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c0faed-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mandatory hearing.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idb9c0faee-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Motion in opposition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after the date on which a motion is filed under paragraph (1), the Government may file a motion in opposition of the motion filed under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9c0faef-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mandatory hearing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Government files a motion described in clause (i), not later than 15 days after the date on which the motion is filed, the court shall hold a hearing on the motion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0faf0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Discretionary hearing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Government does not file a motion described in subparagraph (A)(i), the court may hold a hearing on the motion not later than 45 days after the date on which a motion is filed under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0faf1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Factors.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c0faf2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vacating convictions of level a offenses","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The court may grant a motion under paragraph (1)(A) if, after notice to the Government and an opportunity to be heard, the court finds, by a preponderance of the evidence, that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9c0faf3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the movant was convicted of a level A offense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9c0faf4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participation in the level A offense by the movant was a direct result of the movant having been a victim of trafficking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0faf5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expunging arrests for level a offenses","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The court may grant a motion under paragraph (1)(B) if, after notice to the Government and an opportunity to be heard, the court finds, by a preponderance of the evidence, that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9c0faf6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the movant was arrested for a level A offense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9c0faf7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct or alleged conduct that resulted in the arrest was directly related to the movant having been a victim of trafficking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0faf8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expunging arrests for level b offenses","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The court may grant a motion under paragraph (1)(C) if, after notice to the Government and an opportunity to be heard, the court finds, by a preponderance of the evidence, that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9c0faf9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the movant was arrested for a level B offense and the conduct or alleged conduct that resulted in the arrest was directly related to the movant having been a victim of trafficking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9c0fafa-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb9c0fafb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/4/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the movant was acquitted of the level B offense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb9c0fafc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/4/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Government did not pursue, or the Government moved to dismiss, criminal charges against the movant for the level B offense; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb9c0fafd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/4/C/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"item","attrib":{"id":"idb9c0fafe-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/4/C/ii/III/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the charges against the movant for the level B offense were reduced to a level A offense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idb9c0faff-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/4/C/ii/III/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the movant was acquitted of the level A offense, the Government did not pursue, or the Government moved to dismiss, criminal charges against the movant for the level A offense, or any subsequent conviction of that level A offense was vacated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fb00-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Supporting evidence.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c0fb01-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, in determining whether the movant is a victim of trafficking, the court—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9c0fb02-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall consider an affidavit or sworn testimony of an anti-human trafficking service provider or clinician; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9c0fb03-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may consider any supporting evidence the court determines is of sufficient credibility and probative value, including sworn testimony from a law enforcement officer detailing the role of the movant in coercing other victims of trafficking into committing criminal offenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0fb04-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Affidavit or sworn testimony sufficient evidence","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The affidavit or sworn testimony described in subparagraph (A)(i) shall be sufficient evidence to vacate a conviction or expunge an arrest under this section if the court determines that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9c0fb05-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the affidavit or sworn testimony is credible; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9c0fb06-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no other evidence is readily available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fb07-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conviction or arrest of other persons not required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It shall not be necessary that any person other than the movant be convicted of or arrested for an offense before the movant may file a motion under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fb08-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Denial of motion.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c0fb09-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Finality","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the court denies a motion filed under paragraph (1), the denial shall be final, except as provided under subparagraph (C) of this paragraph and subject to the discovery of any new and compelling evidence or information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0fb0a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reasons for denial","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the court denies a motion filed under paragraph (1), the court shall state the reasons for the denial in writing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0fb0b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reasonable time to cure deficiencies in motion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the court denies a motion filed under paragraph (1) due to a curable deficiency in the motion, the court shall allow the movant sufficient time to cure the deficiency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fb0c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appeal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An order granting or denying a motion under this section may be appealed in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1291"},"text":"section 1291 of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c0fb0d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vacatur of Convictions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c0fb0e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the court grants a motion to vacate a conviction of a level A offense under subsection (b), the court shall immediately—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c0fb0f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vacate the conviction for cause;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0fb10-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set aside the verdict and enter a judgment of acquittal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0fb11-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" enter an expungement order that directs that there be expunged from all official records all references to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9c0fb12-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the arrest of the movant for the level A offense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9c0fb13-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the institution of criminal proceedings against the movant relating to the level A offense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9c0fb14-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of the proceedings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fb15-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this subsection requires a court to amend or remove any fine or restitution order in a criminal or civil proceeding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fb16-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a conviction is vacated under an order entered under paragraph (1), the conviction shall not be regarded as a conviction under Federal law and the movant for whom the conviction was vacated shall be considered to have the status occupied by the movant before the arrest or the institution of the criminal proceedings related to such conviction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c0fb17-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expungement of Arrests.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c0fb18-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the court grants a motion to expunge all records of an arrest for an offense under subsection (b), the court shall immediately enter an expungement order that directs that there be expunged from all official records all references to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c0fb19-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the arrest of the movant for the offense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0fb1a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the institution of any criminal proceedings against the movant relating to the offense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0fb1b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of the proceedings, if any.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fb1c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If an arrest is expunged under an order entered under paragraph (1) the arrest shall not be regarded as an arrest under Federal law and the movant for whom the arrest is expunged shall be considered to have the status occupied by the movant before the arrest or the institution of the criminal proceedings related to such arrest, if any.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c0fb1d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mitigating Factors.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c0fb1e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The court that imposed sentence for a level A offense or level B offense upon a covered prisoner may reduce the term of imprisonment for the offense—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9c0fb1f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" upon—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9c0fb20-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" motion by the covered prisoner; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9c0fb21-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the court’s own motion;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0fb22-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after notice to the Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0fb23-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" after considering—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9c0fb24-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/e/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the factors set forth in section 3553(a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9c0fb25-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/e/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature and seriousness of the danger to any person, if applicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9c0fb26-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/e/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the community, or any crime victims; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9c0fb27-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the court finds, by a preponderance of the evidence, that the covered prisoner committed the offense as a direct result of the covered prisoner having been a victim of trafficking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fb28-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any proceeding under this subsection shall be subject to section 3771.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fb29-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Particularized inquiry","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For any motion under paragraph (1), the Government shall conduct a particularized inquiry of the facts and circumstances of the original sentencing of the covered prisoner in order to assess whether a reduction in sentence would be consistent with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c0fb2a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Actions by Court","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The court shall, upon granting a motion under this section, take any additional action necessary to grant the movant full relief.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c0fb2b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person may not be required to pay a filing fee, service charge, copay fee, processing fee, or any other charge for filing a motion under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c0fb2c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Confidentiality of Movant.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c0fb2d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A motion under this section and any documents, pleadings, or orders relating to the motion shall be filed under seal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c0fb2e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information not available for public inspection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer or employee may not make available for public inspection any report, paper, picture, photograph, court file, or other document, in the custody or possession of the officer or employee, that identifies the movant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c0fb2f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3771A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall apply to any conviction or arrest occurring before, on, or after the date of enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9c0fb30-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/73/s2/a"},"text":"Pub. L. 119–73, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-01-23"},"text":"Jan. 23, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/2003"},"text":"139 Stat. 2003","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9c0fb31-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9c0fb32-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9c0fb33-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (i), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/73"},"text":"Pub. L. 119–73","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2026-01-23"},"text":"Jan. 23, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9c0fb34-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb9c0fb35-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in enactment of this section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/73"},"text":"Pub. L. 119–73","children":[],"tail":" to be construed to conflict with any of the crime victims’ rights described in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3771"},"text":"section 3771 of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/119/73/s8"},"text":"section 8 of Pub. L. 119–73","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s28"},"text":"section 28 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
