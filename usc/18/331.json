{"tag":"section","attrib":{"id":"idb8c6956c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s331"},"text":null,"children":[{"tag":"num","attrib":{"value":"331"},"text":"§ 331.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mutilation, diminution, and falsification of coins","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever fraudulently alters, defaces, mutilates, impairs, diminishes, falsifies, scales, or lightens any of the coins coined at the mints of the United States, or any foreign coins which are by law made current or are in actual use or circulation as money within the United States; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever fraudulently possesses, passes, utters, publishes, or sells, or attempts to pass, utter, publish, or sell, or brings into the United States, any such coin, knowing the same to be altered, defaced, mutilated, impaired, diminished, falsified, scaled, or lightened—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Shall be fined under this title or imprisoned not more than five years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8c6956d-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/700"},"text":"62 Stat. 700","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1951-07-16/ch226/s1"},"text":"July 16, 1951, ch. 226, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/121"},"text":"65 Stat. 121","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/I"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(I)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c6956e-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8c6956f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 279 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s165"},"text":"Mar. 4, 1909, ch. 321, § 165","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1119"},"text":"35 Stat. 1119","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Mandatory punishment provision was rephrased in the alternative.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to persons causing or procuring was omitted as unnecessary in view of definition of “principal” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were also made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8c69570-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8c69571-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $2,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1951—Act ","children":[{"tag":"date","attrib":{"date":"1951-07-16"},"text":"July 16, 1951","children":[],"tail":", made section applicable to minor coins (5-cent and 1-cent pieces), and to fraudulent alteration of coins."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
