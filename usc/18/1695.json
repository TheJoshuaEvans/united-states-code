{"tag":"section","attrib":{"id":"idb92ad603-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1695"},"text":null,"children":[{"tag":"num","attrib":{"value":"1695"},"text":"§ 1695.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carriage of matter out of mail on vessels","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever carries any letter or packet on board any vessel which carries the mail, otherwise than in such mail, shall, except as otherwise provided by law, be fined under this title or imprisoned not more than thirty days, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb92ad604-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/777"},"text":"62 Stat. 777","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/A"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2146"},"text":"108 Stat. 2146","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92ad605-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb92ad606-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 308 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s185"},"text":"Mar. 4, 1909, ch. 321, § 185","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1124"},"text":"35 Stat. 1124","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “thirty days” were substituted for “one month,” to make the term of imprisonment more definite and to conform to other comparable sections. (See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1693"},"text":"section 1693 of this title","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92ad607-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92ad608-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $50”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb92ad609-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb92ad60a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study of Private Carriage of Mail; Reports to President and Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Congressional findings of need for study and reevaluation of restrictions on private carriage of letters and packets contained in this section and submission by United States Postal Service of reports to President and Congress for modernization of law, regulations, and administrative practices, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375/s7"},"text":"section 7 of Pub. L. 91–375","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s601"},"text":"section 601 of Title 39","children":[],"tail":", Postal Service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
