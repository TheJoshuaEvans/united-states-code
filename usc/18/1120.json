{"tag":"section","attrib":{"id":"idb915512b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1120"},"text":null,"children":[{"tag":"num","attrib":{"value":"1120"},"text":"§ 1120.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Murder by escaped prisoners","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb915512c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1120/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, “Federal correctional institution” and “term of life imprisonment” have the meanings stated in section 1118.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb915512d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1120/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offense and Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person, having escaped from a Federal correctional institution where the person was confined under a sentence for a term of life imprisonment, kills another shall be punished as provided in sections 1111 and 1112.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb915512e-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tVI/s60012/a"},"text":"Pub. L. 103–322, title VI, § 60012(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1973"},"text":"108 Stat. 1973","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s601/c/2"},"text":"Pub. L. 104–294, title VI, § 601(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3499"},"text":"110 Stat. 3499","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb915512f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9155130-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9155131-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" substituted “Federal correctional institution” for “Federal prison”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
