{"tag":"section","attrib":{"id":"idb91a0c3c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1202"},"text":null,"children":[{"tag":"num","attrib":{"value":"1202"},"text":"§ 1202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ransom money","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb91a0c3d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever receives, possesses, or disposes of any money or other property, or any portion thereof, which has at any time been delivered as ransom or reward in connection with a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1201"},"text":"section 1201 of this title","children":[],"tail":", knowing the same to be money or property which has been at any time delivered as such ransom or reward, shall be fined under this title or imprisoned not more than ten years, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91a0c3e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who transports, transmits, or transfers in interstate or foreign commerce any proceeds of a kidnapping punishable under State law by imprisonment for more than 1 year, or receives, possesses, conceals, or disposes of any such proceeds after they have crossed a State or United States boundary, knowing the proceeds to have been unlawfully obtained, shall be imprisoned not more than 10 years, fined under this title, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91a0c3f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1202/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this section, the term “State” has the meaning set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s245/d"},"text":"section 245(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb91a0c40-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/760"},"text":"62 Stat. 760","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXII/s320601/b"},"text":"Pub. L. 103–322, title XXXII, § 320601(b)","children":[],"tail":", title XXXIII, § 330016(1)(L), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2115"},"text":"108 Stat. 2115","children":[],"tail":", 2147.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91a0c41-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb91a0c42-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 408c–1 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1932-06-22/ch271/s4"},"text":"June 22, 1932, ch. 271, § 4","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1936-01-24/ch29"},"text":"Jan. 24, 1936, ch. 29","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1099"},"text":"49 Stat. 1099","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “in the penitentiary” after “imprisoned” were omitted in view of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s4082"},"text":"section 4082 of this title","children":[],"tail":" committing prisoners to the custody of the Attorney General. (See reviser’s note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1"},"text":"section 1 of this title","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb91a0c43-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb91a0c44-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s320601/b"},"text":"Pub. L. 103–322, § 320601(b)","children":[],"tail":", designated existing provisions as subsec. (a) and added subsecs. (b) and (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/1/L"},"text":"Pub. L. 103–322, § 330016(1)(L)","children":[],"tail":", substituted “fined under this title” for “fined not more than $10,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
