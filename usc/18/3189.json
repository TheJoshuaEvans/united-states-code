{"tag":"section","attrib":{"id":"idb9961a63-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3189"},"text":null,"children":[{"tag":"num","attrib":{"value":"3189"},"text":"§ 3189.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Place and character of hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Hearings in cases of extradition under treaty stipulation or convention shall be held on land, publicly, and in a room or office easily accessible to the public.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9961a64-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/824"},"text":"62 Stat. 824","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9961a65-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9961a66-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 657 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1882-08-03/ch378/s1"},"text":"Aug. 3, 1882, ch. 378, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/22/215"},"text":"22 Stat. 215","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"First word “All” was omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
