{"tag":"section","attrib":{"id":"idb95a70db-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2282B"},"text":null,"children":[{"tag":"num","attrib":{"value":"2282B"},"text":"§ 2282B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violence against aids to maritime navigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever intentionally destroys, seriously damages, alters, moves, or tampers with any aid to maritime navigation maintained by the Great Lakes St. Lawrence Seaway Development Corporation under the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-05-13/s4"},"text":"section 4 of the Act of May 13, 1954","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s984"},"text":"33 U.S.C. 984","children":[],"tail":"), by the Coast Guard pursuant to section 81 "},{"tag":"ref","attrib":{"idref":"fn002172"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002172"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 14, United States Code, or lawfully maintained under authority granted by the Coast Guard pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s83"},"text":"section 83 of title 14","children":[],"tail":", United States Code, if such act endangers or is likely to endanger the safe navigation of a ship, shall be fined under this title or imprisoned for not more than 20 years, or both."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb95a70dc-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/tIII/s304/b/1"},"text":"Pub. L. 109–177, title III, § 304(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/235"},"text":"120 Stat. 235","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tV/s512/c/2"},"text":"Pub. L. 116–260, div. AA, title V, § 512(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2756"},"text":"134 Stat. 2756","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb95a70dd-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb95a70de-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb95a70df-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s81"},"text":"Section 81 of title 14","children":[],"tail":", referred to in text, was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s541"},"text":"section 541 of title 14","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s105/b"},"text":"Pub. L. 115–282, title I, § 105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4200"},"text":"132 Stat. 4200","children":[],"tail":", and references to "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s81"},"text":"section 81 of title 14","children":[],"tail":" deemed to refer to such redesignated section, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/1"},"text":"section 123(b)(1) of Pub. L. 115–282","children":[],"tail":", set out as a References to Sections of Title 14 as Redesignated by "},{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s101"},"text":"section 101 of Title 14","children":[],"tail":", Coast Guard."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb95a70e0-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" substituted “Great Lakes St. Lawrence Seaway Development Corporation” for “Saint Lawrence Seaway Development Corporation”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
