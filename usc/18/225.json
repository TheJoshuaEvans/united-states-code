{"tag":"section","attrib":{"id":"idb8bf90ad-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s225"},"text":null,"children":[{"tag":"num","attrib":{"value":"225"},"text":"§ 225.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing financial crimes enterprise","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8bf90ae-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s225/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whoever—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8bf90af-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s225/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizes, manages, or supervises a continuing financial crimes enterprise; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf90b0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s225/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receives $5,000,000 or more in gross receipts from such enterprise during any 24-month period,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined not more than $10,000,000 if an individual, or $20,000,000 if an organization, and imprisoned for a term of not less than 10 years and which may be life.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8bf90b1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s225/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of subsection (a), the term “continuing financial crimes enterprise” means a series of violations under section 215, 656, 657, 1005, 1006, 1007, 1014, 1032, or 1344 of this title, or section 1341 or 1343 affecting a financial institution, committed by at least 4 persons acting in concert.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8bf90b2-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV/s2510/a"},"text":"Pub. L. 101–647, title XXV, § 2510(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4863"},"text":"104 Stat. 4863","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
