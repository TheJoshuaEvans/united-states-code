{"tag":"section","attrib":{"id":"idb91a0c54-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1204"},"text":null,"children":[{"tag":"num","attrib":{"value":"1204"},"text":"§ 1204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International parental kidnapping","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb91a0c55-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1204/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever removes a child from the United States, or attempts to do so, or retains a child (who has been in the United States) outside the United States with intent to obstruct the lawful exercise of parental rights shall be fined under this title or imprisoned not more than 3 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91a0c56-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1204/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91a0c57-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1204/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “child” means a person who has not attained the age of 16 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91a0c58-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1204/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “parental rights”, with respect to a child, means the right to physical custody of the child—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb91a0c59-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1204/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether joint or sole (and includes visiting rights); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91a0c5a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1204/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether arising by operation of law, court order, or legally binding agreement of the parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91a0c5b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1204/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" It shall be an affirmative defense under this section that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91a0c5c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1204/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the defendant acted within the provisions of a valid court order granting the defendant legal custody or visitation rights and that order was obtained pursuant to the Uniform Child Custody Jurisdiction Act or the Uniform Child Custody Jurisdiction and Enforcement Act and was in effect at the time of the offense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91a0c5d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1204/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the defendant was fleeing an incidence or pattern of domestic violence; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91a0c5e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1204/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the defendant had physical custody of the child pursuant to a court order granting legal custody or visitation rights and failed to return the child as a result of circumstances beyond the defendant’s control, and the defendant notified or made reasonable attempts to notify the other parent or lawful custodian of the child of such circumstances within 24 hours after the visitation period had expired and returned the child as soon as possible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91a0c5f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1204/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not detract from The Hague Convention on the Civil Aspects of International Parental Child Abduction, done at The Hague on ","children":[{"tag":"date","attrib":{"date":"1980-10-25"},"text":"October 25, 1980","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb91a0c60-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/173/s2/a"},"text":"Pub. L. 103–173, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-02"},"text":"Dec. 2, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1998"},"text":"107 Stat. 1998","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/21/tI/s107"},"text":"Pub. L. 108–21, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-30"},"text":"Apr. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/655"},"text":"117 Stat. 655","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91a0c61-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb91a0c62-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb91a0c63-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21/s107/1"},"text":"Pub. L. 108–21, § 107(1)","children":[],"tail":", inserted “, or attempts to do so,” before “or retains”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21/s107/2/A"},"text":"Pub. L. 108–21, § 107(2)(A)","children":[],"tail":", inserted “or the Uniform Child Custody Jurisdiction and Enforcement Act” before “and was”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21/s107/2/B"},"text":"Pub. L. 108–21, § 107(2)(B)","children":[],"tail":", inserted “or” after semicolon at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb91a0c64-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb91a0c65-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Sense of Congress Regarding Use of Procedures Under The Hague Convention on the Civil Aspects of International Parental Child Abduction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/173/s2/b"},"text":"Pub. L. 103–173, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-02"},"text":"Dec. 2, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1999"},"text":"107 Stat. 1999","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/173/s2/b"},"text":"“It is the sense of the Congress that, inasmuch as use of the procedures under the Hague Convention on the Civil Aspects of International Parental Child Abduction has resulted in the return of many children, those procedures, in circumstances in which they are applicable, should be the option of first choice for a parent who seeks the return of a child who has been removed from the parent.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
