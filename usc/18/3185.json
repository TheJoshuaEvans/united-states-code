children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Par. (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646"},"text":"Pub. L. 99–646","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/99/654"},"text":"Pub. L. 99–654","children":[],"tail":" amended par. (12) identically, substituting “A felony under chapter 109A of this title” for “Rape”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1949—Pars. (2), (3). Act ","children":[{"tag":"date","attrib":{"date":"1949-05-24"},"text":"May 24, 1949","children":[],"tail":", transferred “indebtedness, bank notes, or other instruments of public” from par. (2) to par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9961a55-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb9961a56-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646"},"text":"Pub. L. 99–646","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/99/654"},"text":"Pub. L. 99–654","children":[],"tail":" effective, respectively, 30 days after "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", and 30 days after "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/646/s87/e"},"text":"section 87(e) of Pub. L. 99–646","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/99/654/s4"},"text":"section 4 of Pub. L. 99–654","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2241"},"text":"section 2241 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
