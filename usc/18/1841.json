{"tag":"section","attrib":{"id":"idb9344b01-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1841"},"text":null,"children":[{"tag":"num","attrib":{"value":"1841"},"text":"§ 1841.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of unborn children","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9344b02-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1841/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9344b03-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1841/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever engages in conduct that violates any of the provisions of law listed in subsection (b) and thereby causes the death of, or bodily injury (as defined in section 1365) to, a child, who is in utero at the time the conduct takes place, is guilty of a separate offense under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9344b04-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1841/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9344b05-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1841/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in this paragraph, the punishment for that separate offense is the same as the punishment provided under Federal law for that conduct had that injury or death occurred to the unborn child’s mother.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9344b06-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1841/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An offense under this section does not require proof that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9344b07-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1841/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person engaging in the conduct had knowledge or should have had knowledge that the victim of the underlying offense was pregnant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9344b08-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1841/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the defendant intended to cause the death of, or bodily injury to, the unborn child.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9344b09-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1841/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the person engaging in the conduct thereby intentionally kills or attempts to kill the unborn child, that person shall instead of being punished under subparagraph (A), be punished as provided under sections 1111, 1112, and 1113 of this title for intentionally killing or attempting to kill a human being.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9344b0a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1841/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, the death penalty shall not be imposed for an offense under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9344b0b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1841/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The provisions referred to in subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9344b0c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1841/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 36, 37, 43, 111, 112, 113, 114, 115, 229, 242, 245, 247, 248, 351, 831, 844(d), (f), (h)(1), and (i), 924(j), 930, 1111, 1112, 1113, 1114, 1116, 1118, 1119, 1120, 1121, 1153(a), 1201(a), 1203, 1365(a), 1501, 1503, 1505, 1512, 1513, 1751, 1864, 1951, 1952 (a)(1)(B), (a)(2)(B), and (a)(3)(B), 1958, 1959, 1992, 2113, 2114, 2116, 2118, 2119, 2191, 2231, 2241(a), 2245, 2261, 2261A, 2280, 2281, 2332, 2332a, 2332b, 2340A, and 2441 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9344b0d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1841/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 408(e) of the Controlled Substances Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s848/e"},"text":"21 U.S.C. 848(e)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9344b0e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1841/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 202 of the Atomic Energy Act of 1954 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2283"},"text":"42 U.S.C. 2283","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9344b0f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1841/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Nothing in this section shall be construed to permit the prosecution—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9344b10-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1841/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of any person for conduct relating to an abortion for which the consent of the pregnant woman, or a person authorized by law to act on her behalf, has been obtained or for which such consent is implied by law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9344b11-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1841/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of any person for any medical treatment of the pregnant woman or her unborn child; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9344b12-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1841/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of any woman with respect to her unborn child.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9344b13-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1841/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As used in this section, the term “unborn child” means a child in utero, and the term “child in utero” or “child, who is in utero” means a member of the species homo sapiens, at any stage of development, who is carried in the womb.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9344b14-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/212/s2/a"},"text":"Pub. L. 108–212, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-04-01"},"text":"Apr. 1, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/568"},"text":"118 Stat. 568","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9344b15-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9344b16-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9344b17-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 202 of the Atomic Energy Act of 1954 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2283"},"text":"42 U.S.C. 2283","children":[],"tail":"), referred to in subsec. (b)(3), probably means section 235 of the Atomic Energy Act of 1954, "},{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724/tI"},"text":"act Aug. 1, 1946, ch. 724, title I","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/96/295/tII/s202/a"},"text":"Pub. L. 96–295, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/786"},"text":"94 Stat. 786","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2283"},"text":"section 2283 of Title 42","children":[],"tail":", The Public Health and Welfare. Section 202 of the Atomic Energy Act of 1954, which related to the authority of the Joint Committee on Atomic Energy, was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2252"},"text":"section 2252 of Title 42","children":[],"tail":" and was repealed by "},{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724/tI/s302/a"},"text":"act Aug. 1, 1946, ch. 724, title I, § 302(a)","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/110/s1"},"text":"Pub. L. 95–110, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-20"},"text":"Sept. 20, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/884"},"text":"91 Stat. 884","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIX/s902/a/8"},"text":"Pub. L. 102–486, title IX, § 902(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2944"},"text":"106 Stat. 2944","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9344b18-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb9344b19-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/212/s1"},"text":"Pub. L. 108–212, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-04-01"},"text":"Apr. 1, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/568"},"text":"118 Stat. 568","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/212/s1"},"text":"“This Act [enacting this chapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s919a"},"text":"section 919a of Title 10","children":[],"tail":", Armed Forces] may be cited as the ‘Unborn Victims of Violence Act of 2004’ or ‘Laci and Conner’s Law’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
