{"tag":"section","attrib":{"id":"idb8d0317f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s510"},"text":null,"children":[{"tag":"num","attrib":{"value":"510"},"text":"§ 510.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forging endorsements on Treasury checks or bonds or securities of the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8d03180-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s510/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whoever, with intent to defraud—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8d03181-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s510/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" falsely makes or forges any endorsement or signature on a Treasury check or bond or security of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d03182-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s510/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" passes, utters, or publishes, or attempts to pass, utter, or publish, any Treasury check or bond or security of the United States bearing a falsely made or forged endorsement or signature;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title or imprisoned not more than ten years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8d03183-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s510/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever, with knowledge that such Treasury check or bond or security of the United States is stolen or bears a falsely made or forged endorsement or signature buys, sells, exchanges, receives, delivers, retains, or conceals any such Treasury check or bond or security of the United States shall be fined under this title or imprisoned not more than ten years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8d03184-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s510/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the face value of the Treasury check or bond or security of the United States or the aggregate face value, if more than one Treasury check or bond or security of the United States, does not exceed $1,000, in any of the above-mentioned offenses, the penalty shall be a fine under this title or imprisonment for not more than one year, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8d03185-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/151/s115/a"},"text":"Pub. L. 98–151, § 115(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-14"},"text":"Nov. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/976"},"text":"97 Stat. 976","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXV/s3514"},"text":"Pub. L. 101–647, title XXXV, § 3514","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4923"},"text":"104 Stat. 4923","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", (L), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI"},"text":"Pub. L. 104–294, title VI","children":[],"tail":", §§ 602(e), 606(b), "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3503"},"text":"110 Stat. 3503","children":[],"tail":", 3511; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dB/tIV/s4002/a/1"},"text":"Pub. L. 107–273, div. B, title IV, § 4002(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1806"},"text":"116 Stat. 1806","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8d03186-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8d03187-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8d03188-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" substituted “fine under this title” for “fine of under this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294/s602/e"},"text":"Pub. L. 104–294, § 602(e)","children":[],"tail":", struck out “that in fact is stolen or bears a forged or falsely made endorsement or signature” after “bond or security of the United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294/s606/b"},"text":"Pub. L. 104–294, § 606(b)","children":[],"tail":", substituted “$1,000” for “$500”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/1/L"},"text":"Pub. L. 103–322, § 330016(1)(L)","children":[],"tail":", substituted “fined under this title” for “fined not more than $10,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/1/H"},"text":"Pub. L. 103–322, § 330016(1)(H)","children":[],"tail":", substituted “fined under this title” for “fined not more than $1,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":" inserted semicolon after “or signature” in par. (2) and moved provisions beginning with “shall be fined” flush with left margin."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
