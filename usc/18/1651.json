{"tag":"section","attrib":{"id":"idb92ad5b0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1651"},"text":null,"children":[{"tag":"num","attrib":{"value":"1651"},"text":"§ 1651.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Piracy under law of nations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, on the high seas, commits the crime of piracy as defined by the law of nations, and is afterwards brought into or found in the United States, shall be imprisoned for life.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb92ad5b1-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/774"},"text":"62 Stat. 774","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92ad5b2-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb92ad5b3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 481 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s290"},"text":"Mar. 4, 1909, ch. 321, § 290","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1145"},"text":"35 Stat. 1145","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
