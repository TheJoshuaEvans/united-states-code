{"tag":"section","attrib":{"id":"idb93de815-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1959"},"text":null,"children":[{"tag":"num","attrib":{"value":"1959"},"text":"§ 1959.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violent crimes in aid of racketeering activity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb93de816-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1959/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whoever, as consideration for the receipt of, or as consideration for a promise or agreement to pay, anything of pecuniary value from an enterprise engaged in racketeering activity, or for the purpose of gaining entrance to or maintaining or increasing position in an enterprise engaged in racketeering activity, murders, kidnaps, maims, assaults with a dangerous weapon, commits assault resulting in serious bodily injury upon, or threatens to commit a crime of violence against any individual in violation of the laws of any State or the United States, or attempts or conspires so to do, shall be punished—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb93de817-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1959/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for murder, by death or life imprisonment, or a fine under this title, or both; and for kidnapping, by imprisonment for any term of years or for life, or a fine under this title, or both;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb93de818-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1959/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for maiming, by imprisonment for not more than thirty years or a fine under this title, or both;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb93de819-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1959/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for assault with a dangerous weapon or assault resulting in serious bodily injury, by imprisonment for not more than twenty years or a fine under this title, or both;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb93de81a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1959/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for threatening to commit a crime of violence, by imprisonment for not more than five years or a fine under this title, or both;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb93de81b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1959/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for attempting or conspiring to commit murder or kidnapping, by imprisonment for not more than ten years or a fine under this title, or both; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb93de81c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1959/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for attempting or conspiring to commit a crime involving maiming, assault with a dangerous weapon, or assault resulting in serious bodily injury, by imprisonment for not more than three years or a fine of ","children":[{"tag":"ref","attrib":{"idref":"fn002130"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002130"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “of” probably should not appear."}],"tail":" under this title, or both."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb93de81d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1959/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb93de81e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1959/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “racketeering activity” has the meaning set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1961"},"text":"section 1961 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb93de81f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1959/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “enterprise” includes any partnership, corporation, association, or other legal entity, and any union or group of individuals associated in fact although not a legal entity, which is engaged in, or the activities of which affect, interstate or foreign commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb93de820-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s1002/a"},"text":"Pub. L. 98–473, title II, § 1002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2137"},"text":"98 Stat. 2137","children":[],"tail":", § 1952B; renumbered § 1959, "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7053/b"},"text":"Pub. L. 100–690, title VII, § 7053(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4402"},"text":"102 Stat. 4402","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tVI/s60003/a/12"},"text":"Pub. L. 103–322, title VI, § 60003(a)(12)","children":[],"tail":", title XXXIII, §§ 330016(1)(J), (2)(C), 330021(1), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1969"},"text":"108 Stat. 1969","children":[],"tail":", 2147, 2148, 2150.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb93de821-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb93de822-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb93de823-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/2/C"},"text":"Pub. L. 103–322, § 330016(2)(C)","children":[],"tail":", substituted “fine under this title” for “fine of not more than $250,000” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s60003/a/12"},"text":"Pub. L. 103–322, § 60003(a)(12)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) for murder or kidnaping, by imprisonment for any term of years or for life or a fine of not more than $50,000, or both;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/2/C"},"text":"Pub. L. 103–322, § 330016(2)(C)","children":[],"tail":", substituted “fine under this title” for “fine of not more than $30,000” in par. (2), “fine of not more than $20,000” in par. (3), and “fine of not more than $5,000” in par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330021/1"},"text":"Pub. L. 103–322, § 330021(1)","children":[],"tail":", substituted “kidnapping” for “kidnaping”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/2/C"},"text":"Pub. L. 103–322, § 330016(2)(C)","children":[],"tail":", substituted “fine under this title” for “fine of not more than $10,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/1/J"},"text":"Pub. L. 103–322, § 330016(1)(J)","children":[],"tail":", substituted “under this title” for “not more than $3,000” after “fine of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1952B"},"text":"section 1952B of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
