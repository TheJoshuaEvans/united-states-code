{"tag":"section","attrib":{"id":"idb9582729-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280"},"text":null,"children":[{"tag":"num","attrib":{"value":"2280"},"text":"§ 2280.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violence against maritime navigation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb958272a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offenses.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb958272b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person who unlawfully and intentionally—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb958272c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seizes or exercises control over a ship by force or threat thereof or any other form of intimidation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb958272d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performs an act of violence against a person on board a ship if that act is likely to endanger the safe navigation of that ship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb958272e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" destroys a ship or causes damage to a ship or to its cargo which is likely to endanger the safe navigation of that ship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb958272f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" places or causes to be placed on a ship, by any means whatsoever, a device or substance which is likely to destroy that ship, or cause damage to that ship or its cargo which endangers or is likely to endanger the safe navigation of that ship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9582730-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" destroys or seriously damages maritime navigational facilities or seriously interferes with their operation, if such act is likely to endanger the safe navigation of a ship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9582731-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communicates information, knowing the information to be false and under circumstances in which such information may reasonably be believed, thereby endangering the safe navigation of a ship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9582732-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" injures or kills any person in connection with the commission or the attempted commission of any of the offenses set forth in subparagraphs (A) through (F); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9582733-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attempts or conspires to do any act prohibited under subparagraphs (A) through (G),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title, imprisoned not more than 20 years, or both; and if the death of any person results from conduct prohibited by this paragraph, shall be punished by death or imprisoned for any term of years or for life.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9582734-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Threat to navigation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person who threatens to do any act prohibited under paragraph (1)(B), (C) or (E), with apparent determination and will to carry the threat into execution, if the threatened act is likely to endanger the safe navigation of the ship in question, shall be fined under this title, imprisoned not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9582735-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is jurisdiction over the activity prohibited in subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9582736-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a covered ship, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9582737-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such activity is committed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9582738-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" against or on board a vessel of the United States or a vessel subject to the jurisdiction of the United States (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70502"},"text":"section 70502 of title 46","children":[],"tail":") at the time the prohibited activity is committed;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9582739-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the United States, including the territorial seas; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb958273a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a national of the United States, by a United States corporation or legal entity, or by a stateless person whose habitual residence is in the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb958273b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the commission of such activity, a national of the United States is seized, threatened, injured or killed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb958273c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offender is later found in the United States after such activity is committed;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb958273d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a ship navigating or scheduled to navigate solely within the territorial sea or internal waters of a country other than the United States, if the offender is later found in the United States after such activity is committed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb958273e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any vessel, if such activity is committed in an attempt to compel the United States to do or abstain from doing any act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb958273f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bar To Prosecution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It is a bar to Federal prosecution under subsection (a) for conduct that occurred within the United States that the conduct involved was during or in relation to a labor dispute, and such conduct is prohibited as a felony under the law of the State in which it was committed. For purposes of this section, the term “labor dispute” has the meaning set forth in section 13(c) of the Norris-LaGuardia Act, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s113/c"},"text":"29 U.S.C. 113(c)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9582740-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section, section 2280a, section 2281, and section 2281a, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9582741-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “applicable treaty” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9582742-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Convention for the Suppression of Unlawful Seizure of Aircraft, done at The Hague on 16 December 1970;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9582743-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Convention for the Suppression of Unlawful Acts against the Safety of Civil Aviation, done at Montreal on 23 September 1971;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9582744-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Convention on the Prevention and Punishment of Crimes against Internationally Protected Persons, including Diplomatic Agents, adopted by the General Assembly of the United Nations on 14 December 1973;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9582745-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" International Convention against the Taking of Hostages, adopted by the General Assembly of the United Nations on 17 December 1979;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9582746-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Convention on the Physical Protection of Nuclear Material, done at Vienna on 26 October 1979;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9582747-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Protocol for the Suppression of Unlawful Acts of Violence at Airports Serving International Civil Aviation, supplementary to the Convention for the Suppression of Unlawful Acts against the Safety of Civil Aviation, done at Montreal on 24 February 1988;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9582748-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Protocol for the Suppression of Unlawful Acts against the Safety of Fixed Platforms Located on the Continental Shelf, done at Rome on 10 March 1988;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9582749-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" International Convention for the Suppression of Terrorist Bombings, adopted by the General Assembly of the United Nations on 15 December 1997; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb958274a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" International Convention for the Suppression of the Financing of Terrorism, adopted by the General Assembly of the United Nations on 9 December 1999;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb958274b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “armed conflict” does not include internal disturbances and tensions, such as riots, isolated and sporadic acts of violence, and other acts of a similar nature;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb958274c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “biological weapon” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb958274d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" microbial or other biological agents, or toxins whatever their origin or method of production, of types and in quantities that have no justification for prophylactic, protective, or other peaceful purposes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb958274e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" weapons, equipment, or means of delivery designed to use such agents or toxins for hostile purposes or in armed conflict;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb958274f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “chemical weapon” means, together or separately—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9582750-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" toxic chemicals and their precursors, except where intended for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9582751-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" industrial, agricultural, research, medical, pharmaceutical, or other peaceful purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9582752-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protective purposes, namely those purposes directly related to protection against toxic chemicals and to protection against chemical weapons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9582753-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" military purposes not connected with the use of chemical weapons and not dependent on the use of the toxic properties of chemicals as a method of warfare; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9582754-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" law enforcement including domestic riot control purposes,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"as long as the types and quantities are consistent with such purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9582755-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" munitions and devices, specifically designed to cause death or other harm through the toxic properties of those toxic chemicals specified in subparagraph (A), which would be released as a result of the employment of such munitions and devices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9582756-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any equipment specifically designed for use directly in connection with the employment of munitions and devices specified in subparagraph (B);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9582757-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “covered ship” means a ship that is navigating or is scheduled to navigate into, through or from waters beyond the outer limit of the territorial sea of a single country or a lateral limit of that country’s territorial sea with an adjacent country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9582758-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “explosive material” has the meaning given the term in section 841(c) and includes explosive as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s844/j"},"text":"section 844(j) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9582759-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “infrastructure facility” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2332f/e/5"},"text":"section 2332f(e)(5) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb958275a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “international organization” has the meaning given the term in section 831(f)(3) ","children":[{"tag":"ref","attrib":{"idref":"fn002169"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002169"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb958275b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “military forces of a state” means the armed forces of a state which are organized, trained, and equipped under its internal law for the primary purpose of national defense or security, and persons acting in support of those armed forces who are under their formal command, control, and responsibility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb958275c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “national of the United States” has the meaning stated in section 101(a)(22) of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/22"},"text":"8 U.S.C. 1101(a)(22)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb958275d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Non-Proliferation Treaty” means the Treaty on the Non-Proliferation of Nuclear Weapons, done at Washington, London, and Moscow on 1 July 1968;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb958275e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Non-Proliferation Treaty State Party” means any State Party to the Non-Proliferation Treaty, to include Taiwan, which shall be considered to have the obligations under the Non-Proliferation Treaty of a party to that treaty other than a Nuclear Weapon State Party to the Non-Proliferation Treaty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb958275f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Nuclear Weapon State Party to the Non-Proliferation Treaty” means a State Party to the Non-Proliferation Treaty that is a nuclear-weapon State, as that term is defined in Article IX(3) of the Non-Proliferation Treaty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9582760-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “place of public use” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2332f/e/6"},"text":"section 2332f(e)(6) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9582761-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “precursor” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s229F/6/A"},"text":"section 229F(6)(A) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9582762-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “public transport system” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2332f/e/7"},"text":"section 2332f(e)(7) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9582763-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “serious injury or damage” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9582764-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/17/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serious bodily injury,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9582765-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/17/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extensive destruction of a place of public use, State or government facility, infrastructure facility, or public transportation system, resulting in major economic loss, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9582766-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/17/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantial damage to the environment, including air, soil, water, fauna, or flora;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9582767-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “ship” means a vessel of any type whatsoever not permanently attached to the sea-bed, including dynamically supported craft, submersibles, or any other floating craft, but does not include a warship, a ship owned or operated by a government when being used as a naval auxiliary or for customs or police purposes, or a ship which has been withdrawn from navigation or laid up;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9582768-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “source material” has the meaning given that term in the International Atomic Energy Agency Statute, done at New York on 26 October 1956;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9582769-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “special fissionable material” has the meaning given that term in the International Atomic Energy Agency Statute, done at New York on 26 October 1956;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb958276a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “territorial sea of the United States” means all waters extending seaward to 12 nautical miles from the baselines of the United States determined in accordance with international law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb958276b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “toxic chemical” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s229F/8/A"},"text":"section 229F(8)(A) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb958276c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/23"},"text":null,"children":[{"tag":"num","attrib":{"value":"23"},"text":"(23)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “transport” means to initiate, arrange or exercise effective control, including decisionmaking authority, over the movement of a person or item; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb958276d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/d/24"},"text":null,"children":[{"tag":"num","attrib":{"value":"24"},"text":"(24)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “United States”, when used in a geographical sense, includes the Commonwealth of Puerto Rico, the Commonwealth of the Northern Mariana Islands, and all territories and possessions of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb958276e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb958276f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities of armed forces during an armed conflict, as those terms are understood under the law of war, which are governed by that law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9582770-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities undertaken by military forces of a state in the exercise of their official duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9582771-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delivery of Suspected Offender","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The master of a covered ship flying the flag of the United States who has reasonable grounds to believe that there is on board that ship any person who has committed an offense under section 2280 or section 2280a may deliver such person to the authorities of a country that is a party to the Convention for the Suppression of Unlawful Acts against the Safety of Maritime Navigation. Before delivering such person to the authorities of another country, the master shall notify in an appropriate manner the Attorney General of the United States of the alleged offense and await instructions from the Attorney General as to what action to take. When delivering the person to a country which is a state party to the Convention, the master shall, whenever practicable, and if possible before entering the territorial sea of such country, notify the authorities of such country of the master’s intention to deliver such person and the reasons therefor. If the master delivers such person, the master shall furnish to the authorities of such country the evidence in the master’s possession that pertains to the alleged offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9582772-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9582773-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Forfeiture","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any real or personal property used or intended to be used to commit or to facilitate the commission of a violation of this section, the gross proceeds of such violation, and any real or personal property traceable to such property or proceeds, shall be subject to forfeiture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9582774-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2280/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicable Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Seizures and forfeitures under this section shall be governed by the provisions of chapter 46 of title 18, United States Code, relating to civil forfeitures, except that such duties as are imposed upon the Secretary of the Treasury under the customs laws described in section 981(d) shall be performed by such officers, agents, and other persons as may be designated for that purpose by the Secretary of Homeland Security, the Attorney General, or the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9582775-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tVI/s60019/a"},"text":"Pub. L. 103–322, title VI, § 60019(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1975"},"text":"108 Stat. 1975","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tVII"},"text":"Pub. L. 104–132, title VII","children":[],"tail":", §§ 722, 723(a)(1), "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1299"},"text":"110 Stat. 1299","children":[],"tail":", 1300; "},{"tag":"ref","attrib":{"href":"/us/pl/114/23/tVIII/s801"},"text":"Pub. L. 114–23, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-02"},"text":"June 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/300"},"text":"129 Stat. 300","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9582776-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9582777-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9582778-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s831/f/3"},"text":"Section 831(f)(3) of this title","children":[],"tail":", referred to in subsec. (d)(8), was redesignated section 831(g)(3) by "},{"tag":"ref","attrib":{"href":"/us/pl/114/23/tVIII/s812/d"},"text":"Pub. L. 114–23, title VIII, § 812(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-02"},"text":"June 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/312"},"text":"129 Stat. 312","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9582779-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (b)(1)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s801/1/A"},"text":"Pub. L. 114–23, § 801(1)(A)","children":[],"tail":", substituted “a vessel of the United States or a vessel subject to the jurisdiction of the United States (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s70502"},"text":"section 70502 of title 46","children":[],"tail":")” for “a ship flying the flag of the United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s801/1/B"},"text":"Pub. L. 114–23, § 801(1)(B)","children":[],"tail":", inserted “, including the territorial seas” before semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s801/1/C"},"text":"Pub. L. 114–23, § 801(1)(C)","children":[],"tail":", inserted “, by a United States corporation or legal entity,” after “by a national of the United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s801/2"},"text":"Pub. L. 114–23, § 801(2)","children":[],"tail":", substituted “section 13(c)” for “section 2(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/s801/3"},"text":"Pub. L. 114–23, § 801(3)","children":[],"tail":"–(5), added subsecs. (d) to (g) and struck out former subsecs. (d) and (e) which related to delivery of suspected offender and definitions, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s723/a/1"},"text":"Pub. L. 104–132, § 723(a)(1)","children":[],"tail":", inserted “or conspires” after “attempts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s722/1"},"text":"Pub. L. 104–132, § 722(1)","children":[],"tail":", struck out “and the activity is not prohibited as a crime by the State in which the activity takes place” after “the United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s722/2"},"text":"