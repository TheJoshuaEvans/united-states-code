{"tag":"section","attrib":{"id":"idb9619c61-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2321"},"text":null,"children":[{"tag":"num","attrib":{"value":"2321"},"text":"§ 2321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trafficking in certain motor vehicles or motor vehicle parts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9619c62-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2321/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever buys, receives, possesses, or obtains control of, with intent to sell or otherwise dispose of, a motor vehicle or motor vehicle part, knowing that an identification number for such motor vehicle or part has been removed, obliterated, tampered with, or altered, shall be fined under this title or imprisoned not more than ten years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9619c63-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2321/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subsection (a) does not apply if the removal, obliteration, tampering, or alteration—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9619c64-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2321/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is caused by collision or fire; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9619c65-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2321/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s511"},"text":"section 511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9619c66-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2321/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As used in this section, the terms “identification number” and “motor vehicle” have the meaning given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s511"},"text":"section 511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9619c67-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/547/tII/s204/a"},"text":"Pub. L. 98–547, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-25"},"text":"Oct. 25, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2770"},"text":"98 Stat. 2770","children":[],"tail":", § 2320; renumbered § 2321, "},{"tag":"ref","attrib":{"href":"/us/pl/99/646/s42/a"},"text":"Pub. L. 99–646, § 42(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3601"},"text":"100 Stat. 3601","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/N"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(N)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2148"},"text":"108 Stat. 2148","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9619c68-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9619c69-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9619c6a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $20,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
