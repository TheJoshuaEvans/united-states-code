{"tag":"section","attrib":{"id":"idb9961aa3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3235"},"text":null,"children":[{"tag":"num","attrib":{"value":"3235"},"text":"§ 3235.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venue in capital cases","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The trial of offenses punishable with death shall be had in the county where the offense was committed, where that can be done without great inconvenience.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9961aa4-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/826"},"text":"62 Stat. 826","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9961aa5-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9961aa6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s101"},"text":"section 101 of title 28","children":[],"tail":", U.S.C., 1940 ed., Judicial Code and Judiciary ("},{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s40"},"text":"Mar. 3, 1911, ch. 231, § 40","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1100"},"text":"36 Stat. 1100","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
