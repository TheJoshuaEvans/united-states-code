{"tag":"section","attrib":{"id":"idb8aec7b0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s119"},"text":null,"children":[{"tag":"num","attrib":{"value":"119"},"text":"§ 119.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of individuals performing certain official duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8aec7b1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s119/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever knowingly makes restricted personal information about a covered person, or a member of the immediate family of that covered person, publicly available—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8aec7b2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s119/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the intent to threaten, intimidate, or incite the commission of a crime of violence against that covered person, or a member of the immediate family of that covered person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8aec7b3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s119/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the intent and knowledge that the restricted personal information will be used to threaten, intimidate, or facilitate the commission of a crime of violence against that covered person, or a member of the immediate family of that covered person,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title, imprisoned not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8aec7b4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s119/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8aec7b5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s119/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “restricted personal information” means, with respect to an individual, the Social Security number, the home address, home phone number, mobile phone number, personal email, or home fax number of, and identifiable to, that individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8aec7b6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s119/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “covered person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8aec7b7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s119/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual designated in section 1114;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8aec7b8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s119/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a grand or petit juror, witness, or other officer in or of, any court of the United States, or an officer who may be, or was, serving at any examination or other proceeding before any United States magistrate judge or other committing magistrate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8aec7b9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s119/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an informant or witness in a Federal criminal investigation or prosecution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8aec7ba-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s119/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State or local officer or employee whose restricted personal information is made publicly available because of the participation in, or assistance provided to, a Federal criminal investigation by that officer or employee;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8aec7bb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s119/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “crime of violence” has the meaning given the term in section 16; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8aec7bc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s119/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “immediate family” has the meaning given the term in section 115(c)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8aec7bd-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/177/tII/s202/a"},"text":"Pub. L. 110–177, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-07"},"text":"Jan. 7, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2536"},"text":"121 Stat. 2536","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
