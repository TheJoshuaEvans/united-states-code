{"tag":"section","attrib":{"id":"idb8c69584-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s335"},"text":null,"children":[{"tag":"num","attrib":{"value":"335"},"text":"§ 335.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Circulation of obligations of expired corporations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being a director, officer, or agent of a corporation created by Act of Congress, the charter of which has expired, or trustee thereof, or an agent of such trustee, or a person having in his possession or under his control the property of such corporation for the purpose of paying or redeeming its notes and obligations, knowingly issues, reissues, or utters as money, or in any other way knowingly puts in circulation any bill, note, check, draft, or other security purporting to have been made by any such corporation, or by any officer thereof, or purporting to have been made under authority derived therefrom, shall be fined under this title or imprisoned not more than five years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8c69585-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/700"},"text":"62 Stat. 700","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/L"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(L)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c69586-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8c69587-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 289 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s174"},"text":"Mar. 4, 1909, ch. 321, § 174","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1122"},"text":"35 Stat. 1122","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The reference to persons aiding was omitted as unnecessary, since such persons are made principals by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The last sentence excepting bona fide holders in due course was omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Other changes in phraseology also were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8c69588-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8c69589-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $10,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
