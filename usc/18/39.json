{"tag":"section","attrib":{"id":"idb8a79b47-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s39"},"text":null,"children":[{"tag":"num","attrib":{"value":"39"},"text":"§ 39.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Traffic signal preemption transmitters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8a79b48-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s39/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offenses.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a79b49-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s39/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sale","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever, in or affecting interstate or foreign commerce, knowingly sells a traffic signal preemption transmitter to a nonqualifying user shall be fined under this title, or imprisoned not more than 1 year, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a79b4a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s39/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever, in or affecting interstate or foreign commerce, being a nonqualifying user makes unauthorized use of a traffic signal preemption transmitter shall be fined under this title, or imprisoned not more than 6 months, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a79b4b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s39/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a79b4c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s39/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Traffic signal preemption transmitter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “traffic signal preemption transmitter” means any mechanism that can change or alter a traffic signal’s phase time or sequence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a79b4d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s39/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonqualifying user","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “nonqualifying user” means a person who uses a traffic signal preemption transmitter and is not acting on behalf of a public agency or private corporation authorized by law to provide fire protection, law enforcement, emergency medical services, transit services, maintenance, or other services for a Federal, State, or local government entity, but does not include a person using a traffic signal preemption transmitter for classroom or instructional purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8a79b4e-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tII/s2018/a"},"text":"Pub. L. 109–59, title II, § 2018(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1542"},"text":"119 Stat. 1542","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8a79b4f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8a79b50-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb8a79b51-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 39 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s40"},"text":"section 40 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
