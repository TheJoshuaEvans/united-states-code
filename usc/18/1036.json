{"tag":"section","attrib":{"id":"idb91096ef-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1036"},"text":null,"children":[{"tag":"num","attrib":{"value":"1036"},"text":"§ 1036.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entry by false pretenses to any real property, vessel, or aircraft of the United States or secure area of any airport or seaport","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb91096f0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1036/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whoever, by any fraud or false pretense, enters or attempts to enter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91096f1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1036/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any real property belonging in whole or in part to, or leased by, the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91096f2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1036/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any vessel or aircraft belonging in whole or in part to, or leased by, the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91096f3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1036/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any secure or restricted area of any seaport, designated as secure in an approved security plan, as required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70103"},"text":"section 70103 of title 46","children":[],"tail":", United States Code, and the rules and regulations promulgated under that section; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91096f4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1036/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any secure area of any airport,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished as provided in subsection (b) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91096f5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1036/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The punishment for an offense under subsection (a) of this section is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91096f6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1036/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fine under this title or imprisonment for not more than 10 years, or both, if the offense is committed with the intent to commit a felony; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91096f7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1036/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fine under this title or imprisonment for not more than 6 months, or both, in any other case.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91096f8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1036/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91096f9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1036/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “secure area” means an area access to which is restricted by the airport authority, captain of the seaport, or a public agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91096fa-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1036/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “airport” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47102"},"text":"section 47102 of title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb91096fb-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/547/s2/a"},"text":"Pub. L. 106–547, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-19"},"text":"Dec. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2738"},"text":"114 Stat. 2738","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/tIII/s302/a"},"text":"Pub. L. 109–177, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/233"},"text":"120 Stat. 233","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91096fc-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb91096fd-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb91096fe-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s302/a/4"},"text":"Pub. L. 109–177, § 302(a)(4)","children":[],"tail":", substituted “any airport or seaport” for “any airport” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s302/a/1"},"text":"Pub. L. 109–177, § 302(a)(1)","children":[],"tail":", added par. (3) and redesignated former par. (3) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s302/a/2"},"text":"Pub. L. 109–177, § 302(a)(2)","children":[],"tail":", substituted “10 years” for “5 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s302/a/3"},"text":"Pub. L. 109–177, § 302(a)(3)","children":[],"tail":", inserted “, captain of the seaport,” after “airport authority”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
