{"tag":"section","attrib":{"id":"idb91c7d14-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1345"},"text":null,"children":[{"tag":"num","attrib":{"value":"1345"},"text":"§ 1345.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunctions against fraud","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb91c7d15-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1345/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91c7d16-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1345/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If a person is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb91c7d17-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1345/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" violating or about to violate this chapter or section 287, 371 (insofar as such violation involves a conspiracy to defraud the United States or any agency thereof), or 1001 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91c7d18-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1345/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" committing or about to commit a banking law violation (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3322/d"},"text":"section 3322(d) of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91c7d19-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1345/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" committing or about to commit a Federal health care offense;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Attorney General may commence a civil action in any Federal court to enjoin such violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91c7d1a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1345/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If a person is alienating or disposing of property, or intends to alienate or dispose of property, obtained as a result of a banking law violation (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3322/d"},"text":"section 3322(d) of this title","children":[],"tail":") or a Federal health care offense or property which is traceable to such violation, the Attorney General may commence a civil action in any Federal court—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb91c7d1b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1345/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enjoin such alienation or disposition of property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91c7d1c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1345/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for a restraining order to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb91c7d1d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1345/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibit any person from withdrawing, transferring, removing, dissipating, or disposing of any such property or property of equivalent value; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb91c7d1e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1345/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint a temporary receiver to administer such restraining order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91c7d1f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1345/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A permanent or temporary injunction or restraining order shall be granted without bond.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91c7d20-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1345/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The court shall proceed as soon as practicable to the hearing and determination of such an action, and may, at any time before final determination, enter such a restraining order or prohibition, or take such other action, as is warranted to prevent a continuing and substantial injury to the United States or to any person or class of persons for whose protection the action is brought. A proceeding under this section is governed by the Federal Rules of Civil Procedure, except that, if an indictment has been returned against the respondent, discovery is governed by the Federal Rules of Criminal Procedure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb91c7d21-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s1205/a"},"text":"Pub. L. 98–473, title II, § 1205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2152"},"text":"98 Stat. 2152","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7077"},"text":"Pub. L. 100–690, title VII, § 7077","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4406"},"text":"102 Stat. 4406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV/s2521/b/2"},"text":"Pub. L. 101–647, title XXV, § 2521(b)(2)","children":[],"tail":", title XXXV, § 3542, "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4865"},"text":"104 Stat. 4865","children":[],"tail":", 4925; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330011/k"},"text":"Pub. L. 103–322, title XXXIII, § 330011(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2145"},"text":"108 Stat. 2145","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/tII/s247"},"text":"Pub. L. 104–191, title II, § 247","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2018"},"text":"110 Stat. 2018","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dB/tIV/s4002/b/14"},"text":"Pub. L. 107–273, div. B, title IV, § 4002(b)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1808"},"text":"116 Stat. 1808","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91c7d22-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb91c7d23-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb91c7d24-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Civil Procedure, referred to in subsec. (b), are set out in the Appendix to Title 28, Judiciary and Judicial Procedure.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Rules of Criminal Procedure, referred to in subsec. (b), are set out in the Appendix to this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb91c7d25-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s4002/b/14/A"},"text":"Pub. L. 107–273, § 4002(b)(14)(A)","children":[],"tail":", substituted “; or” for “, or” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s4002/b/14/B"},"text":"Pub. L. 107–273, § 4002(b)(14)(B)","children":[],"tail":", substituted semicolon for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/s247/a"},"text":"Pub. L. 104–191, § 247(a)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/s247/b"},"text":"Pub. L. 104–191, § 247(b)","children":[],"tail":", inserted “or a Federal health care offense” after “title)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330011/k"},"text":"Pub. L. 103–322, § 330011(k)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/s3542"},"text":"Pub. L. 101–647, § 3542","children":[],"tail":". See 1990 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/s2521/b/2"},"text":"Pub. L. 101–647, § 2521(b)(2)","children":[],"tail":", added subsec. (a), inserted subsec. (b) designation, and struck out former first sentence which read as follows: “Whenever it shall appear that any person is engaged or is about to engage in any act which constitutes or will constitute a violation of this chapter, or of section 287, 371 (insofar as such violation involves a conspiracy to defraud the United States or any agency thereof), or 1001 of this title the Attorney General may initiate a civil proceeding in a district court of the United States to enjoin such violation.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/s3542"},"text":"Pub. L. 101–647, § 3542","children":[],"tail":", which directed insertion of a comma after “of this title”, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330011/k"},"text":"Pub. L. 103–322, § 330011(k)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" inserted “or of section 287, 371 (insofar as such violation involves a conspiracy to defraud the United States or any agency thereof), or 1001 of this title” after “violation of this chapter,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb91c7d26-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb91c7d27-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330011/k"},"text":"Pub. L. 103–322, title XXXIII, § 330011(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2145"},"text":"108 Stat. 2145","children":[],"tail":", provided that the amendment made by that section is effective "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
