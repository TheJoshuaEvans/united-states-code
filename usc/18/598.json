{"tag":"section","attrib":{"id":"idb8d2a3b4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s598"},"text":null,"children":[{"tag":"num","attrib":{"value":"598"},"text":"§ 598.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coercion by means of relief appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever uses any part of any appropriation made by Congress for work relief, relief, or for increasing employment by providing loans and grants for public-works projects, or exercises or administers any authority conferred by any Appropriation Act for the purpose of interfering with, restraining, or coercing any individual in the exercise of his right to vote at any election, shall be fined under this title or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8d2a3b5-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/721"},"text":"62 Stat. 721","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8d2a3b6-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8d2a3b7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., §§ 61f, 61g (","children":[{"tag":"date","attrib":{"date":"1939-08-02"},"text":"Aug. 2, 1939","children":[],"tail":", 11:50 a.m., E.S.T., ch. 410. §§ 7, 8, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1148"},"text":"53 Stat. 1148","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section consolidates sections 61f and 61g of title 18, U.S.C., 1940 ed., with changes of phraseology necessary to effect consolidation.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The punishment provision was derived from ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s61g"},"text":"section 61g of title 18","children":[],"tail":", U.S.C., 1940 ed., which, by reference, was made applicable to this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8d2a3b8-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8d2a3b9-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $1,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
