{"tag":"section","attrib":{"id":"idb91a0caf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1302"},"text":null,"children":[{"tag":"num","attrib":{"value":"1302"},"text":"§ 1302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mailing lottery tickets or related matter","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever knowingly deposits in the mail, or sends or delivers by mail:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Any letter, package, postal card, or circular concerning any lottery, gift enterprise, or similar scheme offering prizes dependent in whole or in part upon lot or chance;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Any lottery ticket or part thereof, or paper, certificate, or instrument purporting to be or to represent a ticket, chance, share, or interest in or dependent upon the event of a lottery, gift enterprise, or similar scheme offering prizes dependent in whole or in part upon lot or chance;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Any check, draft, bill, money, postal note, or money order, for the purchase of any ticket or part thereof, or of any share or chance in any such lottery, gift enterprise, or scheme;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Any newspaper, circular, pamphlet, or publication of any kind containing any advertisement of any lottery, gift enterprise, or scheme of any kind offering prizes dependent in whole or in part upon lot or chance, or containing any list of the prizes drawn or awarded by means of any such lottery, gift enterprise, or scheme, whether said list contains any part or all of such prizes;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Any article described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1953"},"text":"section 1953 of this title","children":[],"tail":"—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Shall be fined under this title or imprisoned not more than two years, or both; and for any subsequent offense shall be imprisoned not more than five years.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb91a0cb0-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/762"},"text":"62 Stat. 762","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1951-10-31/ch655/s29"},"text":"Oct. 31, 1951, ch. 655, § 29","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/721"},"text":"65 Stat. 721","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/218/s2"},"text":"Pub. L. 87–218, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-13"},"text":"Sept. 13, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/492"},"text":"75 Stat. 492","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91a0cb1-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb91a0cb2-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 336 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s213"},"text":"Mar. 4, 1909, ch. 321, § 213","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1129"},"