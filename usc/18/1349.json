{"tag":"section","attrib":{"id":"idb91c7d3a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1349"},"text":null,"children":[{"tag":"num","attrib":{"value":"1349"},"text":"§ 1349.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attempt and conspiracy","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person who attempts or conspires to commit any offense under this chapter shall be subject to the same penalties as those prescribed for the offense, the commission of which was the object of the attempt or conspiracy.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb91c7d3b-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204/tIX/s902/a"},"text":"Pub. L. 107–204, title IX, § 902(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/805"},"text":"116 Stat. 805","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
