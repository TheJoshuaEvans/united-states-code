{"tag":"section","attrib":{"id":"idb8cb777f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s474A"},"text":null,"children":[{"tag":"num","attrib":{"value":"474A"},"text":"§ 474A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deterrents to counterfeiting of obligations and securities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8cb7780-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s474A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever has in his control or possession, after a distinctive paper has been adopted by the Secretary of the Treasury for the obligations and other securities of the United States, any similar paper adapted to the making of any such obligation or other security, except under the authority of the Secretary of the Treasury, is guilty of a class B felony.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8cb7781-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s474A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever has in his control or possession, after a distinctive counterfeit deterrent has been adopted by the Secretary of the Treasury for the obligations and other securities of the United States by publication in the Federal Register, any essentially identical feature or device adapted to the making of any such obligation or security, except under the authority of the Secretary of the Treasury, is guilty of a class B felony.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8cb7782-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s474A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8cb7783-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s474A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “distinctive paper” includes any distinctive medium of which currency is made, whether of wood pulp, rag, plastic substrate, or other natural or artificial fibers or materials; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8cb7784-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s474A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “distinctive counterfeit deterrent” includes any ink, watermark, seal, security thread, optically variable device, or other feature or device;","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8cb7785-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s474A/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which the United States has an exclusive property interest; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8cb7786-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s474A/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is not otherwise in commercial use or in the public domain and which the Secretary designates as being necessary in preventing the counterfeiting of obligations or other securities of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8cb7787-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXV/s1553/a"},"text":"Pub. L. 102–550, title XV, § 1553(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4070"},"text":"106 Stat. 4070","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/f/tVI/s648/a"},"text":"Pub. L. 104–208, div. A, title I, § 101(f) [title VI, § 648(a)]","children":[],"tail":", title II, § 2603(a), "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-314"},"text":"110 Stat. 3009–314","children":[],"tail":", 3009–367, 3009–470.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8cb7788-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8cb7789-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8cb778a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":", §§ 101(f) [title VI, § 648(a)] and 2603(a), amended section identically, substituting “class B felony” for “class C felony”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8cb778b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8cb778c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", and to remain in effect for each fiscal year following "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", see section 101(f) [title VI, § 648(c)] of "},{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s474"},"text":"section 474 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
