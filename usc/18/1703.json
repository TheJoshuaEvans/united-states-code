{"tag":"section","attrib":{"id":"idb92d1f2f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1703"},"text":null,"children":[{"tag":"num","attrib":{"value":"1703"},"text":"§ 1703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delay or destruction of mail or newspapers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb92d1f30-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever, being a Postal Service officer or employee, unlawfully secretes, destroys, detains, delays, or opens any letter, postal card, package, bag, or mail entrusted to him or which shall come into his possession, and which was intended to be conveyed by mail, or carried or delivered by any carrier or other employee of the Postal Service, or forwarded through or delivered from any post office or station thereof established by authority of the Postmaster General or the Postal Service, shall be fined under this title or imprisoned not more than five years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92d1f31-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever, being a Postal Service officer or employee, improperly detains, delays, or destroys any newspaper, or permits any other person to detain, delay, or destroy the same, or opens, or permits any other person to open, any mail or package of newspapers not directed to the office where he is employed; or","children":[{"tag":"p","attrib":{},"text":"Whoever, without authority, opens, or destroys any mail or package of newspapers not directed to him, shall be fined under this title or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb92d1f32-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/778"},"text":"62 Stat. 778","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-05-24/ch139/s37"},"text":"May 24, 1949, ch. 139, § 37","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/95"},"text":"63 Stat. 95","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s6/j/16"},"text":"Pub. L. 91–375, § 6(j)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/778"},"text":"84 Stat. 778","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/B"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(B)","children":[],"tail":", (G), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2146"},"text":"108 Stat. 2146","children":[],"tail":", 2147.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92d1f33-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb92d1f34-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb92d1f35-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1948 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., §§ 318, 319 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321"},"text":"Mar. 4, 1909, ch. 321","children":[],"tail":", §§ 195, 196, "},{"tag":"ref","attrib":{"href":"/us/stat/35/1125"},"text":"35 Stat. 1125","children":[],"tail":", 1126)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section consolidated sections 318 and 319 of said title 18, U.S.C., 1940 ed. The embezzlement and theft provisions of each were incorporated in sections 1709 and 1710 of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb92d1f36-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1949 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This section [section 37] corrects typographical errors in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1703"},"text":"section 1703 of title 18","children":[],"tail":", U.S.C."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92d1f37-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92d1f38-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $500” in subsec. (a) and “fined under this title” for “fined not more than $100” in last par."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375/s6/j/16/A"},"text":"Pub. L. 91–375, § 6(j)(16)(A)","children":[],"tail":", amended subsec. (a) generally, which prior to amendment read as follows: “Whoever, being a postmaster or Postal Service employee, unlawfully detains, delays, or opens any letter, postal card, package, bag, or mail intrusted to him or which shall come into his possession, and which was intended to be conveyed by mail, or carried or delivered by any carrier or other employee of the Postal Service, or forwarded through or delivered from any post office or station thereof established by authority of the Postmaster General; or secretes, or destroys any such letter, postal card, package, bag, or mail, shall be fined not more than $500 or imprisoned not more than five years, or both.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375/s6/j/16/B"},"text":"Pub. L. 91–375, § 6(j)(16)(B)","children":[],"tail":", substituted “Postal Service officer or employee” for “postmaster or Postal Service employee”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1949—Subsec. (a). Act ","children":[{"tag":"date","attrib":{"date":"1949-05-24"},"text":"May 24, 1949","children":[],"tail":", § 37(a), substituted “secretes” for “secrets”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). Act ","children":[{"tag":"date","attrib":{"date":"1949-05-24"},"text":"May 24, 1949","children":[],"tail":", § 37(b), substituted “newspapers” for “newspaper”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb92d1f39-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb92d1f3a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":" effective within 1 year after "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", on date established therefor by Board of Governors of United States Postal Service and published by it in Federal Register, see "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as an Effective Date note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of Title 39","children":[],"tail":", Postal Service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
