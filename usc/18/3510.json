{"tag":"section","attrib":{"id":"idb9a20114-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3510"},"text":null,"children":[{"tag":"num","attrib":{"value":"3510"},"text":"§ 3510.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights of victims to attend and observe trial","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9a20115-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3510/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Non-Capital Cases","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any statute, rule, or other provision of law, a United States district court shall not order any victim of an offense excluded from the trial of a defendant accused of that offense because such victim may, during the sentencing hearing, make a statement or present any information in relation to the sentence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9a20116-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3510/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Capital Cases","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any statute, rule, or other provision of law, a United States district court shall not order any victim of an offense excluded from the trial of a defendant accused of that offense because such victim may, during the sentencing hearing, testify as to the effect of the offense on the victim and the victim’s family or as to any other factor for which notice is required under section 3593(a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9a20117-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3510/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As used in this section, the term “victim” includes all persons defined as victims in section 503(e)(2) of the Victims’ Rights and Restitution Act of 1990.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9a20118-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/6/s2/a"},"text":"Pub. L. 105–6, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-03-19"},"text":"Mar. 19, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/12"},"text":"111 Stat. 12","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9a20119-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9a2011a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9a2011b-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 503(e)(2) of the Victims’ Rights and Restitution Act of 1990, referred to in subsec. (c), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20141/e/2"},"text":"section 20141(e)(2) of Title 34","children":[],"tail":", Crime Control and Law Enforcement."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9a2011c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9a2011d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/6/s2/d"},"text":"Pub. L. 105–6, § 2(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-03-19"},"text":"Mar. 19, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/13"},"text":"111 Stat. 13","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/6/s2/d"},"text":"“The amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3593"},"text":"section 3593 of this title","children":[],"tail":"] shall apply in cases pending on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1997-03-19"},"text":"Mar. 19, 1997","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
