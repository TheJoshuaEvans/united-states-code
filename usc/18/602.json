{"tag":"section","attrib":{"id":"idb8d2a3d5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s602"},"text":null,"children":[{"tag":"num","attrib":{"value":"602"},"text":"§ 602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitation of political contributions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8d2a3d6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s602/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" It shall be unlawful for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8d2a3d7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s602/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a candidate for the Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d2a3d8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s602/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual elected to or serving in the office of Senator or Representative in, or Delegate or Resident Commissioner to, the Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d2a3d9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s602/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer or employee of the United States or any department or agency thereof; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d2a3da-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s602/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person receiving any salary or compensation for services from money derived from the Treasury of the United States; to knowingly solicit any contribution within the meaning of section 301(8) of the Federal Election Campaign Act of 1971 from any other such officer, employee, or person. Any person who violates this section shall be fined under this title or imprisoned not more than 3 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8d2a3db-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s602/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The prohibition in subsection (a) shall not apply to any activity of an employee (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7322/1"},"text":"section 7322(1) of title 5","children":[],"tail":") or any individual employed in or under the United States Postal Service or the Postal Regulatory Commission, unless that activity is prohibited by section 7323 or 7324 of such title."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8d2a3dc-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/722"},"text":"62 Stat. 722","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/187/tII/s201/a/3"},"text":"Pub. L. 96–187, title II, § 201(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-01-08"},"text":"Jan. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1367"},"text":"93 Stat. 1367","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/94/s4/a"},"text":"Pub. L. 103–94, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-10-06"},"text":"Oct. 6, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1004"},"text":"107 Stat. 1004","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/435/tVI/s604/f"},"text":"Pub. L. 109–435, title VI, § 604(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3242"},"text":"120 Stat. 3242","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8d2a3dd-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8d2a3de-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., §§ 208, 212 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321"},"text":"Mar. 4, 1909, ch. 321","children":[],"tail":", §§ 118, 122, "},{"tag":"ref","attrib":{"href":"/us/stat/35/1110"},"text":"35 Stat. 1110","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1925-02-28/ch368/s312"},"text":"Feb. 28, 1925, ch. 368, § 312","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/1073"},"text":"43 Stat. 1073","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section consolidates sections 208 and 212 of title 18, U.S.C., 1940 ed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section, like ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s201"},"text":"section 201 of this title","children":[],"tail":", was expanded to embrace all officers or persons acting on behalf of any independent agencies or Government-owned or controlled corporations by inserting words “or any department or agency thereof.” (See definitive "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s6"},"text":"section 6 of this title","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The punishment provision was taken from ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s212"},"text":"section 212 of title 18","children":[],"tail":", U.S.C., 1940 ed., which, by reference, made the punishment applicable to the crime described in this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8d2a3df-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8d2a3e0-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 301(8) of the Federal Election Campaign Act of 1971, referred to in subsec. (a)(4), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101/8"},"text":"section 30101(8) of Title 52","children":[],"tail":", Voting and Elections."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8d2a3e1-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435"},"text":"Pub. L. 109–435","children":[],"tail":" substituted “Postal Regulatory Commission” for “Postal Rate Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":", which directed the amendment of this section by substituting “under this title” for “not more than $5,000”, could not be executed because the phrase “not more than $5,000” does not appear in text. See 1993 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/94"},"text":"Pub. L. 103–94","children":[],"tail":" designated existing provisions as subsec. (a), substituted “; to knowingly solicit any contribution within the meaning of section 301(8) of the Federal Election Campaign Act of 1971 from any other such officer, employee, or person. Any person who violates this section shall be fined under this title or imprisoned not more than 3 years, or both” for “to knowingly solicit, any contribution within the meaning of section 301(8) of the Federal Election Campaign Act of 1971 from any other such officer, employee, or person. Any person who violates this section shall be fined not more than $5,000 or imprisoned not more than three years, or both” in par. (4), and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/187"},"text":"Pub. L. 96–187","children":[],"tail":" amended section generally to conform its terms to revision of the Federal Election Campaign Act of 1971 by title I of "},{"tag":"ref","attrib":{"href":"/us/pl/96/187"},"text":"Pub. L. 96–187","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8d4ecd2-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8d4ecd3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment; Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/94"},"text":"Pub. L. 103–94","children":[],"tail":" effective 120 days after "},{"tag":"date","attrib":{"date":"1993-10-06"},"text":"Oct. 6, 1993","children":[],"tail":", but not to release or extinguish any penalty, forfeiture, or liability incurred under amended provision, which is to be treated as remaining in force for purpose of sustaining any proper proceeding or action for enforcement of that penalty, forfeiture, or liability, and no provision of "},{"tag":"ref","attrib":{"href":"/us/pl/103/94"},"text":"Pub. L. 103–94","children":[],"tail":" to affect any proceedings with respect to which charges were filed on or before 120 days after "},{"tag":"date","attrib":{"date":"1993-10-06"},"text":"Oct. 6, 1993","children":[],"tail":", with orders to be issued in such proceedings and appeals taken therefrom as if "},{"tag":"ref","attrib":{"href":"/us/pl/103/94"},"text":"Pub. L. 103–94","children":[],"tail":" had not been enacted, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/94/s12"},"text":"section 12 of Pub. L. 103–94","children":[],"tail":", set out as an Effective Date; Savings Provision note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s7321"},"text":"section 7321 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8d4ecd4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/187"},"text":"Pub. L. 96–187","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-01-08"},"text":"Jan. 8, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/187/s301/a"},"text":"section 301(a) of Pub. L. 96–187","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"section 30101 of Title 52","children":[],"tail":", Voting and Elections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
