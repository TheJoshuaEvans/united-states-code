{"tag":"section","attrib":{"id":"idb8aec7a5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s117"},"text":null,"children":[{"tag":"num","attrib":{"value":"117"},"text":"§ 117.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic assault by an habitual offender","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8aec7a6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s117/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who commits a domestic assault within the special maritime and territorial jurisdiction of the United States or Indian country and who has a final conviction on at least 2 separate prior occasions in Federal, State, or Indian tribal court proceedings for offenses that would be, if subject to Federal jurisdiction—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8aec7a7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s117/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any assault, sexual abuse, or serious violent felony against a spouse or intimate partner, or against a child of or in the care of the person committing the domestic assault; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8aec7a8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s117/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an offense under chapter 110A,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title, imprisoned for a term of not more than 5 years, or both, except that if substantial bodily injury results from violation under this section, the offender shall be imprisoned for a term of not more than 10 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8aec7a9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s117/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Domestic Assault Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “domestic assault” means an assault committed by a current or former spouse, parent, child, or guardian of the victim, by a person with whom the victim shares a child in common, by a person who is cohabitating with or has cohabitated with the victim as a spouse, parent, child, or guardian, or by a person similarly situated to a spouse, parent, child, or guardian of the victim.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8aec7aa-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/tIX/s909"},"text":"Pub. L. 109–162, title IX, § 909","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3084"},"text":"119 Stat. 3084","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/104/s3"},"text":"Pub. L. 113–104, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-05-20"},"text":"May 20, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1156"},"text":"128 Stat. 1156","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8aec7ab-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8aec7ac-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8aec7ad-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/104"},"text":"Pub. L. 113–104","children":[],"tail":" inserted “, or against a child of or in the care of the person committing the domestic assault” after “intimate partner”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
