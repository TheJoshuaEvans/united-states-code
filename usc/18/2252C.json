{"tag":"section","attrib":{"id":"idb94e899c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2252C"},"text":null,"children":[{"tag":"num","attrib":{"value":"2252C"},"text":"§ 2252C.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Misleading words or digital images on the Internet","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb94e899d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2252C/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever knowingly embeds words or digital images into the source code of a website with the intent to deceive a person into viewing material constituting obscenity shall be fined under this title and imprisoned for not more than 10 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb94e899e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2252C/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever knowingly embeds words or digital images into the source code of a website with the intent to deceive a minor into viewing material harmful to minors on the Internet shall be fined under this title and imprisoned for not more than 20 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb94e899f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2252C/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purposes of this section, a word or digital image that clearly indicates the sexual content of the site, such as “sex” or “porn”, is not misleading.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb94e89a0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2252C/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb94e89a1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2252C/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “material that is harmful to minors” and “sex” have the meaning given such terms in section 2252B; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb94e89a2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2252C/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “source code” means the combination of text and other characters comprising the content, both viewable and nonviewable, of a web page, including any website publishing language, programming language, protocol or functional content, as well as any successor languages or protocols.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb94e89a3-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/tVII/s703/a"},"text":"Pub. L. 109–248, title VII, § 703(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/648"},"text":"120 Stat. 648","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
