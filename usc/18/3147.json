{"tag":"section","attrib":{"id":"idb98eeec7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3147"},"text":null,"children":[{"tag":"num","attrib":{"value":"3147"},"text":"§ 3147.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for an offense committed while on release","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A person convicted of an offense committed while released under this chapter shall be sentenced, in addition to the sentence prescribed for the offense, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb98eeec8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3147/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a term of imprisonment of not more than ten years if the offense is a felony; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb98eeec9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3147/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a term of imprisonment of not more than one year if the offense is a misdemeanor.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"A term of imprisonment imposed under this section shall be consecutive to any other sentence of imprisonment.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb98eeeca-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s203/a"},"text":"Pub. L. 98–473, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1983"},"text":"98 Stat. 1983","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s223/g"},"text":"Pub. L. 98–473, title II, § 223(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2028"},"text":"98 Stat. 2028","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/646/s55/g"},"text":"Pub. L. 99–646, § 55(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3610"},"text":"100 Stat. 3610","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb98eeecb-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb98eeecc-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb98eeecd-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3147, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/465/s3/a"},"text":"Pub. L. 89–465, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-06-22"},"text":"June 22, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/215"},"text":"80 Stat. 215","children":[],"tail":", related to appeals from conditions of release, prior to repeal in the revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/s203/a"},"text":"section 203(a) of Pub. L. 98–473","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb98eeece-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646"},"text":"Pub. L. 99–646","children":[],"tail":" substituted “under” for “pursuant to” in two places and “for the offense,” for “for the offense”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/s223/g"},"text":"Pub. L. 98–473, § 223(g)","children":[],"tail":", struck out “not less than two years and” after “imprisonment of” in par. (1), and “not less than ninety days and” after “imprisonment of” in par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb98eeecf-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb98eeed0-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646"},"text":"Pub. L. 99–646","children":[],"tail":" effective 30 days after "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/646/s55/j"},"text":"section 55(j) of Pub. L. 99–646","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3141"},"text":"section 3141 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb98eeed1-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[