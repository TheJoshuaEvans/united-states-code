{"tag":"section","attrib":{"id":"idb92f907f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1730"},"text":null,"children":[{"tag":"num","attrib":{"value":"1730"},"text":"§ 1730.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniforms of carriers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, not being connected with the letter-carrier branch of the Postal Service, wears the uniform or badge which may be prescribed by the Postal Service to be worn by letter carriers, shall be fined under this title or imprisoned not more than six months, or both.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The provisions of the preceding paragraph shall not apply to an actor or actress in a theatrical, television, or motion-picture production who wears the uniform or badge of the letter-carrier branch of the Postal Service while portraying a member of that service.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb92f9080-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/785"},"text":"62 Stat. 785","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/413"},"text":"Pub. L. 90–413","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-21"},"text":"July 21, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/396"},"text":"82 Stat. 396","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s6/j/35"},"text":"Pub. L. 91–375, § 6(j)(35)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/780"},"text":"84 Stat. 780","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXII/s1210/a"},"text":"Pub. L. 101–647, title XII, § 1210(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4832"},"text":"104 Stat. 4832","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/B"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2146"},"text":"108 Stat. 2146","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92f9081-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb92f9082-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 310 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s187"},"text":"Mar. 4, 1909, ch. 321, § 187","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1124"},"text":"35 Stat. 1124","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor verbal change was made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92f9083-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92f9084-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $100” in first par."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":" struck out “, if the portrayal does not tend to discredit that service” before period at end of second par."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":" substituted “Postal Service” for “Postmaster General” before “to be worn” in first par."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/413"},"text":"Pub. L. 90–413","children":[],"tail":" inserted provision exempting an actor or actress in a theatrical, television, or motion-picture production who wears the uniform or badge of the letter-carrier branch of the Postal Service from the penalties imposed by this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb92f9085-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb92f9086-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":" effective within 1 year after "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", on date established therefor by Board of Governors of United States Postal Service and published by it in Federal Register, see "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as an Effective Date note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of Title 39","children":[],"tail":", Postal Service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
