{"tag":"section","attrib":{"id":"idb9c82703-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4101"},"text":null,"children":[{"tag":"num","attrib":{"value":"4101"},"text":"§ 4101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter the term—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9c82704-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “double criminality” means that at the time of transfer of an offender the offense for which he has been sentenced is still an offense in the transferring country and is also an offense in the receiving country. With regard to a country which has a federal form of government, an act shall be deemed to be an offense in that country if it is an offense under the federal laws or the laws of any state or province thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c82705-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “imprisonment” means a penalty imposed by a court under which the individual is confined to an institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c82706-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4101/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “juvenile” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c82707-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4101/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person who is under eighteen years of age; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c82708-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4101/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the purpose of proceedings and disposition under chapter 403 of this title because of an act of juvenile delinquency, a person who is under twenty-one years of age;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c82709-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4101/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “juvenile delinquency” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c8270a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4101/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a violation of the laws of the United States or a State thereof or of a foreign country committed by a juvenile which would have been a crime if committed by an adult; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c8270b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4101/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" noncriminal acts committed by a juvenile for which supervision or treatment by juvenile authorities of the United States, a State thereof, or of the foreign country concerned is authorized;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c8270c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4101/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “offender” means a person who has been convicted of an offense or who has been adjudged to have committed an act of juvenile delinquency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c8270d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4101/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “parole” means any form of release of an offender from imprisonment to the community by a releasing authority prior to the expiration of his sentence, subject to conditions imposed by the releasing authority and to its supervision, including a term of supervised release pursuant to section 3583;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c8270e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4101/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “probation” means any form of a sentence under which the offender is permitted to remain at liberty under supervision and subject to conditions for the breach of which a penalty of imprisonment may be ordered executed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c8270f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4101/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “sentence” means not only the penalty imposed but also the judgment of conviction in a criminal case or a judgment of acquittal in the same proceeding, or the adjudication of delinquency in a juvenile delinquency proceeding or dismissal of allegations of delinquency in the same proceedings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c82710-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4101/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means any State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, and any territory or possession of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c82711-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4101/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “transfer” means a transfer of an individual for the purpose of the execution in one country of a sentence imposed by the courts of another country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c82712-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4101/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “treaty” means a treaty under which an offender sentenced in the courts of one country may be transferred to the country of which he is a citizen or national for the purpose of serving the sentence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9c82713-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/144/s1"},"text":"Pub. L. 95–144, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-28"},"text":"Oct. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1213"},"text":"91 Stat. 1213","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s223/m/1"},"text":"Pub. L. 98–473, title II, § 223(m)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2029"},"text":"98 Stat. 2029","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9c82714-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9c82715-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9c82716-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":" inserted “including a term of supervised release pursuant to section 3583” after “supervision”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":" substituted “under which” for “to a penalty of imprisonment the execution of which is suspended” and “a” for “the suspended” before “penalty”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9c82717-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb9c82718-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1987-11-01"},"text":"Nov. 1, 1987","children":[],"tail":", and applicable only to offenses committed after the taking effect of such amendment, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/s235/a/1"},"text":"section 235(a)(1) of Pub. L. 98–473","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3551"},"text":"section 3551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
