{"tag":"section","attrib":{"id":"idb92f908d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1732"},"text":null,"children":[{"tag":"num","attrib":{"value":"1732"},"text":"§ 1732.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of bond or sureties by postmaster","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being a postmaster, affixes his signature to the approval of any bond of a bidder, or to the certificate of sufficiency of sureties in any contract, before the said bond or contract is signed by the bidder or contractor and his sureties, or knowingly, or without the exercise of due diligence, approves any bond of a bidder with insufficient sureties, or knowingly makes any false or fraudulent certificate, shall be fined under this title or imprisoned not more than one year, or both; and shall be dismissed from office and disqualified from holding the office of postmaster.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb92f908e-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/785"},"text":"62 Stat. 785","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92f908f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb92f9090-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 352 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s222"},"text":"Mar. 4, 1909, ch. 321, § 222","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1133"},"text":"35 Stat. 1133","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor verbal changes were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92f9091-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92f9092-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $5,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
