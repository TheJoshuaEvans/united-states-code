{"tag":"section","attrib":{"id":"idb8d2a358-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s553"},"text":null,"children":[{"tag":"num","attrib":{"value":"553"},"text":"§ 553.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importation or exportation of stolen motor vehicles, off-highway mobile equipment, vessels, or aircraft","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8d2a359-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s553/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whoever knowingly imports, exports, or attempts to import or export—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8d2a35a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s553/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any motor vehicle, off-highway mobile equipment, vessel, aircraft, or part of any motor vehicle, off-highway mobile equipment, vessel, or aircraft, knowing the same to have been stolen; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d2a35b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s553/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any motor vehicle or off-highway mobile equipment or part of any motor vehicle or off-highway mobile equipment, knowing that the identification number of such motor vehicle, equipment, or part has been removed, obliterated, tampered with, or altered;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title or imprisoned not more than 10 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8d2a35c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s553/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subsection (a)(2) shall not apply if the removal, obliteration, tampering, or alteration—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8d2a35d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s553/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is caused by collision or fire; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d2a35e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s553/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8d2a35f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s553/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a motor vehicle, is not a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s511"},"text":"section 511 of this title","children":[],"tail":" (relating to altering or removing motor vehicle identification numbers); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8d2a360-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s553/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of off-highway mobile equipment, would not be a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s511"},"text":"section 511 of this title","children":[],"tail":" if such equipment were a motor vehicle."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8d2a361-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s553/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in this section, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8d2a362-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s553/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “motor vehicle” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32101"},"text":"section 32101 of title 49","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d2a363-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s553/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “off-highway mobile equipment” means any self-propelled agricultural equipment, self-propelled construction equipment, and self-propelled special use equipment, used or designed for running on land but not on rail or highway;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d2a364-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s553/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “vessel” has the meaning given that term in section 401 of the Tariff Act of 1930 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1401"},"text":"19 U.S.C. 1401","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d2a365-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s553/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “aircraft” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s40102/a"},"text":"section 40102(a) of title 49","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d2a366-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s553/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “identification number”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8d2a367-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s553/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a motor vehicle, has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s511"},"text":"section 511 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8d2a368-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s553/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any other vehicle or equipment covered by this section, means a number or symbol assigned to the vehicle or equipment, or part thereof, by the manufacturer primarily for the purpose of identifying such vehicle, equipment, or part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8d2a369-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/547/tIII/s301/a"},"text":"Pub. L. 98–547, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-25"},"text":"Oct. 25, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2771"},"text":"98 Stat. 2771","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7021"},"text":"Pub. L. 100–690, title VII, § 7021","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4396"},"text":"102 Stat. 4396","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/519/tI/s102"},"text":"Pub. L. 102–519, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-25"},"text":"Oct. 25, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3385"},"text":"106 Stat. 3385","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s5/e/5"},"text":"Pub. L. 103–272, § 5(e)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1374"},"text":"108 Stat. 1374","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8d2a36a-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8d2a36b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8d2a36c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s5/e/5/A"},"text":"Pub. L. 103–272, § 5(e)(5)(A)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t49/s32101"},"text":"section 32101 of title 49","children":[],"tail":"” for “section 2 of the Motor Vehicle Information and Cost Savings Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s5/e/5/B"},"text":"Pub. L. 103–272, § 5(e)(5)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t49/s40102/a"},"text":"section 40102(a) of title 49","children":[],"tail":"” for “section 101 of the Federal Aviation Act of 1958 (49 U.S.C. App. 1301)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/519"},"text":"Pub. L. 102–519","children":[],"tail":" substituted “fined under this title or imprisoned not more than 10 years” for “fined not more than $15,000 or imprisoned not more than five years” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" amended par. (2) generally. Prior to amendment, par. (2) read as follows: “is not a violation of "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s511"},"text":"section 511 of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
