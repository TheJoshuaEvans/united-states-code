{"tag":"section","attrib":{"id":"idb8cdc127-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s501"},"text":null,"children":[{"tag":"num","attrib":{"value":"501"},"text":"§ 501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Postage stamps, postage meter stamps, and postal cards","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever forges or counterfeits any postage stamp, postage meter stamp, or any stamp printed upon any stamped envelope, or postal card, or any die, plate, or engraving thereof; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever makes or prints, or knowingly uses or sells, or possesses with intent to use or sell, any such forged or counterfeited postage stamp, postage meter stamp, stamped envelope, postal card, die, plate, or engraving; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever makes, or knowingly uses or sells, or possesses with intent to use or sell, any paper bearing the watermark of any stamped envelope, or postal card, or any fraudulent imitation thereof; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever makes or prints, or authorizes to be made or printed, any postage stamp, postage meter stamp, stamped envelope, or postal card, of the kind authorized and provided by the Post Office Department or by the Postal Service, without the special authority and direction of the Department or Postal Service; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever after such postage stamp, postage meter stamp, stamped envelope, or postal card has been printed, with intent to defraud, delivers the same to any person not authorized by an instrument in writing, duly executed under the hand of the Postmaster General and the seal of the Post Office Department or the Postal Service, to receive it—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Shall be fined under this title or imprisoned not more than five years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8cdc128-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/713"},"text":"62 Stat. 713","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s6/j/6"},"text":"Pub. L. 91–375, § 6(j)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/777"},"text":"84 Stat. 777","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/448/s1/a"},"text":"Pub. L. 91–448, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-14"},"text":"Oct. 14, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/920"},"text":"84 Stat. 920","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/G"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(G)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8cdc129-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8cdc12a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 348 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s219"},"text":"Mar. 4, 1909, ch. 321, § 219","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1132"},"text":"35 Stat. 1132","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to persons causing or procuring was omitted as unnecessary in view of definition of “principal” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes of phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8cdc12b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8cdc12c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $500” in last par."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/448"},"text":"Pub. L. 91–448","children":[],"tail":" inserted references to the Postal Service and to postage meter stamps. "},{"tag":"ref","attrib":{"href":"/us/pl/91/448/s1/b"},"text":"Pub. L. 91–448, § 1(b)","children":[],"tail":", repealed section 6(j)(6) of the Postal Reorganization Act, "},{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/719"},"text":"84 Stat. 719","children":[],"tail":", by which the references to the Postal Service had been inserted earlier."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":" inserted “or by the Postal Service,” after “Post Office Department,” and substituted “the Department or Postal Service” for “said department” in fourth par. and struck out the comma after “stamped envelope” and “to defraud” and inserted “or the Postal Service” after “Post Office Department” in fifth par."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8cdc12d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb8cdc12e-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Post Office Department redesignated United States Postal Service pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375/s6"},"text":"Pub. L. 91–375, § 6","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/733"},"text":"84 Stat. 733","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of Title 39","children":[],"tail":", Postal Service."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8cdc12f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":" effective within 1 year after "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", on date established therefor by Board of Governors of United States Postal Service and published by it in Federal Register, see "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as an Effective Date note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of Title 39","children":[],"tail":", Postal Service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
