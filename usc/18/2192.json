{"tag":"section","attrib":{"id":"idb94513ff-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2192"},"text":null,"children":[{"tag":"num","attrib":{"value":"2192"},"text":"§ 2192.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incitation of seamen to revolt or mutiny","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being of the crew of a vessel of the United States, on the high seas, or on any other waters within the admiralty and maritime jurisdiction of the United States, endeavors to make a revolt or mutiny on board such vessel, or combines, conspires, or confederates with any other person on board to make such revolt or mutiny, or solicits, incites, or stirs up any other of the crew to disobey or resist the lawful orders of the master or other officer of such vessel, or to refuse or neglect his proper duty on board thereof, or to betray his proper trust, or assembles with others in a tumultuous and mutinous manner, or makes a riot on board thereof, or unlawfully confines the master or other commanding officer thereof, shall be fined under this title or imprisoned not more than five years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9451400-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/800"},"text":"62 Stat. 800","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s601/a/8"},"text":"Pub. L. 104–294, title VI, § 601(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3498"},"text":"110 Stat. 3498","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9451401-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9451402-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 483 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s292"},"text":"Mar. 4, 1909, ch. 321, § 292","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1146"},"text":"35 Stat. 1146","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9451403-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9451404-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" substituted “fined under this title” for “fined not more than $1,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
