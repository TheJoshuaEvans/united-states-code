{"tag":"section","attrib":{"id":"idb91c7d88-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1364"},"text":null,"children":[{"tag":"num","attrib":{"value":"1364"},"text":"§ 1364.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interference with foreign commerce by violence","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, with intent to prevent, interfere with, or obstruct or attempt to prevent, interfere with, or obstruct the exportation to foreign countries of articles from the United States, injures or destroys, by fire or explosives, such articles or the places where they may be while in such foreign commerce, shall be fined under this title or imprisoned not more than twenty years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb91c7d89-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/764"},"text":"62 Stat. 764","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/L"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(L)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91c7d8a-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb91c7d8b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 381 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-06-15/ch30"},"text":"June 15, 1917, ch. 30","children":[],"tail":", titles IV, XIII, § 1, "},{"tag":"ref","attrib":{"href":"/us/stat/40/221"},"text":"40 Stat. 221","children":[],"tail":", 231; "},{"tag":"ref","attrib":{"href":"/us/act/1940-03-28/ch72/s4"},"text":"Mar. 28, 1940, ch. 72, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/79"},"text":"54 Stat. 79","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Mandatory punishment provisions were rephrased in the alternative.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Definition of the term “United States” was omitted and incorporated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s5"},"text":"section 5 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor verbal changes were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb91c7d8c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb91c7d8d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $10,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
