{"tag":"section","attrib":{"id":"idb9bc3fc3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3669"},"text":null,"children":[{"tag":"num","attrib":{"value":"3669"},"text":"§ 3669.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conveyances carrying liquor","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any conveyance, whether used by the owner or another in introducing or attempting to introduce intoxicants into the Indian country, or into other places where the introduction is prohibited by treaty or enactment of Congress, shall be subject to seizure, libel, and forfeiture.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9bc3fc4-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/841"},"text":"62 Stat. 841","children":[],"tail":", § 3618; renumbered § 3669, "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s212/a/1"},"text":"Pub. L. 98–473, title II, § 212(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1987"},"text":"98 Stat. 1987","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9bc3fc5-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9bc3fc6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s247"},"text":"section 247 of title 25","children":[],"tail":", U.S.C., 1940 ed., Indians ("},{"tag":"ref","attrib":{"href":"/us/act/1917-03-02/ch146/s1"},"text":"Mar. 2, 1917, ch. 146, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/970"},"text":"39 Stat. 970","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “Automobiles or any other vehicles or” at beginning of section were omitted, and “any conveyance” substituted to remove possible ambiguity as to scope of section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words at conclusion of section “provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s246"},"text":"section 246 of this title","children":[],"tail":"” added nothing and were therefore omitted. (See also rule 41 of the Federal Rules of Criminal Procedure.)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in arrangement and phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
