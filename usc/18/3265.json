{"tag":"section","attrib":{"id":"idb9988b14-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3265"},"text":null,"children":[{"tag":"num","attrib":{"value":"3265"},"text":"§ 3265.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial proceedings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9988b15-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3265/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9988b16-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3265/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of any person arrested for or charged with a violation of section 3261(a) who is not delivered to authorities of a foreign country under section 3263, the initial appearance of that person under the Federal Rules of Criminal Procedure—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9988b17-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3265/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be conducted by a Federal magistrate judge; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9988b18-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3265/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be carried out by telephony or such other means that enables voice communication among the participants, including any counsel representing the person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9988b19-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3265/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In conducting the initial appearance, the Federal magistrate judge shall also determine whether there is probable cause to believe that an offense under section 3261(a) was committed and that the person committed it.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9988b1a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3265/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Federal magistrate judge determines that probable cause exists that the person committed an offense under section 3261(a), and if no motion is made seeking the person’s detention before trial, the Federal magistrate judge shall also determine at the initial appearance the conditions of the person’s release before trial under chapter 207 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9988b1b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3265/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of any person described in subsection (a), any detention hearing of that person under section 3142(f)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9988b1c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3265/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be conducted by a Federal magistrate judge; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9988b1d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3265/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the request of the person, may be carried out by telephony or such other means that enables voice communication among the participants, including any counsel representing the person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9988b1e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3265/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9988b1f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3265/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If any initial proceeding under this section with respect to any such person is conducted while the person is outside the United States, and the person is entitled to have counsel appointed for purposes of such proceeding, the Federal magistrate judge may appoint as such counsel for purposes of such hearing a qualified military counsel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9988b20-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3265/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this subsection, the term “qualified military counsel” means a judge advocate made available by the Secretary of Defense for purposes of such proceedings, who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9988b21-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3265/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a graduate of an accredited law school or is a member of the bar of a Federal court or of the highest court of a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9988b22-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3265/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is certified as competent to perform such duties by the Judge Advocate General of the armed force of which he is a member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9988b23-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/523/s2/a"},"text":"Pub. L. 106–523, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2490"},"text":"114 Stat. 2490","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9988b24-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9988b25-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9988b26-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Criminal Procedure, referred to in subsec. (a)(1), are set out in the Appendix to this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
