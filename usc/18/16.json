{"tag":"section","attrib":{"id":"idb8a2e076-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"§ 16.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crime of violence defined","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The term “crime of violence” means—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8a2e077-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s16/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an offense that has as an element the use, attempted use, or threatened use of physical force against the person or prop­erty of another, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a2e078-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s16/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other offense that is a felony and that, by its nature, involves a substantial risk that physical force against the person or property of another may be used in the course of committing the offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8a2e079-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s1001/a"},"text":"Pub. L. 98–473, title II, § 1001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2136"},"text":"98 Stat. 2136","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8a2e07a-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8a2e07b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"constitutionality","id":"idb8a2e07c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Constitutionality","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For information regarding the constitutionality of this section, as added by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/s1001/a"},"text":"section 1001(a) of Pub. L. 98–473","children":[],"tail":", see the Table of Laws Held Unconstitutional in Whole or in Part by the Supreme Court on the Constitution Annotated website, constitution.congress.gov."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
