{"tag":"section","attrib":{"id":"idb95344e1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258D"},"text":null,"children":[{"tag":"num","attrib":{"value":"2258D"},"text":"§ 2258D.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited liability for NCMEC","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb95344e2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258D/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Pursuant to its clearinghouse role as a private, nonprofit organization and its mission to help find missing children, reduce online sexual exploitation of children and prevent future victimization, and except as provided in subsections (b) and (c), a civil claim or criminal charge against NCMEC, including any director, officer, employee, or agent of NCMEC, arising from the performance of the CyberTipline responsibilities or functions of NCMEC, as described in this section, section 2258A or 2258C of this title, or section 404 of the Missing Children’s Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s11293"},"text":"34 U.S.C. 11293","children":[],"tail":"), or from the efforts of NCMEC to identify child victims may not be brought in any Federal or State court."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95344e3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258D/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Intentional, Reckless, or Other Misconduct","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to a claim or charge if NCMEC, or a director, officer, employee, or agent of NCMEC—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95344e4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258D/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaged in intentional misconduct; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95344e5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258D/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" acted, or failed to act—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95344e6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258D/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with actual malice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95344e7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258D/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with reckless disregard to a substantial risk of causing injury without legal justification; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95344e8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258D/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a purpose unrelated to the performance of any responsibility or function under this section, section 2258A or 2258C of this title, or section 404 of the Missing Children’s Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s11293"},"text":"34 U.S.C. 11293","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95344e9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258D/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ordinary Business Activities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall not apply to an act or omission relating to an ordinary business activity, including general administration or operations, the use of motor vehicles, or personnel management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95344ea-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258D/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimizing Access","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"NCMEC shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95344eb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258D/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize the number of employees that are provided access to any visual depiction provided under section 2258A; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95344ec-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258D/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that any such visual depiction is permanently destroyed upon notification from a law enforcement agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb95344ed-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/401/tV/s501/a"},"text":"Pub. L. 110–401, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4250"},"text":"122 Stat. 4250","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/395/s5"},"text":"Pub. L. 115–395, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5294"},"text":"132 Stat. 5294","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb95344ee-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb95344ef-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb95344f0-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/395/s5/1"},"text":"Pub. L. 115–395, § 5(1)","children":[],"tail":", substituted “NCMEC” for “the National Center for Missing and Exploited Children” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/395/s5/2"},"text":"Pub. L. 115–395, § 5(2)","children":[],"tail":", substituted “Pursuant to its clearinghouse role as a private, nonprofit organization and its mission to help find missing children, reduce online sexual exploitation of children and prevent future victimization, and except as provided” for “Except as provided”, “against NCMEC” for “against the National Center for Missing and Exploited Children”, “("},{"tag":"ref","attrib":{"href":"/us/usc/t34/s11293"},"text":"34 U.S.C. 11293","children":[],"tail":")” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5773"},"text":"42 U.S.C. 5773","children":[],"tail":")”, “of NCMEC” for “of such center” wherever appearing, and “from the efforts” for “from the effort”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/395/s5/3"},"text":"Pub. L. 115–395, § 5(3)","children":[],"tail":", substituted “if NCMEC” for “if the National Center for Missing and Exploited Children”, “of NCMEC” for “of such center”, and “("},{"tag":"ref","attrib":{"href":"/us/usc/t34/s11293"},"text":"34 U.S.C. 11293","children":[],"tail":")” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5773"},"text":"42 U.S.C. 5773","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/395/s5/4"},"text":"Pub. L. 115–395, § 5(4)","children":[],"tail":", substituted “NCMEC” for “The National Center for Missing and Exploited Children” in introductory provisions and “visual depiction” for “image” in pars. (1) and (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
