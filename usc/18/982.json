e as of the date on which "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/s1401"},"text":"section 1401 of Pub. L. 101–647","children":[],"tail":" took effect."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
