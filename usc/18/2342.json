{"tag":"section","attrib":{"id":"idb96b3954-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2342"},"text":null,"children":[{"tag":"num","attrib":{"value":"2342"},"text":"§ 2342.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful acts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb96b3955-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2342/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It shall be unlawful for any person knowingly to ship, transport, receive, possess, sell, distribute, or purchase contraband cigarettes or contraband smokeless tobacco.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb96b3956-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2342/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It shall be unlawful for any person knowingly to make any false statement or representation with respect to the information required by this chapter to be kept in the records of any person who ships, sells, or distributes any quantity of cigarettes in excess of 10,000 in a single transaction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb96b3957-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/575/s1"},"text":"Pub. L. 95–575, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-02"},"text":"Nov. 2, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2464"},"text":"92 Stat. 2464","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/tI/s121/a/2"},"text":"Pub. L. 109–177, title I, § 121(a)(2)","children":[],"tail":", (b)(2), "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/221"},"text":"120 Stat. 221","children":[],"tail":", 222.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb96b3958-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb96b3959-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb96b395a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s121/b/2"},"text":"Pub. L. 109–177, § 121(b)(2)","children":[],"tail":", inserted “or contraband smokeless tobacco” after “contraband cigarettes”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s121/a/2"},"text":"Pub. L. 109–177, § 121(a)(2)","children":[],"tail":", substituted “10,000” for “60,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb96b395b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb96b395c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (a) of this section effective ","children":[{"tag":"date","attrib":{"date":"1978-11-02"},"text":"Nov. 2, 1978","children":[],"tail":", and subsec. (b) of this section effective on first day of first month beginning more than 120 days after "},{"tag":"date","attrib":{"date":"1978-11-02"},"text":"Nov. 2, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/575/s4"},"text":"section 4 of Pub. L. 95–575","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2341"},"text":"section 2341 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
