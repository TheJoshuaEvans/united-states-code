{"tag":"section","attrib":{"id":"idb9c5dc4b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4046"},"text":null,"children":[{"tag":"num","attrib":{"value":"4046"},"text":"§ 4046.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shock incarceration program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9c5dc4c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4046/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Bureau of Prisons may place in a shock incarceration program any person who is sentenced to a term of imprisonment of more than 12, but not more than 30, months, if such person consents to that placement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c5dc4d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4046/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For such initial portion of the term of imprisonment as the Bureau of Prisons may determine, not to exceed 6 months, an inmate in the shock incarceration program shall be required to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9c5dc4e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4046/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adhere to a highly regimented schedule that provides the strict discipline, physical training, hard labor, drill, and ceremony characteristic of military basic training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9c5dc4f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4046/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in appropriate job training and educational programs (including literacy programs) and drug, alcohol, and other counseling programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9c5dc50-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4046/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An inmate who in the judgment of the Director of the Bureau of Prisons has successfully completed the required period of shock incarceration shall remain in the custody of the Bureau for such period (not to exceed the remainder of the prison term otherwise required by law to be served by that inmate), and under such conditions, as the Bureau deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9c5dc51-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXX/s3001/a"},"text":"Pub. L. 101–647, title XXX, § 3001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4915"},"text":"104 Stat. 4915","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9c5dc52-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9c5dc53-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb9c5dc54-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXX/s3002"},"text":"Pub. L. 101–647, title XXX, § 3002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4915"},"text":"104 Stat. 4915","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/647/tXXX/s3002"},"text":"“There are authorized to be appropriated for fiscal year 1990 and each fiscal year thereafter such sums as may be necessary to carry out the shock incarceration program established under the amendments made by this Act [see Tables for classification]”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
