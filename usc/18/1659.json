{"tag":"section","attrib":{"id":"idb92ad5da-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1659"},"text":null,"children":[{"tag":"num","attrib":{"value":"1659"},"text":"§ 1659.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attack to plunder vessel","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, upon the high seas or other waters within the admiralty and maritime jurisdiction of the United States, by surprise or open force, maliciously attacks or sets upon any vessel belonging to another, with an intent unlawfully to plunder the same, or to despoil any owner thereof of any moneys, goods, or merchandise laden on board thereof, shall be fined under this title or imprisoned not more than ten years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb92ad5db-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/775"},"text":"62 Stat. 775","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92ad5dc-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb92ad5dd-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 489 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s298"},"text":"Mar. 4, 1909, ch. 321, § 298","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1147"},"text":"35 Stat. 1147","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Mandatory punishment provisions were rephrased in the alternative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92ad5de-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92ad5df-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $5,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
