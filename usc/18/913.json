{"tag":"section","attrib":{"id":"idb8ea70d3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s913"},"text":null,"children":[{"tag":"num","attrib":{"value":"913"},"text":"§ 913.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Impersonator making arrest or search","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever falsely represents himself to be an officer, agent, or employee of the United States, and in such assumed character arrests or detains any person or in any manner searches the person, buildings, or other property of any person, shall be fined under this title or imprisoned not more than three years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8ea70d4-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/742"},"text":"62 Stat. 742","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8ea70d5-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8ea70d6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":" Based on title 18, U.S.C., 1940 ed., § 77a (","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-27/ch740/s201"},"text":"Aug. 27, 1935, ch. 740, § 201","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/877"},"text":"49 Stat. 877","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “shall be deemed guilty of a misdemeanor” were omitted. (See definitive ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1"},"text":"section 1 of this title","children":[],"tail":".) Words “and upon conviction thereof” preceding “shall be” were omitted as surplusage since punishment cannot be imposed until conviction is secured."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Maximum imprisonment provision was changed from 1 year to 3 years so as to be consistent with sections 911 and 912 of this title, the latter having also been changed to 3 years. There is no sound reason why a uniform punishment should not be prescribed for the offenses defined in these three sections.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8ea70d7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8ea70d8-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $1,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
