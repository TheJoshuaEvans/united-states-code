{"tag":"section","attrib":{"id":"idb8e344a7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s798B"},"text":null,"children":[{"tag":"num","attrib":{"value":"798B"},"text":"§ 798B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unauthorized access to intelligence community property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8e344a8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s798B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibited Activity","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be unlawful, within the jurisdiction of the United States, without authorization to willfully go upon any property—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8e344a9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s798B/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with intent to gather intelligence or information to the detriment of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8e344aa-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s798B/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" while knowing that such property is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8e344ab-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s798B/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the jurisdiction of an element of the intelligence community (as defined in section 3(4) of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003/4"},"text":"50 U.S.C. 3003(4)","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8e344ac-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s798B/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" closed or restricted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8e344ad-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s798B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who violates subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8e344ae-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s798B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the first offense, be fined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3571"},"text":"section 3571 of this title","children":[],"tail":", imprisoned not more than 6 months, or both;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8e344af-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s798B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a second offense after a prior conviction under subsection (a) has become final, be fined under this title, imprisoned not more than 2 years, or both; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8e344b0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s798B/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a third or subsequent offense after a prior conviction under subsection (a) has become final, be fined under this title, imprisoned not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8e344b1-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dF/tLXIII/s6304"},"text":"Pub. L. 119–60, div. F, title LXIII, § 6304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1611"},"text":"139 Stat. 1611","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
