{"tag":"section","attrib":{"id":"idb8a79b5b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s39B"},"text":null,"children":[{"tag":"num","attrib":{"value":"39B"},"text":"§ 39B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unsafe operation of unmanned aircraft","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8a79b5c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s39B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offense","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who operates an unmanned aircraft and:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a79b5d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s39B/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Knowingly interferes with, or disrupts the operation of, an aircraft carrying 1 or more occupants operating in the special aircraft jurisdiction of the United States, in a manner that poses an imminent safety hazard to such occupants, shall be punished as provided in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a79b5e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s39B/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recklessly interferes with, or disrupts the operation of, an aircraft carrying 1 or more occupants operating in the special aircraft jurisdiction of the United States, in a manner that poses an imminent safety hazard to such occupants, shall be punished as provided in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a79b5f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s39B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operation of Unmanned Aircraft in Close Proximity to Airports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a79b60-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s39B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person who, without authorization, knowingly operates an unmanned aircraft within a runway exclusion zone shall be punished as provided in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a79b61-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s39B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Runway exclusion zone defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “runway exclusion zone” means a rectangular area—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a79b62-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s39B/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" centered on the centerline of an active runway of an airport immediately around which the airspace is designated as class B, class C, or class D airspace at the surface under part 71 of title 14, Code of Federal Regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a79b63-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s39B/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the length of which extends parallel to the runway’s centerline to points that are 1 statute mile from each end of the runway and the width of which is ½ statute mile.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a79b64-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s39B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a79b65-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s39B/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the punishment for an offense under subsections ","children":[{"tag":"ref","attrib":{"idref":"fn002014"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002014"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection”."}],"tail":" (a) or (b) shall be a fine under this title, imprisonment for not more than 1 year, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a79b66-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s39B/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Serious bodily injury or death","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a79b67-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s39B/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Causes serious bodily injury or death during the commission of an offense under subsection (a)(2) shall be fined under this title, imprisoned for a term of up to 10 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a79b68-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s39B/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Causes, or attempts or conspires to cause, serious bodily injury or death during the commission of an offense under subsections (a)(1) and (b) shall be fined under this title, imprisoned for any term of years or for life, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8a79b69-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tIII/s384/a"},"text":"Pub. L. 115–254, div. B, title III, § 384(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3322"},"text":"132 Stat. 3322","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
