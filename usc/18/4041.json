{"tag":"section","attrib":{"id":"idb9c36bf7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4041"},"text":null,"children":[{"tag":"num","attrib":{"value":"4041"},"text":"§ 4041.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bureau of Prisons; director and employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Bureau of Prisons shall be in charge of a director appointed by and serving directly under the Attorney General. The Attorney General may appoint such additional officers and employees as he deems necessary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9c36bf8-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/849"},"text":"62 Stat. 849","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dA/tIII/s302/1"},"text":"Pub. L. 107–273, div. A, title III, § 302(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1781"},"text":"116 Stat. 1781","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9c36bf9-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9c36bfa-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 753 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-05-14/ch274/s1"},"text":"May 14, 1930, ch. 274, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/325"},"text":"46 Stat. 325","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The entire second sentence was omitted as executed. All powers and authority originally vested in the former Superintendent of Prisons are now possessed by the Bureau of Prisons.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes of phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9c36bfb-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9c36bfc-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" struck out “at a salary of $10,000 a year” after “under the Attorney General”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9c36bfd-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb9c36bfe-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Augmentation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/71/s2/c"},"text":"Pub. L. 118–71, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-07-25"},"text":"July 25, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1501"},"text":"138 Stat. 1501","children":[],"tail":", provided that: "},{"tag":"quotedContent",