{"tag":"section","attrib":{"id":"idb91eeea2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1429"},"text":null,"children":[{"tag":"num","attrib":{"value":"1429"},"text":"§ 1429.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties for neglect or refusal to answer subpena","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person who has been subpenaed under the provisions of subsection (d) of section 336 of the Immigration and Nationality Act to appear at the final hearing of an application for naturalization, and who shall neglect or refuse to so appear and to testify, if in the power of such person to do so, shall be fined under this title or imprisoned not more than five years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb91eeea3-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title IV, § 402(b), "},{"tag":"ref","attrib":{"href":"/us/stat/66/276"},"text":"66 Stat. 276","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/116/s18/u/1"},"text":"Pub. L. 97–116, § 18(u)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1621"},"text":"95 Stat. 1621","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/649/tIV/s407/c/21"},"text":"Pub. L. 101–649, title IV, § 407(c)(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5041"},"text":"104 Stat. 5041","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","