{"tag":"section","attrib":{"id":"idb8a79b6a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s40"},"text":null,"children":[{"tag":"num","attrib":{"value":"40"},"text":"§ 40.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial motor vehicles required to stop for inspections","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8a79b6b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s40/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A driver of a commercial motor vehicle (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s31132"},"text":"section 31132 of title 49","children":[],"tail":") shall stop and submit to inspection of the vehicle, driver, cargo, and required records when directed to do so by an authorized employee of the Federal Motor Carrier Safety Administration of the Department of Transportation, at or in the vicinity of an inspection site. The driver shall not leave the inspection site until authorized to do so by an authorized employee."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a79b6c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s40/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A driver of a commercial motor vehicle, as defined in subsection (a), who knowingly fails to stop for inspection when directed to do so by an authorized employee of the Administration at or in the vicinity of an inspection site, or leaves the inspection site without authorization, shall be fined under this title or imprisoned not more than 1 year, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8a79b6d-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIV/s4143/a"},"text":"Pub. L. 109–59, title IV, § 4143(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1747"},"text":"119 Stat. 1747","children":[],"tail":", § 39; renumbered § 40, "},{"tag":"ref","attrib":{"href":"/us/pl/110/244/tIII/s301/j"},"text":"Pub. L. 110–244, title III, § 301(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-06"},"text":"June 6, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1616"},"text":"122 Stat. 1616","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8a79b6e-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8a79b6f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8a79b70-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/244"},"text":"Pub. L. 110–244","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s39"},"text":"section 39 of this title","children":[],"tail":", relating to inspection of commercial vehicles, as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
