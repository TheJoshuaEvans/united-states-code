{"tag":"section","attrib":{"id":"idb8d9a80c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s668"},"text":null,"children":[{"tag":"num","attrib":{"value":"668"},"text":"§ 668.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Theft of major artwork","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8d9a80d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s668/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8d9a80e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s668/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “museum” means an organized and permanent institution, the activities of which affect interstate or foreign commerce, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8d9a80f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s668/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is situated in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8d9a810-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s668/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is established for an essentially educational or aesthetic purpose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8d9a811-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s668/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a professional staff; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8d9a812-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s668/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owns, utilizes, and cares for tangible objects that are exhibited to the public on a regular schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d9a813-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s668/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “object of cultural heritage” means an object that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8d9a814-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s668/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" over 100 years old and worth in excess of $5,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8d9a815-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s668/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" worth at least $100,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8d9a816-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s668/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offenses","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8d9a817-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s668/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" steals or obtains by fraud from the care, custody, or control of a museum any object of cultural heritage; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8d9a818-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s668/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowing that an object of cultural heritage has been stolen or obtained by fraud, if in fact the object was stolen or obtained from the care, custody, or control of a museum (whether or not that fact is known to the person), receives, conceals, exhibits, or disposes of the object,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title, imprisoned not more than 10 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8d9a819-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXII/s320902/a"},"text":"Pub. L. 103–322, title XXXII, § 320902(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2123"},"text":"108 Stat. 2123","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s604/b/18"},"text":"Pub. L. 104–294, title VI, § 604(b)(18)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3507"},"text":"110 Stat. 3507","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8d9a81a-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8d9a81b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8d9a81c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" designated first and second pars. beginning with quotation mark as pars. (1) and (2), respectively, and made technical amendment to provisions appearing in original."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8d9a81d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8d9a81e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/s604/d"},"text":"section 604(d) of Pub. L. 104–294","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s13"},"text":"section 13 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
