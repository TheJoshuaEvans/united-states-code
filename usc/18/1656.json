{"tag":"section","attrib":{"id":"idb92ad5c6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1656"},"text":null,"children":[{"tag":"num","attrib":{"value":"1656"},"text":"§ 1656.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conversion or surrender of vessel","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being a captain or other officer or mariner of a vessel upon the high seas or on any other waters within the admiralty and maritime jurisdiction of the United States, piratically or feloniously runs away with such vessel, or with any goods or merchandise thereof, to the value of $50 or over; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever yields up such vessel voluntarily to any pirate—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Shall be fined under this title or imprisoned not more than ten years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb92ad5c7-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/774"},"text":"62 Stat. 774","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/L"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(L)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92ad5c8-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb92ad5c9-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 497 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s306"},"text":"Mar. 4, 1909, ch. 321, § 306","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1148"},"text":"35 Stat. 1148","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92ad5ca-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92ad5cb-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $10,000” in last par."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
