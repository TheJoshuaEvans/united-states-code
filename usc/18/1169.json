{"tag":"section","attrib":{"id":"idb917c2f7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169"},"text":null,"children":[{"tag":"num","attrib":{"value":"1169"},"text":"§ 1169.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting of child abuse","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb917c2f8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any person who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb917c2f9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is a—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb917c2fa-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physician, surgeon, dentist, podiatrist, chiropractor, nurse, dental hygienist, optometrist, medical examiner, emergency medical technician, paramedic, or health care provider,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb917c2fb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" teacher, school counselor, instructional aide, teacher’s aide, teacher’s assistant, or bus driver employed by any tribal, Federal, public or private school,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb917c2fc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative officer, supervisor of child welfare and attendance, or truancy officer of any tribal, Federal, public or private school,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb917c2fd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" child day care worker, headstart teacher, public assistance worker, worker in a group home or residential or day care facility, or social worker,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb917c2fe-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" psychiatrist, psychologist, or psychological assistant,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb917c2ff-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" licensed or unlicensed marriage, family, or child counselor,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb917c300-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" person employed in the mental health profession, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb917c301-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" law enforcement officer, probation officer, worker in a juvenile rehabilitation or detention facility, or person employed in a public agency who is responsible for enforcing statutes and judicial orders;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb917c302-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" knows, or has reasonable suspicion, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb917c303-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a child was abused in Indian country, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb917c304-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions are being taken, or are going to be taken, that would reasonably be expected to result in abuse of a child in Indian country; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb917c305-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to immediately report such abuse or actions described in paragraph (2) to the local child protective services agency or local law enforcement agency,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title or imprisoned for not more than 6 months or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb917c306-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any person who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb917c307-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supervises, or has authority over, a person described in subsection (a)(1), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb917c308-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inhibits or prevents that person from making the report described in subsection (a),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title or imprisoned for not more than 6 months or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb917c309-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb917c30a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “abuse” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb917c30b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any case in which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb917c30c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a child is dead or exhibits evidence of skin bruising, bleeding, malnutrition, failure to thrive, burns, fracture of any bone, subdural hematoma, soft tissue swelling, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb917c30d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such condition is not justifiably explained or may not be the product of an accidental occurrence; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb917c30e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any case in which a child is subjected to sexual assault, sexual molestation, sexual exploitation, sexual contact, or prostitution;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb917c30f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “child” means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb917c310-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not married, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb917c311-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not attained 18 years of age;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb917c312-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “local child protective services agency” means that agency of the Federal Government, of a State, or of an Indian tribe that has the primary responsibility for child protection on any Indian reservation or within any community in Indian country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb917c313-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “local law enforcement agency” means that Federal, tribal, or State law enforcement agency that has the primary responsibility for the investigation of an instance of alleged child abuse within the portion of Indian country involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb917c314-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1169/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person making a report described in subsection (a) which is based upon their reasonable belief and which is made in good faith shall be immune from civil or criminal liability for making that report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb917c315-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/630/tIV/s404/a/1"},"text":"Pub. L. 101–630, title IV, § 404(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4547"},"text":"104 Stat. 4547","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII"},"text":"Pub. L. 103–322, title XXXIII","children":[],"tail":", §§ 330011(d), 330016(1)(K), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2144"},"text":"108 Stat. 2144","children":[],"tail":", 2147; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s604/b/25"},"text":"Pub. L. 104–294, title VI, § 604(b)(25)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3508"},"text":"110 Stat. 3508","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb917c316-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb917c317-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb917c318-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330011/d"},"text":"Pub. L. 103–322, § 330011(d)","children":[],"tail":". See 1994 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330011/d"},"text":"Pub. L. 103–322, § 330011(d)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":", amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/101/630/s404/a/1"},"text":"Pub. L. 101–630, § 404(a)(1)","children":[],"tail":", which enacted this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/1/K"},"text":"Pub. L. 103–322, § 330016(1)(K)","children":[],"tail":", substituted “fined under this title” for “fined not more than $5,000” in concluding provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb917c319-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb917c31a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/s604/d"},"text":"section 604(d) of Pub. L. 104–294","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s13"},"text":"section 13 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb917c31b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330011/d"},"text":"Pub. L. 103–322, title XXXIII, § 330011(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2144"},"text":"108 Stat. 2144","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s604/b/25"},"text":"Pub. L. 104–294, title VI, § 604(b)(25)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3508"},"text":"110 Stat. 3508","children":[],"tail":", provided that the amendment made by section 330011(d) is effective on the date "},{"tag":"ref","attrib":{"href":"/us/pl/101/630/s404/a"},"text":"section 404(a) of Pub. L. 101–630","children":[],"tail":" took effect."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
