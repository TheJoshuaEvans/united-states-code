{"tag":"section","attrib":{"id":"idb95344f1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258E"},"text":null,"children":[{"tag":"num","attrib":{"value":"2258E"},"text":"§ 2258E.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In sections 2258A through 2258E—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95344f2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258E/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “attorney for the government” and “State” have the meanings given those terms in rule 1 of the Federal Rules of Criminal Procedure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95344f3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258E/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “electronic communication service” has the meaning given that term in section 2510;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95344f4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258E/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “electronic mail address” has the meaning given that term in section 3 of the CAN–SPAM Act of 2003 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7702"},"text":"15 U.S.C. 7702","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95344f5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258E/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Internet” has the meaning given that term in section 1101 of the Internet Tax Freedom Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s151"},"text":"47 U.S.C. 151","children":[],"tail":" note);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95344f6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258E/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “remote computing service” has the meaning given that term in section 2711;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95344f7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258E/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “provider” means an electronic communication service provider or remote computing service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95344f8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258E/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “NCMEC” means the National Center for Missing & Exploited Children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95344f9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258E/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “website” means any collection of material placed in a computer server-based file archive so that it is publicly accessible, over the Internet, using hypertext transfer protocol or any successor protocol.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb95344fa-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/401/tV/s501/a"},"text":"Pub. L. 110–401, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4250"},"text":"122 Stat. 4250","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/395/s6"},"text":"Pub. L. 115–395, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5294"},"text":"132 Stat. 5294","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb95344fb-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb95344fc-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb95344fd-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Criminal Procedure, referred to in par. (1), are set out in the Appendix to this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1101 of the Internet Tax Freedom Act, referred to in par. (4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tXI/s1101"},"text":"section 1101 of title XI of div. C of Pub. L. 105–277","children":[],"tail":", which is set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s151"},"text":"section 151 of Title 47","children":[],"tail":", Telecommunications."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb95344fe-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/395/s6/1"},"text":"Pub. L. 115–395, § 6(1)","children":[],"tail":", substituted “2258E” for “2258D” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (6) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/395/s6/2"},"text":"Pub. L. 115–395, § 6(2)","children":[],"tail":"–(4), added pars. (6) and (7) and redesignated former par. (6) as (8)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
