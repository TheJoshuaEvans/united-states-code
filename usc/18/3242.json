{"tag":"section","attrib":{"id":"idb9988ad5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3242"},"text":null,"children":[{"tag":"num","attrib":{"value":"3242"},"text":"§ 3242.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indians committing certain offenses; acts on reservations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All Indians committing any offense listed in the first paragraph of and punishable under section 1153 (relating to offenses committed within Indian country) of this title shall be tried in the same courts and in the same manner as are all other persons committing such offense within the exclusive jurisdiction of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9988ad6-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/827"},"text":"62 Stat. 827","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-05-24/ch139/s51"},"text":"May 24, 1949, ch. 139, § 51","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/96"},"text":"63 Stat. 96","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/707/s2"},"text":"Pub. L. 89–707, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1101"},"text":"80 Stat. 1101","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/297/s4"},"text":"Pub. L. 94–297, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-29"},"text":"May 29, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/586"},"text":"90 Stat. 586","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9988ad7-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9988ad8-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9988ad9-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1948 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 548 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s328"},"text":"Mar. 4, 1909, ch. 321, § 328","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1151"},"text":"35 Stat. 1151","children":[],"tail":"; June 1932, ch. 284, "},{"tag":"ref","attrib":{"href":"/us/stat/47/337"},"text":"47 Stat. 337","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The provisions defining rape in accordance with the law of the State and prescribing imprisonment at the discretion of the court for rape by an Indian upon an Indian are now included in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1153"},"text":"section 1153 of this title","children":[],"tail":". (See also "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s6"},"text":"section 6 of this title","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 549 of said title 18, relating to crimes in Indian reservations in South Dakota, was omitted as covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1153"},"text":"section 1153 of this title","children":[],"tail":". Accordingly the last sentence of said section 548, extending this section to prosecutions of Indians in South Dakota, was also omitted as unnecessary because this section is sufficient and applicable. Other provisions of said section 548 are incorporated in sections 1151 and 1153 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9988ada-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1949 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This section [section 51] conforms ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3242"},"text":"section 3242 of title 18","children":[],"tail":", U.S.C., with sections 1151 and 1153 of such title, thus eliminating inconsistency and ambiguity with respect to the definition of Indian country."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9988adb-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9988adc-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/297"},"text":"Pub. L. 94–297","children":[],"tail":" substituted provision setting out reference to offenses listed in first paragraph of and punishable under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1153"},"text":"section 1153 of this title","children":[],"tail":", for provision specifically enumerating the covered offenses."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/707"},"text":"Pub. L. 89–707","children":[],"tail":" added carnal knowledge and assault with intent to commit rape as offenses cognizable within the exclusive jurisdiction of the United States when committed on and within the Indian country."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1949—Act ","children":[{"tag":"date","attrib":{"date":"1949-05-24"},"text":"May 24, 1949","children":[],"tail":", substituted “within the Indian country” for “within any Indian reservation, including rights-of-way running through the reservation,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
