{"tag":"section","attrib":{"id":"idb95ce176-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2317"},"text":null,"children":[{"tag":"num","attrib":{"value":"2317"},"text":"§ 2317.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale or receipt of livestock","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever receives, conceals, stores, barters, buys, sells, or disposes of any livestock, moving in or constituting a part of interstate or foreign commerce, knowing the same to have been stolen, shall be fined under this title or imprisoned not more than five years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb95ce177-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/807"},"text":"62 Stat. 807","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s1114"},"text":"Pub. L. 98–473, title II, § 1114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2149"},"text":"98 Stat. 2149","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb95ce178-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb95ce179-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., §§ 419c, 419d (","children":[{"tag":"ref","attrib":{"href":"/us/act/1941-08-18/ch366"},"text":"Aug. 18, 1941, ch. 366","children":[],"tail":", §§ 4, 5, "},{"tag":"ref","attrib":{"href":"/us/stat/55/632"},"text":"55 Stat. 632","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Definitions of “cattle” and “interstate or foreign commerce”, contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s419a"},"text":"section 419a of title 18","children":[],"tail":", U.S.C., 1940 ed., are incorporated in sections 10 and 2311 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Venue provision of said ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s419d"},"text":"section 419d of title 18","children":[],"tail":", U.S.C., 1940 ed., was omitted as completely covered by "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3237"},"text":"section 3237 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb95ce17a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb95ce17b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $5,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text