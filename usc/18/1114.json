54/s13/f/2"},"text":"Pub. L. 102–54, § 13(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-06-13"},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/275"},"text":"105 Stat. 275","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/365/s6"},"text":"Pub. L. 102–365, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-09-03"},"text":"Sept. 3, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/975"},"text":"106 Stat. 975","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tVI/s60007"},"text":"Pub. L. 103–322, title VI, § 60007","children":[],"tail":", title XXXIII, §§ 330009(c), 330011(g), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1971"},"text":"108 Stat. 1971","children":[],"tail":", 2143, 2145; "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tVII/s727/a"},"text":"Pub. L. 104–132, title VII, § 727(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1302"},"text":"110 Stat. 1302","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s601/f/2"},"text":"Pub. L. 104–294, title VI, § 601(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3499"},"text":"110 Stat. 3499","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dB/tIV/s4002/c/1"},"text":"Pub. L. 107–273, div. B, title IV, § 4002(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1808"},"text":"116 Stat. 1808","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/59/s3/3"},"text":"Pub. L. 117–59, § 3(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-18"},"text":"Nov. 18, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1469"},"text":"135 Stat. 1469","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91307fc-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb91307fd-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb91307fe-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1948 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 253 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-05-18/ch299/s1"},"text":"May 18, 1934, ch. 299, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/780"},"text":"48 Stat. 780","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-02-08/ch40"},"text":"Feb. 8, 1936, ch. 40","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1105"},"text":"49 Stat. 1105","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-26/ch830"},"text":"June 26, 1936, ch. 830","children":[],"tail":", title I, § 3, "},{"tag":"ref","attrib":{"href":"/us/stat/49/1940"},"text":"49 Stat. 1940","children":[],"tail":"; Reorg. Plan No. II, § 4(f), eff. "},{"tag":"date","attrib":{"date":"1939-07-01"},"text":"July 1, 1939","children":[],"tail":", 4 F.R. 2731, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1433"},"text":"53 Stat. 1433","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1940-06-13/ch359"},"text":"June 13, 1940, ch. 359","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/391"},"text":"54 Stat. 391","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The section was extended to include United States judges, attorneys and their assistants, and officers of Federal, penal and correctional institutions in view of the obvious desirability of such protective legislation.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Employees of the Bureau of Animal Industry have been included in this section to complete the revision of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s118"},"text":"section 118 of title 18","children":[],"tail":", U.S.C., 1940 ed., which was consolidated with the assault provisions of section 254 of said title 18 and is now "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s111"},"text":"section 111 of this title","children":[],"tail":". There seemed no sound reason for including such officers in the protection against assaults but excluding them from the homicide sections."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For like reasons the section was broadened to include officers or employees of the Secret Service or of the Bureau of Narcotics.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb91307ff-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1949 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This section [section 24] amends ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1114"},"text":"section 1114 of title 18","children":[],"tail":", U.S.C., to conform more closely with the original statute from which it was derived."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9130800-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9130801-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/59"},"text":"Pub. L. 117–59","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" repealed amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":". See 1996 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132"},"text":"Pub. L. 104–132","children":[],"tail":" reenacted section catchline without change and amended text generally, restructuring provisions by inserting par. designations and substituting reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1113"},"text":"section 1113 of this title","children":[],"tail":" and general reference to killing or attempting to kill any officer or employee of any agency in any branch of United States Government for more specific references to killing or attempting to kill certain enumerated officers and employees of United States."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":", which directed substitution in text of “1112,” for “1112.” and could not be executed, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":". See above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330011/g"},"text":"Pub. L. 103–322, § 330011(g)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/s1606"},"text":"Pub. L. 101–647, § 1606","children":[],"tail":". See 1990 Amendment notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330009/c"},"text":"Pub. L. 103–322, § 330009(c)","children":[],"tail":", substituted “or any other officer or employee of the United States or any agency thereof” for “or any other officer, agency, or employee of the United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s60007"},"text":"Pub. L. 103–322, § 60007","children":[],"tail":", substituted “punished, in the case of murder, as provided under section 1111, or, in the case of manslaughter, as provided under section 1112.” for “punished as provided under sections 1111 and 1112 of this title,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/365"},"text":"Pub. L. 102–365","children":[],"tail":" inserted “any officer or employee of the Federal Railroad Administration assigned to perform investigative, inspection, or law enforcement functions,” after “any employee of the Coast Guard assigned to perform investigative, inspection or law enforcement functions,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54"},"text":"Pub. L. 102–54","children":[],"tail":" substituted “Department of Veterans Affairs” for “Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/s3535/3"},"text":"Pub. L. 101–647, § 3535(3)","children":[],"tail":", which directed amendment of section by striking out “the Federal Savings and Loan Insurance Corporation,” could not be executed because that language had been struck out by "},{"tag":"ref","attrib":{"href":"/us/pl/101/73"},"text":"Pub. L. 101–73","children":[],"tail":". See 1989 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/s1606/3"},"text":"Pub. L. 101–647, § 1606(3)","children":[],"tail":", which amended this section identically to amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/s3535/3"},"text":"Pub. L. 101–647, § 3535(3)","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330011/g"},"text":"Pub. L. 103–322, § 330011(g)","children":[],"tail":". See above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/s3535/1"},"text":"Pub. L. 101–647, § 3535(1)","children":[],"tail":", (2), substituted “Secret Service” for “secret service” and “any officer or employee of the Department of Education, the Department of Health and Human Services,” for “any officer or employee of the Department of Health, Education, and Welfare,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/s1606/1"},"text":"Pub. L. 101–647, § 1606(1)","children":[],"tail":", (2), which amended this section identically to amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/s3535/1"},"text":"Pub. L. 101–647, § 3535(1)","children":[],"tail":", (2), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330011/g"},"text":"Pub. L. 103–322, § 330011(g)","children":[],"tail":". See above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/s1205/h"},"text":"Pub. L. 101–647, § 1205(h)","children":[],"tail":", inserted “or any other commonwealth, territory, or possession” after “the Virgin Islands”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73"},"text":"Pub. L. 101–73","children":[],"tail":" struck out “the Federal Savings and Loan Insurance Corporation,” after “Federal Deposit Insurance Corporation,” and substituted “the Office of Thrift Supervision, the Federal Housing Finance Board, the Resolution Trust Corporation” for “the Federal Home Loan Bank Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" struck out second comma after “terms of this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557"},"text":"Pub. L. 98–557","children":[],"tail":" substituted reference to Coast Guard member, and Coast Guard employee assigned to perform investigative, inspection or law enforcement functions, for reference to any officer or enlisted man of the Coast Guard."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":" inserted “or attempts to kill” after “Whoever kills”, substituted “or any United States probation or pretrial services officer, or any United States magistrate, or any officer or employee of any department or agency within the Intelligence Community (as defined in section 3.4(F) of Executive Order 12333, "},{"tag":"date","attrib":{"date":"1981-12-08"},"text":"December 8, 1981","children":[],"tail":", or successor orders) not already covered under the terms of this section,” for “while engaged in the performance of his official duties or on account of the performance of his official duties”, inserted “, or any other officer, agency, or employee of the United States designated for coverage under this section in regulations issued by the Attorney General”, and inserted “, except that any such person who is found guilty of attempted murder shall be imprisoned for not more than twenty years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/63"},"text":"Pub. L. 98–63","children":[],"tail":" inserted “any civilian official or employee of the Army Corps of Engineers assigned to perform investigations, inspections, law or regulatory enforcement functions, or field-level real estate functions,” after “National Park Service,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/452"},"text":"Pub. L. 97–452","children":[],"tail":" substituted “sections 3711 and 3716–3718 of title 31” for “the Federal Claims Collection Act of 1966 ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s951"},"text":"31 U.S.C. 951","children":[],"tail":" et seq.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/365"},"text":"Pub. L. 97–365","children":[],"tail":" struck out “or” before “any attorney, liquidator, examiner, claim agent” and inserted “, or any officer or employee of the United States or any agency thereof designated to collect or compromise a Federal claim in accordance with the Federal Claims Collection Act of 1966 ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s951"},"text":"31 U.S.C. 951","children":[],"tail":" et seq.) or other statutory authority” before “shall be punished”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/259"},"text":"Pub. L. 97–259","children":[],"tail":" inserted “or any officer or employee of the Federal Communications Commission performing investigative, inspection, or law enforcement functions,” after “or law enforcement functions,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/143"},"text":"Pub. L. 97–143","children":[],"tail":" inserted “any officer or member of the United States Capitol Police,” after “Drug Enforcement Administration,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466"},"text":"Pub. L. 96–466","children":[],"tail":" inserted “or any officer or employee of the Veterans’ Administration assigned to perform investigative or law enforcement functions,” after “of the Department of Agriculture assigned to perform investigative, inspection, or law enforcement functions,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/296"},"text":"Pub. L. 96–296","children":[],"tail":" inserted “Interstate Commerce Commission,” after “Consumer Product Safety Commission,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630"},"text":"Pub. L. 95–630","children":[],"tail":" inserted “or any attorney, liquidator, examiner, claim agent, or other employee of the Federal Deposit Insurance Corporation, the Federal Savings and Loan Insurance Corporation, the Comptroller of the Currency, the Federal Home Loan Bank Board, the Board of Governors of the Federal Reserve System, any Federal Reserve bank, or the National Credit Union Administration engaged in or on account of the performance of his official duties” before “shall be punished”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/616"},"text":"Pub. L. 95–616","children":[],"tail":" inserted “the Department of Commerce,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/87"},"text":"Pub. L. 95–87","children":[],"tail":" inserted “or of the Department of the Interior” after “or of the Department of Labor”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/582"},"text":"Pub. L. 94–582","children":[],"tail":" struck out “any employee of the Bureau of Animal Industry of the Department of Agriculture,” after “the field service of the Bureau of Land Management,” and inserted “or of the Department of Agriculture” after “or of the Department of Labor”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/284"},"text":"Pub. L. 94–284","children":[],"tail":" inserted “, the Consumer Product Safety Commission,” after “Department of Health, Education, and Welfare”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/481"},"text":"Pub. L. 93–481","children":[],"tail":" substituted “Drug Enforcement Administration” for “Bureau of Narcotics and Dangerous Drugs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/596"},"text":"Pub. L. 91–596","children":[],"tail":" substituted “or of the Department of Labor assigned to perform investigative, inspection, or law enforcement functions”, for “designated by the Secretary of Health, Education, and Welfare to conduct investigations, or inspections under the Federal Food, Drug, and Cosmetic Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513"},"text":"Pub. L. 91–513","children":[],"tail":" substituted “Bureau of Narcotics and Dangerous Drugs” for “Bureau of Narcotics”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":" substituted “officer or employee of the Postal Service”, for “postal inspector, any postmaster, officer, or employee in the field service of the Post Office Department” after “Department of Justice,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/449"},"text":"Pub. L. 90–449","children":[],"tail":" substituted “any postal inspector, any postmaster, officer, or employee in the field service of the Post Office Department” for “any post-offi