attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as an Effective Date note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of Title 39","children":[],"tail":", Postal Service."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb9130809-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1965 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/74"},"text":"Pub. L. 89–74","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1965-07-15"},"text":"July 15, 1965","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/89/74/s11"},"text":"section 11 of Pub. L. 89–74","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idb913080a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513"},"text":"Pub. L. 91–513","children":[],"tail":" not to affect or abate any prosecutions for violation of law or any civil seizures or forfeitures and injunctive proceedings commenced prior to the effective date of such amendment, and all administrative proceedings pending before the Bureau of Narcotics and Dangerous Drugs on "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", to be continued and brought to final determination in accord with laws and regulations in effect prior to "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/513/s702"},"text":"section 702 of Pub. L. 91–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s321"},"text":"section 321 of Title 21","children":[],"tail":", Food and Drugs."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb913080b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Sense of Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/59/s2"},"text":"Pub. L. 117–59, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-18"},"text":"Nov. 18, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1468"},"text":"135 Stat. 1468","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/59/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“It is the sense of Congress that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" since the founding of the Nation, officers and employees of the United States Government have dutifully and faithfully served the United States overseas, including in situations that place them at serious risk of death or bodily harm, in order to preserve, protect, and defend the interests of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" securing the safety of such officers and employees while serving overseas is of paramount importance and is also in furtherance of preserving, protecting, and defending the interests of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal courts, including the United States Court of Appeals for the Second Circuit, the United States Court of Appeals for the Ninth Circuit, and the United States Court of Appeals for the Eleventh Circuit, have correctly interpreted ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1114"},"text":"section 1114 of title 18","children":[],"tail":", United States Code, to apply extraterritorially to protect officers and employees of the United States while the officers and employees are serving abroad;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a case involving a violent attack against Federal law enforcement officers Jaime Zapata and Victor Avila, a panel of a Federal court of appeals held that ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1114"},"text":"section 1114 of title 18","children":[],"tail":", United States Code, does not apply extraterritorially, creating a split among the United States circuit courts of appeals;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in light of the opinion described in paragraph (4), it has become necessary for Congress to clarify the original intent that ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1114"},"text":"section 1114 of title 18","children":[],"tail":", United States Code, applies extraterritorially; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is further appropriate to clarify the original intent that sections 111 and 115 of title 18, United States Code, apply extraterritorially as well.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb91550fc-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Life Imprisonment or Lesser Term for Killing Person in Performance of Investigative, Inspection, or Law Enforcement Functions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/596/s17/h/2"},"text":"Pub. L. 91–596, § 17(h)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-29"},"text":"Dec. 29, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1607"},"text":"84 Stat. 1607","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/596/s17/h/2"},"text":"“Notwithstanding the provisions of sections 1111 and 1114 of title 18, United States Code, whoever, in violation of the provisions of section 1114 of such title, kills a person while engaged in or on account of the performance of investigative, inspection, or law enforcement functions added to such section 1114 by paragraph (1) of this subsection, and who would otherwise be subject to the penalty provisions of such section 1111 shall be punished by imprisonment for any term of years or for life.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb91550fd-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Immunity From Criminal Prosecution","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/88/493/s5"},"text":"Pub. L. 88–493, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-27"},"text":"Aug. 27, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/610"},"text":"78 Stat. 610","children":[],"tail":", which provided that nothing in "},{"tag":"ref","attrib":{"href":"/us/pl/88/493"},"text":"Pub. L. 88–493","children":[],"tail":", which amended this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s112"},"text":"section 112 of this title","children":[],"tail":", and enacted former section 170e-1 of Title 5, Government Organization and Employees, shall create immunity from criminal prosecution under the laws of any State, territory, possession, Puerto Rico, or the District of Columbia, is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s112"},"text":"section 112 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
