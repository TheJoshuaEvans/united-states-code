{"tag":"section","attrib":{"id":"idb91307f5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1114"},"text":null,"children":[{"tag":"num","attrib":{"value":"1114"},"text":"§ 1114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of officers and employees of the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb91307f6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever kills or attempts to kill any officer or employee of the United States or of any agency in any branch of the United States Government (including any member of the uniformed services) while such officer or employee is engaged in or on account of the performance of official duties, or any person assisting such an officer or employee in the performance of such duties or on account of that assistance, shall be punished—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91307f7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1114/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of murder, as provided under section 1111;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91307f8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1114/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of manslaughter, as provided under section 1112; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91307f9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1114/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of attempted murder or manslaughter, as provided in section 1113.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91307fa-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extraterritorial Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is extraterritorial jurisdiction over the conduct prohibited by this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb91307fb-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/756"},"text":"62 Stat. 756","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-05-24/ch139/s24"},"text":"May 24, 1949, ch. 139, § 24","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/93"},"text":"63 Stat. 93","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1951-10-31/ch655/s28"},"text":"Oct. 31, 1951, ch. 655, § 28","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/721"},"text":"65 Stat. 721","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title IV, § 402(c), "},{"tag":"ref","attrib":{"href":"/us/stat/66/276"},"text":"66 Stat. 276","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/568/tIII/s304/d"},"text":"Pub. L. 85–568, title III, § 304(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-07-29"},"text":"July 29,