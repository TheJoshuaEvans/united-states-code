{"tag":"section","attrib":{"id":"idb98a32db-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3062"},"text":null,"children":[{"tag":"num","attrib":{"value":"3062"},"text":"§ 3062.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General arrest authority for violation of release conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A law enforcement officer, who is authorized to arrest for an offense committed in his presence, may arrest a person who is released pursuant to chapter 207 if the officer has reasonable grounds to believe that the person is violating, in his presence, a condition imposed on the person pursuant to section 3142(c)(1)(B)(iv), (v), (viii), (ix), or (xiii), or, if the violation involves a failure to remain in a specified institution as required, a condition imposed pursuant to section 3142(c)(1)(B)(x).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb98a32dc-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s204/d"},"text":"Pub. L. 98–473, title II, § 204(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1986"},"text":"98 Stat. 1986","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7052"},"text":"Pub. L. 100–690, title VII, § 7052","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4401"},"text":"102 Stat. 4401","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb98a32dd-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb98a32de-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb98a32df-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" substituted “section 3142(c)(1)(B)(iv), (v), (viii), (ix), or (xiii)” for “section 3142(c)(2)(D), (c)(2)(E), (c)(2)(H), (c)(2)(I), or (c)(2)(M)” and “section 3142(c)(1)(B)(x)” for “section 3142(c)(2)(J)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
