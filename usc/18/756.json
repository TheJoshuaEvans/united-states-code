{"tag":"section","attrib":{"id":"idb8e0d41f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s756"},"text":null,"children":[{"tag":"num","attrib":{"value":"756"},"text":"§ 756.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internee of belligerent nation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, within the jurisdiction of the United States, aids or entices any person belonging to the armed forces of a belligerent nation or faction who is interned in the United States in accordance with the law of nations, to escape or attempt to escape from the jurisdiction of the United States or from the limits of internment prescribed, shall be fined under this title or imprisoned not more than five years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8e0d420-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/735"},"text":"62 Stat. 735","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tVII/s705/a/3"},"text":"Pub. L. 104–132, title VII, § 705(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1295"},"text":"110 Stat. 1295","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8e0d421-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","a