{"tag":"section","attrib":{"id":"idb8e8004e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s875"},"text":null,"children":[{"tag":"num","attrib":{"value":"875"},"text":"§ 875.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interstate communications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8e8004f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s875/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever transmits in interstate or foreign commerce any communication containing any demand or request for a ransom or reward for the release of any kidnapped person, shall be fined under this title or imprisoned not more than twenty years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8e80050-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s875/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever, with intent to extort from any person, firm, association, or corporation, any money or other thing of value, transmits in interstate or foreign commerce any communication containing any threat to kidnap any person or any threat to injure the person of another, shall be fined under this title or imprisoned not more than twenty years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8e80051-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s875/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever transmits in interstate or foreign commerce any communication containing any threat to kidnap any person or any threat to injure the person of another, shall be fined under this title or imprisoned not more than five years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8e80052-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s875/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever, with intent to extort from any person, firm, association, or corporation, any money or other thing of value, transmits in interstate or foreign commerce any communication containing any threat to injure the property or reputation of the addressee or of another or the reputation of a deceased person or any threat to accuse the addressee or any other person of a crime, shall be fined under this title or imprisoned not more than two years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8e80053-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/741"},"text":"62 Stat. 741","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/646/s63"},"text":"Pub. L. 99–646, § 63","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3614"},"text":"100 Stat. 3614","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/G"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(G)","children":[],"tail":", (H), (K), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8e80054-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8e80055-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 408d (","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-05-18/ch300"},"text":"May 18, 1934, ch. 300","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/781"},"text":"48 Stat. 781","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1939-05-15/ch133/s2"},"text":"May 15, 1939, ch. 133, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/743"},"text":"53 Stat. 743","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions as to district of trial were omitted as covered by sections 3237 and 3239 of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Definition of “interstate commerce” was omitted in conformity with definitive ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s10"},"text":"section 10 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology and arrangement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8e80056-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8e80057-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/1/K"},"text":"Pub. L. 103–322, § 330016(1)(K)","children":[],"tail":", substituted “fined under this title” for “fined not more than $5,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/1/H"},"text":"Pub. L. 103–322, § 330016(1)(H)","children":[],"tail":", substituted “fined under this title” for “fined not more than $1,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/1/G"},"text":"Pub. L. 103–322, § 330016(1)(G)","children":[],"tail":", substituted “fined under this title” for “fined not more than $500”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646"},"text":"Pub. L. 99–646","children":[],"tail":" inserted “or foreign” after “interstate” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
