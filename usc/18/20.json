{"tag":"section","attrib":{"id":"idb8a2e08b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"§ 20.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial institution defined","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this title, the term “financial institution” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a2e08c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s20/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an insured depository institution (as defined in section 3(c)(2) of the Federal Deposit Insurance Act);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a2e08d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s20/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a credit union with accounts insured by the National Credit Union Share Insurance Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a2e08e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s20/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal home loan bank or a member, as defined in section 2 of the Federal Home Loan Bank Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1422"},"text":"12 U.S.C. 1422","children":[],"tail":"), of the Federal home loan bank system;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a2e08f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s20/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a System institution of the Farm Credit System, as defined in section 5.35(3) of the Farm Credit Act of 1971;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a2e090-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s20/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a small business investment company, as defined in section 103 of the Small Business Investment Act of 1958 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s662"},"text":"15 U.S.C. 662","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a2e091-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s20/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a depository institution holding company (as defined in section 3(w)(1) of the Federal Deposit Insurance Act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a2e092-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s20/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal Reserve bank or a member bank of the Federal Reserve System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a2e093-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s20/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization operating under section 25 or section 25(a) ","children":[{"tag":"ref","attrib":{"idref":"fn002007"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002007"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Federal Reserve Act;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a2e094-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s20/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a branch or agency of a foreign bank (as such terms are defined in paragraphs (1) and (3) of section 1(b) of the International Banking Act of 1978); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a2e095-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s20/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a mortgage lending business (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s27"},"text":"section 27 of this title","children":[],"tail":") or any person or entity that makes in whole or in part a federally related mortgage loan as defined in section 3 of the Real Estate Settlement Procedures Act of 1974."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8a2e096-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s1107/a"},"text":"Pub. L. 98–473, title II, § 1107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2145"},"text":"98 Stat. 2145","children":[],"tail":", § 215(b); amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/370/s2"},"text":"Pub. L. 99–370, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-04"},"text":"Aug. 4, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/779"},"text":"100 Stat. 779","children":[],"tail":"; renumbered § 20 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tIX/s962/e/1"},"text":"Pub. L. 101–73, title IX, § 962(e)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/503"},"text":"103 Stat. 503","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV/s2597/a"},"text":"Pub. L. 101–647, title XXV, § 2597(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4908"},"text":"104 Stat. 4908","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/21/s2/a"},"text":"Pub. L. 111–21, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1617"},"text":"123 Stat. 1617","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8a2e097-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8a2e098-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8a2e099-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 3 of the Federal Deposit Insurance Act, referred to in pars. (1) and (6), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 5.35(3) of the Farm Credit Act of 1971, referred to in par. (4), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2271/3"},"text":"section 2271(3) of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 25 of the Federal Reserve Act, referred to in par. (8), is classified to subchapter I (§ 601 et seq.) of chapter 6 of Title 12, Banks and Banking. Section 25(a) of the Federal Reserve Act, which is classified to subchapter II (§ 611 et seq.) of chapter 6 of Title 12, was renumbered section 25A of that act by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/242/tI/s142/e/2"},"text":"Pub. L. 102–242, title I, § 142(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2281"},"text":"105 Stat. 2281","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1(b) of the International Banking Act of 1978, referred to in par. (9), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3101"},"text":"section 3101 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3 of the Real Estate Settlement Procedures Act of 1974, referred to in par. (10), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2602"},"text":"section 2602 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb8a2e09a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 20 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s17"},"text":"section 17 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8a2e09b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Par. (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/21"},"text":"Pub. L. 111–21","children":[],"tail":" added par. (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Pars. (7) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":" added pars. (7) to (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s962/e/1"},"text":"Pub. L. 101–73, § 962(e)(1)","children":[],"tail":", (2)(A)–(C), redesignated subsec. (b) of "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s215"},"text":"section 215 of this title","children":[],"tail":" as this section, inserted section catchline, struck out subsec. (b) designation before “As used”, and substituted “used in this title” for “used in this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s962/e/2/D"},"text":"Pub. L. 101–73, § 962(e)(2)(D)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “a bank with deposits insured by the Federal Deposit Insurance Corporation;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s962/e/2/E"},"text":"Pub. L. 101–73, § 962(e)(2)(E)","children":[],"tail":", (H), redesignated par. (3) as (2) and struck out former par. (2) which read as follows: “an institution with accounts insured by the Federal Savings and Loan Insurance Corporation;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s962/e/2/H"},"text":"Pub. L. 101–73, § 962(e)(2)(H)","children":[],"tail":", redesignated par. (4) as (3). Former par. (3) redesignated (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s962/e/2/F"},"text":"Pub. L. 101–73, § 962(e)(2)(F)","children":[],"tail":", (H), redesignated par. (5) as (4) and amended it generally. Prior to amendment, par. (4) read as follows: “a Federal land bank, Federal intermediate credit bank, bank for cooperatives, production credit association, and Federal land bank association;”. Former par. (4) redesignated (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s962/e/2/H"},"text":"Pub. L. 101–73, § 962(e)(2)(H)","children":[],"tail":", redesignated par. (6) as (5). Former par. (5) redesignated (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s962/e/2/G"},"text":"Pub. L. 101–73, § 962(e)(2)(G)","children":[],"tail":", (H), redesignated par. (7) as (6) and amended it generally. Prior to amendment, par. (6) read as follows: “a bank holding company as defined in section 2 of the Bank Holding Company Act of 1956 ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1841"},"text":"12 U.S.C. 1841","children":[],"tail":"); or”. Former par. (6) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s962/e/2/E"},"text":"Pub. L. 101–73, § 962(e)(2)(E)","children":[],"tail":", struck out par. (8) which read as follows: “a savings and loan holding company as defined in section 408 of the National Housing Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1730a"},"text":"12 U.S.C. 1730a","children":[],"tail":").”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/370"},"text":"Pub. L. 99–370","children":[],"tail":" amended subsec. (b) [formerly § 215(b)] generally expanding provisions formerly contained in subsec. (c) [former § 215(c)] defining “financial institution”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
