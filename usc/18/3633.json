{"tag":"section","attrib":{"id":"idb9b9ce8c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3633"},"text":null,"children":[{"tag":"num","attrib":{"value":"3633"},"text":"§ 3633.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evidence-based recidivism reduction program and recommendations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9b9ce8d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3633/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Prior to releasing the System, in consultation with the Independent Review Committee authorized by the First Step Act of 2018, the Attorney General shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9b9ce8e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3633/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the effectiveness of evidence-based recidivism reduction programs that exist as of the date of enactment of this subchapter in prisons operated by the Bureau of Prisons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9b9ce8f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3633/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review available information regarding the effectiveness of evidence-based recidivism reduction programs and productive activities that exist in State-operated prisons throughout the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9b9ce90-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3633/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the most effective evidence-based recidivism reduction programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9b9ce91-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3633/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the policies for entering into evidence-based recidivism reduction partnerships described in section 3621(h)(5); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9b9ce92-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3633/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" direct the Bureau of Prisons regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9b9ce93-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3633/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evidence-based recidivism reduction programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9b9ce94-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3633/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability for faith-based organizations to function as a provider of educational evidence-based programs outside of the religious classes and services provided through the Chaplaincy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9b9ce95-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3633/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the addition of any new effective evidence-based recidivism reduction programs that the Attorney General finds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9b9ce96-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3633/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review and Recommendations Regarding Dyslexia Mitigation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), the Attorney General shall consider the prevalence and mitigation of dyslexia in prisons, including by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9b9ce97-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3633/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviewing statistics on the prevalence of dyslexia, and the effectiveness of any programs implemented to mitigate the effects of dyslexia, in prisons operated by the Bureau of Prisons and State-operated prisons throughout the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9b9ce98-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3633/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporating the findings of the Attorney General under paragraph (1) of this subsection into any directives given to the Bureau of Prisons under paragraph (5) of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9b9ce99-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/391/tI/s101/a"},"text":"Pub. L. 115–391, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5204"},"text":"132 Stat. 5204","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9b9ce9a-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9b9ce9b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9b9ce9c-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The First Step Act of 2018, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/391"},"text":"Pub. L. 115–391","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5194"},"text":"132 Stat. 5194","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2018 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1"},"text":"section 1 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of this subchapter, referred to in subsec. (a)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/391"},"text":"Pub. L. 115–391","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
