{"tag":"section","attrib":{"id":"idb92863c9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1582"},"text":null,"children":[{"tag":"num","attrib":{"value":"1582"},"text":"§ 1582.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vessels for slave trade","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, whether as master, factor, or owner, builds, fits out, equips, loads, or otherwise prepares or sends away any vessel, in any port or place within the United States, or causes such vessel to sail from any such port or place, for the purpose of procuring any person from any foreign kingdom or country to be transported and held, sold, or otherwise disposed of as a slave, or held to service or labor, shall be fined under this title or imprisoned not more than seven years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb92863ca-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/772"},"text":"62 Stat. 772","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92863cb-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb92863cc-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 424 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s249"},"text":"Mar. 4, 1909, ch. 321, § 249","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1139"},"text":"35 Stat. 1139","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “within the United States” were substituted for “within the jurisdiction of the United States”. See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s5"},"text":"section 5 of this title","children":[],"tail":" defining “United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provision for division of the fine and its recovery by private person was omitted. (See reviser’s note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1585"},"text":"section 1585 of this title","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Mandatory-punishment provisions were rephrased in the alternative.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92863cd-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92863ce-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $5,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
