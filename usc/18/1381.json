{"tag":"section","attrib":{"id":"idb91eedde-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1381"},"text":null,"children":[{"tag":"num","attrib":{"value":"1381"},"text":"§ 1381.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enticing desertion and harboring deserters","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever entices or procures, or attempts or endeavors to entice or procure any person in the Armed Forces of the United States, or who has been recruited for service therein, to desert therefrom, or aids any such person in deserting or in attempting to desert from such service; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever harbors, conceals, protects, or assists any such person who may have deserted from such service, knowing him to have deserted therefrom, or refuses to give up and deliver such person on the demand of any officer authorized to receive him—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Shall be fined under this title or imprisoned not more than three years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb91eeddf-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/764"},"text":"62 Stat. 764","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/I"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(I)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91eede0-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb91eede1-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 94 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s42"},"text":"Mar. 4, 1909, ch. 321, § 42","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1097"},"text":"35 Stat. 1097","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Mandatory punishment provisions were changed to alternative.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “armed forces” were substituted for repeated references to military service, naval service, soldier and seamen.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb91eede2-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb91eede3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $2,000” in last par."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
