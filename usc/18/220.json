{"tag":"section","attrib":{"id":"idb8bf9079-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220"},"text":null,"children":[{"tag":"num","attrib":{"value":"220"},"text":"§ 220.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Illegal remunerations for referrals to recovery homes, clinical treatment facilities, and laboratories","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8bf907a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offense","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), whoever, with respect to services covered by a health care benefit program, in or affecting interstate or foreign commerce, knowingly and willfully—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8bf907b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solicits or receives any remuneration (including any kickback, bribe, or rebate) directly or indirectly, overtly or covertly, in cash or in kind, in return for referring a patient or patronage to a recovery home, clinical treatment facility, or laboratory; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf907c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" pays or offers any remuneration (including any kickback, bribe, or rebate) directly or indirectly, overtly or covertly, in cash or in kind—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8bf907d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to induce a referral of an individual to a recovery home, clinical treatment facility, or laboratory; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8bf907e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in exchange for an individual using the services of that recovery home, clinical treatment facility, or laboratory,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined not more than $200,000, imprisoned not more than 10 years, or both, for each occurrence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8bf907f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8bf9080-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a discount or other reduction in price obtained by a provider of services or other entity under a health care benefit program if the reduction in price is properly disclosed and appropriately reflected in the costs claimed or charges made by the provider or entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf9081-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a payment made by an employer to an employee or independent contractor (who has a bona fide employment or contractual relationship with such employer) for employment, if the employee’s payment is not determined by or does not vary by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8bf9082-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of individuals referred to a particular recovery home, clinical treatment facility, or laboratory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8bf9083-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of tests or procedures performed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8bf9084-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount billed to or received from, in part or in whole, the health care benefit program from the individuals referred to a particular recovery home, clinical treatment facility, or laboratory;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf9085-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a discount in the price of an applicable drug of a manufacturer that is furnished to an applicable beneficiary under the Medicare coverage gap discount program under section 1860D–14A(g) of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–114a/g"},"text":"42 U.S.C. 1395w–114a(g)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf9086-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a payment made by a principal to an agent as compensation for the services of the agent under a personal services and management contract that meets the requirements of section 1001.952(d) of title 42, Code of Federal Regulations, as in effect on the date of enactment of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf9087-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a waiver or discount (as defined in section 1001.952(h)(5) of title 42, Code of Federal Regulations, or any successor regulation) of any coinsurance or copayment by a health care benefit program if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8bf9088-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the waiver or discount is not routinely provided; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8bf9089-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the waiver or discount is provided in good faith;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf908a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a remuneration described in section 1128B(b)(3)(I) of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7b/b/3/I"},"text":"42 U.S.C. 1320a–7b(b)(3)(I)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf908b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a remuneration made pursuant to an alternative payment model (as defined in section 1833(z)(3)(C) of the Social Security Act) or pursuant to a payment arrangement used by a State, health insurance issuer, or group health plan if the Secretary of Health and Human Services has determined that such arrangement is necessary for care coordination or value-based care; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf908c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other payment, remuneration, discount, or reduction as determined by the Attorney General, in consultation with the Secretary of Health and Human Services, by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8bf908d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Attorney General, in consultation with the Secretary of Health and Human Services, may promulgate regulations to clarify the exceptions described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8bf908e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preemption.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8bf908f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall not apply to conduct that is prohibited under section 1128B of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7b"},"text":"42 U.S.C. 1320a–7b","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf9090-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to occupy the field in which any provisions of this section operate to the exclusion of State laws on the same subject matter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8bf9091-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8bf9092-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “applicable beneficiary” and “applicable drug” have the meanings given those terms in section 1860D–14A(g) of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–114a/g"},"text":"42 U.S.C. 1395w–114a(g)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf9093-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “clinical treatment facility” means a medical setting, other than a hospital, that provides detoxification, risk reduction, outpatient treatment and care, residential treatment, or rehabilitation for substance use, pursuant to licensure or certification under State law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf9094-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “health care benefit program” has the meaning given the term in section 24(b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf9095-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “laboratory” has the meaning given the term in section 353 of the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s263a"},"text":"42 U.S.C. 263a","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf9096-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s220/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “recovery home” means a shared living environment that is, or purports to be, free from alcohol and illicit drug use and centered on peer support and connection to services that promote sustained recovery from substance use disorders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8bf9097-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVIII/s8122/a"},"text":"Pub. L. 115–271, title VIII, § 8122(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4108"},"text":"132 Stat. 4108","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8bf9098-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8bf9099-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8bf909a-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (b)(4), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271"},"text":"Pub. L. 115–271","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1833(z)(3)(C) of the Social Security Act, referred to in subsec. (b)(7), is classified to section 1395","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(z)(3)(C) of Title 42, The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb8bf909b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 220 was renumbered section 215.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
