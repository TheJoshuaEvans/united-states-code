{"tag":"section","attrib":{"id":"idb8aa0c9a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43"},"text":null,"children":[{"tag":"num","attrib":{"value":"43"},"text":"§ 43.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Force, violence, and threats involving animal enterprises","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8aa0c9b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offense","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever travels in interstate or foreign commerce, or uses or causes to be used the mail or any facility of interstate or foreign commerce—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8aa0c9c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the purpose of damaging or interfering with the operations of an animal enterprise; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8aa0c9d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in connection with such purpose—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8aa0c9e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intentionally damages or causes the loss of any real or personal property (including animals or records) used by an animal enterprise, or any real or personal property of a person or entity having a connection to, relationship with, or transactions with an animal enterprise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8aa0c9f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intentionally places a person in reasonable fear of the death of, or serious bodily injury to that person, a member of the immediate family (as defined in section 115) of that person, or a spouse or intimate partner of that person by a course of conduct involving threats, acts of vandalism, property damage, criminal trespass, harassment, or intimidation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8aa0ca0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conspires or attempts to do so;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished as provided for in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8aa0ca1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The punishment for a violation of section ","children":[{"tag":"ref","attrib":{"idref":"fn002017"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002017"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection”."}],"tail":" (a) or an attempt or conspiracy to violate subsection (a) shall be—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8aa0ca2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a fine under this title or imprisonment not ","children":[{"tag":"ref","attrib":{"idref":"fn002018"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002018"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be preceded by “for”."}],"tail":" more than 1 year, or both, if the offense does not instill in another the reasonable fear of serious bodily injury or death and—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8aa0ca3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense results in no economic damage or bodily injury; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8aa0ca4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense results in economic damage that does not exceed $10,000;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8aa0ca5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a fine under this title or imprisonment for not more than 5 years, or both, if no bodily injury occurs and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8aa0ca6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense results in economic damage exceeding $10,000 but not exceeding $100,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8aa0ca7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense instills in another the reasonable fear of serious bodily injury or death;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8aa0ca8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a fine under this title or imprisonment for not more than 10 years, or both, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8aa0ca9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense results in economic damage exceeding $100,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8aa0caa-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense results in substantial bodily injury to another individual;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8aa0cab-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a fine under this title or imprisonment for not more than 20 years, or both, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8aa0cac-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense results in serious bodily injury to another individual; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8aa0cad-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense results in economic damage exceeding $1,000,000; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8aa0cae-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imprisonment for life or for any terms of years, a fine under this title, or both, if the offense results in death of another individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8aa0caf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restitution","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An order of restitution under section 3663 or 3663A of this title with respect to a violation of this section may also include restitution—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8aa0cb0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the reasonable cost of repeating any experimentation that was interrupted or invalidated as a result of the offense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8aa0cb1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the loss of food production or farm income reasonably attributable to the offense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8aa0cb2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any other economic damage, including any losses or costs caused by economic disruption, resulting from the offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8aa0cb3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8aa0cb4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “animal enterprise” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8aa0cb5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a commercial or academic enterprise that uses or sells animals or animal products for profit, food or fiber production, agriculture, education, research, or testing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8aa0cb6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a zoo, aquarium, animal shelter, pet store, breeder, furrier, circus, or rodeo, or other lawful competitive animal event; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8aa0cb7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any fair or similar event intended to advance agricultural arts and sciences;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8aa0cb8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “course of conduct” means a pattern of conduct composed of 2 or more acts, evidencing a continuity of purpose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8aa0cb9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “economic damage”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8aa0cba-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means the replacement costs of lost or damaged property or records, the costs of repeating an interrupted or invalidated experiment, the loss of profits, or increased costs, including losses and increased costs resulting from threats, acts or vandalism, property damage, trespass, harassment, or intimidation taken against a person or entity on account of that person’s or entity’s connection to, relationship with, or transactions with the animal enterprise; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8aa0cbb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include any lawful economic disruption (including a lawful boycott) that results from lawful public, governmental, or business reaction to the disclosure of information about an animal enterprise;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8aa0cbc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “serious bodily injury” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8aa0cbd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" injury posing a substantial risk of death;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8aa0cbe-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extreme physical pain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8aa0cbf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protracted and obvious disfigurement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8aa0cc0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/d/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protracted loss or impairment of the function of a bodily member, organ, or mental faculty; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8aa0cc1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “substantial bodily injury” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8aa0cc2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deep cuts and serious burns or abrasions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8aa0cc3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" short-term or nonobvious disfigurement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8aa0cc4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fractured or dislocated bones, or torn members of the body;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8aa0cc5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/d/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significant physical pain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8aa0cc6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/d/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" illness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8aa0cc7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/d/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" short-term loss or impairment of the function of a bodily member, organ, or mental faculty; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8aa0cc8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/d/5/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other significant injury to the body.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8aa0cc9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rules of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8aa0cca-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prohibit any expressive conduct (including peaceful picketing or other peaceful demonstration) protected from legal prohibition by the First Amendment to the Constitution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8aa0ccb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to create new remedies for interference with activities protected by the free speech or free exercise clauses of the First Amendment to the Constitution, regardless of the point of view expressed, or to limit any existing legal remedies for such interference; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8aa0ccc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s43/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide exclusive criminal penalties or civil remedies with respect to the conduct prohibited by this action, or to preempt State or local laws that may provide such penalties or remedies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8aa0ccd-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/346/s2/a"},"text":"Pub. L. 102–346, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-08-26"},"text":"Aug. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/928"},"text":"106 Stat. 928","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s601/r/3"},"text":"Pub. L. 104–294, title VI, § 601(r)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3502"},"text":"110 Stat. 3502","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/188/tIII/s336"},"text":"Pub. L. 107–188, title III, § 336","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-12"},"text":"June 12, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/681"},"text":"116 Stat. 681","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/374/s2/a"},"text":"Pub. L. 109–374, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-11-27"},"text":"Nov. 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2652"},"text":"120 Stat. 2652","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8aa0cce-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8aa0ccf-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb8aa0cd0-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 43, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/687"},"text":"62 Stat. 687","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1960-09-02"},"text":"Sept. 2, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/86/702/s2"},"text":"Pub. L. 86–702, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/754"},"text":"74 Stat. 754","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1969-12-05"},"text":"Dec. 5, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/91/135/s7/a"},"text":"Pub. L. 91–135, § 7(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/279"},"text":"83 Stat. 279","children":[],"tail":", related to transportation of wildlife taken in violation of State, national, or foreign law, the receipt of such wildlife, and the making of false records in relation thereto, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/97/79/s9/b/2"},"text":"Pub. L. 97–79, § 9(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-11-16"},"text":"Nov. 16, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1079"},"text":"95 Stat. 1079","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3372/a"},"text":"section 3372(a) of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8aa0cd1-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/374"},"text":"Pub. L. 109–374","children":[],"tail":" amended section catchline and text generally, substituting provisions relating to force, violence, and threats involving animal enterprises for provisions relating to animal enterprise terrorism."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/188/s336/a"},"text":"Pub. L. 107–188, § 336(a)","children":[],"tail":", amended heading and text of subsec. (a) generally, deleting par. (2) reference to intentionally stealing and to requirement that economic damage exceed $10,000, and in concluding provisions substituting reference to punishment under subsec. (b) for reference to fine or imprisonment of not more than one year."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/188/s336/b"},"text":"Pub. L. 107–188, § 336(b)","children":[],"tail":", amended subsec. (b) generally, substituting “Penalties” for “Aggravated Offense” in heading and list of penalties for property damage, personal injury and death for reference to serious bodily injury and death in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/188/s336/c"},"text":"Pub. L. 107–188, § 336(c)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" inserted “or 3663A” after “section 3663” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8aa0cd2-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idb8aa0cd3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/346/s1"},"text":"Pub. L. 102–346, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-08-26"},"text":"Aug. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/928"},"text":"106 Stat. 928","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/346/s1"},"text":"“This Act [enacting this section and provisions set out below] may be cited as the ‘Animal Enterprise Protection Act of 1992’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8aa0cd4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study of Effect of Terrorism on Certain Animal Enterprises","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/346/s3"},"text":"Pub. L. 102–346, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-08-26"},"text":"Aug. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/929"},"text":"106 Stat. 929","children":[],"tail":", directed Attorney General and Secretary of Agriculture to jointly conduct a study on extent and effects of domestic and international terrorism on enterprises using animals for food or fiber production, agriculture, research, or testing, and, not later than 1 year after "},{"tag":"date","attrib":{"date":"1992-08-26"},"text":"Aug. 26, 1992","children":[],"tail":", submit a report that describes the results of the study together with any appropriate recommendations and legislation to Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
