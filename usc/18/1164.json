{"tag":"section","attrib":{"id":"idb917c2d4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1164"},"text":null,"children":[{"tag":"num","attrib":{"value":"1164"},"text":"§ 1164.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Destroying boundary and warning signs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever willfully destroys, defaces, or removes any sign erected by an Indian tribe, or a Government agency (1) to indicate the boundary of an Indian reservation or of any Indian country as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1151"},"text":"section 1151 of this title","children":[],"tail":" or (2) to give notice that hunting, trapping, or fishing is not permitted thereon without lawful authority or permission, shall be fined under this title or imprisoned not more than six months, or both."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb917c2d5-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/634/s1"},"text":"Pub. L. 86–634, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-12"},"text":"July 12, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/469"},"text":"74 Stat. 469","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/E"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2146"},"text":"108 Stat. 2146","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb917c2d6-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb917c2d7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb917c2d8-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $250”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
