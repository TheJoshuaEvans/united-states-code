{"tag":"section","attrib":{"id":"idb92137c7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1464"},"text":null,"children":[{"tag":"num","attrib":{"value":"1464"},"text":"§ 1464.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Broadcasting obscene language","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever utters any obscene, indecent, or profane language by means of radio communication shall be fined under this title or imprisoned not more than two years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb92137c8-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/769"},"text":"62 Stat. 769","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/L"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(L)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92137c9-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb92137ca-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on sections 326 and 501 of title 47, U.S.C., 1940 ed., Telegraphs, Telephones, and Radio-telegraphs (","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch652"},"text":"June 19, 1934, ch. 652","children":[],"tail":", §§ 326, 501, "},{"tag":"ref","attrib":{"href":"/us/stat/48/1091"},"text":"48 Stat. 1091","children":[],"tail":", 1100)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section consolidates last sentence of section 326 with penalty provision of section 501 both of title 47, U.S.C., 1940 ed., with changes in phraseology necessary to effect the consolidation.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s501"},"text":"Section 501 of title 47","children":[],"tail":", U.S.C., 1940 ed., is to remain, also, in said title 47, as it relates to other sections therein."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92137cb-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92137cc-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $10,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb92137cd-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb92137ce-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Obscene Language; Promulgation of Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Federal Communications Commission to promulgate regulations by ","children":[{"tag":"date","attrib":{"date":"1989-01-31"},"text":"Jan. 31, 1989","children":[],"tail":", in accordance with this section to enforce this section on a 24 hour per day basis, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/459/s608"},"text":"section 608 of Pub. L. 100–459","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s303"},"text":"section 303 of Title 47","children":[],"tail":", Telecommunications."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
