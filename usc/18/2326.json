{"tag":"section","attrib":{"id":"idb9619c9c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2326"},"text":null,"children":[{"tag":"num","attrib":{"value":"2326"},"text":"§ 2326.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced penalties","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A person who is convicted of an offense under section 1028, 1029, 1341, 1342, 1343, 1344, or 1347 or section 1128B of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7b"},"text":"42 U.S.C. 1320a–7b","children":[],"tail":"), or a conspiracy to commit such an offense, in connection with the conduct of telemarketing or email marketing—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9619c9d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2326/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be imprisoned for a term of up to 5 years in addition to any term of imprisonment imposed under any of those sections, respectively; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9619c9e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2326/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an offense under any of those sections that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9619c9f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2326/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" victimized ten or more persons over the age of 55; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9619ca0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2326/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" targeted persons over the age of 55,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be imprisoned for a term of up to 10 years in addition to any term of imprisonment imposed under any of those sections, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9619ca1-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXV/s250002/a/2"},"text":"Pub. L. 103–322, title XXV, § 250002(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2082"},"text":"108 Stat. 2082","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/184"},"text":"Pub. L. 105–184","children":[],"tail":", §§ 3, 4, "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/520"},"text":"112 Stat. 520","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/70/tIV/s402/a/3"},"text":"Pub. L. 115–70, title IV, § 402(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-10-18"},"text":"Oct. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1214"},"text":"131 Stat. 1214","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9619ca2-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9619ca3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9619ca4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/70"},"text":"Pub. L. 115–70","children":[],"tail":" substituted “1344, or 1347 or section 1128B of the Social Security Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7b"},"text":"42 U.S.C. 1320a–7b","children":[],"tail":")” for “or 1344” and inserted “or email marketing” after “telemarketing” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/184"},"text":"Pub. L. 105–184","children":[],"tail":" inserted “, or a conspiracy to commit such an offense,” after “or 1344” in introductory provisions and substituted “shall” for “may” in two places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
