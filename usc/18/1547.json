{"tag":"section","attrib":{"id":"idb92863b5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1547"},"text":null,"children":[{"tag":"num","attrib":{"value":"1547"},"text":"§ 1547.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative imprisonment maximum for certain offenses","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this title, the maximum term of imprisonment that may be imposed for an offense under this chapter (other than an offense under section 1545)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92863b6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1547/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if committed to facilitate a drug trafficking crime (as defined in 929(a)) is 15 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92863b7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1547/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if committed to facilitate an act of international terrorism (as defined in section 2331) is 20 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb92863b8-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXIII/s130009/a/6"},"text":"Pub. L. 103–322, title XIII, § 130009(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2030"},"text":"108 Stat. 2030","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
