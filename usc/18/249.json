{"tag":"section","attrib":{"id":"idb8c44adb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249"},"text":null,"children":[{"tag":"num","attrib":{"value":"249"},"text":"§ 249.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hate crime acts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8c44adc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c44add-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offenses involving actual or perceived race, color, religion, or national origin","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever, whether or not acting under color of law, willfully causes bodily injury to any person or, through the use of fire, a firearm, a dangerous weapon, or an explosive or incendiary device, attempts to cause bodily injury to any person, because of the actual or perceived race, color, religion, or national origin of any person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8c44ade-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be imprisoned not more than 10 years, fined in accordance with this title, or both; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c44adf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be imprisoned for any term of years or for life, fined in accordance with this title, or both, if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8c44ae0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" death results from the offense; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8c44ae1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense includes kidnapping or an attempt to kidnap, aggravated sexual abuse or an attempt to commit aggravated sexual abuse, or an attempt to kill.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c44ae2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offenses involving actual or perceived religion, national origin, gender, sexual orientation, gender identity, or disability.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8c44ae3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whoever, whether or not acting under color of law, in any circumstance described in subparagraph (B) or paragraph (3), willfully causes bodily injury to any person or, through the use of fire, a firearm, a dangerous weapon, or an explosive or incendiary device, attempts to cause bodily injury to any person, because of the actual or perceived religion, national origin, gender, sexual orientation, gender identity, or disability of any person—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8c44ae4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be imprisoned not more than 10 years, fined in accordance with this title, or both; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8c44ae5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be imprisoned for any term of years or for life, fined in accordance with this title, or both, if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb8c44ae6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/a/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" death results from the offense; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8c44ae7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/a/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense includes kidnapping or an attempt to kidnap, aggravated sexual abuse or an attempt to commit aggravated sexual abuse, or an attempt to kill.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c44ae8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Circumstances described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A), the circumstances described in this subparagraph are that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8c44ae9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the conduct described in subparagraph (A) occurs during the course of, or as the result of, the travel of the defendant or the victim—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb8c44aea-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/a/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" across a State line or national border; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8c44aeb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/a/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using a channel, facility, or instrumentality of interstate or foreign commerce;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8c44aec-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the defendant uses a channel, facility, or instrumentality of interstate or foreign commerce in connection with the conduct described in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8c44aed-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in connection with the conduct described in subparagraph (A), the defendant employs a firearm, dangerous weapon, explosive or incendiary device, or other weapon that has traveled in interstate or foreign commerce; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8c44aee-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the conduct described in subparagraph (A)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb8c44aef-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/a/2/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interferes with commercial or other economic activity in which the victim is engaged at the time of the conduct; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8c44af0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/a/2/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise affects interstate or foreign commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c44af1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offenses occurring in the special maritime or territorial jurisdiction of the united states","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever, within the special maritime or territorial jurisdiction of the United States, engages in conduct described in paragraph (1) or in paragraph (2)(A) (without regard to whether that conduct occurred in a circumstance described in paragraph (2)(B)) shall be subject to the same penalties as prescribed in those paragraphs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c44af2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidelines","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All prosecutions conducted by the United States under this section shall be undertaken pursuant to guidelines issued by the Attorney General, or the designee of the Attorney General, to be included in the United States Attorneys’ Manual that shall establish neutral and objective criteria for determining whether a crime was committed because of the actual or perceived status of any person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c44af3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lynching","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever conspires to commit any offense under paragraph (1), (2), or (3) shall, if death or serious bodily injury (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2246"},"text":"section 2246 of this title","children":[],"tail":") results from the offense, be imprisoned for not more than 30 years, fined in accordance with this title, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c44af4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other conspiracies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever conspires to commit any offense under paragraph (1), (2), or (3) shall, if death or serious bodily injury (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2246"},"text":"section 2246 of this title","children":[],"tail":") results from the offense, or if the offense includes kidnapping or an attempt to kidnap, aggravated sexual abuse or an attempt to commit aggravated sexual abuse, or an attempt to kill, be imprisoned for not more than 30 years, fined in accordance with this title, or both."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c44af5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification Requirement.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c44af6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No prosecution of any offense described in this subsection may be undertaken by the United States, except under the certification in writing of the Attorney General, or a designee, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8c44af7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State does not have jurisdiction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c44af8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State has requested that the Federal Government assume jurisdiction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c44af9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the verdict or sentence obtained pursuant to State charges left demonstratively unvindicated the Federal interest in eradicating bias-motivated violence; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c44afa-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a prosecution by the United States is in the public interest and necessary to secure substantial justice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c44afb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this subsection shall be construed to limit the authority of Federal officers, or a Federal grand jury, to investigate possible violations of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c44afc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c44afd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “bodily injury” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1365/h/4"},"text":"section 1365(h)(4) of this title","children":[],"tail":", but does not include solely emotional or psychological harm to the victim;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c44afe-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “explosive or incendiary device” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s232"},"text":"section 232 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c44aff-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “firearm” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s921/a"},"text":"section 921(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c44b00-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “gender identity” means actual or perceived gender-related characteristics; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c44b01-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” includes the District of Columbia, Puerto Rico, and any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c44b02-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statute of Limitations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c44b03-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offenses not resulting in death","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), no person shall be prosecuted, tried, or punished for any offense under this section unless the indictment for such offense is found, or the information for such offense is instituted, not later than 7 years after the date on which the offense was committed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c44b04-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Death resulting offenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An indictment or information alleging that an offense under this section resulted in death may be found or instituted at any time without limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c44b05-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s249/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Supervised Release","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a court includes, as a part of a sentence of imprisonment imposed for a violation of subsection (a), a requirement that the defendant be placed on a term of supervised release after imprisonment under section 3583, the court may order, as an explicit condition of supervised release, that the defendant undertake educational classes or community service directly related to the community harmed by the defendant’s offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8c44b06-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dE"},"text":"Pub. L. 111–84, div. E","children":[],"tail":", §§ 4707(a), 4711, "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","c