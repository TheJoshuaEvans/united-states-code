{"tag":"section","attrib":{"id":"idb9cce103-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4127"},"text":null,"children":[{"tag":"num","attrib":{"value":"4127"},"text":"§ 4127.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prison Industries report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The board of directors of Federal Prison Industries shall submit an annual report to the Congress on the conduct of the business of the corporation during each fiscal year, and on the condition of its funds during such fiscal year. Such report shall include a statement of the amount of obligations issued under section 4129(a)(1) during such fiscal year, and an estimate of the amount of obligations that will be so issued in the following fiscal year.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9cce104-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/852"},"text":"62 Stat. 852","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7095"},"text":"Pub. L. 100–690, title VII, § 7095","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4413"},"text":"102 Stat. 4413","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9cce105-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9cce106-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 744m (","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-23/ch736/s5"},"text":"June 23, 1934, ch. 736, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1212"},"text":"48 Stat. 1212","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “of Federal Prison Industries” were inserted after “board of directors”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9cce107-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9cce108-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “The board of directors of Federal Prison Industries shall make annual reports to Congress on the conduct of the business of the corporation and on the condition of its funds.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9cce109-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb9cce10a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of reporting provisions in this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and page 117 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
