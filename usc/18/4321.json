{"tag":"section","attrib":{"id":"idb9d1c42a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s4321"},"text":null,"children":[{"tag":"num","attrib":{"value":"4321"},"text":"§ 4321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Advisers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Four citizens of the United States of prominence and distinction, appointed by the President to serve without compensation, for terms of four years, together with the Attorney General of the United States, the Director of the Bureau of Prisons and the warden of the Federal Reformatory for Women, shall constitute a Board of Advisers of said Federal Reformatory for Women, which shall recommend ways and means for the discipline and training of the inmates, to fit them for suitable employment upon their discharge.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Any person chosen to fill a vacancy shall be appointed only for the unexpired term of the citizen whom he shall succeed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9d1c42b-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/856"},"text":"62 Stat. 856","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s223/n"},"text":"Pub. L. 98–473, title II, § 223(n)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2030"},"text":"98 Stat. 2030","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9d1c42c-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9d1c42d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 816 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1924-06-07/ch287/s7"},"text":"June 7, 1924, ch. 287, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/474"},"text":"43 Stat. 474","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1930-05-14/ch274/s1"},"text":"May 14, 1930, ch. 274, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/325"},"text":"46 Stat. 325","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The provisions relating to the appointment of the board in the first instance were omitted as executed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Warden” was substituted for “superintendent” and “Federal Reformatory for Women” for “United States Industrial Institution for Women” to conform to existing administrative usage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in translation, phraseology, and arrangement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9d1c42e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9d1c42f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":" struck out “parole or” before “discharge” at end of first par."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9d1c430-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb9d1c431-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1987-11-01"},"text":"Nov. 1, 1987","children":[],"tail":", and applicable only to offenses committed after the taking effect of such amendment, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/s235/a/1"},"text":"section 235(a)(1) of Pub. L. 98–473","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3551"},"text":"section 3551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
