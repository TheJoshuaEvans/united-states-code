{"tag":"section","attrib":{"id":"idb9beb0ce-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3671"},"text":null,"children":[{"tag":"num","attrib":{"value":"3671"},"text":"§ 3671.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vessels carrying explosives and steerage passengers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The amount of any fine imposed upon the master of a steamship or other vessel under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2278"},"text":"section 2278 of this title","children":[],"tail":" shall be a lien upon such vessel, and such vessel may be libeled therefor in the district court of the United States for any district in which such vessel shall arrive or from which it shall depart."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9beb0cf-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-09-03/ch1263/s36"},"text":"Sept. 3, 1954, ch. 1263, § 36","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1239"},"text":"68 Stat. 1239","children":[],"tail":", § 3620; renumbered § 3671, "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s212/a/1"},"text":"Pub. L. 98–473, title II, § 212(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1987"},"text":"98 Stat. 1987","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
