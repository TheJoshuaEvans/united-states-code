{"tag":"section","attrib":{"id":"idb8c1da6d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s244"},"text":null,"children":[{"tag":"num","attrib":{"value":"244"},"text":"§ 244.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discrimination against person wearing uniform of armed forces","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being a proprietor, manager, or employee of a theater or other public place of entertainment or amusement in the District of Columbia, or in any Territory, or Possession of the United States, causes any person wearing the uniform of any of the armed forces of the United States to be discriminated against because of that uniform, shall be fined under this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8c1da6e-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/697"},"text":"62 Stat. 697","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-05-24/ch139/s5"},"text":"May 24, 1949, ch. 139, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/90"},"text":"63 Stat. 90","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/G"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(G)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c1da6f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8c1da70-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attri