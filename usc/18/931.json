{"tag":"section","attrib":{"id":"idb8fd8354-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s931"},"text":null,"children":[{"tag":"num","attrib":{"value":"931"},"text":"§ 931.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on purchase, ownership, or possession of body armor by violent felons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8fd8355-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s931/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), it shall be unlawful for a person to purchase, own, or possess body armor, if that person has been convicted of a felony that is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fd8356-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s931/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a crime of violence (as defined in section 16); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fd8357-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s931/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an offense under State law that would constitute a crime of violence under paragraph (1) if it occurred within the special maritime and territorial jurisdiction of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fd8358-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s931/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Affirmative Defense.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fd8359-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s931/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be an affirmative defense under this section that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8fd835a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s931/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the defendant obtained prior written certification from his or her employer that the defendant’s purchase, use, or possession of body armor was necessary for the safe performance of lawful business activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fd835b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s931/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use and possession by the defendant were limited to the course of such performance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fd835c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s931/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the term “employer” means any other individual employed by the defendant’s business that supervises defendant’s activity. If that defendant has no supervisor, prior written certification is acceptable from any other employee of the business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8fd835d-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tI/s11009/e/2/A"},"text":"Pub. L. 107–273, div. C, title I, § 11009(e)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1821"},"text":"116 Stat. 1821","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
