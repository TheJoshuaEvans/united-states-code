{"tag":"section","attrib":{"id":"idb9988b5e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3273"},"text":null,"children":[{"tag":"num","attrib":{"value":"3273"},"text":"§ 3273.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offenses committed by certain United States personnel stationed in Canada in furtherance of border security initiatives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9988b5f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3273/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever, while employed by the Department of Homeland Security or the Department of Justice and stationed or deployed in Canada pursuant to a treaty, executive agreement, or bilateral memorandum in furtherance of a border security initiative, engages in conduct (or conspires or attempts to engage in conduct) in Canada that would constitute an offense for which a person may be prosecuted in a court of the United States had the conduct been engaged in within the United States or within the special maritime and territorial jurisdiction of the United States shall be fined or imprisoned, or both, as provided for that offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9988b60-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3273/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “employed by the Department of Homeland Security or the Department of Justice” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9988b61-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3273/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" being employed as a civilian employee, a contractor (including a subcontractor at any tier), or an employee of a contractor (or a subcontractor at any tier) of the Department of Homeland Security or the Department of Justice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9988b62-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3273/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" being present or residing in Canada in connection with such employment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9988b63-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3273/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not being a national of or ordinarily resident in Canada.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9988b64-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/316/s2/a/2"},"text":"Pub. L. 114–316, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1593"},"text":"130 Stat. 1593","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9988b65-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9988b66-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb9988b67-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/316/s2/c"},"text":"Pub. L. 114–316, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1594"},"text":"130 Stat. 1594","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/316/s2/c"},"text":"“Nothing in this section [enacting this section] or the amendments made by this section shall be construed to infringe upon or otherwise affect the exercise of prosecutorial discretion by the Department of Justice in implementing this section and the amendments made by this section.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
