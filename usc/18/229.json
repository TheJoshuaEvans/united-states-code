{"tag":"section","attrib":{"id":"idb8bf90ea-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s229"},"text":null,"children":[{"tag":"num","attrib":{"value":"229"},"text":"§ 229.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8bf90eb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s229/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unlawful Conduct","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), it shall be unlawful for any person knowingly—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8bf90ec-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s229/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop, produce, otherwise acquire, transfer directly or indirectly, receive, stockpile, retain, own, possess, or use, or threaten to use, any chemical weapon; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf90ed-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s229/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist or induce, in any way, any person to violate paragraph (1), or to attempt or conspire to violate paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8bf90ee-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s229/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exempted Agencies and Persons.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8bf90ef-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s229/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) does not apply to the retention, ownership, possession, transfer, or receipt of a chemical weapon by a department, agency, or other entity of the United States, or by a person described in paragraph (2), pending destruction of the weapon.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf90f0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s229/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exempted persons","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person referred to in paragraph (1) is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8bf90f1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s229/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person, including a member of the Armed Forces of the United States, who is authorized by law or by an appropriate officer of the United States to retain, own, possess, transfer, or receive the chemical weapon; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8bf90f2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s229/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an emergency situation, any otherwise nonculpable person if the person is attempting to destroy or seize the weapon.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8bf90f3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s229/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Conduct prohibited by subsection (a) is within the jurisdiction of the United States if the prohibited conduct—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8bf90f4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s229/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" takes place in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf90f5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s229/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" takes place outside of the United States and is committed by a national of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf90f6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s229/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is committed against a national of the United States while the national is outside the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bf90f7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s229/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is committed against any property that is owned, leased, or used by the United States or by any department or agency of the United States, whether the property is within or outside the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8bf90f8-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dI/tII/s201/a"},"text":"Pub. L. 105–277, div. I, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-866"},"text":"112 Stat. 2681–866","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8bf90f9-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8bf90fa-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8bf90fb-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Revocations of Export Privileges","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dI/tII/s211"},"text":"Pub. L. 105–277, div. I, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-872"},"text":"112 Stat. 2681–872","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/277/dI/tII/s211"},"text":"“If the President determines, after notice and an opportunity for a hearing in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s554"},"text":"section 554 of title 5","children":[],"tail":", United States Code, that any person within the United States, or any national of the United States located outside the United States, has committed any violation of "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s229"},"text":"section 229 of title 18","children":[],"tail":", United States Code, the President may issue an order for the suspension or revocation of the authority of the person to export from the United States any goods or technology (as such terms are defined in [former] section 16 of the Export Administration Act of 1979 (50 U.S.C. App. 2415)) [former "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4618"},"text":"50 U.S.C. 4618","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For authority of Secretary of Commerce to suspend or revoke export privileges pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s211"},"text":"section 211 of Pub. L. 105–277","children":[],"tail":", set out above, see section 4 of Ex. Ord. No. 13128, "},{"tag":"date","attrib":{"date":"1999-06-25"},"text":"June 25, 1999","children":[],"tail":", 64 F.R. 34703, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6711"},"text":"section 6711 of Title 22","children":[],"tail":", Foreign Relations and Intercourse.]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb8c1d9ec-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8c1d9ed-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authority to Issue Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For authority to issue regulations under this chapter, see section 3 of Ex. Ord. No. 13128, ","children":[{"tag":"date","attrib":{"date":"1999-06-25"},"text":"June 25, 1999","children":[],"tail":", 64 F.R. 34703, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6711"},"text":"section 6711 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
