{"tag":"section","attrib":{"id":"idb949cee0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2248"},"text":null,"children":[{"tag":"num","attrib":{"value":"2248"},"text":"§ 2248.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory restitution","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb949cee1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2248/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 3663 or 3663A, and in addition to any other civil or criminal penalty authorized by law, the court shall order restitution for any offense under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb949cee2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2248/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope and Nature of Order.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb949cee3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2248/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Directions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The order of restitution under this section shall direct the defendant to pay to the victim (through the appropriate court mechanism) the full amount of the victim’s losses as determined by the court pursuant to paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb949cee4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2248/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enforcement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An order of restitution under this section shall be issued and enforced in accordance with section 3664 in the same manner as an order under section 3663A.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb949cee5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2248/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “full amount of the victim’s losses” includes any costs incurred by the victim for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb949cee6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2248/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical services relating to physical, psychiatric, or psychological care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb949cee7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2248/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical and occupational therapy or rehabilitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb949cee8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2248/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary transportation, temporary housing, and child care expenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb949cee9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2248/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lost income;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb949ceea-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2248/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attorneys’ fees, plus any costs incurred in obtaining a civil protection order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb949ceeb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2248/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other losses suffered by the victim as a proximate result of the offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb949ceec-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2248/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Order mandatory","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb949ceed-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2248/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The issuance of a restitution order under this section is mandatory.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb949ceee-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2248/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A court may not decline to issue an order under this section because of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb949ceef-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2248/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economic circumstances of the defendant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb949cef0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2248/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fact that a victim has, or is entitled to, receive compensation for his or her injuries from the proceeds of insurance or any other source.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb949cef1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2248/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, the term “victim” means the individual harmed as a result of a commission of a crime under this chapter, including, in the case of a victim who is under 18 years of age, incompetent, incapacitated, or deceased, the legal guardian of the victim or representative of the victim’s estate, another family member, or any other person appointed as suitable by the court, but in no event shall the defendant be named as such representative or guardian.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb949cef2-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s40113/a/1"},"text":"Pub. L. 103–322, title IV, § 40113(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1904"},"text":"108 Stat. 1904","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tII/s205/b"},"text":"Pub. L. 104–132, title II, § 205(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1231"},"text":"110 Stat. 1231","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb949cef3-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb949cef4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb949cef5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s205/b/1"},"text":"Pub. L. 104–132, § 205(b)(1)","children":[],"tail":", inserted “or 3663A” after “3663”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s205/b/2/A"},"text":"Pub. L. 104–132, § 205(b)(2)(A)","children":[],"tail":", reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “The order of restitution under this section shall direct that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the defendant pay to the victim (through the appropriate court mechanism) the full amount of the victim’s losses as determined by the court, pursuant to paragraph (3); and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the United States Attorney enforce the restitution order by all available and reasonable means.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s205/b/2/B"},"text":"Pub. L. 104–132, § 205(b)(2)(B)","children":[],"tail":", struck out “by victim” after “Enforcement” in heading and amended text generally. Prior to amendment, text read as follows: “An order of restitution also may be enforced by a victim named in the order to receive the restitution in the same manner as a judgment in a civil action.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(C), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s205/b/2/C"},"text":"Pub. L. 104–132, § 205(b)(2)(C)","children":[],"tail":", struck out subpars. (C) and (D), which related to court’s consideration of economic circumstances of defendant in determining schedule of payment of restitution orders, and court’s entry of nominal restitution awards where economic circumstances of defendant do not allow for payment of restitution, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5) to (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s205/b/2/D"},"text":"Pub. L. 104–132, § 205(b)(2)(D)","children":[],"tail":", struck out pars. (5) to (10), which related, respectively, to more than 1 offender, more than 1 victim, payment schedule, setoff, effect on other sources of compensation, and condition of probation or supervised release."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s205/b/3"},"text":"Pub. L. 104–132, § 205(b)(3)","children":[],"tail":", (4), redesignated subsec. (f) as (c) and struck out former subsec. (c) relating to proof of claim."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s205/b/3"},"text":"Pub. L. 104–132, § 205(b)(3)","children":[],"tail":", struck out subsecs. (d) and (e) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(d) ","children":[{"tag":"inline","attrib":{},"text":"Modification of Order","children":[],"tail":".—A victim or the offender may petition the court at any time to modify a restitution order as appropriate in view of a change in the economic circumstances of the offender."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(e) ","children":[{"tag":"inline","attrib":{},"text":"Reference to Magistrate or Special Master","children":[],"tail":".—The court may refer any issue arising in connection with a proposed order of restitution to a magistrate or special master for proposed findings of fact and recommendations as to disposition, subject to a de novo determination of the issue by the court.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s205/b/4"},"text":"Pub. L. 104–132, § 205(b)(4)","children":[],"tail":", redesignated subsec. (f) as (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb949cef6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb949cef7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/tII/s211"},"text":"Pub. L. 104–132, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1241"},"text":"110 Stat. 1241","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/132/tII/s211"},"text":"“The amendments made by this subtitle [subtitle A (§§ 201–211) of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132"},"text":"Pub. L. 104–132","children":[],"tail":", see Short Title of 1996 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3551"},"text":"section 3551 of this title","children":[],"tail":"] shall, to the extent constitutionally permissible, be effective for sentencing proceedings in cases in which the defendant is convicted on or after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
