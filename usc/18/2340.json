{"tag":"section","attrib":{"id":"idb96b3911-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2340"},"text":null,"children":[{"tag":"num","attrib":{"value":"2340"},"text":"§ 2340.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb96b3912-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2340/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “torture” means an act committed by a person acting under the color of law specifically intended to inflict severe physical or mental pain or suffering (other than pain or suffering incidental to lawful sanctions) upon another person within his custody or physical control;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96b3913-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2340/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “severe mental pain or suffering” means the prolonged mental harm caused by or resulting from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb96b3914-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2340/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the intentional infliction or threatened infliction of severe physical pain or suffering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96b3915-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2340/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the administration or application, or threatened administration or application, of mind-altering substances or other procedures calculated to disrupt profoundly the senses or the personality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96b3916-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2340/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the threat of imminent death; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb96b3917-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2340/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the threat that another person will imminently be subjected to death, severe physical pain or suffering, or the administration or application of mind-altering substances or other procedures calculated to disrupt profoundly the senses or personality; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb96b3918-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2340/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “United States” means the several States of the United States, the District of Columbia, and the commonwealths, territories, and possessions of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb96b3919-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tV/s506/a"},"text":"Pub. L. 103–236, title V, § 506(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/463"},"text":"108 Stat. 463","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/415/s1/k"},"text":"Pub. L. 103–415, § 1(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4301"},"text":"108 Stat. 4301","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/429/s2/2"},"text":"Pub. L. 103–429, § 2(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4377"},"text":"108 Stat. 4377","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tX/s1089"},"text":"Pub. L. 108–375, div. A, title X, § 1089","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2067"},"text":"118 Stat. 2067","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb96b391a-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb96b391b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb96b391c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" amended par. (3) generally. Prior to amendment, par. (3) read as follows: “ ‘United States’ includes all areas under the jurisdiction of the United States including any of the places described in sections 5 and 7 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s46501/2"},"text":"section 46501(2) of title 49","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/415"},"text":"Pub. L. 103–415","children":[],"tail":" substituted “within his custody” for “with custody”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/429"},"text":"Pub. L. 103–429","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t49/s46501/2"},"text":"section 46501(2) of title 49","children":[],"tail":"” for “section 101(38) of the Federal Aviation Act of 1958 (49 U.S.C. App. 1301(38))”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb96b391d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb96b391e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tV/s506/c"},"text":"Pub. L. 103–236, title V, § 506(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/464"},"text":"108 Stat. 464","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/236/tV/s506/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendments made by this section [enacting this chapter] shall take effect on the later of—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":"]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the United States has become a party to the Convention Against Torture and Other Cruel, Inhuman or Degrading Treatment or Punishment.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n [Convention entered into Force with respect to United States "},{"tag":"date","attrib":{"date":"1994-11-20"},"text":"Nov. 20, 1994","children":[],"tail":", Treaty Doc. 100–20.]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
