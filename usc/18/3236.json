{"tag":"section","attrib":{"id":"idb9961aa7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3236"},"text":null,"children":[{"tag":"num","attrib":{"value":"3236"},"text":"§ 3236.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Murder or manslaughter","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In all cases of murder or manslaughter, the offense shall be deemed to have been committed at the place where the injury was inflicted, or the poison administered or other means employed which caused the death, without regard to the place where the death occurs.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9961aa8-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/826"},"text":"62 Stat. 826","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9961aa9-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9961aaa-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 553 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s336"},"text":"Mar. 4, 1909, ch. 321, § 336","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1152"},"text":"35 Stat. 1152","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
