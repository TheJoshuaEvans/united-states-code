{"tag":"section","attrib":{"id":"idb9344b31-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1854"},"text":null,"children":[{"tag":"num","attrib":{"value":"1854"},"text":"§ 1854.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trees boxed for pitch or turpentine","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever cuts, chips, chops, or boxes any tree upon any lands belonging to the United States, or upon any lands covered by or embraced in any unperfected settlement, application, filing, entry, selection, or location, made under any law of the United States, for the purpose of obtaining from such tree any pitch, turpentine, or other substance; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever buys, trades for, or in any manner acquires any pitch, turpentine, or other substance, or any article or commodity made from any such pitch, turpentine, or other substance, with knowledge that the same has been so unlawfully obtained—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Shall be fined under this title or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9344b32-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/788"},"text":"62 Stat. 788","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s601/a/8"},"text":"Pub. L. 104–294, title VI, § 601(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3498"},"text":"110 Stat. 3498","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9344b33-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9344b34-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 105 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s51"},"text":"Mar. 4, 1909, ch. 321, § 51","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1098"},"text":"35 Stat. 1098","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to persons aiding, encouraging, or causing was deleted as unnecessary since such persons are made principals by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Maximum fine was increased from $500 to $1,000 to conform to other comparable sections of this chapter. (See sections 1851 and 1852 of this title.)","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes also were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9344b35-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9344b36-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" substituted “fined under this title” for “fined not more than $1,000” in last par."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
