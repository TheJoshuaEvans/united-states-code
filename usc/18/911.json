{"tag":"section","attrib":{"id":"idb8ea70c7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s911"},"text":null,"children":[{"tag":"num","attrib":{"value":"911"},"text":"§ 911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Citizen of the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever falsely and willfully represents himself to be a citizen of the United States shall be fined under this title or imprisoned not more than three years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8ea70c8-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/742"},"text":"62 Stat. 742","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8ea70c9-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8ea70ca-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on subsection (a), paragraph (18) and subsection (d), of section 746, title 8, U.S.C., 1940 ed., Aliens and Nationality (","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-14/ch876/s346/a"},"text":"Oct. 14, 1940, ch. 876, § 346(a)","children":[],"tail":", par. (18), and (d), "},{"tag":"ref","attrib":{"href":"/us/stat/54/1165"},"text":"54 Stat. 1165","children":[],"tail":", 1167)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section consolidates said provisions of section 746, title 8, U.S.C., 1940 ed., Aliens and Nationality. The word “willfully” was substituted for “knowingly”, “$1,000” for “$5,000”, and “three years” for “five years”, to harmonize with congressional intent evidenced by the other sections of this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology and unnecessary words were omitted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8ea70cb-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8ea70cc-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $1,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
