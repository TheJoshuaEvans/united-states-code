{"tag":"section","attrib":{"id":"idb9155118-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1117"},"text":null,"children":[{"tag":"num","attrib":{"value":"1117"},"text":"§ 1117.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conspiracy to murder","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If two or more persons conspire to violate section 1111, 1114, 1116, or 1119 of this title, and one or more of such persons do any overt act to effect the object of the conspiracy, each shall be punished by imprisonment for any term of years or for life.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9155119-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/539/tI/s101"},"text":"Pub. L. 92–539, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1071"},"text":"86 Stat. 1071","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tVI/s60009/b/1"},"text":"Pub. L. 103–322, title VI, § 60009(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1972"},"text":"108 Stat. 1972","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb915511a-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb915511b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb915511c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “1116, or 1119” for “or 1116”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
