{"tag":"section","attrib":{"id":"idb936bba1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1901"},"text":null,"children":[{"tag":"num","attrib":{"value":"1901"},"text":"§ 1901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collecting or disbursing officer trading in public property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being an officer of the United States concerned in the collection or the disbursement of the revenues thereof, carries on any trade or business in the funds or debts of the United States, or of any State, or in any public property of either, shall be fined under this title or imprisoned not more than one year, or both; and shall be removed from office, and be incapable of holding any office under the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb936bba2-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/790"},"text":"62 Stat. 790","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/J"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(J)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb936bba3-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb936bba4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 192 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s103"},"text":"Mar. 4, 1909, ch. 321, § 103","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1107"},"text":"35 Stat. 1107","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb936bba5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb936bba6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $3,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
