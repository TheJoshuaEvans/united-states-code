{"tag":"section","attrib":{"id":"idb95f52c2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319"},"text":null,"children":[{"tag":"num","attrib":{"value":"2319"},"text":"§ 2319.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal infringement of a copyright","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb95f52c3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who violates section 506(a) (relating to criminal offenses) of title 17 shall be punished as provided in subsections (b), (c), and (d) and such penalties shall be in addition to any other provisions of title 17 or any other law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95f52c4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any person who commits an offense under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t17/s506/a/1/A"},"text":"section 506(a)(1)(A) of title 17","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95f52c5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be imprisoned not more than 5 years, or fined in the amount set forth in this title, or both, if the offense consists of the reproduction or distribution, including by electronic means, during any 180-day period, of at least 10 copies or phonorecords, of 1 or more copyrighted works, which have a total retail value of more than $2,500;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95f52c6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be imprisoned not more than 10 years, or fined in the amount set forth in this title, or both, if the offense is a felony and is a second or subsequent offense under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95f52c7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be imprisoned not more than 1 year, or fined in the amount set forth in this title, or both, in any other case.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95f52c8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any person who commits an offense under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t17/s506/a/1/B"},"text":"section 506(a)(1)(B) of title 17","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95f52c9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be imprisoned not more than 3 years, or fined in the amount set forth in this title, or both, if the offense consists of the reproduction or distribution of 10 or more copies or phonorecords of 1 or more copyrighted works, which have a total retail value of $2,500 or more;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95f52ca-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be imprisoned not more than 6 years, or fined in the amount set forth in this title, or both, if the offense is a felony and is a second or subsequent offense under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95f52cb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be imprisoned not more than 1 year, or fined in the amount set forth in this title, or both, if the offense consists of the reproduction or distribution of 1 or more copies or phonorecords of 1 or more copyrighted works, which have a total retail value of more than $1,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95f52cc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any person who commits an offense under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t17/s506/a/1/C"},"text":"section 506(a)(1)(C) of title 17","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95f52cd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be imprisoned not more than 3 years, fined under this title, or both;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95f52ce-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be imprisoned not more than 5 years, fined under this title, or both, if the offense was committed for purposes of commercial advantage or private financial gain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95f52cf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be imprisoned not more than 6 years, fined under this title, or both, if the offense is a felony and is a second or subsequent offense under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95f52d0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be imprisoned not more than 10 years, fined under this title, or both, if the offense is a felony and is a second or subsequent offense under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95f52d1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95f52d2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During preparation of the presentence report pursuant to Rule 32(c) of the Federal Rules of Criminal Procedure, victims of the offense shall be permitted to submit, and the probation officer shall receive, a victim impact statement that identifies the victim of the offense and the extent and scope of the injury and loss suffered by the victim, including the estimated economic impact of the offense on that victim.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95f52d3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Persons permitted to submit victim impact statements shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95f52d4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" producers and sellers of legitimate works affected by conduct involved in the offense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95f52d5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" holders of intellectual property rights in such works; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95f52d6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the legal representatives of such producers, sellers, and holders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95f52d7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95f52d8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “phonorecord” and “copies” have, respectively, the meanings set forth in section 101 (relating to definitions) of title 17;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95f52d9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “reproduction” and “distribution” refer to the exclusive rights of a copyright owner under clauses (1) and (3) respectively of section 106 (relating to exclusive rights in copyrighted works), as limited by sections 107 through 122, of title 17;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95f52da-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “financial gain” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t17/s101"},"text":"section 101 of title 17","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95f52db-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2319/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “work being prepared for commercial distribution” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t17/s506/a"},"text":"section 506(a) of title 17","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb95f52dc-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/180/s3"},"text":"Pub. L. 97–180, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-05-24"},"text":"May 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/92"},"text":"96 Stat. 92","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/561"},"text":"Pub. L. 102–561","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4233"},"text":"106 Stat. 4233","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/80/s12/b/2"},"text":"Pub. L. 105–80, § 12(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-13"},"text":"Nov. 13, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1536"},"text":"111 Stat. 1536","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/147/s2/d"},"text":"Pub. L. 105–147, § 2(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-12-16"},"text":"Dec. 16, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2678"},"text":"111 Stat. 2678","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tIII/s13211/a"},"text":"Pub. L. 107–273, div. C, title III, § 13211(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1910"},"text":"116 Stat. 1910","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/9/tI/s103/b"},"text":"Pub. L. 109–9, title I, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-27"},"text":"Apr. 27, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/220"},"text":"119 Stat. 220","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/403/tII/s208"},"text":"Pub. L. 110–403, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4263"},"text":"122 Stat. 4263","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb95f52dd-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb95f52de-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb95f52df-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Criminal Procedure, referred to in subsec. (e)(1), are set out in the Appendix to this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb95f52e0-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsecs. (b)(2), (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/403/s208/1"},"text":"Pub. L. 110–403, § 208(1)","children":[],"tail":", (2), inserted “is a felony and” after “the offense” and substituted “subsection (a)” for “paragraph (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/403/s208/3"},"text":"Pub. L. 110–403, § 208(3)","children":[],"tail":", inserted “is a felony and” after “the offense” and “under subsection (a)” before the semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/403/s208/4"},"text":"Pub. L. 110–403, § 208(4)","children":[],"tail":", inserted “is a felony and” after “the offense”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/9/s103/b/1"},"text":"Pub. L. 109–9, § 103(b)(1)","children":[],"tail":", substituted “Any person who” for “Whoever” and “, (c), and (d)” for “and (c) of this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/9/s103/b/2"},"text":"Pub. L. 109–9, § 103(b)(2)","children":[],"tail":", substituted “section 506(a)(1)(A)” for “section 506(a)(1)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/9/s103/b/3"},"text":"Pub. L. 109–9, § 103(b)(3)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t17/s506/a/1/B"},"text":"section 506(a)(1)(B) of title 17","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t17/s506/a/2"},"text":"section 506(a)(2) of title 17","children":[],"tail":", United States Code” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/9/s103/b/4"},"text":"Pub. L. 109–9, § 103(b)(4)","children":[],"tail":", (5), added subsec. (d) and redesignated former subsec. (d) as (e). Former subsec. (e) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/9/s103/b/4"},"text":"Pub. L. 109–9, § 103(b)(4)","children":[],"tail":", (6), redesignated subsec. (e) as (f) and added pars. (3) and (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" substituted “107 through 122” for “107 through 120”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/147/s2/d/1"},"text":"Pub. L. 105–147, § 2(d)(1)","children":[],"tail":", substituted “subsections (b) and (c)” for “subsection (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/147/s2/d/2/A"},"text":"Pub. L. 105–147, § 2(d)(2)(A)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t17/s506/a/1"},"text":"section 506(a)(1) of title 17","children":[],"tail":"” for “subsection (a) of this section” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/147/s2/d/2/B"},"text":"Pub. L. 105–147, § 2(d)(2)(B)","children":[],"tail":", inserted “including by electronic means,” after “if the offense consists of the reproduction or distribution,” and substituted “which have a total retail value of more than $2,500” for “with a retail value of more than $2,500”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/80"},"text":"Pub. L. 105–80","children":[],"tail":", substituted “at least 10 copies” for “at last 10 copies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/147/s2/d/3"},"text":"Pub. L. 105–147, § 2(d)(3)","children":[],"tail":", added subsecs. (c) and (d) and redesignated former subsec. (c) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/561/s1"},"text":"Pub. L. 102–561, § 1","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “Any person who commits an offense under subsection (a) of this section—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) shall be fined not more than $250,000 or imprisoned for not more than five years, or both, if the offense—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) involves the reproduction or distribution, during any one-hundred-and-eighty-day period, of at least one thousand phonorecords or copies infringing the copyright in one or more sound recordings;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) involves the reproduction or distribution, during any one-hundred-and-eighty-day period, of at least sixty-five copies infringing the copyright in one or more motion pictures or other audiovisual works; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) is a second or subsequent offense under either of subsection (b)(1) or (b)(2) of this section, where a prior offense involved a sound recording, or a motion picture or other audiovisual work;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) shall be fined not more than $250,000 or imprisoned for not more than two years, or both, if the offense—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) involves the reproduction or distribution, during any one-hundred-and-eighty-day period, of more than one hundred but less than one thousand phonorecords or copies infringing the copyright in one or more sound recordings; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) involves the reproduction or distribution, during any one-hundred-and-eighty-day period, of more than seven but less than sixty-five copies infringing the copyright in one or more motion pictures or other audiovisual works; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) shall be fined not more than $25,000 or imprisoned for not more than one year, or both, in any other case.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/561/s2"},"text":"Pub. L. 102–561, § 2","children":[],"tail":", substituted “ ‘phonorecord’ ” for “ ‘sound recording’, ‘motion picture’, ‘audiovisual work’, ‘phonorecord’,” in par. (1) and “120” for “118” in par. (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
