{"tag":"section","attrib":{"id":"idb8fff4e0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s960"},"text":null,"children":[{"tag":"num","attrib":{"value":"960"},"text":"§ 960.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedition against friendly nation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, within the United States, knowingly begins or sets on foot or provides or prepares a means for or furnishes the money for, or takes part in, any military or naval expedition or enterprise to be carried on from thence against the territory or dominion of any foreign prince or state, or of any colony, district, or people with whom the United States is at peace, shall be fined under this title or imprisoned not more than three years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8fff4e1-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/745"},"text":"62 Stat. 745","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/J"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(J)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8fff4e2-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8fff4e3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 25 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s13"},"text":"Mar. 4, 1909, ch. 321, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1090"},"text":"35 Stat. 1090","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1917-06-15/ch30"},"text":"June 15, 1917, ch. 30","children":[],"tail":", title V, § 8, "},{"tag":"ref","attrib":{"href":"/us/stat/40/223"},"text":"40 Stat. 223","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “within the United States” were substituted for “within the jurisdiction” etc., in view of the definition of United States in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s5"},"text":"section 5 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to territory or possessions of the United States was omitted as covered by definitive ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s5"},"text":"section 5 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8fff4e4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8fff4e5-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $3,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
