{"tag":"section","attrib":{"id":"idb91307ef-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1113"},"text":null,"children":[{"tag":"num","attrib":{"value":"1113"},"text":"§ 1113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attempt to commit murder or manslaughter","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s113"},"text":"section 113 of this title","children":[],"tail":", whoever, within the special maritime and territorial jurisdiction of the United States, attempts to commit murder or manslaughter, shall, for an attempt to commit murder be imprisoned not more than twenty years or fined under this title, or both, and for an attempt to commit manslaughter be imprisoned not more than seven years or fined under this title, or both."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb91307f0-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/756"},"text":"62 Stat. 756","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7058/c"},"text":"Pub. L. 100–690, title VII, § 7058(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4403"},"text":"102 Stat. 4403","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXV/s3534"},"text":"Pub. L. 101–647, title XXXV, § 3534","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4925"},"text":"104 Stat. 4925","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tVII/s705/a/5"},"text":"Pub. L. 104–132, title VII, § 705(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1295"},"text":"110 Stat. 1295","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91307f1-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb91307f2-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 456 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s277"},"text":"Mar. 4, 1909, ch. 321, § 277","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1143"},"text":"35 Stat. 1143","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “within the special maritime and territorial jurisdiction of the United States” were added in view of definitive ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s7"},"text":"section 7 of this title","children":[],"tail":", and section was rearranged to more clearly express intent of existing law."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Mandatory punishment provision was rephrased in the alternative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb91307f3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb91307f4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132"},"text":"Pub. L. 104–132","children":[],"tail":" substituted “seven years” for “three years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":" struck out final period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" substituted “shall, for an attempt to commit murder be imprisoned not more than twenty years or fined under this title, or both, and for an attempt to commit manslaughter be imprisoned not more than three years or fined under this title, or both.” for “shall be fined not more than $1,000 or imprisoned not more than three years, or both”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
