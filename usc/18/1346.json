{"tag":"section","attrib":{"id":"idb91c7d28-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1346"},"text":null,"children":[{"tag":"num","attrib":{"value":"1346"},"text":"§ 1346.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of “scheme or artifice to defraud”","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purposes of this chapter, the term “scheme or artifice to defraud” includes a scheme or artifice to deprive another of the intangible right of honest services.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb91c7d29-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7603/a"},"text":"Pub. L. 100–690, title VII, § 7603(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4508"},"text":"102 Stat. 4508","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
