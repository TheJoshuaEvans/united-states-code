{"tag":"section","attrib":{"id":"idb955b532-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2259A"},"text":null,"children":[{"tag":"num","attrib":{"value":"2259A"},"text":"§ 2259A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessments in child pornography cases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb955b533-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2259A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to any other criminal penalty, restitution, or special assessment authorized by law, the court shall assess—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb955b534-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2259A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $17,000 on any person convicted of an offense under section 2252(a)(4) or 2252A(a)(5);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb955b535-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2259A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $35,000 on any person convicted of any other offense for trafficking in child pornography; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb955b536-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2259A/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $50,000 on any person convicted of a child pornography production offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb955b537-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2259A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Adjustment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The dollar amounts in subsection (a) shall be adjusted annually in conformity with the Consumer Price Index.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb955b538-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2259A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Factors Considered","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In determining the amount of the assessment under subsection (a), the court shall consider the factors set forth in sections 3553(a) and 3572.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb955b539-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2259A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Imposition and Implementation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb955b53a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2259A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The provisions of subchapter C of chapter 227 (other than section 3571) and subchapter B of chapter 229 (relating to fines) apply to assessments under this section, except that paragraph (2) applies in lieu of any contrary provisions of law relating to fines or disbursement of money received from a defendant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb955b53b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2259A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect on other penalties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Imposition of an assessment under this section does not relieve a defendant of, or entitle a defendant to reduce the amount of any other penalty by the amount of the assessment. Any money received from a defendant shall be disbursed so that each of the following obligations is paid in full in the following sequence:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb955b53c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2259A/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A special assessment under section 3013.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb955b53d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2259A/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Restitution to victims of any child pornography production or trafficking offense that the defendant committed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb955b53e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2259A/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb955b53f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2259A/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other orders under any other section of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb955b540-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2259A/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All other fines, penalties, costs, and other payments required under the sentence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb955b541-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/299/s5/a"},"text":"Pub. L. 115–299, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-07"},"text":"Dec. 7, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4386"},"text":"132 Stat. 4386","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
