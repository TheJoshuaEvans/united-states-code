{"tag":"section","attrib":{"id":"idb98eeee3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3149"},"text":null,"children":[{"tag":"num","attrib":{"value":"3149"},"text":"§ 3149.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surrender of an offender by a surety","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A person charged with an offense, who is released upon the execution of an appearance bond with a surety, may be arrested by the surety, and if so arrested, shall be delivered promptly to a United States marshal and brought before a judicial officer. The judicial officer shall determine in accordance with the provisions of section 3148(b) whether to revoke the release of the person, and may absolve the surety of responsibility to pay all or part of the bond in accordance with the provisions of Rule 46 of the Federal Rules of Criminal Procedure. The person so committed shall be held in official detention until released pursuant to this chapter or another provision of law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb98eeee4-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s203/a"},"text":"Pub. L. 98–473, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1984"},"text":"98 Stat. 1984","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb98eeee5-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb98eeee6-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb98eeee7-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3149, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/465/s3/a"},"text":"Pub. L. 89–465, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-06-22"},"text":"June 22, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/216"},"text":"80 Stat. 216","children":[],"tail":", related to release of material witnesses, prior to repeal in the revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/s203/a"},"text":"section 203(a) of Pub. L. 98–473","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
