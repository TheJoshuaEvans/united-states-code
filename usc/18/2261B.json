{"tag":"section","attrib":{"id":"idb955b57e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2261B"},"text":null,"children":[{"tag":"num","attrib":{"value":"2261B"},"text":"§ 2261B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced penalty for stalkers of children","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb955b57f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2261B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), if the victim of an offense under section 2261A is under the age of 18 years, the maximum imprisonment for the offense is 5 years greater than the maximum term of imprisonment otherwise provided for that offense in section 2261.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb955b580-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2261B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to a person who violates section 2261A if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb955b581-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2261B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person is subject to a sentence under section 2261(b)(5); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb955b582-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2261B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb955b583-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2261B/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person is under the age of 18 at the time the offense occurred; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb955b584-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2261B/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the victim of the offense is not less than 15 nor more than 17 years of age and not more than 3 years younger than the person who committed the offense at the time the offense occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb955b585-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/249/s2/a"},"text":"Pub. L. 116–249, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-22"},"text":"Dec. 22, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1126"},"text":"134 Stat. 1126","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
