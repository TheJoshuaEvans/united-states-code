{"tag":"section","attrib":{"id":"idb95a70e1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2283"},"text":null,"children":[{"tag":"num","attrib":{"value":"2283"},"text":"§ 2283.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation of explosive, biological, chemical, or radioactive or nuclear materials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb95a70e2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2283/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever knowingly transports aboard any vessel within the United States and on waters subject to the jurisdiction of the United States or any vessel outside the United States and on the high seas or having United States nationality an explosive or incendiary device, biological agent, chemical weapon, or radioactive or nuclear material, knowing that any such item is intended to be used to commit an offense listed under section 2332b(g)(5)(B), shall be fined under this title or imprisoned for any term of years or for life, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95a70e3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2283/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Causing Death","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person who causes the death of a person by engaging in conduct prohibited by subsection (a) may be punished by death.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95a70e4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2283/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95a70e5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2283/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Biological agent","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “biological agent” means any biological agent, toxin, or vector (as those terms are defined in section 178).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95a70e6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2283/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"By-product material","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “by-product material” has the meaning given that term in section 11(e) of the Atomic Energy Act of 1954 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2014/e"},"text":"42 U.S.C. 2014(e)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95a70e7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2283/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chemical weapon","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “chemical weapon” has the meaning given that term in section 229F(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95a70e8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2283/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Explosive or incendiary device","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “explosive or incendiary device” has the meaning given the term in section 232(5) and includes explosive materials, as that term is defined in section 841(c) and explosive as defined in section 844(j).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95a70e9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2283/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nuclear material","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “nuclear material” has the meaning given that term in section 831(f)(1).","children":[{"tag":"ref","attrib":{"idref":"fn002173"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002173"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95a70ea-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2283/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Radioactive material","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “radioactive material” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95a70eb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2283/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" source material and special nuclear material, but does not include natural or depleted uranium;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95a70ec-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2283/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nuclear by-product material;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95a70ed-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2283/c/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" material made radioactive by bombardment in an accelerator; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95a70ee-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2283/c/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all refined isotopes of radium.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95a70ef-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2283/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002174"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002174"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. No par. (7) has been enacted."}],"tail":" "},{"tag":"inline","attrib":{},"text":"Source material","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “source material” has the meaning given that term in section 11(z) of the Atomic Energy Act of 1954 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2014/z"},"text":"42 U.S.C. 2014(z)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95a70f0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2283/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special nuclear material","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “special nuclear material” has the meaning given that term in section 11(aa) of the Atomic Energy Act of 1954 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2014/aa"},"text":"42 U.S.C. 2014(aa)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb95a70f1-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/tIII/s305/a"},"text":"Pub. L. 109–177, title III, § 305(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/236"},"text":"120 Stat. 236","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb95a70f2-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb95a70f3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb95a70f4-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 831(f)(1), referred to in subsec. (c)(5), was redesignated section 831(g)(1) by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/23/tVIII/s812/d"},"text":"Pub. L. 114–23, title VIII, § 812(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-06-02"},"text":"June 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/312"},"text":"129 Stat. 312","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
