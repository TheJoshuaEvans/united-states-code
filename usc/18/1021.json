{"tag":"section","attrib":{"id":"idb9096a6d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1021"},"text":null,"children":[{"tag":"num","attrib":{"value":"1021"},"text":"§ 1021.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Title records","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, being an officer or other person authorized by any law of the United States to record a conveyance of real property or any other instrument which by such law may be recorded, knowingly certifies falsely that such conveyance or instrument has or has not been recorded, shall be fined under this title or imprisoned not more than five years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9096a6e-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/754"},"text":"62 Stat. 754","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9096a6f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9096a70-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 194 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s105"},"text":"Mar. 4, 1909, ch. 321, § 105","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1107"},"text":"35 Stat. 1107","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “five years” were substituted for “seven years” as more in conformity with comparable sections of this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor change was made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9096a71-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9096a72-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $1,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
