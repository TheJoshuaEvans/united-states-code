{"tag":"section","attrib":{"id":"idb8c1d9ee-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s229A"},"text":null,"children":[{"tag":"num","attrib":{"value":"229A"},"text":"§ 229A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8c1d9ef-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s229A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criminal Penalties.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c1d9f0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s229A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person who violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s229"},"text":"section 229 of this title","children":[],"tail":" shall be fined under this title, or imprisoned for any term of years, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c1d9f1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s229A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Death penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person who violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s229"},"text":"section 229 of this title","children":[],"tail":" and by whose action the death of another person is the result shall be punished by death or imprisoned for life."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c1d9f2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s229A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Penalties.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c1d9f3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s229A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Attorney General may bring a civil action in the appropriate United States district court against any person who violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s229"},"text":"section 229 of this title","children":[],"tail":" and, upon proof of such violation by a preponderance of the evidence, such person shall be subject to pay a civil penalty in an amount not to exceed $100,000 for each such violation."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c1d9f4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s229A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relation to other proceedings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The imposition of a civil penalty under this subsection does not preclude any other criminal or civil statutory, common law, or administrative remedy, which is available by law to the United States or any other person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c1d9f5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s229A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement of Costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The court shall order any person convicted of an offense under subsection (a) to reimburse the United States for any expenses incurred by the United States incident to the seizure, storage, handling, transportation, and destruction or other disposition of any property that was seized in connection with an investigation of the commission of the offense by that person. A person ordered to reimburse the United States for expenses under this subsection shall be jointly and severally liable for such expenses with each other person, if any, who is ordered under this subsection to reimburse the United States for the same expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8c1d9f6-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dI/tII/s201/a"},"text":"Pub. L. 105–277, div. I, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-867"},"text":"112 Stat. 2681–867","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
