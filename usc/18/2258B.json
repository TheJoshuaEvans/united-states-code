{"tag":"section","attrib":{"id":"idb953449e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B"},"text":null,"children":[{"tag":"num","attrib":{"value":"2258B"},"text":"§ 2258B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited liability for the reporting, storage, and handling of certain visual depictions of apparent child pornography to the National Center for Missing & Exploited Children","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb953449f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), a civil claim or criminal charge against a provider or domain name registrar, including any director, officer, employee, or agent of such provider or domain name registrar arising from the performance of the reporting or preservation responsibilities of such provider or domain name registrar under this section, section 2258A, or section 2258C may not be brought in any Federal or State court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95344a0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Intentional, Reckless, or Other Misconduct","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to a claim or charge if the provider or domain name registrar, or a director, officer, employee, or agent of that provider or domain name registrar—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95344a1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaged in intentional misconduct; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95344a2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" acted, or failed to act—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95344a3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with actual malice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95344a4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with reckless disregard to a substantial risk of causing physical injury without legal justification; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95344a5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a purpose unrelated to the performance of any responsibility or function under sections ","children":[{"tag":"ref","attrib":{"idref":"fn002157"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002157"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" 2258A, 2258C, 2702, or 2703."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95344a6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimizing Access","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A provider and domain name registrar shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95344a7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize the number of employees that are provided access to any visual depiction provided under section 2258A or 2258C; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95344a8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that any such visual depiction is permanently destroyed, upon a request from a law enforcement agency to destroy the visual depiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95344a9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limited Liability for NCMEC-Contracted Vendors.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95344aa-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), a civil claim or criminal charge may not be brought in any Federal or State court against a vendor contractually retained and designated by NCMEC to support the duties of NCMEC under section 404(b)(1)(K) of the Juvenile Justice and Delinquency Prevention Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s11293/b/1/K"},"text":"34 U.S.C. 11293(b)(1)(K)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95344ab-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Intentional, reckless, or other misconduct","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply to a claim or charge if the vendor—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95344ac-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" engaged in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb95344ad-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intentional misconduct; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95344ae-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" negligent conduct; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95344af-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" acted, or failed to act—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb95344b0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with actual malice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95344b1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with reckless disregard to a substantial risk of causing injury without legal justification; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95344b2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for a purpose unrelated to the performance of any responsibility or function—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb95344b3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/d/2/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth in paragraph (1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb95344b4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/d/2/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to sections ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" 2258A, 2258C, 2702, or 2703."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95344b5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vendor cybersecurity requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to any visual depiction provided pursuant to the duties of NCMEC under section 404(b)(1)(K) of the Juvenile Justice and Delinquency Prevention Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s11293/b/1/K"},"text":"34 U.S.C. 11293(b)(1)(K)","children":[],"tail":") that is stored or transferred by a vendor contractually retained and designated by NCMEC to support such duties of NCMEC, a vendor shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95344b6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" secure such visual depiction in a manner that is consistent with the most recent version of the Cybersecurity Framework developed by the National Institute of Standards and Technology, or any successor thereto;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95344b7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize the number of employees that may be able to obtain access to such visual depiction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95344b8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employ end-to-end encryption for data storage and transfer functions, or an equivalent technological standard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95344b9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" undergo an independent annual cybersecurity audit to determine whether such visual depiction is secured as required under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95344ba-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/d/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promptly address all issues identified by an audit described in subparagraph (D).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95344bb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limited Liability for Reporting Apparent Child Pornography by an Individual Depicted in the Child Pornography as a Minor, or a Representative of Such Individual.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95344bc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), a civil claim or criminal charge may not be brought in any Federal or State court against an individual depicted in child pornography as a minor, or a representative of such individual, arising from a report to the NCMEC CyberTipline by the individual, or the representative of such individual, of information that relates to the child pornography in which the individual is depicted as a minor, including a copy of the child pornography.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95344bd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Intentional, reckless, or other misconduct","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply to a claim or charge if the individual, or the representative of such individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95344be-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" engaged in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb95344bf-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intentional misconduct;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95344c0-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" negligent conduct; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95344c1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/e/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any activity which constitutes a violation of section 2251; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95344c2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" acted, or failed to act—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb95344c3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with actual malice; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95344c4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with reckless disregard to a substantial risk of causing injury without legal justification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95344c5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimizing access","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to any child pornography reported to the NCMEC CyberTipline by an individual depicted in the child pornography as a minor, or a representative of such individual, NCMEC shall minimize access to the child pornography and ensure the appropriate deletion of the child pornography, as set forth in section 2258D.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95344c6-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “representative”, with respect to an individual depicted in child pornography—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95344c7-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb95344c8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/e/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the parent or legal guardian of the individual, if the individual is under 18 years of age;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95344c9-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/e/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the legal guardian or other person appointed by a court to represent the individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95344ca-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/e/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a legal representative retained by the individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95344cb-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/e/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative of the estate of the individual; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95344cc-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/e/4/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person who is a mandated reporter under section 226(a)(1) of the Victims of Child Abuse Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20341/a/1"},"text":"34 U.S.C. 20341(a)(1)","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95344cd-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2258B/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include a person who engaged in any activity which constitutes a violation of section 2251.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb95344ce-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/401/tV/s501/a"},"text":"Pub. L. 110–401, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4248"},"text":"122 Stat. 4248","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/395/s3"},"text":"Pub. L. 115–395, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5292"},"text":"132 Stat. 5292","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/59/s2/a"},"text":"Pub. L. 118–59, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-07"},"text":"May 7, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1014"},"text":"138 Stat. 1014","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb95344cf-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb95344d0-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb95344d1-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/59/s2/a/1"},"text":"Pub. L. 118–59, § 2(a)(1)","children":[],"tail":", substituted “the reporting, storage, and handling of certain visual depictions of apparent child pornography to the National Center for Missing & Exploited Children” for “providers or domain name registrars” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/59/s2/a/2/A"},"text":"Pub. L. 118–59, § 2(a)(2)(A)","children":[],"tail":", inserted “or charge” after “a claim” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/59/s2/a/2/B"},"text":"Pub. L. 118–59, § 2(a)(2)(B)","children":[],"tail":", struck out “this section,” after “or function under”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/59/s2/a/3"},"text":"Pub. L. 118–59, § 2(a)(3)","children":[],"tail":", added subsecs. (d) and (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/395/s3/1"},"text":"Pub. L. 115–395, § 3(1)","children":[],"tail":", substituted “providers, or domain name registrars” for “electronic communication service providers, remote computing service providers, or domain name registrar” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/395/s3/2"},"text":"Pub. L. 115–395, § 3(2)","children":[],"tail":", substituted “a provider” for “an electronic communication service provider, a remote computing service provider,” and substituted “such provider” for “such electronic communication service provider, remote computing service provider,” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/395/s3/3"},"text":"Pub. L. 115–395, § 3(3)","children":[],"tail":", substituted “provider” for “electronic communication service provider, remote computing service provider,” in two places in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/395/s3/4"},"text":"Pub. L. 115–395, § 3(4)","children":[],"tail":", substituted “A provider” for “An electronic communication service provider, a remote computing service provider,” in introductory provisions and “visual depiction” for “image” wherever appearing in pars. (1) and (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb95344d2-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb95344d3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/59/s2/b"},"text":"Pub. L. 118–59, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-07"},"text":"May 7, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1016"},"text":"138 Stat. 1016","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/59/s2/b"},"text":"“The amendments made by subsection (a) [amending this section] shall apply with respect to a civil claim or criminal charge that is filed on or after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-05-07"},"text":"May 7, 2024","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
