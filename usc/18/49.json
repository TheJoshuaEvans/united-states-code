{"tag":"section","attrib":{"id":"idb8ac7d10-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s49"},"text":null,"children":[{"tag":"num","attrib":{"value":"49"},"text":"§ 49.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of animal fighting prohibitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8ac7d11-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s49/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever violates subsection (a)(1), (b), (c), or (d) of section 26 of the Animal Welfare Act shall be fined under this title, imprisoned for not more than 5 years, or both, for each violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8ac7d12-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s49/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Attending an Animal Fighting Venture","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever violates subsection (a)(2)(A) of section 26 of the Animal Welfare Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2156"},"text":"7 U.S.C. 2156","children":[],"tail":") shall be fined under this title, imprisoned for not more than 1 year, or both, for each violation."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8ac7d13-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s49/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Causing an Individual Who Has Not Attained the Age of ","children":[],"tail":"16"},{"tag":"inline","attrib":{},"text":" To Attend an Animal Fighting Venture","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever violates subsection (a)(2)(B) of section 26 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2156"},"text":"7 U.S.C. 2156","children":[],"tail":") of the Animal Welfare Act shall be fined under this title, imprisoned for not more than 3 years, or both, for each violation."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8ac7d14-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/22/s2/a"},"text":"Pub. L. 110–22, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-05-03"},"text":"May 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/88"},"text":"121 Stat. 88","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14207/b"},"text":"Pub. L. 110–234, title XIV, § 14207(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1462"},"text":"122 Stat. 1462","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14207(b), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2224; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tXII/s12308/b/2"},"text":"Pub. L. 113–79, title XII, § 12308(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/991"},"text":"128 Stat. 991","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tX