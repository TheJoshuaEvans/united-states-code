{"tag":"section","attrib":{"id":"idb8e0d425-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s757"},"text":null,"children":[{"tag":"num","attrib":{"value":"757"},"text":"§ 757.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prisoners of war or enemy aliens","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever procures the escape of any prisoner of war held by the United States or any of its allies, or the escape of any person apprehended or interned as an enemy alien by the United States or any of its allies, or advises, connives at, aids, or assists in such escape, or aids, relieves, transports, harbors, conceals, shelters, protects, holds correspondence with, gives intelligence to, or otherwise assists any such prisoner of war or enemy alien, after his escape from custody, knowing him to be such prisoner of war or enemy alien, or attempts to commit or conspires to commit any of the above acts, shall be fined under this title or imprisoned not more than ten years, or both.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The provisions of this section shall be in addition to and not in substitution for any other provision of law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8e0d426-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/735"},"text":"62 Stat. 735","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/L"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(L)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8e0d427-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8e0d428-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 97b (","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-04-30/ch103"},"text":"Apr. 30, 1945, ch. 103","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/101"},"text":"59 Stat. 101","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The second sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s97b"},"text":"section 97b of title 18","children":[],"tail":", U.S.C., 1940 ed., was made a separate paragraph."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8e0d429-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8e0d42a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $10,000” in first par."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
