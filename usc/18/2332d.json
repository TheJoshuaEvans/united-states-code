{"tag":"section","attrib":{"id":"idb9640d4f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2332d"},"text":"§ 2332d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial transactions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9640d50-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offense","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in regulations issued by the Secretary of the Treasury, in consultation with the Secretary of State, whoever, being a United States person, knowing or having reasonable cause to know that a country is designated under section 6(j) ","children":[{"tag":"ref","attrib":{"idref":"fn002189"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002189"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Export Administration Act of 1979 (50 U.S.C. App. 2405) as a country supporting international terrorism, engages in a financial transaction with the government of that country, shall be fined under this title, imprisoned for not more than 10 years, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9640d51-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9640d52-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “financial transaction” has the same meaning as in section 1956(c)(4); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9640d53-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “United States person” means any—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9640d54-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332d/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States citizen or national;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9640d55-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332d/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permanent resident alien;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9640d56-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332d/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" juridical person organized under the laws of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9640d57-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2332d/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9640d58-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/tIII/s321/a"},"text":"Pub. L. 104–132, title III, § 321(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1254"},"text":"110 Stat. 1254","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dB/tIV/s4002/a/5"},"text":"Pub. L. 107–273, div. B, title IV, § 4002(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1806"},"text":"116 Stat. 1806","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9640d59-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9640d5a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9640d5b-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 6(j) of the Export Administration Act of 1979, referred to in subsec. (a), was classified to section 2405(j) of the former Appendix to Title 50, War and National Defense, prior to editorial reclassification and renumbering as ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4605/j"},"text":"section 4605(j) of Title 50","children":[],"tail":", and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVII/s1766/a"},"text":"Pub. L. 115–232, div. A, title XVII, § 1766(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2232"},"text":"132 Stat. 2232","children":[],"tail":". For provisions similar to those of former "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4605/j"},"text":"section 4605(j) of Title 50","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4813/c"},"text":"section 4813(c) of Title 50","children":[],"tail":", as enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb9640d5c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 2332d was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2332e"},"text":"section 2332e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9640d5d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" inserted “of 1979” after “Export Administration Act”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9640d5e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9640d5f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/tIII/s321/c"},"text":"Pub. L. 104–132, title III, § 321(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1254"},"text":"110 Stat. 1254","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/132/tIII/s321/c"},"text":"“The amendments made by this section [enacting this section] shall become effective 120 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
