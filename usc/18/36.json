{"tag":"section","attrib":{"id":"idb8a55113-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s36"},"text":null,"children":[{"tag":"num","attrib":{"value":"36"},"text":"§ 36.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drive-by shooting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8a55114-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s36/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, “major drug offense” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a55115-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s36/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a continuing criminal enterprise punishable under section 408(c) of the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s848/c"},"text":"21 U.S.C. 848(c)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a55116-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s36/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a conspiracy to distribute controlled substances punishable under section 406 of the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s846"},"text":"21 U.S.C. 846","children":[],"tail":") section "},{"tag":"ref","attrib":{"idref":"fn002012"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002012"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “or”."}],"tail":" 1013 of the Controlled Substances Import and Export Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s963"},"text":"21 U.S.C. 963","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a55117-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s36/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an offense involving major quantities of drugs and punishable under section 401(b)(1)(A) of the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s841/b/1/A"},"text":"21 U.S.C. 841(b)(1)(A)","children":[],"tail":") or section 1010(b)(1) of the Controlled Substances Import and Export Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s960/b/1"},"text":"21 U.S.C. 960(b)(1)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a55118-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s36/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offense and Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a55119-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s36/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who, in furtherance or to escape detection of a major drug offense and with the intent to intimidate, harass, injure, or maim, fires a weapon into a group of two or more persons and who, in the course of such conduct, causes grave risk to any human life shall be punished by a term of no more than 25 years, by fine under this title, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a5511a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s36/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person who, in furtherance or to escape detection of a major drug offense and with the intent to intimidate, harass, injure, or maim, fires a weapon into a group of 2 or more persons and who, in the course of such conduct, kills any person shall, if the killing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a5511b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s36/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a first degree murder (as defined in section 1111(a)), be punished by death or imprisonment for any term of years or for life, fined under this title, or both; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a5511c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s36/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a murder other than a first degree murder (as defined in section 1111(a)), be fined under this title, imprisoned for any term of years or for life, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8a5511d-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tVI/s60008/b"},"text":"Pub. L. 103–322, title VI, § 60008(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1971"},"text":"108 Stat. 1971","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s604/b/30"},"text":"Pub. L. 104–294, title VI, § 604(b)(30)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3508"},"text":"110 Stat. 3508","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8a5511e-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8a5511f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8a55120-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" substituted “408(c)” for “403(c)” in par. (1) and “Export” for “Export Control” in par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8a55121-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8a55122-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/s604/d"},"text":"section 604(d) of Pub. L. 104–294","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s13"},"text":"section 13 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idb8a55123-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tVI/s60008/a"},"text":"Pub. L. 103–322, title VI, § 60008(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1971"},"text":"108 Stat. 1971","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/322/tVI/s60008/a"},"text":"“This section [enacting this section] may be cited as the ‘Drive-By Shooting Prevention Act of 1994’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
