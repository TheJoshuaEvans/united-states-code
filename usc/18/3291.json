{"tag":"section","attrib":{"id":"idb99ad4af-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3291"},"text":null,"children":[{"tag":"num","attrib":{"value":"3291"},"text":"§ 3291.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nationality, citizenship and passports","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No person shall be prosecuted, tried, or punished for violation of any provision of sections 1423 to 1428, inclusive, of chapter 69 and sections 1541 to 1544, inclusive, of chapter 75 of title 18 of the United States Code, or for conspiracy to violate any of such sections, unless the indictment is found or the information is instituted within ten years after the commission of the offense.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb99ad4b0-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1951-06-30/ch194/s1"},"text":"June 30, 1951, ch. 194, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/107"},"text":"65 Stat. 107","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330008/9"},"text":"Pub. L. 103–322, title XXXIII, § 330008(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2143"},"text":"108 Stat. 2143","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb99ad4b1-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb99ad4b2-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb99ad4b3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “violate any of such sections” for “violate any of the afore-mentioned sections”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
