{"tag":"section","attrib":{"id":"idb8de89ce-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s712"},"text":null,"children":[{"tag":"num","attrib":{"value":"712"},"text":"§ 712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Misuse of names, words, emblems, or insignia","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, in the course of collecting or aiding in the collection of private debts or obligations, or being engaged in furnishing private police, investigation, or other private detective services, uses or employs in any communication, correspondence, notice, advertisement, or circular the words “national”, “Federal”, or “United States”, the initials “U.S.”, or any emblem, insignia, or name, for the purpose of conveying and in a manner reasonably calculated to convey the false impression that such communication is from a department, agency, bureau, or instrumentality of the United States or in any manner represents the United States, shall be fined under this title or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8de89cf-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/291/s1"},"text":"Pub. L. 86–291, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-21"},"text":"Sept. 21, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/570"},"text":"73 Stat. 570","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/147/s1/a"},"text":"Pub. L. 93–147, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-11-03"},"text":"Nov. 3, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/554"},"text":"87 Stat. 554","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8de89d0-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8de89d1-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8de89d2-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $1,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/147"},"text":"Pub. L. 93–147","children":[],"tail":" substituted “Misuse of names, words, emblems, or insignia” for “Misuse of names by collecting agencies or private detective agencies to indicate Federal agency” in section catchline and substituted “in the course” and “such communication is from a department” for “being engaged in the business” and “such business is a department” respectively, and struck out “as part of the firm name of such business,” after “detective services, uses”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8de89d3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8de89d4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/86/291/s2"},"text":"Pub. L. 86–291, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-21"},"text":"Sept. 21, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/570"},"text":"73 Stat. 570","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/86/291/s2"},"text":"“The provisions of this section [enacting this section] shall become effective sixty days from the enactment thereof [","children":[{"tag":"date","attrib":{"date":"1959-09-21"},"text":"Sept. 21, 1959","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
