{"tag":"section","attrib":{"id":"idb8bd1f06-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s210"},"text":null,"children":[{"tag":"num","attrib":{"value":"210"},"text":"§ 210.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offer to procure appointive public office","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever pays or offers or promises any money or thing of value, to any person, firm, or corporation in consideration of the use or promise to use any influence to procure any appointive office or place under the United States for any person, shall be fined under this title or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8bd1f07-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/694"},"text":"62 Stat. 694","children":[],"tail":", § 210, formerly § 214; renumbered § 210, "},{"tag":"ref","attrib":{"href":"/us/pl/87/849/s1/b"},"text":"Pub. L. 87–849, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-23"},"text":"Oct. 23, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1125"},"text":"76 Stat. 1125","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8bd1f08-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8bd1f09-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on Title 18, U. S.C., 1940 ed., §§ 149 and 151 (","children":[{"tag":"date","attrib":{"date":"1926-12-11"},"text":"Dec. 11, 1926","children":[],"tail":", c. 3, §§ 1, 3, "},{"tag":"ref","attrib":{"href":"/us/stat/44/918"},"text":"44 Stat. 918","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes of style and substance were made in this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Term “or place” was inserted after words “appointive office” in order to give broader scope to the section and also to follow the phraseology used in similar provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s202"},"text":"section 202 of Title 18","children":[],"tail":", U.S.C., 1940 ed., now section 216 [repealed] of this title. (See 46 Corpus Juris 924, where it is explained that the work “places” is used in a less technical sense than the word “offices”.)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The punishment provision, added at the end of this section and section 215 [now section 211] of this title to secure uniformity of style throughout this chapter, was originally enacted as a separate section, incorporating the other two by reference. 80th Congress House Report No. 304.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8bd1f0a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb8bd1f0b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 210, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"act June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/693"},"text":"62 Stat. 693","children":[],"tail":", related to acceptance of a bribe by a witness, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/87/849"},"text":"Pub. L. 87–849","children":[],"tail":" and is substantially covered in revised section 201."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8bd1f0c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $1,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
