{"tag":"section","attrib":{"id":"idb8bd1f0d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s211"},"text":null,"children":[{"tag":"num","attrib":{"value":"211"},"text":"§ 211.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance or solicitation to obtain appointive public office","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever solicits or receives, either as a political contribution, or for personal emolument, any money or thing of value, in consideration of the promise of support or use of influence in obtaining for any person any appointive office or place under the United States, shall be fined under this title or imprisoned not more than one year, or both.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever solicits or receives any thing of value in consideration of aiding a person to obtain employment under the United States either by referring his name to an executive department or agency of the United States or by requiring the payment of a fee because such person has secured such employment shall be fined under this title, or imprisoned not more than one year, or both. This section shall not apply to such services rendered by an employment agency pursuant to the written request of an executive department or agency of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8bd1f0e-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/694"},"text":"62 Stat. 694","children":[],"tail":", § 211, formerly § 215; "},{"tag":"ref","attrib":{"href":"/us/act/1951-09-13/ch380"},"text":"Sept. 13, 1951, ch. 380","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/320"},"text":"65 Stat. 320","children":[],"tail":"; renumbered § 211, "},{"tag":"ref","attrib":{"href":"/us/pl/87/849/s1/b"},"text":"Pub. L. 87–849, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-23"},"text":"Oct. 23, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1125"},"text":"76 Stat. 1125","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/H"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8bd1f0f-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8bd1f10-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., §§ 150 and 151 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-12-11/ch3"},"text":"Dec. 11, 1926, ch. 3","children":[],"tail":", §§ 2, 3, "},{"tag":"ref","attrib":{"href":"/us/stat/44/918"},"text":"44 Stat. 918","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Same changes of style and substance were made in this section as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s214"},"text":"section 214 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8bd1f11-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb8bd1f12-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 211, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"act June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/693"},"text":"62 Stat. 693","children":[],"tail":", related to an offer of a gratuity to a revenue officer, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/87/849"},"text":"Pub. L. 87–849","children":[],"tail":" and is substantially covered in revised section 201."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8bd1f13-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $1,000” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1951—Act ","children":[{"tag":"date","attrib":{"date":"1951-09-13"},"text":"Sept. 13, 1951","children":[],"tail":", inserted second paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
