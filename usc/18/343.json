{"tag":"section","attrib":{"id":"idb8c695a3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s343"},"text":null,"children":[{"tag":"num","attrib":{"value":"343"},"text":"§ 343.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presumptions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c695a4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s343/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual with a blood alcohol content of .10 percent or more shall be presumed to be under the influence of alcohol; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c695a5-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s343/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual shall be presumed to be under the influence of drugs if the quantity of the drug in the system of the individual would be sufficient to impair the perception, mental processes, or motor functions of the average individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8c695a6-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/tI/s1971/a"},"text":"Pub. L. 99–570, title I, § 1971(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-59"},"text":"100 Stat. 3207–59","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI/s6473/c"},"text":"Pub. L. 100–690, title VI, § 6473(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4379"},"text":"102 Stat. 4379","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c695a7-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8c695a8-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8c695a9-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s6473/c/1"},"text":"Pub. L. 100–690, § 6473(c)(1)","children":[],"tail":", substituted “.10 percent” for “.10” and struck out “conclusively” after “shall be”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s6473/c/2"},"text":"Pub. L. 100–690, § 6473(c)(2)","children":[],"tail":", struck out “conclusively” after “shall be”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
