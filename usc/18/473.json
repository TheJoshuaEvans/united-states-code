{"tag":"section","attrib":{"id":"idb8cb776f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s473"},"text":null,"children":[{"tag":"num","attrib":{"value":"473"},"text":"§ 473.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dealing in counterfeit obligations or securities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever buys, sells, exchanges, transfers, receives, or delivers any false, forged, counterfeited, or altered obligation or other security of the United States, with the intent that the same be passed, published, or used as true and genuine, shall be fined under this title or imprisoned not more than 20 years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8cb7770-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/705"},"text":"62 Stat. 705","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tIII/s374/d"},"text":"Pub. L. 107–56, title III, § 374(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/340"},"text":"115 Stat. 340","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8cb7771-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8cb7772-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 268 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s154"},"text":"Mar. 4, 1909, ch. 321, § 154","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1117"},"text":"35 Stat. 1117","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to circulating notes of banking associations was omitted as covered by definition of obligation or other security in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s8"},"text":"section 8 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8cb7773-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8cb7774-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56"},"text":"Pub. L. 107–56","children":[],"tail":" substituted “20 years” for “ten years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $5,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
