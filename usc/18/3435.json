{"tag":"section","attrib":{"id":"idb99d4598-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3435"},"text":null,"children":[{"tag":"num","attrib":{"value":"3435"},"text":"§ 3435.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receiver of stolen property triable before or after principal","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A person charged with receiving or concealing stolen property may be tried either before or after the trial of the principal offender.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb99d4599-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/831"},"text":"62 Stat. 831","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb99d459a-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb99d459b-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., §§ 101, 467 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321"},"text":"Mar. 4, 1909, ch. 321","children":[],"tail":", §§ 48, 288, "},{"tag":"ref","attrib":{"href":"/us/stat/35/1098"},"text":"35 Stat. 1098","children":[],"tail":", 1145)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Other provisions of sections 101 and 467 of title 18, U.S.C., 1940 ed., were incorporated in sections 641 and 662 of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Necessary changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
