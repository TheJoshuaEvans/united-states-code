{"tag":"section","attrib":{"id":"idb92ad54b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1593A"},"text":null,"children":[{"tag":"num","attrib":{"value":"1593A"},"text":"§ 1593A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefitting financially from peonage, slavery, and trafficking in persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever knowingly benefits, financially or by receiving anything of value, from participation in a venture which has engaged in any act in violation of this chapter, knowing or in reckless disregard of the fact that the venture has engaged in such violation, shall be fined under this title or imprisoned in the same manner as a completed violation of such section.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb92ad54c-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/457/tII/s222/d/1"},"text":"Pub. L. 110–457, title II, § 222(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-12-23"},"text":"Dec. 23, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/5070"},"text":"122 Stat. 5070","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/393/tIII/s303/c"},"text":"Pub. L. 115–393, title III, § 303(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5273"},"text":"132 Stat. 5273","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92ad54d-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92ad54e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92ad54f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/393"},"text":"Pub. L. 115–393","children":[],"tail":" substituted “this chapter” for “section 1581(a), 1592, or 1595(a)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
