"},"text":"section 171 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8b5f2dd-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/191"},"text":"Pub. L. 100–191","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1987-12-15"},"text":"Dec. 15, 1987","children":[],"tail":", and applicable to independent counsel proceedings under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s591"},"text":"28 U.S.C. 591","children":[],"tail":" et seq. pending on that date as well as to proceedings on and after that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/191/s6"},"text":"section 6 of Pub. L. 100–191","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s591"},"text":"section 591 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8b5f2de-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1968 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/578"},"text":"Pub. L. 90–578","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1968-10-17"},"text":"Oct. 17, 1968","children":[],"tail":", except when a later effective date is applicable, which is the earlier of date when implementation of amendment by appointment of magistrates [now United States magistrate judges] and assumption of office takes place or third anniversary of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/90/578"},"text":"Pub. L. 90–578","children":[],"tail":", 