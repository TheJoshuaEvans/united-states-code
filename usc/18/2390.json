{"tag":"section","attrib":{"id":"idb96d83d8-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2390"},"text":null,"children":[{"tag":"num","attrib":{"value":"2390"},"text":"§ 2390.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enlistment to serve against United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever enlists or is engaged within the United States or in any place subject to the jurisdiction thereof, with intent to serve in armed hostility against the United States, shall be fined under this title ","children":[{"tag":"ref","attrib":{"idref":"fn002198"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002198"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See 1994 Amendment note below."}],"tail":" or imprisoned not more than three years, or both."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb96d83d9-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/812"},"text":"62 Stat. 812","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/B"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2146"},"text":"108 Stat. 2146","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb96d83da-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb96d83db-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 18, U.S.C., 1940 ed., § 8 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s8"},"text":"Mar. 4, 1909, ch. 321, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1089"},"text":"35 Stat. 1089","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Mandatory punishment provision was rephrased in the alternative.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb96d83dc-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb96d83dd-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":", which directed the amendment of this section by striking “fined not more than $100” and inserting “fined under this title”, was executed by substituting “fined under this title” for “fined $100”, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
