{"tag":"section","attrib":{"id":"idb9988b2e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3267"},"text":null,"children":[{"tag":"num","attrib":{"value":"3267"},"text":"§ 3267.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9988b2f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3267/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “employed by the Armed Forces outside the United States” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9988b30-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3267/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" employed as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9988b31-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3267/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a civilian employee of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb9988b32-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3267/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Defense (including a nonappropriated fund instrumentality of the Department); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb9988b33-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3267/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other Federal agency, or any provisional authority, to the extent such employment relates to supporting the mission of the Department of Defense overseas;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9988b34-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3267/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a contractor (including a subcontractor at any tier) of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb9988b35-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3267/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Defense (including a nonappropriated fund instrumentality of the Department); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb9988b36-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3267/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other Federal agency, or any provisional authority, to the extent such employment relates to supporting the mission of the Department of Defense overseas; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9988b37-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3267/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an employee of a contractor (or subcontractor at any tier) of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb9988b38-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3267/1/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Defense (including a nonappropriated fund instrumentality of the Department); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb9988b39-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3267/1/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other Federal agency, or any provisional authority, to the extent such employment relates to supporting the mission of the Department of Defense overseas;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9988b3a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3267/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" present or residing outside the United States in connection with such employment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9988b3b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3267/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not a national of or ordinarily resident in the host nation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9988b3c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3267/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “accompanying the Armed Forces outside the United States” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9988b3d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3267/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a dependent of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9988b3e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3267/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the Armed Forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9988b3f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3267/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a civilian employee of the Department of Defense (including a nonappropriated fund instrumentality of the Department); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9988b40-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3267/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Department of Defense contractor (including a subcontractor at any tier) or an employee of a Department of Defense contractor (including a subcontractor at any tier);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9988b41-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3267/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" residing with such member, civilian employee, contractor, or contractor employee outside the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9988b42-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3267/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not a national of or ordinarily resident in the host nation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9988b43-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3267/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Armed Forces” has the meaning given the term “armed forces” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a/4"},"text":"section 101(a)(4) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9988b44-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3267/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “Judge Advocate General” and “judge advocate” have the meanings given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9988b45-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/523/s2/a"},"text":"Pub. L. 106–523, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2491"},"text":"114 Stat. 2491","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tX/s1088"},"text":"Pub. L. 108–375, div. A, title X, § 1088","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2066"},"text":"118 Stat. 2066","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9988b46-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9988b47-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9988b48-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Par. (1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" amended subpar. (A) generally. Prior to amendment, subpar. (A) read as follows: “employed as a civilian employee of the Department of Defense (including a nonappropriated fund instrumentality of the Department), as a Department of Defense contractor (including a subcontractor at any tier), or as an employee of a Department of Defense contractor (including a subcontractor at any tier);”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
