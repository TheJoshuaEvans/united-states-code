{"tag":"section","attrib":{"id":"idb972652f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2512"},"text":null,"children":[{"tag":"num","attrib":{"value":"2512"},"text":"§ 2512.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manufacture, distribution, possession, and advertising of wire, oral, or electronic communication intercepting devices prohibited","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9726530-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2512/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as otherwise specifically provided in this chapter, any person who intentionally—","children":[],"tail":null},{"tag":"level","attrib":{"id":"idb9726531-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2512/1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sends through the mail, or sends or carries in interstate or foreign commerce, any electronic, mechanical, or other device, knowing or having reason to know that the design of such device renders it primarily useful for the purpose of the surreptitious interception of wire, oral, or electronic communications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"level","attrib":{"id":"idb9726532-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2512/1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manufactures, assembles, possesses, or sells any electronic, mechanical, or other device, knowing or having reason to know that the design of such device renders it primarily useful for the purpose of the surreptitious interception of wire, oral, or electronic communications, and that such device or any component thereof has been or will be sent through the mail or transported in interstate or foreign commerce; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"level","attrib":{"id":"idb9726533-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2512/1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" places in any newspaper, magazine, handbill, or other publication or disseminates by electronic means any advertisement of—","children":[],"tail":null},{"tag":"level","attrib":{"id":"idb9726534-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2512/1/c/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any electronic, mechanical, or other device knowing or having reason to know that the design of such device renders it primarily useful for the purpose of the surreptitious interception of wire, oral, or electronic communications; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"level","attrib":{"id":"idb9726535-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2512/1/c/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other electronic, mechanical, or other device, where such advertisement promotes the use of such device for the purpose of the surreptitious interception of wire, oral, or electronic communications,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"knowing the content of the advertisement and knowing or having reason to know that such advertisement will be sent through the mail or transported in interstate or foreign commerce,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under this title or imprisoned not more than five years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9726536-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2512/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" It shall not be unlawful under this section for—","children":[],"tail":null},{"tag":"level","attrib":{"id":"idb9726537-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2512/2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a provider of wire or electronic communication service or an officer, agent, or employee of, or a person under contract with, such a provider, in the normal course of the business of providing that wire or electronic communication service, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"level","attrib":{"id":"idb9726538-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2512/2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer, agent, or employee of, or a person under contract with, the United States, a State, or a political subdivision thereof, in the normal course of the activities of the United States, a State, or a political subdivision thereof,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to send through the mail, send or carry in interstate or foreign commerce, or manufacture, assemble, possess, or sell any electronic, mechanical, or other device knowing or having reason to know that the design of such device renders it primarily useful for the purpose of the surreptitious interception of wire, oral, or electronic communications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9726539-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s2512/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It shall not be unlawful under this section to advertise for sale a device described in subsection (1) of this section if the advertisement is mailed, sent, or carried in interstate or foreign commerce solely to a domestic provider of wire or electronic communication service or to an agency of the United States, a State, or a political subdivision thereof which is duly authorized to use such device.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb972653a-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tIII/s802"},"text":"Pub. L. 90–351, title III, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-06-19"},"text":"June 19, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/214"},"text":"82 Stat. 214","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/508/tI/s101/c/1/A"},"text":"Pub. L. 99–508, title I, § 101(c)(1)(A)","children":[],"tail":", (7), (f)(2), "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1851"},"text":"100 Stat. 1851","children":[],"tail":", 1853; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII"},"text":"Pub. L. 103–322, title XXXIII","children":[],"tail":", §§ 330016(1)(L), 330022, "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":", 2150; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s604/b/45"},"text":"Pub. L. 104–294, title VI, § 604(b)(45)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3509"},"text":"110 Stat. 3509","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/112/s2"},"text":"Pub. L. 105–112, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2273"},"text":"111 Stat. 2273","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXXII/s2207/f"},"text":"Pub. L. 107–296, title XXII, § 2207(f)","children":[],"tail":", formerly title II, § 225(f), "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2158"},"text":"116 Stat. 2158","children":[],"tail":", renumbered § 2207(f), "},{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/g/2/I"},"text":"Pub. L. 115–278, § 2(g)(2)(I)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-11-16"},"text":"Nov. 16, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4178"},"text":"132 Stat. 4178","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb972653b-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb972653c-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb972653d-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Par. (1)(c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":", in introductory provisions, inserted “or disseminates by electronic means” after “or other publication” and, in concluding provisions, inserted “knowing the content of the advertisement and” before “knowing or having reason to know”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/112"},"text":"Pub. L. 105–112","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330022"},"text":"Pub. L. 103–322, § 330022","children":[],"tail":". See 1994 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330016/1/L"},"text":"Pub. L. 103–322, § 330016(1)(L)","children":[],"tail":", substituted “fined under this title” for “fined not more than $10,000” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s330022"},"text":"Pub. L. 103–322, § 330022","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":", realigned margins of concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/508/s101/c/1/A"},"text":"Pub. L. 99–508, § 101(c)(1)(A)","children":[],"tail":", substituted “wire, oral, or electronic” for “wire or oral” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/508/s101/c/1/A"},"text":"Pub. L. 99–508, § 101(c)(1)(A)","children":[],"tail":", (f)(2), substituted “intentionally” for “willfully” in introductory provision and “wire, oral, or electronic” for “wire or oral” in subpars. (a), (b), and (c)(i), (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/508/s101/c/7"},"text":"Pub. L. 99–508, § 101(c)(7)","children":[],"tail":", substituted “a provider of wire or electronic communication service or” for “a communications common carrier or”, “such a provider, in” for “a communications common carrier, in”, and “business of providing that wire or electronic communication service” for “communications common carrier’s business”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/508/s101/c/1/A"},"text":"Pub. L. 99–508, § 101(c)(1)(A)","children":[],"tail":", substituted “wire, oral, or electronic” for “wire or oral”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb972653e-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb972653f-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s4"},"text":"section 4 of Pub. L. 107–296","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb9726540-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/s604/d"},"text":"section 604(d) of Pub. L. 104–294","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s13"},"text":"section 13 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb9726541-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/508"},"text":"Pub. L. 99–508","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", and, in case of conduct pursuant to court order or extension, applicable only with respect to court orders and extensions made after such date, with special rule for State authorizations of interceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/508/s111"},"text":"section 111 of Pub. L. 99–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2510"},"text":"section 2510 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
