{"tag":"section","attrib":{"id":"idb91307c1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s1092"},"text":null,"children":[{"tag":"num","attrib":{"value":"1092"},"text":"§ 1092.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusive remedies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed as precluding the application of State or local laws to the conduct proscribed by this chapter, nor shall anything in this chapter be construed as creating any substantive or procedural right enforceable by law by any party in any proceeding.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb91307c2-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/606/s2/a"},"text":"Pub. L. 100–606, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3046"},"text":"102 Stat. 3046","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
