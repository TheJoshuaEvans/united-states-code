{"tag":"section","attrib":{"id":"idb8ea70df-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s915"},"text":null,"children":[{"tag":"num","attrib":{"value":"915"},"text":"§ 915.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign diplomats, consuls or officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, with intent to defraud within the United States, falsely assumes or pretends to be a diplomatic, consular or other official of a foreign government duly accredited as such to the United States and acts as such, or in such pretended character, demands or obtains or attempts to obtain any money, paper, document, or other thing of value, shall be fined under this title or imprisoned not more than ten years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8ea70e0-47c4-11f1-9a61-b1559996dfe8"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645"},"text":"June 25, 1948, ch. 645","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/743"},"text":"62 Stat. 743","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330016/1/K"},"text":"Pub. L. 103–322, title XXXIII, § 330016(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2147"},"text":"108 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8ea70e1-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8ea70e2-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s232"},"text":"section 232 of title 22","children":[],"tail":", U.S.C., 1940 ed., Foreign Relations and Intercourse ("},{"tag":"ref","attrib":{"href":"/us/act/1917-06-15/ch30"},"text":"June 15, 1917, ch. 30","children":[],"tail":", title VIII, § 2, "},{"tag":"ref","attrib":{"href":"/us/stat/40/226"},"text":"40 Stat. 226","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1940-03-28/ch72/s6"},"text":"Mar. 28, 1940, ch. 72, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/80"},"text":"54 Stat. 80","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to “jurisdiction” of the United States was omitted as unnecessary in view of definition of “United States” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s5"},"text":"section 5 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Mandatory punishment provision was rephrased in the alternative.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8ea70e3-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8ea70e4-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “fined under this title” for “fined not more than $5,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
