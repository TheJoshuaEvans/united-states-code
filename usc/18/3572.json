{"tag":"section","attrib":{"id":"idb9ab9d57-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3572"},"text":null,"children":[{"tag":"num","attrib":{"value":"3572"},"text":"§ 3572.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of a sentence of fine and related matters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9ab9d58-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3572/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Factors To Be Considered","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether to impose a fine, and the amount, time for payment, and method of payment of a fine, the court shall consider, in addition to the factors set forth in section 3553(a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9ab9d59-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3572/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the defendant’s income, earning capacity, and financial resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9ab9d5a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3572/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the burden that the fine will impose upon the defendant, any person who is financially dependent on the defendant, or any other person (including a government) that would be responsible for the welfare of any person financially dependent on the defendant, relative to the burden that alternative punishments would impose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9ab9d5b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3572/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any pecuniary loss inflicted upon others as a result of the offense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9ab9d5c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3572/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether restitution is ordered or made and the amount of such restitution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9ab9d5d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3572/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need to deprive the defendant of illegally obtained gains from the offense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9ab9d5e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3572/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expected costs to the government of any imprisonment, supervised release, or probation component of the sentence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9ab9d5f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3572/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the defendant can pass on to consumers or other persons the expense of the fine; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9ab9d60-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3572/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the defendant is an organization, the size of the organization and any measure taken by the organization to discipline any officer, director, employee, or agent of the organization responsible for the offense and to prevent a recurrence of such an offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9ab9d61-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3572/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fine Not to Impair Ability to Make Restitution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If, as a result of a conviction, the defendant has the obligation to make restitution to a victim of the offense, other than the United States, the court shall impose a fine or other monetary penalty only to the extent that such fine or penalty will not impair the ability of the defendant to make restitution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9ab9d62-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3572/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of Finality of Judgment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding the fact that a sentence to pay a fine can subsequently be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9ab9d63-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3572/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modified or remitted under section 3573;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9ab9d64-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3572/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" corrected under rule 35 of the Federal Rules of Criminal Procedure and section 3742; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9ab9d65-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3572/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appealed and modified under section 3742;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"a judgment that includes such a sentence is a final judgment for all other purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9ab9d66-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3572/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time, Method of Payment, and Related Items","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9ab9d67-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3572/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person sentenced to pay a fine or other monetary penalty, including restitution, shall make such payment immediately, unless, in the interest of justice, the court provides for payment on a date certain or in installments. If the court provides for payment in installments, the installments shall be in equal monthly payments over the period provided by the court, unless the court establishes another schedule.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9ab9d68-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3572/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the judgment, or, in the case of a restitution order, the order, permits other than immediate payment, the length of time over which scheduled payments will be made shall be set by the court, but shall be the shortest time in which full payment can reasonably be made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9ab9d69-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3572/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A judgment for a fine which permits payments in installments shall include a requirement that the defendant will notify the court of any material change in the defendant’s economic circumstances that might affect the defendant’s ability to pay the fine. Upon receipt of such notice the court may, on its own motion or the motion of any party, adjust the payment schedule, or require immediate payment in full, as the interests of justice require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9ab9d6a-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3572/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternative Sentence Precluded","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At the time a defendant is sentenced to pay a fine, the court may not impose an alternative sentence to be carried out if the fine is not paid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9ab9d6b-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3572/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibility for Payment of Monetary Obligation Relating to Organization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a sentence includes a fine, special assessment, restitution or other monetary obligation (including interest) with respect to an organization, each individual authorized to make disbursements for the organization has a duty to pay the obligation from assets of the organization. If such an obligation is imposed on a director, officer, shareholder, employee, or agent of an organization, payments may not be made, directly or indirectly, from assets of the organization, unless the court finds that such payment is expressly permissible under applicable State law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9ab9d6c-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3572/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Security for Stayed Fine","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a sentence imposing a fine is stayed, the court shall, absent exceptional circumstances (as determined by the court)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9ab9d6d-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3572/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the defendant to deposit, in the registry of the district court, any amount of the fine that is due;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9ab9d6e-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3572/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the defendant to provide a bond or other security to ensure payment of the fine; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9ab9d6f-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3572/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restrain the defendant from transferring or dissipating assets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9ab9d70-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3572/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delinquency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A fine or payment of restitution is delinquent if a payment is more than 30 days late.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9ab9d71-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3572/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Default","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A fine or payment of restitution is in default if a payment is delinquent for more than 90 days. Notwithstanding any installment schedule, when a fine or payment of restitution is in default, the entire amount of the fine or restitution is due within 30 days after notification of the default, subject to the provisions of section 3613A.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9ab9d72-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s212/a/2"},"text":"Pub. L. 98–473, title II, § 212(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1995"},"text":"98 Stat. 1995","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/185/s7"},"text":"Pub. L. 100–185, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-11"},"text":"Dec. 11, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1280"},"text":"101 Stat. 1280","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXV/s3587"},"text":"Pub. L. 101–647, title XXXV, § 3587","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4930"},"text":"104 Stat. 4930","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tII/s20403/a"},"text":"Pub. L. 103–322, title II, § 20403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1825"},"text":"108 Stat. 1825","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tII/s207/b"},"text":"Pub. L. 104–132, title II, § 207(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1236"},"text":"110 Stat. 1236","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9ab9d73-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9ab9d74-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9ab9d75-47c4-11f1-9a61-b1559996dfe8"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Criminal Procedure, referred to in subsec. (c)(2), are set out in the Appendix to this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb9ab9d76-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For a prior section 3572, applicable to offenses committed prior to ","children":[{"tag":"date","attrib":{"date":"1987-11-01"},"text":"Nov. 1, 1987","children":[],"tail":", see note set out preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3551"},"text":"section 3551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9ab9d77-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s207/b/1"},"text":"Pub. L. 104–132, § 207(b)(1)","children":[],"tail":", inserted “other than the United States,” after “offense,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s207/b/2/A"},"text":"Pub. L. 104–132, § 207(b)(2)(A)","children":[],"tail":", (B), substituted “(1) A person sentenced to pay a fine or other monetary penalty, including restitution,” for “A person sentenced to pay a fine or other monetary penalty” and struck out at end “If the judgment permits other than immediate payment, the period provided for shall not exceed five years, excluding any period served by the defendant as imprisonment for the offense.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s207/b/2/C"},"text":"Pub. L. 104–132, § 207(b)(2)(C)","children":[],"tail":", added pars. (2) and (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s207/b/3"},"text":"Pub. L. 104–132, § 207(b)(3)","children":[],"tail":", inserted “restitution” after “special assessment,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s207/b/4"},"text":"Pub. L. 104–132, § 207(b)(4)","children":[],"tail":", inserted “or payment of restitution” after “A fine”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s207/b/5"},"text":"Pub. L. 104–132, § 207(b)(5)","children":[],"tail":", inserted “or payment of restitution” after “A fine” in first sentence and amended second sentence generally. Prior to amendment, second sentence read as follows: “When a fine is in default, the entire amount of the fine is due within 30 days after notification of the default, notwithstanding any installment schedule.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(6) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" added par. (6) and redesignated former pars. (6) and (7) as (7) and (8), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":" inserted “of the Federal Rules of Criminal Procedure” after “rule 35”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/185"},"text":"Pub. L. 100–185","children":[],"tail":" inserted “and related matters” in section catchline and amended text generally, revising and restating as subsecs. (a) to (i) provisions formerly contained in subsecs. (a) to (j)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9ab9d78-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb9ab9d79-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132"},"text":"Pub. L. 104–132","children":[],"tail":" to be effective, to extent constitutionally permissible, for sentencing proceedings in cases in which defendant is convicted on or after "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/s211"},"text":"section 211 of Pub. L. 104–132","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2248"},"text":"section 2248 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9ab9d7a-47c4-11f1-9a61-b1559996dfe8"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1987-11-01"},"text":"Nov. 1, 1987","children":[],"tail":", and applicable only to offenses committed after the taking effect of this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/s235/a/1"},"text":"section 235(a)(1) of Pub. L. 98–473","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3551"},"text":"section 3551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
