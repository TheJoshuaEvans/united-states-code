{"tag":"section","attrib":{"id":"idb99ad4c1-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3293"},"text":null,"children":[{"tag":"num","attrib":{"value":"3293"},"text":"§ 3293.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial institution offenses","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"No person shall be prosecuted, tried, or punished for a violation of, or a conspiracy to violate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb99ad4c2-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3293/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 215, 656, 657, 1005, 1006, 1007, 1014, 1033, or 1344;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb99ad4c3-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3293/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 1341 or 1343, if the offense affects a financial institution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb99ad4c4-47c4-11f1-9a61-b1559996dfe8","identifier":"/us/usc/t18/s3293/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 1963, to the extent that the racketeering activity involves a violation of section 1344;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"unless the indictment is returned or the information is filed within 10 years after the commission of the offense.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb99ad4c5-47c4-11f1-9a61-b1559996dfe8"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/tIX/s961"},"text":"Pub. L. 101–73, title IX, § 961","children":[],"tail":"("},{"t