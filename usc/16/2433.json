{"tag":"section","attrib":{"id":"id799ade0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2433"},"text":null,"children":[{"tag":"num","attrib":{"value":"2433"},"text":"§ 2433.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representatives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id799ade0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2433/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representative to the Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State, with the concurrence of the Secretary of Commerce and the Director of the National Science Foundation, shall appoint an officer or employee of the United States as the United States representative to the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799ade0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2433/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representative to the Scientific Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce and the Director of the National Science Foundation, with the concurrence of the Secretary of State, shall designate the United States representative to the Scientific Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799ade10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2433/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States representatives to the Commission and the Scientific Committee shall receive no additional compensation by reason of their services as such representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id799ade11-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/623/tIII/s304"},"text":"Pub. L. 98–623, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3400"},"text":"98 Stat. 3400","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
