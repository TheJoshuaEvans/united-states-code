{"tag":"section","attrib":{"id":"id770fed89-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s192b–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"192b–2"},"text":"§ 192b–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Addition of lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The following-described lands, comprising approximately one hundred and forty acres, are added to Rocky Mountain National Park and shall be subject to all laws and regulations applicable to said park:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"sixth principal meridian","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Township 5 north, range 73 west, section 27, southwest quarter northwest quarter, and west half southwest quarter; section 34, west half northeast quarter northwest quarter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id770fed8a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-08-24/ch501/s1"},"text":"Aug. 24, 1949, ch. 501, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/626"},"text":"63 Stat. 626","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
