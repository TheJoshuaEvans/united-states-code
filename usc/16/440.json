{"tag":"section","attrib":{"id":"id779a2c5a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s440"},"text":null,"children":[{"tag":"num","attrib":{"value":"440"},"text":"§ 440.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Closure in times of national emergency","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior may, in case of a national emergency, close the said Fort McHenry and it may be used for any and all military purposes during the period of the emergency and for such period of time thereafter, as the public needs may require.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id779a2c5b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-05-26/ch100"},"text":"May 26, 1914, ch. 100","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/382"},"text":"38 Stat. 382","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1925-03-03/ch425"},"text":"Mar. 3, 1925, ch. 425","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/1109"},"text":"43 Stat. 1109","children":[],"tail":"; Ex. Ord. No. 6166, § 2, "},{"tag":"date","attrib":{"date":"1933-06-10"},"text":"June 10, 1933","children":[],"tail":"; Ex. Ord. No. 6228, § 1, "},{"tag":"date","attrib":{"date":"1933-07-28"},"text":"July 28, 1933","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id779a2c5c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id779a2c5d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id779a2c5e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,