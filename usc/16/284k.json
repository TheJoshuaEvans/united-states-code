{"tag":"section","attrib":{"id":"id7727bad3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s284k"},"text":null,"children":[{"tag":"num","attrib":{"value":"284k"},"text":"§ 284k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7727bad4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s284k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" By Federal employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior, any other Federal employee, and any employee of the Foundation, with respect to any reference to the park in any map, publication, sign, notice, or other official document or communication of the Federal Government or Foundation shall refer to the park as “Wolf Trap National Park for the Performing Arts”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7727bad5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s284k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other signs and notices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any directional or official sign or notice pertaining to the park shall refer to the park as “Wolf Trap National Park for the Performing Arts”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7727bad6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s284k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal laws and documents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reference in any law (other than this subchapter), regulation, document, record, map, or other paper of the United States to “Wolf Trap Farm Park” shall be considered to be a reference to “Wolf Trap National Park for the Performing Arts”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7727bad7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/671/s14"},"text":"Pub. L. 89–671, § 14","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/219/s1/a/3"},"text":"Pub. L. 107–219, § 1(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1330"},"text":"116 Stat. 1330","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7727bad8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7727bad9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7727bada-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/219/s1/b"},"text":"Pub. L. 107–219, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1330"},"text":"116 Stat. 1330","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/219/s1/b"},"text":"“Section 14(c) of the Wolf Trap Farm Park Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s284k/c"},"text":"16 U.S.C. 284k(c)","children":[],"tail":"] (as added by subsection (a) of this section) shall not apply to this Act [enacting this section and amending former section 1e and sections 284, 284a, 284c, and 284j of this title and provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s284c"},"text":"section 284c of this title","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
