{"tag":"section","attrib":{"id":"id78163990-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"470dd"},"text":"§ 470dd.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Custody of archaeological resources","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Interior may promulgate regulations providing for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78163991-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470dd/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the exchange, where appropriate, between suitable universities, museums, or other scientific or educational institutions, of archaeological resources removed from public lands and Indian lands pursuant to this chapter, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78163992-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470dd/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ultimate disposition of such resources and other resources removed pursuant to chapter 3125 or chapter 3203 of title 54.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Any exchange or ultimate disposition under such regulation of archaeological resources excavated or removed from Indian lands shall be subject to the consent of the Indian or Indian tribe which owns or has jurisdiction over such lands. Following promulgation of regulations under this section, notwithstanding any other provision of law, such regulations shall govern the disposition of archaeological resources removed from public lands and Indian lands pursuant to this chapter.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78163993-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/95/s5"},"text":"Pub. L. 96–95, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-31"},"text":"Oct. 31, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/724"},"text":"93 Stat. 724","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/287/s5/d/7"},"text":"Pub. L. 113–287, § 5(d)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3264"},"text":"128 Stat. 3264","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78163994-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78163995-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78163996-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287"},"text":"Pub. L. 113–287","children":[],"tail":" substituted “chapter 3125 or chapter 3203 of title 54” for “the Act of "},{"tag":"date","attrib":{"date":"1960-06-27"},"text":"June 27, 1960","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s469–469c"},"text":"16 U.S.C. 469–469c","children":[],"tail":") or the Act of "},{"tag":"date","attrib":{"date":"1906-06-08"},"text":"June 8, 1906","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s431–433"},"text":"16 U.S.C. 431–433","children":[],"tail":")”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
