{"tag":"section","attrib":{"id":"id792d2805-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1421e"},"text":"§ 1421e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id792d2806-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person who is authorized to respond to a stranding or entanglement pursuant to an agreement entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1382/c"},"text":"section 1382(c) of this title","children":[],"tail":" is deemed to be an employee of the Government for purposes of chapter 171 of title 28, with respect to actions of the person that are—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id792d2807-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with the agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d2808-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an unusual mortality event, in accordance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792d2809-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421e/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contingency plan issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1421c/b"},"text":"section 1421c(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d280a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421e/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the instructions of an Onsite Coordinator designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1421c/c"},"text":"section 1421c(c) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d280b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421e/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the best professional judgment of an Onsite Coordinator, in the case of any matter that is not covered by the contingency plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792d280c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) does not apply to actions of a person described in that subsection that are grossly negligent or that constitute willful misconduct.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id792d280d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522/tIV/s406"},"text":"Pub. L. 92–522, title IV, § 406","children":[],"tail":", formerly title III, § 306, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/tIII/s3003/a"},"text":"Pub. L. 102–587, title III, § 3003(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5064"},"text":"106 Stat. 5064","children":[],"tail":"; renumbered title IV, § 406, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/238/s24/b"},"text":"Pub. L. 103–238, § 24(b)","children":[],"tail":", (c)(3), (4), "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/565"},"text":"108 Stat. 565","children":[],"tail":", 566; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tCIV/s10404"},"text":"Pub. L. 117–263, div. J, title CIV, § 10404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3984"},"text":"136 Stat. 3984","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id792d280e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id792d280f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id792d2810-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":", in introductory provisions, inserted “or entanglement” after “to a stranding” and substituted “Government” for “government”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(2)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/238/s24/c/3"},"text":"Pub. L. 103–238, § 24(c)(3)","children":[],"tail":", (4), made technical amendment to references to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1421c"},"text":"section 1421c of this title","children":[],"tail":" to reflect renumbering of corresponding section of original act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
