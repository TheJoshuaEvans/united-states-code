{"tag":"section","attrib":{"id":"id776f4b1b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eee"},"text":null,"children":[{"tag":"num","attrib":{"value":"410eee"},"text":"§ 410eee.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id776f4b1c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eee/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776f4b1d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eee/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in 1946, Secretary of the Interior J.A. Krug, by means of the authority granted the Secretary of the Interior under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1866/a"},"text":"section 1866(a) of title 18","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s320102"},"text":"section 320102 of title 54","children":[],"tail":", established the Adams Mansion National Historic Site, located in Quincy, Massachusetts;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776f4b1e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eee/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in 1952, Acting Secretary of the Interior Vernon D. Northrup enlarged the site and renamed it the Adams National Historic Site, using the Secretary’s authority as provided in the Historic Sites Act; ","children":[{"tag":"ref","attrib":{"idref":"fn002162"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002162"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776f4b1f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eee/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in 1972, Congress, through ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/272"},"text":"Public Law 92–272","children":[],"tail":", authorized the Secretary of the Interior to add approximately 3.68 acres at Adams National Historic Site;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776f4b20-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eee/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in 1978, Congress, through ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625"},"text":"Public Law 95–625","children":[],"tail":", authorized the Secretary of the Interior to accept by conveyance the birthplaces of John Adams and John Quincy Adams, both in Quincy, Massachusetts, to be managed as part of the Adams National Historic Site;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776f4b21-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eee/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in 1980, Congress, through ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/435"},"text":"Public Law 96–435","children":[],"tail":", authorized the Secretary of the Interior to accept the conveyance of the United First Parish Church in Quincy, Massachusetts, the burial place of John Adams, Abigail Adams, and John Quincy Adams and his wife, to be administered as part of the Adams National Historic Site;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776f4b22-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eee/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actions taken by past Secretaries of the Interior and past Congresses to preserve for the benefit, education and inspiration of present and future generations of Americans the home, property, birthplaces and burial site of John Adams, John Quincy Adams, and Abigail Adams, have resulted in a multi-site unit of the National Park System with no overarching enabling or authorizing legislation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776f4b23-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eee/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that ","children":[{"tag":"ref","attrib":{"idref":"fn002163"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002163"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The word “that” probably should not appear."}],"tail":" the sites and resources associated with John Adams, second President of the United States, his wife Abigail Adams, and John Quincy Adams, sixth President of the United States, require recognition as a national historical park in the National Park System."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776f4b24-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eee/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this subchapter is to establish the Adams National Historical Park in the City of Quincy, in the Commonwealth of Massachusetts, to preserve, maintain and interpret the home, property, birthplaces, and burial site of John Adams and his wife Abigail, John Quincy Adams, and subsequent generations of the Adams family associated with the Adams property in Quincy, Massachusetts, for the benefit, education and inspiration of present and future generations of Americans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id776f4b25-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/342/s2"},"text":"Pub. L. 105–342, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-02"},"text":"Nov. 2, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3200"},"text":"112 Stat. 3200","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id776f4b26-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id776f4b27-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id776f4b28-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Historic Sites Act, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-21/ch593"},"text":"act Aug. 21, 1935, ch. 593","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/666"},"text":"49 Stat. 666","children":[],"tail":", also known as the Historic Sites Act of 1935 and as the Historic Sites, Buildings, and Antiquities Act, which enacted sections 461 to 467 of this title. The Act was repealed and restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1866/a"},"text":"section 1866(a) of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and sections 102303 and 102304 and chapter 3201 of Title 54, National Park Service and Related Programs, by "},{"tag":"ref","attrib":{"href":"/us/pl/113/287"},"text":"Pub. L. 113–287","children":[],"tail":", §§ 3, 4(a)(1), 7, "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3094"},"text":"128 Stat. 3094","children":[],"tail":", 3260, 3272. For complete classification of this Act to the Code, see Tables. For disposition of former sections of this title, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100101"},"text":"section 100101 of Title 54","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/272"},"text":"Public Law 92–272","children":[],"tail":", referred to in subsec. (a)(3), is "},{"tag":"ref","attrib":{"href":"/us/pl/92/272"},"text":"Pub. L. 92–272","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-04-11"},"text":"Apr. 11, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/120"},"text":"86 Stat. 120","children":[],"tail":". Provisions of "},{"tag":"ref","attrib":{"href":"/us/pl/92/272"},"text":"Pub. L. 92–272","children":[],"tail":" relating to Adams National Historic Site appear at "},{"tag":"ref","attrib":{"href":"/us/stat/86/121"},"text":"86 Stat. 121","children":[],"tail":" and are not classified to the Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625"},"text":"Public Law 95–625","children":[],"tail":", referred to in subsec. (a)(4), is "},{"tag":"ref","attrib":{"href":"/us/pl/95/625"},"text":"Pub. L. 95–625","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3467"},"text":"92 Stat. 3467","children":[],"tail":". Provisions of "},{"tag":"ref","attrib":{"href":"/us/pl/95/625"},"text":"Pub. L. 95–625","children":[],"tail":" relating to Adams National Historic Site appear at "},{"tag":"ref","attrib":{"href":"/us/stat/92/3479"},"text":"92 Stat. 3479","children":[],"tail":" and are not classified to the Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/435"},"text":"Public Law 96–435","children":[],"tail":", referred to in subsec. (a)(5), is "},{"tag":"ref","attrib":{"href":"/us/pl/96/435"},"text":"Pub. L. 96–435","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-10"},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1861"},"text":"94 Stat. 1861","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id776f4b29-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a)(1), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1866/a"},"text":"section 1866(a) of title 18","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s320102"},"text":"section 320102 of title 54","children":[],"tail":"” substituted for “section 2 of the Historic Sites Act of "},{"tag":"date","attrib":{"date":"1935-08-21"},"text":"August 21, 1935","children":[],"tail":"” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/113/287/s6/e"},"text":"Pub. L. 113–287, § 6(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3272"},"text":"128 Stat. 3272","children":[],"tail":", which Act enacted Title 54, National Park Service and Related Programs."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id776f4b2a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id776f4b2b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/342/s1"},"text":"Pub. L. 105–342, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-02"},"text":"Nov. 2, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3200"},"text":"112 Stat. 3200","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/342/s1"},"text":"“This Act [enacting this subchapter] may be cited as the ‘Adams National Historical Park Act of 1998’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
