{"tag":"section","attrib":{"id":"id77c50c94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460o"},"text":null,"children":[{"tag":"num","attrib":{"value":"460o"},"text":"§ 460o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In order to further the purposes of the joint resolution approved ","children":[{"tag":"date","attrib":{"date":"1961-09-27"},"text":"September 27, 1961","children":[],"tail":" (re Delaware River Basin compact; "},{"tag":"ref","attrib":{"href":"/us/stat/75/688"},"text":"75 Stat. 688","children":[],"tail":"), and to provide in a manner coordinated with the other purposes of the Tocks Island Reservoir project, for public outdoor recreation use and enjoyment of the proposed Tocks Island Reservoir and lands adjacent thereto by the people of the United States and for preservation of the scenic, scientific, and historic features contributing to public enjoyment of such lands and waters, the Secretary of the Interior is authorized, as herein provided, to establish and administer the Delaware Water Gap National Recreation Area, hereinafter referred to as the “area”, as part of the Tocks Island Reservoir project, hereinafter referred to as “the project”."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77c50c95-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/158/s1"},"text":"Pub. L. 89–158, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-09-01"},"text":"Sept. 1, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/612"},"text":"79 Stat. 612","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77c50c96-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77c50c97-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77c50c98-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The joint resolution approved ","children":[{"tag":"date","attrib":{"date":"1961-09-27"},"text":"September 27, 1961","children":[],"tail":", referred to in text, is "},{"tag":"ref","attrib":{"href":"/us/pl/87/328"},"text":"Pub. L. 87–328","children":[],"tail":", which was not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77c50c99-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77c50c9a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Joseph M. McDade Recreational Trail","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tI/s118"},"text":"Pub. L. 105–277, div. A, § 101(e) [title I, § 118]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–257, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/277/dA/s101/e/tI/s118"},"text":"“The 37 mile River Valley Trail from the town of Delaware Gap to the edge of the town of Milford, Pennsylvania located within the Delaware Water Gap National Recreation Area shall hereafter be referred to in any law, regulation, document, or record of the United States as the Joseph M. McDade Recreational Trail.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77c50c9b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Delaware Water Gap National Recreation Area Citizen Advisory Commission","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/573"},"text":"Pub. L. 100–573","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2890"},"text":"102 Stat. 2890","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/333/dI/tVIII/s814/d/1/K"},"text":"Pub. L. 104–333, div. I, title VIII, § 814(d)(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-11-12"},"text":"Nov. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4196"},"text":"110 Stat. 4196","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/355/tV/s507"},"text":"Pub. L. 105–355, title V, § 507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-06"},"text":"Nov. 6, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3264"},"text":"112 Stat. 3264","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/176/tIII/s301"},"text":"Pub. L. 106–176, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-03-10"},"text":"Mar. 10, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/31"},"text":"114 Stat. 31","children":[],"tail":", established Delaware Water Gap National Recreation Area Citizen Advisory Commission to advise Secretary of the Interior on management and operation of Delaware Water Gap National Recreation Area, and other matters affecting the recreation area and surrounding communities, and terminated Commission on the date that is 20 years after "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
