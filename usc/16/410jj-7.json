{"tag":"section","attrib":{"id":"id7759c798-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jj–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"410jj–7"},"text":"§ 410jj–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7759c799-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jj–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is hereby established the Kalaupapa National Historical Park Advisory Commission (hereinafter referred to as the “Commission”), which shall consist of eleven members each appointed by the Secretary for a term of five years as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7759c79a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jj–7/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seven members who shall be present or former patients, elected by the patient community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7759c79b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jj–7/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" four members appointed from recommendations submitted by the Governor of Hawaii, at least one of whom shall be a Native Hawaiian.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7759c79c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jj–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairman; vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall designate one member to be Chairman. Any vacancy in the Commission shall be filled in the same manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7759c79d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jj–7/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation; expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Commission shall serve without compensation as such. The Secretary is authorized to pay the expenses reasonably incurred by the Commission in carrying out its responsibilities under this Act on vouchers signed by the Chairman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7759c79e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jj–7/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consult with and seek the advice of the Commission with respect to the development and operation of the park including training programs. The Commission shall, in addition, advise the Secretary concerning public visitation to the park, and such advice with respect to numbers of visitors shall be binding upon the Secretary if the Commission certifies to him that such advice is based on a referendum, held under the auspices of the Commission, of all patients on the official Kalaupapa Registry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7759c79f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jj–7/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall expire on the date that is 45 years after ","children":[{"tag":"date","attrib":{"date":"1980-12-22"},"text":"December 22, 1980","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7759c7a0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/565/tI/s108"},"text":"Pub. L. 96–565, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3323"},"text":"94 Stat. 3323","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/54/tI/s128"},"text":"Pub. L. 109–54, title I, § 128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-02"},"text":"Aug. 2, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/525"},"text":"119 Stat. 525","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7759c7a1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7759c7a2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7759c7a3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/565"},"text":"Pub. L. 96–565","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3321"},"text":"94 Stat. 3321","children":[],"tail":", which enacted this subchapter and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2991a"},"text":"section 2991a of Title 42","children":[],"tail":", The Public Health and Welfare. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7759c7a4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/54"},"text":"Pub. L. 109–54","children":[],"tail":" substituted “on the date that is 45 years after” for “twenty-five years from”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
