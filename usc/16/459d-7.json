{"tag":"section","attrib":{"id":"id77ad3eab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459d–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"459d–7"},"text":"§ 459d–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out the provisions of sections 459d to 459d–7 of this title; except that no more than $5,350,000 shall be appropriated for the acquisition of land and waters and improvements thereon, and interests therein, and incidental costs relating thereto, in accordance with the provisions of such sections.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77ad3eac-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/712/s8"},"text":"Pub. L. 87–712, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-28"},"text":"Sept. 28, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/652"},"text":"76 Stat. 652","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/578/tI/s101/13"},"text":"Pub. L. 94–578, title I, § 101(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2733"},"text":"90 Stat. 2733","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77ad3ead-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77ad3eae-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77ad3eaf-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/578/s101/13"},"text":"Section 101(13) of Pub. L. 94–578","children":[],"tail":", cited as a credit to this section, as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/96/199/tI/s111"},"text":"Pub. L. 96–199, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-05"},"text":"Mar. 5, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/70"},"text":"94 Stat. 70","children":[],"tail":", is also set out in part as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s459d–1"},"text":"section 459d–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77ad3eb0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/578"},"text":"Pub. L. 94–578","children":[],"tail":" substituted “$5,350,000” for “$5,000,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
