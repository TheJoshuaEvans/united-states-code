{"tag":"section","attrib":{"id":"id7a2eba04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7914"},"text":null,"children":[{"tag":"num","attrib":{"value":"7914"},"text":"§ 7914.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shooting ranges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a2eba05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7914/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), the Secretary concerned may, in accordance with this section and other applicable law, lease or permit the use of Federal land for a shooting range.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2eba06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7914/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned shall not lease or permit the use of Federal land for a shooting range within—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2eba07-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7914/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a component of the National Landscape Conservation System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eba08-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7914/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a component of the National Wilderness Preservation System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eba09-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7914/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any area that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2eba0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7914/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designated as a wilderness study area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2eba0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7914/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" administratively classified as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2eba0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7914/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wilderness-eligible; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2eba0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7914/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wilderness-suitable; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2eba0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7914/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a primitive or semiprimitive area;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eba0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7914/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national monument, national volcanic monument, or national scenic area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eba10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7914/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a component of the National Wild and Scenic Rivers System (including areas designated for study for potential addition to the National Wild and Scenic Rivers System).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a2eba11-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tIV/s4104"},"text":"Pub. L. 116–9, title IV, § 4104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/759"},"text":"133 Stat. 759","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
