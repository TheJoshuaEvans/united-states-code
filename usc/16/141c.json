{"tag":"section","attrib":{"id":"id7708c13f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s141c"},"text":null,"children":[{"tag":"num","attrib":{"value":"141c"},"text":"§ 141c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal of surplus buffalo and elk","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7708c140-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s141c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Interior is authorized, in his discretion and under regulations to be prescribed by him, to sell or otherwise dispose of the surplus buffalo and elk of the Wind Cave National Park herd.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7708c141-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s141c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All moneys received from the sale of any such surplus animals, or products thereof, shall be deposited in the Treasury of the United States as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7708c142-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-16/ch459"},"text":"June 16, 1938, ch. 459","children":[],"tail":", §§ 1, 2, "},{"tag":"ref","attrib":{"href":"/us/stat/52/708"},"text":"52 Stat. 708","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7708c143-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7708c144-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7708c145-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a) and (b) of this section constitute sections 1 and 2, respectively, of act ","children":[{"tag":"date","attrib":{"date":"1938-06-16"},"text":"June 16, 1938","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
