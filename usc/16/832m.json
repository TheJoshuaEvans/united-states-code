{"tag":"section","attrib":{"id":"id78bf7274-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s832m"},"text":null,"children":[{"tag":"num","attrib":{"value":"832m"},"text":"§ 832m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of excess Federal power; fish and wildlife conservation within Federal Columbia River Power System; residential exchange; personnel flexibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78bf7275-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s832m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78bf7276-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s832m/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Bonneville Power Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78bf7277-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s832m/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Council” means the Northwest Power and Conservation Planning Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78bf7278-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s832m/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess Federal power","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “excess Federal power” means such electric power that has become surplus to the firm contractual obligations of the Administrator under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s839c/f"},"text":"section 839c(f) of this title","children":[],"tail":" due to either—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78bf7279-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s832m/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reduction in the quantity of electric power that the Administrator is contractually required to supply under subsections (b) and (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s839c"},"text":"section 839c of this title","children":[],"tail":", due to the election by customers of the Bonneville Power Administration to purchase electric power from other suppliers, as compared to the quantity of electric power that the Administrator was contractually required to supply as of "},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"January 1, 1995","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78bf727a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s832m/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those operations of the Federal Columbia River Power System that are primarily for the benefit of fish and wildlife affected by the development, operation, or management of the System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78bf727b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s832m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of excess Federal power","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s837a"},"text":"section 837a of this title","children":[],"tail":", subsections (a), (b), and (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s837b"},"text":"section 837b of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s837f"},"text":"section 837f of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s839f/c"},"text":"section 839f(c) of this title","children":[],"tail":", the Administrator may, as permitted by otherwise applicable law, sell or otherwise dispose of excess Federal power—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id78bf727c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s832m/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outside the Pacific Northwest on a firm basis for a contract term of not to exceed 7 years, if the excess Federal power is first offered for a reasonable period of time and under the same essential rate, terms and conditions to those Pacific Northwest public body, cooperative and investor-owned utilities and those direct service industrial customers identified in subsection (b) or (d)(1)(A) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s839c"},"text":"section 839c of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78bf727d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s832m/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any region without the prohibition on resale established by the second sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s832d/a"},"text":"section 832d(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78bf727e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s832m/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study by Council","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78bf727f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s832m/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002550"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002550"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No par. (2) has been enacted."}],"tail":" Within 180 days of "},{"tag":"date","attrib":{"date":"1995-11-13"},"text":"November 13, 1995","children":[],"tail":", the Council shall review and report to Congress regarding the most appropriate governance structure to allow more effective regional control over efforts to conserve and enhance anadromous and resident fish and wildlife within the Federal Columbia River Power System."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78bf7280-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s832m/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corps of Engineers procurement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary of the Army for Civil Works, acting through the North Pacific Division of the Corps of Engineers, is authorized to place orders for goods and services related to facilities for electric power generation and fish and wildlife mitigation associated with the Federal Columbia River Power System with and through the Administrator using the authorities available to the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78bf7281-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s832m/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Residential exchange","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the establishment, confirmation and approval of rates pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s839e"},"text":"section 839e of this title","children":[],"tail":", and notwithstanding the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s839c/c"},"text":"section 839c(c) of this title","children":[],"tail":", the cost benefits of eligible utilities’ total purchase and exchange sales under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s839c/c/1"},"text":"section 839c(c)(1) of this title","children":[],"tail":" shall be $145,000,000 for fiscal year 1997, and the net benefits paid to each eligible electric utility shall be $145,000,000 multiplied by the percentage of the total of such net benefits paid by the Administrator to such utility for fiscal year 1995."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78bf7282-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s832m/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel flexibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may offer employees voluntary separation incentives as deemed necessary which shall not exceed $25,000. Recipients who accept employment with the United States within five years after separation shall repay the entire amount to the Bonneville Power Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78bf7283-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s832m/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless superseded by an Act of Congress, the authority provided by this section is expressly intended to extend beyond the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78bf7284-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/46/tV/s508"},"text":"Pub. L. 104–46, title V, § 508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-13"},"text":"Nov. 13, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/419"},"text":"109 Stat. 419","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78bf7285-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78bf7286-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78bf7287-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy and Water Development Appropriations Act, 1996, and not as part of the Bonneville Project Act of 1937 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78bf7288-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78bf7289-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Voluntary Separation Incentives to Employees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/206/tV/s511"},"text":"Pub. L. 104–206, title V, § 511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3004"},"text":"110 Stat. 3004","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/106/377/s1/a/2/tIII"},"text":"Pub. L. 106–377, § 1(a)(2) [title III]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-27"},"text":"Oct. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1441"},"text":"114 Stat. 1441","children":[],"tail":", 1441A–76, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/377/s1/a/2/tIII"},"text":"“The Administrator may offer employees voluntary separation incentives as deemed necessary which shall not exceed $25,000. Recipients who accept employment with the United States within five years after separation shall repay the entire amount to the Bonneville Power Administration. This authority shall expire ","children":[{"tag":"date","attrib":{"date":"2003-01-01"},"text":"January 1, 2003","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
