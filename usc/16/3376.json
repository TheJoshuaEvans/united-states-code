{"tag":"section","attrib":{"id":"id79b9d733-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3376"},"text":null,"children":[{"tag":"num","attrib":{"value":"3376"},"text":"§ 3376.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79b9d734-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3376/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b9d735-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3376/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, after consultation with the Secretary of the Treasury, is authorized to issue such regulations, except as provided in paragraph (2), as may be necessary to carry out the provisions of sections 3372(f), 3373, and 3374 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d736-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3376/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretaries of the Interior and Commerce shall jointly promulgate specific regulations to implement the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3372/b"},"text":"section 3372(b) of this title","children":[],"tail":" for the marking and labeling of containers or packages containing fish or wildlife. These regulations shall be in accordance with existing commercial practices."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d737-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3376/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, in consultation with other relevant Federal and State agencies, promulgate any regulations necessary to implement ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3372/e"},"text":"section 3372(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b9d738-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3376/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning in fiscal year 1983, to the extent and in the amounts provided in advance in appropriations Acts, the Secretary may enter into such contracts, leases, cooperative agreements, or other transactions with any Federal or State agency, Indian tribe, public or private institution, or other person, as may be necessary to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b9d739-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3376/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification of exclusions from definition of plant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture and the Secretary of the Interior, after consultation with the appropriate agencies, shall jointly promulgate regulations to define the terms used in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3371/g/2/A"},"text":"section 3371(g)(2)(A) of this title","children":[],"tail":" for the purposes of enforcement under this chapter."}],"tail":"\n"}],"tail":"\n"}],"ta