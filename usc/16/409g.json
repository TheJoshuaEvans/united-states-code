{"tag":"section","attrib":{"id":"id7744434d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s409g"},"text":null,"children":[{"tag":"num","attrib":{"value":"409g"},"text":"§ 409g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In order to preserve for the benefit and inspiration of the public certain lands historically associated with the winter encampment of General George Washington’s Continental Army at Jockey Hollow in 1779 and 1780, and to facilitate the administration and interpretation of the Morristown National Historical Park, the Secretary of the Interior is authorized to procure, from a willing owner only, by purchase, donation, purchase with appropriated funds, or otherwise, not to exceed 715 acres of land and interests therein which 715 acres shall include Stark’s Brigade campsite and other lands necessary for the proper administration and interpretation of the Morristown National Historical Park: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That title to the property known as the Cross estate may not be accepted until the property is vacant."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7744434e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/601/s1"},"text":"Pub. L. 88–601, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-09-18"},"text":"Sept. 18, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/957"},"text":"78 Stat. 957","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/477/tIII/s301/6"},"text":"Pub. L. 93–477, title III, § 301(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-26"},"text":"Oct. 26, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1447"},"text":"88 Stat. 1447","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/578/tIII/s315"},"text":"Pub. L. 94–578, title III, § 315","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2737"},"text":"90 Stat. 2737","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/118/s1"},"text":"Pub. L. 102–118, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-04"},"text":"Oct. 4, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/586"},"text":"105 Stat. 586","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dG/tI/s119"},"text":"Pub. L. 115–141, div. G, title I, § 119","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/661"},"text":"132 Stat. 661","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7744434f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77444350-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77444351-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as a part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-03-02/ch182"},"text":"act Mar. 2, 1933, ch. 182","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/1421"},"text":"47 Stat. 1421","children":[],"tail":", which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77444352-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" inserted “, from a willing owner only,” after “the Secretary of the Interior is authorized to procure” and substituted “715 acres” for “615 acres” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/118"},"text":"Pub. L. 102–118","children":[],"tail":" substituted “615 acres” for “600 acres” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/578"},"text":"Pub. L. 94–578","children":[],"tail":" substituted “600 acres” for “465 acres” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/477"},"text":"Pub. L. 93–477","children":[],"tail":" substituted “465 acres” for “two hundred and eighty-one acres” in two places and inserted proviso relating to property known as the Cross estate."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77444353-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77444354-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authorization of Appropriations for Additional Lands","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/88/601/s3"},"text":"Section 3 of Pub. L. 88–601","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/93/477/tI/s101/8"},"text":"Pub. L. 93–477, title I, § 101(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-26"},"text":"Oct. 26, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1445"},"text":"88 Stat. 1445","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/93/477/tI/s101/8"},"text":"“There are authorized to be appropriated such sums, but not more than $2,111,000 for acquisition of lands and interests in land, as may be necessary to carry out the purposes of this Act [sections 409g and 409h of this title].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
