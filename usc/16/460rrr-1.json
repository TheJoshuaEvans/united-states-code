{"tag":"section","attrib":{"id":"id7807e1c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"460rrr–1"},"text":"§ 460rrr–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Rio Grande Natural Area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7807e1c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the Rio Grande Natural Area in the State of Colorado to conserve, restore, and protect the natural, historic, cultural, scientific, scenic, wildlife, and recreational resources of the Natural Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7807e1c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Natural Area shall include the Rio Grande River from the southern boundary of the Alamosa National Wildlife Refuge to the New Mexico State border, extending ¼ mile on either side of the bank of the River.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7807e1c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map and legal description","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7807e1c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2006-10-12"},"text":"October 12, 2006","children":[],"tail":", the Secretary shall prepare a map and legal description of the Natural Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e1c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map and legal description of the Natural Area shall have the same force and effect as if included in this subchapter, except that the Secretary may correct any minor errors in the map and legal description.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e1c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map and legal description of the Natural Area shall be available for public inspection in the appropriate offices of the Bureau of Land Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7807e1c8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/337/s3"},"text":"Pub. L. 109–337, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-12"},"text":"Oct. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1777"},"text":"120 Stat. 1777","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
