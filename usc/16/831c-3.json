{"tag":"section","attrib":{"id":"id78b845cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831c–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"831c–3"},"text":"§ 831c–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78b845d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831c–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of law enforcement agents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may designate employees of the corporation to act as law enforcement agents in the area of jurisdiction described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b845d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831c–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties and powers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78b845d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831c–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A law enforcement agent designated under subsection (a) shall maintain law and order and protect persons and property in the area of jurisdiction described in subsection (c) and protect property and officials and employees of the corporation outside that area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b845d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831c–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the performance of duties described in paragraph (1), a law enforcement agent designated under subsection (a) may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78b845d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831c–3/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make arrests without warrant for any offense against the United States committed in the agent’s presence, or for any felony cognizable under the laws of the United States if the agent has probable cause to believe that the person to be arrested has committed or is committing such a felony;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78b845d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831c–3/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" execute any warrant or other process issued by a court or officer of competent jurisdiction for the enforcement of any Federal law or regulation issued pursuant to law in connection with the investigation of an offense described in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78b845d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831c–3/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct an investigation of an offense described in subparagraph (A) in the absence of investigation of the offense by any Federal law enforcement agency having investigative jurisdiction over the offense or with the concurrence of that agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78b845d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831c–3/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry firearms in carrying out any activity described in subparagraph (A), (B), or (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b845d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831c–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area of jurisdiction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A law enforcement agent designated under subsection (a) shall be authorized to exercise the law enforcement duties and powers described in subsection (b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78b845d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831c–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on any lands or facilities owned or leased by the corporation or within such adjoining areas in the vicinities of such lands or facilities as may be determined by the Board under subsection (e); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b845da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831c–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" on other lands or facilities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78b845db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831c–3/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when the person to be arrested is in the process of fleeing from such lands, facilities, or adjoining areas to avoid arrest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78b845dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831c–3/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in conjunction with the protection of property or officials or employees of the corporation on or within lands or facilities other than those owned or leased by the corporation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78b845dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831c–3/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cooperation with other Federal, State, or local law enforcement agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b845de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831c–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal investigative jurisdiction and State civil and criminal jurisdiction not preempted","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78b845df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831c–3/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit or restrict the investigative jurisdiction of any Federal law enforcement agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b845e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831c–3/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affect any right of a State or a political subdivision thereof to exercise civil and criminal jurisdiction on or within lands or facilities owned or leased by the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b845e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831c–3/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of adjoining areas","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78b845e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831c–3/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall determine and may from time-to-time modify the adjoining areas for each facility or particular area of land, or for individual categories of such facilities or lands, for the purposes of subsection (c)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b845e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831c–3/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A notice and description of each adjoining area determination or modification of a determination made under paragraph (1) shall be published in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b845e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831c–3/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications and training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board, in consultation with the Attorney General, shall adopt qualification and training standards for law enforcement agents designated under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b845e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831c–3/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to other law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A law enforcement agent designated under subsection (a) shall not be considered to be a law enforcement officer of the United States for the purposes of any other law, and no law enforcement agent designated under subsection (a) or other employee of the corporation shall receive an increase in compensation solely on account of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b845e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831c–3/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship with Attorney General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The duties and powers of law enforcement agents designated under subsection (a) that are described in subsection (b) shall be exercised in accordance with guidelines approved by the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78b845e7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-18/ch32/s4A"},"text":"May 18, 1933, ch. 32, § 4A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXII/s320929"},"text":"Pub. L. 103–322, title XXXII, § 320929","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2133"},"text":"108 Stat. 2133","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/dC/tVI/s603/a/2"},"text":"Pub. L. 108–447, div. C, title VI, § 603(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2966"},"text":"118 Stat. 2966","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78b845e8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78b845e9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78b845ea-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsecs. (c)(1), (e)(1), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447"},"text":"Pub. L. 108–447","children":[],"tail":" substituted “Board” for “board”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78b845eb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id78b845ec-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447"},"text":"Pub. L. 108–447","children":[],"tail":" effective on the later of the date on which at least three persons nominated under "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/s604/a"},"text":"section 604(a) of Pub. L. 108–447","children":[],"tail":" take office or "},{"tag":"date","attrib":{"date":"2005-05-18"},"text":"May 18, 2005","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/s604/b"},"text":"section 604(b) of Pub. L. 108–447","children":[],"tail":", set out in an Appointments; Effective Date; Transition note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s831a"},"text":"section 831a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
