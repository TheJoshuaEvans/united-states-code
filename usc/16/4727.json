{"tag":"section","attrib":{"id":"id79f581a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4727"},"text":null,"children":[{"tag":"num","attrib":{"value":"4727"},"text":"§ 4727.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intentional introductions policy review","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Within one year of ","children":[{"tag":"date","attrib":{"date":"1990-11-29"},"text":"November 29, 1990","children":[],"tail":", the Task Force shall, in consultation with State fish and wildlife agencies, other regional, State and local entities, potentially affected industries and other interested parties, identify and evaluate approaches for reducing the risk of adverse consequences associated with intentional introduction of aquatic organisms and submit a report of their findings, conclusions and recommendations to the Congress."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79f581a6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/646/tI/s1207"},"text":"Pub. L. 101–646, title I, § 1207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4771"},"text":"104 Stat. 4771","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/g"},"text":"Pub. L. 104–332, § 2(g)","children":[],"tail":", (h)(1), "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4091"},"text":"110 Stat. 4091","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79f581a7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79f581a8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79f581a9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/h/1"},"text":"Pub. L. 104–332, § 2(h)(1)","children":[],"tail":", made technical amendment to "},{"tag":"ref","attrib":{"href":"/us/pl/101/646/s1207"},"text":"Pub. L. 101–646, § 1207","children":[],"tail":", which enacted this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/g"},"text":"Pub. L. 104–332, § 2(g)","children":[],"tail":", substituted “Congress” for “appropriate Committees”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
