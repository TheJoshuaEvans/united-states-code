{"tag":"section","attrib":{"id":"id77afaf36-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459f–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"459f–10"},"text":"§ 459f–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated the sum of not more than $22,400,000 (including such sums, together with interest, as may be necessary to satisfy final judgments rendered against the United States) for the acquisition of lands and interests in land and such sums as may be necessary for the development of the area authorized under sections 459f to 459f–11 of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77afaf37-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/195/s11"},"text":"Pub. L. 89–195, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-09-21"},"text":"Sept. 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/827"},"text":"79 Stat. 827","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/272/tI/s101/1"},"text":"Pub. L. 92–272, title I, § 101(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-04-11"},"text":"Apr. 11, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/120"},"text":"86 Stat. 120","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/578/tI/s101/2"},"text":"Pub. L. 94–578, title I, § 101(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2732"},"text":"90 Stat. 2732","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77afaf38-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77afaf39-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77afaf3a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/578"},"text":"Pub. L. 94–578","children":[],"tail":" substituted “$22,400,000” for “$21,050,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/272"},"text":"Pub. L. 92–272","children":[],"tail":" substituted “$21,050,000 (including such sums, together with interest, as may be necessary to satisfy final judgments rendered against the United States)” for “$16,250,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
