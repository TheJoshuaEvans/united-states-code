{"tag":"section","attrib":{"id":"id774de017-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aa–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"410aa–3"},"text":"§ 410aa–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id774de018-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aa–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are hereby authorized to be appropriated such sums as may be necessary to carry out the purposes of this subchapter, but not more than $13,895,000 for the acquisition of lands and interests in lands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id774de019-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aa–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the development of essential public facilities there are authorized to be appropriated not more than $500,000. Within three years from the date of establishment of the park pursuant to this subchapter, the Secretary shall, after consulting with the Governor of the Commonwealth of Pennsylvania, develop and transmit to the Committee on Energy and Natural Resources of the Senate and the Committee on Natural Resources of the House of Representatives a final master plan for the development of the park consistent with the objectives of this subchapter, indicating:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id774de01a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aa–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the facilities needed to accommodate the health, safety, and interpretive needs of the visiting public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id774de01b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aa–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location and estimated cost of all facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id774de01c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aa–3/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the projected need for any additional facilities within the park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id774de01d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/337/s4"},"text":"Pub. L. 94–337, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-04"},"text":"July 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/797"},"text":"90 Stat. 797","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/287/tIII/s301/3"},"text":"Pub. L. 96–287, title III, § 301(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-28"},"text":"June 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/601"},"text":"94 Stat. 601","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/437/s6/a/3"},"text":"Pub. L. 103–437, § 6(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4583"},"text":"108 Stat. 4583","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id774de01e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"cros