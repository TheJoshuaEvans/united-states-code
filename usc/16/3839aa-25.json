{"tag":"section","attrib":{"id":"id79d687a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25"},"text":null,"children":[{"tag":"num","attrib":{"value":"3839aa–25"},"text":"§ 3839aa–25.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grassland conservation initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79d687a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d687a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding sections 3839aa–21(4) and 3839aa–22(b)(2) of this title, the term “eligible land” means cropland on a farm for which base acres have been maintained by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9012/d/3"},"text":"section 9012(d)(3) of title 7","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d687aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initiative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “initiative” means the grassland conservation initiative established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d687ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish within the program a grassland conservation initiative for the purpose of assisting producers in protecting grazing uses, conserving and improving soil, water, and wildlife resources, and achieving related conservation values by conserving eligible land through grassland conservation contracts under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d687ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning in fiscal year 2019, the Secretary shall provide a 1-time election to enroll eligible land in the initiative under a contract described in subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d687ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of enrollment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d687ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3839aa–23"},"text":"section 3839aa–23 of this title","children":[],"tail":", determine under subsection (c) of that section that eligible land ranks sufficiently high under the evaluation criteria described in subsection (b) of that section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d687af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enroll the eligible land in the initiative under a contract described in subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d687b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grassland conservation contract","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d687b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3839aa–23/a/1"},"text":"section 3839aa–23(a)(1) of this title","children":[],"tail":", to enroll eligible land in the initiative under a grassland conservation contract, a producer shall agree—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d687b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to meet or exceed the stewardship threshold for not less than 1 priority resource concern by the date on which the contract expires; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d687b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to comply with the terms and conditions of the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d687b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grassland conservation contract entered into under this section shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d687b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d687b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be for a single 5-year term; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d687b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not be subject to renewal or reenrollment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3839aa–23/e"},"text":"section 3839aa–23(e) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d687b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3839aa–23/d"},"text":"section 3839aa–23(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d687b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early termination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall allow a producer that enters into a grassland conservation contract under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d687ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to terminate the contract at any time; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d687bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to retain payments already received under the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d687bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grassland conservation plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The grassland conservation plan developed for eligible land shall be limited to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d687bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d687be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resource concerns and activities relating to grassland.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d687bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d687c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning in fiscal year 2019, of the funds made available for this subpart under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3841/a/3/B"},"text":"section 3841(a)(3)(B) of this title","children":[],"tail":", and notwithstanding any payment under title I of the Agriculture Improvement Act of 2018, an amendment made by that title, or "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3839aa–24/c"},"text":"section 3839aa–24(c) of this title","children":[],"tail":", the Secretary shall make annual grassland conservation contract payments to the producer of any eligible land that is the subject of a grassland conservation contract under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d687c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment noneligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grassland conservation contract under this section shall not be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d687c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible for payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3839aa–24/d"},"text":"section 3839aa–24(d) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d687c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the payment limitations under this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d687c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of an annual payment under this subsection shall be $18 per acre, not to exceed the number of base acres on a farm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d687c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considered planted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consider land enrolled under a grassland conservation contract under this section during a crop year to be planted or considered planted to a covered commodity (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9011"},"text":"section 9011 of title 7","children":[],"tail":") during that crop year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d687c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other contracts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A producer with an agricultural operation that contains land eligible under this section and land eligible under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3839aa–23"},"text":"section 3839aa–23 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d687c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may enroll the land eligible under this section through a contract under this section or under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3839aa–23"},"text":"section 3839aa–23 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d687c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–25/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be prohibited from enrolling the land eligible under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3839aa–23"},"text":"section 3839aa–23 of this title","children":[],"tail":" through a contract under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3839aa–23"},"text":"section 3839aa–23 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79d687c9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1240L–1"},"text":"Pub. L. 99–198, title XII, § 1240L–1","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII/s2309"},"text":"Pub. L. 115–334, title II, § 2309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4569"},"text":"132 Stat. 4569","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79d687ca-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79d687cb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79d687cc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Agriculture Improvement Act of 2018, referred to in subsec. (g)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","c