{"tag":"section","attrib":{"id":"id77e4059d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460mm"},"text":null,"children":[{"tag":"num","attrib":{"value":"460mm"},"text":"§ 460mm.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of conservation area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77e4059e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460mm/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to provide for the immediate and future protection of the lands in Federal ownership within the framework of a program of multiple use and sustained yield and for the maintenance of environmental quality, the Steese National Conservation Area is hereby established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e4059f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460mm/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundaries; special values","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Steese National Conservation Area shall include approximately one million two hundred twenty thousand acres of public lands, as generally depicted on the map entitled “Steese National Conservation Area—proposed”, and dated October 1978. Special values to be considered in planning and management of the area are: caribou range and Birch Creek.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77e405a0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/487/tIV/s401"},"text":"Pub. L. 96–487, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-02"},"text":"Dec. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2396"},"text":"94 Stat. 2396","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
