{"tag":"section","attrib":{"id":"id79ebe44d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4265a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4265a"},"text":"§ 4265a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory group","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79ebe44e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4265a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To assist in carrying out this chapter, the Secretary may convene an advisory group consisting of individuals representing public and private organizations actively involved in the conservation of Asian elephants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ebe44f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4265a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public participation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ebe450-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4265a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Group ","children":[{"tag":"ref","attrib":{"idref":"fn002789"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002789"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79ebe451-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4265a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that each meeting of the advisory group is open to the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ebe452-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4265a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide, at each meeting, an opportunity for interested persons to present oral or written statements concerning items on the agenda.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe453-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4265a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide to the public timely notice of each meeting of the advisory group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe454-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4265a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minutes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Minutes of each meeting of the advisory group shall be kept by the Secretary and shall be made available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ebe455-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4265a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 shall not apply to the advisory group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79ebe456-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/96/s7"},"text":"Pub. L. 105–96, § 7","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/141/s4"},"text":"Pub. L. 107–141, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-02-12"},"text":"Feb. 12, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/13"},"text":"116 Stat. 13","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/121"},"text":"Pub. L. 117–286, § 4(a)(121)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4319"},"text":"136 Stat. 4319","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79ebe457-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79ebe458-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id79ebe459-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/96/s7"},"text":"section 7 of Pub. L. 105–96","children":[],"tail":" was renumbered section 8 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4266"},"text":"section 4266 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79ebe45a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5” for “Federal Advisory Committee Act” in heading and “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 U.S.C. App.)” in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
