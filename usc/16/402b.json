{"tag":"section","attrib":{"id":"id77385d2e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s402b"},"text":null,"children":[{"tag":"num","attrib":{"value":"402b"},"text":"§ 402b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additions to park","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The east half east half section 25, township 36 south, range 4 west; the east half and southwest quarter section 20, and all of sections 21, 29, and 30, township 36 south, range 3 west; all of sections 24 and 25, township 37 south, range 4 west; and all of sections 19 and 30, township 37 south, range 3 west, Salt Lake meridian, are excluded from the Powell National Forest and made a part of the Bryce Canyon National Park, subject to the provisions of sections 346, 401, and 402 of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77385d2f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1928-02-25/ch102/s2"},"text":"Feb. 25, 1928, ch. 102, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/147"},"text":"45 Stat. 147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1928-05-12/ch533/s2"},"text":"May 12, 1928, ch. 533, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/502"},"text":"45 Stat. 502","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77385d30-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77385d31-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77385d32-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1928—Act ","children":[{"tag":"date","attrib":{"date":"1928-05-12"},"text":"May 12, 1928","children":[],"tail":", corrected description of land in section 20 by inserting “and” between “east half” and “southwest quarter”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
