{"tag":"section","attrib":{"id":"id79e4b7ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3931"},"text":null,"children":[{"tag":"num","attrib":{"value":"3931"},"text":"§ 3931.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National wetlands inventory project","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79e4b7f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3931/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Director of the United States Fish and Wildlife Service, shall continue the National Wetlands Inventory Project and shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e4b7f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3931/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" produce, by ","children":[{"tag":"date","attrib":{"date":"1988-09-30"},"text":"September 30, 1988","children":[],"tail":", National Wetlands Inventory maps for the areas that have been identified by the Service as top priorities for mapping, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e4b7f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3931/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entire coastal zone of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e4b7f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3931/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" floodplains of major rivers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e4b7f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3931/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Prairie Pothole region;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e4b7f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3931/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produce, by ","children":[{"tag":"date","attrib":{"date":"1998-09-30"},"text":"September 30, 1998","children":[],"tail":", National Wetlands Inventory maps for those portions of the contiguous United States for which final maps have not been produced earlier;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e4b7f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3931/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produce, by ","children":[{"tag":"date","attrib":{"date":"2000-09-30"},"text":"September 30, 2000","children":[],"tail":", National Wetlands Inventory maps for Alaska and other noncontiguous portions of the United States;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e4b7f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3931/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produce, by ","children":[{"tag":"date","attrib":{"date":"1990-09-30"},"text":"September 30, 1990","children":[],"tail":", and at ten-year intervals thereafter, reports to update and improve the information contained in the report dated September 1982 and entitled “Status and Trends of Wetlands and Deepwater Habitat in the Coterminous United States, 1950’s to 1970’s”;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e4b7f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3931/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" produce, by ","children":[{"tag":"date","attrib":{"date":"1990-04-30"},"text":"April 30, 1990","children":[],"tail":", a report that provides—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e4b7f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3931/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the estimated total number of acres of wetland habitat as of the 1780’s in the areas that now comprise each State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e4b7fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3931/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the estimated total number of acres of wetlands in each State as of the 1980’s, and the percentage of loss of wetlands in each State between the 1780’s and the 1980’s;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e4b7fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3931/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produce, by ","children":[{"tag":"date","attrib":{"date":"2004-09-30"},"text":"September 30, 2004","children":[],"tail":", a digital wetlands data base for the United States based on the final wetlands maps produced under this section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e4b7fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3931/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" archive and make available for dissemination wetlands data and maps digitized under this section as such data and maps become available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e4b7fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3931/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall notify the appropriate State and local units of government at such time as he proposes to begin map preparation under subsection (a) in an area. Such notice shall include, but is not limited to, the identification of the area to be mapped, the proposed schedule for completion, and the identification of a source for further information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79e4b7fe-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/645/tIV/s401"},"text":"Pub. L. 99–645, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3588"},"text":"100 Stat. 3588","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/233/s18"},"text":"Pub. L. 101–233, § 18","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-13"},"text":"Dec. 13, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1978"},"text":"103 Stat. 1978","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/440/tIII/s305"},"text":"Pub. L. 102–440, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2235"},"text":"106 Stat. 2235","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79e4b7ff-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79e4b800-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79e4b801-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/440/s305/1"},"text":"Pub. L. 102–440, § 305(1)","children":[],"tail":", substituted “by "},{"tag":"date","attrib":{"date":"2000-09-30"},"text":"September 30, 2000","children":[],"tail":"” for “as soon as practicable”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/440/s305/2"},"text":"Pub. L. 102–440, § 305(2)","children":[],"tail":", which directed amendment of par. (4) by substituting a semicolon for “. And”, was executed by making the substitution for “. and”, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/440/s305/3"},"text":"Pub. L. 102–440, § 305(3)","children":[],"tail":", (4), added pars. (6) and (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/233"},"text":"Pub. L. 101–233","children":[],"tail":" added par. (5)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
