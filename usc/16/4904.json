{"tag":"section","attrib":{"id":"id79f7cb75-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4904"},"text":null,"children":[{"tag":"num","attrib":{"value":"4904"},"text":"§ 4904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Moratoria on imports of exotic birds covered by Convention","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79f7cb76-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immediate moratorium","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f7cb77-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4904/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of moratorium","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The importation of any exotic bird of a species identified as a category B species in the report entitled “Report of the Animals Committee”, adopted by the 8th meeting of the Conference of the Parties to the Convention, is prohibited.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cb78-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4904/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of moratorium","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A species of exotic birds shall be subject to the prohibition on importation established by paragraph (1) until the Secretary, after notice and an opportunity for public comment—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f7cb79-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4904/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that appropriate remedial measures have been taken in the countries of origin for that species, so as to eliminate the threat of trade to the conservation of the species; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f7cb7a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4904/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes the findings described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4905/c"},"text":"section 4905(c) of this title","children":[],"tail":" for the species and includes the species in the list published under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4905/a"},"text":"section 4905(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f7cb7b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency authority to suspend imports of listed species","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f7cb7c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4904/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to suspend imports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to suspend the importation of exotic birds of any species that is listed in any Appendix to the Convention, and if applicable remove the species from the list under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4905/a"},"text":"section 4905(a) of this title","children":[],"tail":", if the Secretary determines that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f7cb7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4904/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f7cb7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4904/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trade in that species is detrimental to the species,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f7cb7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4904/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is not sufficient information available on which to base a judgment that the species is not detrimentally affected by trade in that species, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f7cb80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4904/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remedial measures have been recommended by the Standing Committee of the Convention that have not been implemented; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f7cb81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4904/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the suspension might be necessary for the conservation of the species.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cb82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4904/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of suspension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A species of exotic birds shall be subject to a suspension of importation under paragraph (1) until the Secretary, after notice and an opportunity for public comment, makes the findings described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4905/c"},"text":"section 4905(c) of this title","children":[],"tail":" and includes the species in the list published under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4905/a"},"text":"section 4905(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f7cb83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4904/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Moratorium after one year for other species listed in appendices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Effective on the date that is one year after ","children":[{"tag":"date","attrib":{"date":"1992-10-23"},"text":"October 23, 1992","children":[],"tail":", the importation of any exotic bird of a species that is listed in any Appendix to the Convention is prohibited unless the Secretary makes the findings described in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4905/c"},"text":"section 4905(c) of this title","children":[],"tail":" and includes the species in the list published under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4905/a"},"text":"section 4905(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f7cb84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4904/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on number imported during first year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this chapter, the Secretary shall prohibit the importation, during the 1-year period beginning on ","children":[{"tag":"date","attrib":{"date":"1992-10-23"},"text":"October 23, 1992","children":[],"tail":", of exotic birds of each species that is listed under any Appendix to the Convention in excess of the number of that species that were imported during the most recent year for which the Secretary has complete import data."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f7cb85-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/440/tI/s105"},"text":"Pub. L. 102–440, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2226"},"text":"106 Stat. 2226","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79f7cb86-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79f7cb87-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79f7cb88-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (d), was in the original “this Act” and was translated as reading “this title”, meaning title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/440"},"text":"Pub. L. 102–440","children":[],"tail":", known as the Wild Bird Conservation Act of 1992, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
