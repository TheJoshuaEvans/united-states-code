{"tag":"section","attrib":{"id":"id79345426-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1440"},"text":null,"children":[{"tag":"num","attrib":{"value":"1440"},"text":"§ 1440.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research, monitoring, and education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79345427-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1440/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct, support, or coordinate research, monitoring, evaluation, and education programs consistent with subsections (b) and (c) and the purposes and policies of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79345428-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1440/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and monitoring","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79345429-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1440/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7934542a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1440/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support, promote, and coordinate research on, and long-term monitoring of, sanctuary resources and natural processes that occur in national marine sanctuaries, including exploration, mapping, and environmental and socioeconomic assessment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7934542b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1440/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and test methods to enhance degraded habitats or restore damaged, injured, or lost sanctuary resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7934542c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1440/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support, promote, and coordinate research on, and the conservation, curation, and public display of, the cultural, archeological, and historical resources of national marine sanctuaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7934542d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1440/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of results","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The results of research and monitoring conducted, supported, or permitted by the Secretary under this subsection shall be made available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7934542e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1440/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7934542f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1440/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may support, promote, and coordinate efforts to enhance public awareness, understanding, and appreciation of national marine sanctuaries and the System. Efforts supported, promoted, or coordinated under this subsection must emphasize the conservation goals and sustainable public uses of national marine sanctuaries and the System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79345430-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1440/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Activities under this subsection may include education of the general public, teachers, students, national marine sanctuary users, and ocean and coastal resource managers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79345431-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1440/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interpretive facilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79345432-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1440/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may develop interpretive facilities near any national marine sanctuary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79345433-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1440/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facility requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any facility developed under this subsection must emphasize the conservation goals and sustainable public uses of national marine sanctuaries by providing the public with information about the conservation, recreational, ecological, historical, cultural, archeological, scientific, educational, or esthetic qualities of the national marine sanctuary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79345434-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1440/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation and coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting, supporting, and coordinating research, monitoring, evaluation, and education programs under subsection (a) and developing interpretive facilities under subsection (d), the Secretary may consult or coordinate with Federal, interstate, or regional agencies, States or local governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79345435-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532/tIII/s309"},"text":"Pub. L. 92–532, title III, § 309","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/627/tII/s203/3"},"text":"Pub. L. 100–627, title II, § 203(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3214"},"text":"102 Stat. 3214","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/tII/s2108"},"text":"Pub. L. 102–587, title II, § 2108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5045"},"text":"106 Stat. 5045","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/513/s10"},"text":"Pub. L. 106–513, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2388"},"text":"114 Stat. 2388","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79345436-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79345437-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id79345438-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532/s309"},"text":"section 309 of Pub. L. 92–532","children":[],"tail":" was renumbered section 308 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1439"},"text":"section 1439 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79345439-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/513"},"text":"Pub. L. 106–513","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—The Secretary shall conduct research, monitoring, evaluation, and education programs as are necessary and reasonable to carry out the purposes and policies of this chapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Promotion and Coordination of Sanctuary Use","children":[],"tail":".—The Secretary shall take such action as is necessary and reasonable to promote and coordinate the use of national marine sanctuaries for research, monitoring, and education purposes. Such action may include consulting with Federal agencies, States, local governments, regional agencies, interstate agencies, or other persons to promote use of one or more sanctuaries for research, monitoring, and education, including coordination with the National Estuarine Research Reserve System.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587"},"text":"Pub. L. 102–587","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “The Secretary shall take such action as is necessary to promote and coordinate the use of national marine sanctuaries for research purposes, including—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) requiring that the National Oceanic and Atmospheric Administration, in conducting or supporting marine research, give priority to research involving national marine sanctuaries; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) consulting with other Federal and State agencies to promote use by such agencies of one or more sanctuaries for marine research.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
