{"tag":"section","attrib":{"id":"id79f09e8e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4502"},"text":null,"children":[{"tag":"num","attrib":{"value":"4502"},"text":"§ 4502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tropical deforestation assessment and assistance","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In support of the Tropical Forestry Action Plan and to specifically address tropical deforestation and degradation, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f09e8f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4502/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support and actively participate in global and regional meetings that seek to reform such Plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f09e90-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4502/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" together with the United States Agency for International Development,","children":[{"tag":"ref","attrib":{"idref":"fn002795"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002795"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" and other Federal agencies, provide technical assistance to tropical countries for the formulation of national forestry sector development strategies; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f09e91-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4502/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with tropical countries on research, training, and technical programs aimed at implementing national forestry sector development strategies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f09e92-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/513/tVI/s603"},"text":"Pub. L. 101–513, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2071"},"text":"104 Stat. 2071","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
