{"tag":"section","attrib":{"id":"id77a3c86a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450ii–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"450ii–1"},"text":"§ 450ii–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excluded lands opened to entry under mining laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All public-domain lands included before ","children":[{"tag":"date","attrib":{"date":"1950-09-25"},"text":"September 25, 1950","children":[],"tail":", within the Joshua Tree National Monument which are eliminated from the National Monument by sections 450ii to 450ii–3 of this title are opened to location, entry, and patenting under the United States mining laws: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That such public-domain lands or portions thereof shall be restored to application and entry under other applicable public land laws, including the mineral leasing laws."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77a3c86b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-25/ch1030/s2"},"text":"Sept. 25, 1950, ch. 1030, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/1035"},"text":"64 Stat. 1035","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77a3c86c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77a3c86d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77a3c86e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Joshua Tree National Monument","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Joshua Tree National Monument abolished and incorporated in Joshua Tree National Park, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410aaa–22"},"text":"section 410aaa–22 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
