{"tag":"section","attrib":{"id":"id795a7a15-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1687"},"text":null,"children":[{"tag":"num","attrib":{"value":"1687"},"text":"§ 1687.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is hereby authorized to be appropriated not to exceed $25,000,000 for each of the fiscal years 1982, 1983, 1984, 1985, and 1986 to carry out the pilot projects and demonstrations authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1682"},"text":"section 1682 of this title","children":[],"tail":", the residue removal credits authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1683"},"text":"section 1683 of this title","children":[],"tail":", and the other provisions of this subchapter: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That not to exceed $2,500,000 of such amount may be appropriated for administrative expenses to carry out this subchapter for the period beginning "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"October 1, 1981","children":[],"tail":", and ending "},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"September 30, 1986","children":[],"tail":". Such sums shall be in addition to those provided under other provisions of law and shall remain available until expended."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id795a7a16-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/554/s8"},"text":"Pub. L. 96–554, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-19"},"text":"Dec. 19, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3259"},"text":"94 Stat. 3259","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id795a7a17-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id795a7a18-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id795a7a19-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/554/s9"},"text":"section 9 of Pub. L. 96–554","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1681"},"text":"section 1681 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
