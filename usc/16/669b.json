children":[],"tail":", 2762A–120; "},{"tag":"ref","attrib":{"href":"/us/pl/109/75/s1"},"text":"Pub. L. 109–75, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-09-29"},"text":"Sept. 29, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2034"},"text":"119 Stat. 2034","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dG/tI/s120"},"text":"Pub. L. 114–113, div. G, title I, § 120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2552"},"text":"129 Stat. 2552","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/40/s2"},"text":"Pub. L. 119–40, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-11-25"},"text":"Nov. 25, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/662"},"text":"139 Stat. 662","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id786bfa83-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id786bfa84-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id786bfa85-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Migratory Bird Conservation Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1929-02-18/ch257"},"text":"act Feb. 18, 1929, ch. 257","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1222"},"text":"45 Stat. 1222","children":[],"tail":", which is classified generally to subchapter III (§ 715 et seq.) of chapter 7 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s715"},"text":"section 715 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id786bfa86-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/40"},"text":"Pub. L. 119–40","children":[],"tail":" substituted “2033” for “2026”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113"},"text":"Pub. L. 114–113","children":[],"tail":" substituted “2026” for “2016”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/75"},"text":"Pub. L. 109–75","children":[],"tail":" substituted “2016” for “2006”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/553/s1/a/2/tIX/s902/d/1"},"text":"Pub. L. 106–553, § 1(a)(2) [title IX, § 902(d)(1)]","children":[],"tail":", designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/553/s1/a/2/tIX/s902/d/2"},"text":"Pub. L. 106–553, § 1(a)(2) [title IX, § 902(d)(2)]","children":[],"tail":", added subsecs. (c) and (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/233"},"text":"Pub. L. 101–233","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”, which for purposes of codification was translated as “title 26” thus requiring no change in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/558"},"text":"Pub. L. 92–558","children":[],"tail":" substituted “(beginning with the fiscal year 1975)” for “(beginning with the fiscal year 1971)” and inserted reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4161/b"},"text":"section 4161(b) of title 26","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/503"},"text":"Pub. L. 91–503","children":[],"tail":" inserted provisions for the deposit of the 10 per cent tax on pistols and revolvers under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4181"},"text":"section 4181 of title 26","children":[],"tail":" into the Federal aid to wildlife restoration fund beginning in fiscal year 1971."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id786bfa87-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id786bfa88-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/233/s7/a/3"},"text":"Pub. L. 101–233, § 7(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-13"},"text":"Dec. 13, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1975"},"text":"103 Stat. 1975","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/233/s7/a/3"},"text":"“The amendments made by this subsection of this Act [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s669c"},"text":"section 669c of this title","children":[],"tail":"] take effect "},{"tag":"date","attrib":{"date":"1989-10-01"},"text":"October 1, 1989","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id786bfa89-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1972 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/558/tI/s101/c"},"text":"Pub. L. 92–558, title I, § 101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-25"},"text":"Oct. 25, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1172"},"text":"86 Stat. 1172","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/93/313"},"text":"Pub. L. 93–313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-06-08"},"text":"June 8, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/238"},"text":"88 Stat. 238","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/93/313"},"text":"“The amendments made by subsections (a) and (b) [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s669c"},"text":"section 669c of this title","children":[],"tail":"] of this section shall take effect "},{"tag":"date","attrib":{"date":"1975-01-01"},"text":"January 1, 1975","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id786bfa8a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id786bfa8b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reorg. Plan No. II of 1939, set out in the Appendix to Title 5, Government Organization and Employees, transferred functions of Secretary of Agriculture relating to conservation of wildlife, game, and migratory birds to Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
