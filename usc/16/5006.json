{"tag":"section","attrib":{"id":"id79fa3b58-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5006"},"text":null,"children":[{"tag":"num","attrib":{"value":"5006"},"text":"§ 5006.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration and enforcement of Convention","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79fa3b59-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5006/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce shall be responsible for administering provisions of the Convention, this chapter, and regulations issued under this chapter. The Secretary, in consultation with the Secretary of Commerce and the Secretary of Transportation, shall be responsible for coordinating the participation of the United States in the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79fa3b5a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5006/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation and cooperation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out such functions, the Secretary of Commerce—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79fa3b5b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5006/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall, in consultation with the Secretary of Transportation and the United States Section, issue such regulations as may be necessary to carry out the purposes and objectives of the Convention and this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fa3b5c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5006/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, with the concurrence of the Secretary, cooperate with the authorized officials of the government of any Party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79fa3b5d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/567/tVIII/s807"},"text":"Pub. L. 102–567, title VIII, § 807","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4311"},"text":"106 Stat. 4311","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/tVIII/s8007"},"text":"Pub. L. 102–587, title VIII, § 8007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5101"},"text":"106 Stat. 5101","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/562/tIII/s304/a"},"text":"Pub. L. 106–562, title III, § 304(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-23"},"text":"Dec. 23, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2806"},"text":"114 Stat. 2806","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79fa3b5e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79fa3b5f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attr