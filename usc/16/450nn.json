{"tag":"section","attrib":{"id":"id77a612f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450nn"},"text":null,"children":[{"tag":"num","attrib":{"value":"450nn"},"text":"§ 450nn.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General Grant National Memorial; establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized and directed to accept, as a gift to the United States, title to the real property known as Grant’s Tomb at Riverside Drive and West One Hundred and Twenty-Second Street in New York, New York, and thereafter to administer and maintain such real property as the General Grant National Memorial.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77a612fa-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/659"},"text":"Pub. L. 85–659","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-14"},"text":"Aug. 14, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/614"},"text":"72 Stat. 614","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
