{"tag":"section","attrib":{"id":"id783051b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539l–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"539l–2"},"text":"§ 539l–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" James Peak Fall River trailhead","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id783051b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539l–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services and facilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Following the consultation required by subsection (c), the Forest Supervisor of the Arapaho/Roosevelt National Forest in the State of Colorado (in this section referred to as the “Forest Supervisor”) shall establish a trailhead and corresponding facilities and services to regulate use of National Forest System lands in the vicinity of the Fall River basin south of the communities of Alice Township and St. Mary’s Glacier in the State of Colorado. The facilities and services shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id783051b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539l–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Trailhead parking.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id783051b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539l–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Public restroom accommodations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id783051b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539l–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Trailhead and trail maintenance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id783051b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539l–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Forest Supervisor shall assign Forest Service personnel to provide appropriate management and oversight of the area described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id783051b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539l–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Forest Supervisor shall consult with the Clear Creek County commissioners and with residents of Alice Township and St. Mary’s Glacier regarding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id783051b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539l–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate location of facilities and services in the area described in subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id783051ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539l–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" appropriate measures that may be needed in this area—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id783051bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539l–2/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide access by emergency or law enforcement vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id783051bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539l–2/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for public health; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id783051bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539l–2/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to address concerns regarding impeded access by local residents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id783051be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539l–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the consultation required by subsection (c), the Forest Supervisor shall submit to the Committee on Resources and the Committee on Appropriations of the House of Representatives and the Committee on Energy and Natural Resources and the Committee on Appropriations of the Senate a report regarding the amount of any additional funding required to implement this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id783051bf-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/216/s5"},"text":"Pub. L. 107–216, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1060"},"text":"116 Stat. 1060","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id783051c0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id783051c1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id783051c2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Resources of House of Representatives changed to Committee on Natural Resources of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
