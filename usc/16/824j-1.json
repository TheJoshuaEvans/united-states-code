{"tag":"section","attrib":{"id":"id78ac5f78-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824j–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"824j–1"},"text":"§ 824j–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Open access by unregulated transmitting utilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78ac5f79-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824j–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of unregulated transmitting utility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “unregulated transmitting utility” means an entity that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78ac5f7a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824j–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owns or operates facilities used for the transmission of electric energy in interstate commerce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78ac5f7b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824j–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an entity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s824/f"},"text":"section 824(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ac5f7c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824j–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmission operation services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s824k/h"},"text":"section 824k(h) of this title","children":[],"tail":", the Commission may, by rule or order, require an unregulated transmitting utility to provide transmission services—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id78ac5f7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824j–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at rates that are comparable to those that the unregulated transmitting utility charges itself; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78ac5f7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824j–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on terms and conditions (not relating to rates) that are comparable to those under which the unregulated transmitting utility provides transmission services to itself and that are not unduly discriminatory or preferential.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ac5f7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824j–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall exempt from any rule or order under this section any unregulated transmitting utility that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78ac5f80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824j–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sells not more than 4,000,000 megawatt hours of electricity per year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78ac5f81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824j–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not own or operate any transmission facilities that are necessary for operating an interconnected transmission system (or any portion of the system); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78ac5f82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824j–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets other criteria the Commission determines to be in the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ac5f83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824j–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local distribution facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of subsection (b) shall not apply to facilities used in local distribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ac5f84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824j–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Commission, after an evidentiary hearing held on a complaint and after giving consideration to reliability standards established under section 824","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title, finds on the basis of a preponderance of the evidence that any exemption granted pursuant to subsection (c) unreasonably impairs the continued reliability of an interconnected transmission system, the Commission shall revoke the exemption granted to the transmitting utility."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ac5f85-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824j–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to unregulated transmitting utilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rate changing procedures applicable to public utilities under subsections (c) and (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s824d"},"text":"section 824d of this title","children":[],"tail":" are applicable to unregulated transmitting utilities for purposes of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ac5f86-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824j–1/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remand","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In exercising authority under subsection (b)(1), the Commission may remand transmission rates to an unregulated transmitting utility for review and revision if necessary to meet the requirements of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ac5f87-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824j–1/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other requests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provision of transmission services under subsection (b) does not preclude a request for transmission services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s824j"},"text":"section 824j of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ac5f88-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824j–1/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may not require a State or municipality to take action under this section that would violate a private activity bond rule for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s141"},"text":"section 141 of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ac5f89-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824j–1/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of control of transmitting facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section authorizes the Commission to require an unregulated transmitting utility to transfer control or operational control of its transmitting facilities to a Transmission Organization that is designated to provide nondiscriminatory transmission access.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78ac5f8a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-10/ch285"},"text":"June 10, 1920, ch. 285","children":[],"tail":", pt. II, § 211A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXII/s1231"},"text":"Pub. L. 109–58, title XII, § 1231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/955"},"text":"119 Stat. 955","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
