{"tag":"section","attrib":{"id":"id77c9ee5c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460s–14"},"text":null,"children":[{"tag":"num","attrib":{"value":"460s–14"},"text":"§ 460s–14.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pictured Rocks National Lakeshore boundary adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The boundary of Pictured Rocks National Lakeshore is hereby modified as depicted on the map entitled “Area Proposed for Addition to Pictured Rocks National Lakeshore”, numbered 625–80,043A, and dated July 1992.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77c9ee5d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/333/dI/tII/s203"},"text":"Pub. L. 104–333, div. I, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-11-12"},"text":"Nov. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4106"},"text":"110 Stat. 4106","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77c9ee5e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77c9ee5f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77c9ee60-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Omnibus Parks and Public Lands Management Act of 1996, and not as part of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/668"},"text":"Pub. L. 89–668","children":[],"tail":" which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
