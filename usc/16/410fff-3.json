{"tag":"section","attrib":{"id":"id776f4b7c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"410fff–3"},"text":"§ 410fff–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of property and minor boundary adjustments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id776f4b7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional acquisitions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776f4b7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire land or interests in land depicted on the Map or the map described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410fff–2/a/2"},"text":"section 410fff–2(a)(2) of this title","children":[],"tail":" as proposed additions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776f4b7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of acquisition","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id776f4b80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–3/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Land or interests in land may be acquired by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id776f4b81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–3/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" donation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id776f4b82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–3/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id776f4b83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–3/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase with donated or appropriated funds; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id776f4b84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–3/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776f4b85-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–3/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No land or interest in land may be acquired without the consent of the owner of the land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776f4b86-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary revision","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After acquiring land for the Park, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776f4b87-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revise the boundary of the Park to include newly-acquired land within the boundary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776f4b88-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer newly-acquired land subject to applicable laws (including regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776f4b89-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary survey","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable and subject to the availability of funds the Secretary shall complete an official boundary survey of the Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776f4b8a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hunting on privately owned lands","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776f4b8b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–3/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may permit hunting on privately owned land added to the Park under this subchapter, subject to limitations, conditions, or regulations that may be prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7771947c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–3/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the date that the Secretary acquires fee ownership of any privately owned land added to the Park under this subchapter, the authority under paragraph (1) shall terminate with respect to the privately owned land acquired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7771947d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/76/s5"},"text":"Pub. L. 106–76, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-21"},"text":"Oct. 21, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1128"},"text":"113 Stat. 1128","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/128/s2/c"},"text":"Pub. L. 108–128, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-17"},"text":"Nov. 17, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1355"},"text":"117 Stat. 1355","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7771947e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7771947f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77719480-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/128"},"text":"Pub. L. 108–128","children":[],"tail":" substituted “Map or the map described in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410fff–2/a/2"},"text":"section 410fff–2(a)(2) of this title","children":[],"tail":"” for “Map”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
