{"tag":"section","attrib":{"id":"id77908f50-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s429b–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"429b–3"},"text":"§ 429b–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of sections 429b to 429b–5 of this title—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77908f51-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s429b–3/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “improved property” means a detached, one-family dwelling, construction of which was begun before ","children":[{"tag":"date","attrib":{"date":"1979-01-01"},"text":"January 1, 1979","children":[],"tail":", which is used for noncommercial residential purposes, together with not to exceed three acres of land on which the dwelling is situated and together with such additional lands or interests therein as the Secretary deems to be reasonably necessary for access thereto, such lands being in the same ownership as the dwelling, together with any structures accessory to the dwelling which are situated on such land."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77908f52-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s429b–3/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “park” means the Manassas National Battlefield Park established under sections 429b to 429b–5 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77908f53-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s429b–3/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77908f54-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s429b–3/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “owner” means the owner of record as of ","children":[{"tag":"date","attrib":{"date":"1980-09-01"},"text":"September 1, 1980","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77908f55-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-04-17/ch153/s4"},"text":"Apr. 17, 1954, ch. 153, § 4","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/442/s2"},"text":"Pub. L. 96–442, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-13"},"text":"Oct. 13, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1886"},"text":"94 Stat. 1886","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
