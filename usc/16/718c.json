{"tag":"section","attrib":{"id":"id788639b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718c"},"text":null,"children":[{"tag":"num","attrib":{"value":"718c"},"text":"§ 718c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization and exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to authorize any person to take any migratory waterfowl otherwise than in accordance with regulations adopted and approved pursuant to any treaty or convention heretofore or hereafter entered into between the United States and any other country for the protection of migratory birds, nor to exempt any person from complying with the game laws of the several States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id788639ba-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-03-16/ch71/s3"},"text":"Mar. 16, 1934, ch. 71, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/451"},"text":"48 Stat. 451","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/616/s7/b"},"text":"Pub. L. 95–616, § 7(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-08"},"text":"Nov. 8, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3114"},"text":"92 Stat. 3114","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/266/s10/d"},"text":"Pub. L. 109–266, § 10(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-03"},"text":"Aug. 3, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/675"},"text":"120 Stat. 675","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id788639bb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id788639bc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id788639bd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/266"},"text":"Pub. L. 109–266","children":[],"tail":" inserted section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/616"},"text":"Pub. L. 95–616","children":[],"tail":" inserted “or convention” after “treaty”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
