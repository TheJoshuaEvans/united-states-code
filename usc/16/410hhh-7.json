{"tag":"section","attrib":{"id":"id777405bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"410hhh–7"},"text":"§ 410hhh–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water rights","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id777405bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777405bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on water rights","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777405be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the amendment made by subsection (a),","children":[{"tag":"ref","attrib":{"idref":"fn002173"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002173"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Codification note below."}],"tail":" nothing in this subchapter affects—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777405bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use, allocation, ownership, or control, in existence on ","children":[{"tag":"date","attrib":{"date":"2000-11-22"},"text":"November 22, 2000","children":[],"tail":", of any water, water right, or any other valid existing right;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777405c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any vested absolute or decreed conditional water right in existence on ","children":[{"tag":"date","attrib":{"date":"2000-11-22"},"text":"November 22, 2000","children":[],"tail":", including any water right held by the United States;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777405c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any interstate water compact in existence on ","children":[{"tag":"date","attrib":{"date":"2000-11-22"},"text":"November 22, 2000","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777405c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the provisions of paragraph (2), State jurisdiction over any water law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777405c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water rights for national park and national preserve","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this subchapter, the Secretary shall obtain and exercise any water rights required to fulfill the purposes of the national park and the national preserve in accordance with the following provisions:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777405c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such water rights shall be appropriated, adjudicated, changed, and administered pursuant to the procedural requirements and priority system of the laws of the State of Colorado.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777405c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The purposes and other substantive characteristics of such water rights shall be established pursuant to State law, except that the Secretary is specifically authorized to appropriate water under this subchapter exclusively for the purpose of maintaining ground water levels, surface water levels, and stream flows on, across, and under the national park and national preserve, in order to accomplish the purposes of the national park and the national preserve and to protect park resources and park uses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777405c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such water rights shall be established and used without interfering with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777405c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any exercise of a water right in existence on ","children":[{"tag":"date","attrib":{"date":"2000-11-22"},"text":"November 22, 2000","children":[],"tail":", for a non-Federal purpose in the San Luis Valley, Colorado; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777405c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Closed Basin Division, San Luis Valley Project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777405c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsections (c) and (d), no Federal reservation of water may be claimed or established for the national park or the national preserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777405ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Forest water rights","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent that a water right is established or acquired by the United States for the Rio Grande National Forest, the water right shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777405cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be considered to be of equal use and value for the national preserve; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777405cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retain its priority and purpose when included in the national preserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777405cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Monument water rights","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent that a water right has been established or acquired by the United States for the Great Sand Dunes National Monument, the water right shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777405ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be considered to be of equal use and value for the national park; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777405cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retain its priority and purpose when included in the national park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777405d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquired water rights and water resources","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777405d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777405d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If, and to the extent that, the Luis Maria Baca Grant No. 4 is acquired, all water rights and water resources associated with the Luis Maria Baca Grant No. 4 shall be restricted for use only within—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777405d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the national park;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777405d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preserve;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777405d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/e/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the national wildlife refuge; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777405d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/e/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the immediately surrounding areas of Alamosa or Saguache Counties, Colorado.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777405d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in the memorandum of water service agreement and the water service agreement between the Cabeza de Vaca Land and Cattle Company, LLC, and Baca Grande Water and Sanitation District, dated ","children":[{"tag":"date","attrib":{"date":"1997-08-28"},"text":"August 28, 1997","children":[],"tail":", water rights and water resources described in subparagraph (A) shall be restricted for use in—"}],"tail":null},{"tag":"clause","attrib":{"id":"id777405d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection of resources and values for the national monument, the national park, the preserve, or the wildlife refuge;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777405d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fish and wildlife management and protection; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777405da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/e/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" irrigation necessary to protect water resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777405db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, and to the extent that, water rights associated with the Luis Maria Baca Grant No. 4 are acquired, the use of those water rights shall be changed only in accordance with the laws of the State of Colorado.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777405dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–7/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to sell the water resources and related appurtenances and fixtures as the Secretary deems necessary to obtain the termination of obligations specified in the memorandum of water service agreement and the water service agreement between the Cabeza de Vaca Land and Cattle Company, LLC and the Baca Grande Water and Sanitation District, dated ","children":[{"tag":"date","attrib":{"date":"1997-08-28"},"text":"August 28, 1997","children":[],"tail":". Prior to the sale, the Secretary shall determine that the sale is not detrimental to the protection of the resources of Great Sand Dunes National Monument, Great Sand Dunes National Park, and Great Sand Dunes National Preserve, and the Baca National Wildlife Refuge, and that appropriate measures to provide for such protection are included in the sale."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id777405dd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/530/s9"},"text":"Pub. L. 106–530, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2533"},"text":"114 Stat. 2533","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id777405de-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id777405df-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id777405e0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/530/s9"},"text":"section 9 of Pub. L. 106–530","children":[],"tail":". Subsec. (a) of "},{"tag":"ref","attrib":{"href":"/us/pl/106/530/s9"},"text":"section 9 of Pub. L. 106–530","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/575/s1501/a"},"text":"section 1501(a) of Pub. L. 102–575","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4663"},"text":"106 Stat. 4663","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
