{"tag":"section","attrib":{"id":"id79c37490-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3709"},"text":null,"children":[{"tag":"num","attrib":{"value":"3709"},"text":"§ 3709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79c37491-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3709/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79c37492-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3709/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this Act for each of fiscal years 2021 through 2030—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79c37493-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3709/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $15,000,000 to the Secretary of the Interior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c37494-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3709/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 to the Secretary of Agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c37495-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3709/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 to the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c37496-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3709/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of advance payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount made available for a fiscal year under paragraph (1) shall be provided to the Foundation in an advance payment of the entire amount on October 1, or as soon as practicable thereafter, of the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c37497-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3709/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of appropriated funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (4), amounts made available under paragraph (1) shall be provided to the Foundation for use for matching, on a 1-to-1 basis, contributions (whether in currency, services, or property) made to the Foundation, or to a recipient of a grant provided by the Foundation, by private persons and State and local government agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c37498-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3709/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on use for administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No Federal funds made available under paragraph (1) shall be used by the Foundation for administrative expenses of the Foundation, including for salaries, travel and transportation expenses, and other overhead expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c37499-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3709/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional authorization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79c3749a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3709/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts from Federal agencies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79c3749b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3709/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the amounts authorized to be appropriated under subsection (a), Federal departments, agencies, or instrumentalities are authorized to provide funds to the Foundation through Federal financial assistance grants, cooperative agreements, participating agreements, and similar instruments used for providing partnership funds, subject to the condition that the amounts are used for purposes that further the conservation and management of fish, wildlife, plants, and other natural resources in accordance with this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c3749c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3709/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Federal departments, agencies, and instrumentalities may enter into a Federal funding agreement with the Foundation for a period of not more than 10 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c3749d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3709/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Federal departments, agencies, or instrumentalities may, and should when possible, advance amounts described in subparagraph (A) to the Foundation in a lump sum without regard to when the expenses for which the amounts are used are incurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c3749e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3709/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation may assess and collect fees for the management of amounts received under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c3749f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3709/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of amounts accepted from Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Federal funds provided to the Foundation under paragraph (1) may be used by the Foundation for matching, in whole or in part, contributions (whether in currency, services, or property) made to the Foundation by private persons, State and local government agencies, and other entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c374a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3709/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of amounts","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79c374a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3709/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In entering into contracts, agreements, or other partnerships pursuant to this Act, a Federal department, agency, or instrumentality shall have discretion to waive any competitive process applicable to the department, agency, or instrumentality for entering into contracts, agreements, or partnerships with the Foundation if the purpose of the waiver is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79c374a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3709/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to address an environmental emergency resulting from a natural or other disaster; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79c374a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3709/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as determined by the head of the applicable Federal department, agency, or instrumentality, to reduce administrative expenses and expedite the conservation and management of fish, wildlife, plants, and other natural resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c374a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3709/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall include in the annual report submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3706/b"},"text":"section 3706(b) of this title","children":[],"tail":" a description of any use of the authority under subparagraph (A) by a Federal department, agency, or instrumentality in that fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c374a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3709/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on use of grant amounts for litigation and lobbying expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts provided as a grant by the Foundation shall not be used for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79c374a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3709/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any expense related to litigation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c374a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3709/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any activity the purpose of which is to influence legislation pending before Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c374a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3709/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of gifts, devises, or bequests of money or other property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any gifts, devises, or bequests of amounts or other property, or any other amounts or other property, transferred to, deposited with, or otherwise in the possession of the Foundation pursuant to this Act, may be made available by the Foundation to Federal departments, agencies, or instrumentalities and may be accepted and expended (or the disposition of the amounts or property directed), without further appropriation, by those Federal departments, agencies, or instrumentalities, subject to the condition that the amounts or property be used for purposes that further the conservation and management of fish, wildlife, plants, and other natural resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79c374a9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/244/s10"},"text":"Pub. L. 98–244, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-03-26"},"text":"Mar. 26, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/110"},"text":"98 Stat. 110","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/240/s4"},"text":"Pub. L. 100–240, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-11"},"text":"Jan. 11, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1786"},"text":"101 Stat. 1786","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/593/tI/s110/c"},"text":"Pub. L. 101–593, title I, § 110(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2960"},"text":"104 Stat. 2960","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/232/tI/s104"},"text":"Pub. L. 103–232, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-11"},"text":"Apr. 11, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/337"},"text":"108 Stat. 337","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/408/tII/s207"},"text":"Pub. L. 106–408, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1781"},"text":"114 Stat. 1781","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/141/s6"},"text":"Pub. L. 107–141, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-02-12"},"text":"Feb. 12, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/14"},"text":"116 Stat. 14","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/363/tII"},"text":"Pub. L. 109–363, title II","children":[],"tail":", §§ 202, 204, "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2075"},"text":"120 Stat. 2075","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/188/tI/s107/c"},"text":"Pub. L. 116–188, title I, § 107(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/919"},"text":"134 Stat. 919","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/198/tI/s106"},"text":"Pub. L. 118–198, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2680"},"text":"138 Stat. 2680","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79c374aa-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79c374ab-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79c374ac-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsecs. (a)(1), (b)(1)(A), (3)(A), and (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/188"},"text":"Pub. L. 116–188","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/905"},"text":"134 Stat. 905","children":[],"tail":", known as the America’s Conservation Enhancement Act. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s8201"},"text":"section 8201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79c374ad-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/198/s106/1"},"text":"Pub. L. 118–198, § 106(1)","children":[],"tail":", substituted “2030” for “2025” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/198/s106/2/A"},"text":"Pub. L. 118–198, § 106(2)(A)","children":[],"tail":", substituted “, cooperative agreements, participating agreements, and similar instruments used for providing partnership funds,” for “and cooperative agreements,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/198/s106/2/C"},"text":"Pub. L. 118–198, § 106(2)(C)","children":[],"tail":", added subpar. (B). Former subpar. (B) redesignated (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/198/s106/2/D"},"text":"Pub. L. 118–198, § 106(2)(D)","children":[],"tail":", inserted “, and should when possible,” after “may”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/198/s106/2/B"},"text":"Pub. L. 118–198, § 106(2)(B)","children":[],"tail":", redesignated subpar. (B) as (C). Former subpar. (C) redesignated (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/198/s106/2/B"},"text":"Pub. L. 118–198, § 106(2)(B)","children":[],"tail":", redesignated subpar. (C) as (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/188/s107/c/1"},"text":"Pub. L. 116–188, § 107(c)(1)","children":[],"tail":", added par. (1) and struck out former par. (1) which related to authorization of appropriations for fiscal years 2006 through 2010."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/188/s107/c/2/A"},"text":"Pub. L. 116–188, § 107(c)(2)(A)","children":[],"tail":", added par. (1) and struck out former par. (1). Prior to amendment, text read as follows: “In addition to the amounts authorized to be appropriated under subsection (a), the Foundation may accept Federal funds from a Federal agency under any other Federal law for use by the Foundation to further the conservation and management of fish, wildlife, plants, and other natural resources in accordance with the requirements of this chapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/188/s107/c/2/B"},"text":"Pub. L. 116–188, § 107(c)(2)(B)","children":[],"tail":", substituted, in heading, “amounts” for “funds” and, in text, “may be used” for “shall be used” and “, State and local government agencies, and other entities” for “and State and local government agencies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/188/s107/c/2/C"},"text":"Pub. L. 116–188, § 107(c)(2)(C)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/188/s107/c/3"},"text":"Pub. L. 116–188, § 107(c)(3)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/363/s202"},"text":"Pub. L. 109–363, § 202","children":[],"tail":", substituted “fiscal years 2006 through 2010” for “fiscal years 2001 through 2005”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/363/s204"},"text":"Pub. L. 109–363, § 204","children":[],"tail":", inserted “, or to a recipient of a grant provided by the Foundation,” after “made to the Foundation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/141/s6/1"},"text":"Pub. L. 107–141, § 6(1)","children":[],"tail":", substituted “2005” for “2003”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/141/s6/2"},"text":"Pub. L. 107–141, § 6(2)","children":[],"tail":", substituted “$25,000,000” for “$20,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/408"},"text":"Pub. L. 106–408","children":[],"tail":" added text of section and struck out former text which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"Authorization","children":[],"tail":".—There are authorized to be appropriated to the Department of the Interior $25,000,000 for each of fiscal years 1994, 1995, 1996, 1997, and 1998."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Use of Amounts Appropriated","children":[],"tail":".—(1) Subject to paragraph (2), amounts appropriated under this section shall be made available to the Foundation for use for matching, in whole or in part, contributions (whether in currency, services, or property) made to the Foundation by private persons and State and local government agencies."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) No Federal funds authorized under this section shall be used by the Foundation for administrative expenses of the Foundation, including for salaries, travel and transportation expenses, and other overhead expenses.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) ","children":[{"tag":"inline","attrib":{},"text":"Additional Authorization","children":[],"tail":".—The amounts authorized to be appropriated under this section are in addition to any amounts provided or available to the Foundation under any other Federal law.”"}],"tail":"\n"},{"tag":"p","attrib"