{"tag":"section","attrib":{"id":"id780c9ceb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa"},"text":null,"children":[{"tag":"num","attrib":{"value":"460aaaa"},"text":"§ 460aaaa.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nellis Dunes Off-Highway Vehicle Recreation Area","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780c9cec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780c9ced-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" City","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “City” means the city of North Las Vegas, Nevada.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9cee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clark County Off-Highway Vehicle Recreation Park","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Clark County Off-Highway Vehicle Recreation Park” means the approximately 960 acres of land identified on the Map as “Clark County Off-Highway Vehicle Recreation Park”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9cef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" County","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “County” means Clark County, Nevada.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9cf0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Map” means the map entitled “Nellis Dunes OHV Recreation Area” and dated ","children":[{"tag":"date","attrib":{"date":"2013-12-17"},"text":"December 17, 2013","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9cf1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nellis Dunes Off-Highway Recreation Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Nellis Dunes Off-Highway Recreation Area” means the approximately 10,035 acres of land identified on the Map as “Nellis Dunes OHV Recreation Area”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9cf2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9cf3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means the State of Nevada.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9cf4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conveyance of Federal land to County","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780c9cf5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2014-12-19"},"text":"December 19, 2014","children":[],"tail":", the Secretary shall convey to the County, subject to valid existing rights and subparagraph (B), without consideration, all right, title, and interest of the United States in and to the Clark County Off-Highway Vehicle Recreation Park."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9cf6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of mineral estate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conveying the parcels of Federal land under subparagraph (A), the Secretary shall reserve the mineral estate, except for purposes related to flood mitigation (including removal from aggregate flood events).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9cf7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of conveyed land","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id780c9cf8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The parcels of land conveyed under subparagraph (A) may be used by the County for any public purposes described in clause (ii), consistent with the Act of ","children":[{"tag":"date","attrib":{"date":"1926-06-14"},"text":"June 14, 1926","children":[],"tail":" (commonly known as the “Recreation and Public Purposes Act”) ("},{"tag":"ref","attrib":{"href":"/us/usc/t43/s869"},"text":"43 U.S.C. 869","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id780c9cf9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The land conveyed under subparagraph (A)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id780c9cfa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/2/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be used by the County—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id780c9cfb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/2/C/ii/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide a suitable location for the establishment of a centralized off-road vehicle recreation park in the County;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id780c9cfc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/2/C/ii/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide the public with opportunities for off-road vehicle recreation, including a location for races, competitive events, training and other commercial services that directly support a centralized off-road vehicle recreation area and County park;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id780c9cfd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/2/C/ii/I/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide a designated area and facilities that would discourage unauthorized use of off-highway vehicles in areas that have been identified by the Federal Government, State government, or County government as containing environmentally sensitive land; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id780c9cfe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/2/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be disposed of by the County.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id780c9cff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reversion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the County ceases to use any parcel of land conveyed under subparagraph (A) for the purposes described in clause (ii)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id780c9d00-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/2/C/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" title to the parcel shall revert to the Secretary, at the option of the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id780c9d01-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/2/C/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the County shall be responsible for any reclamation necessary to revert the parcel to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id780c9d02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Air Force and the County, may develop a special management plan for the land conveyed under subparagraph (A)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id780c9d03-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/2/C/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance public safety and safe off-highway vehicle recreation use in the Nellis Dunes Recreation Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id780c9d04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/2/C/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure compatible development with the mission requirements of the Nellis Air Force Base; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id780c9d05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/2/C/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to avoid and mitigate known public health risks associated with off-highway vehicle use in the Nellis Dunes Recreation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9d06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement with Nellis Air Force Base","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id780c9d07-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before the Federal land may be conveyed to the County under subparagraph (A), the Clark County Board of Commissioners and Nellis Air Force Base shall enter into an interlocal agreement for the Federal land and the Nellis Dunes Recreation Area—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id780c9d08-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/2/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance safe off-highway recreation use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id780c9d09-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/2/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that development of the Federal land is consistent with the long-term mission requirements of Nellis Air Force Base.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id780c9d0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The use of the Federal land conveyed under subparagraph (A) shall not compromise the national security mission of Nellis Air Force Base.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9d0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to the conveyance of Federal land under subparagraph (A), the Secretary may require such additional terms and conditions as the Secretary considers to be appropriate to protect the interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9d0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of Nellis Dunes Off-Highway Vehicle Recreation Area","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780c9d0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The approximately 10,035 acres of land identified on the Map as the “Nellis Dunes OHV Recreation Area” shall be known and designated as the “Nellis Dunes Off-Highway Vehicle Recreation Area”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9d0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaaa/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may develop a special management plan for the Nellis Dunes Off-Highway Recreation Area to enhance the safe use of off-highway vehicles for recreational purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id780c9d0f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dB/tXXX/s3092/j"},"text":"Pub. L. 113–291, div. B, title XXX, § 3092(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3876"},"text":"128 Stat. 3876","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id780c9d10-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id780c9d11-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id780c9d12-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1926-06-14"},"text":"June 14, 1926","children":[],"tail":", referred to in par. (2)(C)(i), is "},{"tag":"ref","attrib":{"href":"/us/act/1926-06-14/ch578"},"text":"act June 14, 1926, ch. 578","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/741"},"text":"44 Stat. 741","children":[],"tail":", popularly known as the Recreation and Public Purposes Act, which is classified to sections 869 to 869–4 of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s869"},"text":"section 869 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
