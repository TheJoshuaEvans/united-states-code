{"tag":"section","attrib":{"id":"id79534d31-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1603"},"text":null,"children":[{"tag":"num","attrib":{"value":"1603"},"text":"§ 1603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Forest System resource inventories; development, maintenance, and updating by Secretary as part of Assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As a part of the Assessment, the Secretary shall develop and maintain on a continuing basis a comprehensive and appropriately detailed inventory of all National Forest System lands and renewable resources. This inventory shall be kept current so as to reflect changes in conditions and identify new and emerging resources and values.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79534d32-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/378/s5"},"text":"Pub. L. 93–378, § 5","children":[],"tail":", formerly § 4, "},{"tag":"date","attrib":{"date":"1974-08-17"},"text":"Aug. 17, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/477"},"text":"88 Stat. 477","children":[],"tail":", renumbered § 5, "},{"tag":"ref","attrib":{"href":"/us/pl/94/588/s2"},"text":"Pub. L. 94–588, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-22"},"text":"Oct. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2949"},"text":"90 Stat. 2949","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dO/tII/s208/b/2"},"text":"Pub. L. 115–141, div. O, title II, § 208(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1066"},"text":"132 Stat. 1066","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79534d33-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79534d34-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79534d35-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “Secretary” for “Secretary of Agriculture”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
