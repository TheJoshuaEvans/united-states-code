{"tag":"section","attrib":{"id":"id79ebe3db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4241"},"text":null,"children":[{"tag":"num","attrib":{"value":"4241"},"text":"§ 4241.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to Endangered Species Act of 1973","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The authority of the Secretary under this chapter is in addition to and shall not affect the authority of the Secretary under the Endangered Species Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"16 U.S.C. 1531","children":[],"tail":" et seq.) or diminish the Secretary’s authority under the Lacey Act Amendments of 1981 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3371"},"text":"16 U.S.C. 3371","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79ebe3dc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/478/tII/s2302"},"text":"Pub. L. 100–478, title II, § 2302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-07"},"text":"Oct. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2321"},"text":"102 Stat. 2321","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79ebe3dd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79ebe3de-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79ebe3df-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Endangered Species Act of 1973, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/205"},"text":"Pub. L. 93–205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-28"},"text":"Dec. 28, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/884"},"text":"87 Stat. 884","children":[],"tail":", which is classified generally to chapter 35 (§ 1531 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"section 1531 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Lacey Act Amendments of 1981, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/79"},"text":"Pub. L. 97–79","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-11-16"},"text":"Nov. 16, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1073"},"text":"95 Stat. 1073","children":[],"tail":", which is classified principally to chapter 53 (§ 3371 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3371"},"text":"section 3371 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
