{"tag":"section","attrib":{"id":"id79f7cba1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4906"},"text":null,"children":[{"tag":"num","attrib":{"value":"4906"},"text":"§ 4906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79f7cba2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon submission of a petition under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4909"},"text":"section 4909 of this title","children":[],"tail":" by any person, the Secretary shall determine whether an exotic bird breeding facility is a qualifying facility. Such determination shall be effective for a period specified by the Secretary, which may not exceed 3 years. The Secretary shall, from time to time, publish a list of qualifying facilities in the Federal Register."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f7cba3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall determine under subsection (a) that a facility is a qualifying facility for a species of exotic birds if the Secretary finds each of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f7cba4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4906/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The facility has demonstrated the capability of producing captive bred birds of the species in the numbers to be imported into the United States from that facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cba5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4906/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The facility is operated in a manner that is not detrimental to the survival of the species in the wild.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cba6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4906/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The facility is operated in a humane manner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cba7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4906/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The appropriate governmental authority of the country in which the facility is located has certified in writing, and the Secretary is satisfied, that the facility has the capability of breeding the species in captivity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cba8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4906/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The country in which the facility is located is a Party to the Convention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cba9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4906/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All birds exported from the facility are bred at the facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f7cbaa-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/440/tI/s107"},"text":"Pub. L. 102–440, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2228"},"text":"106 Stat. 2228","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
