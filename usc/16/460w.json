{"tag":"section","attrib":{"id":"id77cea97d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460w"},"text":null,"children":[{"tag":"num","attrib":{"value":"460w"},"text":"§ 460w.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; boundaries","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In order to conserve and develop for the benefit, inspiration, education, recreational use, and enjoyment of the public certain significant islands, shoreline, and light stations of the United States and their related geographic, scenic, historic, and scientific values, there is hereby established the Apostle Islands National Lakeshore (hereinafter referred to as the “lakeshore”) in Ashland and Bayfield Counties, Wisconsin, consisting of:","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77cea97e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460w/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The area generally depicted on the map entitled “Apostle Islands National Lakeshore”, numbered NL–AI–91,000, sheets 1 and 2, and dated June 1970.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77cea97f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460w/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Long Island addition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Approximately 200 acres of land at the mouth of Chequamegon Bay known as “Long Island”, as depicted on the map numbered NL–AI–91,001 and dated December, 1985.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77cea980-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460w/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ashland Harbor Breakwater Light","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77cea981-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460w/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Ashland Harbor Breakwater Light generally depicted on the map titled “Ashland Harbor Breakwater Light Addition to Apostle Islands National Lakeshore” and dated ","children":[{"tag":"date","attrib":{"date":"2014-02-11"},"text":"February 11, 2014","children":[],"tail":", located at the end of the breakwater on Chequamegon Bay, Wisconsin."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77cea982-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460w/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Congress does not intend for the designation of the property under paragraph (1) to create a protective perimeter or buffer zone around the boundary of that property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The maps shall be on file and available for public inspection in the office of the Director, National Park Service, Department of the Interior.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77cea983-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/424/s1"},"text":"Pub. L. 91–424, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-09-26"},"text":"Sept. 26, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/880"},"text":"84 Stat. 880","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/497/s1/1"},"text":"Pub. L. 99–497, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1267"},"text":"100 Stat. 1267","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dB/tXXX/s3030/1"},"text":"Pub. L. 113–291, div. B, title XXX, § 3030(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3766"},"text":"128 Stat. 3766","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77cea984-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77cea985-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77cea986-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3030/1/A"},"text":"Pub. L. 113–291, § 3030(1)(A)","children":[],"tail":", in introductory provisions, substituted “islands, shoreline, and light stations” for “islands and shoreline” and inserted “historic,” after “scenic,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3030/1/B"},"text":"Pub. L. 113–291, § 3030(1)(B)","children":[],"tail":", substituted “The area” for “the area” and period at end for “; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3030/1/C"},"text":"Pub. L. 113–291, § 3030(1)(C)","children":[],"tail":", substituted “1985.” for “1985..”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3030/1/D"},"text":"Pub. L. 113–291, § 3030(1)(D)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/497"},"text":"Pub. L. 99–497","children":[],"tail":" designated the provision specifying the boundaries of the Apostle Islands National Lakeshore as the area depicted on the map numbered NL–AI–91,000 as subsec. (a), substituted “1970; and” for “1970”, added subsec. (b), and in provision following subsec. (b) substituted “maps” for “map”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
