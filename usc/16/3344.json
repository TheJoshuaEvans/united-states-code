{"tag":"section","attrib":{"id":"id79b51d7a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3344"},"text":null,"children":[{"tag":"num","attrib":{"value":"3344"},"text":"§ 3344.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction with other laws","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter shall be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b51d7b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3344/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to diminish Federal, State, or tribal jurisdiction, responsibility, or rights in the field of resource enhancement and management, or control of water resources, submerged lands, or navigable waters; nor to limit the authority of Congress to authorize and fund projects; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b51d7c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3344/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as superseding, modifying, or repealing any existing applicable law, except as provided for in this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79b51d7d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/561/tI/s143"},"text":"Pub. L. 96–561, title I, § 143","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3286"},"text":"94 Stat. 3286","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
