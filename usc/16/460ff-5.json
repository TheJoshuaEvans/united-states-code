{"tag":"section","attrib":{"id":"id77dd011a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ff–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"460ff–5"},"text":"§ 460ff–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; master plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77dd011b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ff–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on acquisition of lands and interests in lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated such sums as may be necessary to carry out the purposes of this subchapter, but not more than $70,100,000 for the acquisition of lands and interests in lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77dd011c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ff–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of plan; consultation with State; transmittal to Congressional committees; contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the development of the park, including improvements of properties acquired for purposes of this subchapter, there is authorized to be appropriated not more than $13,000,000. Within one year from the date of establishment of the park pursuant to this subchapter, the Secretary shall, after consulting with the Governor of the State of Ohio, develop and transmit to the Committees on Interior and Insular Affairs of the United States Congress a final master plan for the development of the park consistent with the objectives of this subchapter, indicating:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77dd011d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ff–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the facilities needed to accommodate the health, safety, and recreation needs of the visiting public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77dd011e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ff–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location and estimated cost of all facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77dd011f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ff–5/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the projected need for any additional facilities within the area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77dd0120-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ff–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restoration of vegetative cover to eliminate erosion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated not more than $500,000 for fiscal year 1986, $1,000,000 for fiscal year 1987, $1,500,000 for fiscal year 1988, and $1,750,000 for fiscal year 1989, to carry out the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460ff–3/c/2"},"text":"section 460ff–3(c)(2) of this title","children":[],"tail":". Any amounts authorized to be appropriated for any fiscal year under this subsection which are not appropriated for that fiscal year shall remain available for appropriation in succeeding fiscal years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77dd0121-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/555/s5"},"text":"Pub. L. 93–555, § 5","children":[],"tail":", formerly § 6, "},{"tag":"date","attrib":{"date":"1974-12-27"},"text":"Dec. 27, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1788"},"text":"88 Stat. 1788","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/578/tIII/s323/b"},"text":"Pub. L. 94–578, title III, § 323(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2742"},"text":"90 Stat. 2742","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/625/tIII/s315/b"},"text":"Pub. L. 95–625, title III, § 315(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3483"},"text":"92 Stat. 3483","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/658/tI/s104/j/2"},"text":"Pub. L. 99–658, title I, § 104(j)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3678"},"text":"100 Stat. 3678","children":[],"tail":"; renumbered § 5 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/291/tI/s149/c/2"},"text":"Pub. L. 106–291, title I, § 149(c)(2)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2000-10-11"},"text":"Oct. 11, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/956"},"text":"114 Stat. 956","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77dd0122-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77dd0123-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id77dd0124-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/555/s5"},"text":"section 5 of Pub. L. 93–555","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460ff–4"},"text":"section 460ff–4 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/106/291"},"text":"Pub. L. 106–291","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77dd0125-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/291/s149/c/2"},"text":"Pub. L. 106–291, § 149(c)(2)","children":[],"tail":", substituted “park” for “recreation area” wherever appearing in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/658"},"text":"Pub. L. 99–658","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625/s315/b"},"text":"Pub. L. 95–625, § 315(b)","children":[],"tail":", increased appropriations authorization to $70,100,000 from $41,100,000."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625/s315/c"},"text":"Pub. L. 95–625, § 315(c)","children":[],"tail":", substituted “For the development of the recreation area, including improvements of properties acquired for purposes of this subchapter, there is authorized to be appropriated not more than $13,000,000” for “For the development of essential public facilities there are authorized to be appropriated not more than $500,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/578"},"text":"Pub. L. 94–578","children":[],"tail":" substituted “$41,100,000” for “$34,500,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77dd0126-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id77dd0127-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Interior and Insular Affairs of the Senate abolished and replaced by Committee on Energy and Natural Resources of the Senate, effective ","children":[{"tag":"date","attrib":{"date":"1977-02-11"},"text":"Feb. 11, 1977","children":[],"tail":". See Rule XXV of Standing Rules of the Senate, as amended by Senate Resolution No. 4 (popularly cited as the “Committee System Reorganization Amendments of 1977”), approved "},{"tag":"date","attrib":{"date":"1977-02-04"},"text":"Feb. 4, 1977","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Interior and Insular Affairs of the House of Representatives changed to Committee on Natural Resources of the House of Representatives on ","children":[{"tag":"date","attrib":{"date":"1993-01-05"},"text":"Jan. 5, 1993","children":[],"tail":", by House Resolution No. 5, One Hundred Third Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77dd0128-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Expenditure of Funds To Commence October 1, 1977","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/578/tIII/s323/c"},"text":"Pub. L. 94–578, title III, § 323(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2742"},"text":"90 Stat. 2742","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/578/tIII/s323/c"},"text":"“No funds authorized by this section [amending sections 460ff–1(a) and 460ff–5 of this title] in excess of those sums previously authorized by the Act of ","children":[{"tag":"date","attrib":{"date":"1974-12-27"},"text":"December 27, 1974","children":[],"tail":", [this section as originally enacted], shall be available for expenditure before "},{"tag":"date","attrib":{"date":"1977-10-01"},"text":"October 1, 1977","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
