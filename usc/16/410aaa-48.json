{"tag":"section","attrib":{"id":"id77681f96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–48"},"text":null,"children":[{"tag":"num","attrib":{"value":"410aaa–48"},"text":"§ 410aaa–48.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulation of mining","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Subject to valid existing rights, all mining claims located within the preserve shall be subject to all applicable laws and regulations applicable to mining within units of the National Park System, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1865/b"},"text":"section 1865(b) of title 18","children":[],"tail":" and subchapter III of chapter 1007 of title 54, and any patent issued after "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"October 31, 1994","children":[],"tail":", shall convey title only to the minerals together with the right to use the surface of lands for mining purposes, subject to such laws and regulations."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77681f97-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/tV/s508"},"text":"Pub. L. 103–433, title V, § 508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4491"},"text":"108 Stat. 4491","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77681f98-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77681f99-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77681f9a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In text, “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1865/b"},"text":"section 1865(b) of title 18","children":[],"tail":" and subchapter III of chapter 1007 of title 54” substituted for “the Mining in the Parks Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1901"},"text":"16 U.S.C. 1901","children":[],"tail":" et seq.)” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/113/287/s6/e"},"text":"Pub. L. 113–287, § 6(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3272"},"text":"128 Stat. 3272","children":[],"tail":", which Act enacted Title 54, National Park Service and Related Programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
