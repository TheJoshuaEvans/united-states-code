{"tag":"section","attrib":{"id":"id79f7cbeb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4913"},"text":null,"children":[{"tag":"num","attrib":{"value":"4913"},"text":"§ 4913.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exotic bird conservation assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79f7cbec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4913/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, subject to the availability of appropriations, shall use amounts in the Exotic Bird Conservation Fund established by subsection (b) to provide financial and technical assistance for projects to conserve exotic birds in their native countries. In selecting projects for assistance, the Secretary shall give particular attention to species that are subject to an import moratorium or quota under this chapter, in order to assist those countries in the development and implementation of conservation management programs, or law enforcement, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f7cbed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4913/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f7cbee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4913/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury a separate account, which shall be known as the “Exotic Bird Conservation Fund”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cbef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4913/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Fund shall consist of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f7cbf0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4913/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all amounts received by the United States in the form of penalties, fines, or forfeiture of property collected under this chapter in excess of the cost of paying rewards under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4912/c"},"text":"section 4912(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f7cbf1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4913/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" donations received by the Secretary for exotic bird conservation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f7cbf2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4913/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such amounts as are appropriated to the Secretary for conserving exotic birds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f7cbf3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4913/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and report on other conservation opportunities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with appropriate representatives of industry, the conservation community, the Secretariat of the Convention, and other national and international bodies, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f7cbf4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4913/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review opportunities for a voluntary program of labeling exotic birds, certification of exotic bird breeding facilities and retail outlets, and provision of privately organized or funded technical assistance to other nations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cbf5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4913/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to the Congress the results of this review within 2 years after ","children":[{"tag":"date","attrib":{"date":"1992-10-23"},"text":"October 23, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f7cbf6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/440/tI/s114"},"text":"Pub. L. 102–440, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2232"},"text":"106 Stat. 2232","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
