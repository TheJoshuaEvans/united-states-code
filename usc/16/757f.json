{"tag":"section","attrib":{"id":"id78921fb1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s757f"},"text":null,"children":[{"tag":"num","attrib":{"value":"757f"},"text":"§ 757f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies on pollution; recommendations to Secretary of Health and Human Services","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall, on the basis of studies carried out pursuant to sections 757a to 757f of this title and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s665"},"text":"section 665 of this title","children":[],"tail":", make recommendations to the Secretary of Health and Human Services concerning the elimination or reduction of polluting substances detrimental to fish and wildlife in interstate or navigable waters or the tributaries thereof. Such recommendations and any enforcement measures initiated pursuant thereto by the Secretary of Health and Human Services shall be designed to enhance the quality of such waters, and shall take into consideration all other legitimate uses of such waters."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78921fb2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/304/s6"},"text":"Pub. L. 89–304, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-30"},"text":"Oct. 30, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1126"},"text":"79 Stat. 1126","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78921fb3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78921fb4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id78921fb5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of Health and Human Services” substituted in text for “Secretary of Health, Education, and Welfare” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s509/b"},"text":"section 509(b) of Pub. L. 96–88","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508/b"},"text":"section 3508(b) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id78921fb6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id78921fb7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of functions to Secretary of Commerce from Secretary of the Interior by Reorg. Plan No. 4 of 1970, eff. ","children":[{"tag":"date","attrib":{"date":"1970-10-03"},"text":"Oct. 3, 1970","children":[],"tail":", 35 F.R. 15627, "},{"tag":"ref","attrib":{"href":"/us/stat/84/2090"},"text":"84 Stat. 2090","children":[],"tail":", see note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s755"},"text":"section 755 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
