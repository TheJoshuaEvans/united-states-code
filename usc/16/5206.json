{"tag":"section","attrib":{"id":"id79fcacdf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5206"},"text":null,"children":[{"tag":"num","attrib":{"value":"5206"},"text":"§ 5206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to impair a right guaranteed to a person under the first article of amendment to the Constitution or limit any legal remedy for forceful interference with a person’s lawful participation in speech or peaceful assembly.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79fcace0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXII/s320807"},"text":"Pub. L. 103–322, title XXXII, § 320807","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2122"},"text":"108 Stat. 2122","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
