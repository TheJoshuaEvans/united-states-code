{"tag":"section","attrib":{"id":"id7a2eb9d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913"},"text":null,"children":[{"tag":"num","attrib":{"value":"7913"},"text":"§ 7913.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Closure of Federal land to hunting, fishing, and recreational shooting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a2eb9d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2eb9d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2) and in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1732/b"},"text":"section 1732(b) of title 43","children":[],"tail":", the Secretary concerned may designate any area on Federal land in which, and establish any period during which, for reasons of public safety, administration, or compliance with applicable laws, no hunting, fishing, or recreational shooting shall be permitted."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eb9da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making a designation under paragraph (1), the Secretary concerned shall designate the smallest area for the least amount of time that is required for public safety, administration, or compliance with applicable laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2eb9db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Closure procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2eb9dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except in an emergency, before permanently or temporarily closing any Federal land to hunting, fishing, or recreational shooting, the Secretary concerned shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2eb9dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with State fish and wildlife agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2eb9de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide public notice and opportunity for comment under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eb9df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public notice and comment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2eb9e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Public notice and comment shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2eb9e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a notice of intent—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a2eb9e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/b/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" published in advance of the public comment period for the closure—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id7a2eb9e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/b/2/A/i/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the Federal Register;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a2eb9e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/b/2/A/i/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the website of the applicable Federal agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a2eb9e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/b/2/A/i/I/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the website of the Federal land unit, if available; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a2eb9e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/b/2/A/i/I/dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"dd"},"text":"(dd)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in at least 1 local newspaper;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a2eb9e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/b/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made available in advance of the public comment period to local offices, chapters, and affiliate organizations in the vicinity of the closure that are signatories to the memorandum of understanding entitled “Federal Lands Hunting, Fishing, and Shooting Sports Roundtable Memorandum of Understanding”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a2eb9e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/b/2/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that describes—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id7a2eb9e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/b/2/A/i/III/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed closure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a2eb9ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/b/2/A/i/III/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the justification for the proposed closure, including an explanation of the reasons and necessity for the decision to close the area to hunting, fishing, or recreational shooting; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2eb9eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an opportunity for public comment for a period of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a2eb9ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/b/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 60 days for a permanent closure; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a2eb9ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/b/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 30 days for a temporary closure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2eb9ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final decision","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In a final decision to permanently or temporarily close an area to hunting, fishing, or recreation ","children":[{"tag":"ref","attrib":{"idref":"fn002865"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002865"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “recreational”."}],"tail":" shooting, the Secretary concerned shall—"}],"tail":null},{"tag":"clause","attrib":{"id":"id7a2eb9ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" respond in a reasoned manner to the comments received;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2eb9f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explain how the Secretary concerned resolved any significant issues raised by the comments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2eb9f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" show how the resolution led to the closure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2eb9f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary closures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2eb9f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A temporary closure under this section may not exceed a period of 180 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eb9f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except in an emergency, a temporary closure for the same area of land closed to the same activities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2eb9f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be renewed more than 3 times after the first temporary closure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2eb9f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" must be subject to a separate notice and comment procedure in accordance with subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eb9f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of temporary closure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any Federal land that is temporarily closed to hunting, fishing, or recreational shooting under this section shall not become permanently closed to that activity without a separate public notice and opportunity to comment in accordance with subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2eb9f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On an annual basis, the Secretaries concerned shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2eb9f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish on a public website a list of all areas of Federal land temporarily or permanently subject to a closure under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eb9fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the Committee on Energy and Natural Resources and the Committee on Agriculture, Nutrition, and Forestry of the Senate and the Committee on Natural Resources and the Committee on Agriculture of the House of Representatives a report that identifies—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2eb9fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of each area of Federal land temporarily or permanently subject to a closure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2eb9fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acreage of each closure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2eb9fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a survey of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2eb9fe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate areas and acreage closed under this section in each State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2eb9ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of Federal land in each State closed under this section with respect to hunting, fishing, and recreational shooting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2eba00-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall not apply if the closure is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2eba01-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" less than 14 days in duration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eba02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7913/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" covered by a special use permit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a2eba03-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tIV/s4103"},"text":"Pub. L. 116–9, title IV, § 4103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/757"},"text":"133 Stat. 757","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
