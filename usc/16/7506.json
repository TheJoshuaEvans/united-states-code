{"tag":"section","attrib":{"id":"id7a29ff01-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7506"},"text":null,"children":[{"tag":"num","attrib":{"value":"7506"},"text":"§ 7506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a29ff02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (c),","children":[{"tag":"ref","attrib":{"idref":"fn002859"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002859"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" beginning with fiscal year 2017, not later than 60 days after the end of each fiscal year, the Foundation shall submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Natural Resources of the House of Representatives a report on the operation of the Fund during that fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a29ff03-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each annual report submitted under subsection (a) for a fiscal year shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a29ff04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7506/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a full and complete statement of the receipts, including the source of all receipts, expenditures, and investments of the Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29ff05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7506/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the amounts deposited in the Fund and the balance remaining in the Fund at the end of the fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29ff06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7506/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the expenditures made from the Fund for the fiscal year, including the purpose of the expenditures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a29ff07-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dO/tIX/s907"},"text":"Pub. L. 114–113, div. O, title IX, § 907","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3034"},"text":"129 Stat. 3034","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
