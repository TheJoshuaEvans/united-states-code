{"tag":"section","attrib":{"id":"id793454a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1445a"},"text":"§ 1445a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Councils","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id793454a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may establish one or more advisory councils (in this section referred to as an “Advisory Council”) to advise and make recommendations to the Secretary regarding the designation and management of national marine sanctuaries. The Advisory Councils shall be exempt from chapter 10 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id793454a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Members of the Advisory Councils may be appointed from among—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id793454a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" persons employed by Federal or State agencies with expertise in management of natural resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793454a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of relevant Regional Fishery Management Councils established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1852"},"text":"section 1852 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369d98-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of local user groups, conservation and other public interest organizations, scientific organizations, educational organizations, or others interested in the protection and multiple use management of sanctuary resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79369d99-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limits on membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For sanctuaries designated after ","children":[{"tag":"date","attrib":{"date":"1992-11-04"},"text":"November 4, 1992","children":[],"tail":", the membership of Advisory Councils shall be limited to no more than 15 members."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79369d9a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staffing and assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make available to an Advisory Council any staff, information, administrative services, or assistance the Secretary determines are reasonably required to enable the Advisory Council to carry out its functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79369d9b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public participation and procedural matters","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following guidelines apply with respect to the conduct of business meetings of an Advisory Council:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79369d9c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each meeting shall be open to the public, and interested persons shall be permitted to present oral or written statements on items on the agenda.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369d9d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Emergency meetings may be held at the call of the chairman or presiding officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369d9e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Timely notice of each meeting, including the time, place, and agenda of the meeting, shall be published locally and in the Federal Register, except that in the case of a meeting of an Advisory Council established to provide assistance regarding any individual national marine sanctuary the notice is not required to be published in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79369d9f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445a/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Minutes of each meeting shall be kept and contain a summary of the attendees and matters discussed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79369da0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532/tIII/s315"},"text":"Pub. L. 92–532, title III, § 315","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/tII/s2112"},"text":"Pub. L. 102–587, title II, § 2112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5046"},"text":"106 Stat. 5046","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/283"},"text":"Pub. L. 104–283","children":[],"tail":", §§ 5, 9(f), "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3363"},"text":"110 Stat. 3363","children":[],"tail":", 3368; "},{"tag":"ref","attrib":{"href":"/us/pl/106/513"},"text":"Pub. L. 106–513","children":[],"tail":", §§ 16, 19(b)(5), "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2391"},"text":"114 Stat. 2391","children":[],"tail":", 2393; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/112"},"text":"Pub. L. 117–286, § 4(a)(112)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4318"},"text":"136 Stat. 4318","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79369da1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79369da2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79369da3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5.” for “the Federal Advisory Committee Act.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/513/s16"},"text":"Pub. L. 106–513, § 16","children":[],"tail":", substituted “advise and make recommendations” for “provide assistance”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/513/s19/b/5"},"text":"Pub. L. 106–513, § 19(b)(5)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1852"},"text":"section 1852 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/283/s9/f"},"text":"Pub. L. 104–283, § 9(f)","children":[],"tail":", made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/s2112"},"text":"Pub. L. 102–587, § 2112","children":[],"tail":", which added this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/283/s5"},"text":"Pub. L. 104–283, § 5","children":[],"tail":", inserted before period at end “, except that in the case of a meeting of an Advisory Council established to provide assistance regarding any individual national marine sanctuary the notice is not required to be published in the Federal Register”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
