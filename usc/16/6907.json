{"tag":"section","attrib":{"id":"id7a2061ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6907"},"text":null,"children":[{"tag":"num","attrib":{"value":"6907"},"text":"§ 6907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation in carrying out convention","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a2061f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6907/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal and State agencies; private institutions and organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may cooperate with agencies of the United States government,","children":[{"tag":"ref","attrib":{"idref":"fn002842"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002842"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" any public or private institutions or organizations within the United States or abroad, and, through the Secretary of State, the duly authorized officials of the government of any party to the WCPFC Convention, in carrying out responsibilities under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2061f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6907/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientific and other programs; facilities and personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All Federal agencies are authorized, upon the request of the Secretary, to cooperate in the conduct of scientific and other programs and to furnish facilities and personnel for the purpose of assisting the Commission in carrying out its duties under the WCPFC Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2061f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6907/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctioned fishing operations and biological experiments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter, or in the laws or regulations of any State, prevents the Secretary or the Commission from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2061f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6907/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting or authorizing the conduct of fishing operations and biological experiments at any time for purposes of scientific investigation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2061f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6907/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discharging any other duties prescribed by the WCPFC Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2061f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6907/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State jurisdiction not affected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (e) of this section, nothing in this chapter shall be construed to diminish or to increase the jurisdiction of any State in the territorial sea of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2061f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6907/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2061f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6907/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Regulations promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6905/a"},"text":"section 6905(a) of this title","children":[],"tail":" shall apply within the boundaries of any State bordering on the Convention area if the Secretary has provided notice to such State, the State does not request an agency hearing, and the Secretary determines that the State—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2061f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6907/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not, within a reasonable period of time after the promulgation of regulations pursuant to this chapter, enacted laws or promulgated regulations that implement the recommendations of the Commission within the boundaries of such State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2061f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6907/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has enacted laws or promulgated regulations that implement the recommendations of the commission within the boundaries of such State that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2061fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6907/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are less restrictive that ","children":[{"tag":"ref","attrib":{"idref":"fn002843"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002843"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “than”."}],"tail":" the regulations promulgated under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6905/a"},"text":"section 6905(a) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2061fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6907/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are not effectively enforced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2061fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6907/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations promulgated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6905/a"},"text":"section 6905(a) of this title","children":[],"tail":" shall apply until the Secretary determines that the State is effectively enforcing within its boundaries measures that are not less restrictive than the regulations promulgated under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6905/a"},"text":"section 6905(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2061fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6907/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State requests a formal agency hearing, the Secretary shall not apply the regulations promulgated pursuant ","children":[{"tag":"ref","attrib":{"idref":"fn002844"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002844"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be followed by “to”."}],"tail":" "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6905/a"},"text":"section 6905(a) of this title","children":[],"tail":" within that State’s boundaries unless the hearing record supports a determination under paragraph (1)(A) or (B)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2061fe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6907/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of State laws and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To ensure that the purposes of subsection (e) are carried out, the Secretary shall undertake a continuing review of the laws and regulations of all States to which subsection (e) applies or may apply and the extent to which such laws and regulations are enforced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a2061ff-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/479/tV/s508"},"text":"Pub. L. 109–479, title V, § 508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3642"},"text":"120 Stat. 3642","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
