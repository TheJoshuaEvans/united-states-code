{"tag":"section","attrib":{"id":"id7a06231f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303"},"text":null,"children":[{"tag":"num","attrib":{"value":"6303"},"text":"§ 6303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Great ape conservation assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a062320-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of funds and in consultation with other appropriate Federal officials, the Secretary shall use amounts in the Fund to provide financial assistance for projects for the conservation of great apes for which project proposals are approved by the Secretary in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a062321-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project proposals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a062322-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible applicants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A proposal for a project for the conservation of great apes may be submitted to the Secretary by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a062323-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any wildlife management authority of a country that has within its boundaries any part of the range of a great ape if the activities of the authority directly or indirectly affect a great ape population;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a062324-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the CITES Secretariat; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a062325-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person or group with the demonstrated expertise required for the conservation of great apes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a062326-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project proposal shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a062327-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a concise statement of the purposes of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a062328-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the individual responsible for conducting the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a062329-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the qualifications of the individuals who will conduct the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a06232a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a concise description of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a06232b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods for project implementation and outcome assessment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a06232c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" staff and community management for the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a06232d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/b/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the logistics of the project;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a06232e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the funds and time required to complete the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a06232f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evidence of support for the project by appropriate governmental entities of the countries in which the project will be conducted, if the Secretary determines that such support is required for the success of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a062330-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information regarding the source and amount of matching funding available for the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a062331-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information that the Secretary considers to be necessary for evaluating the eligibility of the project for funding under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a062332-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project review and approval","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a062333-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a062334-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 30 days after receiving a project proposal, provide a copy of the proposal to other appropriate Federal officials; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a062335-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review each project proposal in a timely manner to determine if the proposal meets the criteria specified in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a062336-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation; approval or disapproval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after receiving a project proposal, and subject to the availability of funds, the Secretary, after consulting with other appropriate Federal officials, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a062337-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult on the proposal with the government of each country in which the project is to be conducted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a062338-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after taking into consideration any comments resulting from the consultation, approve or disapprove the proposal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a062339-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide written notification of the approval or disapproval to the person who submitted the proposal, other appropriate Federal officials, and each country described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a06233a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may approve a project proposal under this section if the project will enhance programs for conservation of great apes by assisting efforts to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a06233b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement conservation programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a06233c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address the conflicts between humans and great apes that arise from competition for the same habitat;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a06233d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance compliance with CITES and other applicable laws that prohibit or regulate the taking or trade of great apes or regulate the use and management of great ape habitat;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a06233e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop sound scientific information on, or methods for monitoring—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a06233f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the condition and health of great ape habitat;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a062340-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" great ape population numbers and trends; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a062341-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current and projected threats to the habitat, current and projected numbers, or current and projected trends;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a062342-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote cooperative projects on the issues described in paragraph (4) among government entities, affected local communities, nongovernmental organizations, or other persons in the private sector; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a062343-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address root causes of threats to great apes in range states, including illegal bushmeat trade, diseases, lack of regional or local capacity for conservation, and habitat loss due to natural disasters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a062344-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project sustainability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, in determining whether to approve project proposals under this section, the Secretary shall give preference to conservation projects that are designed to ensure effective, long-term conservation of great apes and their habitats.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a062345-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining whether to approve project proposals under this section, the Secretary shall give preference to projects for which matching funds are available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a062346-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a062347-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each person that receives assistance under this section for a project shall submit to the Secretary periodic reports (at such intervals as the Secretary considers necessary) that include all information that the Secretary, after consultation with other appropriate government officials, determines is necessary to evaluate the progress and success of the project for the purposes of ensuring positive results, assessing problems, and fostering improvements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a062348-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability to the public","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Reports under paragraph (1), and any other documents relating to projects for which financial assistance is provided under this chapter, shall be made available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a062349-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on use for captive breeding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts provided as a grant under this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a06234a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be used for captive breeding of great apes other than for captive breeding for release into the wild; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a06234b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be used for captive breeding of a species for release into the wild only if no other conservation method for the species is biologically feasible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a06234c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Panel","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a06234d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Convention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", and every 5 years thereafter, the Secretary may convene a panel of experts on great apes to identify the greatest needs and priorities for the conservation of great apes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a06234e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that the panel referred to in paragraph (1) includes, to the maximum extent practicable, 1 or more representatives—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a06234f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from each country that comprises the natural range of great apes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a062350-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with expertise in great ape conservation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a062351-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In identifying the conservation needs and priorities under paragraph (1), the panel referred to in that paragraph shall consider any relevant great ape conservation plan or strategy, including scientific research and findings relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a062352-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/i/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conservation needs and priorities of great apes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a062353-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/i/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any regional or species-specific action plan or strategy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a062354-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/i/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any applicable strategy developed or initiated by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a062355-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/i/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other applicable conservation plan or strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a062356-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, the Secretary may use amounts available to the Secretary to pay for the costs of convening and facilitating any meeting of the panel referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a062357-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/i/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 shall not apply to a panel convened under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a062358-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiyear grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a062359-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award to a person who is otherwise eligible for a grant under this section a multiyear grant of up to 5 years to carry out a project that the person demonstrates is an effective, long-term conservation strategy for great apes and the habitat of great apes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a06235a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6303/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of subsection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection precludes the Secretary from awarding a grant on an annual basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a06235b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/411/s4"},"text":"Pub. L. 106–411, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1791"},"text":"114 Stat. 1791","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/363/tVII/s701"},"text":"Pub. L. 109–363, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2081"},"text":"120 Stat. 2081","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tVII/s7001/c/2/A"},"text":"Pub. L. 116–9, title VII, § 7001(c)(2)(A)","children":[],"tail":", (B), "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/785"},"text":"133 Stat. 785","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/129"},"text":"Pub. L. 117–286, § 4(a)(129)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4319"},"text":"136 Stat. 4319","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dE/tLIII/s5306/a"},"text":"Pub. L. 118–159, div. E, title LIII, § 5306(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2446"},"text":"138 Stat. 2446","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a06235c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a06235d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a06235e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (j)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" inserted “of up to 5 years” after “multiyear grant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (i)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5” for “FACA” in heading and “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 App. U.S.C.)” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (i)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s7001/c/2/A/i"},"text":"Pub. L. 116–9, § 7001(c)(2)(A)(i)","children":[],"tail":", added par. (1) and struck out former par. (1). Prior to amendment, text read as follows: “Every 2 years, the Secretary may convene a panel of experts to identify the greatest needs for the conservation of great apes.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(2) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s7001/c/2/A/ii"},"text":"Pub. L. 116–9, § 7001(c)(2)(A)(ii)","children":[],"tail":", (iii), added pars. (2) to (4) and redesignated former par. (2) as (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s7001/c/2/B"},"text":"Pub. L. 116–9, § 7001(c)(2)(B)","children":[],"tail":", added subsec. (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (d)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/363/s701/1"},"text":"Pub. L. 109–363, § 701(1)","children":[],"tail":", added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/363/s701/2"},"text":"Pub. L. 109–363, § 701(2)","children":[],"tail":", designated existing provisions as par. (1), inserted par. heading, substituted “may convene” for “shall convene”, and added par. (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
