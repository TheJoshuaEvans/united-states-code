{"tag":"section","attrib":{"id":"id792f9908-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1423d"},"text":"§ 1423d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission appointments; compensation, travel expenses, and claims","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id792f9909-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of United States commissioners","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792f990a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The United States commissioners on the Commission shall be appointed by the President, in accordance with paragraph 2 of article 8 of the Agreement, after taking into consideration the recommendations of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792f990b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423d/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792f990c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423d/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792f990d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423d/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Alaska Nanuuq Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792f990e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to the United States commissioners appointed under this subsection, in accordance with paragraph 2 of article 8 of the Agreement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792f990f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423d/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 United States commissioner shall be an official of the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792f9910-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423d/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 United States commissioner shall be a representative of the Native people of Alaska, and, in particular, the Native people for whom polar bears are an integral part of their culture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792f9911-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423d/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" both commissioners shall be knowledgeable of, or have expertise in, polar bears.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792f9912-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service and term","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each United States commissioner shall serve—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792f9913-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423d/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the pleasure of the President; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792f9914-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423d/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for an initial 4-year term and such additional terms as the President shall determine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792f9915-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423d/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792f9916-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423d/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any individual appointed to fill a vacancy occurring before the expiration of any term of office of a United States commissioner shall be appointed for the remainder of that term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792f9917-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423d/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vacancy on the Commission shall be filled in the same manner as the original appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792f9918-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternate commissioners","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792f9919-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of State and the Alaska Nanuuq Commission, shall designate an alternate commissioner for each member of the United States section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792f991a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the absence of a United States commissioner, an alternate commissioner may exercise all functions of the United States commissioner at any meetings of the Commission or of the United States section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792f991b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reappointment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An alternate commissioner—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792f991c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423d/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be eligible for reappointment by the President; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792f991d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423d/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may attend all meetings of the United States section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792f991e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the United States section may carry out the functions and responsibilities described in article 8 of the Agreement in accordance with this subchapter and the Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792f991f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792f9920-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the United States section shall serve without compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792f9921-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the United States section shall be allowed travel expenses, including per diem in lieu of subsistence, at rates authorized for an employee of an agency under subchapter I of chapter 57 of title 5 while away from the home or regular place of business of the member in the performance of the duties of the United States-Russia Polar Bear Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792f9922-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States section shall, for the purpose of title 28 relating to claims against the United States and tort claims procedure, be considered to be a Federal agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id792f9923-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522/tV/s505"},"text":"Pub. L. 92–522, title V, § 505","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/479/tIX/s902/a"},"text":"Pub. L. 109–479, title IX, § 902(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3663"},"text":"120 Stat. 3663","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
