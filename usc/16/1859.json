imprisonment for not more than 1 year, or both” after “subsection (a)(2) is punishable by a fine of not more than $100,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79830fae-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79830faf-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/453/s11/b"},"text":"Pub. L. 97–453, § 11(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2491"},"text":"96 Stat. 2491","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/453/s11/b"},"text":"“The amendment made by subsection (a) [amending this section] applies with respect to offenses committed under section 309 [this section] on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79830fb0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1977-03-01"},"text":"Mar. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/265/s312"},"text":"section 312 of Pub. L. 94–265","children":[],"tail":", formerly set out as a note under "}