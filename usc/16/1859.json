{"tag":"section","attrib":{"id":"id79830fa3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1859"},"text":null,"children":[{"tag":"num","attrib":{"value":"1859"},"text":"§ 1859.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal offenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79830fa4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1859/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person is guilty of an offense if he commits any act prohibited by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79830fa5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1859/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 1857(1)(D), (E), (F), (H), (I), or (L) of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79830fa6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1859/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1857/2"},"text":"section 1857(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79830fa7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1859/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Punishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any offense described in subsection (a)(1) is punishable by a fine of not more than $100,000, or imprisonment for not more than 6 months, or both; except that if in the commission of any such offense the person uses a dangerous weapon, engages in conduct that causes bodily injury to any observer described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1857/1/L"},"text":"section 1857(1)(L) of this title","children":[],"tail":" or any officer authorized to enforce the provisions of this chapter (as provided for in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1861"},"text":"section 1861 of this title","children":[],"tail":"), or places any such observer or officer in fear of imminent bodily injury, the offense is punishable by a fine of not more than $200,000, or imprisonment for not more than 10 years, or both. Any offense described in subsection (a)(2) is punishable by a fine of not more than $200,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79830fa8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1859/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is Federal jurisdiction over any offense described in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79830fa9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265/tIII/s309"},"text":"Pub. L. 94–265, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-13"},"text":"Apr. 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/357"},"text":"90 Stat. 357","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/453/s11/a"},"text":"Pub. L. 97–453, § 11(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","a