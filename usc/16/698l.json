{"tag":"section","attrib":{"id":"id787a529a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698l"},"text":null,"children":[{"tag":"num","attrib":{"value":"698l"},"text":"§ 698l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of Big Cypress Preserve area and Addition area by Secretary; report to President","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Within five years from ","children":[{"tag":"date","attrib":{"date":"1974-10-11"},"text":"October 11, 1974","children":[],"tail":", with respect to the preserve and five years from "},{"tag":"date","attrib":{"date":"1988-04-29"},"text":"April 29, 1988","children":[],"tail":", with respect to the Addition, the Secretary shall review the area within the preserve or the area within the Addition (as the case may be) and shall report to the President, in accordance with section 1132(c) and (d) of this title, his recommendations as to the suitability or nonsuitability of any area within the preserve or the area within the Addition (as the case may be) for preservation as wilderness, and any designation of any such areas as a wilderness shall be accomplished in accordance with section 1132(c) and (d) of this title."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id787a529b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/440/s7"},"text":"Pub. L. 93–440, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-11"},"text":"Oct. 11, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1261"},"text":"88 Stat. 1261","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/301/s3/c"},"text":"Pub. L. 100–301, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-29"},"text":"Apr. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/444"},"text":"102 Stat. 444","children":[],