c. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4603"},"text":"132 Stat. 4603","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79dd8c51-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79dd8c52-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79dd8c53-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (b)(2), was in the original “this title”, meaning title XII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":", which enacted this chapter and former "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2005a"},"text":"section 2005a of this title","children":[],"tail":" and amended sections 590g, 2004, 2005, 2006, and 2009 of this title, sections 4207 and 4209 of Title 7, Agriculture, and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1981"},"text":"section 1981 of Title 7","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79dd8c54-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79dd8c55-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2822/a"},"text":"Pub. L. 115–334, § 2822(a)","children":[],"tail":", struck out “under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3862/b"},"text":"section 3862(b) of this title","children":[],"tail":"” after “technical guidelines”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2822/b"},"text":"Pub. L. 115–334, § 2822(b)","children":[],"tail":", added par. (14)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":", in introductory provisions, substituted “The Secretary shall review and update as necessary” for “Not later than 180 days after the date of enactment of the Food, Conservation, and Energy Act of 2008, the Secretary shall develop”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s2711"},"text":"Pub. L. 110–246, § 2711","children":[],"tail":", which directed the general amendment of section 1261 of the “Farm Security Act of 1985”, was executed by making the amendment to this section, which is section 1261 of the Food Security Act of 1985, to reflect the probable intent of Congress. Prior to amendment, section related to the establishment in each State of a technical committee to assist the Secretary in the technical considerations relating to implementation of conservation provisions under this chapter, composition of each such committee, and development of standards to be used in the development of guidelines under former "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3862/b"},"text":"section 3862(b) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7511/c/38"},"text":"Pub. L. 110–246, § 7511(c)(38)","children":[],"tail":", which directed amendment of par. (4) by substituting “National Institute of Food and Agriculture” for “Extension Service”, could not be executed because “Extension Service” did not appear subsequent to amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s2711"},"text":"Pub. L. 110–246, § 2711","children":[],"tail":". See above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c)(9) to (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" added pars. (9) to (12)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79dd8c56-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79dd8c57-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail"