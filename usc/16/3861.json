{"tag":"section","attrib":{"id":"id79dd8c3c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3861"},"text":null,"children":[{"tag":"num","attrib":{"value":"3861"},"text":"§ 3861.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of State technical committees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79dd8c3d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3861/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a technical committee in each State to assist the Secretary in the considerations relating to implementation and technical aspects of the conservation programs under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79dd8c3e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3861/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall review and update as necessary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79dd8c3f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3861/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standard operating procedures to standardize the operations of State technical committees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8c40-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3861/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards to be used by State technical committees in the development of technical guidelines for the implementation of the conservation provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79dd8c41-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3861/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State technical committee shall be composed of agricultural producers and other professionals that represent a variety of disciplines in the soil, water, wetland, and wildlife sciences. The technical committee for a State shall include representatives from among the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79dd8c42-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3861/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Natural Resources Conservation Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8c43-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3861/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Farm Service Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8c44-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3861/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Forest Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8c45-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3861/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Institute of Food and Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8c46-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3861/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The State fish and wildlife agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8c47-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3861/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The State forester or equivalent State official.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8c48-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3861/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The State water resources agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8c49-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3861/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The State department of agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8c4a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3861/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The State association of soil and water conservation districts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8c4b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3861/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Agricultural producers representing the variety of crops and livestock or poultry raised within the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8c4c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3861/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Owners of nonindustrial private forest land.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8c4d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3861/c/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nonprofit organizations within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":" with demonstrable conservation expertise and experience working with agriculture producers in the State."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8c4e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3861/c/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Agribusiness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8c4f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3861/c/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The State Cooperative Extension Service and land grant university in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79dd8c50-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"hr