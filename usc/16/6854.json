{"tag":"section","attrib":{"id":"id7a1df0ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6854"},"text":null,"children":[{"tag":"num","attrib":{"value":"6854"},"text":"§ 6854.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data consolidation and publication of route and area data for public recreational use","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1df0ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6854/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning not later than 5 years after ","children":[{"tag":"date","attrib":{"date":"2022-04-29"},"text":"April 29, 2022","children":[],"tail":", each of the Secretaries, to the maximum extent practicable, shall make publicly available on the website of the Department of the Interior, the Forest Service, and the Corps of Engineers, as applicable, geographic information system data with respect to the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1df0ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6854/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Status information with respect to whether roads and trails on the Federal land are open or closed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1df0f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6854/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The dates on which roads and trails on the Federal land are seasonally closed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1df0f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6854/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The classes of vehicles and types of recreational uses that are allowed on each segment of roads and trails on the Federal land, including the permissibility of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1df0f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6854/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" off-highway vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df0f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6854/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" motorcycles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df0f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6854/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonmotorized bicycles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df0f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6854/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electric bicycles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df0f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6854/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" passenger vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df0f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6854/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonmechanized transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df0f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6854/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" over-snow vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1df0f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6854/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The boundaries of areas where hunting or recreational shooting (including archery, firearm discharge, and target shooting) is regulated or closed on the Federal land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1df0fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6854/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1df0fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6854/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries, to the maximum extent practicable, shall update the data described in subsection (a) not less frequently than twice per year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1df0fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6854/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries shall develop a process to allow members of the public to submit questions or comments regarding the information described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1df0fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6854/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Geographic information system data made publicly available under subsection (a) shall not disclose information regarding the nature, location, character, or ownership of historic, paleontological, or archaeological resources, consistent with applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1df0fe-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/114/s5"},"text":"Pub. L. 117–114, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-04-29"},"text":"Apr. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1176"},"text":"136 Stat. 1176","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/234/tIII/s354/2"},"text":"Pub. L. 118–234, title III, § 354(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2917"},"text":"138 Stat. 2917","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a1df0ff-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a1df100-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a1df101-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234"},"text":"Pub. L. 118–234","children":[],"tail":" substituted “regulated or closed” for “permanently restricted or prohibited”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
