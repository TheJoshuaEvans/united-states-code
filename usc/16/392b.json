{"tag":"section","attrib":{"id":"id7731313e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s392b"},"text":null,"children":[{"tag":"num","attrib":{"value":"392b"},"text":"§ 392b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conveyance of added lands to United States by Governor","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Governor of the Territory of Hawaii is authorized to convey to the United States any and all lands and interests in lands acquired by the Territorial Government under the provisions of sections 391b, 391b–1, 392c, 396, 396a of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7731313f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-20/ch530/s4"},"text":"June 20, 1938, ch. 530, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/785"},"text":"52 Stat. 785","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77313140-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77313141-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77313142-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of the last provision of section 4 of act ","children":[{"tag":"date","attrib":{"date":"1938-06-20"},"text":"June 20, 1938","children":[],"tail":", the remainder of which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s391b–1"},"text":"section 391b–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id77313143-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77313144-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Admission of Hawaii as State","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Admission of Hawaii into the union was accomplished on ","children":[{"tag":"date","attrib":{"date":"1959-08-21"},"text":"Aug. 21, 1959","children":[],"tail":", on issuance of Proc. No. 3309, "},{"tag":"date","attrib":{"date":"1959-08-21"},"text":"Aug. 21, 1959","children":[],"tail":", 24 F.R. 6868, 73 Stat. c74, as required by sections 1 and 7(c) of "},{"tag":"ref","attrib":{"href":"/us/pl/86/3"},"text":"Pub. L. 86–3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-03-18"},"text":"Mar. 18, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/4"},"text":"73 Stat. 4","children":[],"tail":", set out as notes preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s491"},"text":"section 491 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
