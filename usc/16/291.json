{"tag":"section","attrib":{"id":"id7727badc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s291"},"text":null,"children":[{"tag":"num","attrib":{"value":"291"},"text":"§ 291.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; acceptance of land","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to accept the donation by the State of Indiana of approximately seventeen acres of land comprising the George Rogers Clark Memorial in Vincennes, Indiana, for establishment and administration as the George Rogers Clark National Historical Park.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7727badd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/517/s1"},"text":"Pub. L. 89–517, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-07-23"},"text":"July 23, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/325"},"text":"80 Stat. 325","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
