{"tag":"section","attrib":{"id":"id78057077-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"460qqq–3"},"text":"§ 460qqq–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78057078-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Director of the Bureau of Land Management, shall manage the Conservation Area—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78057079-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner that conserves, protects, and enhances the resources of the Conservation Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7805707a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in accordance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7805707b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"43 U.S.C. 1701","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7805707c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other applicable law, including this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7805707d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7805707e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2002-11-06"},"text":"November 6, 2002","children":[],"tail":", the Secretary, in consultation with the State, the city of Henderson, the County, and any other interested persons, shall develop a management plan for the Conservation Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7805707f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The management plan shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78057080-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the appropriate uses and management of the Conservation Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78057081-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78057082-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" authorize the use of motorized vehicles in the Conservation Area—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id78057083-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/b/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for installing, repairing, maintaining, and reconstructing water development projects, including guzzlers, that would enhance the Conservation Area by promoting healthy, viable, and more naturally distributed wildlife populations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78057084-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/b/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to any limitations that are not more restrictive than the limitations on such uses authorized in wilderness areas under section 208; ","children":[{"tag":"ref","attrib":{"idref":"fn002388"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002388"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78057085-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include or provide recommendations on ways of minimizing the visual impacts of such activities on the Conservation Area;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78057086-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a plan for litter cleanup and public lands awareness campaign on public lands in and around the Conservation Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78057087-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a recommendation on the location for a right-of-way for a rural roadway to provide the city of Henderson with access to the Conservation Area, in accordance with the application numbered N–65874.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78057088-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall allow only such uses of the Conservation Area that the Secretary determines will further the purpose described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460qqq"},"text":"section 460qqq of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78057089-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motorized vehicles","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as needed for administrative purposes or to respond to an emergency, the use of motorized vehicles in the Conservation Area shall be permitted only on roads and trails designated for the use of motorized vehicles by the management plan developed under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7805708a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7805708b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to valid existing rights, all public land in the Conservation Area is withdrawn from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7805708c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all forms of entry and appropriation under the public land laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7805708d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" location, entry, and patent under the mining laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7805708e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operation of the mineral leasing, mineral materials, and geothermal leasing laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7805708f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, if the Secretary acquires mineral or other interests in a parcel of land within the Conservation Area after ","children":[{"tag":"date","attrib":{"date":"2002-11-06"},"text":"November 6, 2002","children":[],"tail":", the parcel is withdrawn from operation of the laws referred to in paragraph (1) on the date of acquisition of the land."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78057090-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hunting, fishing, and trapping","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78057091-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter affects the jurisdiction of the State with respect to fish and wildlife, including hunting, fishing, and trapping in the Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78057092-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78057093-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may designate by regulation areas in which, and establish periods during which, for reasons of public safety, administration, or compliance with applicable laws, no hunting, fishing, or trapping will be permitted in the Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78057094-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except in emergencies, the Secretary shall consult with the appropriate State agency before promulgating regulations under subparagraph (A) that close a portion of the Conservation Area to hunting, fishing, or trapping.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78057095-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No buffer zones","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78057096-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The establishment of the Conservation Area shall not create an express or implied protective perimeter or buffer zone around the Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78057097-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the use of, or conduct of an activity on, private land that shares a boundary with the Conservation Area is consistent with applicable law, nothing in this subchapter concerning the establishment of the Conservation Area shall prohibit or limit the use or conduct of the activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7807e198-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Horizon lateral pipeline right-of-way","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7807e199-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding sections 202 and 503 of the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1712"},"text":"43 U.S.C. 1712","children":[],"tail":", 1763) and subject to valid existing rights and paragraph (3), the Secretary of the Interior, acting through the Director of the Bureau of Land Management (referred to in this subsection as the “Secretary”), shall, not later than 1 year after "},{"tag":"date","attrib":{"date":"2026-05-19"},"text":"May 19, 2026","children":[],"tail":", grant to the Southern Nevada Water Authority (referred to in this subsection as the “Authority”), not subject to the payment of rents or other charges, the temporary and permanent water pipeline infrastructure, and outside the boundaries of the Conservation Area, powerline, facility, and access road rights-of-way depicted on the map for the purposes of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7807e19a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performing geotechnical investigations within the rights-of-way; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7807e19b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constructing and operating water transmission and related facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e19c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excavation and disposal","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7807e19d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority may, without consideration, excavate and use or dispose of sand, gravel, minerals, or other materials from the tunneling of the water pipeline necessary to fulfill the purpose of the rights-of-way granted under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7807e19e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Memorandum of understanding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the date on which the rights-of-way are granted under paragraph (1), the Secretary and the Authority shall enter into a memorandum of understanding identifying Federal land on which the Authority may dispose of materials under subparagraph (A) to further the interests of the Bureau of Land Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e19f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A right-of-way issued under this subsection shall be subject to the following requirements:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7807e1a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may include reasonable terms and conditions, consistent with section 505 of the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1765"},"text":"43 U.S.C. 1765","children":[],"tail":"), as are necessary to protect Conservation Area resources."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7807e1a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Construction of the water pipeline shall not permanently adversely affect conservation area surface resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7807e1a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460qqq–3/h/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The right-of-way shall not be located through or under any area designated as wilderness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7807e1a3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/282/tVI/s605"},"text":"Pub. L. 107–282, title VI, § 605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-06"},"text":"Nov. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2010"},"text":"116 Stat. 2010","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/91/s3/b"},"text":"Pub. L. 119–91, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-05-19"},"text":"May 19, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/822"},"text":"140 Stat. 822","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7807e1a4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7807e1a5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7807e1a6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Land Policy and Management Act of 1976, referred to in subsec. (a)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579"},"text":"Pub. L. 94–579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2743"},"text":"90 Stat. 2743","children":[],"tail":", which is classified principally to chapter 35 (§ 1701 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (a)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/282"},"text":"Pub. L. 107–282","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-06"},"text":"Nov. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1994"},"text":"116 Stat. 1994","children":[],"tail":", known as the Clark County Conservation of Public Land and Natural Resources Act of 2002. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460qqq"},"text":"section 460qqq of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 208, referred to in subsec. (b)(2)(B)(i)(II), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/282/s208"},"text":"section 208 of Pub. L. 107–282","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-06"},"text":"Nov. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2005"},"text":"116 Stat. 2005","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7807e1a7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2026—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/91"},"text":"Pub. L. 119–91","children":[],"tail":" added subsec. (h)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
