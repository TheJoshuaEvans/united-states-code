{"tag":"section","attrib":{"id":"id7a016867-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5726"},"text":null,"children":[{"tag":"num","attrib":{"value":"5726"},"text":"§ 5726.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Yukon River salmon stock restoration and enhancement projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a016868-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5726/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior, in consultation with the Secretary of Commerce, may carry out projects to restore or enhance salmon stocks originating from the Yukon River in Canada and the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a016869-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5726/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation with Canada","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If there is in effect an agreement between the Government of the United States and the Government of Canada for the conservation of salmon stocks originating from the Yukon River in Canada that includes provisions governing projects authorized under this section, then—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a01686a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5726/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects under this section shall be carried out in accordance with that agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a01686b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5726/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" amounts available for projects under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a01686c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5726/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be expended in accordance with the agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a01686d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5726/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be deposited in any joint account established by the agreement to fund such projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a01686e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/450/tII/s207"},"text":"Pub. L. 106–450, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1944"},"text":"114 Stat. 1944","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
