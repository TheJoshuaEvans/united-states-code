{"tag":"section","attrib":{"id":"id77208ede-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s251m"},"text":null,"children":[{"tag":"num","attrib":{"value":"251m"},"text":"§ 251m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is hereby authorized to be appropriated not to exceed $23,700,000 for the acquisition of lands, privately owned aquatic lands, or interests therein in accordance with the provisions of sections 251e to 251m of this title. No funds authorized to be appropriated pursuant to sections 251e to 251m of this title shall be available prior to ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"October 1, 1977","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77208edf-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/578/tIII/s320/j"},"text":"Pub. L. 94–578, title III, § 320(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2741"},"text":"90 Stat. 2741","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/199/tI/s110"},"text":"Pub. L. 96–199, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-05"},"text":"Mar. 5, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/70"},"text":"94 Stat. 70","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77208ee0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77208ee1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77208ee2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 251e to 251m of this title, referred to in text, was in the original “this title”, meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/578"},"text":"Pub. L. 94–578","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77208ee3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/199"},"text":"Pub. L. 96–199","children":[],"tail":" substituted “$23,700,000” for “$13,000,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
