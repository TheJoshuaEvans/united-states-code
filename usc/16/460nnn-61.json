{"tag":"section","attrib":{"id":"id7800b63a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–61"},"text":null,"children":[{"tag":"num","attrib":{"value":"460nnn–61"},"text":"§ 460nnn–61.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of Steens Mountain Wilderness Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Federal lands in the Cooperative Management and Protection Area depicted as wilderness on the map entitled “Steens Mountain Wilderness Area” and dated ","children":[{"tag":"date","attrib":{"date":"2000-09-18"},"text":"September 18, 2000","children":[],"tail":", are hereby designated as wilderness and therefore as a component of the National Wilderness Preservation System. The wilderness area shall be known as the Steens Mountain Wilderness Area."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7800b63b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/399/tII/s201"},"text":"Pub. L. 106–399, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1666"},"text":"114 Stat. 1666","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7800b63c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7800b63d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7800b63e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/399/s201"},"text":"section 201 of Pub. L. 106–399","children":[],"tail":". Section 201 also enacted provisions listed in a table of Wilderness Areas set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1132"},"text":"section 1132 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
