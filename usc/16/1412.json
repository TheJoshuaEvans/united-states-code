{"tag":"section","attrib":{"id":"id792ab6d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1412"},"text":null,"children":[{"tag":"num","attrib":{"value":"1412"},"text":"§ 1412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International Dolphin Conservation Program","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of State, in consultation with the Secretary, shall seek to secure a binding international agreement to establish an International Dolphin Conservation Program that requires—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792ab6d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1412/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the total annual dolphin mortality in the purse seine fishery for yellowfin tuna in the eastern tropical Pacific Ocean shall not exceed 5,000 animals with a commitment and objective to progressively reduce dolphin mortality to a level approaching zero through the setting of annual limits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792ab6da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1412/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of a per-stock per-year dolphin mortality limit, to be in effect through calendar year 2000, at a level between 0.2 percent and 0.1 percent of the minimum population estimate, as calculated, revised, or approved by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792ab6db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1412/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of a per-stock per-year dolphin mortality limit, beginning with the calendar year 2001, at a level less than or equal to 0.1 percent of the minimum population estimate as calculated, revised, or approved by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792ab6dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1412/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that if a dolphin mortality limit is exceeded under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792ab6dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1412/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paragraph (1), all sets on dolphins shall cease for the applicable fishing year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792ab6de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1412/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paragraph (2) or (3), all sets on the stocks covered under paragraph (2) or (3) and any mixed schools that contain any of those stocks shall cease for the applicable fishing year;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792ab6df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1412/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a scientific review and assessment to be conducted in calendar year 1998 to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792ab6e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1412/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess progress in meeting the objectives set for calendar year 2000 under paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792ab6e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1412/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as appropriate, consider recommendations for meeting these objectives;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792ab6e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1412/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a scientific review and assessment to be conducted in calendar year 2000—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792ab6e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1412/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to review the stocks covered under paragraph (3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792ab6e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1412/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as appropriate to consider recommendations to further the objectives set under that paragraph;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792ab6e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1412/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of a per vessel maximum annual dolphin mortality limit consistent with the established per-year mortality limits, as determined under paragraphs (1) through (3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792ab6e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1412/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of a system of incentives to vessel captains to continue to reduce dolphin mortality, with the goal of eliminating dolphin mortality.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id792ab6e7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522/tIII/s302"},"text":"Pub. L. 92–522, title III, § 302","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/42/s6/c"},"text":"Pub. L. 105–42, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-15"},"text":"Aug. 15, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1130"},"text":"111 Stat. 1130","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id792ab6e8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id792ab6e9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id792ab6ea-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1412, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522/tIII/s302"},"text":"Pub. L. 92–522, title III, § 302","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/523/s2/a"},"text":"Pub. L. 102–523, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-26"},"text":"Oct. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3426"},"text":"106 Stat. 3426","children":[],"tail":", related to international agreements to establish global moratorium to prohibit certain tuna harvesting practices prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/42/s6/c"},"text":"Pub. L. 105–42, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-15"},"text":"Aug. 15, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1130"},"text":"111 Stat. 1130","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522/s302"},"text":"section 302 of Pub. L. 92–522","children":[],"tail":" was renumbered section 402 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1421a"},"text":"section 1421a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id792ab6eb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id792ab6ec-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/42/s8"},"text":"section 8 of Pub. L. 105–42","children":[],"tail":", set out as an Effective Date of 1997 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1362"},"text":"section 1362 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
