{"tag":"section","attrib":{"id":"id77f4ce66-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ccc–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"460ccc–5"},"text":"§ 460ccc–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal; exchange of lands","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77f4ce67-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ccc–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as specifically authorized in this subchapter, and subject to valid existing rights, all Federal lands within the conservation area and all lands and interests therein which are acquired by the United States after ","children":[{"tag":"date","attrib":{"date":"1990-11-16"},"text":"November 16, 1990","children":[],"tail":", for inclusion in the conservation area are withdrawn from all forms of entry, appropriation, or disposal under the public land laws, from location, entry, and patent under the mining laws, and from operation under the mineral leasing and geothermal leasing laws, and all amendments thereto."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f4ce68-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ccc–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may transfer to the owner of the Old Nevada recreation facility the approximately 20 acres of Federal lands within the conservation area which, on ","children":[{"tag":"date","attrib":{"date":"1994-03-01"},"text":"March 1, 1994","children":[],"tail":", were used to provide parking for visitors to such facility, in exchange for lands of equal or greater value within the conservation area acceptable to the Secretary."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77f4ce69-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/621/s7"},"text":"Pub. L. 101–621, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3344"},"text":"104 Stat. 3344","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/450/s2/b"},"text":"Pub. L. 103–450, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4766"},"text":"108 Stat. 4766","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77f4ce6a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77f4ce6b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77f4ce6c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/450"},"text":"Pub. L. 103–450","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
