{"tag":"section","attrib":{"id":"id7708c13a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s141b"},"text":null,"children":[{"tag":"num","attrib":{"value":"141b"},"text":"§ 141b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wind Cave National Game Preserve transferred to park","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Effective ","children":[{"tag":"date","attrib":{"date":"1935-07-01"},"text":"July 1, 1935","children":[],"tail":", the Wind Cave National Game Preserve in the State of South Dakota is abolished, and all the property, real or personal, comprising the same is transferred to and made a part of the Wind Cave National Park and the same shall be administered by the Secretary of the Interior as a part of said park, subject to all laws and regulations applicable thereto, for the purposes expressed in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s672"},"text":"section 672 of this title","children":[],"tail":", establishing said game preserve."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7708c13b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-06-15/ch261"},"text":"June 15, 1935, ch. 261","children":[],"tail":", title VI, § 601, "},{"tag":"ref","attrib":{"href":"/us/stat/49/383"},"text":"49 Stat. 383","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7708c13c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7708c13d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7708c13e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},