{"tag":"section","attrib":{"id":"id79c103a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3637"},"text":null,"children":[{"tag":"num","attrib":{"value":"3637"},"text":"§ 3637.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited acts and penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79c103a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3637/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful acts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is unlawful for any person or vessel subject to the jurisdiction of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79c103a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3637/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to violate any provision of this chapter, or of any regulation adopted hereunder, or of any Fraser River Panel regulation approved by the United States under the Treaty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c103a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3637/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to refuse to permit any officer authorized to enforce the provisions of this chapter to board a fishing vessel subject to such person’s control for purposes of conducting any search, investigation, or inspection in connection with the enforcement of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c103a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3637/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to forcibly assault, resist, oppose, impede, intimidate, or interfere with any such authorized officer in the conduct of any search, investigation, or inspection described in paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c103a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3637/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to resist a lawful arrest for any act prohibited by this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c103a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3637/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ship, transport, offer for sale, sell, purchase, import, export, or have custody, control, or possession of, any fish taken or retained in violation of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c103aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3637/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to interfere with, delay, or prevent, by any means, the apprehension or arrest of another person, knowing that such other person has committed any act prohibited by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c103ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3637/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional prohibitions and enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For additional prohibitions relating to this chapter and enforcement of this chapter, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1826g"},"text":"section 1826g of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79c103ac-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/5/s8"},"text":"Pub. L. 99–5, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-03-15"},"text":"Mar. 15, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/12"},"text":"99 Stat. 12","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/81/tI/s104"},"text":"Pub. L. 114–81, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-05"},"text":"Nov. 5, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/657"},"text":"129 Stat. 657","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79c103ad-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79c103ae-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79c103af-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/81/s104/1/B"},"text":"Pub. L. 114–81, § 104(1)(B)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to “this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/81/s104/1/A"},"text":"Pub. L. 114–81, § 104(1)(A)","children":[],"tail":", inserted “, investigation,” after “search”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/81/s104/2"},"text":"Pub. L. 114–81, § 104(2)","children":[],"tail":", inserted “, investigation,” after “search” and substituted “paragraph (2);” for “subparagraph (2);”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/81/s104/3"},"text":"Pub. L. 114–81, § 104(3)","children":[],"tail":", made technical amendment to reference in original act which appears as a reference to “this chapter” and struck out “or” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/81/s104/4"},"text":"Pub. L. 114–81, § 104(4)","children":[],"tail":", added subsec. (b) and struck out former subsecs. (b) to (f), which related to civil penalty, criminal penalty, forfeiture, enforcement authority, and jurisdiction."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79c103b0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id79c103b1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
