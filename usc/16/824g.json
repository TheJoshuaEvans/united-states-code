{"tag":"section","attrib":{"id":"id78ac5f37-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824g"},"text":null,"children":[{"tag":"num","attrib":{"value":"824g"},"text":"§ 824g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ascertainment of cost of property and depreciation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78ac5f38-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigation of property costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may investigate and ascertain the actual legitimate cost of the property of every public utility, the depreciation therein, and, when found necessary for rate-making purposes, other facts which bear on the determination of such cost or depreciation, and the fair value of such property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ac5f39-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request for inventory and cost statements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every public utility upon request shall file with the Commission an inventory of all or any part of its property and a statement of the original cost thereof, and shall keep the Commission informed regarding the cost of all additions, betterments, extensions, and new construction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78ac5f3a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-10/ch285"},"text":"June 10, 1920, ch. 285","children":[],"tail":", pt. II, § 208, as added "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-26/ch687"},"text":"Aug. 26, 1935, ch. 687","children":[],"tail":", title II, § 213, "},{"tag":"ref","attrib":{"href":"/us/stat/49/853"},"text":"49 Stat. 853","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
