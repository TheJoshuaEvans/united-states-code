{"tag":"section","attrib":{"id":"id77c051a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460j"},"text":null,"children":[{"tag":"num","attrib":{"value":"460j"},"text":"§ 460j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of proceeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The proceeds from any sale made under this subchapter shall be covered into the Treasury of the United States as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77c051a7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-06/ch987/s6"},"text":"Aug. 6, 1956, ch. 987, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/1066"},"text":"70 Stat. 1066","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
