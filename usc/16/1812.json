{"tag":"section","attrib":{"id":"id7963eedd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1812"},"text":null,"children":[{"tag":"num","attrib":{"value":"1812"},"text":"§ 1812.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Highly migratory species","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7963eede-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1812/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States shall cooperate directly or through appropriate international organizations with those nations involved in fisheries for highly migratory species with a view to ensuring conservation and shall promote the achievement of optimum yield of such species throughout their range, both within and beyond the exclusive economic zone.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7963eedf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1812/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Traditional participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In managing any fisheries under an international fisheries agreement to which the United States is a party, the appropriate Council or Secretary shall take into account the traditional participation in the fishery, relative to other nations, by fishermen of the United States on fishing vessels of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7963eee0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1812/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion of stock management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a relevant international fisheries organization does not have a process for developing a formal plan to rebuild a depleted stock, an overfished stock, or a stock that is approaching a condition of being overfished, the provisions of this chapter in this regard shall be communicated to and promoted by the United States in the international or regional fisheries organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7963eee1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265/tI/s102"},"text":"Pub. L. 94–265, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-13"},"text":"Apr. 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/336"},"text":"90 Stat. 336","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/659/tI/s101/b"},"text":"Pub. L. 99–659, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3707"},"text":"100 Stat. 3707","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/627/tI/s103/a"},"text":"Pub. L. 101–627, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4439"},"text":"104 Stat. 4439","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/297/tI/s104"},"text":"Pub. L. 104–297, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3563"},"text":"110 Stat. 3563","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/479/s4"},"text":"Pub. L. 109–479, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3578"},"text":"120 Stat. 3578","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7963eee2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7963eee3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7963eee4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265"},"text":"Pub. L. 94–265","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-13"},"text":"Apr. 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/331"},"text":"90 Stat. 331","children":[],"tail":", known as the Magnuson-Stevens Fishery Conservation and Management Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1801"},"text":"section 1801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7963eee5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/479"},"text":"Pub. L. 109–479","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsecs. (b) and (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/297"},"text":"Pub. L. 104–297","children":[],"tail":" substituted “shall promote the achievement of optimum yield” for “promoting the objective of optimum utilization”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/627"},"text":"Pub. L. 101–627","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “The sovereign rights and exclusive fishery management authority asserted by the United States under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1811"},"text":"section 1811 of this title","children":[],"tail":" over fish do not include, and may not be construed to extend to, highly migratory species of fish.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/659"},"text":"Pub. L. 99–659","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “The United States shall exercise exclusive fishery management authority, in the manner provided for in this chapter, over the following:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) All fish within the fishery conservation zone.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) All anadromous species throughout the migratory range of each such species beyond the fishery conservation zone; except that such management authority shall not extend to such species during the time they are found within any foreign nation’s territorial sea or fishery conservation zone (or the equivalent), to the extent that such sea or zone is recognized by the United States.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) All Continental Shelf fishery resources beyond the fishery conservation zone.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7963eee6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7963eee7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/627/tI/s103/c"},"text":"Pub. L. 101–627, title I, § 103(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4439"},"text":"104 Stat. 4439","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/627/tI/s103/c"},"text":"“The amendments made by this section [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1992-01-01"},"text":"January 1, 1992","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
