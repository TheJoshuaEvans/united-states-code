{"tag":"section","attrib":{"id":"id77c9eea1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460u–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"460u–2"},"text":"§ 460u–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direction for establishment; publication in Federal Register; continuing acquisition of lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"1966-11-05"},"text":"November 5, 1966","children":[],"tail":", and following the acquisition by the Secretary of an acreage within the boundaries of the area described in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460u"},"text":"section 460u of this title","children":[],"tail":" which in his opinion is efficiently administrable for the purposes of this subchapter, he shall establish the Indiana Dunes National Park by publication of notice thereof in the Federal Register. By no later than "},{"tag":"date","attrib":{"date":"1977-10-01"},"text":"October 1, 1977","children":[],"tail":", the Secretary shall publish in the Federal Register a detailed description of the boundaries of the Park and shall from time to time so publish any additional boundary changes as may occur. Following such establishment and subject to the limitations and conditions prescribed in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460u"},"text":"section 460u of this title","children":[],"tail":", the Secretary may continue to acquire lands and interests in lands for the Park."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77c9eea2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/761/s3"},"text":"Pub. L. 89–761, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-05"},"text":"Nov. 5, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1309"},"text":"80 