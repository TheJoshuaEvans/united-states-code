{"tag":"section","attrib":{"id":"id7a3d11ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8545"},"text":null,"children":[{"tag":"num","attrib":{"value":"8545"},"text":"§ 8545.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forest Service and Bureau of Land Management temporary special recreation permits for outfitting and guiding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a3d11eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8545/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretary concerned shall establish and implement a program to authorize the issuance of temporary special recreation permits for new or additional recreational uses of Federal recreational land and water managed by the Forest Service and the Bureau of Land Management."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3d11ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8545/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of temporary permits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A temporary special recreation permit issued under paragraph (1) ","children":[{"tag":"ref","attrib":{"idref":"fn002881"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002881"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection (a)”."}],"tail":" shall be issued for a period of not more than 2 years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3d11ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8545/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conversion to long-term permit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary concerned determines that a permittee under paragraph (1) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" has completed 2 years of satisfactory operation under the permit proposed to be converted, the Secretary may provide for the conversion of a temporary special recreation permit issued under paragraph (1) "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" to a long-term special recreation permit."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3d11ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8545/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection ","children":[{"tag":"ref","attrib":{"idref":"fn002882"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002882"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “this section”."}],"tail":" alters or affects the authority of the Secretary to issue a special recreation permit under subsection (h)(1) of "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6802"},"text":"section 6802 of this title","children":[],"tail":" (as amended by this title)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7