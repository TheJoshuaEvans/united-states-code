{"tag":"section","attrib":{"id":"id788af43d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s742d"},"text":null,"children":[{"tag":"num","attrib":{"value":"742d"},"text":"§ 742d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigations; preparation and dissemination of information; reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id788af43e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s742d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002501"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002501"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No subsec. (b) has been enacted."}],"tail":" The Secretary shall conduct continuing investigations, prepare and disseminate information, and make periodical reports to the public, to the President, and to Congress, with respect to the following matters:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id788af43f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s742d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The production and flow to market of fish and fishery products domestically produced, and also those produced by foreign producers which affect the domestic fisheries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id788af440-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s742d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The availability and abundance and the biological requirements of the fish and wildlife resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id788af441-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s742d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The competitive economic position of the various fish and fishery products with respect to each other, and with respect to competitive domestic and foreign-produced commodities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id788af442-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s742d/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The collection and dissemination of statistics on commercial and sport fishing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id788af443-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s742d/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The collection and dissemination of statistics on the nature and availability of wildlife, progress in acquisition of additional refuges and measures being taken to foster a coordinated program to encourage and develop wildlife values;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id788af444-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s742d/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The improvement of production and marketing practices in regard to commercial species and the conduct of educational and extension services relative to commercial and sport fishing, and wildlife matters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id788af445-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s742d/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other matters which in the judgment of the Secretary are of public interest in connection with any phases of fish and wildlife operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id788af446-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-08/ch1036/s5"},"text":"Aug. 8, 1956, ch. 1036, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/1121"},"text":"70 Stat. 1121","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id788af447-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id788af448-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id788af449-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions of law requiring submittal to Congress of any annual, semiannual, or other regular periodic report listed in House Document No. 103–7 (in which a report to Congress required under this section is listed on page 54), see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id788af44a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id788af44b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of functions to Secretary of Commerce from Secretary of the Interior by Reorg. Plan No. 4 of 1970, eff. ","children":[{"tag":"date","attrib":{"date":"1970-10-03"},"text":"Oct. 3, 1970","children":[],"tail":", 35 F.R. 15627, "},{"tag":"ref","attrib":{"href":"/us/stat/84/2090"},"text":"84 Stat. 2090","children":[],"tail":", see note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s742b"},"text":"section 742b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
