{"tag":"section","attrib":{"id":"id79a45388-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2810"},"text":null,"children":[{"tag":"num","attrib":{"value":"2810"},"text":"§ 2810.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclaimer","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to amend, repeal, or otherwise modify the authority of any Federal officer, department, or agency to perform any function, responsibility, or activity authorized under any other provision of law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79a45389-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/362/s11"},"text":"Pub. L. 96–362, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1206"},"text":"94 Stat. 1206","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
