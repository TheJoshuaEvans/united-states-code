{"tag":"section","attrib":{"id":"id77681fc5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–55"},"text":null,"children":[{"tag":"num","attrib":{"value":"410aaa–55"},"text":"§ 410aaa–55.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of visitor center","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to construct a visitor center in the preserve for the purpose of providing information through appropriate displays, printed material, and other interpretive programs, about the resources of the preserve.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77681fc6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/tV/s515"},"text":"Pub. L. 103–433, title V, § 515","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4494"},"text":"108 Stat. 4494","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
