{"tag":"section","attrib":{"id":"id784a8fb3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s579c–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"579c–1"},"text":"§ 579c–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forest Service interest bearing account","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id784a8fb4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s579c–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any monies covered into the Treasury under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s579c"},"text":"section 579c of this title","children":[],"tail":", including all monies that were previously collected by the United States in a forfeiture, judgment, compromise, or settlement, shall be invested by the Secretary of the Treasury in interest bearing obligations of the United States to the extent the amounts are not, in the judgment of the Secretary of the Treasury, required to meet current withdrawals."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id784a8fb5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s579c–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any interest earned under subsection (a) shall be available in the same manner as the monies covered into the Treasury under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s579c"},"text":"section 579c of this title","children":[],"tail":" to cover the costs to the United States specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s579c"},"text":"section 579c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id784a8fb6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s579c–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any portion of the monies received or earned under subsection (a) in excess of the amount expended in performing the work necessitated by the action which led to their receipt may be used to cover the other work specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s579c"},"text":"section 579c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id784a8fb7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s579c–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to fiscal year 2023 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id784a8fb8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dG/tIV/s441"},"text":"Pub. L. 117–328, div. G, title IV, § 441","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4832"},"text":"136 Stat. 4832","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
