{"tag":"section","attrib":{"id":"id77e6779b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"460ss–3"},"text":"§ 460ss–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Klamath River Basin Fisheries Task Force","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77e6779c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a Klamath River Basin Fisheries Task Force (hereafter in this subchapter referred to as the “Task Force”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e6779d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Task Force—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e6779e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall assist the Secretary in the formulation, coordination, and implementation of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e6779f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall assist, and coordinate its activities with, Federal, State, and local governmental or private anadromous fish restoration projects within the Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e677a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall conduct any other activity that is necessary to accomplish the objectives of the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e677a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may act as an advisor to the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e677a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership and appointment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Task Force is composed of 14 members as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e677a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A representative, who shall be appointed by the Governor of California, of each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77e677a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The commercial salmon fishing industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e677a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The in-river sport fishing community.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e677a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The California Department of Fish and Game.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e677a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A representative of the Hoopa Indian Tribe who shall be appointed by the Hoopa Valley Business Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e677a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A representative of the Department of the Interior who shall be appointed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e677a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A representative of the National Marine Fisheries Service who shall be appointed by the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e677aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A representative of the Department of Agriculture who shall be appointed by the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e677ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A representative of the Oregon Department of Fish and Wildlife who shall be appointed by the Governor of Oregon.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e677ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One individual who shall be appointed by the Board of Supervisors of Del Norte County, California.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e677ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One individual who shall be appointed by the Board of Supervisors of Siskiyou County, California.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e677ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One individual who shall be appointed by the Board of Supervisors of Humboldt County, California.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e677af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One individual who shall be appointed by the Board of Supervisors of Trinity County, California.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e677b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A representative of the Karuk Tribe, who shall be appointed by the governing body of the Tribe,","children":[{"tag":"ref","attrib":{"idref":"fn002338"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002338"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should be a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e677b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/c/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A representative of the Yurok Tribe, who shall be appointed by the Secretary until such time as the Yurok Tribe is organized upon which time the Yurok Tribe shall appoint such representative beginning with the first appointment ordinarily occurring after the Yurok Tribe is organized ","children":[{"tag":"ref","attrib":{"idref":"fn002339"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002339"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be followed by a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e677b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council membership not a bar to Task Force appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual who is a member of the Council is not ineligible for appointment as a member of the Task Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e677b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e677b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of a member of the Task Force is 4 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e677b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Task Force serve at the pleasure of the appointing authorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e677b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vacancy on the Task Force shall be filled in the manner in which the original appointment was made. Any member appointed to fill a vacancy occurring before the expiration of the term for which his predecessor was appointed shall be appointed only for the remainder of such term. A member may serve after the expiration of his term until his successor has taken office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e677b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transaction of business","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e677b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Task Force shall establish practices and procedures for the carrying out of its functions under subsection (b). The procedures shall include the requirement that a quorum of the Task Force must be present before business may be transacted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e677b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairman","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Task Force shall select a Chairman from among its members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e677ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Task Force shall meet at the call of the Chairman or upon the request of a majority of its members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e677bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff and administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e677bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Director of the California Department of Fish and Game shall provide the Task Force with the administrative and technical support services necessary for the effective functioning of the Task Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e677bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Director of the California Department of Fish and Game shall furnish the members of the Task Force with relevant information concerning the Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e677be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Task Force shall determine its organization, and prescribe the practices and procedures for carrying out its functions under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e677bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members who are Federal or State employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any Task Force member who is an officer or employee of the United States, the State of California, or the State of Oregon at the time of appointment to the Task Force shall cease to be a member of the Task Force within 14 days of the date on which he ceases to be so employed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e677c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e677c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"While away from their homes or regular places of business in the performance of services for the Task Force, Task Force members shall be allowed travel expenses, including a per diem allowance in lieu of subsistence, in the same manner as persons employed intermittently in the Government service are allowed travel expenses under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":". Any Task Force member who is an employee of an agency or governmental unit and is eligible for travel expenses from that agency or unit for performing services for the Task Force is not eligible for travel expenses under this paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e677c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on spending authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No money authorized to be appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460ss–5"},"text":"section 460ss–5 of this title","children":[],"tail":" may be used to reimburse any agency or governmental unit (whose employees are Task Force members) for time spent by any such employee performing Task Force duties."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e677c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership increase upon program expansion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At such time as the program is expanded to include portions of the Klamath River upstream from the Iron Gate dam, membership on the Task Force shall be increased to include the following—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e677c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One individual who shall be appointed by the Commissioners of Klamath County, Oregon.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e677c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ss–3/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A representative of the Klamath Tribe, who shall be appointed by the governing body of the Tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77e677c6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/552/s4"},"text":"Pub. L. 99–552, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3084"},"text":"100 Stat. 3084","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/580/s12/a"},"text":"Pub. L. 100–580, § 12(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2935"},"text":"102 Stat. 2935","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/653/tVI"},"text":"Pub. L. 100–653, title VI","children":[],"tail":", §§ 601, 602(b), 603(1), "},{"tag":"date","attrib":{"date":"1988-11-14"},"text":"Nov. 14, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3829"},"text":"102 Stat. 3829","children":[],"tail":", 3830; "},{"tag":"ref","attrib":{"href":"/us/pl/102/570/s2"},"text":"Pub. L. 102–570, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4490"},"text":"106 Stat. 4490","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77e677c7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77e677c8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77e677c9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/570"},"text":"Pub. L. 102–570","children":[],"tail":" added subsec. (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/580/s12/a/A"},"text":"Pub. L. 100–580, § 12(a)(A)","children":[],"tail":", substituted “14” for “12” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(11), (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/580/s12/a/B"},"text":"Pub. L. 100–580, § 12(a)(B)","children":[],"tail":", added pars. (11) and (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/653/s602/b"},"text":"Pub. L. 100–653, § 602(b)","children":[],"tail":", substituted “Procedures” for “Decisions of Task Force” as par. heading and amended text generally. Prior to amendment, text read as follows: “All decisions of the Task Force must be by unanimous vote of all the members.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/653/s603/1"},"text":"Pub. L. 100–653, § 603(1)","children":[],"tail":", substituted “, the State of California, or the State of Oregon” for “or the State of California”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/653/s601"},"text":"Pub. L. 100–653, § 601","children":[],"tail":", substituted “Expenses” for “Limitation on spending authority” in heading and amended text generally, designating existing provisions as par. (2) and adding par. (1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77e677ca-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77e677cb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Special Rule","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/580/s12/b"},"text":"Pub. L. 100–580, § 12(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2935"},"text":"102 Stat. 2935","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/580/s12/b"},"text":"“The initial term of the representative appointed pursuant to section 4(c)(11) and (12) of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460ss–3/c/11"},"text":"16 U.S.C. 460ss–3(c)(11)","children":[],"tail":", (12)] (as added by the amendment made by subsection (a)) shall be for that time which is the remainder of the terms of the members of the Task Force then serving. Thereafter, the term of such representatives shall be as provided in section 4(e) of such Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
