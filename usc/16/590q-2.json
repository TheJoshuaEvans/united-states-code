{"tag":"section","attrib":{"id":"id78569df2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s590q–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"590q–2"},"text":"§ 590q–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary relinquishment of allotments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary may provide for the reduction or cancellation of any allotment or base when the owner of the farm states in writing that he has no further use of such allotment or base.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78569df3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/524/tVIII/s803"},"text":"Pub. L. 91–524, title VIII, § 803","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-11-30"},"text":"Nov. 30, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1381"},"text":"84 Stat. 1381","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78569df4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78569df5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78569df6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Agriculture Act of 1970, and not as part of the Soil Conservation and Domestic Allotment Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
