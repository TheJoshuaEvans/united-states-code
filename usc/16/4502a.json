{"tag":"section","attrib":{"id":"id79f09e93-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4502a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4502a"},"text":"§ 4502a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tropical forestry research and assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79f09e94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4502a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To promote sound management and conservation of tropical forests of the United States and to promote the development and transfer of technical, managerial, educational, and administrative skills to managers of tropical forests within or outside the United States, the Secretary of Agriculture is authorized to provide assistance through the Forest Service to eligible entities in States with tropical forests to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f09e95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4502a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop, promote, and demonstrate sustainable harvesting of native woods and other forest products on a sustainable yield basis in balance with natural resource conservation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f09e96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4502a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote habitat preservation and species protection or recovery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f09e97-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4502a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect indigenous plant and animal species and essential watersheds from non-native animals, plants, and pathogens;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f09e98-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4502a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish biological control agents for non-native species that threaten natural ecosystems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f09e99-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4502a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a monitoring system in tropical forests to identify baseline conditions and determine detrimental changes or improvements over time;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f09e9a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4502a/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detect and appraise stresses affecting tropical forests caused by insect infestations, diseases, pollution, fire, and non-native animal and plant species, and by the influence of people;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f09e9b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4502a/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the causes of changes that are detected through experimentation, intensive monitoring, and data collection at affected tropical forest sites; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f09e9c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4502a/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage in research, demonstration, education, training, and outreach that furthers the objectives of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f09e9d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4502a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance provided to eligible entities under this section may be in the form of grants, contracts, or cooperative agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f09e9e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4502a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f09e9f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4502a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible entity” means a State forester or equivalent State official, State, political subdivision of a State, Federal agency, private organization, corporation, or other private person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f09ea0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4502a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the 50 States, Guam, American Samoa, the Republic of Palau (until the Compact of Free Association enters into effect), Puerto Rico, the Virgin Islands, and the Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f09ea1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/574/s3"},"text":"Pub. L. 102–574, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4596"},"text":"106 Stat. 4596","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79f09ea2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79f09ea3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79f09ea4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For ","children":[{"tag":"date","attrib":{"date":"1994-10-01"},"text":"Oct. 1, 1994","children":[],"tail":", as the date the Compact of Free Association with the Republic of Palau enters into effect, referred to in subsec. (c)(2), see Proc. No. 6726, "},{"tag":"date","attrib":{"date":"1994-09-27"},"text":"Sept. 27, 1994","children":[],"tail":", 59 F.R. 49777, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1931"},"text":"section 1931 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79f09ea5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Hawaii Tropical Forest Recovery Act, and not as part of the International Forestry Cooperation Act of 1990 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79f09ea6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79f09ea7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/574/s5"},"text":"Pub. L. 102–574, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4599"},"text":"106 Stat. 4599","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/574/s5"},"text":"“There are authorized to be appropriated such sums as are necessary to carry out sections 3 and 4 [enacting this section and provisions set out as a note under 4503a of this title].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
