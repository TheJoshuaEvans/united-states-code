{"tag":"section","attrib":{"id":"id77a8838e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450ss–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"450ss–5"},"text":"§ 450ss–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on funding","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Authorization of Appropriations: ","children":[{"tag":"ref","attrib":{"idref":"fn002273"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002273"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. “Appropriations” probably should not be capitalized."}],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id77a8838f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450ss–5/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In furtherance of the purposes of sections 450ss to 450ss–7 of this title, the Secretary may provide, from the National Park Service’s National Recreation and Preservation account, the remainder of the sum of $5,000,000 for an endowment fund subject to paragraph (2), to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77a88390-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450ss–5/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated in any fiscal year to carry out the provisions of sections 450ss to 450ss–7 may only be expended on a matching basis in a ratio of at least one non-Federal dollar to every Federal dollar. For the purposes of this provision, each non-Federal dollar donated to the Foundation for the creation, maintenance, operation, or endowment of the Memorial shall satisfy the matching dollar requirement without regard to the fiscal year in which such donation is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77a88391-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/58/s7"},"text":"Pub. L. 105–58, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-10-09"},"text":"Oct. 9, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1266"},"text":"111 Stat. 1266","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/199/dF/tV/s544/f"},"text":"Pub. L. 108–199, div. F, title V, § 544(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/348"},"text":"118 Stat. 348","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dH/tXCV/s9501"},"text":"Pub. L. 116–283, div. H, title XCV, § 9501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4822"},"text":"134 Stat. 4822","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77a88392-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77a88393-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77a88394-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “the Secretary may provide, from the National Park Service’s National Recreation and Preservation account, the remainder of” for “there is hereby authorized”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/s544/f/1"},"text":"Pub. L. 108–199, § 544(f)(1)","children":[],"tail":", inserted “for an endowment fund subject to paragraph (2)” after “the sum of $5,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/s544/f/2"},"text":"Pub. L. 108–199, § 544(f)(2)","children":[],"tail":", struck out “Trust or to the Oklahoma City Memorial” after “each non-Federal dollar donated to the” and substituted “operation, or endowment” for “or operation”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
