{"tag":"section","attrib":{"id":"id77681f6f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–28"},"text":null,"children":[{"tag":"num","attrib":{"value":"410aaa–28"},"text":"§ 410aaa–28.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Visitor center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77681f70-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–28/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire not more than 5 acres of land and interests in land, and improvements on the land and interests, outside the boundaries of the park, in the unincorporated village of Joshua Tree, for the purpose of operating a visitor center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77681f71-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–28/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall modify the boundary of the park to include the land acquired under this section as a noncontiguous parcel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77681f72-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–28/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Land and facilities acquired under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77681f73-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–28/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include the property owned (as of ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":") by the Joshua Tree National Park Association and commonly referred to as the “Joshua Tree National Park Visitor Center”;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77681f74-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–28/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be administered by the Secretary as part of the park; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77681f75-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–28/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be acquired only with the consent of the owner, by donation, purchase with donated or appropriated funds, or exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77681f76-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/tIV/s408"},"text":"Pub. L. 103–433, title IV, § 408","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tI/s1433/e"},"text":"Pub. L. 116–9, title I, § 1433(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/701"},"text":"133 Stat. 701","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77681f77-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77681f78-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77681f79-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/s103"},"text":"Section 103 of Pub. L. 103–433","children":[],"tail":" provided in part that in this subchapter “Secretary” means the Secretary of the Interior."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
