{"tag":"section","attrib":{"id":"id780326b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–122"},"text":null,"children":[{"tag":"num","attrib":{"value":"460nnn–122"},"text":"§ 460nnn–122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of land and water conservation fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id780326b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $25,000,000 from the land and water conservation fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s200302"},"text":"section 200302 of title 54","children":[],"tail":" to provide funds for the acquisition of land and interests in land under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460nnn–24"},"text":"section 460nnn–24 of this title","children":[],"tail":" and to enter into nondevelopment easements and conservation easements under subsections (b) and (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460nnn–42"},"text":"section 460nnn–42 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780326ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated pursuant to the authorization of appropriations in subsection (a) shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag"