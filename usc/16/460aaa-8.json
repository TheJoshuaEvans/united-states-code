{"tag":"section","attrib":{"id":"id77f01480-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaa–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"460aaa–8"},"text":"§ 460aaa–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77f01481-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaa–8/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated an amount not to exceed $5,000,000 for the acquisition of land, interests in land, or structures within the national recreation area and on the mainland as needed for access and administrative facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f01482-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aaa–8/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the amounts authorized to be appropriated under subsection (a), there are authorized to be appropriated not more than $5,000,000 for development to carry out the other purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77f01483-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/292/s9"},"text":"Pub. L. 101–292, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-05-17"},"text":"May 17, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/190"},"text":"104 Stat. 190","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
