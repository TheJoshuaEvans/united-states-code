{"tag":"section","attrib":{"id":"id792f9924-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1423e"},"text":"§ 1423e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Votes taken by the United States section on matters before the Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In accordance with paragraph 3 of article 8 of the Agreement, the United States section, made up of commissioners appointed by the President, shall vote on any issue before the United States-Russia Polar Bear Commission only if there is no disagreement between the United States commissioners regarding the vote.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id792f9925-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522/tV/s506"},"text":"Pub. L. 92–522, title V, § 506","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/479/tIX/s902/a"},"text":"Pub. L. 109–479, title IX, § 902(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3664"},"text":"120 Stat. 3664","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
