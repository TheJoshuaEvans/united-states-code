{"tag":"section","attrib":{"id":"id77f0148f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bbb–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"460bbb–1"},"text":"§ 460bbb–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77f01490-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bbb–1/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “excluded area” means one of the four areas specifically excluded from the recreation area, as generally depicted on the map referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460bbb–2/b"},"text":"section 460bbb–2(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77f01491-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bbb–1/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “forest plan” means the land and resource management plan for the Six Rivers National Forest prepared pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1604"},"text":"section 1604 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77f01492-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bbb–1/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “recreation area” means the Smith River National Recreation Area established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460bbb–2"},"text":"section 460bbb–2 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77f01493-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bbb–1/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of Agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77f01494-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bbb–1/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “inner gorge” means the inherently unstable steep slope (65 percent gradient or more) immediately adjacent to the stream or river channel, extending from the channel or recent floodplain to the first significant break in slope (usually 15 percent or more).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77f01495-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/612/s3"},"text":"Pub. L. 101–612, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3209"},"text":"104 Stat. 3209","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77f01496-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77f01497-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77f01498-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subcha