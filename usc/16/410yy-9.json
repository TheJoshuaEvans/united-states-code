{"tag":"section","attrib":{"id":"id776364fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"410yy–9"},"text":"§ 410yy–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id776364fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–9/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b), there are authorized to be appropriated such sums as may be necessary to carry out this subchapter, but not to exceed $5,000,000 for the acquisition of lands and interests therein, $50,000,000 for development, and $25,000,000 for financial and technical assistance to owners of non-Federal property as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410yy–7"},"text":"section 410yy–7 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776364fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–9/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated annually to the Commission to carry out its duties under this subchapter, $250,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id776364fd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/543/s10"},"text":"Pub. L. 102–543, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3574"},"text":"106 Stat. 3574","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVII/s7101/c"},"text":"Pub. L. 111–11, title VII, § 7101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1190"},"text":"123 Stat. 1190","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id776364fe-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id776364ff-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77636500-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s7101/c/1"},"text":"Pub. L. 111–11, § 7101(c)(1)","children":[],"tail":", substituted “$50,000,000 for development, and $25,000,000” for “$25,000,000 for development, and $3,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s7101/c/2"},"text":"Pub. L. 111–11, § 7101(c)(2)","children":[],"tail":", substituted “$250,000” for “$100,000 except that the Federal contribution to the Commission shall not exceed 50 percent of the annual costs to the Commission in carrying out those duties”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
