{"tag":"section","attrib":{"id":"id78294c1f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521d"},"text":null,"children":[{"tag":"num","attrib":{"value":"521d"},"text":"§ 521d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale, exchange, or interchange of National Forest System land","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78294c20-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conveyance authority; consideration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized, when the Secretary determines it to be in the public interest—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78294c21-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to sell, exchange, or interchange by quitclaim deed, all right, title, and interest, including the mineral estate, of the United States in and to National Forest System lands described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s521e"},"text":"section 521e of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78294c22-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accept as consideration for the lands sold, exchanged, or interchanged other lands, interests in lands, or cash payment, or any combination of such forms of consideration, which, in the case of conveyance by sale or exchange, is at least equal in value, including the mineral estate, or, in the case of conveyance by interchange, is of approximately equal value, including the mineral estate, to the lands being conveyed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78294c23-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of terms, covenants, conditions, and reservations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78294c24-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall insert in any such quitclaim deed such terms, covenants, conditions, and reservations as the Secretary deems necessary to ensure protection of the public interest, including protection of the scenic, wildlife, and recreation values of the National Forest System and provision for appropriate public access to and use of lands within the System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78294c25-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not be applicable to deeds issued by the Secretary to lands outside the boundary of units of the National Forest System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78294c26-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of proceeds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78294c27-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit in Sisk fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The net proceeds derived from any sale or exchange conducted under paragraph (4), (5), or (6) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s521e"},"text":"section 521e of this title","children":[],"tail":" shall be deposited in the fund established under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s484a"},"text":"section 484a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78294c28-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts deposited under paragraph (1) shall be available to the Secretary until expended for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78294c29-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521d/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition of land or interests in land for administrative sites for the National Forest System in the State from which the amounts were derived;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78294c2a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521d/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition of land or interests in land for inclusion in the National Forest System in that State, including land or interests in land that enhance opportunities for recreational access; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78294c2b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521d/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reimbursement of the Secretary for costs incurred in preparing a sale conducted under the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s521e"},"text":"section 521e of this title","children":[],"tail":" if the sale is a competitive sale."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78294c2c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/465/s2"},"text":"Pub. L. 97–465, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2535"},"text":"96 Stat. 2535","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVIII/s8621/c"},"text":"Pub. L. 115–334, title VIII, § 8621(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4852"},"text":"132 Stat. 4852","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78294c2d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78294c2e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78294c2f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8621/c/1"},"text":"Pub. L. 115–334, § 8621(c)(1)","children":[],"tail":"–(3), designated first sentence as subsec. (a) and inserted subsec. heading, designated second sentence as par. (1) of subsec. (b), inserted subsec. and par. headings, and substituted “covenants” for “convenants”, and designated third sentence as par. (2) of subsec. (b), inserted par. heading, and substituted “Paragraph (1) shall not” for “The preceding sentence shall not”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8621/c/4"},"text":"Pub. L. 115–334, § 8621(c)(4)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
