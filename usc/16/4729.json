{"tag":"section","attrib":{"id":"id79f581af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729"},"text":null,"children":[{"tag":"num","attrib":{"value":"4729"},"text":"§ 4729.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coastal Aquatic Invasive Species Mitigation Grant Program and Mitigation Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f581b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f581b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coastal zone","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “coastal zone” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1453"},"text":"section 1453 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f581b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f581b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f581b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f581b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian Tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f581b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nongovernmental organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f581b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f581b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusive Economic Zone","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Exclusive Economic Zone” means the Exclusive Economic Zone of the United States, as established by Presidential Proclamation 5030, dated ","children":[{"tag":"date","attrib":{"date":"1983-03-10"},"text":"March 10, 1983","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1453"},"text":"16 U.S.C. 1453","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f581b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foundation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Foundation” means the National Fish and Wildlife Foundation established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3701/a"},"text":"section 3701(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f581ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Fund” means the Coastal Aquatic Invasive Species Mitigation Fund established by paragraph (3)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f581bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Program” means the Coastal Aquatic Invasive Species Mitigation Grant Program established under paragraph (2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f581bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f581bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f581be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Foundation shall establish a program, to be known as the “Coastal Aquatic Invasive Species Mitigation Grant Program”, under which the Secretary and the Foundation shall award grants to eligible entities in accordance with this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f581bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Program are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f581c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to improve the understanding, prevention, and mitigation of, and response to, aquatic invasive species in—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79f581c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the coastal zone; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79f581c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Exclusive Economic Zone;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f581c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the prevention and mitigation of impacts from aquatic invasive species in the coastal zone; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f581c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the restoration of Pacific Island habitats, marine, estuarine, and Great Lakes environments in the coastal zone and the Exclusive Economic Zone that are impacted by aquatic invasive species.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f581c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grants","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f581c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant awarded under the Program shall be used for an activity to carry out the purposes of the Program, including an activity—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79f581c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/2/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and implement procedures and programs, including permissible State ballast water inspection programs, to prevent, detect, control, mitigate, and rapidly or progressively eradicate aquatic invasive species in the coastal zone or the Exclusive Economic Zone, particularly in areas with high numbers of established aquatic invasive species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79f581c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/2/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to restore habitat impacted by an aquatic invasive species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79f581c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/2/C/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop new shipboard and land-based ballast water treatment system technologies and performance standards to prevent the introduction of aquatic invasive species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79f581ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/2/C/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop mitigation measures to protect natural and cultural living resources, including shellfish, from the impacts of aquatic invasive species; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79f581cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/2/C/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop mitigation measures to protect infrastructure, such as hydroelectric infrastructure, from aquatic invasive species.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f581cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on funding litigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded under the Program may not be used to fund litigation in any matter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f581cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2018-12-04"},"text":"December 4, 2018","children":[],"tail":", the Foundation, in consultation with the Secretary, shall establish the following:"}],"tail":null},{"tag":"clause","attrib":{"id":"id79f581ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Application and review procedures for awarding grants under the Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f581cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Approval procedures for awarding grants under the Program, including a requirement for consultation with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79f581d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/2/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79f581d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/2/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f581d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Performance accountability and monitoring measures for activities funded by a grant awarded under the Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f581d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Procedures and methods to ensure accurate accounting and appropriate administration of grants awarded under the Program, including standards of recordkeeping.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f581d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible entity that receives a grant under the Program shall provide, in cash or through in-kind contributions from non-Federal sources, matching funds to carry out the activities funded by the grant in an amount equal to not less than 25 percent of the cost of the activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f581d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Foundation are authorized to use the amounts available in the Fund to award grants under the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f581d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mitigation Fund","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f581d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a trust fund, to be known as the “Coastal Aquatic Invasive Species Mitigation Fund”, consisting of such amounts as are appropriated or credited to the Fund in accordance with this paragraph or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s9602"},"text":"section 9602 of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f581d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers to Fund","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f581d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated from the Treasury to the Fund, for each fiscal year, an amount equal to the amount of penalties assessed for violations of subsection (p) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1322"},"text":"section 1322 of title 33","children":[],"tail":" during the preceding fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f581da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the amounts transferred to the Fund under clause (i), there is authorized to be appropriated to the Fund $5,000,000 for each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f581db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4729/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to appropriations, the amounts in the Fund shall be available to the Secretary and the Foundation to award grants under the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f581dc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tIX/s903/f"},"text":"Pub. L. 115–282, title IX, § 903(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4357"},"text":"132 Stat. 4357","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79f581dd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79f581de-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79f581df-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Presidential Proclamation 5030, referred to in par. (1)(C), is Proc. No. 5030, ","children":[{"tag":"date","attrib":{"date":"1983-03-10"},"text":"Mar. 10, 1983","children":[],"tail":", 48 F.R. 10605, which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1453"},"text":"section 1453 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79f581e0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Vessel Incidental Discharge Act of 2018 and also as part of the Frank LoBiondo Coast Guard Authorization Act of 2018, and not as part of the Nonindigenous Aquatic Nuisance Prevention and Control Act of 1990 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of subsec. (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s903"},"text":"section 903 of Pub. L. 115–282","children":[],"tail":". For classification to the Code of other provisions of section 903, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
