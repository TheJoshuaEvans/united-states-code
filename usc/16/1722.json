ified to "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s698"},"text":"section 698 of Title 48","children":[],"tail":", Territories and Insular Possessions, and was omitted from the Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/86/3/s4"},"text":"Section 4 of Public Law 86–3","children":[],"tail":", referred to in par. (4), is set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s491"},"text":"section 491 of Title 48","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Alaska Native Claims Settlement Act, referred to in par. (6)(D), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/203"},"text":"Pub. L. 92–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-18"},"text":"Dec. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/688"},"text":"85 Stat. 688","children":[],"tail":", which is classified generally to chapter 33 (§ 1601 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"section 1601 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Healthy Forests Restoration Act of 2003, referred to in par. (9), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/148"},"text":"Pub. L. 108–148","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-03"},"text":"Dec. 3, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1887"},"text":"117 Stat. 1887","children":[],"tail":", which is classified principally to chapter 84 (§ 6501 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6501"},"text":"section 6501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag"