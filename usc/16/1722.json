{"tag":"section","attrib":{"id":"id795cea6d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722"},"text":null,"children":[{"tag":"num","attrib":{"value":"1722"},"text":"§ 1722.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id795cea6e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate conservation project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “appropriate conservation project” means any project for the conservation, restoration, construction or rehabilitation of natural, cultural, historic, archaeological, recreational, or scenic resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795cea6f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corps and Public Lands Corps","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “Corps” and “Public Lands Corps” mean the Public Lands Corps established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1723/a/1"},"text":"section 1723(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795cea70-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible service lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible service lands” means public lands, Indian lands, and Hawaiian home lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795cea71-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hawaiian home lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Hawaiian home lands” means all lands given the status of Hawaiian home lands under section 204 of the Hawaiian Homes Commission Act, 1920 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/42/110"},"text":"42 Stat. 110","children":[],"tail":"), or under the corresponding provision of the Constitution of the State of Hawaii adopted under section 4 of the Act entitled “An Act to provide for the admission of the State of Hawaii into the Union”, approved "},{"tag":"date","attrib":{"date":"1959-03-18"},"text":"March 18, 1959","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/86/3"},"text":"Public Law 86–3","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/73/5"},"text":"73 Stat. 5","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795cea72-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Indian” means a person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id795cea73-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a member of an Indian tribe; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id795cea74-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a “Native”, as defined in section 3(b) of the Alaska Native Claims Settlement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1602/b"},"text":"43 U.S.C. 1602(b)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795cea75-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian lands","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Indian lands” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id795cea76-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Indian reservation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id795cea77-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any public domain Indian allotments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id795cea78-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any former Indian reservation in the State of Oklahoma;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id795cea79-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any land held by incorporated Native groups, regional corporations, and village corporations under the Alaska Native Claims Settlement Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"43 U.S.C. 1601","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id795cea7a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any land held by dependent Indian communities within the borders of the United States whether within the original or subsequently acquired territory thereof, and whether within or without the limits of a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795cea7b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” means an Indian tribe, band, nation, or other organized group or community, including any Native village, Regional Corporation, or Village Corporation, as defined in subsection (c), (g), or (j), respectively, of section 3 of the Alaska Native Claims Settlement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1602/c"},"text":"43 U.S.C. 1602(c)","children":[],"tail":", (g), or (j)), that is recognized as eligible for the special programs and services provided by the United States under Federal law to Indians because of their status as Indians."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795cea7c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution of higher education","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id795cea7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “institution of higher education” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002"},"text":"section 1002 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id795cea7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “institution of higher education” does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id795cea7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/8/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/b"},"text":"section 1001(b) of title 20","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id795cea80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/8/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution outside the United States, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002/a/1/C"},"text":"section 1002(a)(1)(C) of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795cea81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority project","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “priority project” means an appropriate conservation project conducted on eligible service lands to further 1 or more of the purposes of the Healthy Forests Restoration Act of 2003 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6501"},"text":"16 U.S.C. 6501","children":[],"tail":" et seq.) and other conservation and restoration initiatives, as follows:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id795cea82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To reduce wildfire risk to a community, municipal water supply, or other at-risk Federal land.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id795cea83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To protect a watershed or address a threat to forest and rangeland health, including catastrophic wildfire.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id795cea84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To address the impact of insect or disease infestations or other damaging agents on forest and rangeland health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id795cea85-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To protect, restore, or enhance forest ecosystem components to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id795cea86-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/9/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the recovery of threatened or endangered species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id795cea87-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/9/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve biological diversity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id795cea88-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/9/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance productivity and carbon sequestration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id795cea89-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/9/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To protect, restore, or enhance marine, estuarine, riverine, and coastal habitat ecosystem components—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id795cea8a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/9/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote the recovery of threatened species, endangered species, and managed fisheries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id795cea8b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/9/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to restore fisheries, protected resources, and habitats impacted by oil and chemical spills and natural disasters; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id795cea8c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/9/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance the resilience of coastal ecosystems, communities, and economies through habitat conservation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795cea8d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “public lands” means any lands or waters (or interest therein) owned or administered by the United States, except that such term does not include any Indian lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795cea8e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified youth or conservation corps","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified youth or conservation corps” means any program established by a State or local government, by the governing body of any Indian tribe, or by a nonprofit organization that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id795cea8f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is capable of offering meaningful, full-time, productive work for individuals between the ages of 16 and 30, inclusive, or veterans age 35 or younger in a natural or cultural resource setting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id795cea90-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gives participants a mix of work experience, basic and life skills, education, training, and support services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id795cea91-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/11/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides participants with the opportunity to develop citizenship values and skills through service to their community and the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795cea92-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resource assistant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “resource assistant” means a resource assistant selected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1725"},"text":"section 1725 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795cea93-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Secretary” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id795cea94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to National Forest System land, the Secretary of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id795cea95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to Indian lands, Hawaiian home lands, or land administered by the Department of the Interior, the Secretary of the Interior; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id795cea96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/13/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the National Marine Sanctuary System, coral reefs, and other coastal, estuarine, and marine habitats, and other land and facilities administered by the National Oceanic and Atmospheric Administration, the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795cea97-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means any State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, Guam, the Virgin Islands of the United States, American Samoa, and the Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795cea98-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1722/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veteran","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “veteran” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of title 38","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id795cea99-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/378/tII/s203"},"text":"Pub. L. 91–378, title II, § 203","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s105/6"},"text":"Pub. L. 103–82, title I, § 105(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/849"},"text":"107 S