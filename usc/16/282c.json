{"tag":"section","attrib":{"id":"id77254a4b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s282c"},"text":null,"children":[{"tag":"num","attrib":{"value":"282c"},"text":"§ 282c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated such sums, but not more than $13,575,000 for the acquisition of lands and interests therein and for the development of the San Juan National Historical Park.","children":[{"tag":"ref","attrib":{"idref":"fn002059"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002059"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “San Juan Island National Historical Park.”"}],"tail":null}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77254a4c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/565/s4"},"text":"Pub. L. 89–565, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-09"},"text":"Sept. 9, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/737"},"text":"80 Stat. 737","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/625/tI/s101/22"},"text":"Pub. L. 95–625, title I, § 101(22)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3472"},"text":"92 Stat. 3472","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/88/dA/tI/s118"},"text":"Pub. L. 111–88, div. A, title I, § 118","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2929"},"text":"123 Stat. 2929","children":[