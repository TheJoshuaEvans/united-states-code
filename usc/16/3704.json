{"tag":"section","attrib":{"id":"id79c37472-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3704"},"text":null,"children":[{"tag":"num","attrib":{"value":"3704"},"text":"§ 3704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative services and support","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79c37473-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide personnel, facilities, and other administrative services to the Foundation, including reimbursement of expenses under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3702"},"text":"section 3702 of this title","children":[],"tail":", not to exceed then current Federal Government per diem rates, for a period of up to five years from "},{"tag":"date","attrib":{"date":"1984-03-26"},"text":"March 26, 1984","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c37474-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation may reimburse the Secretary for any administrative service provided under subsection (a). The Secretary shall deposit any reimbursement received under this subsection into the Treasury to the credit of the appropriations then current and chargeable for the cost of providing such services.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this section, the Secretary of the Interior is authorized to continue to provide facilities, and necessary support services for such facilities, to the National Fish and Wildlife Foundation after ","children":[{"tag":"date","attrib":{"date":"1989-03-26"},"text":"March 26, 1989","children":[],"tail":", on a space available, reimbursable cost basis."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79c37475-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/244/s5"},"text":"Pub. L. 98–244, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-03-26"},"text":"Mar. 26, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/109"},"text":"98 Stat. 109","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/240/s3"},"text":"Pub. L. 100–240, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-11"},"text":"Jan. 11, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1786"},"text":"101 Stat. 1786","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/653/tIX/s903"},"text":"Pub. L. 100–653, title IX, § 903","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-14"},"text":"Nov. 14, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3834"},"text":"102 Stat. 3834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79c37476-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79c37477-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79c37478-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/653"},"text":"Pub. L. 100–653","children":[],"tail":" inserted provision at end authorizing Secretary of the Interior to continue to provide facilities and necessary support services to National Fish and Wildlife Foundation after "},{"tag":"date","attrib":{"date":"1989-03-26"},"text":"Mar. 26, 1989","children":[],"tail":", on space available, reimbursable cost basis."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/240"},"text":"Pub. L. 100–240","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and struck out “, and may accept reimbursement therefor, to be deposited in the Treasury to the credit of the appropriations then current and chargeable for the cost of providing such services” after “"},{"tag":"date","attrib":{"date":"1984-03-26"},"text":"March 26, 1984","children":[],"tail":"”, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
