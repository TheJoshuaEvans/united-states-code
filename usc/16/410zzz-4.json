{"tag":"section","attrib":{"id":"id777fec78-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410zzz–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"410zzz–4"},"text":"§ 410zzz–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Saint-Gaudens Memorial","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Saint-Gaudens Memorial having by its active interest preserved for posterity this important site, its structures, objects, and cultural values, the executive committee thereof shall, upon establishment of the Saint-Gaudens National Historical Park, serve in an advisory capacity to the Secretary of the Interior in matters relating to its preservation, development, and use.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id777fec79-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/543/s5"},"text":"Pub. L. 88–543, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-31"},"text":"Aug. 31, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/749"},"text":"78 Stat. 749","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tII/s2201/b/1"},"text":"Pub. L. 116–9, title II, § 2201(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/733"},"text":"133 Stat. 733","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id777fec7a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id777fec7b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id777fec7c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9"},"text":"Pub. L. 116–9","children":[],"tail":" substituted “National Historical Park” for “National Historic Site”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
