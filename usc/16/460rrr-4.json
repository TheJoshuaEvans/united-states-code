{"tag":"section","attrib":{"id":"id7807e1f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"460rrr–4"},"text":"§ 460rrr–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7807e1f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 4 years after ","children":[{"tag":"date","attrib":{"date":"2006-10-12"},"text":"October 12, 2006","children":[],"tail":", the Secretary and the Commission, in coordination with appropriate agencies in the State of Colorado, political subdivisions of the State, and private landowners in the Natural Area, shall prepare management plans for the Natural Area as provided in subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7807e1f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Secretary and Commission","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7807e1f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–4/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prepare a management plan relating to the management of Federal land in the Natural Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e1f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–4/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7807e1fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–4/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall prepare a management plan relating to the management of the non-Federal land in the Natural Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7807e1fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–4/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval or disapproval","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7807e1fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–4/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall submit to the Secretary the management plan prepared under subparagraph (A) for approval or disapproval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7807e1fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–4/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action following disapproval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary disapproves the management plan submitted under clause (i), the Secretary shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7807e1fe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–4/b/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the Commission of the reasons for the disapproval; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7807e1ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–4/b/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow the Commission to submit to the Secretary revisions to the management plan submitted under clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e200-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–4/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Commission shall cooperate to ensure that the management plans relating to the management of Federal land and non-Federal land are consistent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7807e201-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The management plans shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7807e202-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–4/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into consideration Federal, State, and local plans in existence on ","children":[{"tag":"date","attrib":{"date":"2006-10-12"},"text":"October 12, 2006","children":[],"tail":", to present a unified preservation, restoration, and conservation plan for the Natural Area;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e203-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–4/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to Federal land in the Natural Area—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7807e204-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–4/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be developed in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1712"},"text":"section 1712 of title 43","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7807e205-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–4/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be consistent, to the maximum extent practicable, with the management plans adopted by the Director of the Bureau of Land Management for land adjacent to the Natural Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7807e206-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–4/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be considered to be an amendment to the San Luis Resource Management Plan of the Bureau of Land Management; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e207-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–4/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7807e208-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–4/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an inventory of the resources contained in the Natural Area (including a list of property in the Natural Area that should be preserved, restored, managed, developed, maintained, or acquired to further the purposes of the Natural Area); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7807e209-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–4/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a recommendation of policies for resource management, including the use of intergovernmental cooperative agreements, that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7807e20a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–4/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect the resources of the Natural Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7807e20b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–4/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for solitude, quiet use, and pristine natural values of the Natural Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7807e20c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–4/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall publish notice of the management plans in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7807e20d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/337/s6"},"text":"Pub. L. 109–337, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-12"},"text":"Oct. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1779"},"text":"120 Stat. 1779","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
