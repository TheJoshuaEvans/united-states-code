{"tag":"section","attrib":{"id":"id784f7243-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s580p–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"580p–4"},"text":"§ 580p–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunction against unauthorized manufacture, use, or reproduction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id784f7244-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s580p–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever, except as provided by rules and regulations issued by the Secretary, manufactures, uses, or reproduces the character “Smokey Bear”, or the name “Smokey Bear”, or a facsimile or simulation of such character or name in such a manner as suggests “Smokey Bear” may be enjoined from such manufacture, use, or reproduction at the suit of the Attorney General upon complaint by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id784f7245-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s580p–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever, except as provided by rules and regulations issued by the Secretary, manufactures, uses, or reproduces the character “Woodsy Owl”, the name “Woodsy Owl”, or the slogan “Give a Hoot, Don’t Pollute”, or a fac­simile or simulation of such character, name, or slogan in such a manner as suggests “Woodsy Owl” may be enjoined from such manufacture, use, or reproduction at the suit of the Attorney General upon complaint by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id784f7246-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/318/s4"},"text":"Pub. L. 93–318, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-06-22"},"text":"June 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/245"},"text":"88 Stat. 245","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id784f7247-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id784f7248-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id784f7249-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s488b–6"},"text":"section 488b–6 of Title 31","children":[],"tail":" prior to the general revision and enactment of Title 31, Money and Finance, by "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s1"},"text":"Pub. L. 97–258, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/877"},"text":"96 Stat. 877","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
