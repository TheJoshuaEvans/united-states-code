{"tag":"section","attrib":{"id":"id776f4b48-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff"},"text":null,"children":[{"tag":"num","attrib":{"value":"410fff"},"text":"§ 410fff.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776f4b49-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Black Canyon of the Gunnison National Monument was established for the preservation of its spectacular gorges and additional features of scenic, scientific, and educational interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776f4b4a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Black Canyon of the Gunnison and adjacent upland include a variety of unique ecological, geological, scenic, historical, and wildlife components enhanced by the serenity and rural western setting of the area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776f4b4b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Black Canyon of the Gunnison and adjacent land provide extensive opportunities for educational and recreational activities, and are publicly used for hiking, camping, and fishing, and for wilderness value, including solitude;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776f4b4c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adjacent public land downstream of the Black Canyon of the Gunnison National Monument has wilderness value and offers unique geological, paleontological, scientific, educational, and recreational resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776f4b4d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public land adjacent to the Black Canyon of the Gunnison National Monument contributes to the protection of the wildlife, viewshed, and scenic qualities of the Black Canyon;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776f4b4e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" some private land adjacent to the Black Canyon of the Gunnison National Monument has exceptional natural and scenic value that would be threatened by future development pressures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776f4b4f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the benefits of designating public and private land surrounding the national monument as a national park include greater long-term protection of the resources and expanded visitor use opportunities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776f4b50-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" land in and adjacent to the Black Canyon of the Gunnison Gorge is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id776f4b51-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognized for offering exceptional multiple use opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776f4b52-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognized for offering natural, cultural, scenic, wilderness, and recreational resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776f4b53-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" worthy of additional protection as a national conservation area, and with respect to the Gunnison Gorge itself, as a component of the national wilderness system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id776f4b54-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/76/s2"},"text":"Pub. L. 106–76, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-21"},"text":"Oct. 21, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1126"},"text":"113 Stat. 1126","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id776f4b55-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id776f4b56-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id776f4b57-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/128/s1"},"text":"Pub. L. 108–128, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-17"},"text":"Nov. 17, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1355"},"text":"117 Stat. 1355","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/128/s1"},"text":"“This Act [amending sections 410fff–2, 410fff–3, and 410fff–5 of this title and enacting provisions set out as notes under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410fff–2"},"text":"section 410fff–2 of this title","children":[],"tail":"] may be cited as the ‘Black Canyon of the Gunnison Boundary Revision Act of 2003’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id776f4b58-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/76/s1"},"text":"Pub. L. 106–76, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-21"},"text":"Oct. 21, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1126"},"text":"113 Stat. 1126","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/76/s1"},"text":"“This Act [enacting this subchapter and amending provisions listed in a table of National Monuments Established Under Presidential Proclamation set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s431"},"text":"section 431 of this title","children":[],"tail":" and provisions listed in a table of Wilderness Areas set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1132"},"text":"section 1132 of this title","children":[],"tail":"] may be cited as the ‘Black Canyon of the Gunnison National Park and Gunnison Gorge National Conservation Area Act of 1999’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
