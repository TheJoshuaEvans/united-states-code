{"tag":"section","attrib":{"id":"id78b5fc1a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s825t"},"text":null,"children":[{"tag":"num","attrib":{"value":"825t"},"text":"§ 825t.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of power revenues","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No power revenues on any project shall be distributed as profits, before or after retirement of the project debt, and nothing contained in any previous appropriation Act shall be deemed to have authorized such distribution: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the application of such revenues to the cost of operation, maintenance, and debt service of the irrigation system of the project, or to other purposes in aid of such irrigation system, shall not be construed to be such a distribution."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78b5fc1b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-07-01/ch529/s1"},"text":"July 1, 1946, ch. 529, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/366"},"text":"60 Stat. 366","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78b5fc1c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78b5fc1d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78b5fc1e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Federal Power Act which generally comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
