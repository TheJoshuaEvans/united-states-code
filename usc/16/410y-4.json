{"tag":"section","attrib":{"id":"id774b6fab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410y–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"410y–4"},"text":"§ 410y–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chesapeake and Ohio Canal National Historical Park Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id774b6fac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410y–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established a Chesapeake and Ohio Canal National Historical Park Commission (hereafter in this section referred to as the “Commission”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id774b6fad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410y–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership; appointment; term","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall be composed of nineteen members appointed by the Secretary for terms of five years each, as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id774b6fae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410y–4/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Eight members to be appointed from recommendations submitted by the boards of commissioners or the county councils, as the case may be, of Montgomery, Frederick, Washington, and Allegany Counties, Maryland, of which two members shall be appointed from recommendations submitted by each such board or council, as the case may be;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id774b6faf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410y–4/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Eight members to be appointed from recommendations submitted by the Governor of the State of Maryland, the Governor of the State of West Virginia, the Governor of the Commonwealth of Virginia, and the Mayor of the District of Columbia, of which two members shall be appointed from recommendations submitted by each such Governor or Mayor, as the case may be; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id774b6fb0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410y–4/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three members to be appointed by the Secretary, one of whom shall be designated Chairman of the Commission and two of whom shall be members of regularly constituted conservation organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id774b6fb1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410y–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vacancy in the Commission shall be filled in the same manner in which the original appointment was made. A member may serve after the expiration of his term until his successor has taken office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id774b6fb2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410y–4/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and payment of expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Commission shall serve without compensation, as such, but the Secretary is authorized to pay, upon vouchers signed by the Chairman, the expenses reasonably incurred by the Commission and its members in carrying out their responsibilities under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id774b6fb3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410y–4/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, or his designee, shall from time to time but at least annually, meet and consult with the Commission on general policies and specific matters related to the administration and development of the park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id774b6fb4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410y–4/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Majority vote","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall act and advise by affirmative vote of a majority of the members thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id774b6fb5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410y–4/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall cease to exist on ","children":[{"tag":"date","attrib":{"date":"2031-10-01"},"text":"October 1, 2031","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id774b6fb6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/664/s6"},"text":"Pub. L. 91–664, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-08"},"text":"Jan. 8, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1980"},"text":"84 Stat. 1980","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/198/tIV/s421"},"text":"Pub. L. 93–198, title IV, § 421","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-24"},"text":"Dec. 24, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/789"},"text":"87 Stat. 789","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/555"},"text":"Pub. L. 96–555","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-19"},"text":"Dec. 19, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3260"},"text":"94 Stat. 3260","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/320"},"text":"Pub. L. 101–320","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-07-03"},"text":"July 3, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/292"},"text":"104 Stat. 292","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tI/s134"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title I, § 134]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–230; "},{"tag":"ref","attrib":{"href":"/us/pl/118/83/dB/tI/s104"},"text":"Pub. L. 118–83, div. B, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-09-26"},"text":"Sept. 26, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1534"},"text":"138 Stat. 1534","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/163/s2"},"text":"Pub. L. 118–163, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2578"},"text":"138 Stat. 2578","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id774b6fb7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id774b6fb8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id774b6fb9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/163"},"text":"Pub. L. 118–163","children":[],"tail":", which directed the substitution of “on "},{"tag":"date","attrib":{"date":"2031-10-01"},"text":"October 1, 2031","children":[],"tail":".” for “ ‘40’ and all that follows through the period at the end”, was executed by substituting “on "},{"tag":"date","attrib":{"date":"2031-10-01"},"text":"October 1, 2031","children":[],"tail":".” for “on "},{"tag":"date","attrib":{"date":"2024-12-20"},"text":"December 20, 2024","children":[],"tail":".” to reflect the probable intent of Congress and the intervening amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/118/83"},"text":"Pub. L. 118–83","children":[],"tail":". See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/83"},"text":"Pub. L. 118–83","children":[],"tail":" substituted “on "},{"tag":"date","attrib":{"date":"2024-12-20"},"text":"December 20, 2024","children":[],"tail":".” for “40 years from "},{"tag":"date","attrib":{"date":"1971-01-08"},"text":"January 8, 1971","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":" substituted “40” for “thirty”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/320/s1/a"},"text":"Pub. L. 101–320, § 1(a)","children":[],"tail":", inserted at end “A member may serve after the expiration of his term until his successor has taken office.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/320/s1/b"},"text":"Pub. L. 101–320, § 1(b)","children":[],"tail":", substituted “thirty” for “twenty”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/555"},"text":"Pub. L. 96–555","children":[],"tail":" substituted “twenty” for “ten”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id774b6fba-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id774b6fbb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Office of Commissioner of District of Columbia, as established by Reorg. Plan No. 3 of 1967, abolished as of noon ","children":[{"tag":"date","attrib":{"date":"1975-01-02"},"text":"Jan. 2, 1975","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/93/198/tVII/s711"},"text":"Pub. L. 93–198, title VII, § 711","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-24"},"text":"Dec. 24, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/818"},"text":"87 Stat. 818","children":[],"tail":", and replaced by office of Mayor of District of Columbia by "},{"tag":"ref","attrib":{"href":"/us/pl/93/198/s421"},"text":"section 421 of Pub. L. 93–198","children":[],"tail":". Accordingly, “Mayor” substituted in subsec. (b)(2) for “Commissioner” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id774b6fbc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Chesapeake and Ohio Canal National Historical Park Commission","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/178/s1"},"text":"Pub. L. 113–178, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-09-26"},"text":"Sept. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1912"},"text":"128 Stat. 1912","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/178/s1"},"text":"“The Chesapeake and Ohio Canal National Historical Park Commission (referred to in this Act [enacting this note] as the ‘Commission’) is authorized in accordance with the provisions of section 6 of the Chesapeake and Ohio Canal Development Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410y–4"},"text":"16 U.S.C. 410y–4","children":[],"tail":"), except that the Commission shall terminate 10 years after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2014-09-26"},"text":"Sept. 26, 2014","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
