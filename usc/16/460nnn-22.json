{"tag":"section","attrib":{"id":"id7800b5bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–22"},"text":null,"children":[{"tag":"num","attrib":{"value":"460nnn–22"},"text":"§ 460nnn–22.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Roads and travel access","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7800b5bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–22/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The management plan shall include, as an integral part, a comprehensive transportation plan for the Federal lands included in the Cooperative Management and Protection Area, which shall address the maintenance, improvement, and closure of roads and trails as well as travel access.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b5bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–22/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on off-road motorized travel","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7800b5be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–22/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The use of motorized or mechanized vehicles on Federal lands included in the Cooperative Management and Protection Area—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7800b5bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–22/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is prohibited off road; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7800b5c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–22/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is limited to such roads and trails as may be designated for their use as part of the management plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b5c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–22/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) does not prohibit the use of motorized or mechanized vehicles on Federal lands included in the Cooperative Management and Protection Area if the Secretary determines that such use—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7800b5c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–22/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is needed for administrative purposes or to respond to an emergency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7800b5c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–22/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is appropriate for the construction or maintenance of agricultural facilities, fish and wildlife management, or ecological restoration projects, except in areas designated as wilderness or managed under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1782/c"},"text":"section 1782(c) of title 43","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b5c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–22/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Road closures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any determination to permanently close an existing road in the Cooperative Management and Protection Area or to restrict the access of motorized or mechanized vehicles on certain roads shall be made in consultation with the advisory council and the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b5c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–22/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on new construction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7800b5c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–22/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition, exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No new road or trail for motorized or mechanized vehicles may be constructed on Federal lands in the Cooperative Management and Protection Area unless the Secretary determines that the road or trail is necessary for public safety or protection of the environment. Any determination under this subsection shall be made in consultation with the advisory council and the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b5c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–22/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trails","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection is intended to limit the authority of the Secretary to construct or maintain trails for nonmotorized or nonmechanized use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b5c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–22/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to nonfederally owned lands","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7800b5c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–22/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasonable access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide reasonable access to nonfederally owned lands or interests in land within the boundaries of the Cooperative Management and Protection Area and the Wilderness Area to provide the owner of the land or interest the reasonable use thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b5ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–22/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on existing rights-of-way","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall have the effect of terminating any valid existing right-of-way on Federal lands included in the Cooperative Management and Protection Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7800b5cb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/399/tI/s112"},"text":"Pub. L. 106–399, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1660"},"text":"114 Stat. 1660","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7800b5cc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7800b5cd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7800b5ce-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (e)(2), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/399"},"text":"Pub. L. 106–399","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1655"},"text":"114 Stat. 1655","children":[],"tail":", known as the Steens Mountain Cooperative Management and Protection Act of 2000, which is classified generally to this subchapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460nnn"},"text":"section 460nnn of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
