{"tag":"section","attrib":{"id":"id77c051bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460k–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"460k–3"},"text":"§ 460k–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charges and fees; permits; regulations; penalties; enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may establish reasonable charges and fees and issue permits for public use of national wildlife refuges, game ranges, national fish hatcheries, and other conservation areas administered by the Department of the Interior for fish and wildlife purposes. The Secretary may issue regulations to carry out the purposes of this subchapter. A violation of such regulations shall be a misdemeanor with maximum penalties of imprisonment for not more than six months, or a fine of not more than $500, or both. The provisions of this subchapter and any such regulation shall be enforced by any officer or employee of the United States Fish and Wildlife Service designated by the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77c051c0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/714/s4"},"text":"Pub. L. 87–714, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-28"},"text":"Sept. 28, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/654"},"text":"76 Stat. 654","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/616/s3/e"},"text":"Pub. L. 95–616, § 3(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-08"},"text":"Nov. 8, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3111"},"text":"92 Stat. 3111","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s221"},"text":"Pub. L. 98–473, title II, § 221","children":[