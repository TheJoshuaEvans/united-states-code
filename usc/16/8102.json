{"tag":"section","attrib":{"id":"id7a33745c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8102"},"text":null,"children":[{"tag":"num","attrib":{"value":"8102"},"text":"§ 8102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nutria eradication program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a33745d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior (referred to in this chapter as the “Secretary”),","children":[{"tag":"ref","attrib":{"idref":"fn002870"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002870"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" may provide financial assistance to a State, in an amount that is in proportion to the total impacted area of such State affected by nutria, that has demonstrated to the Secretary sufficient need for a program to implement measures to eradicate or control nutria and restore marshland, public and private wetlands, and agricultural lands damaged by nutria."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a33745e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the State of Maryland, the Secretary shall require that the program consist of management, research, and public education activities carried out in accordance with the document published by the United States Fish and Wildlife Service entitled “Eradication Strategies for Nutria in the Chesapeake and Delaware Bay Watersheds”, dated March 2002.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a33745f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a337460-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8102/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the costs of a State program referred to in subsection (a) may not exceed 75 percent of the total costs of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a337461-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8102/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In-kind contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share of the costs of a State program referred to in subsection (a) may be provided in the form of in-kind contributions of materials or services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a337462-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8102/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 5 percent of financial assistance provided to a State by the Secretary under this section may be used for administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a337463-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8102/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For financial assistance under this section, there is authorized to be appropriated to the Secretary $12,000,000 for each of fiscal years 2021 through 2025.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a337464-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/16/s3"},"text":"Pub. L. 108–16, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-23"},"text":"Apr. 23, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/621"},"text":"117 Stat. 621","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/186/s1/2"},"text":"Pub. L. 116–186, § 1(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/901"},"text":"134 Stat. 901","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a337465-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a337466-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a337467-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/16"},"text":"Pub. L. 108–16","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-23"},"text":"Apr. 23, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/621"},"text":"117 Stat. 621","children":[],"tail":", known as the Nutria Eradication and Control Act of 2003, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s8101"},"text":"section 8101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a337468-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/186/s1/2/A"},"text":"Pub. L. 116–186, § 1(2)(A)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, text read as follows: “The Secretary of the Interior (in this chapter referred to as the ‘Secretary’), subject to the availability of appropriations, may provide financial assistance to the State of Maryland and the State of Louisiana for a program to implement measures to eradicate or control nutria and restore marshland damaged by nutria.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/186/s1/2/B"},"text":"Pub. L. 116–186, § 1(2)(B)","children":[],"tail":", (F), redesignated subsecs. (c) and (d) as (b) and (c), respectively, and struck out former subsec. (b) which related to goals of the program."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/186/s1/2/F"},"text":"Pub. L. 116–186, § 1(2)(F)","children":[],"tail":", redesignated subsec. (e) as (d). Former subsec. (d) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/186/s1/2/C/i"},"text":"Pub. L. 116–186, § 1(2)(C)(i)","children":[],"tail":", substituted “a State program referred to in subsection (a) may” for “the program may”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/186/s1/2/C/ii"},"text":"Pub. L. 116–186, § 1(2)(C)(ii)","children":[],"tail":", substituted “a State program referred to in subsection (a) may” for “the program may”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/186/s1/2/F"},"text":"Pub. L. 116–186, § 1(2)(F)","children":[],"tail":", redesignated subsec. (f) as (e). Former subsec. (e) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/186/s1/2/D"},"text":"Pub. L. 116–186, § 1(2)(D)","children":[],"tail":", inserted “to a State” after “provided”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/186/s1/2/F"},"text":"Pub. L. 116–186, § 1(2)(F)","children":[],"tail":", redesignated subsec. (f) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/186/s1/2/E"},"text":"Pub. L. 116–186, § 1(2)(E)","children":[],"tail":", substituted “$12,000,000 for each of fiscal years 2021 through 2025.” for “$4,000,000 for the State of Maryland program and $2,000,000 for the State of Louisiana program for each of fiscal years 2004, 2005, 2006, 2007, and 2008.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
