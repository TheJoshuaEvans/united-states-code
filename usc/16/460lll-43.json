{"tag":"section","attrib":{"id":"id77fbfb5e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–43"},"text":null,"children":[{"tag":"num","attrib":{"value":"460lll–43"},"text":"§ 460lll–43.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Memorandum of agreement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77fbfb5f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–43/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the date of transfer pursuant to section 460","children":[{"tag":"i","attrib":{},"text":"lll","children":[],"tail":"–41 of this title, the Secretary and the Tennessee Valley Authority shall enter into a memorandum of agreement concerning implementation of this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfb60-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–43/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The memorandum of understanding shall provide procedures for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fbfb61-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–43/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the orderly withdrawal of officers and employees of the Tennessee Valley Authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfb62-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–43/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transfer of property, fixtures, and facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfb63-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–43/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interagency transfer of officers and employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfb64-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–43/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transfer of records; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfb65-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–43/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other transfer issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfb66-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–43/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition team","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fbfb67-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–43/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The memorandum of understanding may provide for a transition team consisting of the Tennessee Valley Authority and Forest Service employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfb68-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–43/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The team may continue in existence after the date of transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfb69-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–43/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Tennessee Valley Authority and the Forest Service shall pay personnel costs of their respective team members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77fbfb6a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tV/s543"},"text":"Pub. L. 105–277, div. A, § 101(e) [title V, § 543]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–318.)"}],"tail":"\n"}],"tail":null}
