{"tag":"section","attrib":{"id":"id79dffdb4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871"},"text":null,"children":[{"tag":"num","attrib":{"value":"3871"},"text":"§ 3871.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79dffdb5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a regional conservation partnership program to implement eligible activities on eligible land through—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79dffdb6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partnership agreements, including partnership agreements funded through alternative funding arrangements or grant agreements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3871c/d"},"text":"section 3871c(d) of this title","children":[],"tail":", with eligible partners; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dffdb7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" program contracts with producers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79dffdb8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the program are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79dffdb9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To carry out eligible activities to accomplish purposes and functions similar to those of the following programs, as in effect on the day before ","children":[{"tag":"date","attrib":{"date":"2014-02-07"},"text":"February 7, 2014","children":[],"tail":":"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79dffdba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The agricultural water enhancement program established under section 3839aa–9 ","children":[{"tag":"ref","attrib":{"idref":"fn002775"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002775"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffdbb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chesapeake Bay watershed program established under section 3839bb–4 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffdbc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The cooperative conservation partnership initiative established under section 3843 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffdbd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Great Lakes basin program for soil erosion and sediment control established under section 3839bb–3 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dffdbe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To further the conservation, protection, restoration, and sustainable use of soil, water (including sources of drinking water and groundwater), wildlife, agricultural land, and related natural resources on eligible land on a regional or watershed scale.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dffdbf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To encourage eligible partners to cooperate with producers in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79dffdc0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meeting or avoiding the need for national, State, and local natural resource regulatory requirements related to production on eligible land, including through alignment of partnership projects with other national, State, and local agencies and programs addressing similar natural resource or environmental concerns; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffdc1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementing projects that will result in the adoption, installation, and maintenance of eligible activities that affect multiple agricultural or nonindustrial private forest operations on a local, regional, State, or multistate basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dffdc2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To encourage the flexible and streamlined delivery of conservation assistance to producers through partnership agreements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dffdc3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To engage producers and eligible partners in conservation projects to achieve greater conservation outcomes and benefits for producers than would otherwise be achieved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79dffdc4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1271"},"text":"Pub. L. 99–198, title XII, § 1271","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII/s2401"},"text":"Pub. L. 113–79, title II, § 2401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/744"},"text":"128 Stat. 744","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII/s2701"},"text":"Pub. L. 115–334, title II, § 2701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4592"},"text":"132 Stat. 4592","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79dffdc5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79dffdc6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79dffdc7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 3839aa–9, 3839bb–3, 3839bb–4, and 3843 of this title, referred to in subsec. (b)(1), were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII"},"text":"Pub. L. 113–79, title II","children":[],"tail":", §§ 2706(a), 2708, 2709(a), 2710(a), "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/768"},"text":"128 Stat. 768","children":[],"tail":", 770."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79dffdc8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2701/1/A"},"text":"Pub. L. 115–334, § 2701(1)(A)","children":[],"tail":", inserted “, including partnership agreements funded through alternative funding arrangements or grant agreements under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3871c/d"},"text":"section 3871c(d) of this title","children":[],"tail":",” after “partnership agreements”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2701/1/B"},"text":"Pub. L. 115–334, § 2701(1)(B)","children":[],"tail":", substituted “program contracts with producers” for “contracts with producers”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2701/2/A"},"text":"Pub. L. 115–334, § 2701(2)(A)","children":[],"tail":", substituted “To carry out eligible activities” for “To use covered programs” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2701/2/B"},"text":"Pub. L. 115–334, § 2701(2)(B)","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows: “To further the conservation, restoration, and sustainable use of soil, water, wildlife, and related natural resources on eligible land on a regional or watershed scale.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2701/2/C/i"},"text":"Pub. L. 115–334, § 2701(2)(C)(i)","children":[],"tail":", inserted “, including through alignment of partnership projects with other national, State, and local agencies and programs addressing similar natural resource or environmental concerns” after “production on eligible land”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2701/2/C/ii"},"text":"Pub. L. 115–334, § 2701(2)(C)(ii)","children":[],"tail":", substituted “adoption, installation, and maintenance” for “installation and maintenance”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2701/2/D"},"text":"Pub. L. 115–334, § 2701(2)(D)","children":[],"tail":", added pars. (4) and (5)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
