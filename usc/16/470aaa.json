{"tag":"section","attrib":{"id":"id781639e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa"},"text":null,"children":[{"tag":"num","attrib":{"value":"470aaa"},"text":"§ 470aaa.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id781639e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Casual collecting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “casual collecting” means the collecting of a reasonable amount of common invertebrate and plant paleontological resources for non-commercial personal use, either by surface collection or the use of non-powered hand tools resulting in only negligible disturbance to the Earth’s surface and other resources. As used in this paragraph, the terms “reasonable amount”, “common invertebrate and plant paleontological resources” and “negligible disturbance” shall be determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id781639e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal land","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal land” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id781882d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land controlled or administered by the Secretary of the Interior, except Indian land; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id781882d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National Forest System land controlled or administered by the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id781882da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian Land” means land of Indian tribes, or Indian individuals, which are either held in trust by the United States or subject to a restriction against alienation imposed by the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id781882db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Paleontological resource","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “paleontological resource” means any fossilized remains, traces, or imprints of organisms, preserved in or on the earth’s crust, that are of paleontological interest and that provide information about the history of life on earth, except that the term does not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id781882dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any materials associated with an archaeological resource (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s470bb/1"},"text":"section 470bb(1) of this title","children":[],"tail":"; "},{"tag":"ref","attrib":{"idref":"fn002397"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002397"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. A closing parenthesis probably should precede the semicolon."}],"tail":" or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id781882dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any cultural item (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3001"},"text":"section 3001 of title 25","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id781882de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior with respect to land controlled or administered by the Secretary of the Interior or the Secretary of Agriculture with respect to National Forest System land controlled or administered by the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id781882df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means the 50 States, the District of Columbia, the Commonwealth of Puerto Rico, and any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id781882e0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVI/s6301"},"text":"Pub. L. 111–11, title VI, § 6301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1172"},"text":"123 Stat. 1172","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
