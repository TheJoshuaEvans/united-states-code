{"tag":"section","attrib":{"id":"id7a0167b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5608"},"text":null,"children":[{"tag":"num","attrib":{"value":"5608"},"text":"§ 5608.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative matters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a0167b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5608/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on compensation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person shall not receive any compensation from the Government by reason of any service of the person as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0167b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5608/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Commissioner, Alternate Commissioner, Representative, or Alternative Representative;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0167b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5608/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an expert or adviser authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s5601/e"},"text":"section 5601(e) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0167b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5608/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the consultative committee established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s5607"},"text":"section 5607 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0167ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5608/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel and expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall, subject to the availability of appropriations, pay all necessary travel and other expenses of persons described in subsection (a)(1) and of not more than six experts and advisers authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s5601/e"},"text":"section 5601(e) of this title","children":[],"tail":" with respect to their actual performance of their official duties pursuant to this chapter, in accordance with the Federal Travel Regulations and sections 5701, 5702, 5704 through 5708, and 5731 of title 5."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0167bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5608/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status as Federal employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person shall not be considered to be a Federal employee by reason of any service of the person in a capacity described in subsection (a), except for purposes of injury compensation and tort claims liability under chapter 81 of title 5 and chapter 171 of title 28, respectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0167bc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/tII/s209"},"text":"Pub. L. 104–43, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/381"},"text":"109 Stat. 381","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/384/tII/s201/b/2"},"text":"Pub. L. 105–384, title II, § 201(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3451"},"text":"112 Stat. 3451","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a0167bd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a0167be-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a0167bf-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/384"},"text":"Pub. L. 105–384","children":[],"tail":" substituted “171” for “17”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
