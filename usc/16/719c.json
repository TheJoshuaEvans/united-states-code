{"tag":"section","attrib":{"id":"id7888aa9d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719c"},"text":null,"children":[{"tag":"num","attrib":{"value":"719c"},"text":"§ 719c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7888aa9e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary for administrative expenses of the Program $350,000 for each of the fiscal years 2006 through 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7888aa9f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on use for distribution to State and regional coordinators to implement competitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amount appropriated under this section for a fiscal year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7888aaa0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $100,000 may be used by the Secretary to administer the Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7888aaa1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $250,000 may be distributed to State and regional coordinators to implement competitions under the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7888aaa2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/340/s6"},"text":"Pub. L. 103–340, § 6","children":[],"tail":", formerly § 5, "},{"tag":"date","attrib":{"date":"1994-10-06"},"text":"Oct. 6, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3120"},"text":"108 Stat. 3120","children":[],"tail":"; renumbered § 6 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/316"},"text":"Pub. L. 106–316","children":[],"tail":", §§ 1, 2(2), "},{"tag":"date","attrib":{"date":"2000-10-19"},"text":"Oct. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1276"},"text":"114 Stat. 1276","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/166/s3"},"text":"Pub. L. 109–166, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-10"},"text":"Jan. 10, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3577"},"text":"119 Stat. 3577","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7888aaa3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7888aaa4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7888aaa5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/340/s6"},"text":"section 6 of Pub. L. 103–340","children":[],"tail":" was renumbered section 7 and enacted provisions listed in a table of National Wildlife Refuges set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s668dd"},"text":"section 668dd of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7888aaa6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/166"},"text":"Pub. L. 109–166","children":[],"tail":" designated existing provisions as subsec. (a), inserted subsec. (a) heading, substituted “$350,000” for “$250,000” and “fiscal years 2006 through 2010” for “fiscal years 2001 through 2005”, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/316/s1"},"text":"Pub. L. 106–316, § 1","children":[],"tail":", substituted “for each of the fiscal years 2001 through 2005” for “for each of the fiscal years 1995 through 2000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
