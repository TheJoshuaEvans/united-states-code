{"tag":"section","attrib":{"id":"id77f25dc6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bbb–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"460bbb–6"},"text":"§ 460bbb–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minerals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77f25dc7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bbb–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to valid existing rights, Federal lands within the exterior boundary of the recreation area are hereby withdrawn from all forms of location, entry, and patent under the United States mining laws and from disposition under the mineral leasing laws, including all laws pertaining to geothermal leasing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f25dc8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bbb–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Patents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Patents may not be issued under the mining laws of the United States after ","children":[{"tag":"date","attrib":{"date":"1990-11-16"},"text":"November 16, 1990","children":[],"tail":", for locations and claims made before "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"November 16, 1990","children":[],"tail":", on Federal lands located within the exterior boundaries of the recreation area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f25dc9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bbb–6/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to valid existing rights except for extraction of common variety minerals such as stone, sand, and gravel for use in construction and maintenance of roads and other facilities within the recreation area and the excluded areas, all other mineral development on federally owned lands within the recreation area is prohibited.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f25dca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bbb–6/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized and directed to issue supplementary regulations to promote and protect the purposes for which the recreation area is designated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77f25dcb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/612/s8"},"text":"Pub. L. 101–612, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3214"},"text":"104 Stat. 3214","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
