{"tag":"section","attrib":{"id":"id79c5be95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3811"},"text":null,"children":[{"tag":"num","attrib":{"value":"3811"},"text":"§ 3811.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program ineligibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79c5be96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3811/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3812"},"text":"section 3812 of this title","children":[],"tail":", and notwithstanding any other provision of law, any person who in any crop year produces an agricultural commodity on a field on which highly erodible land is predominant, or designates land on which highly erodible land is predominant to be set aside, diverted, devoted to conservation uses, or otherwise not cultivated under a program administered by the Secretary to reduce production of an agricultural commodity, as determined by the Secretary shall be ineligible for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79c5be97-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3811/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as to any commodity produced during that crop year by such person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79c5be98-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3811/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contract payments under a production flexibility contract, marketing assistance loans, and any type of price support or payment made available under the Agricultural Market Transition Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7201"},"text":"7 U.S.C. 7201","children":[],"tail":" et seq.], the Commodity Credit Corporation Charter Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s714"},"text":"15 U.S.C. 714","children":[],"tail":" et seq.), or any other Act;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c5be99-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3811/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a farm storage facility loan made under section 4(h) of the Commodity Credit Corporation Charter Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s714b/h"},"text":"15 U.S.C. 714b(h)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c5be9a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3811/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a disaster payment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c5be9b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3811/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a loan made, insured, or guaranteed under the Consolidated Farm and Rural Development Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"7 U.S.C. 1921","children":[],"tail":" et seq.) or any other provision of law administered by the Consolidated Farm Service Agency,"},{"tag":"ref","attrib":{"idref":"fn002762"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002762"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Change of Name note below."}],"tail":" if the Secretary determines that the proceeds of such loan will be used for a purpose that will contribute to excessive erosion of highly erodible land; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c5be9c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3811/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any portion of the premium paid by the Federal Crop Insurance Corporation for a policy or plan of insurance under the Federal Crop Insurance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1501"},"text":"7 U.S.C. 1501","children":[],"tail":" et seq.), on the condition that if a person is determined to have committed a violation under this subsection during a crop year, ineligibility under this subparagraph shall—"}],"tail":null},{"tag":"clause","attrib":{"id":"id79c5be9d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3811/a/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only apply to reinsurance years subsequent to the date of final determination of a violation, including all administrative appeals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79c5be9e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3811/a/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not apply to the existing reinsurance year or any reinsurance year prior to the date of final determination;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c5be9f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3811/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a payment made under section 4 or 5 of the Commodity Credit Corporation Charter Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s714b"},"text":"15 U.S.C. 714b","children":[],"tail":" or 714c) during such crop year for the storage of an agricultural commodity acquired by the Commodity Credit Corporation; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c5bea0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3811/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" during the crop year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79c5bea1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3811/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a payment made pursuant to a contract entered into under the environmental quality incentives program under subpart A of part IV of subchapter IV;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c5bea2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3811/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a payment under any other provision of subchapter IV;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c5bea3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3811/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a payment under section 2201 or 2202 of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c5bea4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3811/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a payment, loan, or other assistance under section 1003 or 1006a of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c5bea5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3811/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Highly erodible land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall have, and shall not delegate to any private person or entity, authority to determine whether a person has complied with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79c5bea6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1211"},"text":"Pub. L. 99–198, title XII, § 1211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1506"},"text":"99 Stat. 1506","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIV/s1411"},"text":"Pub. L. 101–624, title XIV, § 1411","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3569"},"text":"104 Stat. 3569","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tII/s204/1"},"text":"Pub. L. 102–237, title II, § 204(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1854"},"text":"105 Stat. 1854","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tIII/s311"},"text":"Pub. L. 104–127, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/982"},"text":"110 Stat. 982","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tII/s2002/a"},"text":"Pub. L. 107–171, title II, § 2002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/233"},"text":"116 Stat. 233","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII"},"text":"Pub. L. 113–79, title II","children":[],"tail":", §§ 2611(a)(1), 2713(b), "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/762"},"text":"128 Stat. 762","children":[],"tail":", 772; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII/s2301/d/1/A"},"text":"Pub. L. 115–334, title II, § 2301(d)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4553"},"text":"132 Stat. 4553","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79c5bea7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79c5bea8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79c5bea9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Agricultural Market Transition Act, referred to in subsec. (a)(1)(A), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/896"},"text":"110 Stat. 896","children":[],"tail":", which is classified principally to chapter 100 (§ 7201 et seq.) of Title 7, Agriculture. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7201"},"text":"section 7201 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Commodity Credit Corporation Charter Act, referred to in subsec. (a)(1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-29/ch704"},"text":"act June 29, 1948, ch. 704","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/1070"},"text":"62 Stat. 1070","children":[],"tail":", which is classified generally to subchapter II (§ 714 et seq.) of chapter 15 of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s714"},"text":"section 714 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Consolidated Farm and Rural Development Act, referred to in subsec. (a)(1)(D), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128"},"text":"Pub. L. 87–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-08"},"text":"Aug. 8, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/307"},"text":"75 Stat. 307","children":[],"tail":", which is classified principally to chapter 50 (§ 1921 et seq.) of Title 7, Agriculture. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"section 1921 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Crop Insurance Act, referred to in subsec. (a)(1)(E), is subtitle A of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"act Feb. 16, 1938, ch. 30","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/72"},"text":"52 Stat. 72","children":[],"tail":", which is classified generally to subchapter I (§ 1501 et seq.) of chapter 36 of Title 7, Agriculture. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1501"},"text":"section 1501 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79c5beaa-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" inserted “subpart A of” before “part IV”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s2713/b"},"text":"Pub. L. 113–79, § 2713(b)","children":[],"tail":", substituted “predominant” for “predominate” in two places in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s2611/a/1"},"text":"Pub. L. 113–79, § 2611(a)(1)","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s311/1"},"text":"Pub. L. 104–127, § 311(1)","children":[],"tail":", struck out “following "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"December 23, 1985","children":[],"tail":",” before “any person who” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s311/2/A"},"text":"Pub. L. 104–127, § 311(2)(A)","children":[],"tail":", added subpar. (A) and struck out former subpar. (A) which read as follows: “any type of price support or payment made available under the Agricultural Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"7 U.S.C. 1421","children":[],"tail":" et seq.), the Commodity Credit Corporation Charter Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s714"},"text":"15 U.S.C. 714","children":[],"tail":" et seq.), or any other Act;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s311/2/B"},"text":"Pub. L. 104–127, § 311(2)(B)","children":[],"tail":", (E), redesignated subpar. (D) as (C) and struck out former subpar. (C) which read as follows: “crop insurance under the Federal Crop Insurance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1501"},"text":"7 U.S.C. 1501","children":[],"tail":" et seq.);”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s311/2/E"},"text":"Pub. L. 104–127, § 311(2)(E)","children":[],"tail":", redesignated subpar. (E) as (D). Former subpar. (D) redesignated (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s311/2/C"},"text":"Pub. L. 104–127, § 311(2)(C)","children":[],"tail":", struck out before semicolon “made under the Agricultural Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"7 U.S.C. 1421","children":[],"tail":" et seq.), under section 132 of the Disaster Assistance Act of 1989 ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"7 U.S.C. 1421","children":[],"tail":" note), or under any similar provision enacted subsequent to "},{"tag":"date","attrib":{"date":"1989-08-14"},"text":"August 14, 1989","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s311/2/D"},"text":"Pub. L. 104–127, § 311(2)(D)","children":[],"tail":", (E), substituted “Consolidated Farm Service Agency” for “Farmers Home Administration” and redesignated subpar. (E) as (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s311/3"},"text":"Pub. L. 104–127, § 311(3)","children":[],"tail":", added par. (3) and struck out former par. (3) which read as follows: “during such crop year—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) a payment made under section 590h, section 590","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s590p/b"},"text":"section 590p(b) of this title","children":[],"tail":";"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) a payment made under section 2201 or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2202"},"text":"section 2202 of this title","children":[],"tail":";"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) a payment under any contract entered into pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3831"},"text":"section 3831 of this title","children":[],"tail":";"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) a payment under part II of subchapter IV of this chapter;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(E) a payment under part III of subchapter IV of this chapter; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(F) a payment, loan or other assistance under section 1003 or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1006a"},"text":"section 1006a of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Par. (1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237/s204/1/A"},"text":"Pub. L. 102–237, § 204(1)(A)","children":[],"tail":", substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"7 U.S.C. 1421","children":[],"tail":" note)” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1421"},"text":"16 U.S.C. 1421","children":[],"tail":" note)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3)(D), (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237/s204/1/B"},"text":"Pub. L. 102–237, § 204(1)(B)","children":[],"tail":", (C), made technical amendments to references to part II of subchapter IV of this chapter and part III of subchapter IV of this chapter, in subpars. (D) and (E), respectively, to clarify references in corresponding provisions of original Act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1411/1"},"text":"Pub. L. 101–624, § 1411(1)","children":[],"tail":", inserted “, or designates land on which highly erodible land is predominate to be set aside, diverted, devoted to conservation uses, or otherwise not cultivated under a program administered by the Secretary to reduce production of an agricultural commodity, as determined by the Secretary” after “is predominate” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1411/2"},"text":"Pub. L. 101–624, § 1411(2)","children":[],"tail":", inserted reference to section 132 of the Disaster Assistance Act of 1989 and similar provisions enacted after "},{"tag":"date","attrib":{"date":"1989-08-14"},"text":"Aug. 14, 1989","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1411/3"},"text":"Pub. L. 101–624, § 1411(3)","children":[],"tail":"–(5), added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79c82eab-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id79c82eac-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Consolidated Farm Service Agency effectively renamed Farm Service Agency by the amendments made to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6932"},"text":"section 6932 of Title 7","children":[],"tail":", Agriculture, by "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12404/a"},"text":"Pub. L. 115–334, title XII, § 12404(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4974"},"text":"132 Stat. 4974","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79c82ead-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tIII/s311"},"text":"Pub. L. 104–127, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/982"},"text":"110 Stat. 982","children":[],"tail":", provided that the amendment made by that section is effective 90 days after "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id79c82eae-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII"},"text":"Pub. L. 99–198, title XII","children":[],"tail":", subtitle B, "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1506"},"text":"99 Stat. 1506","children":[],"tail":", which is classified generally to this subchapter, is popularly known as the sodbuster provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79c82eaf-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wind Erosion Estimation Pilot Project","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tIII/s317"},"text":"Pub. L. 104–127, title III, § 317","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/986"},"text":"110 Stat. 986","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/127/tIII/s317"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Agriculture shall conduct a pilot project to review, and modify as appropriate, the use of wind erosion factors under the highly erodible conservation requirements of subtitle B of title XII of the Food Security Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3811"},"text":"16 U.S.C. 3811","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection of Counties and Producers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The pilot project shall be conducted for producers in those counties that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have approximately 100 percent of their cropland determined to be highly erodible under title XII of the Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3801"},"text":"16 U.S.C. 3801","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a reasonable likelihood that the use of wind erosion factors under title XII of the Act have resulted in an inequitable application of the highly erodible land requirements of title XII of the Act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the use of the land classification system under section 1201(a)(9)(A) of the Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3801/a/9/A"},"text":"16 U.S.C. 3801(a)(9)(A)","children":[],"tail":"] (as redesignated by section 301(a)(1)) may result in a more accurate delineation of the cropland."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Errors in Delineation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary determines that a significant error has occurred in delineating cropland under the pilot project, the Secretary shall, at the request of the owners or operators of the cropland, conduct a new delineation of the cropland using the most accurate available delineation process, as determined by the Secretary.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
