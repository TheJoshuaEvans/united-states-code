{"tag":"section","attrib":{"id":"id78863a6c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719"},"text":null,"children":[{"tag":"num","attrib":{"value":"719"},"text":"§ 719.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78863a6d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Interior (in this subchapter referred to as the “Secretary”) may carry out in accordance with this subchapter a program to be known as the “Junior Duck Stamp Conservation and Design Program” (in this subchapter referred to as the “Program”) to accomplish the goals of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78863a6e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing to school children environmental education opportunities relating to the conservation and management of migratory birds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78863a6f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the capacity for schools, States, and other educational programs to conduct conservation and education programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78863a70-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program features","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Program shall consist of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78863a71-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting in all interested States the activities which on the day before ","children":[{"tag":"date","attrib":{"date":"1994-10-06"},"text":"October 6, 1994","children":[],"tail":", are conducted under the program known as the Junior Duck Stamp Conservation and Design Program;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78863a72-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities authorized under the Program by this subchapter or any other Act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78863a73-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other activity necessary to carry out the conservation and education goals of the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78863a74-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effort to conduct Program in all States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78863a75-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall take appropriate steps to seek to conduct the Program in all of the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78863a76-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall annually submit a report to the Congress on the status of the Program in each of the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78863a77-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/340/s2"},"text":"Pub. L. 103–340, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-06"},"text":"Oct. 6, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3119"},"text":"108 Stat. 3119","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/316/s2/1"},"text":"Pub. L. 106–316, § 2(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-19"},"text":"Oct. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1276"},"text":"114 Stat. 1276","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78863a78-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78863a79-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78863a7a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/316"},"text":"Pub. L. 106–316","children":[],"tail":" struck out “50” before “States” in pars. (1) and (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78863a7b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id78863a7c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/166/s1"},"text":"Pub. L. 109–166, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-10"},"text":"Jan. 10, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3576"},"text":"119 Stat. 3576","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/166/s1"},"text":"“This Act [amending sections 719a and 719c of this title and provisions listed in a table of National Wildlife Refuges set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s668dd"},"text":"section 668dd of this title","children":[],"tail":"] may be cited as the ‘Junior Duck Stamp Reauthorization Amendments Act of 2005’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id78863a7d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/340/s1"},"text":"Pub. L. 103–340, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-06"},"text":"Oct. 6, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3119"},"text":"108 Stat. 3119","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/340/s1"},"text":"“This Act [enacting this subchapter and provisions listed in a table of National Wildlife Refuges set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s668dd"},"text":"section 668dd of this title","children":[],"tail":"] may be cited as the ‘Junior Duck Stamp Conservation and Design Program Act of 1994’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
