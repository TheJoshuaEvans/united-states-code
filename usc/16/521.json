{"tag":"section","attrib":{"id":"id7826dc05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521"},"text":null,"children":[{"tag":"num","attrib":{"value":"521"},"text":"§ 521.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lands acquired to be reserved, held, and administered as national forest lands; designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Subject to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s519"},"text":"section 519 of this title","children":[],"tail":" the lands acquired under this Act shall be permanently reserved, held, and administered as national forest lands under the provisions of section 471 "},{"tag":"ref","attrib":{"idref":"fn002407"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002407"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title and acts supplemental to and amendatory thereof. And the Secretary of Agriculture may from time to time divide the lands acquired under this Act into such specific national forests and so designate the same as he may deem best for administrative purposes."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7826dc06-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-01/ch186/s11"},"text":"Mar. 1, 1911, ch. 186, § 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/963"},"text":"36 Stat. 963","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7826dc07-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7826dc08-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"te