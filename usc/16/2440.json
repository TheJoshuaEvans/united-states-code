{"tag":"section","attrib":{"id":"id799ade63-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2440"},"text":null,"children":[{"tag":"num","attrib":{"value":"2440"},"text":"§ 2440.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of courts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The district courts of the United States shall have exclusive jurisdiction over any case or controversy arising under the provisions of this chapter or of any regulation promulgated under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id799ade64-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/623/tIII/s311"},"text":"Pub. L. 98–623, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3405"},"text":"98 Stat. 3405","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
