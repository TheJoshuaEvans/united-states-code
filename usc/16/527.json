{"tag":"section","attrib":{"id":"id78294c67-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s527"},"text":null,"children":[{"tag":"num","attrib":{"value":"527"},"text":"§ 527.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Forest Service funds for administration of certain lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Forest Service may expend funds available for national forest protection and management for the administration of lands under contract for purchase or for the acquisition of which condemnation proceedings have been instituted under the Act of ","children":[{"tag":"date","attrib":{"date":"1911-03-01"},"text":"March 1, 1911","children":[],"tail":", and the Act of "},{"tag":"date","attrib":{"date":"1924-06-07"},"text":"June 7, 1924","children":[],"tail":", and lands transferred to the Forest Service for administration."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78294c68-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-09-21/ch412"},"text":"Sept. 21, 1944, ch. 412","children":[],"tail":", title II, § 211, "},{"tag":"ref","attrib":{"href":"/us/stat/58/737"},"text":"58 Stat. 737","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78294c69-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78294c6a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78294c6b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1911-03-01"},"text":"March 1, 1911","children":[],"tail":", referred to in text, is "},{"tag":"ref","attrib":{"href":"/us/act/1911-03-01/ch186"},"text":"act Mar. 1, 1911, ch. 186","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/961"},"text":"36 Stat. 961","children":[],"tail":", popularly known as the Weeks Law, which enacted former sections 513 and 514 and sections 515 to 519, 521, 552, and 563 of this title and amended sections 480 and 500 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s552"},"text":"section 552 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1924-06-07"},"text":"June 7, 1924","children":[],"tail":", referred to in text, is "},{"tag":"ref","attrib":{"href":"/us/act/1924-06-07/ch348"},"text":"act June 7, 1924, ch. 348","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/653"},"text":"43 Stat. 653","children":[],"tail":", which is classified to sections 471, 499, 505, 515, 564, 565, 566, 567, 568, 569, and 570 of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78294c6c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section was enacted as a part of the Department of Agriculture Organic Act of 1944.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
