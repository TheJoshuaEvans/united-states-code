{"tag":"section","attrib":{"id":"id7851bc33-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"583j–5"},"text":"§ 583j–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits and report requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7851bc34-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s10101"},"text":"section 10101 of title 36","children":[],"tail":" the Foundation shall be treated as a corporation in part B of subtitle II of title 36."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7851bc35-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall transmit each year to Congress a report of its proceedings and activities of the previous year, including a full and complete statement of its receipts, expenditures, and investments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7851bc36-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/593/tIV/s407"},"text":"Pub. L. 101–593, title IV, § 407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2973"},"text":"104 Stat. 2973","ch