{"tag":"section","attrib":{"id":"id789491fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s773g"},"text":null,"children":[{"tag":"num","attrib":{"value":"773g"},"text":"§ 773g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crimes and criminal penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id789491fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s773g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person is guilty of any ","children":[{"tag":"ref","attrib":{"idref":"fn002508"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002508"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “an”."}],"tail":" offense if he commits an act prohibited by section 773e(a)(2), (3), (4), or (6) "},{"tag":"ref","attrib":{"idref":"fn002509"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002509"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":"See References in Text note below."}],"tail":" of this title; or section 773e(b) "},{"tag":"ref","attrib":{"idref":"fn002509"},"text":"2","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id789491fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s773g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fines; imprisonment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any offense described in subsection (a) is punishable by a fine of not more than $200,000 or imprisonment for not more than 6 months, or both; except that if in the commission of any offense the person uses a dangerous weapon, engages in conduct that causes bodily injury to any officer authorized to enforce the provisions of this subchapter, or places any such officer in fear of imminent bodily injury the offense is punishable by a fine of not more than $400,000, or imprisonment for not more than 10 years or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id789491fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s773g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is Federal jurisdiction over any offense described in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id789491fe-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/176/s9"},"text":"Pub. L. 97–176, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-05-17"},"text":"May 17, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/81"},"text":"96 Stat. 81","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/479/tIII/s301/c"},"text":"Pub. L. 109–479, title III, § 301(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3623"},"text":"120 Stat. 3623","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id789491ff-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78949200-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78949201-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (a) and pars. (2), (3), (4), and (6) of subsec. (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s773e"},"text":"section 773e of this title","children":[],"tail":", referred to in subsec. (a), were renumbered par. (1) and subpars. (B), (C), (D), and (F), respectively, of par. (1) of "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s773e"},"text":"section 773e of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/114/81/tI/s110/1"},"text":"Pub. L. 114–81, title I, § 110(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2015-11-05"},"text":"Nov. 5, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/659"},"text":"129 Stat. 659","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s773e"},"text":"section 773e of this title","children":[],"tail":", referred to in subsec. (a), was renumbered par. (2) of "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s773e"},"text":"section 773e of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/114/81/tI/s110/2"},"text":"Pub. L. 114–81, title I, § 110(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-05"},"text":"Nov. 5, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/659"},"text":"129 Stat. 659","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78949202-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/479"},"text":"Pub. L. 109–479","children":[],"tail":" substituted “$200,000” for “$50,000” and “$400,000,” for “$100,000,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
