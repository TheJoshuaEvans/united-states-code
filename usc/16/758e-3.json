{"tag":"section","attrib":{"id":"id78921ff4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s758e–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"758e–3"},"text":"§ 758e–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations; contract terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary to carry out the purposes of sections 758e to 758e–5 of this title. Any contract entered into pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s758e"},"text":"section 758e of this title","children":[],"tail":" shall be subject to such terms and conditions as the Secretary deems necessary and appropriate to protect the interests of the United States."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78921ff5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/444/s6"},"text":"Pub. L. 92–444, § 6","children":[],"tail":", formerly § 5, "},{"tag":"date","attrib":{"date":"1972-09-29"},"text":"Sept. 29, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/745"},"text":"86 Stat. 745","children":[],"tail":"; renumbered § 6, "},{"tag":"ref","attrib":{"href":"/us/pl/95/295/s1/4"},"text":"Pub. L. 95–295, § 1(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-06-16"},"text":"June 16, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/319"},"text":"92 Stat. 319","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
