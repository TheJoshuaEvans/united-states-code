{"tag":"section","attrib":{"id":"id7a22d234-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7004"},"text":null,"children":[{"tag":"num","attrib":{"value":"7004"},"text":"§ 7004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States representation on joint technical committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a22d235-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7004/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientific experts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a22d236-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7004/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of State, shall appoint no more than 2 individuals to serve as scientific experts on the joint technical committee, at least 1 of whom shall be an official of the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a22d237-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7004/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual appointed under paragraph (1) shall be appointed for a term of not to exceed 4 years, but shall be eligible for reappointment. An individual appointed to fill a vacancy occurring prior to the expiration of the term of office of that individual’s predecessor shall be appointed for the remainder of that term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a22d238-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7004/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent member","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to individuals appointed under subsection (a), the Secretary, jointly with the Government of Canada, shall appoint 1 independent member to the joint technical committee selected from a list of names provided by the advisory panel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a22d239-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/479/tVI/s605"},"text":"Pub. L. 109–479, title VI, § 605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3646"},"text":"120 Stat. 3646","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/348/tIII/s302/a"},"text":"Pub. L. 111–348, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3672"},"text":"124 Stat. 3672","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a22d23a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a22d23b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a22d23c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/348"},"text":"Pub. L. 111–348","children":[],"tail":" substituted “no more than 2” for “at least 6 but not more than 12”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
