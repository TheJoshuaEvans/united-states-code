{"tag":"section","attrib":{"id":"id79c103d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3644"},"text":null,"children":[{"tag":"num","attrib":{"value":"3644"},"text":"§ 3644.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on spending authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"New spending authority or authority to enter into contracts provided in this chapter shall be effective only to such extent, or in such amounts, as are provided in advance in appropriation Acts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79c103da-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/5/s15"},"text":"Pub. L. 99–5, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-03-15"},"text":"Mar. 15, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/15"},"text":"99 Stat. 15","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
