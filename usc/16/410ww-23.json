{"tag":"section","attrib":{"id":"id7763644b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–23"},"text":null,"children":[{"tag":"num","attrib":{"value":"410ww–23"},"text":"§ 410ww–23.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General powers of Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7763644c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–23/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may hold such hearings, sit and act at such times and places, take such testimony, and receive such evidence as the Commission may deem advisable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7763644d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–23/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Commission may seek and accept donations of funds, property, or service from individuals, foundations, corporations, and other private entities and public entities for the purpose of carrying out its duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7763644e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–23/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds to obtain money","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may use its funds to obtain money from any source under any program or law requiring the recipient of such money to make a contribution in order to receive such money.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7763644f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–23/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mail","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may use the United States mails in the same manner and upon the same conditions as other departments and agencies of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77636450-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–23/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of acquired assets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any revenues or other assets acquired by the Commission by donations, the lease or sale of property, or fees for services shall be available to the Commission, without fiscal year limitations, to be used for any function of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77636451-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–23/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Historical and cultural programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission is authorized to carry out historical, educational, or cultural programs which encourage or enhance appreciation of the historic resources in the Miami Valley associated with the Wright brothers, aviation, or the life and works of Paul Laurence Dunbar.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77636452-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–23/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical and preservation assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may provide technical and preservation assistance to owners of property within the districts, sites, and properties referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410ww–22/a"},"text":"section 410ww–22(a) of this title","children":[],"tail":" consistent with the purposes of this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77636453-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–23/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obtaining property","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77636454-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–23/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission may obtain by purchase, rental, donation, or otherwise, such property, facilities, and services as may be needed to carry out its duties except that the Commission may not acquire any real property or interest in real property otherwise than under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77636455-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–23/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (3), the Commission may acquire real property, or interests in real property, in the districts, sites, and properties referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410ww–22/a"},"text":"section 410ww–22(a) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77636456-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–23/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by gift or devise; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77636457-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–23/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by purchase from a willing seller with money which was given or bequeathed to the Commission on the condition that such money would be used to purchase real property, or interests in real property, in such district and sites.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77636458-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–23/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any real property or interest in real property acquired by the Commission under paragraph (2) shall be conveyed by the Commission to an appropriate public agency, as determined by the Commission. Any such conveyance shall be made—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77636459-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–23/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as soon as practicable after such acquisition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7763645a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–23/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without consideration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7763645b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–23/h/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the condition that the real property or interest in real property so conveyed is used for public purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7763645c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/419/tII/s203"},"text":"Pub. L. 102–419, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-16"},"text":"Oct. 16, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2146"},"text":"106 Stat. 2146","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
