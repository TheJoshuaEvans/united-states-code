{"tag":"section","attrib":{"id":"id777d7beb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx"},"text":null,"children":[{"tag":"num","attrib":{"value":"410xxx"},"text":"§ 410xxx.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ste. Genevieve National Historical Park","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id777d7bec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777d7bed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Historic District","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Historic District” means the Ste. Genevieve Historic District National Historic Landmark, as generally depicted on the Map.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7bee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Historical Park","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Historical Park” means the Ste. Genevieve National Historical Park established by subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7bef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Map” means the map entitled “Ste. Genevieve National Historical Park Proposed Boundary Addition”, numbered 571/177,464, and dated September 2021.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7bf0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7bf1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special resource study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “special resource study” means the study entitled “Ste. Genevieve Final Special Resources Study and Environmental Assessment, Missouri” and dated May 2016.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7bf2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means the State of Missouri.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777d7bf3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777d7bf4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), there is established the Ste. Genevieve National Historical Park in the State as a unit of the National Park System to preserve, protect, and interpret for the benefit of present and future generations the themes of French settlement, vernacular architecture, and community form and farming on the frontier associated with Ste. Genevieve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7bf5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions for establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Historical Park shall not be established until the date on which the Secretary determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777d7bf6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sufficient land has been acquired for the Historical Park to constitute a manageable unit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777d7bf7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary has entered into a written agreement providing that land owned by the State, the City of Ste. Genevieve, or other entity within the Historic District shall be managed consistent with the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777d7bf8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The boundaries of the Historical Park shall be the boundaries generally depicted on the Map.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777d7bf9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of Map","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777d7bfa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Map shall be on file and available for public inspection in the appropriate offices of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7bfb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to correct errors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may correct any clerical or typographical errors in the Map.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777d7bfc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777d7bfd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may acquire any land or interest in land located within the boundary of the Historical Park or any nationally significant property identified in the special resource study within the Historic District by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777d7bfe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" donation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777d7bff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase with donated or appropriated funds; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777d7c00-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7c01-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary revision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the acquisition of any property within the Historic District under paragraph (1), the Secretary shall revise the boundary of the Historical Park to include the property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7c02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Visitor center","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777d7c03-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may acquire, by donation, the land (including any improvements to the land) owned by the city of Ste. Genevieve, Missouri, and used as the visitor center for the Historical Park, as generally depicted on the Map as “Proposed Boundary Addition”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777d7c04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on acquisition of the land described in subparagraph (A), shall revise the boundary of the Historical Park to include the acquired land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7c05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire, by purchase from a willing seller or by donation, not more than 20 acres of land in the vicinity of the Historical Park for administrative facilities for the Historical Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777d7c06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777d7c07-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall administer the Historical Park in accordance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777d7c08-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777d7c09-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the laws generally applicable to units of the National Park System, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777d7c0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 100101(a), chapter 1003, and sections 100751(a), 100752, 100753, and 102101 of title 54; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777d7c0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 3201 of title 54.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7c0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777d7c0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after the date on which funds are made available to prepare a general management plan for the Historical Park, the Secretary shall prepare the general management plan in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s100502"},"text":"section 100502 of title 54","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777d7c0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On completion of the general management plan under subparagraph (A), the Secretary shall submit to the Committee on Natural Resources of the House of Representatives and the Committee on Energy and Natural Resources of the Senate the general management plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7c0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related sites","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide interpretative tours and educational programs at related historic and cultural sites within the Historic District associated with the purposes for which the Historical Park is established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777d7c10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777d7c11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide technical assistance and enter into cooperative agreements with the owner of a nationally significant property within the Historical Park or the Historic District, to identify, mark, interpret, improve, and restore the property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7c12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right of access","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A cooperative agreement entered into under paragraph (1) shall provide that the Secretary, acting through the Director of the National Park Service, shall have the right of access at all reasonable times to all public portions of the property covered by the agreement for the purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777d7c13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting visitors through the property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777d7c14-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interpreting the property for the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7c15-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-sharing requirement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777d7c16-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the total cost of any activity carried out under a cooperative agreement entered into under this subsection shall be not more than 50 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777d7c17-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share of an activity carried out under a cooperative agreement entered into under this subsection may be in the form of donated property, goods, or services fairly valued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7c18-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Changes or alterations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No changes or alterations shall be made to any property or project covered by a cooperative agreement entered into under paragraph (1) unless the Secretary and the other party to the agreement agree to the changes or alterations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7c19-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conversion, use, or disposal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any payment by the Secretary under this subsection shall be subject to an agreement that the conversion, use, or disposal of a property or project for purposes contrary to the purposes of this section, as determined by the Secretary, shall entitle the United States to reimbursement in any amount equal to the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777d7c1a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/g/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts made available to the property or project by the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777d7c1b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/g/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the portion of the increased value of the property or project attributable to the amounts made available under this subsection, as determined at the time of the conversion, use, or disposal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777d7c1c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410xxx/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited role of the Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section authorizes the Secretary to assume overall financial responsibility for the operation, maintenance, or management of the Historic District.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id777d7c1d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dG/tI/s121/a/2/dB/tVII/s7134"},"text":"Pub. L. 115–141, div. G, title I, § 121(a)(2) [div. B, title VII, § 7134]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/661"},"text":"132 Stat. 661","children":[],"tail":", 1225A–5; "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tII/s2109/a"},"text":"Pub. L. 116–9, title II, § 2109(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/731"},"text":"133 Stat. 731","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dDD/tVI/s617"},"text":"Pub. L. 117–328, div. DD, title VI, § 617","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5605"},"text":"136 Stat. 5605","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id777d7c1e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id777d7c1f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id777d7c20-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460cccc"},"text":"section 460cccc of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section 7134 of S. 1460, One Hundred Fifteenth Congress, as placed on the calendar of the Senate on ","children":[{"tag":"date","attrib":{"date":"2017-06-29"},"text":"June 29, 2017","children":[],"tail":", which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id777d7c21-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s617/a/1"},"text":"Pub. L. 117–328, § 617(a)(1)","children":[],"tail":", substituted “numbered 571/177,464, and dated September 2021” for “numbered 571/149,942, and dated December 2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s617/a/2"},"text":"Pub. L. 117–328, § 617(a)(2)","children":[],"tail":", (3), added par. (4) and redesignated former pars. (4) and (5) as (5) and (6), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s617/b"},"text":"Pub. L. 117–328, § 617(b)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s617/c"},"text":"Pub. L. 117–328, § 617(c)","children":[],"tail":", added pars. (3) and (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9"},"text":"Pub. L. 116–9","children":[],"tail":" substituted “ ‘Ste. Genevieve National Historical Park Proposed Boundary Addition’, numbered 571/149,942, and dated December 2018” for “ ‘Ste. Genevieve National Historical Park Proposed Boundary’ ”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
