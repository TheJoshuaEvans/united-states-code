{"tag":"section","attrib":{"id":"id7a2eb9bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7901"},"text":null,"children":[{"tag":"num","attrib":{"value":"7901"},"text":"§ 7901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of national policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a2eb9bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7901/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress declares that it is the policy of the United States that Federal departments and agencies, in accordance with the missions of the departments and agencies, Executive Orders 12962 and 13443 (60 Fed. Reg. 30769 (","children":[{"tag":"date","attrib":{"date":"1995-06-07"},"text":"June 7, 1995","children":[],"tail":"); 72 Fed. Reg. 46537 ("},{"tag":"date","attrib":{"date":"2007-08-16"},"text":"August 16, 2007","children":[],"tail":")), and applicable law, shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2eb9bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7901/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the expansion and enhancement of hunting, fishing, and recreational shooting opportunities on Federal land, in consultation with the Wildlife and Hunting Heritage Conservation Council, the Sport Fishing and Boating Partnership Council, State and Tribal fish and wildlife agencies, and the public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eb9be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7901/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conserve and enhance aquatic systems and the management of game species and the habitat of those species on Federal land, including through hunting and fishing, in a manner that respects—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2eb9bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7901/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State management authority over wildlife resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2eb9c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7901/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private property rights; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2eb9c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7901/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider hunting, fishing, and recreational shooting opportunities as part of all Federal plans for land, resource, and travel management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2eb9c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7901/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this title,","children":[{"tag":"ref","attrib":{"idref":"fn002864"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002864"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note be