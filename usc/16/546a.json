{"tag":"section","attrib":{"id":"id78411a26-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546a"},"text":null,"children":[{"tag":"num","attrib":{"value":"546a"},"text":"§ 546a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundaries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78411a27-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Saint Helena Island","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The scenic area shall comprise all of Saint Helena Island, in Lake Michigan, Michigan, and all associated rocks, pinnacles, islands, and islets within one-eighth mile of the shore of Saint Helena Island.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78411a28-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundaries of Hiawatha National Forest extended","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon establishment of the scenic area, the boundaries of the Hiawatha National Forest shall be extended to include all of the lands within the scenic area. All such extended boundaries shall be deemed boundaries in existence as of ","children":[{"tag":"date","attrib":{"date":"1965-01-01"},"text":"January 1, 1965","children":[],"tail":", for the purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100506"},"text":"section 100506 of title 54","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78411a29-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to local governments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Solely for purposes of payments to local governments pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6902"},"text":"section 6902 of title 31","children":[],"tail":", lands acquired by the United States under sections 546 to 546a–5 of this title shall be treated as entitlement lands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78411a2a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/431/s3"},"text":"Pub. L. 106–431, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-06"},"text":"Nov. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1905"},"text":"114 Stat. 1905","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/287/s5/d/18"},"text":"Pub. L. 113–287, § 5(d)(18)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3266"},"text":"128 Stat. 3266","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78411a2b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78411a2c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78411a2d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (b). ","chil