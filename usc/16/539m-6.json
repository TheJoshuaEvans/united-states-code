{"tag":"section","attrib":{"id":"id7832c298-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"539m–6"},"text":"§ 539m–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction over the Area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7832c299-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal jurisdiction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7832c29a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–6/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, jurisdiction over crimes committed in the Area shall be allocated as provided in this paragraph.","children":[{"tag":"ref","attrib":{"idref":"fn002412"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002412"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection.”"}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c29b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–6/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of the Pueblo","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Pueblo shall have jurisdiction over an offense committed by a member of the Pueblo or of another federally-recognized Indian tribe who is present in the Area with the permission of the Pueblo under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m–3/a/4"},"text":"section 539m–3(a)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c29c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–6/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of the United States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The United States shall have jurisdiction over—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7832c29d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–6/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an offense described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1153"},"text":"section 1153 of title 18","children":[],"tail":" committed by a member of the Pueblo or another federally-recognized Indian tribe;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7832c29e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–6/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an offense committed by any person in violation of the laws (including regulations) pertaining to the protection and management of national forests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7832c29f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–6/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforcement of Federal criminal laws of general applicability; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7832c2a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–6/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other offense committed by a member of the Pueblo against a person not a member of the Pueblo.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c2a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–6/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of the State of New Mexico","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State of New Mexico shall have jurisdiction over an offense under the law of the State committed by a person not a member of the Pueblo.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c2a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–6/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overlapping jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent that the respective allocations of jurisdiction over the Area under paragraphs (2), (3), and (4) overlap, the governments shall have concurrent jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c2a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–6/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal use of State law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under the jurisdiction of the United States described in paragraph (3)(D), Federal law shall incorporate any offense defined and punishable under State law that is not so defined under Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7832c2a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil jurisdiction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7832c2a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–6/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraphs (2) and (3), the United States, the State of New Mexico, and local public bodies shall have the same civil adjudicatory, regulatory, and taxing jurisdiction over the Area as was exercised by those entities on the day before ","children":[{"tag":"date","attrib":{"date":"2003-02-20"},"text":"February 20, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c2a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–6/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of the Pueblo","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7832c2a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–6/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Pueblo shall have exclusive civil adjudicatory jurisdiction over—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7832c2a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–6/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a dispute involving only members of the Pueblo;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7832c2a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–6/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a civil action brought by the Pueblo against a member of the Pueblo; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7832c2aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–6/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a civil action brought by the Pueblo against a member of another federally-recognized Indian tribe for a violation of an understanding between the Pueblo and the other tribe regarding use of or access to the Area for traditional or cultural uses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7832c2ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–6/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulatory jurisdiction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Pueblo shall have no regulatory jurisdiction over the Area, except that the Pueblo shall have exclusive authority to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7832c2ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–6/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulate traditional or cultural uses by the members of the Pueblo and administer access to the Area by other federally-recognized Indian tribes for traditional or cultural uses, to the extent such regulation is consistent with sections 539m to 539m–12 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7832c2ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–6/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulate hunting and trapping in the Area by members of the Pueblo, to the extent that the hunting or trapping is related to traditional or cultural uses, except that such hunting and trapping outside of that portion of the Area in sections 13, 14, 23, 24, and the northeast quarter of section 25 of T12N, R4E, and section 19 of T12N, R5E, N.M.P.M., Sandoval County, New Mexico, shall be regulated by the Pueblo in a manner consistent with the regulations of the State of New Mexico concerning types of weapons and proximity of hunting and trapping to trails and residences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7832c2ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–6/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxing jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Pueblo shall have no authority to impose taxes within the Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c2af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–6/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and local taxing jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State of New Mexico and local public bodies shall have no authority within the Area to tax the uses or the property of the Pueblo, members of the Pueblo, or members of other federally-recognized Indian tribes authorized to use the Area under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m–3/a/4"},"text":"section 539m–3(a)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7832c2b0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dF/tIV/s408"},"text":"Pub. L. 108–7, div. F, title IV, § 408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/286"},"text":"117 Stat. 286","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7832c2b1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7832c2b2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7832c2b3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 539m to 539m–12 of this title, referred to in subsec. (b)(2)(B)(i), was in the original “this title”, meaning title IV of div. F of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/279"},"text":"117 Stat. 279","children":[],"tail":", which is classified generally to sections 539m to 539m–12 of this title. For complete classification of title IV to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m"},"text":"section 539m of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
