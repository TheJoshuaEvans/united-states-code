{"tag":"section","attrib":{"id":"id77a15817-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"450dd"},"text":"§ 450dd.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" De Soto National Memorial; establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of establishing an appropriate memorial to Hernando De Soto, the Secretary of the Interior is authorized, in his discretion, to acquire on behalf of the United States, by donation, by purchase with donated funds when purchaseable ","children":[{"tag":"ref","attrib":{"idref":"fn002259"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002259"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “purchasable”."}],"tail":" at prices deemed by him reasonable, or by condemnation with donated funds, such lands and interests in land within an area of not to exceed thirty acres as he may select in the vicinity of Tampa Bay and Bradenton, Florida, and to construct thereon a suitable memorial structure, together with such connecting roads and public facilities as may be desirable."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77a15818-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-03-11/ch109/s1"},"text":"Mar. 11, 1948, ch. 109, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/78"},"text":"62 Stat. 78","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/728/s1A"},"text":"Pub. L. 86–728, § 1A","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-08"},"text":"Sept. 8, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/856"},"text":"74 Stat. 856","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77a15819-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77a1581a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77a1581b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1960—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/728"},"text":"Pub. L. 86–728","children":[],"tail":" increased limitation on acquisition of land from twenty-five to thirty acres."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77a1581c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77a1581d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 3 of act ","children":[{"tag":"date","attrib":{"date":"1948-03-11"},"text":"Mar. 11, 1948","children":[],"tail":", as amended "},{"tag":"ref","attrib":{"href":"/us/act/1950-08-21/ch768"},"text":"Aug. 21, 1950, ch. 768","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/469"},"text":"64 Stat. 469","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1960-09-08"},"text":"Sept. 8, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/86/728/s1B"},"text":"Pub. L. 86–728, § 1B","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/856"},"text":"74 Stat. 856","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/95/625/tI/s101/8"},"text":"Pub. L. 95–625, title I, § 101(8)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3471"},"text":"92 Stat. 3471","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1979-10-12"},"text":"Oct. 12, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/96/87/tIV/s401/a"},"text":"Pub. L. 96–87, title IV, § 401(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/665"},"text":"93 Stat. 665","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/87/tIV/s401/a"},"text":"“There is hereby authorized to be appropriated such sums, not to exceed $292,000, as may be necessary to carry out the provisions of this Act [sections 450dd and 450dd–1 of this title].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
