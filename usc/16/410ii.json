{"tag":"section","attrib":{"id":"id77575624-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"410ii"},"text":"§ 410ii.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77575625-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ii/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77575626-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ii/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" archeological research in the San Juan Basin conducted over the past several years has greatly increased public knowledge of the scope of the prehistoric culture referred to as Chacoan Anasazi;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77575627-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ii/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the discoveries and the increased general interest in the Chaco phenomenon have come at a time when the San Juan Basin is experiencing extensive exploration and development for a wide variety of energy-related resources, including coal, uranium, oil, and natural gas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77575628-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ii/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of the San Juan Basin’s important natural resources and the valid existing rights of private property owners will not be adversely affected by the preservation of the archeological integrity of the area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77575629-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ii/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in light of the national significance of the Chacoan sites and the urgent need to protect them, continued cooperation between Federal agencies and private corporations is necessary to provide for development in the San Juan Basin in a manner compatible with preservation and archeological research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7757562a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ii/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is the purpose of this subchapter to recognize the unique archeological resources associated with the prehistoric Chacoan culture in the San Juan Basin and surrounding areas; to provide for the preservation and interpretation of these resources; and to facilitate research activities associated with these resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7757562b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/550/tV/s501"},"text":"Pub. L. 96–550, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-19"},"text":"Dec. 19, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3227"},"text":"94 Stat. 3227","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/11/s2"},"text":"Pub. L. 104–11, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-05-18"},"text":"May 18, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/158"},"text":"109 Stat. 158","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7757562c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7757562d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7757562e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1995—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/11"},"text":"Pub. L. 104–11","children":[],"tail":" substituted “San Juan Basin and surrounding areas” for “San Juan Basin”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7757562f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id77575630-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/413/s1"},"text":"Pub. L. 108–413, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2325"},"text":"118 Stat. 2325","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/413/s1"},"text":"“This Act [enacting provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410ii–6"},"text":"section 410ii–6 of this title","children":[],"tail":"] may be cited as the ‘Hibben Center Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id77575631-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/11/s1"},"text":"Pub. L. 104–11, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-05-18"},"text":"May 18, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/158"},"text":"109 Stat. 158","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/11/s1"},"text":"“This Act [amending this section and sections 410ii–1, 410ii–3, and 410ii–5 of this title] may be cited as the ‘Chacoan Outliers Protection Act of 1995’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
