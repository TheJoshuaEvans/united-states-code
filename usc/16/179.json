{"tag":"section","attrib":{"id":"id770fed62-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s179"},"text":null,"children":[{"tag":"num","attrib":{"value":"179"},"text":"§ 179.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donations of buildings and other property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized, in his discretion, to accept buildings, moneys, or other property which may be useful in the betterment of the administration and affairs of the Glacier National Park under his supervision, and which may be donated for park purposes. He may accept patented lands or rights-of-way over patented lands in the Glacier National Park that may be donated for park purposes.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id770fed63-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-07-01/ch209/s1"},"text":"July 1, 1916, ch. 209, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/308"},"text":"39 Stat. 308","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1917-06-12/ch27/s1"},"text":"June 12, 1917, ch. 27, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/151"},"text":"40 Stat. 151","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id770fed64-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id770fed65-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id770fed66-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The first sentence of this section is from section 1 of act ","children":[{"tag":"date","attrib":{"date":"1917-06-12"},"text":"June 12, 1917","children":[],"tail":", and the last sentence from section 1 of act "},{"tag":"date","attrib":{"date":"1916-07-01"},"text":"July 1, 1916","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
