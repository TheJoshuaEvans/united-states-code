{"tag":"section","attrib":{"id":"id79e4b802-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3932"},"text":null,"children":[{"tag":"num","attrib":{"value":"3932"},"text":"§ 3932.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79e4b803-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3932/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation and cooperation with the Secretary of Agriculture, shall prepare and submit to the committees—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e4b804-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3932/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by ","children":[{"tag":"date","attrib":{"date":"1987-03-30"},"text":"March 30, 1987","children":[],"tail":", a report regarding the status, condition, and trends of wetlands in the lower Mississippi alluvial plain and the prairie pothole regions of the United States; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e4b805-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3932/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by ","children":[{"tag":"date","attrib":{"date":"1987-09-30"},"text":"September 30, 1987","children":[],"tail":", a report regarding trends of wetlands in all other areas of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e4b806-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3932/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The reports required under subsection (a) shall contain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e4b807-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3932/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the factors responsible for wetlands destruction, degradation, protection and enhancement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e4b808-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3932/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a compilation and analysis of Federal statutory and regulatory mechanisms, including expenditures, financial assistance, and tax provisions which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e4b809-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3932/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" induce wetlands destruction or degradation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e4b80a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3932/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect or enhance wetlands;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e4b80b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3932/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a compilation and analysis of Federal expenditures resulting from wetlands destruction, degradation, protection or enhancement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e4b80c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3932/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of public and private patterns of ownership of wetlands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e4b80d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3932/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an analysis of the environmental and economic impact of eliminating or restricting future Federal expenditures and financial assistance, whether direct or indirect, which have the effect of encouraging the destruction, degradation, protection or enhancement of wetlands, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e4b80e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3932/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public works expenditures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e4b80f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3932/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance programs such as price support programs, commodity loans and purchase programs and disaster assistance programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e4b810-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3932/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" soil conservation programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e4b811-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3932/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certain income tax provisions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e4b812-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3932/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an analysis of the environmental and economic impact of failure to restrict future Federal expenditures, financial assistance, and tax provisions which have the effect of encouraging the destruction, degradation, protection or enhancement of wetlands, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e4b813-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3932/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance for normal silviculture activity (such as plowing, seeding, planting, cultivating, minor drainage, or harvesting for the production of fiber or forest products);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e4b814-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3932/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal expenditures required incident to studies, evaluations, design, construction, operation, maintenance, or rehabilitation of Federal water resource development activities, including channel improvements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e4b815-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3932/b/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the commodity loans and purchases program and cotton, feed grain, wheat, and rice production stabilization programs administered by the Department of Agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e4b816-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3932/b/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal expenditures for the construction of publicly owned or publicly operated highways, roads, structures, or facilities that are essential links in a larger network or system; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e4b817-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3932/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for the conservation of wetlands resources based on an evaluation and comparison of all management alternatives, and combinations of management alternatives, such as State and local actions, Federal actions, and initiatives by private organizations and individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79e4b818-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/645/tIV/s402"},"text":"Pub. L. 99–645, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3589"},"text":"100 Stat. 3589","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
