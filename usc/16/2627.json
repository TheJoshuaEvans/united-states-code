{"tag":"section","attrib":{"id":"id799f991f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2627"},"text":null,"children":[{"tag":"num","attrib":{"value":"2627"},"text":"§ 2627.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to State law","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id799f9920-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2627/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revenue and rate of return","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall authorize or require the recovery by an electric utility of revenues, or of a rate of return, in excess of, or less than, the amount of revenues or the rate of return determined to be lawful under any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799f9921-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2627/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter prohibits any State regulatory authority or nonregulated electric utility from adopting, pursuant to State law, any standard or rule affecting electric utilities which is different from any standard established by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799f9922-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2627/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to any electric utility which is a Federal agency, and with respect to the Tennessee Valley Authority when it is treated as a State regulatory authority as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2602/17"},"text":"section 2602(17) of this title","children":[],"tail":", any reference in section 2621 or 2623 of this title to State law shall be treated as a reference to Federal law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id799f9923-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617/tI/s117"},"text":"Pub. L. 95–617, title I, § 117","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3128"},"text":"92 Stat. 3128","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id799f9924-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id799f9925-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id799f9926-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (b), was in the original “this title”, meaning title I (§ 101 et seq.) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617"},"text":"Pub. L. 95–617","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3120"},"text":"92 Stat. 3120","children":[],"tail":", which enacted subchapters I to IV of this chapter and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6808"},"text":"section 6808 of Title 42","children":[],"tail":", The Public Health and Welfare, and amended sections 6802 to 6807 of Title 42. For complete classification of title I to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
