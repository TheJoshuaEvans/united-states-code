{"tag":"section","attrib":{"id":"id77908f63-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430a"},"text":null,"children":[{"tag":"num","attrib":{"value":"430a"},"text":"§ 430a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of land","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall ascertain on what land the Battle of Kings Mountain was fought and, subject to the provisions of sections 3111 and 3112 of title 40, shall proceed to acquire title to such land together with such adjacent and contiguous lands as he may deem useful and proper in effectually carrying out the purposes of sections 430, 430a, and 430b of this title, either by purchase or gift or by condemnation under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3113"},"text":"section 3113 of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77908f64-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1931-03-03/ch437/s2"},"text":"Mar. 3, 1931, ch. 437, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/1508"},"text":"46 Stat. 1508","children":[],"tail":"; Ex. Ord. No. 6166, § 2, "},{"tag":"date","attrib":{"date":"1933-06-10"},"text":"June 10, 1933","children":[],"tail":"; Ex. Ord. No. 6228, § 1, "},{"tag":"date","attrib":{"date":"1933-07-28"},"text":"July 28, 1933","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77908f65-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77908f66-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib