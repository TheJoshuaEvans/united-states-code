{"tag":"section","attrib":{"id":"id76ff24ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s81f"},"text":null,"children":[{"tag":"num","attrib":{"value":"81f"},"text":"§ 81f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated, out of any money in the Treasury not otherwise appropriated, such sums as may be necessary to carry out the provisions of this subchapter, which shall not exceed the sum of $8,572,000 to be available for all expenses incident to the examination and establishment of the said Colonial National Historical Park and for the acquisition of lands and/or lands and improvements needed for the completion of the park, including the securing of options and other incidental expenses. The area of the Yorktown battlefield, authorized for inclusion in said park, is extended to not to exceed four thousand five hundred acres, and all Government-owned lands within the boundaries of said park as established by presidential proclamation, except those determined by the Secretary of the Interior as not necessary in carrying out the objects of said park are transferred to the administrative jurisdiction and control of the National Park Service.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id76ff24af-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-07-03/ch837/s4"},"text":"July 3, 1930, ch. 837, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/856"},"text":"46 Stat. 856","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1931-03-03/ch405"},"text":"Mar. 3, 1931, ch. 405","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/1490"},"text":"46 Stat. 1490","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-05/ch525/s2"},"text":"June 5, 1936, ch. 525, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1483"},"text":"49 Stat. 1483","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/74"},"text":"Pub. L. 90–74","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-08-29"},"text":"Aug. 29, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/176"},"text":"81 Stat. 176","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/477/tI/s101/2"},"text":"Pub. L. 93–477, title I, § 101(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-26"},"text":"Oct. 26, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1445"},"text":"88 Stat. 1445","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/418/s3"},"text":"Pub. L. 109–418, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2883"},"text":"120 Stat. 2883","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id76ff24b0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id76ff24b1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id76ff24b2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s443c"},"text":"section 443c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id76ff24b3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/418"},"text":"Pub. L. 109–418","children":[],"tail":" substituted “$8,572,000” for “$10,472,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/477"},"text":"Pub. L. 93–477","children":[],"tail":" substituted “$10,472,000” for “$2,777,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/74"},"text":"Pub. L. 90–74","children":[],"tail":" substituted “$2,777,000” for “$2,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1931—Act ","children":[{"tag":"date","attrib":{"date":"1931-03-03"},"text":"Mar. 3, 1931","children":[],"tail":", changed amount of appropriation and inserted last sentence extending the area of Yorktown battlefield."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id76ff24b4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id76ff24b5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1936-06-05"},"text":"June 5, 1936","children":[],"tail":", changed “Colonial National Monument” to “Colonial National Historical Park”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id76ff24b6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"George Waller Blow Estate; Use of 1967 Increase in Authorization of Appropriations To Purchase","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/74"},"text":"Pub. L. 90–74","children":[],"tail":" provided in part that the limit on the authorized appropriation was increased from $2,000,000 to $2,777,000 in order to permit acquisition of the Thomas Nelson House, the Edmund Smith House, the John Ballard House, and the Thomas Pate House, all of which are located within the boundaries of the Colonial National Historical Park on lots numbered 42A, 44 through 55, 84, 85, and 120 through 129, and known as the George Waller Blow Estate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
