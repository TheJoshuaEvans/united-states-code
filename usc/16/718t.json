{"tag":"section","attrib":{"id":"id78863a65-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718t"},"text":null,"children":[{"tag":"num","attrib":{"value":"718t"},"text":"§ 718t.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of State participation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The authority of a State to issue electronic stamps under this subchapter may be terminated—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78863a66-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718t/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" by the Secretary, if the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78863a67-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718t/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" finds that the State has violated any of the terms of the application of the State approved by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s718q"},"text":"section 718q of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78863a68-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718t/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides to the State written notice of the termination by not later than the date that is 30 days before the date of termination; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78863a69-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718t/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"t