{"tag":"section","attrib":{"id":"id7811578e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gggg"},"text":null,"children":[{"tag":"num","attrib":{"value":"460gggg"},"text":"§ 460gggg.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Numu Newe Special Management Area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7811578f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gggg/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78115790-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gggg/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “management plan” means the management plan for the Special Management Area developed under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78115791-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gggg/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78115792-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gggg/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special Management Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Special Management Area” means the Numu Newe Special Management Area established by subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78115793-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gggg/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To protect, conserve, and enhance the unique and nationally important historic, cultural, archaeological, natural, and educational resources of the Numu Newe traditional homeland, subject to valid existing rights, there is established in Churchill and Mineral Counties, Nevada, the Numu Newe Special Management Area, to be administered by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78115794-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gggg/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area included","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Special Management Area shall consist of the approximately 209,181 acres of public land in Churchill and Mineral Counties, Nevada, administered by the Bureau of Land Management, as depicted on the map entitled “Churchill County Proposed Fallon Range Training Complex Modernization and Lands Bill” and dated ","children":[{"tag":"date","attrib":{"date":"2022-11-30"},"text":"November 30, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78115795-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gggg/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78115796-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gggg/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the Secretary shall develop a comprehensive management plan for the long-term management of the Special Management Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78115797-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gggg/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing and implementing the management plan, the Secretary shall consult with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78115798-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gggg/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate Federal, Tribal, State, and local governmental entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78115799-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gggg/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interested members of the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7811579a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gggg/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The management plan shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7811579b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gggg/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the appropriate uses of the Special Management Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7811579c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gggg/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to any land within the Special Management Area that is withdrawn and reserved for military uses, ensure that management of the Special Management Area is consistent with the purposes under section 2981(c)(2) of the Military Land Withdrawals Act of 2013 (as added by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2901"},"text":"section 2901 of this title","children":[],"tail":") for which the land is withdrawn and reserved;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7811579d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gggg/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize the use of motor vehicles in the Special Management Area, where appropriate, including providing for the maintenance of existing roads;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7811579e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gggg/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate any provision of an applicable land and resource management plan that the Secretary considers to be appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7811579f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gggg/d/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure, to the maximum extent practicable, the protection and preservation of traditional cultural and religious sites within the Special Management Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id781157a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gggg/d/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, carefully and fully integrate the traditional and historical knowledge and special expertise of the Fallon Paiute Shoshone Tribe and other affected Indian tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id781157a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gggg/d/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with subparagraph (D), ensure public access to Federal land within the Special Management Area for hunting, fishing, and other recreational purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id781157a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gggg/d/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not affect the allocation, ownership, interest, or control, as in existence on ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", of any water, water right, or any other valid existing right; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id781157a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gggg/d/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be reviewed not less frequently than annually by the Secretary to ensure the management plan is meeting the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id781157a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gggg/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military overflights","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section restricts or precludes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id781157a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gggg/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" low-level overflights of military aircraft over the Special Management Area, including military overflights that can be seen or heard within the Special Management Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id781157a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gggg/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flight testing and evaluation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id781157a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460gggg/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the designation or creation of new units of special use airspace, or the establishment of military flight training routes, over the Special Management Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id781157a8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dB/tXXIX/s2902"},"text":"Pub. L. 117–263, div. B, title XXIX, § 2902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3033"},"text":"136 Stat. 3033","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dB/tXXVIII/s2883/a"},"text":"Pub. L. 118–31, div. B, title XXVIII, § 2883(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/782"},"text":"137 Stat. 782","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id781157a9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id781157aa-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id781157ab-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 2981(c)(2) of the Military Land Withdrawals Act of 2013 (as added by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2901"},"text":"section 2901 of this title","children":[],"tail":"), referred to in subsec. (d)(3)(B), is "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dB/tXXIX/s2981/c/2"},"text":"section 2981(c)(2) of title XXIX of div. B of Pub. L. 113–66","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dB/tXXIX/s2901"},"text":"Pub. L. 117–263, div. B, title XXIX, § 2901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3016"},"text":"136 Stat. 3016","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id781157ac-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" substituted “209,181 acres” for “217,845 acres”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
