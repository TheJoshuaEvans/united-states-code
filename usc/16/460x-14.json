{"tag":"section","attrib":{"id":"id77d0f328-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460x–14"},"text":null,"children":[{"tag":"num","attrib":{"value":"460x–14"},"text":"§ 460x–14.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; adjustments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated not more than $84,149,558 for the acquisition of lands and interests in lands and not more than $18,769,000 (June 1970 prices) for development, plus or minus such amounts, if any, as may be justified by reason of ordinary fluctuations in construction costs as indicated by engineering cost indices applicable to the type of construction involved herein.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77d0f329-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/479/s15"},"text":"Pub. L. 91–479, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-21"},"text":"Oct. 21, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1081"},"text":"84 Stat. 1081","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/477/tI/s101/13"},"text":"Pub. L. 93–477, title I, § 101(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-26"},"text":"Oct. 26, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1446"},"text":"88 Stat. 1446","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/361/s4"},"text":"Pub. L. 97–361, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-22"},"text":"Oct. 22, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1724"},"text":"96 Stat. 1724","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/141/s5"},"text":"Pub. L. 98–141, § 5","children":[],"tail":", "},{"tag":"da