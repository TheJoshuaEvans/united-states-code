{"tag":"section","attrib":{"id":"id778bd451-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s426f"},"text":null,"children":[{"tag":"num","attrib":{"value":"426f"},"text":"§ 426f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Control of battlefield; regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The said Stones River National Battlefield shall be under the control of the Secretary of the Interior, and he is authorized to make all needed regulations for the care of the battlefield. The superintendent of the Stones River National Cemetery shall likewise be the superintendent of and have the custody and care of the Stones River National Battlefield, under the direction of the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id778bd452-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-03/ch374/s7"},"text":"Mar. 3, 1927, ch. 374, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1400"},"text":"44 Stat. 1400","children":[],"tail":"; Ex. Ord. No. 6166, § 2, "},{"tag":"date","attrib":{"date":"1933-06-10"},"text":"June 10, 1933","children":[],"tail":"; Ex. Ord. No. 6228, § 1, "},{"tag":"date","attrib":{"date":"1933-07-28"},"text":"July 28, 1933","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/443/s2"},"text":"Pub. L. 86–443, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-04-22"},"text":"Apr. 22, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/82"},"text":"74 Stat. 82","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id778bd453-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id778bd454-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id778bd455-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Stones River National Battlefield” and “battlefield” substituted in text for “Stones River National Park” and “park”, respectively, in view of redesignation of Stones River National Military Park as Stones River National Battlefield by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/443"},"text":"Pub. L. 86–443","children":[],"tail":". See section 426"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id778bd456-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id778bd457-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of administrative functions of park, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s426"},"text":"section 426 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
