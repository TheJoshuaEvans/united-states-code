{"tag":"section","attrib":{"id":"id79e99a82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4211"},"text":null,"children":[{"tag":"num","attrib":{"value":"4211"},"text":"§ 4211.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79e99a83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4211/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide financial assistance under this subchapter from the Fund for approved projects for research, conservation, management, or protection of African elephants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e99a84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4211/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project proposal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any African government agency responsible for African elephant conservation and protection, the CITES Secretariat, and any organization or individual with experience in African elephant conservation may submit to the Secretary a project proposal under this section. Each such proposal shall contain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e99a85-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4211/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the person responsible for conducting the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e99a86-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4211/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a succinct statement of the need for and purposes of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e99a87-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4211/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the qualifications of the individuals who will be conducting the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e99a88-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4211/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the funds and time required to complete the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e99a89-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4211/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evidence of support of the project by governmental entities of countries within which the project will be conducted, if such support may be important for the success of the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e99a8a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4211/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information the Secretary considers to be necessary or appropriate for evaluating the eligibility of the project for funding under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e99a8b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4211/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project review and approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall review each project proposal to determine if it meets the criteria set forth in subsection (d) and otherwise merits assistance under this chapter. Not later than six months after receiving a project proposal, and subject to the availability of funds, the Secretary shall approve or disapprove the proposal and provide written notification to the person who submitted the proposal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e99a8c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4211/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may approve a project under this section if the project will enhance programs for African elephant research, conservation, management, or protection by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e99a8d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4211/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing in a usable form sound scientific information on African elephant habitat condition and carrying capacity, total elephant numbers and population trends, or annual reproduction and mortality; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e99a8e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4211/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assisting efforts—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e99a8f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4211/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that any taking of African elephants in the country is effectively controlled and monitored;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e99a90-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4211/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to implement conservation programs to provide for healthy, sustainable African elephant populations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e99a91-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4211/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance compliance with the CITES Ivory Control System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e99a92-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4211/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project sustainability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practical, in determining whether to approve project proposals under this section, the Secretary shall give consideration to projects that will enhance sustainable conservation programs to ensure effective long-term conservation of African elephants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e99a93-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4211/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each entity that receives assistance under this section shall provide such periodic reports to the Director of the United States Fish and Wildlife Service as the Director considers relevant and appropriate. Each report shall include all information requested by the Director for evaluating the progress and success of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e99a94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4211/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiyear grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e99a95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4211/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award to a person who is otherwise eligible for a grant under this section a multiyear grant of up to 5 years to carry out a project that the person demonstrates is an effective, long-term conservation strategy for African elephants and the habitat of African elephants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e99a96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4211/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection precludes the Secretary from awarding a grant on an annual basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79e99a97-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/478/tII/s2101"},"text":"Pub. L. 100–478, title II, § 2101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-07"},"text":"Oct. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2316"},"text":"102 Stat. 2316","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/111"},"text":"Pub. L. 107–111","children":[],"tail":", §§ 5, 6(a)(1), "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2096"},"text":"115 Stat. 2096","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/132/s2/a"},"text":"Pub. L. 110–132, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-06"},"text":"Dec. 6, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1360"},"text":"121 Stat. 1360","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dE/tLIII/s5303/a"},"text":"Pub. L. 118–159, div. E, title LIII, § 5303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2445"},"text":"138 Stat. 2445","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79e99a98-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79e99a99-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79e99a9a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/132"},"text":"Pub. L. 110–132","children":[],"tail":", struck out “and to each country within which the project is proposed to be conducted” before period at end in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/111/s6/a/1"},"text":"Pub. L. 107–111, § 6(a)(1)","children":[],"tail":", struck out “African Elephant Conservation” before “Fund”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/111/s5"},"text":"Pub. L. 107–111, § 5","children":[],"tail":", added subsec. (e) and redesignated former subsec. (e) as (f)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
