{"tag":"section","attrib":{"id":"id79ccea7a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3831b"},"text":"§ 3831b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farmable wetland program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79ccea7b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ccea7c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the 2008 through 2023 fiscal years, the Secretary shall carry out a farmable wetland program in each State under which the Secretary shall enroll eligible acreage described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ccea7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation among States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure, to the maximum extent practicable, that owners and operators in each State have an equitable opportunity to participate in the program established under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ccea7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible acreage","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ccea7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wetland and related land","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsections (c) and (d), an owner or operator may enroll in the conservation reserve, pursuant to the program established under this section, land—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79ccea80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is wetland (including a converted wetland described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3822/b/1/A"},"text":"section 3822(b)(1)(A) of this title","children":[],"tail":") that had a cropping history during at least 3 of the immediately preceding 10 crop years;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ccea81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on which a constructed wetland is to be developed that will receive surface and subsurface flow from row crop agricultural production and is designed to provide nitrogen removal in addition to other wetland functions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ccea82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that was devoted to commercial pond-raised aquaculture in any year during the period of calendar years 2002 through 2007; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ccea83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that, after ","children":[{"tag":"date","attrib":{"date":"1990-01-01"},"text":"January 1, 1990","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"2002-12-31"},"text":"December 31, 2002","children":[],"tail":", was—"}],"tail":null},{"tag":"clause","attrib":{"id":"id79ccea84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/b/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cropped during at least 3 of 10 crop years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79ccea85-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/b/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the natural overflow of a prairie wetland.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ccea86-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Buffer acreage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsections (c) and (d), an owner or operator may enroll in the conservation reserve, pursuant to the program established under this section, buffer acreage that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79ccea87-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to land described in subparagraph (A), (B), or (C) of paragraph (1)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79ccea88-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is contiguous to such land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79ccea89-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is used to protect such land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79ccea8a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is of such width as the Secretary determines is necessary to protect such land, taking into consideration and accommodating the farming practices (including the straightening of boundaries to accommodate machinery) used with respect to the cropland that surrounds such land; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ccea8b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to land described in subparagraph (D) of paragraph (1), enhances a wildlife benefit to the extent practicable in terms of upland to wetland ratios, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ccea8c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ccea8d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acreage limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may enroll in the conservation reserve, pursuant to the program established under this section, not more than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79ccea8e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100,000 acres in any State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ccea8f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a total of 750,000 acres.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ccea90-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to maximum enrollment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (3), any acreage enrolled in the conservation reserve under this section shall be considered acres maintained in the conservation reserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ccea91-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other enrolled acreage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Acreage enrolled in the conservation reserve under this section shall not affect for any fiscal year the quantity of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79ccea92-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acreage enrolled to establish conservation buffers as part of the program announced on ","children":[{"tag":"date","attrib":{"date":"1998-03-24"},"text":"March 24, 1998","children":[],"tail":" (63 Fed. Reg. 14109); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ccea93-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acreage enrolled into the conservation reserve enhancement program announced on ","children":[{"tag":"date","attrib":{"date":"1998-05-27"},"text":"May 27, 1998","children":[],"tail":" (63 Fed. Reg. 28965)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ccea94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review; potential increase in enrollment acreage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct a review of the program established under this section with respect to each State that has enrolled land in the conservation reserve pursuant to the program. As a result of the review, the Secretary may increase the number of acres that may be enrolled in a State under the program to not more than 200,000 acres, notwithstanding paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ccea95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Owner or operator enrollment limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ccea96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wetland and related land","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79ccea97-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wetlands and constructed wetlands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The maximum size of any land described in subparagraph (A) or (B) of subsection (b)(1) that an owner or operator may enroll in the conservation reserve, pursuant to the program established under this section, shall be 40 contiguous acres.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ccea98-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flooded farmland","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The maximum size of any land described in subparagraph (D) of subsection (b)(1) that an owner or operator may enroll in the conservation reserve, pursuant to the program established under this section, shall be 20 contiguous acres.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ccea99-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All acres described in subparagraph (A) or (B), including acres that are ineligible for payment, shall be covered by the conservation contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ccea9a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Buffer acreage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The maximum size of any buffer acreage described in subsection (b)(2) that an owner or operator may enroll in the conservation reserve under this section shall be determined by the Secretary in consultation with the State Technical Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ccea9b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except for land described in subsection (b)(1)(C) and buffer acreage related to such land, the maximum size of any eligible acreage described in subsection (b)(1) in a tract of an owner or operator enrolled in the conservation reserve under this section shall be 40 acres.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ccea9c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of owners and operators","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the term of a contract entered into under the program established under this section, an owner or operator shall agree—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ccea9d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to restore the hydrology of the wetland within the eligible acreage to the maximum extent practicable, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ccea9e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish vegetative cover (which may include emerging vegetation in water and bottomland hardwoods, cypress, and other appropriate tree species) on the eligible acreage, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ccea9f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a general prohibition of commercial use of the enrolled land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cceaa0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out other duties described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3832"},"text":"section 3832 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79cceaa1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of the Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79cceaa2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraphs (2) and (3), in return for a contract entered into under this section, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cceaa3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make payments to the owner or operator based on rental rates for cropland; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cceaa4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assistance to the owner or operator in accordance with sections 3833 and 3834 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cceaa5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract offers and payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall use the method of determination described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3834/d"},"text":"section 3834(d) of this title","children":[],"tail":" to determine the acceptability of contract offers and the amount of rental payments under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cceaa6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831b/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amounts payable to owners and operators in the form of rental payments under contracts entered into under this section shall reflect incentives that are provided to owners and operators to enroll filterstrips in the conservation reserve under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3834"},"text":"section 3834 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79cceaa7-6992-11f1-ab3f-8b4c0