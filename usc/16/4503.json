{"tag":"section","attrib":{"id":"id79f09ea8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503"},"text":null,"children":[{"tag":"num","attrib":{"value":"4503"},"text":"§ 4503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institute of Tropical Forestry in Puerto Rico","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79f09ea9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall expand the capabilities of and construct additional facilities at the Caribbean National Forest and Institute of Tropical Forestry in Puerto Rico, as the Secretary determines necessary to support the purpose of this chapter, and as funds are appropriated for such expansion and construction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f09eaa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tropical forestry plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"November 5, 1990","children":[],"tail":", the Secretary shall prepare and submit to the Committee on Agriculture, Nutrition, and Forestry of the Senate, the Committee on Agriculture of the House of Representatives, and to the Committees on Appropriations of the Senate and House of Representatives, a tropical forestry plan for the expansion and construction of additional facilities under subsection (a). Such plan shall include provisions for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f09eab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction or acquisition of a major center for education, interpretation, and appreciation of the benefits and methods of the intelligent management of tropical forests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f09eac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition or construction of facilities for housing and classroom instruction near the Caribbean National Forest/Luguillo Experimental Forest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f09ead-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4503/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition or construction of facilities for the study and recovery of endangered tropical wildlife, fish and plant species.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f09eae-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/513/tVI/s604"},"text":"Pub. L. 101–513, title VI, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2071"},"text":"104 Stat. 2071","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/574/s2/b/2"},"text":"Pub. L. 102–574, § 2(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4596"},"text":"106 Stat. 4596","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79f09eaf-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79f09eb0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79f09eb1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/574"},"text":"Pub. L. 102–574","children":[],"tail":" inserted “in Puerto Rico” in section catchline."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id79f09eb2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id79f09eb3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 13428, ","children":[{"tag":"date","attrib":{"date":"2007-04-02"},"text":"Apr. 2, 2007","children":[],"tail":", 72 F.R. 16693, provided that the Caribbean National Forest in the Commonwealth of Puerto Rico, referred to in subsecs. (a) and (b)(2), is renamed the “El Yunque National Forest”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
