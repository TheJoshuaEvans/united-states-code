{"tag":"section","attrib":{"id":"id771e1d9e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s247"},"text":null,"children":[{"tag":"num","attrib":{"value":"247"},"text":"§ 247.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Homestead, mineral, and other rights un­affected","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"That nothing herein contained shall affect any valid existing claim, location, or entry under the land laws of the United States, whether for homestead, mineral, right-of-way, or any other purposes whatsoever, or shall affect the right of any such claimant, locator, or entryman to the full use and enjoyment of his land.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id771e1d9f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-04-25/ch41/s6"},"text":"Apr. 25, 1947, ch. 41, § 6","children":[],"tail":", formerly § 7, "},{"tag":"ref","attrib":{"href":"/us/stat/61/54"},"text":"61 Stat. 54","children":[],"tail":"; renumbered § 6, "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-10/ch437/s1"},"text":"June 10, 1948, ch. 437, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/352"},"text":"62 Stat. 352","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id771e1da0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id771e1da1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id771e1da2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Herein, referred to in text, means act ","children":[{"tag":"date","attrib":{"date":"1947-04-25"},"text":"Apr. 25, 1947","children":[],"tail":", which was generally classified to this subchapter. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The land laws of the United States, referred to in text, are classified generally to Title 43, Public Lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
