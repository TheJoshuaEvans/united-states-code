{"tag":"section","attrib":{"id":"id7942ab79-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1463b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1463b"},"text":"§ 1463b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Coastal Resources Research and Development Institute","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7942ab7a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1463b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment by Secretary; administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce shall provide for the establishment of a National Coastal Resources Research and Development Institute (hereinafter in this section referred to as the “Institute”) to be administered by the Oregon State Marine Science Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7942ab7b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1463b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes of Institute","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Institute shall conduct research and carry out educational and demonstration projects designed to promote the efficient and responsible development of ocean and coastal resources, including arctic resources. Such projects shall be based on biological, geological, genetic, economic and other scientific research applicable to the purposes of this section and shall include studies on the economic diversification and environmental protection of the Nation’s coastal areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7942ab7c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1463b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of Institute policies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7942ab7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1463b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The policies of the Institute shall be determined by a Board of Governors composed of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7942ab7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1463b/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two representatives appointed by the Governor of Oregon;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942ab7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1463b/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one representative appointed by the Governor of Alaska;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942ab80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1463b/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one representative appointed by the Governor of Washington;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942ab81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1463b/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one representative appointed by the Governor of California; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942ab82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1463b/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one representative appointed by the Governor of Hawaii.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942ab83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1463b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such policies shall include the selection, on a nationally competitive basis, of the research, projects, and studies to be supported by the Institute in accordance with the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7942ab84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1463b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Advisory Council; functions and composition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7942ab85-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1463b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board of Governors shall establish an Advisory Council composed of specialists in ocean and coastal resources from the academic community.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942ab86-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1463b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the maximum extent practicable, the Advisory Council shall be composed of such specialists from every coastal region of the Nation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942ab87-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1463b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Advisory Council shall provide such advice to the Board of Governors as such Board shall request, including recommendations regarding the support of research, projects, and studies in accordance with the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7942ab88-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1463b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of Institute","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Institute shall be administered by a Director who shall be appointed by the Chancellor of the Oregon Board of Higher Education in consultation with the Board of Governors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7942ab89-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1463b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation of Institute by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce shall conduct an ongoing evaluation of the activities of the Institute to ensure that funds received by the Institute under this section are used in a manner consistent with the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7942ab8a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1463b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Institute shall report to the Secretary of Commerce on its activities within 2 years after ","children":[{"tag":"date","attrib":{"date":"1984-07-17"},"text":"July 17, 1984","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7942ab8b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1463b/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to Institute books, records, and documents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General of the United States, and any of his duly authorized representatives, shall have access, for the purpose of audit and examination, to any books, documents, papers and records of the Institute that are pertinent to the funds received under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7942ab8c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1463b/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of Institute employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Employees of the Institute shall not, by reason of such employment, be considered to be employees of the Federal Government for any purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7942ab8d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1463b/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this section, there are authorized to be appropriated in each fiscal year $5,000,000, commencing with fiscal year 1985.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7942ab8e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/364/tII/s201"},"text":"Pub. L. 98–364, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-17"},"text":"July 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/443"},"text":"98 Stat. 443","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7942ab8f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7942ab90-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7942ab91-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section, referred to in subsecs. (a) to (d), (f), (h) and (j), was in the original “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/364"},"text":"Pub. L. 98–364","children":[],"tail":", which enacted this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7942ab92-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Coastal Zone Management Act of 1972 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7942ab93-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7942ab94-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Councils","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory councils established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of their establishment, unless, in the case of a council established by the President or an officer of the Federal Government, such council is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a council established by the Congress, its duration is otherwise provided for by law. See sections 1001(2) and 1013 of Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
