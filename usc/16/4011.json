{"tag":"section","attrib":{"id":"id79e729a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4011"},"text":null,"children":[{"tag":"num","attrib":{"value":"4011"},"text":"§ 4011.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions and powers of Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79e729a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4011/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of the Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the duties prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4009"},"text":"section 4009 of this title","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e729a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4011/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review, for consistency with the provisions of this chapter and other applicable law, and approve or disapprove, marketing and promotion plans and budgets within sixty days after their submission by a council;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e729a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4011/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immediately notify a council in writing of the disapproval of a marketing and promotion plan or budget, together with reasons for such disapproval;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e729a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4011/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue orders and amendments to such orders that are necessary to implement quality standards under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4010/c"},"text":"section 4010(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e729a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4011/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promulgate regulations necessary to carry out the purposes of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e729aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4011/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforce the provisions of this chapter, as provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4016"},"text":"section 4016 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e729ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4011/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make all appointments to councils in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4009/f"},"text":"section 4009(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e729ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4011/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide, on a reimbursable or other basis, such administrative or technical assistance as a council may request for purposes of the initial organization and subsequent operation of the council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79e729ad-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/659/tII/s212"},"text":"Pub. L. 99–659, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3726"},"text":"100 Stat. 3726","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
