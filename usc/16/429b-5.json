{"tag":"section","attrib":{"id":"id77908f5d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s429b–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"429b–5"},"text":"§ 429b–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding limitations; contracting authority, etc.","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77908f5e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s429b–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date of authorizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Authorizations of moneys to be appropriated under sections 429b to 429b–5 of this title from the Land and Water Conservation Fund for acquisition of properties and interests shall be effective on ","children":[{"tag":"date","attrib":{"date":"1981-10-01"},"text":"October 1, 1981","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77908f5f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s429b–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority limited by appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of sections 429b to 429b–5 of this title, authority to enter into contracts, to incur obligations, or to make payments under sections 429b to 429b–5 of this title shall be effective only to the extent, and in such amounts as are provided in advance in appropriation Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77908f60-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-04-17/ch153/s6"},"text":"Apr. 17, 1954, ch. 153, § 6","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/442/s2"},"text":"Pub. L. 96–442, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-13"},"text":"Oct. 13, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1887"},"text":"94 Stat. 1887","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
