{"tag":"section","attrib":{"id":"id778e44b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s428b"},"text":null,"children":[{"tag":"num","attrib":{"value":"428b"},"text":"§ 428b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be the duty of the commission, acting under the direction of the Secretary of the Interior, to inspect the battlefield of Fort Donelson, Tennessee, and to carefully study the available records and historical data with respect to the location and movement of all troops which engaged in the Battle of Fort Donelson, and the important events connected therewith, with a view of preserving and marking such field for historical and professional military study.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id778e44b8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1928-03-26/ch248/s3"},"text":"Mar. 26, 1928, ch. 248, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/367"},"text":"45 Stat. 367","children":[],"tail":"; Ex. Ord. No. 6166, § 2, "},{"tag":"date","attrib":{"date":"1933-06-10"},"text":"June 10, 1933","children":[],"tail":"; Ex. Ord. No. 6228, § 1, "},{"tag":"date","attrib":{"date":"1933-07-28"},"text":"July 28, 1933","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/738/s5"},"text":"Pub. L. 86–738, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-08"},"text":"Sept. 8, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/876"},"text":"74 Stat. 876","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id778e44b9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id778e44ba-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id778e44bb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of administrative functions of park, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s428"},"text":"section 428 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
