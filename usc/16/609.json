{"tag":"section","attrib":{"id":"id785b58cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s609"},"text":null,"children":[{"tag":"num","attrib":{"value":"609"},"text":"§ 609.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permits to cut and remove timber; citizens of Modoc County, California","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be lawful for the Secretary of the Interior to grant permits under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s607"},"text":"section 607 of this title","children":[],"tail":", to citizens of Modoc County, California, to cut timber in the State of Nevada for agricultural, mining, or other domestic purposes, and to remove the timber so cut to Modoc County, State of California."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id785b58cc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1891-03-03/ch561/s8"},"text":"Mar. 3, 1891, ch. 561, § 8","children":[],"tail":" (part), as added "},{"tag":"ref","attrib":{"href":"/us/act/1919-03-03/ch115"},"text":"Mar. 3, 1919, ch. 115","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/1322"},"text":"40 Stat. 1322","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id785b58cd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id785b58ce-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id785b58cf-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is derived from act ","children":[{"tag":"date","attrib":{"date":"1919-03-03"},"text":"Mar. 3, 1919","children":[],"tail":", which recites that it amends section 8 of act "},{"tag":"date","attrib":{"date":"1891-03-03"},"text":"Mar. 3, 1891","children":[],"tail":", which is the source of "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s607"},"text":"section 607 of this title","children":[],"tail":", by adding this section thereto. Section 8 of act "},{"tag":"date","attrib":{"date":"1891-03-03"},"text":"Mar. 3, 1891","children":[],"tail":", is classified to sections 607, 608 to 611a of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
