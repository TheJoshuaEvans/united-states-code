{"tag":"section","attrib":{"id":"id774b6fc2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410y–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"410y–6"},"text":"§ 410y–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds; authorization of appropriations; adjustment of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id774b6fc3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410y–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any funds that may be available for purposes of administration of the Chesapeake and Ohio Canal property may hereafter be used by the Secretary for the purposes of the park.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id774b6fc4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410y–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated such sums as may be necessary to carry out the provisions of this subchapter, not to exceed $28,400,000 for land acquisition and not to exceed $17,000,000 (1970 prices) for development, plus or minus such amounts, if any, as may be justified by reason of ordinary fluctuations in construction costs as indicated by engineering cost indices applicable to the types of construction involved herein.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id774b6fc5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/664/s8"},"text":"Pub. L. 91–664, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-08"},"text":"Jan. 8, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1980"},"text":"84 Stat. 1980","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/625/tIII/s320"},"text":"Pub. L. 95–625, title III, § 320","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3488"},"text":"92 Stat. 3488","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id774b6fc6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id774b6fc7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id774b6fc8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625"},"text":"Pub. L. 95–625","children":[],"tail":" substituted “$28,400,000” for “$20,400,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
