{"tag":"section","attrib":{"id":"id77fbfb07-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–25"},"text":null,"children":[{"tag":"num","attrib":{"value":"460lll–25"},"text":"§ 460lll–25.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special use authorizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77fbfb08-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–25/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to other authorities for the authorization of special uses within the National Forest System, within the Recreation Area, the Secretary may, on such terms and conditions as the Secretary may prescribe—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fbfb09-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–25/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" convey for no consideration perpetual easements to governmental units for public roads over United States Route 68 and the Trace, and such other rights-of-way as the Secretary and a governmental unit may agree;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfb0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–25/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer or lease to governmental units developed recreation sites or other facilities to be managed for public purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfb0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–25/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lease or authorize recreational sites or other facilities, consistent with sections 460","children":[{"tag":"i","attrib":{},"text":"lll","children":[],"tail":"–1(2) and 460"},{"tag":"i","attrib":{},"text":"lll","children":[],"tail":"–11(b)(2) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfb0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–25/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fbfb0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–25/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Consideration for a lease or other special use authorization within the Recreation Area shall be based on fair market value.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfb0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–25/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction or waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may reduce or waive a fee to a governmental unit or nonprofit organization commensurate with other consideration provided to the United States, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfb0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–25/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may use any fair and equitable method for authorizing special uses within the Recreation Area, including public solicitation of proposals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfb10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–25/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing authorizations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fbfb11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–25/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A permit or other authorization granted by the Tennessee Valley Authority that is in effect on the date of transfer pursuant to section 460","children":[{"tag":"i","attrib":{},"text":"lll","children":[],"tail":"–41 of this title may continue on transfer of administration of the Recreation Area to the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfb12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–25/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reissuance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A permit or authorization described in paragraph (1) may be reissued or terminated under terms and conditions prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfb13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–25/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exercise of rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may exercise any of the rights of the Tennessee Valley Authority contained in any permit or other authorization, including any right to amend, modify, and revoke the permit or authorization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77fbfb14-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tV/s525"},"text":"Pub. L. 105–277, div. A, § 101(e) [title V, § 525]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–315.)"}],"tail":"\n"}],"tail":null}
