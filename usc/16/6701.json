{"tag":"section","attrib":{"id":"id7a193571-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701"},"text":null,"children":[{"tag":"num","attrib":{"value":"6701"},"text":"§ 6701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a193572-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is an increasing threat of wildfire to millions of acres of forest land and rangeland throughout the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a193573-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forest land and rangeland are degraded as a direct consequence of land management practices, including practices to control and prevent wildfires and the failure to harvest subdominant trees from overstocked stands that disrupt the occurrence of frequent low-intensity fires that have periodically removed flammable undergrowth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a193574-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 39,000,000 acres of land of the National Forest System in the interior West are at high risk of wildfire;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a193575-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an average of 95 percent of the expenditures by the Forest Service for wildfire suppression during fiscal years 1990 through 1994 were made to suppress wildfires in the interior West;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a193576-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number, size, and severity of wildfires in the interior West are increasing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a193577-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the timberland in National Forests in the States of Arizona and New Mexico, 59 percent of such land in Arizona, and 56 percent of such land in New Mexico, has an average diameter of 9 to 12 inches diameter at breast height;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a193578-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the population of the interior West grew twice as fast as the national average during the 1990s;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a193579-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" catastrophic wildfires—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a19357a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" endanger homes and communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a19357b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" damage and destroy watersheds and soils; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a19357c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pose a serious threat to the habitat of threatened and endangered species;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a19357d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a 1994 assessment of forest health in the interior West estimated that only a 15- to 30-year window of opportunity exists for effective management intervention before damage from uncontrollable wildfire becomes widespread, with 8 years having already elapsed since the assessment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a19357e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" healthy forest and woodland ecosystems—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a19357f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce the risk of wildfire to forests and communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a193580-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve wildlife habitat and biodiversity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a193581-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase tree, grass, forb, and shrub productivity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a193582-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/10/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance watershed values;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a193583-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/10/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a193584-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/10/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a basis in some areas for economically and environmentally sustainable uses;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a193585-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sustaining the long-term ecological and economic health of interior West forests and woodland, and their associated human communities requires preventing severe wildfires before the wildfires occur and permitting natural, low-intensity ground fires;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a193586-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more natural fire regimes cannot be accomplished without the reduction of excess fuels and thinning of subdominant trees (which fuels and trees may be of commercial value);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a193587-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ecologically based forest and woodland ecosystem restoration on a landscape scale will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a193588-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve long-term community protection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a193589-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize the need for wildfire suppression;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a19358a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/13/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve resource values;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a19358b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/13/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the ecological integrity and resilience of these systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a19358c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/13/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce rehabilitation costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a19358d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/13/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce loss of critical habitat; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a19358e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/13/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect forests for future generations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a19358f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" although landscape scale restoration is needed to effectively reverse degradation, scientific understanding of landscape scale treatments is limited;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a193590-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" rigorous, objective, understandable, and applied scientific information is needed for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a193591-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the design, implementation, monitoring, and adaptation of landscape scale restoration treatments and improvement of wildfire management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a193592-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the environmental review process; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a193593-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6701/15/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affected entities that collaborate in the development and implementation of wildfire treatment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a193594-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/317/s2"},"text":"Pub. L. 108–317, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-05"},"text":"Oct. 5, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1204"},"text":"118 Stat. 1204","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a193595-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a193596-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a193597-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/317/s1"},"text":"Pub. L. 108–317, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-05"},"text":"Oct. 5, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1204"},"text":"118 Stat. 1204","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/317/s1"},"text":"“This Act [enacting this chapter] may be cited as the ‘Southwest Forest Health and Wildfire Prevention Act of 2004’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
