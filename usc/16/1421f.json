{"tag":"section","attrib":{"id":"id792d2811-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1421f"},"text":"§ 1421f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Marine Mammal Tissue Bank and tissue analysis","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id792d2812-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tissue Bank","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792d2813-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make provision for the storage, preparation, examination, and archiving of marine mammal tissues. Tissues archived pursuant to this subsection shall be known as the “National Marine Mammal Tissue Bank”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d2814-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance for marine mammal tissue collection, preparation, and archiving","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, in consultation with individuals with knowledge and expertise in marine science, marine mammal science, marine mammal veterinary and husbandry practices, and marine conservation, issue guidance, after an opportunity for public review and comment, for marine mammal tissue collection, preparation, archiving, and quality control procedures, regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792d2815-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate and uniform methods and standards for those activities to provide confidence in marine mammal tissue samples used for research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d2816-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documentation of procedures used for collecting, preparing, and archiving those samples.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d2817-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Source of tissue","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to tissues taken during marine mammal unusual mortality events, the Tissue Bank shall incorporate tissue samples taken from other sources in the wild, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792d2818-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" samples from marine mammals taken incidental to commercial fishing operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d2819-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" samples from marine mammals taken for subsistence purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d281a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" biopsy samples; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d281b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other samples properly collected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792d281c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tissue analysis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, in consultation with the Marine Mammal Commission, the Secretary of the Interior, and individuals with knowledge and experience in marine science, marine mammal science, marine mammal veterinary and husbandry practices, and marine conservation, issue guidance, after an opportunity for public review and comment, for analyzing tissue samples (by use of the most effective and advanced diagnostic technologies and tools practicable) as a means to monitor and measure overall health trends in representative species or populations of marine mammals, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792d281d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the levels of, and if possible, the effects of, potentially harmful contaminants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d281e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the frequency of, and if possible, the causes and effects of abnormal lesions or anomalies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792d281f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data base","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792d2820-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall maintain a central data base which provides an effective means for tracking and accessing data on marine mammals, including relevant data on marine mammal tissues collected for and maintained in the Tissue Bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d2821-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The data base established under this subsection shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792d2822-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reference data on marine mammal health and mortality and the health of populations of marine mammals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d2823-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data on species of marine mammals that are subject to unusual mortality events.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792d2824-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, in consultation with the Secretary of the Interior, establish criteria, after an opportunity for public review and comment, for public access to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792d2825-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marine mammal tissues in the Tissue Bank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d2826-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyses conducted pursuant to subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d2827-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421f/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marine mammal data in the data base maintained under subsection (c);","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"which provide for appropriate uses of the tissues, analyses, and data by qualified scientists, including stranding network participants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id792d2828-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522/tIV/s407"},"text":"Pub. L. 92–522, title IV, § 407","children":[],"tail":", formerly title III, § 307, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/tIII/s3003/a"},"text":"Pub. L. 102–587, title III, § 3003(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5065"},"text":"106 Stat. 5065","children":[],"tail":"; renumbered title IV, § 407, "},{"tag":"ref","attrib":{"href":"/us/pl/103/238/s24/b"},"text":"Pub. L. 103–238, § 24(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/565"},"text":"108 Stat. 565","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tCIV/s10405"},"text":"Pub. L. 117–263, div. J, title CIV, § 10405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3984"},"text":"136 Stat. 3984","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id792d2829-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id792d282a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id792d282b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10405/1"},"text":"Pub. L. 117–263, § 10405(1)","children":[],"tail":", substituted “marine mammal health and mortality and the health of” for “the health of marine mammals and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10405/2"},"text":"Pub. L. 117–263, § 10405(2)","children":[],"tail":", inserted “public” before “access” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
