{"tag":"section","attrib":{"id":"id7a29feda-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505"},"text":null,"children":[{"tag":"num","attrib":{"value":"7505"},"text":"§ 7505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a29fedb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a29fedc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after funds are deposited into the Fund and made available to the Foundation for administrative purposes, the Foundation shall establish the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a29fedd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Application and review procedures for the awarding of grants under this section, including requirements ensuring that any amounts awarded under such subsections may only be used for an eligible use described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7504"},"text":"section 7504 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a29fede-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Selection procedures and criteria for the awarding of grants under this section that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a29fedf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require consultation with the Administrator and the Secretary of the Interior; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a29fee0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritize the projects or activities where non-Federal partners have committed to share the cost of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a29fee1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Eligibility criteria for awarding grants—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a29fee2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under subsection (b) to coastal States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a29fee3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" under subsection (c) to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a29fee4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/a/1/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entities including States, local governments, and Indian tribes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a29fee5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/a/1/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the research and restoration work of associations, nongovernmental organizations, public-private partnerships, and academic institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a29fee6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Performance accountability and monitoring measures for programs and activities funded by a grant awarded under subsection (b) or (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a29fee7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Procedures and methods to ensure accurate accounting and appropriate administration of grants awarded under this section, including standards of recordkeeping.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a29fee8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Procedures to carry out audits of the Fund as necessary, but not less frequently than once every year if grants have been awarded in that year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a29fee9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Procedures to carry out audits of the recipients of grants under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a29feea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Procedures to make publicly available on the Internet a list of all projects funded by the Fund, that includes at a minimum the grant recipient, grant amount, project description, and project status.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29feeb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall submit to the Administrator for approval each procedure, measure, method, and standard established under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a29feec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to coastal States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a29feed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator and the Foundation may award grants according to the procedures established in subsection (a) to coastal States and United States territories to support activities consistent with section 7503 ","children":[{"tag":"ref","attrib":{"idref":"fn002858"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002858"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title. In determining distribution of grants, the Foundation may—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a29feee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consider for each State—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a29feef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" percent of total United States shoreline miles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a29fef0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coastal population density; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a29fef1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other factors;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a29fef2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish criteria for States, including the requirement for a State to establish a plan to distribute the funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a29fef3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a maximum and minimum percentage of funding to be awarded to each State or United States territory.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29fef4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition on receipt of a grant under this subsection, a State that receives a grant under this subsection shall ensure that Indian tribes in the State are eligible to participate in any competitive grants established in this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a29fef5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National grants for oceans, coasts, and Great Lakes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a29fef6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator and the Foundation may award grants according to the procedures established in subsection (a) to support activities consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7504"},"text":"section 7504 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29fef7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory panel","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a29fef8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation may establish an advisory panel to conduct reviews of applications for grants under paragraph (1) and the Foundation may consider the recommendations of the advisory panel with respect to such applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a29fef9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The advisory panel described under subparagraph (A) shall include persons representing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a29fefa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ocean and coastal dependent industries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a29fefb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geographic regions as defined by the Foundation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a29fefc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7505/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a29fefd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dO/tIX/s906"},"text":"Pub. L. 114–113, div. O, title IX, § 906","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3032"},"text":"129 Stat. 3032","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a29fefe-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a29feff-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a29ff00-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7503"},"text":"Section 7503 of this title","children":[],"tail":", referred to in subsec. (b), was in the original “section 904”, meaning "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dO/s904"},"text":"section 904 of div. O of Pub. L. 114–113","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s7503"},"text":"section 7503 of this title","children":[],"tail":", but probably should have been a reference to "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dO/s905"},"text":"section 905 of div. O of Pub. L. 114–113","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s7504"},"text":"section 7504 of this title","children":[],"tail":". See subsec. (c)(1) of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
