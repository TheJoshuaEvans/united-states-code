{"tag":"section","attrib":{"id":"id7784a8dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhhh–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"410hhhh–6"},"text":"§ 410hhhh–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7784a8dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhhh–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated such sums as may be necessary to carry out this subchapter, except that not more than $3,500,000 is authorized to be appropriated for acquisition of real and personal property (including preservation easements) and development of the preservation district and the historical park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7784a8de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhhh–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 60 percent of the aggregate cost of restoring the Plains High School (referred to in section 410hhhh (b)(2)(E) of this title) may be provided from appropriated Federal funds. The remaining 40 percent, non-Federal share of such cost may be in the form of cash, goods, or services, fairly valued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7784a8df-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/206/s7"},"text":"Pub. L. 100–206, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-23"},"text":"Dec. 23, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1437"},"text":"101 Stat. 1437","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/341/s2/b/4"},"text":"Pub. L. 116–341, § 2(b)(4)","children":[],"tail":", (5), "},{"tag":"date","attrib":{"date":"2021-01-13"},"text":"Jan. 13, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5132"},"text":"134 Stat. 5132","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7784a8e0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7784a8e1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7784a8e2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/341/s2/b/4"},"text":"Pub. L. 116–341, § 2(b)(4)","children":[],"tail":", (5), made identical amendments, substituting “historical park” for “historic site”. See Codification note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410hhhh"},"text":"section 410hhhh of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
