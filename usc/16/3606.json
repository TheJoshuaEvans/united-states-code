{"tag":"section","attrib":{"id":"id79be9233-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3606"},"text":null,"children":[{"tag":"num","attrib":{"value":"3606"},"text":"§ 3606.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations and penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79be9234-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3606/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Directed fishing for salmon; Convention, rules and regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is unlawful for any person, or any vessel, subject to the jurisdiction of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79be9235-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3606/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct directed fishing for salmon in waters seaward of twelve miles from the baselines from which the breadths of territorial seas are measured, in waters of the Atlantic Ocean north of 36 degrees north latitude; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79be9236-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3606/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to violate any provision of the Convention or this chapter, or of any regulation promulgated under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79be9237-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3606/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil and criminal penalties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who commits any act that is unlawful under subsection (a) of this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79be9238-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3606/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be liable to the United States for a civil penalty under section 308 of the Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1858"},"text":"16 U.S.C. 1858","children":[],"tail":") to the same extent as if such act were an act prohibited under section 307 of the Act of 1976 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1857"},"text":"16 U.S.C. 1857","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79be9239-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3606/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be guilty of an offense under section 309 of the Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1859"},"text":"16 U.S.C. 1859","children":[],"tail":") to the same extent as if such act were an act prohibited by section 307(1)(D), (E), (F), or (H) of the Act of 1976 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1857/1/D"},"text":"16 U.S.C. 1857(1)(D)","children":[],"tail":", (E), (F), or (H))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79be923a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3606/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil forfeiture of vessel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vessel used, and any fish (or the fair market value thereof) taken or retained in any manner, in connection with or as the result of the commission of an act which is unlawful under subsection (a) of this section shall be subject to civil forfeiture under section 310 of the Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1860"},"text":"16 U.S.C. 1860","children":[],"tail":") to the same extent as if such vessel was used in, or such fish was taken or retained in connection with or as the result of, the commission of an act prohibited by section 307 of the Act of 1976 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1857"},"text":"16 U.S.C. 1857","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79be923b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/389/tIII/s307"},"text":"Pub. L. 97–389, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-29"},"text":"Dec. 29, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1953"},"text":"96 Stat. 1953","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/44/tI/s102/2"},"text":"Pub. L. 98–44, title I, § 102(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-07-12"},"text":"July 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/216"},"text":"97 Stat. 216","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79be923c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79be923d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79be923e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1983—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/44"},"text":"Pub. L. 98–44","children":[],"tail":" inserted provision that any fish, or the fair market value thereof, taken or retained in connection with or as the result of the commission of an act unlawful under subsection (a) of this section shall be subject to civil forfeitures under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1860"},"text":"section 1860 of this title","children":[],"tail":" to the same extent as if such fish was taken or retained in connection with or as the result of the commission of an act prohibited by "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1857"},"text":"section 1857 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
