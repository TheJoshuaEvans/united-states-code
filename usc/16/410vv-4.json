{"tag":"section","attrib":{"id":"id7760f3ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vv–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"410vv–4"},"text":"§ 410vv–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7760f3bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vv–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into cooperative agreements with such persons or entities as the Secretary determines to be appropriate for the preservation, interpretation, management, and providing of educational and recreational uses for the properties in the park and the scenic zone.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7760f3bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vv–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, through cooperative agreements with owners or operators of land and facilities in the protection zone, may provide for facilities in the protection zone to support activities within the historic zone.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7760f3bd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/350/s6"},"text":"Pub. L. 102–350, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-08-26"},"text":"Aug. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/935"},"text":"106 Stat. 935","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
