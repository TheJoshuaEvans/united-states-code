{"tag":"section","attrib":{"id":"id77908f26-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s429a–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"429a–1"},"text":"§ 429a–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tupelo National Battlefield; acquisition of additional lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To further the purposes of sections 429 and 429a of this title, the Secretary of the Interior may acquire by donation or with donated funds not to exceed one-half acre of land and interests in land for addition to the adjoining Tupelo National Battlefield site.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77908f27-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/133/s1"},"text":"Pub. L. 87–133, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-10"},"text":"Aug. 10, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/336"},"text":"75 Stat. 336","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
