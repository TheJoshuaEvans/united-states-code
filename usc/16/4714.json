{"tag":"section","attrib":{"id":"id79f30fd3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714"},"text":null,"children":[{"tag":"num","attrib":{"value":"4714"},"text":"§ 4714.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ballast water management demonstration program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79f30fd4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Technologies and practices” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “technologies and practices” means those technologies and practices that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f30fd5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may be retrofitted—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f30fd6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on existing vessels or incorporated in new vessel designs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f30fd7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on existing land-based ballast water treatment facilities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30fd8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be designed into new water treatment facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30fd9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are operationally practical;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30fda-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are safe for a vessel and crew;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30fdb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are environmentally sound;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30fdc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are cost-effective;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30fdd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel operator is capable of monitoring; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30fde-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are effective against a broad range of aquatic nuisance species.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f30fdf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f30fe0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the 18-month period beginning on the date that funds are made available by appropriations pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4741/e"},"text":"section 4741(e) of this title","children":[],"tail":", the Secretary of the Interior and the Secretary of Commerce, with the concurrence of and in cooperation with the Secretary, shall conduct a ballast water management demonstration program to demonstrate technologies and practices to prevent aquatic nonindigenous species from being introduced into and spread through ballast water in the Great Lakes and other waters of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30fe1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The installation and construction of the technologies and practices used in the demonstration program conducted under this subsection shall be performed in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30fe2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vessel selection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In demonstrating technologies and practices on vessels under this subsection, the Secretary of the Interior and the Secretary of Commerce, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f30fe3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" use only vessels that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f30fe4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are approved by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f30fe5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have ballast water systems conducive to testing aboard-vessel or land-based technologies and practices applicable to a significant number of merchant vessels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f30fe6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" are—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79f30fe7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/b/3/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publicly or privately owned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79f30fe8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/b/3/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in active use for trade or other cargo shipment purposes during the demonstration;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f30fe9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" select vessels for participation in the program by giving priority consideration—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f30fea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" first, to vessels documented under chapter 121 of title 46;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f30feb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" second, to vessels that are a majority owned by citizens of the United States, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f30fec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" third, to any other vessels that regularly call on ports in the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f30fed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" seek to use a variety of vessel types, including vessels that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f30fee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" call on ports in the United States and on the Great Lakes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f30fef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are operated along major coasts of the United States and inland waterways, including the San Francisco Bay and Chesapeake Bay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30ff0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of technologies and practices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In selecting technologies and practices for demonstration under this subsection, the Secretary of the Interior and the Secretary of Commerce shall give priority consideration to technologies and practices identified as promising by the National Research Council Marine Board of the National Academy of Sciences in its report on ships’ ballast water operations issued in July 1996.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30ff1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"1996-10-26"},"text":"October 26, 1996","children":[],"tail":", the Secretary of the Interior and the Secretary of Commerce shall prepare and submit a report to the Congress on the demonstration program conducted pursuant to this section. The report shall include findings and recommendations of the Secretary of the Interior and the Secretary of Commerce concerning technologies and practices."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f30ff2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities; consultation and cooperation with International Maritime Organization and Task Force","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f30ff3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the demonstration program under subsection (b), the Secretary of the Interior may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f30ff4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into cooperative agreements with appropriate officials of other agencies of the Federal Government, agencies of States and political subdivisions thereof, and private entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f30ff5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept funds, facilities, equipment, or personnel from other Federal agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f30ff6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept donations of property and services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30ff7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4714/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation and cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall consult and cooperate with the International Maritime Organization and the Task Force in carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f30ff8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/646/tI/s1104"},"text":"Pub. L. 101–646, title I, § 1104","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/d"},"text":"Pub. L. 104–332, § 2(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4083"},"text":"110 Stat. 4083","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
