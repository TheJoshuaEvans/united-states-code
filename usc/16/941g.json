"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s3901/g"},"text":"Pub. L. 114–322, § 3901(g)","children":[],"tail":", designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s3901/f/1"},"text":"Pub. L. 114–322, § 3901(f)(1)","children":[],"tail":" substituted “2016 through 2021” for “2007 through 2012” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s3901/f/2/A"},"text":"Pub. L. 114–322, § 3901(f)(2)(A)","children":[],"tail":", substituted “$6,000,000” for “$14,000,000” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s3901/f/2/B"},"text":"Pub. L. 114–322, § 3901(f)(2)(B)","children":[],"tail":", substituted “$2,000,000” for “$4,600,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s3901/f/2/C"},"text":"Pub. L. 114–322, § 3901(f)(2)(C)","children":[],"tail":", substituted “$300,000” for “$700,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s3901/f/3"},"text":"Pub. L. 114–322, § 3901(f)(3)","children":[],"tail":", substituted “the activities of the Upper Great Lakes Fish and Wildlife Conservation Offices and the Lower Great Lakes Fish and Wildlife Conservation Office under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s941e"},"text":"section 941e of this title","children":[],"tail":"” for “the activities of the Great Lakes Coordination Office in East Lansing, Michigan, of the Upper Great Lakes Fishery Resources Office, and the Lower Great Lakes Fishery Resources Office under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s941e"},"text":"section 941e of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/326"},"text":"Pub. L. 109–326","children":[],"tail":" amended section generally, substituting provisions authorizing appropriations for fiscal years 2007 to 2012 for provisions authorizing appropriations for fiscal years 1999 to 2004."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/265"},"text":"Pub. L. 105–265","children":[],"tail":" amended section generally, substituting provisions authorizing appropriations for fiscal years 1999 to 2004 for provisions authorizing appropriations for fiscal years 1991 to 1994 to conduct a study under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s941c"},"text":"section 941c of this title","children":[],"tail":" and for fiscal years 1991 to 1995 to establish and operate Great Lakes Coordination and Upper and Lower Great Lakes Fishery Resources Offices."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332"},"text":"Pub. L. 104–332","children":[],"tail":" made technical amendment to "},{"tag":"ref","attrib":{"href":"/us/pl/101/646/s2009"},"text":"Pub. L. 101–646, § 2009","children":[],"tail":", which enacted this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
