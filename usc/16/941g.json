{"tag":"section","attrib":{"id":"id78d74019-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941g"},"text":null,"children":[{"tag":"num","attrib":{"value":"941g"},"text":"§ 941g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78d7401a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Director for each of fiscal years 2023 through 2028—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78d7401b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" $6,000,000 to implement fish and wildlife restoration proposals as selected by the Director under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s941c/e"},"text":"section 941c(e) of this title","children":[],"tail":", of which—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78d7401c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941g/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than the lesser of 33 1/3 percent or $2,000,000 may be allocated to implement regional projects by the United States Fish and Wildlife Service, as selected by the Director under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s941c/e"},"text":"section 941c(e) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78d7401d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941g/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lesser of 3 percent or $300,000 shall be allocated to the United States Fish and Wildlife Service to cover costs incurred in administering the proposals by any entity; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d7401e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,000,000, which shall be allocated for the activities of the Upper Great Lakes Fish and Wildlife Conservation Offices and the Lower Great Lakes Fish and Wildlife Conservation Office under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s941e"},"text":"section 941e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78d7401f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on use of funds for Federal acquisition of interests in land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No funds appropriated or used to carry out this chapter may be used for acquisition by the Federal Government of any interest in land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78d74020-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/537/tI/s1009"},"text":"Pub. L. 101–537, title I, § 1009","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-08"},"text":"Nov. 8, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2374"},"text":"104 Stat. 2374","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/646/tII/s2009"},"text":"Pub. L. 101–646, title II, § 2009","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4778"},"text":"104 Stat. 4778","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/h/1"},"text":"Pub. L. 104–332, § 2(h)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4091"},"text":"110 Stat. 4091","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/265"},"text":"Pub. L. 105–265","children":[],"tail":", §§ 3(b), 8, "},{"tag":"date","attrib":{"date":"1998-10-19"},"text":"Oct. 19, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2358"},"text":"112 Stat. 2358","children":[],"tail":", 2361; "},{"tag":"ref","attrib":{"href":"/us/pl/109/326/s9"},"text":"Pub. L. 109–326, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-11"},"text":"Oct. 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1766"},"text":"120 Stat. 1766","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tIII/s3901/f"},"text":"Pub. L. 114–322, title III, § 3901(f)","children":[],"tail":", (g), "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1850"},"text":"130 Stat. 1850","children":[],"tail":", 1851; "},{"tag":"ref","attrib":{"href":"/us/pl/117/287/s2/b"},"text":"Pub. L. 117–287, § 2(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4363"},"text":"136 Stat. 4363","children":[],"tail":", 4364.)"}],"tail":"\n"},{"tag":"notes","attrib":{"ty