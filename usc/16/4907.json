{"tag":"section","attrib":{"id":"id79f7cbab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4907"},"text":null,"children":[{"tag":"num","attrib":{"value":"4907"},"text":"§ 4907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Moratoria for species not covered by Convention","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79f7cbac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4907/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f7cbad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4907/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review periodically the trade in species of exotic birds that are not listed in any Appendix to the Convention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cbae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4907/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" after notice and an opportunity for public comment, establish a moratorium or quota on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f7cbaf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4907/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" importation of any species of exotic birds from one or more countries of origin for the species, if the Secretary determines that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f7cbb0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4907/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the findings described in section 4905(c)(2), (3), and (4) of this title cannot be made with respect to the species; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f7cbb1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4907/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the moratorium or quota is necessary for the conservation of the species or is otherwise consistent with the purpose of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f7cbb2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4907/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the importation of all species of exotic birds from a particular country, if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f7cbb3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4907/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the country has not developed and implemented a management program for exotic birds in trade generally, that ensures both the conservation and the humane treatment of exotic birds during capture, transport, and maintenance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f7cbb4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4907/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary finds that the moratorium or quota is necessary for the conservation of the species or is otherwise consistent with the purpose of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f7cbb5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4907/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of quota or moratorium","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall terminate a quota or moratorium established under subsection (a) if the Secretary finds that the reasons for establishing the quota or moratorium no longer exist.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f7cbb6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/440/tI/s108"},"text":"Pub. L. 102–440, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2229"},"text":"106 Stat. 2229","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
