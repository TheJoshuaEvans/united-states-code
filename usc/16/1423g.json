{"tag":"section","attrib":{"id":"id792f992a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1423g"},"text":"§ 1423g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application with other subchapters of chapter","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id792f992b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The authority of the Secretary under this subchapter is in addition to, and shall not affect—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792f992c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority of the Secretary under other subchapters ","children":[{"tag":"ref","attrib":{"idref":"fn002640"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002640"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this chapter or the Lacey Act Amendments of 1981 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3371"},"text":"16 U.S.C. 3371","children":[],"tail":" et seq.) or the exemption for Alaskan natives under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1371/b"},"text":"section 1371(b) of this title","children":[],"tail":" as applied to other marine mammal populations; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792f992d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authorities provided under subchapter III of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792f992e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain provisions inapplicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of subchapters II through V of this chapter do not apply with respect to the implementation or administration of this subchapter, except as specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1423b"},"text":"section 1423b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id792f992f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522/tV/s508"},"text":"Pub. L. 92–522, title V, § 508","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/479/tIX/s902/a"},"text":"Pub. L. 109–479, title IX, § 902(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3664"},"text":"120 Stat. 3664","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id792f9930-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id792f9931-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id792f9932-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Other subchapters of this chapter, referred to in subsec. (a)(1), was in the original a reference to “other titles of this Act” meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522"},"text":"Pub. L. 92–522","children":[],"tail":". Subchapter I of this chapter consists of sections of "},{"tag":"ref","attrib":{"href":"/us/pl/92/522"},"text":"Pub. L. 92–522","children":[],"tail":" that are not part of a title of that Act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Lacey Act Amendments of 1981, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/79"},"text":"Pub. L. 97–79","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-11-16"},"text":"Nov. 16, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1073"},"text":"95 Stat. 1073","children":[],"tail":", which enacted chapter 53 (§ 3371 et seq.) of this title, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1540"},"text":"section 1540 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s42"},"text":"section 42 of Title 18","children":[],"tail":", Crimes and Criminal Procedure, repealed sections 667e and 851 to 856 of this title and sections 43, 44, 3054, and 3112 of Title 18, and enacted provisions set out as notes under sections 1540 and 3371 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3371"},"text":"section 3371 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
