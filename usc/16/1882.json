{"tag":"section","attrib":{"id":"id798a1551-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1882"},"text":null,"children":[{"tag":"num","attrib":{"value":"1882"},"text":"§ 1882.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fisheries systems research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id798a1552-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1882/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of panel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1996-10-11"},"text":"October 11, 1996","children":[],"tail":", the Secretary shall establish an advisory panel under this chapter to develop recommendations to expand the application of ecosystem principles in fishery conservation and management activities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798a1553-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1882/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Panel membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The advisory panel shall consist of not more than 20 individuals and include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id798a1554-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1882/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals with expertise in the structures, functions, and physical and biological characteristics of ecosystems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798a1555-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1882/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives from the Councils, States, fishing industry, conservation organizations, or others with expertise in the management of marine resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798a1556-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1882/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to selecting advisory panel members, the Secretary shall, with respect to panel members described in subsection (b)(1), solicit recommendations from the National Academy of Sciences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798a1557-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1882/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 2 years after ","children":[{"tag":"date","attrib":{"date":"1996-10-11"},"text":"October 11, 1996","children":[],"tail":", the Secretary shall submit to the Congress a completed report of the panel established under this section, which shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id798a1558-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1882/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the extent to which ecosystem principles are being applied in fishery conservation and management activities, including research activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798a1559-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1882/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proposed actions by the Secretary and by the Congress that should be undertaken to expand the application of ecosystem principles in fishery conservation and management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798a155a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1882/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as may be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798a155b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1882/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedural matter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The advisory panel established under this section shall be deemed an advisory panel under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1852/g"},"text":"section 1852(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798a155c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1882/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional ecosystem research","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id798a155d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1882/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 180 days after ","children":[{"tag":"date","attrib":{"date":"2007-01-12"},"text":"January 12, 2007","children":[],"tail":", the Secretary, in consultation with the Councils, shall undertake and complete a study on the state of the science for advancing the concepts and integration of ecosystem considerations in regional fishery management. The study should build upon the recommendations of the advisory panel and include—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id798a155e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1882/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for scientific data, information and technology requirements for understanding ecosystem processes, and methods for integrating such information from a variety of federal,","children":[{"tag":"ref","attrib":{"idref":"fn002704"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002704"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" state,"},{"tag":"ref","attrib":{"idref":"fn002704"},"text":"1","children":[],"tail":" and regional sources;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id798a155f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1882/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for processes for incorporating broad stake holder participation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id798a1560-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1882/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for processes to account for effects of environmental variation on fish stocks and fisheries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id798a1561-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1882/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of existing and developing council efforts to implement ecosystem approaches, including lessons learned by the councils.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798a1562-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1882/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency technical advice and assistance, regional pilot programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to provide necessary technical advice and assistance, including grants, to the Councils for the development and design of regional pilot programs that build upon the recommendations of the advisory panel and, when completed, the study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id798a1563-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265/tIV/s406"},"text":"Pub. L. 94–265, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-13"},"text":"Apr. 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/361"},"text":"90 Stat. 361","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/354/s1"},"text":"Pub. L. 95–354, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-08-28"},"text":"Aug. 28, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/519"},"text":"92 Stat. 519","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/61/s1"},"text":"Pub. L. 96–61, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-15"},"text":"Aug. 15, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/407"},"text":"93 Stat. 407","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/453/s14/a"},"text":"Pub. L. 97–453, § 14(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2492"},"text":"96 Stat. 2492","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/659/tI/s111/a"},"text":"Pub. L. 99–659, title I, § 111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3715"},"text":"100 Stat. 3715","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/627/tI/s119"},"text":"Pub. L. 101–627, title I, § 119","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4459"},"text":"104 Stat. 4459","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/297/tII/s207/a"},"text":"Pub. L. 104–297, title II, § 207(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3612"},"text":"110 Stat. 3612","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/479/tII/s210"},"text":"Pub. L. 109–479, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3617"},"text":"120 Stat. 3617","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id798a1564-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id798a1565-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id798a1566-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265"},"text":"Pub. L. 94–265","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-13"},"text":"Apr. 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/331"},"text":"90 Stat. 331","children":[],"tail":", known as the Magnuson-Stevens Fishery Conservation and Management Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1801"},"text":"section 1801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id798a1567-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"1996-10-11"},"text":"October 11, 1996","children":[],"tail":", referred to in subsec. (d), was in the original “the date of enactment of this Act”, which was translated as meaning the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/104/297"},"text":"Pub. L. 104–297","children":[],"tail":", which amended this section generally, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id798a1568-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/479"},"text":"Pub. L. 109–479","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/297"},"text":"Pub. L. 104–297","children":[],"tail":" amended section catchline and text generally. Prior to amendment, section authorized appropriations to carry out this chapter for fiscal year ending "},{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":" to fiscal year ending "},{"tag":"date","attrib":{"date":"1993-09-30"},"text":"September 30, 1993","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Pars. (16) to (19). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/627"},"text":"Pub. L. 101–627","children":[],"tail":" added pars. (16) to (19)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Pars. (12) to (15). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/659"},"text":"Pub. L. 99–659","children":[],"tail":" added pars. (12) to (15)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Pars. (9) to (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/453"},"text":"Pub. L. 97–453","children":[],"tail":" added pars. (9) to (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Pars. (6) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/61"},"text":"Pub. L. 96–61","children":[],"tail":" added pars. (6) to (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/354"},"text":"Pub. L. 95–354","children":[],"tail":" added par. (5)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
