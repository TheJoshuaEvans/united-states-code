{"tag":"section","attrib":{"id":"id79d41654-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"3839aa–5"},"text":"§ 3839aa–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental quality incentives program plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79d41655-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan of operations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive payments under the program, a producer shall submit to the Secretary for approval a plan of operations that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d41656-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–5/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifies practices covered under the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d41657-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–5/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes such terms and conditions as the Secretary considers necessary to carry out the program, including a description of the purposes to be met by the implementation of the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d41658-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–5/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a confined livestock feeding operation, provides for development and progressive implementation of a comprehensive nutrient management plan, if applicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d41659-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–5/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of forest land, is consistent with the provisions of a forest management plan that is approved by the Secretary, which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d4165a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–5/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a forest stewardship plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2103a"},"text":"section 2103a of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d4165b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–5/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another practice plan approved by the State forester; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d4165c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–5/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another plan determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d4165d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Avoidance of duplication","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d4165e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider a plan developed in order to acquire a permit under a water or air quality regulatory program as the equivalent of a plan of operations under subsection (a), if the plan contains elements equivalent to those elements required by a plan of operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d4165f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, eliminate duplication of planning activities under the program under this subpart and comparable conservation programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79d41660-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1240E"},"text":"Pub. L. 99–198, title XII, § 1240E","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tII/s2301"},"text":"Pub. L. 107–171, title II, § 2301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/256"},"text":"116 Stat. 256","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tII/s2506"},"text":"Pub. L. 110–234, title II, § 2506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"hr