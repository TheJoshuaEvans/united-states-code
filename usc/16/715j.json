{"tag":"section","attrib":{"id":"id78817f13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s715j"},"text":null,"children":[{"tag":"num","attrib":{"value":"715j"},"text":"§ 715j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Migratory birds” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purposes of this subchapter and the Migratory Bird Treaty Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s703"},"text":"16 U.S.C. 703","children":[],"tail":" et seq.), migratory birds are those defined as such by the treaty between the United States and Great Britain for the protection of migratory birds concluded "},{"tag":"date","attrib":{"date":"1916-08-16"},"text":"August 16, 1916","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/39/1702"},"text":"39 Stat. 1702","children":[],"tail":"), the treaty between the United States and the United Mexican States for the protection of migratory birds and game mammals concluded "},{"tag":"date","attrib":{"date":"1936-02-07"},"text":"February 7, 1936","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/50/1311"},"text":"50 Stat. 1311","children":[],"tail":"), the Convention between the Government of the United States of America and the Government of Japan for the Protection of Migratory Birds and Birds in Danger of Extinction, and their Environment concluded "},{"tag":"date","attrib":{"date":"1972-03-04"},"text":"March 4, 1972","children":[],"tail":", and the Convention between the United States and the Union of Soviet Socialist Republics for the Conservation of Migratory Birds and their Environment concluded "},{"tag":"date","attrib":{"date":"1976-11-19"},"text":"November 19, 1976","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78817f14-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1929-02-18/ch257/s11"},"text":"Feb. 18, 1929, ch. 257, § 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1224"},"text":"45 Stat. 1224","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/669/s7/c"},"text":"Pub. L. 89–669, § 7(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/930"},"text":"80 Stat. 930","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/616/s5/c"},"text":"Pub. L. 95–616, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-08"},"text":"Nov. 8, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3114"},"text":"92 Stat. 3114","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78817f15-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78817f16-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78817f17-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Migratory Bird Treaty Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1918-07-03/ch128"},"text":"act July 3, 1918, ch. 128","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/755"},"text":"40 Stat. 755","children":[],"tail":", which is classified generally to subchapter II (§ 703 et seq.) of this chapter. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s710"},"text":"section 710 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78817f18-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/616"},"text":"Pub. L. 95–616","children":[],"tail":" defined migratory birds for purposes of the Migratory Bird Treaty Act and to include those defined in the Convention of "},{"tag":"date","attrib":{"date":"1972-03-04"},"text":"Mar. 4, 1972","children":[],"tail":", concluded with Government of Japan and the Convention of "},{"tag":"date","attrib":{"date":"1976-11-19"},"text":"Nov. 19, 1976","children":[],"tail":", concluded with Union of Soviet Socialist Republics."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/669"},"text":"Pub. L. 89–669","children":[],"tail":" inserted “("},{"tag":"ref","attrib":{"href":"/us/stat/39/1702"},"text":"39 Stat. 1702","children":[],"tail":")” and defined migratory birds to include those defined in the Treaty of "},{"tag":"date","attrib":{"date":"1936-02-07"},"text":"Feb. 7, 1936","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/50/1311"},"text":"50 Stat. 1311","children":[],"tail":") with the United Mexican States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
