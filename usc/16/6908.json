{"tag":"section","attrib":{"id":"id7a206200-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6908"},"text":null,"children":[{"tag":"num","attrib":{"value":"6908"},"text":"§ 6908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Territorial participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall ensure participation in the Commission and its subsidiary bodies by American Samoa, Guam, and the Northern Mariana Islands to the same extent provided to the territories of other nations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a206201-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/479/tV/s509"},"text":"Pub. L. 109–479, title V, § 509","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3643"},"text":"120 Stat. 3643","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
