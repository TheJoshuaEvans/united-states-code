{"tag":"section","attrib":{"id":"id79986ca3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2203"},"text":null,"children":[{"tag":"num","attrib":{"value":"2203"},"text":"§ 2203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency watershed program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79986ca4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to undertake emergency watershed protection measures, including the purchase of floodplain easements, for runoff retardation and soil-erosion prevention, in cooperation with landowners and land users, as the Secretary deems necessary to safeguard lives and property from floods, drought, and the products of erosion on any watershed whenever fire, flood, or any other natural occurrence is causing or has caused a sudden impairment of that watershed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79986ca5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Floodplain easements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79986ca6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2203/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification and termination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may modify or terminate a floodplain easement administered by the Secretary under this section if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79986ca7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2203/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current owner agrees to the modification or termination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79986ca8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2203/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary determines that the modification or termination—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79986ca9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2203/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will address a compelling public need for which there is no practicable alternative; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79986caa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2203/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79986cab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2203/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79986cac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2203/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As consideration for termination of an easement and associated agreements under paragraph (1), the Secretary shall enter into compensatory arrangements as determined to be appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79986cad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2203/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a modification under paragraph (1)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79986cae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2203/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a condition of the modification, the current owner shall enter into a compensatory arrangement (as determined to be appropriate by the Secretary) to incur the costs of modification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79986caf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2203/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary shall ensure that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79986cb0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2203/b/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the modification will not adversely affect the floodplain functions and values for which the easement was acquired;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79986cb1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2203/b/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any adverse impacts will be mitigated by enrollment and restoration of other land that provides greater floodplain functions and values at no additional cost to the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79986cb2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2203/b/2/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the modification will result in equal or greater environmental and economic values to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79986cb3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/334/tIV/s403"},"text":"Pub. L. 95–334, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-08-04"},"text":"Aug. 4, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/434"},"text":"92 Stat. 434","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tIII/s382"},"text":"Pub. L. 104–127, title III, § 382","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1016"},"text":"110 Stat. 1016","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII/s2506"},"text":"Pub. L. 113–79, title II, § 2506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/752"},"text":"128 Stat. 752","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII/s2403/a/2/A"},"text":"Pub. L. 115–334, title II, § 2403(a)(2)(A)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4571"},"text":"132 Stat. 4571","children":[],"tail":", 4572.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79986cb4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79986cb5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79986cb6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2403/d/1"},"text":"Pub. L. 115–334, § 2403(d)(1)","children":[],"tail":", substituted “Emergency watershed program” for “Emergency measures” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2403/d/2"},"text":"Pub. L. 115–334, § 2403(d)(2)","children":[],"tail":", inserted “watershed protection” after “emergency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2403/a/2/A"},"text":"Pub. L. 115–334, § 2403(a)(2)(A)","children":[],"tail":", substituted “The Secretary is” for “The Secretary of Agriculture is”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" inserted section catchline, designated existing provisions as subsec. (a) and inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" inserted “, including the purchase of floodplain easements,” after “emergency measures”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79986cb7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79986cb8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1978-10-01"},"text":"Oct. 1, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/334/s406"},"text":"section 406 of Pub. L. 95–334","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79986cb9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Disaster Assistance for Watershed Protection Activities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/387/tIV/s402"},"text":"Pub. L. 100–387, title IV, § 402","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/82/tV/s503"},"text":"Pub. L. 101–82, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-14"},"text":"Aug. 14, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/586"},"text":"103 Stat. 586","children":[],"tail":", authorized the Secretary of Agriculture to provide financial and technical disaster relief assistance in accordance with this section to repair damage caused by storms occurring in 1988 or 1989 to watersheds located in any county in any State, to the extent that funds authorized by this section remain available, with $25,000,000 appropriated for fiscal year 1990."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
