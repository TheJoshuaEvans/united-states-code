{"tag":"section","attrib":{"id":"id776cda8c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ccc–21"},"text":null,"children":[{"tag":"num","attrib":{"value":"410ccc–21"},"text":"§ 410ccc–21.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id776cda8d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ccc–21/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established the Cane River National Heritage Area (hereinafter in this part referred to as the “heritage area”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776cda8e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ccc–21/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In furtherance of the need to recognize the value and importance of the Cane River region and in recognition of the findings of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410ccc/a"},"text":"section 410ccc(a) of this title","children":[],"tail":", it is the purpose of this part to establish a heritage area to complement the historical park and to provide for a culturally sensitive approach to the preservation of the heritage of the Cane River region, and for other needs including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id776cda8f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ccc–21/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognizing areas important to the Nation’s heritage and identity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776cda90-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ccc–21/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting in the preservation and enhancement of the cultural landscape and traditions of the Cane River region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776cda91-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ccc–21/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing a framework for those who live within this important dynamic cultural landscape to assist in preservation and educational actions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776cda92-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ccc–21/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimizing the need for Federal land acquisition and management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776cda93-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ccc–21/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The heritage area shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776cda94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ccc–21/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an area approximately 1 mile on both sides of the Cane River as depicted on map CARI, 80,000A, dated May 1994;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776cda95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ccc–21/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those properties within the Natchitoches National Historic Landmark District which are the subject of cooperative agreements pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410ccc–2/d"},"text":"section 410ccc–2(d) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776cda96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ccc–21/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Los Adaes State Commemorative Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776cda97-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ccc–21/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Fort Jesup State Commemorative Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776cda98-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ccc–21/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Fort St. Jean Baptiste State Commemorative Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776cda99-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ccc–21/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Kate Chopin House.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"A final identification of all areas and sites to be included in the heritage area shall be included in the heritage area management plan as required in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410ccc–23"},"text":"section 410ccc–23 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id776cda9a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/449/tIV/s401"},"text":"Pub. L. 103–449, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4760"},"text":"108 Stat. 4760","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
