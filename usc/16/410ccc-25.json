{"tag":"section","attrib":{"id":"id776f4ad8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ccc–25"},"text":null,"children":[{"tag":"num","attrib":{"value":"410ccc–25"},"text":"§ 410ccc–25.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of other Federal agencies","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any Federal entity conducting or supporting activities directly affecting the heritage area shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776f4ad9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ccc–25/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the Secretary and the Commission with respect to implementation of their proposed actions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776f4ada-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ccc–25/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, coordinate such activities with the Commission to minimize potential impacts on the resources of the heritage area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id776f4adb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/449/tIV/s405"},"text":"Pub. L. 103–449, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4764"},"text":"108 Stat. 4764","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
