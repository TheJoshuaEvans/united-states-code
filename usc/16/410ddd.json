":[],"tail":", redesignated subsec. (e), relating to general management plan, as (f). Former subsec. (f) redesignated (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/176/s111/a/4"},"text":"Pub. L. 106–176, § 111(a)(4)","children":[],"tail":", redesignated subsec. (f) as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/176/s111/a/5/A"},"text":"Pub. L. 106–176, § 111(a)(5)(A)","children":[],"tail":", substituted “subsection (d).” for “section 3(D).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/176/s111/a/5/B"},"text":"Pub. L. 106–176, § 111(a)(5)(B)","children":[],"tail":", substituted “cooperative agreements under subsection (e)(2)” for “cooperative grants under subsection (d)(2)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id776f4b18-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id776f4b19-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Resources of House of Representatives changed to Committee on Natural Resources of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
