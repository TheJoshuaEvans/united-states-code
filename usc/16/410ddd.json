{"tag":"section","attrib":{"id":"id776f4adf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd"},"text":null,"children":[{"tag":"num","attrib":{"value":"410ddd"},"text":"§ 410ddd.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New Bedford Whaling National Historical Park","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id776f4ae0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purposes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776f4ae1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id776f4ae2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the New Bedford National Historic Landmark District and associated historic sites as described in subsection (c)(2), including the Schooner Ernestina, are National Historic Landmarks and are listed on the National Register of Historic Places as historic sites associated with the history of whaling in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776f4ae3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the city of New Bedford was the 19th century capital of the world’s whaling industry and retains significant architectural features, archival materials, and museum collections illustrative of this period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776f4ae4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" New Bedford’s historic resources provide unique opportunities for illustrating and interpreting the whaling industry’s contribution to the economic, social, and environmental history of the United States and provide opportunities for public use and enjoyment; and ","children":[{"tag":"ref","attrib":{"idref":"fn002160"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002160"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “and” probably should not appear."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776f4ae5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the nineteenth century, over two thousand whaling voyages sailed out of New Bedford to the Arctic region of Alaska, and joined Alaska Natives from Barrow, Alaska and other areas in the Arctic region in subsistence whaling activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776f4ae6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Park System presently contains no sites commemorating whaling and its contribution to American history.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776f4ae7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this section are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id776f4ae8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to help preserve, protect, and interpret the resources within the areas described in subsection (c)(2), including architecture, setting, and associated archival and museum collections;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776f4ae9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to collaborate with the city of New Bedford and with associated historical, cultural, and preservation organizations to further the purposes of the park established under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776f4aea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide opportunities for the inspirational benefit and education of the American people.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776f4aeb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776f4aec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “park” means the New Bedford Whaling National Historical Park established by subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776f4aed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776f4aee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New Bedford Whaling National Historical Park","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776f4aef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to preserve for the benefit and inspiration of the people of the United States as a national historical park certain districts, structures, and relics located in New Bedford, Massachusetts, and associated with the history of whaling and related social and economic themes in America, there is established the New Bedford Whaling National Historical Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776f4af0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundaries","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id776f4af1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The boundaries of the park shall be those generally depicted on the map numbered NAR–P49–80,000–4 and dated June 1994. Such map shall be on file and available for public inspection in the appropriate offices of the National Park Service. In case of any conflict between the descriptions set forth in clauses (i) through (iv) and such map, such map shall govern. The park shall include the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id776f4af2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The area included within the New Bedford Historic District (a National Landmark District), also known as the Bedford Landing Waterfront Historic District, as listed within the National Register of Historic Places and in the Massachusetts State Register of Historic Places.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id776f4af3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Historic Landmark Schooner Ernestina, with its home port in New Bedford.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id776f4af4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The land along the eastern boundary of the New Bedford National Historic Landmark District over the east side of MacArthur Drive from the Route 6 overpass on the north to an extension of School Street on the south.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id776f4af5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/c/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The land north of Elm Street in New Bedford, bounded by Acushnet Avenue on the west, Route 6 (ramps) on the north, MacArthur Drive on the east, and Elm Street on the south.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776f4af6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In addition to the sites, areas, and relics referred to in subparagraph (A), the Secretary may assist in the interpretation and preservation of each of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id776f4af7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The southwest corner of the State Pier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id776f4af8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Waterfront Park, immediately south of land adjacent to the State Pier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id776f4af9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Rotch-Jones-Duff House and Garden Museum, located at 396 County Street.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id776f4afa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/c/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Wharfinger Building, located on Piers 3 and 4.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id776f4afb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/c/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Bourne Counting House, located on Merrill’s Wharf.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776f4afc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related facilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To ensure that the contribution of Alaska Natives to the history of whaling in the United States is fully recognized, the Secretary shall provide—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776f4afd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial and other assistance to establish links between the New Bedford Whaling National Historical Park and the North Slope Borough Cultural Center, located in Barrow, Alaska; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776f4afe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate assistance and funding for the North Slope Borough Cultural Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776f4aff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of park","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776f4b00-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The park shall be administered by the Secretary in accordance with this section and the provisions of law generally applicable to units of the National Park System, including the Act entitled “An Act to establish a National Park Service, and for other purposes”, approved ","children":[{"tag":"date","attrib":{"date":"1916-08-25"},"text":"August 25, 1916","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/39/535"},"text":"39 Stat. 535","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"16 U.S.C. 1","children":[],"tail":", 2, 3, and 4) "},{"tag":"ref","attrib":{"idref":"fn002161"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002161"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" and the Act of "},{"tag":"date","attrib":{"date":"1935-08-21"},"text":"August 21, 1935","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/49/666"},"text":"49 Stat. 666","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s461–467"},"text":"16 U.S.C. 461–467","children":[],"tail":")."},{"tag":"ref","attrib":{"idref":"fn002161"},"text":"2","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776f4b01-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id776f4b02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may consult and enter into cooperative agreements with interested entities and individuals to provide for the preservation, development, interpretation, and use of the park.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776f4b03-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any payment made by the Secretary pursuant to a cooperative agreement under this paragraph shall be subject to an agreement that conversion, use, or disposal of the project so assisted for purposes contrary to the purposes of this section, as determined by the Secretary, shall result in a right of the United States to reimbursement of all funds made available to such project or the proportion of the increased value of the project attributable to such funds as determined at the time of such conversion, use, or disposal, whichever is greater.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776f4b04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal matching requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id776f4b05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Funds authorized to be appropriated to the Secretary for the purposes of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id776f4b06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/e/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperative agreements under paragraph (2) shall be expended in the ratio of one dollar of Federal funds for each four dollars of funds contributed by non-Federal sources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id776f4b07-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/e/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction, restoration, and rehabilitation of visitors and interpretive facilities (other than annual operation and maintenance costs) shall be expended in the ratio of one dollar of Federal funds for each one dollar of funds contributed by non-Federal sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776f4b08-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this paragraph, the Secretary is authorized to accept from non-Federal sources, and to utilize for purposes of this section, any money so contributed. With the approval of the Secretary, any donation of property, services, or goods from a non-Federal source may be considered as a contribution of funds from a non-Federal source for the purposes of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776f4b09-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of real property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of the park, the Secretary may acquire only by donation such lands, interests in lands, and improvements thereon within the park as are needed for essential visitor contact and interpretive facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776f4b0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other property, funds, and services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may accept donated funds, property, and services to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776f4b0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General management plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the end of the second fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"1996-11-12"},"text":"November 12, 1996","children":[],"tail":", the Secretary shall submit to the Committee on Resources of the House of Representatives and the Committee on Energy and Natural Resources of the Senate a general management plan for the park and shall implement such plan as soon as practically possible. The plan shall be prepared in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100502"},"text":"section 100502 of title 54","children":[],"tail":" and other applicable law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776f4b0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776f4b0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), there are authorized to be appropriated such sums as may be necessary to carry out annual operations and maintenance with respect to the park and to carry out the activities under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776f4b0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id776f4b0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $5,000,000 may be appropriated for construction, restoration, and rehabilitation of visitor and interpretive facilities, and directional and visitor orientation signage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776f4b10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" none of the funds authorized to be appropriated by this section may be used for the operation or maintenance of the Schooner Ernestina; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776f4b11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ddd/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $50,000 annually of Federal funds may be used for interpretive and education programs for the Schooner Ernestina pursuant to cooperative agreements under subsection (e)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id776f4b12-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/333/dI/tV/s511"},"text":"Pub. L. 104–333, div. I, title V, § 511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-11-12"},"text":"Nov. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4159"},"text":"110 Stat. 4159","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/176/tI/s111/a"},"text":"Pub. L. 106–176, title I, § 111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-03-10"},"text":"Mar. 10, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/26"},"text":"114 Stat. 26","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/dF/tI/s154"},"text":"Pub. L. 108–7, div. F, title I, § 154","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/246"},"text":"117 Stat. 246","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id776f4b13-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id776f4b14-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id776f4b15-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Act entitled “An Act to establish a National Park Service, and for other purposes”, approved ","children":[{"tag":"date","attrib":{"date":"1916-08-25"},"text":"August 25, 1916","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/39/535"},"text":"39 Stat. 535","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"16 U.S.C. 1","children":[],"tail":", 2, 3, and 4), referred to in subsec. (e)(1), is "},{"tag":"ref","attrib":{"hre