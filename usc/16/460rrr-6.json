{"tag":"section","attrib":{"id":"id7807e224-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"460rrr–6"},"text":"§ 460rrr–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Nothing in this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7807e225-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–6/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amends, modifies, or is in conflict with the Rio Grande Compact, consented to by Congress in the Act of ","children":[{"tag":"date","attrib":{"date":"1939-05-31"},"text":"May 31, 1939","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/53/785"},"text":"53 Stat. 785","children":[],"tail":", ch. 155);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e226-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–6/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorizes the regulation of private land in the Natural Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e227-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–6/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorizes the imposition of any mandatory streamflow requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e228-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460rrr–6/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creates an express or implied Fede