{"tag":"section","attrib":{"id":"id7778c0cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp"},"text":null,"children":[{"tag":"num","attrib":{"value":"410ppp"},"text":"§ 410ppp.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Blackstone River Valley National Historical Park","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7778c0cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of this section is to establish the Blackstone River Valley National Historical Park—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7778c0ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to help preserve, protect, and interpret the nationally significant resources that exemplify the industrial heritage of the Blackstone River Valley for the benefit and inspiration of future generations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7778c0cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the preservation, protection, and interpretation of the urban, rural, and agricultural landscape features (including the Blackstone River and Canal) of the region that provide an overarching context for the industrial heritage of the Blackstone River Valley;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7778c0d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to educate the public about—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7778c0d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nationally significant sites and districts that convey the industrial history of the Blackstone River Valley; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7778c0d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the significance of the Blackstone River Valley to the past and present of the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7778c0d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support and enhance the network of partners in the protection, improvement, management, and operation of related resources and facilities throughout the John H. Chafee Blackstone River Valley National Heritage Corridor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7778c0d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7778c0d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Heritage Corridor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National Heritage Corridor” means the John H. Chafee Blackstone River Valley National Heritage Corridor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7778c0d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Park","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Park” means the Blackstone River Valley National Historical Park established by subsection (c)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7778c0d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7778c0d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “States” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7778c0d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State of Massachusetts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7778c0da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State of Rhode Island.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7778c0db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Blackstone River Valley National Historical Park","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7778c0dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the States a unit of the National Park System, to be known as the “Blackstone River Valley National Historical Park”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7778c0dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Historic sites and districts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Park shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7778c0de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Blackstone River State Park; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7778c0df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the following resources, as described in Management Option 3 of the study entitled “Blackstone River Valley Special Resource Study—Study Report 2011”:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7778c0e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Old Slater Mill National Historic Landmark District.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7778c0e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Slatersville Historic District.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7778c0e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ashton Historic District.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7778c0e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whitinsville Historic District.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7778c0e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hopedale Village Historic District.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7778c0e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Blackstone River and the tributaries of Blackstone River.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7778c0e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Blackstone Canal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7778c0e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of land; park boundary","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7778c0e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land acquisition","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7778c0e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire land or interests in land that are considered contributing historic resources in the historic sites and districts described in paragraph (2)(B) for inclusion in the Park boundary by donation, purchase from a willing seller with donated or appropriated funds, or exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7778c0ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No condemnation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No land or interest in land may be acquired for the Park by condemnation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7778c0eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Park boundary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On a determination by the Secretary that a sufficient quantity of land or interests in land has been acquired to constitute a manageable park unit, the Secretary shall establish a boundary for the Park by publishing a boundary map in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7778c0ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may include in the Park boundary any resources that are the subject of an agreement with the States or a subdivision of the States entered into under paragraph (4)(D).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7778c0ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the acquisition of additional land or interests in land under subparagraph (A), or on entering an agreement under subparagraph (C), the boundary of the Park shall be adjusted to reflect the acquisition or agreement by publishing a Park boundary map in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7778c0ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The maps referred to in this paragraph shall be available for public inspection in the appropriate offices of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7778c0ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire not more than 10 acres in Woonsocket, Rhode Island ","children":[{"tag":"ref","attrib":{"idref":"fn002181"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002181"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" for the development of administrative, curatorial, maintenance, or visitor facilities for the Park."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7778c0f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Land owned by the States or a political subdivision of the States may be acquired under this paragraph only by donation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7778c0f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7778c0f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall administer land within the boundary of the Park in accordance with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7778c0f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7778c0f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the laws generally applicable to units of the National Park System, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7778c0f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/4/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Park Service Organic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"16 U.S.C. 1","children":[],"tail":" et seq.); "},{"tag":"ref","attrib":{"idref":"fn002182"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002182"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7778c0f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/4/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Act of ","children":[{"tag":"date","attrib":{"date":"1935-08-21"},"text":"August 21, 1935","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s461"},"text":"16 U.S.C. 461","children":[],"tail":" et seq.)."},{"tag":"sup","attrib":{},"text":"2","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7778c0f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General management plan","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7778c0f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after the date on which funds are made available to carry out this subsection, the Secretary shall prepare a general management plan for the Park—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7778c0f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/4/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the States and other interested parties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7778c0fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/4/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s100502"},"text":"section 100502 of title 54","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7778c0fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan shall consider ways to use preexisting or planned visitor facilities and recreational opportunities developed in the National Heritage Corridor, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7778c0fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/4/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Blackstone Valley Visitor Center, Pawtucket, Rhode Island;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7778c0fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/4/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Captain Wilbur Kelly House, Blackstone River State Park, Lincoln, Rhode Island;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7778c0fe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/4/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Museum of Work and Culture, Woonsocket, Rhode Island;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7778c0ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/4/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the River Bend Farm/Blackstone River and Canal Heritage State Park, Uxbridge, Massachusetts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7778c100-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/4/B/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Worcester Blackstone Visitor Center, located at the former Washburn & Moen wire mill facility, Worcester, Massachusetts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7778c101-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/4/B/ii/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Route 295 Visitor Center adjacent to Blackstone River State Park; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7778c102-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/4/B/ii/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Blackstone River Bikeway.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7778c103-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related sites","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide technical assistance, visitor services, interpretive tours, and educational programs to sites and resources in the National Heritage Corridor that are located outside the boundary of the Park and associated with the purposes for which the Park is established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7778c104-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7778c105-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To further the purposes of this subsection and notwithstanding chapter 63 of title 31, the Secretary may enter into cooperative agreements with the States, political subdivisions of the States, nonprofit organizations (including the local coordinating entity for the National Heritage Corridor), and other interested parties—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7778c106-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/4/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide technical assistance, interpretation, and educational programs in the historic sites and districts described in paragraph (2)(B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7778c107-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/4/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the availability of appropriations and clauses (ii) and (iii), to provide not more than 50 percent of the cost of any natural, historic, or cultural resource protection project in the Park that is consistent with the general management plan prepared under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7778c108-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of the receipt of funds under clause (i)(II), the Secretary shall require that any Federal funds made available under a cooperative agreement entered into under this paragraph are to be matched on a 1-to-1 basis by non-Federal funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7778c109-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/4/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any payment made by the Secretary under clause (i)(ii) ","children":[{"tag":"ref","attrib":{"idref":"fn002183"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002183"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be “(i)(II)”."}],"tail":" shall be subject to an agreement that the conversion, use, or disposal of the project for purposes that are inconsistent with the purposes of this subsection, as determined by the Secretary, shall result in a right of the United States to reimbursement of the greater of—"}],"tail":null},{"tag":"subclause","attrib":{"id":"id7778c10a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/4/D/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount provided by the Secretary to the project under clause (i)(II); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7778c10b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/4/D/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the increase in the value of the project that is attributable to the funds, as determined by the Secretary at the time of the conversion, use, or disposal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7778c10c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/4/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any cooperative agreement entered into under this subparagraph shall provide for reasonable public access to the resources covered by the cooperative agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7778c10d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dedication; memorial","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7778c10e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress dedicates the Park to John H. Chafee, the former United States Senator from Rhode Island, in recognition of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7778c10f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the role of John H. Chafee in the preservation of the resources of the Blackstone River Valley and the heritage corridor that bears the name of John H. Chafee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7778c110-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the decades of the service of John H. Chafee to the people of Rhode Island and the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7778c111-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ppp/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Memorial","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall display a memorial at an appropriate location in the Park that recognizes the role of John H. Chafee in preserving the resources of the Blackstone River Valley for the people of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7778c112-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dB/tXXX/s3031"},"text":"Pub. L. 113–291, div. B, title XXX, § 3031","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3767"},"text":"128 Stat. 3767","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7778c113-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7778c114-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7778c115-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Park Service Organic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"16 U.S.C. 1","children":[],"tail":" et seq.), referred to in subsec. (c)(4)(A)(ii)(I), is "},{"tag":"ref","attrib":{"href":"/us/act/1916-08-25/ch408"},"text":"act Aug. 25, 1916, ch. 408","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/535"},"text":"39 Stat. 535","children":[],"tail":", which enacted sections 1, 2, 3, and 4 of this title and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100101"},"text":"section 100101 of Title 54","children":[],"tail":", National Park Service and Related Programs. Sections 1 to 4 of the Act were repealed and restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1865/a"},"text":"section 1865(a) of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and section 100101(a), chapter 1003, and sections 100751(a), 100752, 100753, and 102101 of Title 54 by "},{"tag":"ref","attrib":{"href":"/us/pl/113/287"},"text":"Pub. L. 113–287","children":[],"tail":", §§ 3, 4(a)(1), 7, "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3094"},"text":"128 Stat. 3094","children":[],"tail":", 3260, 3272. For complete classification of this Act to the Code, see Tables. For disposition of former sections of this title, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100101"},"text":"section 100101 of Title 54","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Act of ","children":[{"tag":"date","attrib":{"date":"1935-08-21"},"text":"August 21, 1935","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s461"},"text":"16 U.S.C. 461","children":[],"tail":" et seq.), referred to in subsec. (c)(4)(A)(ii)(II), is "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-21/ch593"},"text":"act Aug. 21, 1935, ch. 593","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/666"},"text":"49 Stat. 666","children":[],"tail":", known as the Historic Sites Act of 1935 and also as the Historic Sites, Buildings, and Antiquities Act, which enacted sections 461 to 467 of this title. The Act was repealed and restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1866/a"},"text":"section 1866(a) of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and sections 102303 and 102304 and chapter 3201 of Title 54, National Park Service and Related Programs, by "},{"tag":"ref","attrib":{"href":"/us/pl/113/287"},"text":"Pub. L. 113–287","children":[],"tail":", §§ 3, 4(a)(1), 7, "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3094"},"text":"128 Stat. 3094","children":[],"tail":", 3260, 3272. For complete classification of this Act to the Code, see Tables. For disposition of former sections of this title, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100101"},"text":"section 100101 of Title 54","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7778c116-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (c)(4)(B)(i)(II), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s100502"},"text":"section 100502 of title 54","children":[],"tail":"” substituted for “section 12(b) of the National Park System General Authorities Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1a–7/b"},"text":"16 U.S.C. 1a–7(b)","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/113/287/s6/e"},"text":"Pub. L. 113–287, § 6(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3272"},"text":"128 Stat. 3272","children":[],"tail":", which Act enacted Title 54, National Park Service and Related Programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
