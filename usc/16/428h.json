{"tag":"section","attrib":{"id":"id778e44ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s428h"},"text":null,"children":[{"tag":"num","attrib":{"value":"428h"},"text":"§ 428h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ascertaining and marking line of battle","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be lawful for the authorities of any State having troops engaged in the Battle of Fort Donelson to enter upon the lands and approaches of the Fort Donelson National Battlefield for the purpose of ascertaining and marking the lines of battle of troops engaged therein: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That before any such lines are permanently designated, the position of the lines and the proposed methods of marking them by monuments, tablets, or otherwise shall be submitted to the Secretary of the Interior and shall first receive the written approval of the Secretary."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id778e44ef-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1928-03-26/ch248/s9"},"text":"Mar. 26, 1928, ch. 248, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/368"},"text":"45 Stat. 368","children":[],"tail":"; Ex. Ord. No. 6166, § 2, "},{"tag":"date","attrib":{"date":"1933-06-10"},"text":"June 10, 1933","children":[],"tail":"; Ex. Ord. No. 6228, § 1, "},{"tag":"date","attrib":{"date":"1933-07-28"},"text":"July 28, 1933","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/738"},"text":"Pub. L. 86–738","children":[],"tail":", §§ 4, 5, "},{"tag":"date","attrib":{"date":"1960-09-08"},"text":"Sept. 8, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/876"},"text":"74 Stat. 876","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id778e44f0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id778e44f1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id778e44f2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Fort Donelson National Battlefield” substituted in text for “Fort Donelson National Military Park” in view of redesignation of Fort Donelson National Military Park as Fort Donelson National Battlefield by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/738"},"text":"Pub. L. 86–738","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s428n"},"text":"section 428n of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id778e44f3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id778e44f4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of administrative functions of park, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s428"},"text":"section 428 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
