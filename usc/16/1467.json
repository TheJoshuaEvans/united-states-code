{"tag":"section","attrib":{"id":"id7942abc0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467"},"text":null,"children":[{"tag":"num","attrib":{"value":"1467"},"text":"§ 1467.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of the Digital Coast","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7942abc1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7942abc2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program for the provision of an enabling platform that integrates geospatial data, decision-support tools, training, and best practices to address coastal management issues and needs. Under the program, the Secretary shall strive to enhance resilient communities, ecosystem values, and coastal economic growth and development by helping communities address their issues, needs, and challenges through cost-effective and participatory solutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942abc3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program established under paragraph (1) shall be known as the “Digital Coast” (in this section referred to as the “program”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7942abc4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program, the Secretary shall ensure that the program provides data integration, tool development, training, documentation, dissemination, and archive by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7942abc5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making data and resulting integrated products developed under this section readily accessible via the Digital Coast internet website of the National Oceanic and Atmospheric Administration, the GeoPlatform.gov and data.gov internet websites, and such other information distribution technologies as the Secretary considers appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942abc6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing decision-support tools that use and display resulting integrated data and provide training on use of such tools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942abc7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documenting such data to Federal Geographic Data Committee standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942abc8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" archiving all raw data acquired under this Act at the appropriate National Oceanic and Atmospheric Administration data center or such other Federal data center as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7942abc9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall coordinate the activities carried out under the program to optimize data collection, sharing, and integration, and to minimize duplication by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7942abca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consulting with coastal managers and decision makers concerning coastal issues, and sharing information and best practices, as the Secretary considers appropriate, with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7942abcb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coastal States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942abcc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local governments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942abcd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of academia, the private sector, and nongovernmental organizations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942abce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consulting with other Federal agencies, including interagency committees, on relevant Federal activities, including activities carried out under the Ocean and Coastal Mapping Integration Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3501"},"text":"33 U.S.C. 3501","children":[],"tail":" et seq.), the Coastal Zone Management Act of 1972 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1451"},"text":"16 U.S.C. 1451","children":[],"tail":" et seq.), the Integrated Coastal and Ocean Observation System Act of 2009 ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s3601"},"text":"33 U.S.C. 3601","children":[],"tail":" et seq.), and the Hydrographic Services Improvement Act of 1998 ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s892"},"text":"33 U.S.C. 892","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942abcf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" participating, pursuant to section 216 of the E-Government Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/347"},"text":"Public Law 107–347","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3501"},"text":"44 U.S.C. 3501","children":[],"tail":" note), in the establishment of such standards and common protocols as the Secretary considers necessary to assure the interoperability of remote sensing and other geospatial data with all users of such information within—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7942abd0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Oceanic and Atmospheric Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942abd1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942abd2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942abd3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the private sector;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942abd4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating with, seeking assistance and cooperation of, and providing liaison to the Federal Geographic Data Committee pursuant to Office of Management and Budget Circular A–16 and Executive Order 12906 of ","children":[{"tag":"date","attrib":{"date":"1994-04-11"},"text":"April 11, 1994","children":[],"tail":" (59 Fed. Reg. 17671), as amended by Executive Order 13286 of "},{"tag":"date","attrib":{"date":"2003-02-28"},"text":"February 28, 2003","children":[],"tail":" (68 Fed. Reg. 10619); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942abd5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and maintaining a best practices document that sets out the best practices used by the Secretary in carrying out the program and providing such document to the United States Geological Survey, the Corps of Engineers, and other relevant Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7942abd6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filling needs and gaps","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7942abd7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximize the use of remote sensing and other geospatial data collection activities conducted for other purposes and under other authorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942abd8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" focus on filling data needs and gaps for coastal management issues, including with respect to areas that, as of ","children":[{"tag":"date","attrib":{"date":"2020-12-18"},"text":"December 18, 2020","children":[],"tail":", were underserved by coastal data and the areas of the Arctic that are under the jurisdiction of the United States;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942abd9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" pursuant to the Ocean and Coastal Mapping Integration Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3501"},"text":"33 U.S.C. 3501","children":[],"tail":" et seq.), support continue improvement in existing efforts to coordinate the acquisition and integration of key data sets needed for coastal management and other purposes, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7942abda-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coastal elevation data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942abdb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land use and land cover data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942abdc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" socioeconomic and human use data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942abdd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" critical infrastructure data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942abde-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/d/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" structures data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942abdf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/d/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" living resources and habitat data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942abe0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/d/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cadastral data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942abe1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/d/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aerial imagery; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942abe2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrate the priority supporting data set forth under paragraph (3) with other available data for the benefit of the broadest measure of coastal resource management constituents and applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7942abe3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial agreements and contracts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7942abe4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program, the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7942abe5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may enter into financial agreements to carry out the program, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7942abe6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support to non-Federal entities that participate in implementing the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7942abe7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grants, cooperative agreements, interagency agreements, contracts, or any other agreement on a reimbursable or non-reimbursable basis, with other Federal, tribal, State, and local governmental and nongovernmental entities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942abe8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, to the maximum extent practicable, enter into such contracts with private sector entities for such products and services as the Secretary determines may be necessary to collect, process, and provide remote sensing and other geospatial data and products for purposes of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942abe9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7942abea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment and collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, to the extent provided in advance in appropriations Acts, assess and collect fees for the conduct of any training, workshop, or conference that advances the purposes of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942abeb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of a fee under this paragraph may not exceed the sum of costs incurred, or expected to be incurred, by the Secretary as a direct result of the conduct of the training, workshop, or conference, including for subsistence expenses incidental to the training, workshop, or conference, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7942abec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of fees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts collected by the Secretary in the form of fees under this paragraph shall be available to the extent and in such amounts as are provided in advance in appropriations Acts for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7942abed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/e/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs incurred for conducting an activity described in subparagraph (A); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7942abee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/e/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expenses described in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7942abef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survey and mapping","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Contracts entered into under paragraph (1)(B) shall be considered “surveying and mapping” services as such term is used in and as such contracts are awarded by the Secretary in accordance with the selection procedures in chapter 11 of title 40.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7942abf0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ocean economy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may establish publically available tools that track ocean and Great Lakes economy data for each coastal State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7942abf1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1467/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary $4,000,000 for each fiscal year 2021 through 2025 to carry out the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7942abf2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/223/s4"},"text":"Pub. L. 116–223, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1068"},"text":"134 Stat. 1068","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7942abf3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7942abf4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7942abf5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (b)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/223"},"text":"Pub. L. 116–223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1067"},"text":"134 Stat. 1067","children":[],"tail":", known as the Digital Coast Act. For complete classification of this Act to the Code, see Short Title of 2020 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1451"},"text":"section 1451 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Ocean and Coastal Mapping Integration Act, referred to in subsecs. (c)(2) and (d)(3), is subtitle B of title XII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11"},"text":"Pub. L. 111–11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1421"},"text":"123 Stat. 1421","children":[],"tail":", which is classified generally to chapter 48 (§ 3501 et seq.) of Title 33, Navigation and Navigable Waters. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s3501"},"text":"section 3501 of Title 33","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Coastal Zone Management Act of 1972, referred to in subsec. (c)(2), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/454"},"text":"Pub. L. 89–454","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/92/583"},"text":"Pub. L. 92–583","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1280"},"text":"86 Stat. 1280","children":[],"tail":", which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1451"},"text":"section 1451 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Integrated Coastal and Ocean Observation System Act of 2009, referred to in subsec. (c)(2), is subtitle C of title XII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11"},"text":"Pub. L. 111–11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1427"},"text":"123 Stat. 1427","children":[],"tail":", which is classified generally to chapter 49 (§ 3601 et seq.) of Title 33, Navigation and Navigable Waters. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s3601"},"text":"section 3601 of Title 33","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Hydrographic Services Improvement Act of 1998, referred to in subsec. (c)(2), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/384"},"text":"Pub. L. 105–384","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3454"},"text":"112 Stat. 3454","children":[],"tail":", which is classified principally to subchapter IV (§ 892 et seq.) of chapter 17 of Title 33, Navigation and Navigable Waters. For complete classification of this Act to the Code, see Short Title of 1998 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s851"},"text":"section 851 of Title 33","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Executive Order 12906, as amended by Executive Order 13286, referred to in subsec. (c)(4), is Ex. Ord. No. 12906, ","children":[{"tag":"date","attrib":{"date":"1994-04-11"},"text":"Apr. 11, 1994","children":[],"tail":", 59 F.R. 17671, as amended by Ex. Ord. No. 13286, § 25, "},{"tag":"date","attrib":{"date":"2003-02-28"},"text":"Feb. 28, 2003","children":[],"tail":", 68 F.R. 10624, which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1457"},"text":"section 1457 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7942abf6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Digital Coast Act, and not as part of the Coastal Zone Management Act of 1972 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7942abf7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7942abf8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/223/s2"},"text":"Pub. L. 116–223, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1067"},"text":"134 Stat. 1067","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/223/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress makes the following findings:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Digital Coast is a model approach for effective Federal partnerships with State and local government, nongovernmental organizations, and the private sector.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Access to current, accurate, uniform, and standards-based geospatial information, tools, and training to characterize the United States coastal region is critical for public safety and for the environment, infrastructure, and economy of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" More than half of all people of the United States (153,000,000) currently live on or near a coast and an additional 12,000,000 are expected in the next decade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coastal counties in the United States average 300 persons per square mile, compared with the national average of 98.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On a typical day, more than 1,540 permits for construction of single-family homes are issued in coastal counties, combined with other commercial, retail, and institutional construction to support this population.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Over half of the economic productivity of the United States is located within coastal regions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Highly accurate, high-resolution remote sensing and other geospatial data play an increasingly important role in decision making and management of the coastal zone and economy, including for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flood and coastal storm surge prediction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hazard risk and vulnerability assessment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emergency response and recovery planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community resilience to longer range coastal change;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local planning and permitting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"“(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" habitat and ecosystem health assessments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"“(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" landscape change detection.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id7942abf9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/223/s3"},"text":"Pub. L. 116–223, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1068"},"text":"134 Stat. 1068","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/223/s3"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this Act [see Short Title of 2020 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1451"},"text":"section 1451 of this title","children":[],"tail":"]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coastal region","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘coastal region’ means the area of United States waters extending inland from the shoreline to include coastal watersheds and seaward to the territorial sea.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coastal state","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘coastal State’ has the meaning given the term ‘coastal state’ in section 304 of the Coastal Zone Management Act of 1972 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1453"},"text":"16 U.S.C. 1453","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal geographic data committee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Federal Geographic Data Committee’ means the interagency committee that promotes the coordinated development, use, sharing, and dissemination of geospatial data on a national basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remote sensing and other geospatial","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘remote sensing and other geospatial’ means collecting, storing, retrieving, or disseminating graphical or digital data depicting natural or manmade physical features, phenomena, or boundaries of the Earth and any information related thereto, including surveys, maps, charts, satellite and airborne remote sensing data, images, LiDAR, and services performed by professionals such as surveyors, photogrammetrists, hydrographers, geodesists, cartographers, and other such services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Secretary’ means the Secretary of Commerce, acting through the Administrator of the National Oceanic and Atmospheric Administration.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
