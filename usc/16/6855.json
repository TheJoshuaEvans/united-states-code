{"tag":"section","attrib":{"id":"id7a1df102-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6855"},"text":null,"children":[{"tag":"num","attrib":{"value":"6855"},"text":"§ 6855.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation and coordination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1df103-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6855/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Third-party providers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries may enter into an agreement with a third party to carry out any provision of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1df104-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6855/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" US Geological Survey","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries shall work with the Director of the United States Geological Survey to collect, aggregate, digitize, standardize, or publish data on behalf of the Secretaries to meet the requirements of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1df105-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/114/s6"},"text":"Pub. L. 117–114, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-04-29"},"text":"Apr. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1177"},"text":"136 Stat. 1177","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/234/tIII/s354/3"},"text":"Pub. L. 118–234, title III, § 354(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2917"},"text":"138 Stat. 2917","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a1df106-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a1df107-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a1df108-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234"},"text":"Pub. L. 118–234","children":[],"tail":" substituted “shall” for “may” and “the Secretaries” for “the Secretary of the Interior”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
