{"tag":"section","attrib":{"id":"id79fef687-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5501"},"text":null,"children":[{"tag":"num","attrib":{"value":"5501"},"text":"§ 5501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79fef688-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to implement the Agreement to Promote Compliance with International Conservation and Management Measures by Fishing Vessels on the High Seas, adopted by the Conference of the Food and Agriculture Organization of the United Nations on ","children":[{"tag":"date","attrib":{"date":"1993-11-24"},"text":"November 24, 1993","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef689-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish a system of permitting, reporting, and regulation for vessels of the United States fishing on the high seas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79fef68a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/tI/s102"},"text":"Pub. L. 104–43, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/367"},"text":"109 Stat. 367","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79fef68b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79fef68c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79fef68d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, and was translated as reading “this title”, meaning title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43"},"text":"Pub. L. 104–43","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79fef68e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79fef68f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/tI/s111"},"text":"Pub. L. 104–43, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/376"},"text":"109 Stat. 376","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/43/tI/s111"},"text":"“This title [enacting this chapter] shall take effect 120 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id79fef690-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/s1"},"text":"Pub. L. 104–43, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/366"},"text":"109 Stat. 366","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/43/s1"},"text":"“This Act [enacting this chapter, chapters 76 (§ 5601 et seq.) and 77 (§ 5701 et seq.) of this title, sections 971j, 971k, and 1826d to 1826g of this title, and sections 1980a and 1980b of Title 22, Foreign Relations and Intercourse, amending sections 971, 971b, 971c to 971e, 971h, 971i, 973g, 1383a, and 5002 of this title and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1977"},"text":"section 1977 of Title 22","children":[],"tail":", enacting provisions set out as notes under this section, sections 971, 971c, 1383a, 1801, 1821, 1823, 1826d, 5601, and 5701 of this title, and "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1980a"},"text":"section 1980a of Title 22","children":[],"tail":", and amending provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1823"},"text":"section 1823 of this title","children":[],"tail":"] may be cited as the ‘Fisheries Act of 1995’.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/tI/s101"},"text":"Pub. L. 104–43, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/367"},"text":"109 Stat. 367","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/43/tI/s101"},"text":"“This title [enacting this chapter] may be cited as the ‘High Seas Fishing Compliance Act of 1995’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
