{"tag":"section","attrib":{"id":"id78fb1b23-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1249"},"text":null,"children":[{"tag":"num","attrib":{"value":"1249"},"text":"§ 1249.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78fb1b24-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1249/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appalachian and Pacific Crest National Scenic Trails","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78fb1b25-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1249/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are hereby authorized to be appropriated for the acquisition of lands or interests in lands not more than $5,000,000 for the Appalachian National Scenic Trail and not more than $500,000 for the Pacific Crest National Scenic Trail. From the appropriations authorized for fiscal year 1979 and succeeding fiscal years pursuant to chapter 2003 of title 54, not more than the following amounts may be expended for the acquisition of lands and interests in lands authorized to be acquired pursuant to the provisions of this chapter: for the Appalachian National Scenic Trail, not to exceed $30,000,000 for fiscal year 1979, $30,000,000 for fiscal year 1980, and $30,000,000 for fiscal year 1981, except that the difference between the foregoing amounts and the actual appropriations in any one fiscal year shall be available for appropriation in subsequent fiscal years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78fb1b26-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1249/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is the express intent of the Congress that the Secretary should substantially complete the land acquisition program necessary to insure the protection of the Appalachian Trail within three complete fiscal years following ","children":[{"tag":"date","attrib":{"date":"1978-03-21"},"text":"March 21, 1978","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78fb1b27-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1249/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land deemed to qualify for funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/42"},"text":"Public Law 95–42","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/91/211"},"text":"91 Stat. 211","children":[],"tail":"), the lands and interests therein acquired pursuant to this section shall be deemed to qualify for funding under the provisions of section 1, clause 2, of said Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78fb1b28-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1249/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78fb1b29-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1249/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this chapter, there are authorized to be appropriated such sums as are necessary to implement the provisions of this chapter relating to the trails designated by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1244/a"},"text":"section 1244(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78fb1b2a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1249/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Natchez Trace National Scenic Trail","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78fb1b2b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1249/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to the Natchez Trace National Scenic Trail (referred to in this paragraph as the “trail”) designated by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1244/a/12"},"text":"section 1244(a)(12) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{"id":"id78fb1b2c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1249/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $500,000 shall be appropriated for the acquisition of land or interests in land for the trail; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78fb1b2d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1249/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $2,000,000 shall be appropriated for the development of the trail.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78fb1b2e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1249/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation by volunteer trail groups","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The administering agency for the trail shall encourage volunteer trail groups to participate in the development of the trail.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78fb1b2f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/543/s10"},"text":"Pub. L. 90–543, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-02"},"text":"Oct. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/926"},"text":"82 Stat. 926","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/248/s1/5"},"text":"Pub. L. 95–248, § 1(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-03-21"},"text":"Mar. 21, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/160"},"text":"92 Stat. 160","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/625/tV/s551/23"},"text":"Pub. L. 95–625, title V, § 551(23)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3517"},"text":"92 Stat. 3517","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/199/tI/s101/b/4"},"text":"Pub. L. 96–199, title I, § 101(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-05"},"text":"Mar. 5, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/68"},"text":"94 Stat. 68","children":[],"tail":";