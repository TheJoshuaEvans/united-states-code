Stat. 211","children":[],"tail":"), referred to in subsec. (b), is "},{"tag":"ref","attrib":{"href":"/us/pl/95/42"},"text":"Pub. L. 95–42","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-06-10"},"text":"June 10, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/210"},"text":"91 Stat. 210","children":[],"tail":", which, to the extent classified to the Code, amended former sections 460"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–5, 460"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–7, and 460"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–9 of this title. Section 1, clause 2 of said Act amended former section 460"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–7 of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78fb1b33-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287"},"text":"Pub. L. 113–287","children":[],"tail":" substituted “chapter 2003 of title 54” for “the Land and Water Conservation Fund Act ("},{"tag":"ref","attrib":{"href":"/us/stat/78/897"},"text":"78 Stat. 897","children":[],"tail":"), as amended”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11"},"text":"Pub. L. 111–11","children":[],"tail":" added subsec. (c) and struck out former subsec. (c) which appropriated such sums as necessary to implement the provisions of this chapter relating to the trails designated by "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1244/a"},"text":"section 1244(a) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/352"},"text":"Pub. L. 108–352","children":[],"tail":" substituted “the Ice Age” for “The Ice Age”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/333"},"text":"Pub. L. 104–333","children":[],"tail":" struck out at end “Until the entire acquisition program is completed, he shall transmit in writing at the close of each fiscal year the following information to the Committee on Energy and Natural Resources of the Senate and to the Committee on Natural Resources of the House of Representatives:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the amount of land acquired during the fiscal year and the amount expended therefor;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the estimated amount of land remaining to be acquired; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) the amount of land planned for acquisition in the ensuing fiscal year and the estimated cost thereof.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/437"},"text":"Pub. L. 103–437","children":[],"tail":" in introductory provisions substituted “Natural Resources” for “Interior and Insular Affairs” after “Committee on”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/365"},"text":"Pub. L. 101–365","children":[],"tail":" amended first sentence generally. Prior to amendment, first sentence read as follows: “There is hereby authorized to be appropriated for fiscal year 1983 and subsequent fiscal years such sums as may be necessary to implement the provisions of this chapter relating to the trails designated by paragraphs (9), (10), (11), (12), (13), (15), and (16) of "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1244/a"},"text":"section 1244(a) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/192"},"text":"Pub. L. 100–192","children":[],"tail":" substituted “, (10), (11), (12), (13), (15), and (16)” for “through (13) and (15)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/35"},"text":"Pub. L. 100–35","children":[],"tail":" inserted “and (15)” after “(13)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/11/s209/1"},"text":"Pub. L. 98–11, § 209(1)","children":[],"tail":", (2), inserted “(a)(1)” before “There are hereby authorized to be appropriated” at beginning of undesignated opening paragraph, and substituted “for the” for “(a) The” before “Appalachian National Scenic Trail” at beginning of former subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/11/s209/3"},"text":"Pub. L. 98–11, § 209(3)","children":[],"tail":", (4), inserted “(2)” before sentence beginning “It is the express intent of the Congress” and substituted “protection of the Appalachian Trail” for “protection of the Trail”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/11/s209/5"},"text":"Pub. L. 98–11, § 209(5)","children":[],"tail":", designated existing provisions as par. (1), inserted provision that funds may be expended for the acquisition of lands or interests therein for the purpose of providing for one trail interpretation site, as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1246/c"},"text":"section 1246(c) of this title","children":[],"tail":", and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/370"},"text":"Pub. L. 96–370","children":[],"tail":" substituted “(7), (8), (9), and (10)” for “(7), and (8)” and inserted reference to the Ice Age National Scenic Trail."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/199"},"text":"Pub. L. 96–199","children":[],"tail":" inserted references to the North Country National Scenic Trail in two places, once by its full name and once by the designation as the trail “designated by” "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1244/a/8"},"text":"section 1244(a)(8) of this title","children":[],"tail":", substituted “appropriated prior to "},{"tag":"date","attrib":{"date":"1978-10-01"},"text":"October 1, 1978","children":[],"tail":"” for “appropriated prior to "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"October 1, 1979","children":[],"tail":"”, and substituted “no funds may be expended by Federal agencies for the acquisition of lands or interests in lands outside the exterior boundaries of existing Federal area” for “no funds may be expended for the acquisition of lands or interests in lands”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/248"},"text":"Pub. L. 95–248","children":[],"tail":" inserted provisions relating to determinations respecting appropriations authorized for fiscal year 1979 and succeeding fiscal years."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625"},"text":"Pub. L. 95–625","children":[],"tail":" struck out par. (1) designation, substituted “in subsequent fiscal years” for “in the subsequent fiscal year” and struck out par. (2) which provided for transmission of a report to Congressional committees by the Appalachian Trail Conference at the close of each fiscal year, until entire acquisition program was completed, covering conduct of negotiations for acquisition program and whether larger interests in land were being acquired than were necessary for the purposes of this chapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625"},"text":"Pub. L. 95–625","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78fb1b34-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78fb1b35-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of Appropriation Authorizations Under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/11"},"text":"Pub. L. 98–11","children":[],"tail":"; Contract Authority"}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/11/tI/s101"},"text":"Pub. L. 98–11, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-03-28"},"text":"Mar. 28, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/42"},"text":"97 Stat. 42","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/11/tI/s101"},"text":"“Authorizations of appropriations under this Act [enacting sections 1250 and 1251 of this title, amending this section and sections 1241 to 1247 of this title, and enacting provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1241"},"text":"section 1241 of this title","children":[],"tail":"] shall be effective only for the fiscal year beginning on "},{"tag":"date","attrib":{"date":"1983-10-01"},"text":"October 1, 1983","children":[],"tail":", and subsequent fiscal years. Notwithstanding any other provision of this Act, authority to enter into contracts, and to make payments, under this Act shall be effective only to such extent or in such amounts as are provided in advance in appropriation Acts.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78fb1b36-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Appropriations for Overmountain Victory National Historic Trail and Ice Age National Scenic Trail; Effective Date; Contract Authority","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/370/s2"},"text":"Pub. L. 96–370, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-03"},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1360"},"text":"94 Stat. 1360","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/370/s2"},"text":"“Authorizations of moneys to be appropriated under this Act [amending sections 1244 and 1249 of this title] shall be effective on ","children":[{"tag":"date","attrib":{"date":"1981-10-01"},"text":"October 1, 1981","children":[],"tail":". Notwithstanding any other provision of this Act, authority to enter into contracts, to incur obligations, or to make payments under this Act shall be effective only to the extent, and in such amounts, as are provided in advance in appropriation Acts.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
