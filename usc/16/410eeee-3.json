{"tag":"section","attrib":{"id":"id77825dc0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"410eeee–3"},"text":"§ 410eeee–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lands and areas plan; submission to Congressional committees","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Within two years from ","children":[{"tag":"date","attrib":{"date":"1978-11-10"},"text":"November 10, 1978","children":[],"tail":", the Secretary shall submit, in writing, to the House Committee on Interior and Insular Affairs, the Senate Committee on Energy and Natural Resources and the Committees on Appropriations of the United States Congress, a detailed plan which shall indicate—"}],"tail":null},{"tag":"clause","attrib":{"id":"id77825dc1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee–3/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lands and areas which he deems essential to the protection and public enjoyment of the natural, scenic, and historic values and objects of this national river;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77825dc2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee–3/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lands which he has previously acquired by purchase, donation, exchange, or transfer for the purpose of this national river;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77825dc3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee–3/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the annual acquisition program (including the level of funding) which he recommends for the ensuing four fiscal years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77825dc4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee–3/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the feasibility and suitability of including within the boundaries of the national river, the section of the New River from Fayetteville to Gauley Bridge, and reasons therefor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77825dc5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625/tXI/s1103"},"text":"Pub. L. 95–625, title XI, § 1103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3546"},"text":"92 Stat. 3546","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77825dc6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77825dc7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77825dc8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460m–17"},"text":"section 460m–17 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77825dc9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id77825dca-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Interior and Insular Affairs of the House of Representatives changed to Committee on Natural Resources of the House of Representatives on ","children":[{"tag":"date","attrib":{"date":"1993-01-05"},"text":"Jan. 5, 1993","children":[],"tail":", by House Resolution No. 5, One Hundred Third Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
