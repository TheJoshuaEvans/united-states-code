{"tag":"section","attrib":{"id":"id7996229f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2108"},"text":null,"children":[{"tag":"num","attrib":{"value":"2108"},"text":"§ 2108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidation of payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id799622a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request by State; excluded funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To provide flexibility in funding activities authorized under this chapter, the Secretary may, upon the request of any State, consolidate the annual financial assistance payments to that State under this chapter, in lieu of functional cost sharing mechanisms, formulas, or agreements. However, consolidated payments shall not include money appropriated under section 2103 ","children":[{"tag":"ref","attrib":{"idref":"fn002713"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002713"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title or money from any special Treasury fund established under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799622a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State forest resources programs as basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Consolidation of payments made under this section shall be based upon State forest resources programs developed by State foresters or equivalent State officials, and reviewed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799622a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2108/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Consolidated payments to any State during any fiscal year shall not exceed the total amount of non-Federal funds expended within the State during that year to implement its State forest resources program. However, the Secretary may make payments that exceed the non-Federal amount expended for selected activities under the program, if the total Federal expenditure during any fiscal year does not exceed the total non-Federal expenditure during that year under the State forest resources program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799622a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2108/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification requirement by State forester or equivalent State official for Federal payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make consolidated payments on the certificate of the State forester or equivalent State official that the conditions for Federal payment have been met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799622a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2108/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of consolidated payments program not to adversely affect, etc., other programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall administer this section to ensure that the use of consolidated payments does not adversely affect or eliminate any program authorized under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799622a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2108/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Total annual amount of financial assistance to participating State; financial assistance for special projects not to be included in determining base amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to applicable appropriation Acts, the total annual amount of financial assistance to any participating State after ","children":[{"tag":"date","attrib":{"date":"1978-07-01"},"text":"July 1, 1978","children":[],"tail":", shall not be less than the base amount of financial assistance provided to that State under all the provisions of law specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2111"},"text":"section 2111 of this title","children":[],"tail":" during the fiscal year in which this chapter is enacted. However, financial assistance for special projects of two years or less duration shall not be included in determining the base amount for any participating State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id799622a6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/313/s12"},"text":"Pub. L. 95–313, § 12","children":[],"tail":", formerly § 9, "},{"tag":"date","attrib":{"date":"1978-07-01"},"text":"July 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/372"},"text":"92 Stat. 372","children":[],"tail":"; renumbered § 12 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXII"},"text":"Pub. L. 101–624, title XII","children":[],"tail":", §§ 1215(1), 1224(2), "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3525"},"text":"104 Stat. 3525","children":[],"tail":", 3542.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id799622a7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id799622a8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id799622a9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2103"},"text":"Section 2103 of this title","children":[],"tail":", referred to in subsec. (a), was repealed and a new section 2103 enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVIII"},"text":"Pub. L. 107–171, title VIII","children":[],"tail":", §§ 8001(a), 8002(b), "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/468"},"text":"116 Stat. 468","children":[],"tail":". Section 2103, as enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":", was subsequently repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVIII/s8001/a"},"text":"Pub. L. 113–79, title VIII, § 8001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/913"},"text":"128 Stat. 913","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id799622aa-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/313/s12"},"text":"section 12 of Pub. L. 95–313","children":[],"tail":", which amended "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1606"},"text":"section 1606 of this title","children":[],"tail":" and enacted provisions set out as a note under that section, was renumbered section 15."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id799622ab-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1224/2"},"text":"Pub. L. 101–624, § 1224(2)","children":[],"tail":", made technical amendment to reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2111"},"text":"section 2111 of this title","children":[],"tail":" to reflect renumbering of corresponding section of original act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
