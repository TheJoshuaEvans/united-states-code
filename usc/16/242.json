{"tag":"section","attrib":{"id":"id771e1d84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s242"},"text":null,"children":[{"tag":"num","attrib":{"value":"242"},"text":"§ 242.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condemnation of land; acceptance of donations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to cause condemnation proceedings to be instituted in the name of the United States under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3113"},"text":"section 3113 of title 40","children":[],"tail":", to acquire title to the lands, interests therein, or rights pertaining thereto that are privately owned within the boundaries of the said national park, and such property, when acquired, shall become a part thereof: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That when the owner of such lands, interests therein, or rights pertaining thereto shall fix a price for the same, which, in the opinion of the Secretary of the Interior, shall be reasonable, the Secretary may purchase the same without further delay: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That the Secretary of the Interior is authorized to accept, on behalf of the United States, donations of land, interests therein, or rights pertaining thereto required for the Theodore Roosevelt National Park: "},{"tag":"i","attrib":{},"text":"And provided further","children":[],"tail":", That title and evidence of title to land and interests therein acquired for said park shall be satisfactory to the Attorney General."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id771e1d85-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-04-25/ch41/s2"},"text":"Apr. 25, 1947, ch. 41, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/53"},"text":"61 Stat. 53","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/625/tVI/s610"},"text":"Pub. L. 95–625, title VI, § 610","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3521"},"text":"92 Stat. 3521","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id771e1d86-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id771e1d87-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id771e1d88-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3113"},"text":"Section 3113 of title 40","children":[],"tail":"” substituted in text for “the Act of "},{"tag":"date","attrib":{"date":"1888-08-01"},"text":"August 1, 1888","children":[],"tail":", entitled ‘An Act to authorize the condemnation of lands for sites for public buildings, and other purposes’ ("},{"tag":"ref","attrib":{"href":"/us/stat/25/357"},"text":"25 Stat. 357","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s5/c"},"text":"Pub. L. 107–217, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1303"},"text":"116 Stat. 1303","children":[],"tail":", the first section of which enacted Title 40, Public Buildings, Property, and Works."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id771e1d89-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id771e1d8a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Theodore Roosevelt National Memorial Park redesignated Theodore Roosevelt National Park pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625/tVI/s610"},"text":"Pub. L. 95–625, title VI, § 610","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3521"},"text":"92 Stat. 3521","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s241g"},"text":"section 241g of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
