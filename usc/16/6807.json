{"tag":"section","attrib":{"id":"id7a1df065-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6807"},"text":null,"children":[{"tag":"num","attrib":{"value":"6807"},"text":"§ 6807.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1df066-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6807/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of fees at specific site or area","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts available for expenditure at a specific site or area—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1df067-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6807/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be accounted for separately from the amounts collected;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1df068-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6807/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be distributed agency-wide; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1df069-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6807/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be used only for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1df06a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6807/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repair, maintenance, and facility enhancement related directly to visitor enjoyment, visitor access, and health and safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df06b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6807/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interpretation, visitor information, visitor service, visitor needs assessments, and signs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df06c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6807/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" habitat restoration directly related to wildlife-dependent recreation that is limited to hunting, fishing, wildlife observation, or photography;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df06d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6807/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" law enforcement related to public use and recreation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df06e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6807/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct operating or capital costs associated with the recreation fee program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df06f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6807/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fee management agreement established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6805/a"},"text":"section 6805(a) of this title","children":[],"tail":" or a visitor reservation service;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df070-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6807/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the processing of special recreation permit applications and administration of special recreation permits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df071-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6807/a/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the improvement of the operation of the special recreation permit program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6802/h"},"text":"section 6802(h) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1df072-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6807/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not use any recreation fees for biological monitoring on Federal recreational lands and waters under the Endangered Species Act of 1973 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"16 U.S.C. 1531","children":[],"tail":" et seq.] for listed or candidate species."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1df073-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6807/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration, overhead, and indirect costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may use not more than an average of 15 percent of total revenues collected under this chapter for administration, overhead, and indirect costs related to the recreation fee program by that Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1df074-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6807/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transitional exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this chapter, the Secretary may use amounts available in the special account of a Federal land management agency to supplement administration and marketing costs associated with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1df075-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6807/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Parks and Federal Recreational Lands Pass during the 5-year period beginning on the date the joint guidelines are issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6804/a/7"},"text":"section 6804(a)(7) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1df076-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6807/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a regional multientity pass authorized ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6804/d"},"text":"section 6804(d) of this title","children":[],"tail":" during the 5-year period beginning on the date the regional multientity pass agreement for that recreation pass takes effect."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1df077-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dJ/tVIII/s808"},"text":"Pub. L. 108–447, div. J, title VIII, § 808","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3388"},"text":"118 Stat. 3388","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVII/s7116/h"},"text":"Pub. L. 111–11, title VII, § 7116(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1203"},"text":"123 Stat. 1203","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/234/tIII/s311/d"},"text":"Pub. L. 118–234, title III, § 311(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2897"},"text":"138 Stat. 2897","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a1df078-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a1df079-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a1df07a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Endangered Species Act of 1973, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/205"},"text":"Pub. L. 93–205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-28"},"text":"Dec. 28, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/884"},"text":"87 Stat. 884","children":[],"tail":", which is classified principally to chapter 35 (§ 1531 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"section 1531 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a1df07b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(3)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/s311/d/2/B"},"text":"Pub. L. 118–234, § 311(d)(2)(B)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6805/a"},"text":"section 6805(a) of this title","children":[],"tail":" and substituted semicolon for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(G), (H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/s311/d/2/A"},"text":"Pub. L. 118–234, § 311(d)(2)(A)","children":[],"tail":", (C), added subpars. (G) and (H)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/s311/d/1"},"text":"Pub. L. 118–234, § 311(d)(1)","children":[],"tail":", made technical amendment to references in original act which appear in text of subsec. (c) and in introductory provisions of subsec. (d) as references to this chapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/s311/d/3/A"},"text":"Pub. L. 118–234, § 311(d)(3)(A)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6804/a/7"},"text":"section 6804(a)(7) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/s311/d/3/B"},"text":"Pub. L. 118–234, § 311(d)(3)(B)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6804/d"},"text":"section 6804(d) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (a)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11"},"text":"Pub. L. 111–11","children":[],"tail":", which directed technical amendment in subsec. (a)(1)(F) to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6805/a"},"text":"section 6805(a) of this title","children":[],"tail":", could not be executed because there is no subsec. (a)(1)(F) of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
