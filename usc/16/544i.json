{"tag":"section","attrib":{"id":"id783ea8d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544i"},"text":null,"children":[{"tag":"num","attrib":{"value":"544i"},"text":"§ 544i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Economic development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id783ea8d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Economic development plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Based on the Economic Opportunity Study and other appropriate information, each State, in consultation with the counties and the Commission, shall develop a plan for economic development projects for which grants under this section may be used in a manner consistent with sections 544 to 544p of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id783ea8d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds provided to States for grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon certification of the management plan, and receipt of a plan referred to in subsection (a) of this section, the Secretary shall provide $5,000,000 to each State which each State shall use to make grants and loans for economic development projects that further the purposes of sections 544 to 544p of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id783ea8d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions of grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State making grants under this section shall require as a condition of a grant that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id783ea8d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544i/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all activities undertaken under the grant are certified by the Commission as being consistent with the purposes of sections 544 to 544p of this title, the management plan, and land use ordinances adopted pursuant to sections 544 to 544p of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id783ea8d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544i/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grants and loans are not used to relocate a business from one community to another;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id783ea8d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544i/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grants and loans are not used for program administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id783ea8d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544i/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grants and loans are used only in counties which have in effect land use ordinances found consistent by the Commission and concurred on by the Secretary pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s544f"},"text":"section 544f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id783ea8da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544i/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id783ea8db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544i/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and provide the Secretary with an annual report to the Secretary on the use of the funds made available under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id783ea8dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544i/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available to the Secretary and to the Commission, upon request, all accounts, financial records, and other information related to grants and loans made available pursuant to this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id783ea8dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s544i/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as loans are repaid, make additional grants and loans with the money made available for obligation by such repayments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id783ea8de-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/663/s11"},"text":"Pub. L. 99–663, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4292"},"text":"100 Stat. 4292","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
