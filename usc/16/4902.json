{"tag":"section","attrib":{"id":"id79f7cb5a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4902"},"text":null,"children":[{"tag":"num","attrib":{"value":"4902"},"text":"§ 4902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this chapter is to promote the conservation of exotic birds by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f7cb5b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4902/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting wild bird conservation and management programs in the countries of origin of wild birds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cb5c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4902/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that all trade in species of exotic birds involving the United States is biologically sustainable and is not detrimental to the species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cb5d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4902/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" limiting or prohibiting imports of exotic birds when necessary to ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f7cb5e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4902/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wild exotic bird populations are not harmed by removal of exotic birds from the wild for the trade; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f7cb5f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4902/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exotic birds in trade are not subject to inhumane treatment; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cb60-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4902/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging and supporting effective implementation of the Convention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f7cb61-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/440/tI/s103"},"text":"Pub. L. 102–440, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2225"},"text":"106 Stat. 2225","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
