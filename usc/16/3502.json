{"tag":"section","attrib":{"id":"id79b9d862-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3502"},"text":null,"children":[{"tag":"num","attrib":{"value":"3502"},"text":"§ 3502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79b9d863-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b9d864-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coastal barrier","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “coastal barrier” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b9d865-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3502/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a depositional geologic feature (such as a bay barrier, tombolo, barrier spit, bluff, or barrier island) that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79b9d866-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3502/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is subject to wave, tidal, and wind energies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b9d867-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3502/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protects landward aquatic habitats from direct wave attack; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b9d868-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3502/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all associated aquatic habitats including the adjacent wetlands, marshes, estuaries, inlets, and nearshore waters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d869-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Committees” means the Committee on Natural Resources of the House of Representatives and the Committee on Environment and Public Works of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d86a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3502/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b9d86b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3502/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “financial assistance” means any form of loan, grant, guaranty, insurance, payment, rebate, subsidy, or any other form of direct or indirect Federal assistance other than—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79b9d86c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3502/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deposit or account insurance for customers of banks, savings and loan associations, credit unions, or similar institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b9d86d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3502/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase of mortgages or loans by the Government National Mortgage Association, the Federal National Mortgage Association, or the Federal Home Loan Mortgage Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b9d86e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3502/a/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance for environmental studies, planning, and assessments that are required incident to the issuance of permits or other authorizations under Federal law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b9d86f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3502/a/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance pursuant to programs entirely unrelated to development, such as any Federal or federally assisted public assistance program or any Federal old-age survivors or disability insurance program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b9d870-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3502/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flood insurance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “financial assistance” includes flood insurance described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4028"},"text":"section 4028 of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d871-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3502/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Great Lakes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Great Lakes” means Lake Ontario, Lake Erie, Lake Huron, Lake St. Clair, Lake Michigan, and Lake Superior, to the extent that those lakes are subject to the jurisdiction of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b9d872-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3502/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Otherwise Protected Area","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b9d873-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3502/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Otherwise Protected Area” means any unit of the System that, at the time of designation, was predominantly composed of areas established under Federal, State, or local law, or held by a qualified organization, primarily for wildlife refuge, wildlife sanctuary, recreational, or natural resource conservation purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79bc4874-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3502/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), the term “qualified organization” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s170/h/3"},"text":"section 170(h)(3) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bc4875-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3502/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bc4876-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3502/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" System","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “System” means the John H. Chafee Coastal Barrier Resources System established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3503/a"},"text":"section 3503(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bc4877-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3502/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" System unit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “System unit” means any undeveloped coastal barrier, or combination of closely-related undeveloped coastal barriers, included within the John H. Chafee Coastal Barrier Resources System established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3503/a"},"text":"section 3503(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bc4878-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3502/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Undeveloped coastal barrier","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “undeveloped coastal barrier” means a coastal barrier the features and associated habitats of which contain few manmade structures and these structures, and man’s activities on such features and within such habitats, do not significantly impede geomorphic and ecological processes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79bc4879-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings clause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section supersedes the official maps described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3503/a"},"text":"section 3503(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79bc487a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/348/s3"},"text":"Pub. L. 97–348, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-18"},"text":"Oct. 18, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1653"},"text":"96 Stat. 1653","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXIV/s14001/b/5"},"text":"Pub. L. 99–272, title XIV, § 14001(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/329"},"text":"100 Stat. 329","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/tII/s204/c/2"},"text":"Pub. L. 100–707, title II, § 204(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4714"},"text":"102 Stat. 4714","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/591/s2/a"},"text":"Pub. L. 101–591, § 2(a)","children":[],"tail":", (b)(1), (c), "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2931"},"text":"104 Stat. 2931","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/167/s3/c/2"},"text":"Pub. L. 106–167, § 3(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1804"},"text":"113 Stat. 1804","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/514/s4/a/1"},"text":"Pub. L. 106–514, § 4(a)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2396"},"text":"114 Stat. 2396","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/117/tI/s101"},"text":"Pub. L. 118–117, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-11-25"},"text":"Nov. 25, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1608"},"text":"138 Stat. 1608","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79bc487b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79bc487c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79bc487d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/117"},"text":"Pub. L. 118–117","children":[],"tail":" amended section generally. Prior to amendment, section defined terms for this chapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/514/s4/a/1"},"text":"Pub. L. 106–514, § 4(a)(1)","children":[],"tail":", substituted “means the Committee on Resources” for “refers to the Committee on Merchant Marine and Fisheries”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/514/s4/a/2"},"text":"Pub. L. 106–514, § 4(a)(2)","children":[],"tail":", substituted “Such” for “Effective "},{"tag":"date","attrib":{"date":"1983-10-01"},"text":"October 1, 1983","children":[],"tail":", such” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Pars. (6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/167"},"text":"Pub. L. 106–167","children":[],"tail":" substituted “John H. Chafee Coastal Barrier Resources System” for “Coastal Barrier Resources System”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/591/s2/c"},"text":"Pub. L. 101–591, § 2(c)","children":[],"tail":", in concluding provisions, struck out cl. (i) designation, inserted a period after “processes”, and struck out at end “, and (ii) are not included within the boundaries of an area established under Federal, State, or local law, or held by a qualified organization as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s170/h/3"},"text":"section 170(h)(3) of title 26","children":[],"tail":", primarily for wildlife refuge, sanctuary, recreational, or natural resource conservation purposes.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/591/s2/a"},"text":"Pub. L. 101–591, § 2(a)","children":[],"tail":", redesignated cls. (ii) and (iii) as (i) and (ii), respectively, and struck out former cl. (i) which read as follows: “consists of unconsolidated sedimentary materials,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/591/s2/b/1"},"text":"Pub. L. 101–591, § 2(b)(1)","children":[],"tail":", amended par. (6) generally. Prior to amendment, par. (6) read as follows: “The term ‘system maps’ means—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the maps that are entitled ‘Coastal Barrier Resources System’, numbered A01 through T12 (but excluding maps T02 and T03) and dated ","children":[{"tag":"date","attrib":{"date":"1982-09-30"},"text":"September 30, 1982","children":[],"tail":", and the maps numbered T02A and T03A and dated "},{"tag":"date","attrib":{"date":"1982-12-08"},"text":"December 8, 1982","children":[],"tail":"; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the maps prepared under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3503/b"},"text":"section 3503(b) of this title","children":[],"tail":" and any modification to those maps under that section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Pars. (4) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/707"},"text":"Pub. L. 100–707","children":[],"tail":" added pars. (4) and (6) and redesignated former pars. (4) and (5) as (5) and (7), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”, which for purposes of codification was translated as “title 26” thus requiring no change in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272"},"text":"Pub. L. 99–272","children":[],"tail":" struck out subpar. (A) relating to general revenue-sharing grants made under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s6702"},"text":"section 6702 of title 31","children":[],"tail":", and redesignated subpars. (B) to (E) as (A) to (D), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79bc487e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id79bc487f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Resources of House of Representatives changed to Committee on Natural Resources of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79bc4880-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272"},"text":"Pub. L. 99–272","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/s14001/e"},"text":"section 14001(e) of Pub. L. 99–272","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
