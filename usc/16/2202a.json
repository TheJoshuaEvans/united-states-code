{"tag":"section","attrib":{"id":"id799623ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2202a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2202a"},"text":"§ 2202a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-share requirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id799623ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2202a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-share rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsections (b) and (c), the maximum cost-share payment under sections 2201 and 2202 of this title shall not exceed 75 percent of the total allowable cost, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79986c9e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2202a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (a), a payment to a limited resource farmer or rancher, a socially disadvantaged farmer or rancher (as defined in subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2279"},"text":"section 2279 of title 7","children":[],"tail":"), or a beginning farmer or rancher under section 2201 or 2202 of this title shall not exceed 90 percent of the total allowable cost, as determined by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79986c9f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2202a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total payment under sections 2201 and 2202 of this title for a single event may not exceed 50 percent of the agriculture value of the land, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79986ca0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/334/tIV/s402A"},"text":"Pub. L. 95–334, title IV, § 402A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII/s2403/b"},"text":"Pub. L. 115–334, title II, § 2403(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4571"},"text":"132 Stat. 4571","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
