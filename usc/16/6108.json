{"tag":"section","attrib":{"id":"id7a03b255-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6108"},"text":null,"children":[{"tag":"num","attrib":{"value":"6108"},"text":"§ 6108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Neotropical Migratory Bird Conservation Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a03b256-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury a separate account, which shall be known as the “Neotropical Migratory Bird Conservation Fund”. The Fund shall consist of amounts deposited into the Fund by the Secretary of the Treasury under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a03b257-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits into the Fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury shall deposit into the Fund—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a03b258-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6108/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all amounts received by the Secretary in the form of donations under subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a03b259-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6108/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other amounts appropriated to the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a03b25a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6108/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a03b25b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6108/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Secretary may use amounts in the Account,","children":[{"tag":"ref","attrib":{"idref":"fn002820"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002820"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Fund”."}],"tail":" without further Act of appropriation, to carry out this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a03b25c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6108/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of amounts in the Account ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" available for each fiscal year, the Secretary may expend not more than 3 percent or up to $100,000, whichever is greater, to pay the administrative expenses necessary to carry out this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a03b25d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6108/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance and use of donations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may accept and use donations to carry out this chapter. Amounts received by the Secretary in the form of donations shall be transferred to the Secretary of the Treasury for deposit into the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a03b25e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/247/s9"},"text":"Pub. L. 106–247, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-07-20"},"text":"July 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/596"},"text":"114 Stat. 596","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/363/tIII/s302/h/1"},"text":"Pub. L. 109–363, title III, § 302(h)(1)","children":[],"tail":", (2), (3)(B), "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2076"},"text":"120 Stat. 2076","children":[],"tail":", 2077.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a03b25f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a03b260-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a03b261-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/363/s302/h/1"},"text":"Pub. L. 109–363, § 302(h)(1)","children":[],"tail":", substituted “Neotropical Migratory Bird Conservation Fund” for “Neotropical Migratory Bird Conservation Account” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/363/s302/h/1"},"text":"Pub. L. 109–363, § 302(h)(1)","children":[],"tail":", added subsecs. (a) and (b) and struck out former subsecs. (a) and (b) which related to the establishment of and deposits into the Neotropical Migratory Bird Conservation Account."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/363/s302/h/2"},"text":"Pub. L. 109–363, § 302(h)(2)","children":[],"tail":", substituted “$100,000” for “$80,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/363/s302/h/3/B"},"text":"Pub. L. 109–363, § 302(h)(3)(B)","children":[],"tail":", substituted “Fund” for “Account”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a03b262-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a03b263-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transfer of Funds","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/363/tIII/s302/h/4"},"text":"Pub. L. 109–363, title III, § 302(h)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2077"},"text":"120 Stat. 2077","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/363/tIII/s302/h/4"},"text":"“The Secretary of the Treasury may transfer to the Neotropical Migratory Bird Conservation Fund amounts that were in the Neotropical Migratory Bird Conservation Account immediately before the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
