{"tag":"section","attrib":{"id":"id77898a76-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423l–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"423l–3"},"text":"§ 423l–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Richmond National Battlefield Park; boundaries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77898a77-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423l–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of protecting, managing, and interpreting the resources associated with the Civil War battles in and around the City of Richmond, Virginia, there is established the Richmond National Battlefield Park consisting of approximately 7,307 acres of land, as generally depicted on the map entitled “Richmond National Battlefield Park Boundary Revision”, numbered 367N.E.F.A.80026A, and dated September 2000. The map shall be on file in the appropriate offices of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77898a78-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423l–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary adjustments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make minor adjustments in the boundaries of the battlefield park consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s100506/c"},"text":"section 100506(c) of title 54","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77898a79-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/511/tV/s503"},"text":"Pub. L. 106–511, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2374"},"text":"114 Stat. 2374","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77898a7a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77898a7b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77898a7c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s100506/c"},"text":"section 100506(c) of title 54","children":[],"tail":"” substituted for “section 7(c) of the Land and Water Conservation Fund Act of 1965 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460"},"text":"16 U.S.C. 460","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–9(c))” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/113/287/s6/e"},"text":"Pub. L. 113–287, § 6(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3272"},"text":"128 Stat. 3272","children":[],"tail":", which Act enacted Title 54, National Park Service and Related Programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
