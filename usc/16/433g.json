{"tag":"section","attrib":{"id":"id779a2bf7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s433g"},"text":null,"children":[{"tag":"num","attrib":{"value":"433g"},"text":"§ 433g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fort Frederica National Monument; establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When title to the site of Fort Frederica, on Saint Simon Island, Georgia, and such other related sites located thereon, as may be designated by the Secretary of the Interior, in the exercise of his discretion, as necessary or desirable for national-monument purposes, shall have been vested in the United States, said area not to exceed 305 acres shall be, and is, set apart as a national monument for the benefit and inspiration of the people, and shall be called the “Fort Frederica National Monument.”","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id779a2bf8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-26/ch451/s1"},"text":"May 26, 1936, ch. 451, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1373"},"text":"49 Stat. 1373","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1950-09-20/ch957/s1"},"text":"Sept. 20, 1950, ch. 957, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/869"},"text":"64 Stat. 869","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/401/s1"},"text":"Pub. L. 85–401, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-05-16"},"text":"May 16, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/110"},"text":"72 Stat. 110","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tII/s2104/a"},"text":"Pub. L. 116–9, title II, § 2104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/726"},"text":"133 Stat. 726","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id779a2bf9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id779a2bfa-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id779a2bfb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9"},"text":"Pub. L. 116–9","children":[],"tail":" substituted “305 acres” for “two hundred and fifty acres”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/401"},"text":"Pub. L. 85–401","children":[],"tail":" increased maximum acreage from one hundred acres to two hundred and fifty acres."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1950—Act ","children":[{"tag":"date","attrib":{"date":"1950-09-20"},"text":"Sept. 20, 1950","children":[],"tail":", increased maximum acreage from eighty to one hundred acres."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id779a2bfc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id779a2bfd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-20/ch957/s2"},"text":"Act Sept. 20, 1950, ch. 957, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/869"},"text":"64 Stat. 869","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1950-09-20/ch957/s2"},"text":"“There is hereby authorized to be appropriated not to exceed $5,000 for the acquisition of land and interests in land for the said national monument. The Secretary of the Interior is authorized to use any funds so appropriated, together with any donated funds made available pursuant to the aforesaid Act of ","children":[{"tag":"date","attrib":{"date":"1936-05-26"},"text":"May 26, 1936","children":[],"tail":" [sections 433g, 433h, 433i, and 433j of this title], for this procurement of land and interests in land for the national monument.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id779a2bfe-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Boundary Expansion, 2019","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tII/s2104/b"},"text":"Pub. L. 116–9, title II, § 2104(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/726"},"text":"133 Stat. 726","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/9/tII/s2104/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The boundary of the Fort Frederica National Monument in the State of Georgia is modified to include the land generally depicted as ‘Proposed Acquisition Areas’ on the map entitled ‘Fort Frederica National Monument Proposed Boundary Expansion’, numbered 369/132,469, and dated April 2016.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of map","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The map described in paragraph (1) shall be on file and available for public inspection in the appropriate offices of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisition of land","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary [of the Interior] may acquire the land and interests in land described in paragraph (1) by donation or purchase with donated or appropriated funds from willing sellers only.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No use of condemnation or eminent domain","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not acquire by condemnation or eminent domain any land or interests in land under this section or for the purposes of this section.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id779a2bff-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Land Exchange and Boundary Adjustment, 2004","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/417"},"text":"Pub. L. 108–417","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-11-30"},"text":"Nov. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2339"},"text":"118 Stat. 2339","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/417"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“SECTION 1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" EXCHANGE OF LANDS.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/401/s5/b"},"text":"section 5(b) of Public Law 90–401","children":[],"tail":" ([former] "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460"},"text":"16 U.S.C. 460","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–22(b)) [see "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s102901/b"},"text":"54 U.S.C. 102901(b)","children":[],"tail":"], the Secretary of the Interior is authorized to convey to Christ Church of St. Simons Island, Georgia, the approximately 6.0 acres of land within the boundary of Fort Frederica National Monument adjacent to Christ Church and depicted as ‘NPS Lands for Exchange’ on the map entitled ‘Fort Frederica National Monument 2003 Boundary Revision’ numbered 369/80016, and dated April 2003, in exchange for approximately 8.7 acres of land to be acquired by Christ Church, which is depicted as ‘Private Lands for Addition’ on the same map."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Map Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The map referred to in subsection (a) shall be on file and available for public inspection in the appropriate offices of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“SEC. 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" BOUNDARY ADJUSTMENT.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“Upon completion of the land exchange under subsection (a) of section 1, the Secretary of the Interior shall revise the boundary of Fort Frederica National Monument to reflect the exchange and shall administer the land acquired through the exchange as part of that monument.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
