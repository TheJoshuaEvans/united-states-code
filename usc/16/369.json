{"tag":"section","attrib":{"id":"id772ee6d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s369"},"text":null,"children":[{"tag":"num","attrib":{"value":"369"},"text":"§ 369.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charges assessable against bath attendants and masseurs and physicians prescribing use of hot waters","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to assess and collect from physicians who desire to prescribe the hot waters from the Hot Springs National Park reasonable fees for examination and registration; and he is also authorized to assess and collect from bath attendants and masseurs operating in bathhouses receiving hot water from the park reasonable annual charges to cover the cost of physical examinations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id772ee6d3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-05/ch235/s1"},"text":"June 5, 1920, ch. 235, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/918"},"text":"41 Stat. 918","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1921-03-04/ch161/s1"},"text":"Mar. 4, 1921, ch. 161, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/1407"},"text":"41 Stat. 1407","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1931-03-02/ch365"},"text":"Mar. 2, 1931, ch. 365","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/1462"},"text":"46 Stat. 1462","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id772ee6d4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id772ee6d5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id772ee6d6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"As originally enacted, this section authorized reasonable charges against physicians, including fees for examination and registration. It also authorized collection of reasonable charges from bath attendants and masseurs, and provided that the moneys received should be used in the protection and improvement of the park.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id772ee6d7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1931—Act ","children":[{"tag":"date","attrib":{"date":"1931-03-02"},"text":"Mar. 2, 1931","children":[],"tail":", struck out provision that moneys received from the assessment and collection of fees were to be used for the protection and improvement of the park."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id772ee6d8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id772ee6d9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Hot Springs National Park” substituted in text for “Hot Springs Reservation” pursuant to act ","children":[{"tag":"date","attrib":{"date":"1921-03-04"},"text":"Mar. 4, 1921","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
