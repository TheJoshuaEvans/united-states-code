8/234/s311/a/8"},"text":"Pub. L. 118–234, § 311(a)(8)","children":[],"tail":", redesignated par. (1) as (15)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (16). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/s311/a/11"},"text":"Pub. L. 118–234, § 311(a)(11)","children":[],"tail":", added par. (16)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a19363a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id7a19363b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/205/s1"},"text":"Pub. L. 116–205, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-03"},"text":"Dec. 3, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/996"},"text":"134 Stat. 996","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/205/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6804"},"text":"section 6804 of this title","children":[],"tail":"] may be cited as the ‘Wounded Veterans Recreation Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a19363c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dJ/tVIII/s801/a"},"text":"Pub. L. 108–447, div. J, title VIII, § 801(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3377"},"text":"118 Stat. 3377","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/447/dJ/tVIII/s801/a"},"text":"“This title [enacting this chapter, amending section 460","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–6a of this title, repealing sections 3911, 5982, and 5991 to 5995 of this title, and repealing provisions set out as a note under 460"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–6a of this title] may be cited as the ‘Federal Lands Recreation Enhancement Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id7a19363d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"id7a19363e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Ex. Ord. No. 14314. Making America Beautiful Again by Improving Our National Parks","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 14314, ","children":[{"tag":"date","attrib":{"date":"2025-07-03"},"text":"July 3, 2025","children":[],"tail":", 90 F.R. 30201, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States of America, it is hereby ordered:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Section","children":[],"tail":" 1. "},{"tag":"i","attrib":{},"text":"Policy","children":[],"tail":". From the awe-inspiring Grand Canyon to the tranquility of the Great Smoky Mountains, America’s national parks have provided generations of American families with unforgettable memories. It is the policy of my Administration to preserve these opportunities for American families in future generations by increasing entry fees for foreign tourists, improving affordability for United States residents, and expanding opportunities to enjoy America’s splendid national treasures."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec.","children":[],"tail":" 2. "},{"tag":"i","attrib":{},"text":"Making America Beautiful Again by Improving Our National Parks","children":[],"tail":". (a) The Secretary of the Interior shall develop a strategy to increase revenue and improve the recreational experience at national parks by appropriately increasing entrance fees and recreation pass fees for nonresidents in areas of the National Park System that charge entrance fees or recreation pass fees as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6801"},"text":"16 U.S.C. 6801","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/pl/108/447/s802"},"text":"section 802 of Pub. L. 108–447","children":[],"tail":"]. Additionally, to the extent consistent with applicable law, the Secretary of the Interior, working with the Secretary of Agriculture as appropriate, shall take steps to increase the prices at which the America the Beautiful Pass—the National Parks and Federal Recreational Lands Pass—and any site-specific agency or regional multi-entity passes are sold to nonresidents."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) The Secretary of the Interior shall use any increased fee revenue generated pursuant to subsection (a) of this section to improve the infrastructure of, or otherwise enhance enjoyment of or access to, America’s Federal recreational areas, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6807"},"text":"16 U.S.C. 6807","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/pl/108/447/s808"},"text":"section 808 of Pub. L. 108–447","children":[],"tail":"]."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(c) The Secretary of the Interior, working with the Secretary of Agriculture as appropriate, shall take steps to improve services and affordability for United States residents visiting national parks, as consistent with applicable law.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(d) The Secretary of the Interior, working with the Secretary of State, shall work to encourage international tourism to America’s national parks and outdoor recreation areas, and especially wider utilization of America’s many such areas that may be underutilized.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(e) The Secretary of the Interior shall review the maintenance backlog within the National Park Service and take all appropriate action to fully implement the National Parks and Public Land Legacy Restoration Fund established in the Great American Outdoors Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/152"},"text":"Public Law 116–152","children":[],"tail":") [see Tables for classification], invest in the infrastructure of national parks, and increase visitor capacity to allow more Americans to visit national parks."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(f) The Secretary of the Interior shall review all of the Department of the Interior’s rules and policies related to public use of national parks and take actions consistent with applicable law to ensure that the National Park Service manages national parks consistent with the policy of this order. The Secretary of the Interior shall review all of the Department’s recreational access rules and take steps to rescind any that unnecessarily restrict recreation in national parks. In conducting this review, the Secretary of the Interior shall especially scrutinize all recreational access rules or other restrictions promulgated or enacted during the prior administration. The Secretary of the Interior shall take appropriate actions to grant American residents preferential treatment with respect to any remaining recreational access rules, including permitting or lottery rules, consistent with applicable law.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec.","children":[],"tail":" 3. "},{"tag":"i","attrib":{},"text":"Revocation","children":[],"tail":". The Presidential Memorandum of "},{"tag":"date","attrib":{"date":"2017-01-12"},"text":"January 12, 2017","children":[],"tail":" (Promoting Diversity and Inclusion in Our National Parks, National Forests, and Other Public Lands and Waters) ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e"},"text":"42 U.S.C. 2000e","children":[],"tail":" note], is hereby revoked."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec.","children":[],"tail":" 4. "},{"tag":"i","attrib":{},"text":"General Provisions","children":[],"tail":". (a) Nothing in this order shall be construed to impair or otherwise affect:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(i) the authority granted by law to an executive department, agency, or the head thereof; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(ii) the functions of the Director of the Office of Management and Budget relating to budgetary, administrative, or legislative proposals.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) This order shall be implemented consistent with applicable law and subject to the availability of appropriations.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(c) This order is not intended to, and does not, create any right or benefit, substantive or procedural, enforceable at law or in equity by any party against the United States, its departments, agencies, or entities, its officers, employees, or agents, or any other person.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(d) The costs for publication of this order shall be borne by the Department of the Interior.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Donald J. Trump.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
