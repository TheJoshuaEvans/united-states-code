{"tag":"section","attrib":{"id":"id7a193607-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801"},"text":null,"children":[{"tag":"num","attrib":{"value":"6801"},"text":"§ 6801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a193608-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entrance fee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “entrance fee” means the recreation fee authorized to be charged to enter onto lands managed by the National Park Service or the United States Fish and Wildlife Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a193609-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expanded amenity recreation fee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “expanded amenity recreation fee” means the recreation fee authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6802/g"},"text":"section 6802(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a19360a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal land management agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal land management agency” means the National Park Service, the United States Fish and Wildlife Service, the Bureau of Land Management, the Bureau of Reclamation, or the Forest Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a19360b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal recreational lands and waters","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal recreational lands and waters” means lands or waters managed by a Federal land management agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a19360c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Parks and Federal Recreational Lands Pass","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National Parks and Federal Recreational Lands Pass” means the interagency national pass authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6804"},"text":"section 6804 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a19360d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Passholder","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “passholder” means the person who is issued a recreation pass.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a19360e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recreation fee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “recreation fee” means an entrance fee, standard amenity recreation fee, expanded amenity recreation fee, or special recreation permit fee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a19360f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recreation pass","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “recreation pass” means the National Parks and Federal Recreational Lands Pass or one of the other recreation passes available as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6804"},"text":"section 6804 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a193610-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recreation service provider","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “recreation service provider” means a person that provides recreational services to the public under a special recreation permit under clause (iii) or (iv) of paragraph (13)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a193611-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretaries” means the Secretary of the Interior and the Secretary of Agriculture acting jointly.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a193612-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Secretary” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a193613-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior, with respect to a Federal land management agency (other than the Forest Service); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a193614-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture, with respect to the Forest Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a193615-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “special account” means the special account established in the Treasury under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6806"},"text":"section 6806 of this title","children":[],"tail":" for a Federal land management agency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a193616-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special recreation permit","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a193617-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “special recreation permit” means a permit issued by a Federal land management agency for the use of Federal recreational lands and waters—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a193618-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/13/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for a specialized recreational use not described in clause (ii), (iii), or (iv), such as—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a193619-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/13/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organizational camp;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a19361a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/13/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a single event that does not require an entry or participation fee that is not strictly a sharing of expenses for the purposes of the event; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a19361b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/13/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participation by the public in a recreation activity or recreation use of a specific area of Federal recreational lands and waters in which use by the public is allocated;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a19361c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/13/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a large-group activity or event of 75 participants or more;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a19361d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/13/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a19361e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/13/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at the discretion of the Secretary, a single organized group recreation activity or event (including an activity or event in which motorized recreational vehicles are used or in which outfitting and guiding services are used) that—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id7a19361f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/13/A/iii/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a structured or scheduled event or activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a193620-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/13/A/iii/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not competitive and is for fewer than 75 participants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a193621-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/13/A/iii/I/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may charge an entry or participation fee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a193622-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/13/A/iii/I/dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"dd"},"text":"(dd)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involves fewer than 200 visitor-use days; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a193623-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/13/A/iii/I/ee"},"text":null,"children":[{"tag":"num","attrib":{"value":"ee"},"text":"(ee)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is undertaken or provided by the recreation service provider at the same site not more frequently than 3 times a year;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a193624-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/13/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a single competitive event; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a193625-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/13/A/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at the discretion of the Secretary, a recurring organized group recreation activity (including an outfitting and guiding activity) that—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id7a193626-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/13/A/iii/III/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a structured or scheduled activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a193627-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/13/A/iii/III/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not competitive;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a193628-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/13/A/iii/III/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may charge a participation fee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a193629-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/13/A/iii/III/dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"dd"},"text":"(dd)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" occurs in a group size of fewer than 7 participants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a19362a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/13/A/iii/III/ee"},"text":null,"children":[{"tag":"num","attrib":{"value":"ee"},"text":"(ee)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involves fewer than 40 visitor-use days; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a19362b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/13/A/iii/III/ff"},"text":null,"children":[{"tag":"num","attrib":{"value":"ff"},"text":"(ff)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is undertaken or provided by the recreation service provider for a term of not more than 180 days; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a19362c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/13/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a19362d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/13/A/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a recurring outfitting, guiding, or, at the discretion of the Secretary, other recreation service, the authorization for which is for a term of not more than 10 years; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a19362e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/13/A/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a recurring outfitting, guiding, or, at the discretion of the Secretary, other recreation service, that occurs under a temporary special recreation permit authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s8545"},"text":"section 8545 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a19362f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “special recreation permit” does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a193630-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/13/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a concession contract for the provision of accommodations, facilities, or services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a193631-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/13/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a commercial use authorization issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s101925"},"text":"section 101925 of title 54","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a193632-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/13/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other type of permit, including a special use permit administered by the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a193633-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special recreation permit fee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “special recreation permit fee” means the fee authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6802/h/2"},"text":"section 6802(h)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a193634-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard amenity recreation fee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “standard amenity recreation fee” means the recreation fee authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6802/f"},"text":"section 6802(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a193635-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6801/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the several States, the District of Columbia, and each territory of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a193636-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dJ/tVIII/s802"},"text":"Pub. L. 108–447, div. J, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3377"},"text":"118 Stat. 3377","children":[],"tail":"; "},{