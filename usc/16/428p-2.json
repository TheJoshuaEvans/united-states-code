{"tag":"section","attrib":{"id":"id778e4527-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s428p–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"428p–2"},"text":"§ 428p–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of Fort Donelson National Battlefield","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall administer the Fort Donelson National Battlefield in accordance with sections 428p to 428p–2 of this title and the laws generally applicable to units of the National Park System, including the Act of ","children":[{"tag":"date","attrib":{"date":"1916-08-25"},"text":"August 25, 1916","children":[],"tail":" (commonly known as the National Park Service Organic Act; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"16 U.S.C. 1","children":[],"tail":" et seq.),"},{"tag":"ref","attrib":{"idref":"fn002226"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002226"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and the Act of "},{"tag":"date","attrib":{"date":"1935-08-21"},"text":"August 21, 1935","children":[],"tail":" (commonly known as the Historic Sites, Buildings, and Antiquities Act; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s461"},"text":"16 U.S.C. 461","children":[],"tail":" et seq.)."},{"tag":"ref","attrib":{"idref":"fn002226"},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id778e4528-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/367/s4"},"text":"Pub. L. 108–367, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-25"},"text":"Oct. 25, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1744"},"text":"118 Stat. 1744","children":[],"ta