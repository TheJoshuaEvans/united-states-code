{"tag":"section","attrib":{"id":"id77c77cbc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460o–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"460o–7"},"text":"§ 460o–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated to the Secretary of the Interior for the acquisition of lands and interests in land pursuant to the provisions of section 460","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–1 of this title and for expenses incident thereto not more than $65,000,000 which moneys shall be transferred to the Secretary of the Army. There are also authorized to be appropriated not more than $18,200,000 for the cost of installing and constructing recreation facilities on the lands and interests in lands so acquired. The amounts herein authorized to be appropriated are supplemental to those authorized to be appropriated for the Tocks Island project and related facilities by the Flood Control Act of 1962 ("},{"tag":"ref","attrib":{"href":"/us/stat/76/1182"},"text":"76 Stat. 1182","children":[],"tail":")."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77c77cbd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/158/s8"},"text":"Pub. L. 89–158, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-09-01"},"text":"Sept. 1, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/614"},"text":"79 Stat. 614","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/575/s1"},"text":"Pub. L. 92–575, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1250"},"text":"86 Stat. 1250","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77c77cbe-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77c77cbf-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77c77cc0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The amounts authorized to be appropriated for the Tocks Island project and related facilities by the Flood Control Act of 1962, referred to in text, appear at ","children":[{"tag":"ref","attrib":{"href":"/us/stat/76/1182"},"text":"76 Stat. 1182","children":[],"tail":", and were not classified to the Code. The Flood Control Act of 1962 is Title II of "},{"tag":"ref","attrib":{"href":"/us/pl/87/874"},"text":"Pub. L. 87–874","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-23"},"text":"Oct. 23, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1173"},"text":"76 Stat. 1173","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77c77cc1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/575"},"text":"Pub. L. 92–575","children":[],"tail":" substituted “$65,000,000” for “$37,412,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
