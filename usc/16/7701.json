{"tag":"section","attrib":{"id":"id7a2c4879-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701"},"text":null,"children":[{"tag":"num","attrib":{"value":"7701"},"text":"§ 7701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2c487a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commission” means the North Pacific Fisheries Commission established in accordance with the North Pacific Fisheries Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2c487b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commissioner” means a United States Commissioner appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7702/a"},"text":"section 7702(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2c487c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Convention Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Convention Area” means the area to which the Convention on the Conservation and Management of High Seas Fisheries Resources in the North Pacific Ocean applies under Article 4 of such Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2c487d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Council” means the North Pacific Fishery Management Council, the Pacific Fishery Management Council, or the Western Pacific Fishery Management Council established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1852"},"text":"section 1852 of this title","children":[],"tail":", as the context requires."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2c487e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusive economic zone","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “exclusive economic zone” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2c487f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the United States, the zone established by Presidential Proclamation Numbered 5030 of ","children":[{"tag":"date","attrib":{"date":"1983-03-10"},"text":"March 10, 1983","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1453"},"text":"16 U.S.C. 1453","children":[],"tail":" note); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2c4880-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a foreign country, a designated zone similar to the zone referred to in subparagraph (A) for that country, consistent with international law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2c4881-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fisheries resources","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2c4882-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the term “fisheries resources” means all fish, mollusks, crustaceans, and other marine species caught by a fishing vessel within the Convention Area, as well as any products thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2c4883-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “fisheries resources” does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2c4884-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sedentary species insofar as they are subject to the sovereign rights of coastal nations consistent with Article 77, paragraph 4 of the 1982 Convention and indicator species of vulnerable marine ecosystems as listed in, or adopted pursuant to, Article 13, paragraph 5 of the North Pacific Fisheries Convention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2c4885-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" catadromous species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2c4886-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/6/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marine mammals, marine reptiles, or seabirds; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2c4887-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/6/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other marine species already covered by preexisting international fisheries management instruments within the area of competence of such instruments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2c4888-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fishing activities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2c4889-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “fishing activities” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2c488a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual or attempted searching for, catching, taking, or harvesting of fisheries resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2c488b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaging in any activity that can reasonably be expected to result in the locating, catching, taking, or harvesting of fisheries resources for any purpose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2c488c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/7/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the processing of fisheries resources at sea;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2c488d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/7/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transshipment of fisheries resources at sea or in port; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2c488e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/7/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any operation at sea in direct support of, or in preparation for, any activity described in clauses (i) through (iv), including transshipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2c488f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “fishing activities” does not include any operation related to an emergency involving the health or safety of a crew member or the safety of a fishing vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2c4890-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fishing vessel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “fishing vessel” means any vessel used or intended for use for the purpose of engaging in fishing activities, including a processing vessel, a support ship, a carrier vessel, or any other vessel directly engaged in such fishing activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2c4891-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High seas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “high seas” does not include an area that is within the exclusive economic zone of the United States or of any other country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2c4892-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" North Pacific Fisheries Convention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “North Pacific Fisheries Convention” means the Convention on the Conservation and Management of the High Seas Fisheries Resources in the North Pacific Ocean (including any annexes, amendments, or protocols that are in force, or have come into force) for the United States, which was adopted at Tokyo on ","children":[{"tag":"date","attrib":{"date":"2012-02-24"},"text":"February 24, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2c4893-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2c4894-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual, whether or not a citizen or national of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2c4895-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any corporation, partnership, association, or other entity, whether or not organized or existing under the laws of any State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2c4896-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/11/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Federal, State, local, tribal, or foreign government or any entity of such government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2c4897-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise specifically provided, the term “Secretary” means the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2c4898-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the several States of the United States, the District of Columbia, the Commonwealth of the Northern Mariana Islands, American Samoa, Guam, and any other commonwealth, territory, or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2c4899-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Straddling stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “straddling stock” means a stock of fisheries resources that migrates between, or occurs in, the economic exclusion zone of one or more parties to the Convention and the Convention Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2c489a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transshipment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “transshipment” means the unloading of any fisheries resources taken in the Convention Area from one fishing vessel to another fishing vessel either at sea or in port.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2c489b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7701/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 1982 convention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “1982 Convention” means the United Nations Convention on the Law of the Sea of 10 December 1982.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a2c489c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/327/tI/s101"},"text":"Pub. L. 114–327, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1974"},"text":"130 Stat. 1974","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a2c489d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a2c489e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a2c489f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/327/s1"},"text":"Pub. L. 114–327, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1974"},"text":"130 Stat. 1974","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/327/s1"},"text":"“This Act [enacting this chapter, chapter 97, and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6909a"},"text":"section 6909a of this title","children":[],"tail":", amending sections 1826g, 1826h, 1826j, 1826k, 5003, 5004, 5601 to 5604, 5606, 5607, 5609, 5610, 6902, and 6910 of this title, "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1541"},"text":"section 1541 of Title 15","children":[],"tail":", Commerce and Trade, and "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s3103"},"text":"section 3103 of Title 33","children":[],"tail":", Navigation and Navigable Waters, repealing "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s5612"},"text":"section 5612 of this title","children":[],"tail":", enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s5601"},"text":"section 5601 of this title","children":[],"tail":", and amending provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1823"},"text":"section 1823 of this title","children":[],"tail":"] may be cited as the ‘Ensuring Access to Pacific Fisheries Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
