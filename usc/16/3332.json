{"tag":"section","attrib":{"id":"id79b51d44-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3332"},"text":null,"children":[{"tag":"num","attrib":{"value":"3332"},"text":"§ 3332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State program for reduction of overall fishing capacity","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The State shall submit to the Secretary a program within three months of ","children":[{"tag":"date","attrib":{"date":"1980-12-22"},"text":"December 22, 1980","children":[],"tail":", designed to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b51d45-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3332/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide incentives for early retirement of licenses, or early sale of vessels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b51d46-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3332/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set aside specific allocations of funds for each gear type to achieve the specific fleet reductions provided for in the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b51d47-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3332/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain an effective and expeditious reduction in the overall fishing capacity of and the number of vessels and licenses in the non-Indian commercial and charter salmon fishing fleets in the Washington conservation area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b51d48-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3332/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide State funding for 25 per centum of the total cost of the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79b51d49-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/561/tI/s131"},"text":"Pub. L. 96–561, title I, § 131","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3284"},"text":"94 Stat. 3284","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
