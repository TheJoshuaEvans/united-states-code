{"tag":"section","attrib":{"id":"id7a33746b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8201"},"text":null,"children":[{"tag":"num","attrib":{"value":"8201"},"text":"§ 8201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this chapter is to encourage partnerships among public agencies and other interested persons to promote fish conservation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a33746c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8201/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to achieve measurable habitat conservation results through strategic actions of Fish Habitat Partnerships that lead to better fish habitat conditions and increased fishing opportunities by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a33746d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8201/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving ecological conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a33746e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8201/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restoring natural processes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a33746f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8201/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preventing the decline of intact and healthy systems;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a337470-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8201/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish a consensus set of national conservation strategies as a framework to guide future actions and investment by Fish Habitat Partnerships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a337471-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8201/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to broaden the community of support for fish habitat conservation by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a337472-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8201/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing fishing opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a337473-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8201/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fostering the participation of local communities, especially young people in local communities, in conservation activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a337474-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8201/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" raising public awareness of the role healthy fish habitat play in the quality of life and economic well-being of local communities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a337475-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8201/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to fill gaps in the National Fish Habitat Assessment and the associated database of the National Fish Habitat Assessment—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a337476-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8201/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to empower strategic conservation actions supported by broadly available scientific information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a337477-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8201/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to integrate socioeconomic data in the analysis to improve the lives of humans in a manner consistent with fish habitat conservation goals; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a337478-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8201/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to communicate to the public and conservation partners—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a337479-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8201/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conservation outcomes produced collectively by Fish Habitat Partnerships; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a33747a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8201/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new opportunities and voluntary approaches for conserving fish habitat.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a33747b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/188/tII/s201"},"text":"Pub. L. 116–188, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/924"},"text":"134 Stat. 924","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a33747c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a33747d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id7a33747e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2024 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/198/s1/a"},"text":"Pub. L. 118–198, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2678"},"text":"138 Stat. 2678","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/198/s1/a"},"text":"“This Act [amending sections 666c–1, 667h, 3709, 4406, 8203 to 8206, 8209, 8211, and 8212 of this title, sections 8355 and 8356 of Title 7, Agriculture, and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1267"},"text":"section 1267 of Title 33","children":[],"tail":", Navigation and Navigable Waters, and provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2601"},"text":"section 2601 of Title 15","children":[],"tail":", Commerce and Trade, "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1267"},"text":"section 1267 of Title 33","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s320101"},"text":"section 320101 of Title 54","children":[],"tail":", National Park Service and Related Programs] may be cited as the ‘America’s Conservation Enhancement Reauthorization Act of 2024’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a33747f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/188/s1/a"},"text":"Pub. L. 116–188, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/905"},"text":"134 Stat. 905","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/188/s1/a"},"text":"“This Act [enacting this chapter, sections 667h and 669","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title, and sections 8355 and 8356 of Title 7, Agriculture, amending sections 666c–1, 3702, 3703, 3709, 3710, 4403, and 4406 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1267"},"text":"section 1267 of Title 33","children":[],"tail":", Navigation and Navigable Waters, enacting provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2601"},"text":"section 2601 of Title 15","children":[],"tail":", Commerce and Trade, and "},{"tag":"ref","attrib":{"hr