{"tag":"section","attrib":{"id":"id77f7190d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"460hhh–2"},"text":"§ 460hhh–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77f7190e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to valid existing rights, there is established the Spring Mountains National Recreation Area in Nevada.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f7190f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundaries and map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Recreation Area shall consist of approximately 316,000 acres of federally owned lands and interests therein in the Toiyabe National Forest, as generally depicted on a map entitled “Spring Mountain National Recreation Area—Proposed”, numbered NV–CH, and dated ","children":[{"tag":"date","attrib":{"date":"1992-08-02"},"text":"August 2, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f71910-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map filing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"1993-08-04"},"text":"August 4, 1993","children":[],"tail":", the Secretary shall file a map of the Recreation Area with the Committee on Energy and Natural Resources of the Senate and the Committee on Natural Resources of the House of Representatives."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f71911-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public inspection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map shall be on file and available for public inspection in the offices of the Chief of the Forest Service, Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f71912-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discrepancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any discrepancy between or among the acreage referred to in subsection (b) and the map described in subsection (b), the map described in subsection (b) shall control any question concerning the boundaries of the Recreation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77f71913-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/63/s4"},"text":"Pub. L. 103–63, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-04"},"text":"Aug. 4, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/297"},"text":"107 Stat. 297","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
