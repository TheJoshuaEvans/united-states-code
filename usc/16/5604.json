{"tag":"section","attrib":{"id":"id7a016789-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5604"},"text":null,"children":[{"tag":"num","attrib":{"value":"5604"},"text":"§ 5604.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency cooperation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a01678a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5604/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities of the Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the provisions of the Convention and this chapter, the Secretary may arrange for cooperation with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a01678b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5604/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any department, agency, or instrumentality of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a01678c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5604/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a01678d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5604/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Council; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a01678e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5604/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private institution or an organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a01678f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5604/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other agencies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of any Federal agency may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a016790-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5604/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate in the conduct of scientific and other programs, and furnish facilities and personnel, for the purposes of assisting the Organization in carrying out its duties under the Convention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a016791-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5604/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept reimbursement from the Organization for providing such services, facilities, and personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a016792-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/tII/s205"},"text":"Pub. L. 104–43, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/379"},"text":"109 Stat. 379","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/327/tV/s505"},"text":"Pub. L. 114–327, title V, § 505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1996"},"text":"130 Stat. 1996","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a016793-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a016794-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a016795-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/327"},"text":"Pub. L. 114–327","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, text read as follows: “In carrying out the provisions of the Convention and this chapter, the Secretary may arrange for cooperation with other agencies of the United States, the States, the New England and the Mid-Atlantic Fishery Management Councils, and private institutions and organizations.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
