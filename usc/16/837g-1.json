{"tag":"section","attrib":{"id":"id78c69dd2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s837g–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"837g–1"},"text":"§ 837g–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of additional facilities by Secretary of Energy for mutually beneficial power sales between Pacific Northwest and California; contribution of funds by non-Federal entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s837g"},"text":"section 837g of this title","children":[],"tail":", the Secretary of Energy is authorized to construct or participate in the construction of such additional facilities as he deems necessary to allow mutually beneficial power sales between the Pacific Northwest and California and to accept funds contributed by non-Federal entities for that purpose."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78c69dd3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/360/tIII"},"text":"Pub. L. 98–360, title III","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-16"},"text":"July 16, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/416"},"text":"98 Stat. 416","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78c69dd4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78c69dd5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78c69dd6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/552"},"text":"Pub. L. 88–552","children":[],"tail":" which comprises this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
