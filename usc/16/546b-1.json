{"tag":"section","attrib":{"id":"id78411a7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"546b–1"},"text":"§ 546b–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maps and boundary descriptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78411a7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", the Secretary shall file with the Committee on Energy and Natural Resources of the Senate and the Committee on Natural Resources and the Committee on Agriculture of the House of Representatives maps and boundary descriptions of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id78411a7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the scenic areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78411a80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the wilderness areas designated by paragraphs (9) through (20) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/326/s1"},"text":"section 1 of Public Law 100–326","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1132"},"text":"16 U.S.C. 1132","children":[],"tail":" note) (as added by section 1102(a)(5));"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78411a81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the wilderness study area designated by section 6(a)(5) of the Virginia Wilderness Act of 1984 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1132"},"text":"16 U.S.C. 1132","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/98/586"},"text":"Public Law 98–586","children":[],"tail":") (as added by section 1102(b)(2)(D)); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78411a82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b–1/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential wilderness area designated by section 1103(a).","children":[{"tag":"ref","attrib":{"idref":"fn002443"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002443"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78411a83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Force and effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The maps and boundary descriptions filed under subsection (a) shall have the same force and effect as if included in this subtitle, except that the Secretary may correct any minor errors in the maps and boundary descriptions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78411a84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of map and boundary description","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The maps and boundary descriptions filed under subsection (a) shall be on file and available for public inspection in the Office of the Chief of the Forest Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78411a85-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546b–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflict","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a conflict between a map filed under subsection (a) and the acreage of the applicable areas specified in this subtitle, the map shall control.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78411a86-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tI/s1106"},"text":"Pub. L. 111–11, title I, § 1106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1007"},"text":"123 Stat. 1007","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78411a87-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78411a88-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic"