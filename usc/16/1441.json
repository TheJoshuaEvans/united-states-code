{"tag":"section","attrib":{"id":"id7934543a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1441"},"text":null,"children":[{"tag":"num","attrib":{"value":"1441"},"text":"§ 1441.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special use permits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7934543b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1441/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of permits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may issue special use permits which authorize the conduct of specific activities in a national marine sanctuary if the Secretary determines such authorization is necessary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7934543c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1441/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish conditions of access to and use of any sanctuary resource; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7934543d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1441/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote public use and understanding of a sanctuary resource.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7934543e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1441/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public notice required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide appropriate public notice before identifying any category of activity subject to a special use permit under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7934543f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1441/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permit terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A permit issued under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79345440-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1441/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall authorize the conduct of an activity only if that activity is compatible with the purposes for which the sanctuary is designated and with protection of sanctuary resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79345441-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1441/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not authorize the conduct of any activity for a period of more than 5 years unless renewed by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79345442-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1441/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall require that activities carried out under the permit be conducted in a manner that does not destroy, cause the loss of, or injure sanctuary resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79345443-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1441/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall require the permittee to purchase and maintain comprehensive general liability insurance, or post an equivalent bond, against claims arising out of activities conducted under the permit and to agree to hold the United States harmless against such claims.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79345444-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1441/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79345445-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1441/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment and collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may assess and collect fees for the conduct of any activity under a permit issued under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79345446-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1441/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of a fee under this subsection shall be equal to the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79345447-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1441/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" costs incurred, or expected to be incurred, by the Secretary in issuing the permit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79345448-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1441/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" costs incurred, or expected to be incurred, by the Secretary as a direct result of the conduct of the activity for which the permit is issued, including costs of monitoring the conduct of the activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79345449-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1441/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount which represents the fair market value of the use of the sanctuary resource.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7934544a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1441/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of fees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts collected by the Secretary in the form of fees under this section may be used by the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7934544b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1441/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for issuing and administering permits under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7934544c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1441/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for expenses of managing national marine sanctuaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7934544d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1441/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver or reduction of fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may accept in-kind contributions in lieu of a fee under paragraph (2)(C), or waive or reduce any fee assessed under this subsection for any activity that does not derive profit from the access to or use of sanctuary resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7934544e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1441/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon violation of a term or condition of a permit issued under this section, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7934544f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1441/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspend or revoke the permit without compensation to the permittee and without liability to the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79345450-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1441/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess a civil penalty in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1437"},"text":"section 1437 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79345451-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1441/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79345452-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1441/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each person issued a permit under this section shall submit an annual report to the Secretary not later than December 31 of each year which describes activities conducted under that permit and revenues derived from such activities during the year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79345453-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1441/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fishing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be considered to require a person to obtain a permit under this section for the conduct of any fishing activities in a national marine sanctuary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79345454-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532/tIII/s310"},"text":"Pub. L. 92–532, title III, § 310","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/627/tII/s203/3"},"text":"Pub. L. 100–627, title II, § 203(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3214"},"text":"102 Stat. 3214","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/513/s11"},"text":"Pub. L. 106–513, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2389"},"text":"114 Stat. 2389","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79345455-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79345456-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79345457-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/513/s11/1"},"text":"Pub. L. 106–513, § 11(1)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/513/s11/1"},"text":"Pub. L. 106–513, § 11(1)","children":[],"tail":", (2), redesignated subsec. (b) as (c) and substituted “insurance, or post an equivalent bond,” for “insurance” in par. (4). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/513/s11/1"},"text":"Pub. L. 106–513, § 11(1)","children":[],"tail":", redesignated subsec. (c) as (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/513/s11/3"},"text":"Pub. L. 106–513, § 11(3)","children":[],"tail":", substituted “resource.” for “resource and a reasonable return to the United States Government.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/513/s11/4"},"text":"Pub. L. 106–513, § 11(4)","children":[],"tail":", struck out “designating and” after “expenses of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/513/s11/5"},"text":"Pub. L. 106–513, § 11(5)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/513/s11/1"},"text":"Pub. L. 106–513, § 11(1)","children":[],"tail":", redesignated subsecs. (d) to (f) as (e) to (g), respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
