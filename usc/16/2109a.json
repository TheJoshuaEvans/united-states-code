{"tag":"section","attrib":{"id":"id799622c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2109a"},"text":"§ 2109a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and private forest landscape-scale restoration program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id799622c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to encourage collaborative, science-based restoration of priority forest landscapes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799622c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id799622c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799622c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonindustrial private forest land","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “nonindustrial private forest land” means land that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id799622ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is rural, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799622cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has existing tree cover or is suitable for growing trees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799622cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is owned by any private individual, group, association, corporation, Indian tribe, or other private legal entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799622cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State forest land","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “State forest land” means land that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id799622ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is rural, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799622cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is under State or local governmental ownership and considered to be non-Federal forest land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799622d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with State foresters or appropriate State agencies, shall establish a competitive grant program to provide financial and technical assistance to encourage collaborative, science-based restoration of priority forest landscapes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799622d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under this section, an applicant shall submit to the Secretary, through the State forester or appropriate State agency, a State and private forest landscape-scale restoration proposal based on a restoration strategy that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id799622d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is complete or substantially complete;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799622d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is for a multiyear period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799622d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" covers nonindustrial private forest land or State forest land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799622d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is accessible by wood-processing infrastructure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799622d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is based on the best available science.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799622d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State and private forest landscape-scale restoration proposal submitted under this section shall include plans—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id799622d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce the risk of uncharacteristic wildfires;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799622d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve fish and wildlife habitats, including the habitats of threatened and endangered species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799622da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain or improve water quality and watershed function;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799622db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to mitigate invasive species, insect infestation, and disease;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799622dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve important forest ecosystems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799622dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to measure ecological and economic benefits, including air quality and soil quality and productivity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799622de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to take other relevant actions, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799622df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making grants under this section, the Secretary shall give priority to plans that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id799622e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" further a statewide forest assessment and resource strategy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799622e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote cross boundary landscape collaboration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799622e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leverage public and private resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799622e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration and consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chief of the Forest Service, the Chief of the Natural Resources Conservation Service, and relevant stakeholders shall collaborate and consult on an ongoing basis regarding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id799622e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administration of the program established under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799622e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of other applicable resources for landscape-scale restoration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799622e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of receiving a grant under this section, the Secretary shall require the recipient of the grant to provide funds or in-kind support from non-Federal sources in an amount that is at least equal to the amount of Federal funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799622e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination and proximity encouraged","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making grants under this section, the Secretary may consider coordination with and proximity to other landscape-scale projects on other land under the jurisdiction of the Secretary, the Secretary of the Interior, or a Governor of a State, including under—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id799622e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Collaborative Forest Landscape Restoration Program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7303"},"text":"section 7303 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799622e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" landscape areas designated for insect and disease treatments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6591a"},"text":"section 6591a of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799622ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" good neighbor authority under section 2113 ","children":[{"tag":"ref","attrib":{"idref":"fn002715"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002715"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. See "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2113a"},"text":"section 2113a of this title","children":[],"tail":"."}],"tail":" of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799622eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stewardship end result contracting projects authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6591c"},"text":"section 6591c of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799622ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/i/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate State-level programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799622ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/i/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant programs, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799622ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate such regulations as the Secretary determines necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799622ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id799622f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of development, execution, and administration of selected projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799622f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accounting of program funding expenditures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799622f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/k/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific accomplishments that have resulted from landscape-scale projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799622f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id799622f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury a fund, to be known as the “State and Private Forest Landscape-Scale Restoration Fund” (referred to in this subsection as the “Fund”), to be used by the Secretary to make grants under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799622f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Fund shall consist of such amounts as are appropriated to the Fund under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799622f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109a/l/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Fund $20,000,000 for each fiscal year beginning with the first full fiscal year after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", through fiscal year 2023, to remain available until expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id799622f7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/313/s13A"},"text":"Pub. L. 95–313, § 13A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVIII/s8007"},"text":"Pub. L. 110–234, title VIII, § 8007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1285"},"text":"122 Stat. 1285","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VIII, § 8007, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2047; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVIII/s8102/a"},"text":"Pub. L. 115–334, title VIII, § 8102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4837"},"text":"132 Stat. 4837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id799622f8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id799622f9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id799622fa-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attri