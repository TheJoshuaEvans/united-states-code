{"tag":"section","attrib":{"id":"id79a209bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2704"},"text":null,"children":[{"tag":"num","attrib":{"value":"2704"},"text":"§ 2704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan rates and repayment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79a209bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each loan made pursuant to this chapter shall bear interest at the discount or interest rate used at the time the loan is made for water resources planning projects under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962d–17"},"text":"section 1962d–17 of title 42","children":[],"tail":". Each such loan shall be for such term, as the Secretary deems appropriate, but not in excess of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a209bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2704/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 years (in the case of a loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2702"},"text":"section 2702 of this title","children":[],"tail":") or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a209be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2704/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 30 years (in the case of a loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2703"},"text":"section 2703 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a209bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts repaid on loans made pursuant to this chapter shall be deposited into the United States Treasury as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a209c0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617/tIV/s404"},"text":"Pub. L. 95–617, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3155"},"text":"92 Stat. 3155","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a209c1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79a209c2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79a209c3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"In subsec. (a), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962d–17"},"text":"section 1962d–17 of title 42","children":[],"tail":"” was in the original “section 80 of the Water Resources Development Act of 1974 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962–17/a"},"text":"42 U.S.C. 1962–17(a)","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Secretary, referred to in subsec. (a), means the Secretary of Energy, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2602/14"},"text":"section 2602(14) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
