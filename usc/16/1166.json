{"tag":"section","attrib":{"id":"id78ef346d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166"},"text":null,"children":[{"tag":"num","attrib":{"value":"1166"},"text":"§ 1166.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78ef346e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78ef346f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, the Secretary shall provide financial assistance to any city government, village corporation, or tribal council of St. George, Alaska, or St. Paul, Alaska.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78ef3470-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use for matching","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law relating to matching funds, funds provided by the Secretary as assistance under this subsection may be used by the entity as non-Federal matching funds under any Federal program that requires such matching funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78ef3471-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on use","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not use financial assistance authorized by this chapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78ef3472-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to settle any debt owed to the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78ef3473-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for administrative or overhead expenses; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78ef3474-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for contributions sought or required from any person for costs or fees to clean up any matter that was caused or contributed to by such person on or after ","children":[{"tag":"date","attrib":{"date":"2000-03-15"},"text":"March 15, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78ef3475-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding instruments and procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing assistance under this subsection the Secretary shall transfer any funds appropriated to carry out this section to the Secretary of the Interior, who shall obligate such funds through instruments and procedures that are equivalent to the instruments and procedures required to be used by the Bureau of Indian Affairs pursuant to title IV of the Indian Self-Determination and Education Assistance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5361"},"text":"25 U.S.C. 5361","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78ef3476-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pro rata distribution of assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any fiscal year for which less than all of the funds authorized under subsection (c)(1) are appropriated, such funds shall be distributed under this subsection on a pro rata basis among the entities referred to in subsection (c)(1) in the same proportions in which amounts are authorized by that subsection for grants to those entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ef3477-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solid waste assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78ef3478-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, the Secretary shall provide assistance to the State of Alaska for designing, locating, constructing, redeveloping, permitting, or certifying solid waste management facilities on the Pribilof Islands to be operated under permits issued to the City of St. George and the City of St. Paul, Alaska, by the State of Alaska under section 46.03.100 of the Alaska Statutes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78ef3479-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall transfer any appropriations received under paragraph (1) to the State of Alaska for the benefit of rural and Native villages in Alaska for obligation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1263a"},"text":"section 1263a of title 33","children":[],"tail":", except that subsection (b) of that section shall not apply to those funds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78ef347a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to be eligible to receive financial assistance under this subsection, not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2000-12-23"},"text":"December 23, 2000","children":[],"tail":", each of the Cities of St. Paul and St. George shall enter into a written agreement with the State of Alaska under which such City shall identify by its legal boundaries the tract or tracts of land that such City has selected as the site for its solid waste management facility and any supporting infrastructure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ef347b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78ef347c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for assistance under subsection (a), for fiscal years 2001, 2002, 2003, 2004, 2005, 2006, and 2007 a total not to exceed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78ef347d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $9,000,000, for grants to the City of St. Paul;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78ef347e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $6,300,000, for grants to the Tanadgusix Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78ef347f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,500,000, for grants to the St. Paul Tribal Council;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78ef3480-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $6,000,000, for grants to the City of St. George;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78ef3481-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $4,200,000, for grants to the St. George Tanaq Corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78ef3482-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000, for grants to the St. George Tribal Council; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78ef3483-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for assistance under subsection (b), for fiscal years 2001, 2002, 2003, 2004, and 2005 a total not to exceed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78ef3484-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $6,500,000 for the City of St. Paul; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78ef3485-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,500,000 for the City of St. George.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ef3486-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of assistance for lobbying activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"None of the funds authorized by this section may be available for any activity a purpose of which is to influence legislation pending before the Congress, except that this subsection shall not prevent officers or employees of the United States or of its departments, agencies, or commissions from communicating to Members of Congress, through proper channels, requests for legislation or appropriations that they consider necessary for the efficient conduct of public business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ef3487-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immunity from liability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Neither the United States nor any of its agencies, officers, or employees shall have any liability under this chapter or any other law associated with or resulting from the designing, locating, contracting for, redeveloping, permitting, certifying, operating, or maintaining any solid waste management facility on the Pribilof Islands as a consequence of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78ef3488-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" having provided assistance to the State of Alaska under subsection (b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78ef3489-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing funds for, or planning, constructing, or operating, any interim solid waste management facilities that may be required by the State of Alaska before permanent solid waste management facilities constructed with assistance provided under subsection (b) are complete and operational.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ef348a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each entity which receives assistance authorized under subsection (c) shall submit an audited statement listing the expenditure of that assistance to the Committee on Appropriations and the Committee on Resources of the House of Representatives and the Committee on Appropriations and the Committee on Commerce, Science, and Transportation of the Senate, on the last day of fiscal years 2002, 2004, and 2006.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78ef348b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1166/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional intent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts authorized under subsection (c) are intended by Congress to be provided in addition to the base funding appropriated to the National Oceanic and Atmospheric Administration in fiscal year 2000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78ef348c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/702/tII/s206"},"text":"Pub. L. 89–702, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1094"},"text":"80 Stat. 1094","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/129/s2"},"text":"Pub. L. 98–129, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-10-14"},"text":"Oct. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/840"},"text":"97 Stat. 840","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/711/s9"},"text":"Pub. L. 100–711, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4772"},"text":"102 Stat. 4772","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/512/tI"},"text":"Pub. L. 101–512, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1931"},"text":"104 Stat. 1931","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tI/s144/e/3"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title I, § 144(e)(3)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–244; "},{"tag":"ref","attrib":{"href":"/us/pl/106/562/tI/s103"},"text":"Pub. L. 106–562, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-23"},"text":"Dec. 23, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2794"},"text":"114 Stat. 2794","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIV/s4403"},"text":"Pub. L. 109–59, title IV, § 4403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1775"},"text":"119 Stat. 1775","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78ef348d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78ef348e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78ef348f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act, referred to in subsec. (a)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":". Title IV of the Act is classified generally to subchapter IV (§ 5361 et seq.) of chapter 46 of Title 25, Indians. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of Title 25","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78ef3490-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4403/1"},"text":"Pub. L. 109–59, § 4403(1)","children":[],"tail":", struck out “for fiscal years 2001, 2002, 2003, 2004, and 2005” after “Secretary” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4403/2"},"text":"Pub. L. 109–59, § 4403(2)","children":[],"tail":", inserted “, for fiscal years 2001, 2002, 2003, 2004, 2005, 2006, and 2007” after “subsection (a)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/562"},"text":"Pub. L. 106–562","children":[],"tail":" amended section generally, inserting section catchline and subsec. and par. headings and reenacting substantially identical text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":" amended section generally. Prior to amendment, section consisted of subsecs. (a) to (h) containing provisions establishing the Pribilof Islands Trust for the benefit of natives of the Pribilof Islands and relating to the Trust’s administration, funding, distributions, trust instrument, taxation, interest and proceeds, appropriations, and annual report to Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/512"},"text":"Pub. L. 101–512","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/711"},"text":"Pub. L. 100–711","children":[],"tail":" authorized appropriations for fiscal years 1989 and 1990 to fund the Saint Paul Island Trust, and authorized appropriations for fiscal year 1990 to fund the Saint George Trust."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/129"},"text":"Pub. L. 98–129","children":[],"tail":" amended section generally, substituting provisions for the creation and functioning of a Pribilof Islands Trust for provisions which authorized the Secretary to set apart land on Saint Paul Island for a townsite and to aid in the development of a municipal government therefor."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78ef3491-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id78ef3492-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Resources of House of Representatives changed to Committee on Natural Resources of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
