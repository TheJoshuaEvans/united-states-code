{"tag":"section","attrib":{"id":"id7800b582-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"460nnn–1"},"text":"§ 460nnn–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maps and legal descriptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7800b583-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation and submission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2000-10-30"},"text":"October 30, 2000","children":[],"tail":", the Secretary shall prepare and submit to Congress maps and legal descriptions of the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7800b584-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Cooperative Management and Protection Area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b585-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Wilderness Area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b586-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The wild and scenic river segments and redband trout reserve designated by part C.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b587-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–1/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The mineral withdrawal area designated by part D.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b588-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–1/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The wildlands juniper management area established by part E.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b589-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–1/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The land exchanges required by part F.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b58a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legal effect and correction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The maps and legal descriptions referred to in subsection (a) shall have the same force and effect as if included in this subchapter, except the Secretary may correct clerical and typographical errors in such maps and legal descriptions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b58b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Copies of the maps and legal descriptions referred to in subsection (a) shall be on file and available for public inspection in the Office of the Director of the Bureau of Land Management and in the appropriate office of the Bureau of Land Management in the State of Oregon.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7800b58c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/399/s3"},"text":"Pub. L. 106–399, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1657"},"text":"114 Stat. 1657","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7800b58d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7800b58e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7800b58f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/399"},"text":"Pub. L. 106–399","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1655"},"text":"114 Stat. 1655","children":[],"tail":", known as the Steens Mountain Cooperative Management and Protection Act of 2000, which is classified generally to this subchapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460nnn"},"text":"section 460nnn of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
