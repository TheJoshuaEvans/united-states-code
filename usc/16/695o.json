{"tag":"section","attrib":{"id":"id7877e209-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s695o"},"text":null,"children":[{"tag":"num","attrib":{"value":"695o"},"text":"§ 695o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on reduction of areas by diking or other construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The areas of sumps 1(a) and 1(b) in the Klamath project lying within the Executive order boundaries of the Tule Lake National Wildlife Refuge shall not be reduced by diking or by any other construction to less than the existing thirteen thousand acres.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7877e20a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/567/s5"},"text":"Pub. L. 88–567, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-09-02"},"text":"Sept. 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/851"},"text":"78 Stat. 851","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
