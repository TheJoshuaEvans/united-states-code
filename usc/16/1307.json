{"tag":"section","attrib":{"id":"id79155a06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1307"},"text":null,"children":[{"tag":"num","attrib":{"value":"1307"},"text":"§ 1307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of services and facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In carrying out the program, the Secretary may utilize the services of local, county, and State committees established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s590h"},"text":"section 590h of this title","children":[],"tail":". The Secretary is authorized to utilize the facilities and services of the Commodity Credit Corporation in discharging his functions and responsibilities under this program."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79155a07-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/559/s8"},"text":"Pub. L. 91–559, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-19"},"text":"Dec. 19, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1471"},"text":"84 Stat. 1471","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
