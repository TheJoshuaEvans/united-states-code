{"tag":"section","attrib":{"id":"id79fcac9f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5156"},"text":null,"children":[{"tag":"num","attrib":{"value":"5156"},"text":"§ 5156.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; cooperative agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79fcaca0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5156/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each of fiscal years 2007, 2008, 2009, 2010,","children":[{"tag":"ref","attrib":{"idref":"fn002811"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002811"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “and”."}],"tail":" 2011, there are authorized to be appropriated to carry out this chapter—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79fcaca1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5156/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000 to the Secretary of Commerce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fcaca2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5156/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $250,000 to the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79fcaca3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5156/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":n