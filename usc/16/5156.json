hildren":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2676"},"text":"111 Stat. 2676","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/555/tI/s101"},"text":"Pub. L. 106–555, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2765"},"text":"114 Stat. 2765","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/479/tIII/s302/a"},"text":"Pub. L. 109–479, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3623"},"text":"120 Stat. 3623","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79fcaca5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79fcaca6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79fcaca7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/479"},"text":"Pub. L. 109–479","children":[],"tail":" amended subsec. (a) generally, substituting “For each of fiscal years 2007, 2008, 2009, 2010, 2011,” for “For each of fiscal years 2001, 2002, and 2003,” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/555"},"text":"Pub. L. 106–555","children":[],"tail":" reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “For each of fiscal years 1998, 1999, and 2000, there are authorized to be appropriated to carry out this chapter—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) $800,000 to the Secretary of Commerce; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) $250,000 to the Secretary of the Interior.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/146"},"text":"Pub. L. 105–146","children":[],"tail":" amended section catchline and text generally. Prior to amendment, section authorized appropriations for fiscal years 1986 through 1994 and authorized the Secretaries to enter into cooperative agreements with the Atlantic States Marine Fisheries Commission."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/130/s2/b/4"},"text":"Pub. L. 102–130, § 2(b)(4)","children":[],"tail":", in section catchline inserted at end “; cooperative agreements”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/130/s2/b/1"},"text":"Pub. L. 102–130, § 2(b)(1)","children":[],"tail":"–(3), designated existing provisions as subsec. (a), inserted subsec. heading, substituted “1991, 1992, 1993, and 1994,” for “and 1991,”, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/589"},"text":"Pub. L. 100–589","children":[],"tail":" substituted “1988, 1989, 1990, and 1991,” for “and 1988,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/432"},"text":"Pub. L. 99–432","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text read as follows: “Funds for activities in fiscal year 1985 under this chapter shall be made available only from funds appropriated for the Department of Commerce and the Department of the Interior for fiscal year 1985. For fiscal year 1986, there are authorized such sums as may be necessary or appropriate to carry out the provisions of this chapter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
