{"tag":"section","attrib":{"id":"id77fbfb2b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–28"},"text":null,"children":[{"tag":"num","attrib":{"value":"460lll–28"},"text":"§ 460lll–28.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cemeteries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77fbfb2c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–28/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall maintain an inventory of and ensure access to cemeteries within the Recreation Area for purposes of burial, visitation, and maintenance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfb2d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–28/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land for plots for qualified residents or relatives","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77fbfb2e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–28/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, on request from a qualified resident or relative or a cemetery association, shall grant additional land for the minor expansion of existing cemeteries within the Recreation Area, to the extent necessary, to allow for the burial of qualified residents or relatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77fbfb2f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–28/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any expenses required to move border fences or markers due to an expansion under paragraph (1) shall be the responsibility of the person making the request under that paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77fbfb30-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tV/s528"},"text":"Pub. L. 105–277, div. A, § 101(e) [title V, § 528]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–317; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dDD/tII/s201/g"},"text":"Pub. L. 117–328, div. DD, title II, § 201(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5583"},"text":"136 Stat. 5583","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77fbfb31-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77fbfb32-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77fbfb33-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
