{"tag":"section","attrib":{"id":"id79fef6d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5504"},"text":null,"children":[{"tag":"num","attrib":{"value":"5504"},"text":"§ 5504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79fef6d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Record","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall maintain an automated file or record of high seas fishing vessels issued permits under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s5503"},"text":"section 5503 of this title","children":[],"tail":", including all information submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s5503/c/2"},"text":"section 5503(c)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79fef6d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to FAO","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in cooperation with the Secretary of State and the Secretary of the department in which the Coast Guard is operating, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79fef6d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5504/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available to FAO information contained in the record maintained under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef6d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5504/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promptly notify FAO of changes in such information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef6da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5504/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promptly notify FAO of additions to or deletions from the record, and the reason for any deletion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef6db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5504/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" convey to FAO information relating to any permit granted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s5503/b/3"},"text":"section 5503(b)(3) of this title","children":[],"tail":", including the vessel’s identity, owner or operator, and factors relevant to the Secretary’s determination to issue the permit;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef6dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5504/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report promptly to FAO all relevant information regarding any activities of high seas fishing vessels that undermine the effectiveness of international conservation and management measures, including the identity of the vessels and any sanctions imposed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef6dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5504/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the FAO a summary of evidence regarding any activities of foreign vessels that undermine the effectiveness of international conservation and management measures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79fef6de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to flag nations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary, in cooperation with the Secretary of State and the Secretary of the department in which the Coast Guard is operating, has reasonable grounds to believe that a foreign vessel has engaged in activities undermining the effectiveness of international conservation and management measures, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79fef6df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5504/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the flag nation information, including appropriate evidentiary material, relating to those activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef6e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5504/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when such foreign vessel is voluntarily in a United States port, promptly notify the flag nation and, if requested by the flag nation, make arrangements to undertake such lawful investigatory measures as may be considered necessary to establish whether the vessel has been used contrary to the provisions of the Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79fef6e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5504/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, after consultation with the Secretary of State and the Secretary of the department in which the Coast Guard is operating, may promulgate such regulations, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":", as may be necessary to carry out the purposes of the Agreement and this chapter. The Secretary shall coordinate such regulations with any other entities regulating high seas fishing vessels, in order to minimize duplication of permit application and reporting requirements. To the extent practicable, such regulations shall also be consistent with regulations implementing fishery management plans under the Magnuson-Stevens Fishery Conservation and Management Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1801"},"text":"16 U.S.C. 1801","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79fef6e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5504/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of international conservation and management measures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of State, shall publish in the Federal Register, from time to time, a notice listing international conservation and management measures recognized by the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79fef6e3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/tI/s105"},"text":"Pub. L. 104–43, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/370"},"text":"109 Stat. 370","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/a/tII/s211/b"},"text":"Pub. L. 104–208, div. A, title I, § 101(a) [title II, § 211(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009"},"text":"110 Stat. 3009","children":[],"tail":", 3009–41.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79fef6e4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79fef6e5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79fef6e6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Magnuson-Stevens Fishery Conservation and Management Act, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265"},"text":"Pub. L. 94–265","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-13"},"text":"Apr. 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/331"},"text":"90 Stat. 331","children":[],"tail":", which is classified principally to chapter 38 (§ 1801 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1801"},"text":"section 1801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79fef6e7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" substituted “Magnuson-Stevens Fishery” for “Magnuson Fishery”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79fef6e8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79fef6e9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/a/tII/s211/b"},"text":"Pub. L. 104–208, div. A, title I, § 101(a) [title II, § 211(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009"},"text":"110 Stat. 3009","children":[],"tail":", 3009–41, provided that the amendment made by that section is effective 15 days after "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79fef6ea-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 120 days after ","children":[{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/43/s111"},"text":"section 111 of Pub. L. 104–43","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s5501"},"text":"section 5501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id79fef6eb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
