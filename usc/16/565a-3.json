{"tag":"section","attrib":{"id":"id7845d5e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s565a–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"565a–3"},"text":"§ 565a–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements otherwise authorized by law","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in sections 565a–1 to 565a–3 of this title shall be construed as limiting or modifying the authority of the Secretary to enter into cooperative agreements otherwise authorized by law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7845d5e2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/148/s3"},"text":"Pub. L. 94–148, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-12"},"text":"Dec. 12, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/804"},"text":"89 Stat. 804","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
