{"tag":"section","attrib":{"id":"id7795708e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430h–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"430h–4"},"text":"§ 430h–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction over lands and roads","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Upon the delivery and acceptance of the conveyances herein authorized, any jurisdiction heretofore ceded to the United States by the State of Mississippi over the lands and roads transferred shall thereby cease and thereafter rest in the State of Mississippi.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7795708f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/37/s2"},"text":"Pub. L. 88–37, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-06-04"},"text":"June 4, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/56"},"text":"77 Stat. 56","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
