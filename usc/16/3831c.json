{"tag":"section","attrib":{"id":"id79cceaaf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c"},"text":null,"children":[{"tag":"num","attrib":{"value":"3831c"},"text":"§ 3831c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79cceab0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CLEAR 30","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79cceab1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cceab2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enrollment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a pilot program to enroll land in the conservation reserve program through a 30-year conservation reserve contract (referred to in this subsection as a “CLEAR 30 contract”) in accordance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cceab3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of acreage limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of applying the limitations in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3831/d/1"},"text":"section 3831(d)(1) of this title","children":[],"tail":", the Secretary shall include acres of land enrolled under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cceab4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expired conservation contract election","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cceab5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of covered contract","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this paragraph, the term “covered contract” means a contract entered into under this subpart that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79cceab6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expires on or after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cceab7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" covers land enrolled in the conservation reserve program under the clean lakes, estuaries, and rivers priority described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3831/d/3"},"text":"section 3831(d)(3) of this title","children":[],"tail":" (or the predecessor practices that constitute the priority, as determined by the Secretary)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cceab8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On the expiration of a covered contract, an owner or operator party to the covered contract shall elect—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79cceab9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not to reenroll the land under the contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cceaba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to offer to reenroll the land under the contract if the land remains eligible under the terms in effect as of the date of expiration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cceabb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not to reenroll the land under the contract and to enroll that land through a CLEAR 30 contract under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cceabc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Only land that is subject to an expired covered contract shall be eligible for enrollment through a CLEAR 30 contract under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cceabd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of a CLEAR 30 contract shall be 30 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cceabe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to enroll land in the conservation reserve program through a CLEAR 30 contract, the owner of the land shall enter into an agreement with the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cceabf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to implement a conservation reserve plan developed for the land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cceac0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to comply with the terms and conditions of the contract and any related agreements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cceac1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to temporarily suspend the base history for the land covered by the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cceac2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions of CLEAR 30 contracts","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cceac3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A CLEAR 30 contract shall include terms and conditions that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79cceac4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" permit—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79cceac5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/6/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repairs, improvements, and inspections on the land that are necessary to maintain existing public drainage systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79cceac6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/6/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owners to control public access on the land while identifying access routes to be used for restoration activities and management and contract monitoring;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cceac7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prohibit—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79cceac8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/6/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the alteration of wildlife habitat and other natural features of the land, unless specifically authorized by the Secretary as part of the conservation reserve plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79cceac9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/6/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the spraying of the land with chemicals or the mowing of the land, except where the spraying or mowing is authorized by the Secretary or is necessary—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id79cceaca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/6/A/ii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to comply with Federal or State noxious weed control laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id79cceacb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/6/A/ii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to comply with a Federal or State emergency pest treatment program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id79cceacc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/6/A/ii/II/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to meet habitat needs of specific wildlife species;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79cceacd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/6/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any activity to be carried out on the land of the owner or successor that is immediately adjacent to, and functionally related to, the land that is subject to the contract if the activity will alter, degrade, or otherwise diminish the functional value of the land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79cceace-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/6/A/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adoption of any other practice that would tend to defeat the purposes of the conservation reserve program, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cceacf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/6/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include any additional provision that the Secretary determines is appropriate to carry out this section or facilitate the practical administration of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ccead0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the violation of a term or condition of a CLEAR 30 contract, the Secretary may require the owner to refund all or part of any payments received by the owner under the conservation reserve program, with interest on the payments, as determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ccead1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compatible uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Land subject to a CLEAR 30 contract may be used for compatible economic uses, including hunting and fishing, managed timber harvest, or periodic haying or grazing, if the use—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79ccead2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/6/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is specifically permitted by the conservation reserve plan developed for the land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79ccead3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/6/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consistent with the long-term protection and enhancement of the conservation resources for which the contract was established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ccead4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79ccead5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide payment under this subsection to an owner of land enrolled through a CLEAR 30 contract using 30 annual payments in an amount equal to the amount that would be used if the land were to be enrolled in the conservation reserve program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3831/d/3"},"text":"section 3831(d)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ccead6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Compensation for a CLEAR 30 contract shall be provided by the Secretary in the form of a cash payment in an amount determined under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ccead7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide any annual payment obligation under subparagraph (A) as early as practicable in each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ccead8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to others","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make a payment, in accordance with regulations prescribed by the Secretary, in a manner as the Secretary determines is fair and reasonable under the circumstances, if an owner who is entitled to a payment under this section—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79ccead9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/7/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cceada-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/7/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" becomes incompetent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cceadb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/7/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is succeeded by another person or entity who renders or completes the required performance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cceadc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/7/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is otherwise unable to receive the payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cceadd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cceade-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall assist owners in complying with the terms and conditions of a CLEAR 30 contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cceadf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts or agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into 1 or more contracts with private entities or agreements with a State, nongovernmental organization, or Indian Tribe to carry out necessary maintenance of a CLEAR 30 contract if the Secretary determines that the contract or agreement will advance the purposes of the conservation reserve program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cceae0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cceae1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation reserve plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop a conservation reserve plan for any land subject to a CLEAR 30 contract, which shall include practices and activities necessary to maintain, protect, and enhance the conservation value of the enrolled land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cceae2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation of contract administration","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79cceae3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/9/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal, State, or local government agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may delegate any of the management, monitoring, and enforcement responsibilities of the Secretary under this subsection to other Federal, State, or local government agencies that have the appropriate authority, expertise, and resources necessary to carry out those delegated responsibilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cceae4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/a/9/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may delegate any management responsibilities of the Secretary under this subsection to conservation organizations if the Secretary determines the conservation organization has similar expertise and resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79cceae5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Soil health and income protection pilot program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79cceae6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible land","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cceae7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible land” means cropland that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79cceae8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is selected by the owner or operator of the land for proposed enrollment in the pilot program under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cceae9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as determined by the Secretary—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79cceaea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located within 1 or more States that are part of the prairie pothole region, as selected by the Secretary based on consultation with State Committees of the Farm Service Agency and State technical committees established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3861/a"},"text":"section 3861(a) of this title","children":[],"tail":" from that region;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79cceaeb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" had a cropping history or was considered to be planted during each of the 3 crop years preceding enrollment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79cceaec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/1/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is verified to be less-productive land, as compared to other land on the applicable farm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cceaed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible land” does not include any land that was enrolled in a conservation reserve program contract in any of the 3 crop years preceding enrollment in the pilot program under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cceaee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cceaef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a voluntary soil health and income protection pilot program under which eligible land is enrolled through the use of contracts to assist owners and operators of eligible land to conserve and improve the soil, water, and wildlife resources of the eligible land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cceaf0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Eligible land may be enrolled in the program under this section through ","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn002766"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002766"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Soil Health and Income Protection Pilot Program Extension note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cceaf1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cceaf2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A contract described in paragraph (2) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79cceaf3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be entered into by the Secretary, the owner of the eligible land, and (if applicable) the operator of the eligible land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cceaf4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide that, during the term of the contract—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79cceaf5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lowest practicable cost perennial conserving use cover crop for the eligible land, as determined by the applicable State conservationist after considering the advice of the applicable State technical committee, shall be planted on the eligible land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79cceaf6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subparagraph (E), the owner or operator of the eligible land shall pay the cost of planting the conserving use cover crop under subclause (I);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79cceaf7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/3/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subparagraph (F), the eligible land may be harvested for seed, hayed, or grazed outside the primary nesting season established for the applicable county;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79cceaf8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/3/A/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible land may be eligible for a walk-in access program of the applicable State, if any; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79cceaf9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/3/A/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit wildlife organization may provide to the owner or operator of the eligible land a payment in exchange for an agreement by the owner or operator not to harvest the conserving use cover.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cceafa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraphs (E) and (F)(ii)(II), the annual rental rate for a payment under a contract described in paragraph (2) shall be equal to 50 percent of the average rental rate for the applicable county under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3834/d"},"text":"section 3834(d) of this title","children":[],"tail":", as determined by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cceafb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on enrolled land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 15 percent of the eligible land on a farm may be enrolled in the pilot program under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cceafc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79cceafd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in clause (ii), each contract described in paragraph (2) shall be for a term of 3, 4, or 5 years, as determined by the parties to the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cceafe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early termination","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79cceaff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/3/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may terminate a contract described in paragraph (2) before the end of the term described in clause (i) if the Secretary determines that the early termination of the contract is necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79cceb00-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/3/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Owners and operators","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An owner and (if applicable) an operator of eligible land enrolled in the pilot program under this subsection may terminate a contract described in paragraph (2) before the end of the term described in clause (i) if the owner and (if applicable) the operator pay to the Secretary an amount equal to the amount of rental payments received under the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cceb01-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beginning, limited resource, socially disadvantaged, or veteran farmers and ranchers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a beginning, limited resource, socially disadvantaged, or veteran farmer or rancher, as determined by the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79cceb02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/3/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a contract described in paragraph (2) shall provide that, during the term of the contract, of the actual cost of establishment of the conserving use cover crop under subparagraph (A)(ii)(I)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79cceb03-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/3/E/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using the funds of the Commodity Credit Corporation, the Secretary shall pay 50 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79cceb04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/3/E/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the beginning, limited resource, socially disadvantaged, or veteran farmer or rancher shall pay 50 percent; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cceb05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/3/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the annual rental rate for a payment under a contract described in paragraph (2) shall be equal to 75 percent of the average rental rate for the applicable county under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3834/d"},"text":"section 3834(d) of this title","children":[],"tail":", as determined by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cceb06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Harvesting, haying, and grazing outside applicable period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The harvesting for seed, haying, or grazing of eligible land under subparagraph (A)(ii)(III) outside of the primary nesting season established for the applicable county shall be subject to the conditions that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79cceb07-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/3/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to eligible land that is so hayed or grazed, adequate stubble height shall be maintained to protect the soil on the eligible land, as determined by the applicable State conservationist after considering the advice of the applicable State technical committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cceb08-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/3/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to eligible land that is so harvested for seed—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79cceb09-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/3/F/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible land shall not be eligible to be insured or reinsured under the Federal Crop Insurance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1501"},"text":"7 U.S.C. 1501","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79cceb0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/3/F/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rental payment otherwise applicable to the eligible land under this subsection shall be reduced by 25 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cceb0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acreage limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the number of acres available for enrollment in the conservation reserve under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3831/d/1"},"text":"section 3831(d)(1) of this title","children":[],"tail":", not more than 50,000 total acres of eligible land may be enrolled under the pilot program under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cceb0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate an annual report describing the eligible land enrolled in the pilot program under this subsection, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cceb0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated conservation value of the land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cceb0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831c/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimated savings from reduced commodity payments, crop insurance indemnities, and crop insurance premium subsidies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79cceb0f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1231C"},"text":"Pub. L. 99–198, title XII, § 1231C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII/s2204"},"text":"Pub. L. 115–334, title II, § 2204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4538"},"text":"132 Stat. 4538","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79cceb10-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79cceb11-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79cceb12-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Crop Insurance Act, referred to in subsec. (b)(3)(F)(ii)(I), is subtitle A of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"act Feb. 16, 1938, ch. 30","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/72"},"text":"52 Stat. 72","children":[],"tail":", which is classified generally to subchapter I (§ 1501 et seq.) of chapter 36 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1501"},"text":"section 1501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79cceb13-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79cceb14-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Soil Health and Income Protection Pilot Program Extension","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dO/tV/s501"},"text":"Pub. L. 116–260, div. O, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2149"},"text":"134 Stat. 2149","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dO/tV/s501"},"text":"“Section 1231C(b)(2)(B) of the Food Security Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3831c/b/2/B"},"text":"16 U.S.C. 3831c(b)(2)(B)","children":[],"tail":") shall be applied by substituting ‘"},{"tag":"date","attrib":{"date":"2021-09-30"},"text":"September 30, 2021","children":[],"tail":"’ for ‘"},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":"’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
