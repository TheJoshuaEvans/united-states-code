{"tag":"section","attrib":{"id":"id79fef6b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5503"},"text":null,"children":[{"tag":"num","attrib":{"value":"5503"},"text":"§ 5503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permitting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79fef6b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No high seas fishing vessel shall engage in harvesting operations on the high seas unless the vessel has on board a valid permit issued under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79fef6b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79fef6b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any vessel of the United States is eligible to receive a permit under this section, unless the vessel was previously authorized to be used for fishing on the high seas by a foreign nation, and","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79fef6b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5503/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the foreign nation suspended such authorization because the vessel undermined the effectiveness of international conservation and management measures, and the suspension has not expired; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79fef6b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5503/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the foreign nation, within the last three years preceding application for a permit under this section, withdrew such authorization because the vessel undermined the effectiveness of international conservation and management measures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef6b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The restriction in paragraph (1) does not apply if ownership of the vessel has changed since the vessel undermined the effectiveness of international conservation and management measures, and the new owner has provided sufficient evidence to the Secretary demonstrating that the previous owner or operator has no further legal, beneficial or financial interest in, or control of, the vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef6b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5503/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The restriction in paragraph (1) does not apply if the Secretary makes a determination that issuing a permit would not subvert the purposes of the Agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef6b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5503/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not issue a permit to a vessel unless the Secretary is satisfied that the United States will be able to exercise effectively its responsibilities under the Agreement with respect to that vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79fef6b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79fef6ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5503/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The owner or operator of a high seas fishing vessel may apply for a permit under this section by completing an application form prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef6bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5503/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The application form shall contain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79fef6bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5503/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel’s name, previous names (if known), official numbers, and port of record;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79fef6bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5503/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel’s previous flags (if any);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79fef6be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5503/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel’s International Radio Call Sign (if any);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79fef6bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5503/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the names and addresses of the vessel’s owners and operators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79fef6c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5503/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where and when the vessel was built;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79fef6c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5503/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type of vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79fef6c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5503/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel’s length; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79fef6c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5503/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information the Secretary requires for the purposes of implementing the Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79fef6c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5503/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish such conditions and restrictions on each permit issued under this section as are necessary and appropriate to carry out the obligations of the United States under the Agreement, including but not limited to the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79fef6c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5503/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The vessel shall be marked in accordance with the FAO Standard Specifications for the Marking and Identification of Fishing Vessels, or with regulations issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1855"},"text":"section 1855 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef6c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5503/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The permit holder shall report such information as the Secretary by regulation requires, including area of fishing operations and catch statistics. The Secretary shall promulgate regulations concerning conditions under which information submitted under this paragraph may be released.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79fef6c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5503/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79fef6c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5503/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall by regulation establish the level of fees to be charged for permits issued under this section. The amount of any fee charged for a permit issued under this section shall not exceed the administrative costs incurred in issuing such permits. The permitting fee may be in addition to any fee required under any regional permitting regime applicable to high seas fishing vessels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef6c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5503/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The fees authorized by paragraph (1) shall be collected and credited to the Operations, Research and Facilities account of the National Oceanic and Atmospheric Administration. Fees collected under this subsection shall be available for the necessary expenses of the National Oceanic and Atmospheric Administration in implementing this chapter, and shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79fef6ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5503/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Validity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A permit issued under this section for a vessel is void if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79fef6cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5503/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other permit or authorization required for the vessel to fish is expired, revoked, or suspended; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef6cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5503/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is no longer documented under the laws of the United States or eligible for such documentation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79fef6cd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/tI/s104"},"text":"Pub. L. 104–43, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/369"},"text":"109 Stat. 369","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/a/tII/s211/b"},"text":"Pub. L. 104–208, div. A, title I, § 101(a) [title II, § 211(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009"},"text":"110 Stat. 3009","children":[],"tail":", 3009–41; "},{"tag":"ref","attrib":{"href":"/us/pl/114/81/tI/s108"},"text":"Pub. L. 114–81, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-05"},"text":"Nov. 5, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/658"},"text":"129 Stat. 658","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79fef6ce-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79fef6cf-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79fef6d0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (e)(2), was in the original “this Act”, and was translated as reading “this title”, meaning title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43"},"text":"Pub. L. 104–43","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79fef6d1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/81"},"text":"Pub. L. 114–81","children":[],"tail":" amended subsec. (f) generally. Prior to amendment, text read as follows: “A permit issued under this section is valid for 5 years. A permit issued under this section is void in the event the vessel is no longer eligible for United States documentation, such documentation is revoked or denied, or the vessel is deleted from such documentation.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1855"},"text":"section 1855 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79fef6d2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79fef6d3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/a/tII/s211/b"},"text":"Pub. L. 104–208, div. A, title I, § 101(a) [title II, § 211(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009"},"text":"110 Stat. 3009","children":[],"tail":", 3009–41, provided that the amendment made by that section is effective 15 days after "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79fef6d4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 120 days after ","children":[{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/43/s111"},"text":"section 111 of Pub. L. 104–43","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s5501"},"text":"section 5501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
