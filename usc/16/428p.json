{"tag":"section","attrib":{"id":"id778e4518-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s428p"},"text":null,"children":[{"tag":"num","attrib":{"value":"428p"},"text":"§ 428p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fort Donelson National Battlefield","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id778e4519-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s428p/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation; purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There exists as a unit of the National Park System the Fort Donelson National Battlefield to commemorate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id778e451a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s428p/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Battle of Fort Donelson in February 1862; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id778e451b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s428p/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the campaign conducted by General Ulysses S. Grant and Admiral Andrew H. Foote that resulted in the capture of Fort Donelson by Union forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id778e451c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s428p/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The boundary of the Fort Donelson National Battlefield is revised to include the site of Fort Donelson and associated land that has been acquired by the Secretary of the Interior for administration by the National Park Service, including Fort Donelson National Cemetery, in Stewart County, Tennessee and the site of Fort Heiman and associated land in Calloway County, Kentucky, as generally depicted on the map entitled “Fort Donelson National Battlefield Boundary Adjustment” numbered 328/80024, and dated September 2003. The map shall be on file and available for public inspection in the appropriate offices of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id778e451d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s428p/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion of boundaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Fort Donelson National Battlefield shall also include any land acquired pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s428p–1"},"text":"section 428p–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id778e451e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/367/s2"},"text":"Pub. L. 108–367, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-25"},"text":"Oct. 25, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1743"},"text":"118 Stat. 1743","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
