{"tag":"section","attrib":{"id":"id78e0dc1e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1007"},"text":null,"children":[{"tag":"num","attrib":{"value":"1007"},"text":"§ 1007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated such sums as may be necessary to carry out the purposes of this chapter, such sums to remain available until expended. No appropriation hereafter available for assisting local organizations in preparing and carrying out plans for works of improvement under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1003"},"text":"section 1003 of this title","children":[],"tail":" or clause (a) of "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1006a"},"text":"section 1006a of this title","children":[],"tail":" shall be available for any works of improvement pursuant to this chapter or otherwise in connection with the eleven watershed improvement programs authorized by "},{"tag":"ref","attrib":{"href":"/us/act/1944-12-22/s13"},"text":"section 13 of the Act of December 22, 1944","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/58/887"},"text":"58 Stat. 887","children":[],"tail":"), as amended and supplemented, or for making loans or advancements to State and local agencies as authorized by clause (b) of "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1006a"},"text":"section 1006a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78e0dc1f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-04/ch656/s10"},"text":"Aug. 4, 1954, ch. 656, § 10","children":[],"tail":", formerly § 8, "},{"tag":"ref","attrib":{"href":"/us/stat/68/668"},"text":"68 Stat. 668","children":[],"tail":"; renumbered § 10, "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-07/ch1027/s1/g"},"text":"Aug. 7, 1956, ch. 1027, § 1(g)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/1090"},"text":"70 Stat. 1090","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/86/468/s3"},"text":"Pub. L. 86–468, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-05-13"},"text":"May 13, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/132"},"text":"74 Stat. 132","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78e0dc20-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78e0dc21-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78e0dc22-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1944-12-22/s13"},"text":"Section 13 of the Act of December 22, 1944","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/58/887"},"text":"58 Stat. 887","children":[],"tail":"), as amended and supplemented, referred to in text, is section 13 of "},{"tag":"ref","attrib":{"href":"/us/act/1944-12-22/ch665"},"text":"act Dec. 22, 1944, ch. 665","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/887"},"text":"58 Stat. 887","children":[],"tail":", which was not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78e0dc23-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","