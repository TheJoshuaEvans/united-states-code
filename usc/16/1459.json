{"tag":"section","attrib":{"id":"id793dca19-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1459"},"text":null,"children":[{"tag":"num","attrib":{"value":"1459"},"text":"§ 1459.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records and audit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id793dca1a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1459/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of records by recipients of grants or financial assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each recipient of a grant under this chapter or of financial assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1456a"},"text":"section 1456a of this title","children":[],"tail":", as in effect before "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"November 5, 1990","children":[],"tail":", shall keep such records as the Secretary shall prescribe, including records which fully disclose the amount and disposition of the funds received under the grant and of the proceeds of such assistance, the total cost of the project or undertaking supplied by other sources, and such other records as will facilitate an effective audit."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id793dca1b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1459/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access by Secretary and Comptroller General to records, books, etc., of recipients of grants or financial assistance for audit and examination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary and the Comptroller General of the United States, or any of their duly authorized representatives, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id793dca1c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1459/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after any grant is made under this chapter or any financial assistance is provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1456a"},"text":"section 1456a of this title","children":[],"tail":", as in effect before "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"November 5, 1990","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793dca1d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1459/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" until the expiration of 3 years after—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id793dca1e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1459/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completion of the project, program, or other undertaking for which such grant was made or used, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id793dca1f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1459/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repayment of the loan or guaranteed indebtedness for which such financial assistance was provided,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"have access for purposes of audit and examination to any record, book, document, and paper which belongs to or is used or controlled by, any recipient of the grant funds or any person who entered into any transaction relating to such financial assistance and which is pertinent for purposes of determining if the grant funds or the proceeds of such financial assistance are being, or were, used in accordance with the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id793dca20-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/454/tIII/s313"},"text":"Pub. L. 89–454, title III, § 313","children":[],"tail":", formerly § 310, as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/583"},"text":"Pub. L. 92–583","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1287"},"text":"86 Stat. 1287","children":[],"tail":"; renumbered § 313 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/370"},"text":"Pub. L. 94–370","children":[],"tail":", §§ 7, 11, "},{"tag":"date","attrib":{"date":"1976-07-26"},"text":"July 26, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1019"},"text":"90 Stat. 1019","children":[],"tail":", 1030; "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/tII/s2205/b/19"},"text":"Pub. L. 102–587, title II, § 2205(b)(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5052"},"text":"106 Stat. 5052","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id793dca21-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id793dca22-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id793dca23-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/s2205/b/19/A"},"text":"Pub. L. 102–587, § 2205(b)(19)(A)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1456a"},"text":"section 1456a of this title","children":[],"tail":", as in effect before "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"November 5, 1990","children":[],"tail":",” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1456a"},"text":"section 1456a of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/s2205/b/19/B"},"text":"Pub. L. 102–587, § 2205(b)(19)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1456a"},"text":"section 1456a of this title","children":[],"tail":", as in effect before "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"November 5, 1990","children":[],"tail":"; and” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1456a/d"},"text":"section 1456a(d) of this title","children":[],"tail":"; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/370/s11/2"},"text":"Pub. L. 94–370, § 11(2)","children":[],"tail":", inserted “or of financial assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1456a"},"text":"section 1456a of this title","children":[],"tail":"” after “grant under this chapter” and “and of the proceeds of such assistance” after “received under the grant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/370/s11/3"},"text":"Pub. L. 94–370, § 11(3)","children":[],"tail":", inserted provisions limiting duration of authority to 3 years after completion of project or repayment of loan and enlarged scope of access to include persons who entered into transactions relating to the grant of funds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
