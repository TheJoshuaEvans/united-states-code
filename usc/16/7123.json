{"tag":"section","attrib":{"id":"id7a251c50-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7123"},"text":null,"children":[{"tag":"num","attrib":{"value":"7123"},"text":"§ 7123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of project proposals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a251c51-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7123/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of project proposals to Secretary concerned","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a251c52-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7123/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects funded using project funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than September 30 of each fiscal year (or a later date specified by the Secretary concerned for the fiscal year), each resource advisory committee shall submit to the Secretary concerned a description of any projects that the resource advisory committee proposes the Secretary undertake using any project funds reserved by eligible counties in the area in which the resource advisory committee has geographic jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a251c53-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7123/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects funded using other funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A resource advisory committee may submit to the Secretary concerned a description of any projects that the committee proposes the Secretary undertake using funds from State or local governments, or from the private sector, other than project funds and funds appropriated and otherwise available to do similar work.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a251c54-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7123/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Participating counties or other persons may propose to pool project funds or other funds, described in paragraph (2), and jointly propose a project or group of projects to a resource advisory committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7125"},"text":"section 7125 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a251c55-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7123/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required description of projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In submitting proposed projects to the Secretary concerned under subsection (a), a resource advisory committee shall include in the description of each proposed project the following information:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a251c56-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7123/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The purpose of the project and a description of how the project will meet the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a251c57-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7123/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The anticipated duration of the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a251c58-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7123/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The anticipated cost of the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a251c59-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7123/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The proposed source of funding for the project, whether project funds or other funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a251c5a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7123/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a251c5b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7123/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Expected outcomes, including how the project will meet or exceed desired ecological conditions, maintenance objectives, or stewardship objectives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a251c5c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7123/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An estimate of the amount of any timber, forage, and other commodities and other economic activity, including jobs generated, if any, anticipated as part of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a251c5d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7123/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A detailed monitoring plan, including funding needs and sources, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a251c5e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7123/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tracks and identifies the positive or negative impacts of the project, implementation,","children":[{"tag":"ref","attrib":{"idref":"fn002850"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002850"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" and provides for validation monitoring; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a251c5f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7123/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes an assessment of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a251c60-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7123/b/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether or not the project met or exceeded desired ecological conditions; created local employment or training opportunities, including summer youth jobs programs such as the Youth Conservation Corps where appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a251c61-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7123/b/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the project improved the use of, or added value to, any products removed from land consistent with the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a251c62-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7123/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment that the project is to be in the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a251c63-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7123/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Projects proposed under subsection (a) shall be consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7101"},"text":"section 7101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a251c64-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/393/tII/s203"},"text":"Pub. L. 106–393, title II, § 203","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/343/dC/tVI/s601/a"},"text":"Pub. L. 110–343, div. C, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3901"},"text":"122 Stat. 3901","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dF/tI/s100101/a/2"},"text":"Pub. L. 112–141, div. F, title I, § 100101(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/905"},"text":"126 Stat. 905","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/40/s10/a/2/A"},"text":"Pub. L. 113–40, § 10(a)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-10-02"},"text":"Oct. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/545"},"text":"127 Stat. 545","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/10/tV/s524/c/1"},"text":"Pub. L. 114–10, title V, § 524(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-04-16"},"text":"Apr. 16, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/180"},"text":"129 Stat. 180","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a251c65-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a251c66-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a251c67-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/393/s203"},"text":"section 203 of Pub. L. 106–393","children":[],"tail":" was set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s500"},"text":"section 500 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/110/343/dC/tVI/s601/a"},"text":"Pub. L. 110–343, div. C, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3893"},"text":"122 Stat. 3893","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a251c68-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/10"},"text":"Pub. L. 114–10","children":[],"tail":" substituted “September 30 of each fiscal year (or a later date specified by the Secretary concerned for the fiscal year)” for “September 30 for fiscal year 2008 (or as soon thereafter as the Secretary concerned determines is practicable), and each September 30 thereafter for each succeeding fiscal year through fiscal year 2013”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/40"},"text":"Pub. L. 113–40","children":[],"tail":" substituted “2013” for “2012”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" substituted “2012” for “2011”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
