{"tag":"section","attrib":{"id":"id78484652-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s574"},"text":null,"children":[{"tag":"num","attrib":{"value":"574"},"text":"§ 574.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Damages caused private property in protection, administration, and improvement of national forests; reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture is authorized to reimburse owners of private property for damage or destruction thereof caused by employees of the United States in connection with the protection, administration, or improvement of the national forests, payment to be made from any funds appropriated for the protection, administration, and improvement of the national forests: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That no payment in excess of $2,500 shall be made on any such claim."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78484653-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-05-27/ch337/s2"},"text":"May 27, 1930, ch. 337, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/387"},"text":"46 Stat. 387","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/869/s8"},"text":"Pub. L. 87–869, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-23"},"text":"Oct. 23, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1157"},"text":"76 Stat. 1157","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78484654-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78484655-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78484656-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/869"},"text":"Pub. L. 87–869","children":[],"tail":" increased from $500 to $2,500 the authorization for reimbursement of owners of private property for damages caused in protection, administration, and improvement of national forests."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
