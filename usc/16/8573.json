{"tag":"section","attrib":{"id":"id7a3f5b78-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8573"},"text":null,"children":[{"tag":"num","attrib":{"value":"8573"},"text":"§ 8573.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency report on special recreation permits for underserved communities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a3f5b79-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8573/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered community defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered community” means a rural or urban community, including an Indian Tribe, that is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3f5b7a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8573/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" low-income or underserved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3f5b7b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8573/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been underrepresented in outdoor recreation opportunities on Federal recreational lands and waters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3f5b7c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8573/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretaries, acting jointly, shall submit to the Committee on Energy and Natural Resources of the Senate and the Committee on Natural Resources of the House of Representatives a report that describes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3f5b7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8573/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated use of special recreation permits serving covered communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3f5b7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8573/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examples of special recreation permits, partnerships, cooperative agreements, or other arrangements providing access to Federal recreational lands and waters for covered communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3f5b7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8573/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other ways covered communities are engaging on Federal recreational lands and waters, including through stewardship and conservation projects or activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3f5b80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8573/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any barriers for existing or prospective recreation service providers and holders of commercial use authorizations operating within or serving a covered community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3f5b81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8573/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations to facilitate and increase permitted access to Federal recreational lands and waters for covered communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3f5b82-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tIII/s353"},"text":"Pub. L. 118–234, title III, § 353","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2917"},"text":"138 Stat. 2917","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
