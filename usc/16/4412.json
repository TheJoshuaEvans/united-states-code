{"tag":"section","attrib":{"id":"id79f09e68-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4412"},"text":null,"children":[{"tag":"num","attrib":{"value":"4412"},"text":"§ 4412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on assessments against Migratory Bird Conservation Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, only those personnel and administrative costs directly related to acquisition of real property shall be levied against the Migratory Bird Conservation Account.","children":[{"tag":"ref","attrib":{"idref":"fn002794"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002794"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Fund”. See "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s718d"},"text":"section 718d of this title","children":[],"tail":"."}],"tail":null}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79f09e69-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/233/s14"},"text":"Pub. L. 101–233, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-13"},"text":"Dec. 13, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1977"},"text":"103 Stat. 1977","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
