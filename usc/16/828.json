{"tag":"section","attrib":{"id":"id78b5fc29-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s828"},"text":null,"children":[{"tag":"num","attrib":{"value":"828"},"text":"§ 828.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilitation of development and construction of water conservation facilities; exemption from certain Federal requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In order to facilitate the development and construction by States and municipalities of water conservation facilities, certain requirements in the Federal Power Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s791a"},"text":"16 U.S.C. 791a","children":[],"tail":" et seq.] are made inapplicable to States and municipalities as provided in this subchapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78b5fc2a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1953-08-15/ch503/s1"},"text":"Aug. 15, 1953, ch. 503, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/587"},"text":"67 Stat. 587","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78b5fc2b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78b5fc2c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78b5fc2d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Power Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-10/ch285"},"text":"act June 10, 1920, ch. 285","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/1063"},"text":"41 Stat. 1063","children":[],"tail":", which is classified generally to this chapter. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s791a"},"text":"section 791a of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78b5fc2e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Federal Power Act which generally comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
