{"tag":"section","attrib":{"id":"id774de0a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–23"},"text":null,"children":[{"tag":"num","attrib":{"value":"410cc–23"},"text":"§ 410cc–23.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements and technical assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id774de0a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–23/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interpretative exhibits or programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may enter into agreements with any owner of property with national historic or cultural significance within the park to provide for interpretive exhibits or programs. Such agreements shall provide, whenever appropriate, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id774de0a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–23/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public may have access to such property at specified, reasonable times for purposes of viewing such property or the exhibits or attending the programs established by the Secretary under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id774de0a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–23/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may make such minor improvements to such property as the Secretary deems necessary to enhance the public use and enjoyment of such property, exhibits, and programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id774de0aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–23/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request for assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id774de0ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–23/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall provide, upon request, technical assistance to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id774de0ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–23/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the city of Lowell to assist the city in establishing regulations or laws consistent with the standards and criteria established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410cc–32/e"},"text":"section 410cc–32(e) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id774de0ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–23/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commission to assist the Commission in establishing the index and the standards and criteria required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410cc–32"},"text":"section 410cc–32 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id774de0ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410cc–23/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may provide to any owner of property within the park or preservation district, the Commission, the Commonwealth of Massachusetts, the city of Lowell, and any other Federal entity or any institution such technical assistance as the Secretary considers appropriate to carry out the purpose of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id775051af-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/290/tII/s203"},"text":"Pub. L. 95–290, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-06-05"},"text":"June 5, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/294"},"text":"92 Stat. 294","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
