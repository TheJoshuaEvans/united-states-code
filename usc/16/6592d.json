{"tag":"section","attrib":{"id":"id7a16c493-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d"},"text":null,"children":[{"tag":"num","attrib":{"value":"6592d"},"text":"§ 6592d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint Chiefs Landscape Restoration Partnership program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a16c494-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a16c495-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chiefs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Chiefs” means the Chief of the Forest Service and the Chief of the Natural Resources Conservation Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c496-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible activity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible activity” means an activity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c497-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce the risk of wildfire;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c498-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect water quality and supply; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c499-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve wildlife habitat for at-risk species.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c49a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Program” means the Joint Chiefs Landscape Restoration Partnership program established under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c49b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c49c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wildland-urban interface","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “wildland-urban interface” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6511"},"text":"section 6511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a16c49d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a16c49e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a Joint Chiefs Landscape Restoration Partnership program to improve the health and resilience of forest landscapes across National Forest System land and State, Tribal, and private land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c49f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall administer the Program by coordinating eligible activities conducted on National Forest System land and State, Tribal, or private land across a forest landscape to improve the health and resilience of the forest landscape by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c4a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting producers and landowners in implementing eligible activities on eligible private or Tribal land using the applicable programs and authorities administered by the Chief of the Natural Resources Conservation Service under title XII of the Food Security Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3801"},"text":"16 U.S.C. 3801","children":[],"tail":" et seq.), not including the conservation reserve program established under subchapter B of chapter 1 of subtitle D of that title ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3831"},"text":"16 U.S.C. 3831","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c4a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting eligible activities on National Forest System land or assisting landowners in implementing eligible activities on State, Tribal, or private land using the applicable programs and authorities administered by the Chief of the Forest Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a16c4a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of eligible activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The appropriate Regional Forester and State Conservationist shall jointly submit to the Chiefs on an annual basis proposals for eligible activities under the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a16c4a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In evaluating and selecting proposals submitted under subsection (c), the Chiefs shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a16c4a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" criteria including whether the proposal—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c4a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduces wildfire risk in a municipal watershed or the wildland-urban interface;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c4a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was developed through a collaborative process with participation from diverse stakeholders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c4a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increases forest workforce capacity or forest business infrastructure and development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c4a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leverages existing authorities and non-Federal funding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c4a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides measurable outcomes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c4aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supports established State and regional priorities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c4ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other criteria relating to the merits of the proposals as the Chiefs determine to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a16c4ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a16c4ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" public notice on the websites of the Forest Service and the Natural Resources Conservation Service describing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c4ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the solicitation of proposals under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c4af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the criteria for selecting proposals in accordance with subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c4b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information relating to the Program and activities funded under the Program to States, Indian Tribes, units of local government, and private landowners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a16c4b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible activity may not be carried out under the Program—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a16c4b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a wilderness area or designated wilderness study area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c4b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an inventoried roadless area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c4b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on any Federal land on which, by Act of Congress or Presidential proclamation, the removal of vegetation is restricted or prohibited; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c4b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an area in which the eligible activity would be inconsistent with the applicable land and resource management plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a16c4b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a16c4b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Secretary shall submit to Congress a report providing recommendations to Congress relating to the Program, including a review of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c4b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funding mechanisms for the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c4b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" staff capacity to carry out the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c4ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" privacy laws applicable to the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c4bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/g/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data collection under the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c4bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/g/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring and outcomes under the Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c4bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/g/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other matters as the Secretary considers to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c4be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each of fiscal years 2022 and 2023, the Chiefs shall submit to the Committee on Agriculture, Nutrition, and Forestry and the Committee on Appropriations of the Senate and the Committee on Agriculture and the Committee on Appropriations of the House of Representatives a report describing projects for which funding is provided under the Program, including the status and outcomes of those projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a16c4bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a16c4c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out the Program $90,000,000 for each of fiscal years 2022 and 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c4c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the funds described in paragraph (1), the Secretary may obligate available funds from accounts used to carry out the existing Joint Chiefs’ Landscape Restoration Partnership prior to ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", to carry out the Program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c4c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available under paragraph (1) shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c4c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the funds made available under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c4c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/h/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 40 percent shall be allocated to carry out eligible activities through the Natural Resources Conservation Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c4c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/h/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 40 percent shall be allocated to carry out eligible activities through the Forest Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c4c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/h/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the remaining funds shall be allocated by the Chiefs to the Natural Resources Conservation Service or the Forest Service—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a16c4c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/h/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out eligible activities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a16c4c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592d/h/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for other purposes, such as technical assistance, project development, or local capacity building.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a16c4c9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tVIII/s40808"},"text":"Pub. L. 117–58, div. D, title VIII, § 40808","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1114"},"text":"135 Stat. 1114","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a16c4ca-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a16c4cb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a16c4cc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Food Security Act of 1985, referred to in subsec. (b)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1354"},"text":"99 Stat. 1354","children":[],"tail":". Title XII of the Act is classified principally to chapter 58 (§ 3801 et seq.) of this title. Subchapter B of chapter 1 of subtitle D of title XII of the Act is classified generally to subpart B (§ 3831 et seq.) of part I of subchapter IV of chapter 58 of this title. For complete classification of this Act to the Code, see Short Title of 1985 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1281"},"text":"section 1281 of Title 7","children":[],"tail":", Agriculture, and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a16c4cd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Infrastructure Investment and Jobs Act, and not as part of the Healthy Forests Restoration Act of 2003 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a16c4ce-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a16c4cf-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id7a16c4d0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “Indian Tribe” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of Title 25","children":[],"tail":", Indians, as made applicable by "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18701/2"},"text":"section 18701(2) of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
