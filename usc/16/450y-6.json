{"tag":"section","attrib":{"id":"id77a157b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450y–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"450y–6"},"text":"§ 450y–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of lands; administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to acquire lands and interests in lands within the revised boundaries of the Coronado National Memorial by purchase, donation, with donated funds, or by such other means as he may consider to be in the public interest. Lands and interests in lands acquired pursuant to this Act shall become a part of the Memorial and be administered by the Secretary of the Interior in accordance with the provisions of the Act of ","children":[{"tag":"date","attrib":{"date":"1916-08-25"},"text":"August 25, 1916","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/39/535"},"text":"39 Stat. 535","children":[],"tail":"),"},{"tag":"ref","attrib":{"idref":"fn002255"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002255"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" as amended, and pursuant to sections 450y–1 to 450y–3 of this title."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77a157b6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/689/s2"},"text":"Pub. L. 86–689, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-02"},"text":"Sept. 2, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/737"},"text":"74 Stat. 737","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77a157b7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"rol