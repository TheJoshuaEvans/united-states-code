{"tag":"section","attrib":{"id":"id7845d5d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s565a"},"text":null,"children":[{"tag":"num","attrib":{"value":"565a"},"text":"§ 565a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation by Secretary of Agriculture with Territories","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture is authorized to cooperate with the Territories of the United States on the same terms and conditions as with States under sections 564 and 565 ","children":[{"tag":"ref","attrib":{"idref":"fn002448"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002448"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7845d5d2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1931-02-20/ch249"},"text":"Feb. 20, 1931, ch. 249","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/1200"},"text":"46 Stat. 1200","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7845d5d3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7845d5d4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7845d5d5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 564 and 565 of this title, referred to in text, were repealed by ","children":[{"tag":"