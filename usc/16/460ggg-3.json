{"tag":"section","attrib":{"id":"id77f718fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ggg–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"460ggg–3"},"text":"§ 460ggg–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maps and legal descriptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"1991-12-11"},"text":"December 11, 1991","children":[],"tail":", the Secretary of Agriculture shall file a map and a legal description of each area designated by this subchapter with the Committee on Natural Resources and the Committee on Agriculture of the House of Representatives and with the Committee on Agriculture, Nutrition, and Forestry of the Senate. Each such map and description shall have the same force and effect as if included in this subchapter, except that correction of clerical and typographical errors in each such map and description shall be on file and available for public inspection in the Office of the Chief of the Forest Service, Department of Agriculture."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77f718fb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/217/s5"},"text":"Pub. L. 102–217, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-11"},"text":"Dec. 11, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1669"},"text":"105 Stat. 1669","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/437/s6/d/25"},"text":"Pub. L. 103–437, § 6(d)(25)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4584"},"text":"108 Stat. 4584","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77f718fc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77f718fd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77f718fe-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/437"},"text":"Pub. L. 103–437","children":[],"tail":" substituted “Natural Resources” for “Interior and Insular Affairs” after “Committee on”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
