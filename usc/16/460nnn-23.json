{"tag":"section","attrib":{"id":"id7800b5cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–23"},"text":null,"children":[{"tag":"num","attrib":{"value":"460nnn–23"},"text":"§ 460nnn–23.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land use authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7800b5d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–23/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall allow only such uses of the Federal lands included in the Cooperative Management and Protection Area as the Secretary finds will further the purposes for which the Cooperative Management and Protection Area is established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b5d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–23/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial timber","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7800b5d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–23/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal lands included in the Cooperative Management and Protection Area shall not be made available for commercial timber harvest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b5d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–23/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may authorize the removal of trees from Federal lands in the Cooperative Management and Protection Area only if the Secretary determines that the removal is clearly needed for purposes of ecological restoration and maintenance or for public safety. Except in the Wilderness Area and the wilderness study areas referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460nnn–64/a"},"text":"section 460nnn–64(a) of this title","children":[],"tail":", the Secretary may authorize the sale of products resulting from the authorized removal of trees under this paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b5d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–23/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Juniper management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall emphasize the restoration of the historic fire regime in the Cooperative Management and Protection Area and the resulting native vegetation communities through active management of Western Juniper on a landscape level. Management measures shall include the use of natural and prescribed burning.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b5d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–23/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hunting, fishing, and trapping","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7800b5d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–23/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall permit hunting, fishing, and trapping on Federal lands included in the Cooperative Management and Protection Area in accordance with applicable laws and regulations of the United States and the State of Oregon.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b5d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–23/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area and time limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After consultation with the Oregon Department of Fish and Wildlife, the Secretary may designate zones where, and establish periods when, hunting, trapping or fishing is prohibited on Federal lands included in the Cooperative Management and Protection Area for reasons of public safety, administration, or public use and enjoyment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b5d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–23/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grazing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7800b5d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–23/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of existing law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this section and part F, the laws, regulations, and executive orders otherwise applicable to the Bureau of Land Management in issuing and administering grazing leases and permits on lands under its jurisdiction shall apply in regard to the Federal lands included in the Cooperative Management and Protection Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b5da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–23/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cancellation of certain permits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall cancel that portion of the permitted grazing on Federal lands in the Fish Creek/Big Indian, East Ridge, and South Steens allotments located within the area designated as the “no livestock grazing area” on the map referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460nnn–11/a"},"text":"section 460nnn–11(a) of this title","children":[],"tail":". Upon cancellation, future grazing use in that designated area is prohibited. The Secretary shall be responsible for installing and maintaining any fencing required for resource protection within the designated no livestock grazing area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b5db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–23/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forage replacement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Reallocation of available forage shall be made as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7800b5dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–23/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" O’Keefe pasture within the Miners Field allotment to Stafford Ranches.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7800b5dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–23/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fields Seeding and Bone Creek Pasture east of the county road within the Miners Field allotment to Amy Ready.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7800b5de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–23/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Miners Field Pasture, Schouver Seeding and Bone Creek Pasture west of the county road within the Miners Field allotment to Roaring Springs Ranch.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7800b5df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–23/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 800 animal unit months within the Crows Nest allotment to Lowther (Clemens) Ranch.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b5e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–23/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fencing and water systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall also construct fencing and develop water systems as necessary to allow reasonable and efficient livestock use of the forage resources referred to in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b5e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–23/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on construction of facilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No new facilities may be constructed on Federal lands included in the Cooperative Management and Protection Area unless the Secretary determines that the structure—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7800b5e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–23/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be minimal in nature;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b5e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–23/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consistent with the purposes of this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b5e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–23/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is necessary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7800b5e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–23/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for enhancing botanical, fish, wildlife, or watershed conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7800b5e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–23/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for public information, health, or safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7800b5e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–23/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the management of livestock; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7800b5e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–23/f/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the management of recreation, but not for the promotion of recreation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b5e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–23/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to valid existing rights, the Federal lands and interests in lands included in the Cooperative Management and Protection Areas are hereby withdrawn from all forms of entry, appropriation, or disposal under the public land laws, except in the case of land exchanges if the Secretary determines that the exchange furthers the purpose and objectives specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460nnn–12"},"text":"section 460nnn–12 of this title","children":[],"tail":" and so certifies to Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7800b5ea-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/399/tI/s113"},"text":"Pub. L. 106–399, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1661"},"text":"114 Stat. 1661","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7800b5eb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7800b5ec-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7800b5ed-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (f)(2), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/399"},"text":"Pub. L. 106–399","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1655"},"text":"114 Stat. 1655","children":[],"tail":", known as the Steens Mountain Cooperative Management and Protection Act of 2000, which is classified generally to this subchapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460nnn"},"text":"section 460nnn of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
