{"tag":"section","attrib":{"id":"id785b58c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s607a"},"text":null,"children":[{"tag":"num","attrib":{"value":"607a"},"text":"§ 607a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cutting and use of timber in Alaska by settlers, residents, miners, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior may permit under regulations to be prescribed by him the use of timber found upon the public land in Alaska by actual settlers, residents, individual miners, and prospectors for minerals, for firewood, fencing, buildings, mining, prospecting, and for domestic purposes, as may actually be needed by such persons for such purposes and may permit such use by churches, hospitals, and charitable institutions in Alaska for firewood, fencing, buildings, and for domestic purposes.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id785b58c1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1898-05-14/ch299/s11"},"text":"May 14, 1898, ch. 299, § 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/414"},"text":"30 Stat. 414","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1938-06-15/ch437"},"text":"June 15, 1938, ch. 437","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/699"},"text":"52 Stat. 699","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id785b58c2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id785b58c3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id785b58c4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of the last sentence of section 11 of act ","children":[{"tag":"date","attrib":{"date":"1898-05-14"},"text":"May 14, 1898","children":[],"tail":". The remainder of section 11 of act "},{"tag":"date","attrib":{"date":"1898-05-14"},"text":"May 14, 1898","children":[],"tail":", is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s615a"},"text":"section 615a of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s423"},"text":"section 423 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id785b58c5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1938—Act ","children":[{"tag":"date","attrib":{"date":"1938-06-15"},"text":"June 15, 1938","children":[],"tail":", inserted last clause relating to use of timber by churches, hospitals, and charitable institutions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
