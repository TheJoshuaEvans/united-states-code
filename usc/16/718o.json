{"tag":"section","attrib":{"id":"id78863a1d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718o"},"text":null,"children":[{"tag":"num","attrib":{"value":"718o"},"text":"§ 718o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78863a1e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718o/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actual stamp","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “actual stamp” means a Migratory Bird Hunting and Conservation Stamp required under the Migratory Bird Hunting and Conservation Stamp Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s718a"},"text":"16 U.S.C. 718a","children":[],"tail":" et seq.) that is printed on paper and sold through the means established by the authority of the Secretary immediately before "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"December 18, 2014","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78863a1f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718o/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Automated licensing system","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78863a20-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718o/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “automated licensing system” means an electronic, computerized licensing system used by a State fish and wildlife agency to issue hunting, fishing, and other associated licenses and products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78863a21-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718o/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “automated licensing system” includes a point-of-sale, Internet, telephonic system, or other electronic applications used for a purpose described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78863a22-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718o/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic stamp","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “electronic stamp” means an electronic version of an actual stamp that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78863a23-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718o/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a unique identifier for the individual to whom it is issued;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78863a24-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718o/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can be printed on paper or produced through an electronic application with the same indicators as the State endorsement provides;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78863a25-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718o/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is issued through a State automated licensing system that is authorized, under State law and by the Secretary under this subchapter, to issue electronic stamps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78863a26-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718o/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is compatible with the hunting licensing system of the State that issues the electronic stamp;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78863a27-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718o/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is described in the State application approved by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s718q/b"},"text":"section 718q(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78863a28-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718o/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may contain an image of the actual stamp.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78863a29-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718o/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78863a2a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/239/s2"},"text":"Pub. L. 113–239, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2847"},"text":"128 Stat. 2847","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/25/s2/b"},"text":"Pub. L. 118–25, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-19"},"text":"Dec. 19, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/129"},"text":"137 Stat. 129","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78863a2b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78863a2c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78863a2d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Migratory Bird Hunting and Conservation Stamp Act, referred to in par. (1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-03-16/ch71"},"text":"act Mar. 16, 1934, ch. 71","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/451"},"text":"48 Stat. 451","children":[],"tail":", which is classified generally to subchapter IV (§ 718 et seq.) of this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s718"},"text":"section 718 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78863a2e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/25/s2/b/1"},"text":"Pub. L. 118–25, § 2(b)(1)","children":[],"tail":", substituted “Migratory Bird Hunting and Conservation Stamp required under the Migratory Bird Hunting and Conservation Stamp Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s718a"},"text":"16 U.S.C. 718a","children":[],"tail":" et seq.) that is printed” for “Federal migratory-bird hunting and conservation stamp required under the Act of "},{"tag":"date","attrib":{"date":"1934-03-16"},"text":"March 16, 1934","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s718a"},"text":"16 U.S.C. 718a","children":[],"tail":" et seq.) (popularly known as the ‘Duck Stamp Act’), that is printed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/25/s2/b/2"},"text":"Pub. L. 118–25, § 2(b)(2)","children":[],"tail":", added subpar. (F)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78863a2f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id78863a30-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2023 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/25/s1"},"text":"Pub. L. 118–25, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-19"},"text":"Dec. 19, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/129"},"text":"137 Stat. 129","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/25/s1"},"text":"“This Act [amending this section and sections 718a, 718r, and 718s of this title] may be cited as the ‘Duck Stamp Modernization Act of 2023’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id78863a31-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/239/s1"},"text":"Pub. L. 113–239, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2847"},"text":"128 Stat. 2847","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/239/s1"},"text":"“This Act [enacting this subchapter] may be cited as the ‘Permanent Electronic Duck Stamp Act of 2013’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
