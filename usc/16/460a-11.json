{"tag":"section","attrib":{"id":"id77bde06c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460a–11"},"text":null,"children":[{"tag":"num","attrib":{"value":"460a–11"},"text":"§ 460a–11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is hereby authorized to be appropriated, for construction of the Blue Ridge Parkway extension, not more than $87,536,000, plus or minus such amounts, if any, as may be justified by reason of fluctuations in construction costs as indicated by engineering cost indices applicable to the type of construction involved herein.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77bde06d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/555/s6"},"text":"Pub. L. 90–555, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-09"},"text":"Oct. 9, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/968"},"text":"82 Stat. 968","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
