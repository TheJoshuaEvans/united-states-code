{"tag":"section","attrib":{"id":"id7a2eb9ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7808"},"text":null,"children":[{"tag":"num","attrib":{"value":"7808"},"text":"§ 7808.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Territorial participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall ensure participation in the Commission and its subsidiary bodies by American Samoa, Guam, and the Commonwealth of the Northern Mariana Islands to the extent allowed under United States law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a2eb9af-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/327/tII/s208"},"text":"Pub. L. 114–327, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1992"},"text":"130 Stat. 1992","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
