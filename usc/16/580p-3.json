{"tag":"section","attrib":{"id":"id784f723b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s580p–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"580p–3"},"text":"§ 580p–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of royalty fees; special account","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id784f723c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s580p–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may establish and collect use or royalty fees for the manufacture, reproduction, or use of the name or character “Woodsy Owl” and the associated slogan, “Give a Hoot, Don’t Pollute”, as a symbol for a public service campaign to promote wise use of the environment and programs which foster maintenance and improvement of environmental quality.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id784f723d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s580p–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall deposit into a special account all fees collected pursuant to this Act. Such fees are hereby made available for obligation and expenditure for the purpose of furthering the “Woodsy Owl” campaign.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id784f723e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/318/s3"},"text":"Pub. L. 93–318, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-06-22"},"text":"June 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/245"},"text":"88 Stat. 245","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id784f723f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id784f7240-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id784f7241-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/318"},"text":"Pub. L. 93–318","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-06-22"},"text":"June 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/244"},"text":"88 Stat. 244","children":[],"tail":", which enacted sections 580p, 580p–1, 580p–3, and 580p–4 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s711a"},"text":"section 711a of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s580p–2"},"text":"section 580p–2 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s711"},"text":"section 711 of Title 18","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id784f7242-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s488b–5"},"text":"section 488b–5 of Title 31","children":[],"tail":" prior to the general revision and enactment of Title 31, Money and Finance, by "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s1"},"text":"Pub. L. 97–258, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/877"},"text":"96 Stat. 877","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
