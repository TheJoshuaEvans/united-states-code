{"tag":"section","attrib":{"id":"id772c766f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s352"},"text":null,"children":[{"tag":"num","attrib":{"value":"352"},"text":"§ 352.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Game refuge; killing game","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The said park is established as a game refuge, and no person shall kill any game in said park except under an order from the Secretary of the Interior for the protection of persons or to protect or prevent the extermination of other animals or birds.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id772c7670-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-02-26/ch121/s6"},"text":"Feb. 26, 1917, ch. 121, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/939"},"text":"39 Stat. 939","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1928-05-21/ch654/s2"},"text":"May 21, 1928, ch. 654, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/622"},"text":"45 Stat. 622","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id772c7671-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id772c7672-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id772c7673-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1928—Act ","children":[{"tag":"date","attrib":{"date":"1928-05-21"},"text":"May 21, 1928","children":[],"tail":", struck out provision that prospectors and miners could kill game or birds needed for actual necessities when short of food."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
