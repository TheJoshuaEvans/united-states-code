{"tag":"section","attrib":{"id":"id7a38308e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8453"},"text":null,"children":[{"tag":"num","attrib":{"value":"8453"},"text":"§ 8453.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public lands telecommunications cooperative agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a38308f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8453/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements for the Department of the Interior","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may enter into cooperative agreements to carry out activities related to communications sites on lands managed by Federal land management agencies, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a383090-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8453/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administering communications use authorizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a383091-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8453/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparing needs assessments or other programmatic analyses necessary to establish communications sites and authorize communications uses on or adjacent to Federal recreational lands and waters managed by a Federal land management agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a383092-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8453/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing management plans for communications sites on or adjacent to Federal recreational lands and waters managed by a Federal land management agency on a competitively neutral, technology neutral, nondiscriminatory basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a383093-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8453/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training for management of communications sites on or adjacent to Federal recreational lands and waters managed by a Federal land management agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a383094-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8453/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtaining, improving access to, or establishing communications sites on or adjacent to Federal recreational lands and waters managed by a Federal land management agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a383095-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8453/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any combination of purposes described in subparagraphs ","children":[{"tag":"ref","attrib":{"idref":"fn002874"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002874"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “paragraphs”."}],"tail":" (1) through (5)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a383096-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8453/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a383097-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8453/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of rental fee retention authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretary shall conduct a comprehensive assessment to evaluate the potential benefits of rental fee retention whereby any fee collected for the occupancy and use of Federal lands and waters authorized by a communications use authorization would be deposited into a special account and used solely for activities related to communications sites on lands and waters managed by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a383098-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tI/s143"},"text":"Pub. L. 118–234, title I, § 143","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2865"},"text":"138 Stat. 2865","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a383099-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a38309a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a38309b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/s143"},"text":"section 143 of Pub. L. 118–234","children":[],"tail":". Subsec. (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/118/234/s143"},"text":"section 143 of Pub. L. 118–234","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1761a"},"text":"section 1761a of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
