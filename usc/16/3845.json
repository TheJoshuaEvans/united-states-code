{"tag":"section","attrib":{"id":"id79dd8bde-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3845"},"text":null,"children":[{"tag":"num","attrib":{"value":"3845"},"text":"§ 3845.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental services markets","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79dd8bdf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3845/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical guidelines required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish technical guidelines that outline science-based methods to measure the environmental services benefits from conservation and land management activities in order to facilitate the participation of farmers, ranchers, and forest landowners in emerging environmental services markets. The Secretary shall give priority to the establishment of guidelines related to farmer, rancher, and forest landowner participation in carbon markets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79dd8be0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3845/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish guidelines under subsection (a) for use in developing the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79dd8be1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3845/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A procedure to measure environmental services benefits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8be2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3845/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A protocol to report environmental services benefits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8be3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3845/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A registry to collect, record and maintain the benefits measured.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79dd8be4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3845/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Verification requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79dd8be5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3845/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Verification of reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish guidelines for a process to verify that a farmer, rancher, or forest landowner who reports an environmental services benefit pursuant to the protocol required by paragraph (2) of subsection (b) for inclusion in the registry required by paragraph (3) of such subsection has implemented the conservation or land management activity covered by the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8be6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3845/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Role of third parties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In establishing the verification guidelines required by paragraph (1), the Secretary shall consider the role of third-parties in conducting independent verification of benefits produced for environmental services markets and other functions, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79dd8be7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3845/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of existing information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out subsection (b), the Secretary shall build on activities or information in existence on the date of the enactment of the Food, Conservation, and Energy Act of 2008 regarding environmental services markets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79dd8be8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3845/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary shall consult with the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79dd8be9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3845/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal and State government agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8bea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3845/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Nongovernmental interests including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79dd8beb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3845/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" farm, ranch, and forestry producers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dd8bec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3845/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial institutions involved in environmental services trading;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dd8bed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3845/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education with relevant expertise or experience;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dd8bee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3845/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nongovernmental organizations with relevant expertise or experience; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dd8bef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3845/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private sector representatives with relevant expertise or experience.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8bf0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3845/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other interested persons, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79dd8bf1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1245"},"text":"Pub. L. 99–198, title XII, § 1245","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tII/s2709"},"text":"Pub. L. 110–234, title II, § 2709","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1081"},"text":"122 Stat. 1081","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title II, § 2709, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1809.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79dd8bf2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79dd8bf3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79dd8bf4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"he