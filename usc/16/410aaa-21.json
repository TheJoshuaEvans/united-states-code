{"tag":"section","attrib":{"id":"id7765ae47-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–21"},"text":null,"children":[{"tag":"num","attrib":{"value":"410aaa–21"},"text":"§ 410aaa–21.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7765ae48-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–21/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proclamation by President Franklin Roosevelt in 1936 established Joshua Tree National Monument to protect various objects of historical and scientific interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7765ae49-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–21/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Joshua Tree National Monument today is recognized as a major unit of the National Park System, having extraordinary values enjoyed by millions of visitors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7765ae4a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–21/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the monument boundaries as modified in 1950 and 1961 exclude and thereby expose to incompatible development and inconsistent management, contiguous Federal lands of essential and superlative natural, ecological, archeological, paleontological, cultural, historical, and wilderness values;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7765ae4b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–21/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Joshua Tree National Monument should be enlarged by the addition of contiguous Federal lands of national park caliber, and afforded full recognition and statutory protection as a National Park; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7765ae4c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–21/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nondesignated wilderness within Joshua Tree should receive statutory protection by designation pursuant to the Wilderness Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"16 U.S.C. 1131","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7765ae4d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/tIV/s401"},"text":"Pub. L. 103–433, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4487"},"text":"108 Stat. 4487","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7765ae4e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7765ae4f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7765ae50-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Wilderness Act, referred to in par. (5), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/577"},"text":"Pub. L. 88–577","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-09-03"},"text":"Sept. 3, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/890"},"text":"78 Stat. 890","children":[],"tail":", which is classified generally to chapter 23 (§ 1131 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"section 1131 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
