{"tag":"section","attrib":{"id":"id773acdbc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s403h–13"},"text":null,"children":[{"tag":"num","attrib":{"value":"403h–13"},"text":"§ 403h–13.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is hereby authorized to be appropriated for construction of an entrance road on land acquired pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s403h–12"},"text":"section 403h–12 of this title","children":[],"tail":" not more than $2,500,000 (1969 prices), plus or minus such amounts, if any, as may be justified by reason of ordinary fluctuations in construction costs as indicated by engineering cost indexes applicable to the types of construction involved herein."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id773acdbd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/120/s2"},"text":"Pub. L. 88–120, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-09"},"text":"Sept. 9, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/155"},"text":"77 Stat. 155","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/108/s1/3"},"text":"Pub. L. 91–108, § 1(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-11-04"},"text":"Nov. 4, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/183"},"text":"83 Stat. 183","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id773acdbe-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id773acdbf-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id773acdc0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1969—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/108"},"text":"Pub. L. 91–108","children":[],"tail":" substituted appropriations authorization of “$2,500,000 (1969 prices), plus or minus such amounts, if any, as may be justified by reason of ordinary fluctuations in construction costs as indicated by engineering cost indexes applicable to the types of construction involved herein” for prior authorization or “$1,160,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
