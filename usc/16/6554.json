{"tag":"section","attrib":{"id":"id7a0fc082-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6554"},"text":null,"children":[{"tag":"num","attrib":{"value":"6554"},"text":"§ 6554.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applied silvicultural assessments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a0fc083-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6554/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment efforts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For information gathering and research purposes, the Secretary may conduct applied silvicultural assessments on Federal land that the Secretary determines is at risk of infestation by, or is infested with, forest-damaging insects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0fc084-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6554/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0fc085-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6554/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of certain areas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) does not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0fc086-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6554/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a component of the National Wilderness Preservation System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc087-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6554/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Federal land on which, by Act of Congress or Presidential proclamation, the removal of vegetation is restricted or prohibited;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc088-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6554/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a congressionally-designated wilderness study area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc089-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6554/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an area in which activities under subsection (a) would be inconsistent with the applicable land and resource management plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fc08a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6554/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain treatment prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in subsection (a) authorizes the application of insecticides in municipal watersheds or associated riparian areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fc08b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6554/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer review","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0fc08c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6554/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before being carried out, each applied silvicultural assessment under this subchapter shall be peer reviewed by scientific experts selected by the Secretary, which shall include non-Federal experts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc08d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6554/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing peer review processes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may use existing peer review processes to the extent the processes comply with subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0fc08e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6554/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public notice and comment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0fc08f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6554/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide notice of each applied silvicultural assessment proposed to be carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fc090-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6554/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide an opportunity for public comment before carrying out an applied silviculture assessment under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0fc091-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6554/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Categorical exclusion","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0fc092-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6554/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Applied silvicultural assessment and research treatments carried out under this section on not more than 1,000 acres for an assessment or treatment may be categorically excluded from documentation in an environmental impact statement and environmental assessment under the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120983-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6554/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Applied silvicultural assessments and research treatments categorically excluded under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a120984-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6554/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be carried out in an area that is adjacent to another area that is categorically excluded under paragraph (1) that is being treated with similar methods; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a120985-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6554/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be subject to the extraordinary circumstances procedures established by the Secretary pursuant to section 1508.4 of title 40, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120986-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6554/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum categorical exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total number of acres categorically excluded under paragraph (1) shall not exceed 250,000 acres.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120987-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6554/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No additional findings required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with paragraph (1), the Secretary shall not be required to make any findings as to whether an applied silvicultural assessment project, either individually or cumulatively, has a significant effect on the environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a120988-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/148/tIV/s404"},"text":"Pub. L. 108–148, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-03"},"text":"Dec. 3, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1910"},"text":"117 Stat. 1910","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a120989-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a12098a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a12098b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (d)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
