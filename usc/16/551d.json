{"tag":"section","attrib":{"id":"id78438abe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551d"},"text":null,"children":[{"tag":"num","attrib":{"value":"551d"},"text":"§ 551d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wildland firefighter safety","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78438abf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78438ac0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretaries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Secretaries” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78438ac1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551d/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior, acting through the Directors of the Bureau of Land Management, the United States Fish and Wildlife Service, the National Park Service, and the Bureau of Indian Affairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78438ac2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551d/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture, acting through the Chief of the Forest Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78438ac3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wildland firefighter","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “wildland firefighter” means any person who participates in wildland firefighting activities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78438ac4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551d/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the direction of either of the Secretaries; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78438ac5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551d/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under a contract or compact with a federally recognized Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78438ac6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report to Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78438ac7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries shall jointly submit to Congress an annual report on the wildland firefighter safety practices of the Secretaries, including training programs and activities for wildland fire suppression, prescribed burning, and wildland fire use, during the preceding calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78438ac8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timeline","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78438ac9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551d/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be submitted by not later than March of the year following the calendar year covered by the report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78438aca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551d/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78438acb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551d/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of, and any changes to, wildland firefighter safety practices, including training programs and activities for wildland fire suppression, prescribed burning, and wildland fire use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78438acc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551d/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" statistics and trend analyses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78438acd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551d/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the amount of Federal funds expended by the Secretaries on wildland firefighter safety practices, including training programs and activities for wildland fire suppression, prescribed burning, and wildland fire use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78438ace-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551d/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" progress made in implementing recommendations from the Inspector General, the Government Accountability Office, the Occupational Safety and Health Administration, or an agency report relating to a wildland firefighting fatality issued during the preceding 10 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78438acf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551d/b/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id78438ad0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551d/b/2/B/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions relating to wildland firefighter safety practices in any Federal contract or other agreement governing the provision of wildland firefighters by a non-Federal entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78438ad1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551d/b/2/B/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of any actions taken by the Secretaries to ensure that the provisions relating to safety practices, including training, are complied with by the non-Federal entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78438ad2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551d/b/2/B/v/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of those actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78438ad3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tIII/s3101"},"text":"Pub. L. 111–11, title III, § 3101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1127"},"text":"123 Stat. 1127","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
