{"tag":"section","attrib":{"id":"id776a692e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–78"},"text":null,"children":[{"tag":"num","attrib":{"value":"410aaa–78"},"text":"§ 410aaa–78.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to private property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide adequate access to nonfederally owned land or interests in land within the boundaries of the conservation units and wilderness areas designated by this Act which will provide the owner of such land or interest the reasonable use and enjoyment thereof.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id776a692f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/tVII/s708"},"text":"Pub. L. 103–433, title VII, § 708","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4500"},"text":"108 Stat. 4500","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id776a6930-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id776a6931-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id776a6932-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/s3"},"text":"section 3 of Pub. L. 103–433","children":[],"tail":", which is set out as a Definitions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410aaa"},"text":"section 410aaa of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
