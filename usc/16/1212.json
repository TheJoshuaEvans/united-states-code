{"tag":"section","attrib":{"id":"id78f17df0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1212"},"text":null,"children":[{"tag":"num","attrib":{"value":"1212"},"text":"§ 1212.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigation and control of crown of thorns starfish","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In carrying out the purposes of this chapter, the Secretary of Commerce and the Secretary of the Smithsonian Institution are authorized to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78f17df1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1212/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct such studies, research, and investigations, as they deem desirable to determine the causes of the population increase of the “Crown of Thorns”, their effects on corals and coral reefs, and the stability and regeneration of reefs following predation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78f17df2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1212/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to monitor areas where the “Crown of Thorns” may be increasing in numbers and to determine future needs for control;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78f17df3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1212/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop improved methods of control and to carry out programs of control in areas where these are deemed necessary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78f17df4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1212/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to take such other actions as deemed desirable to gain an understanding of the ecology and control of the seastar “Crown of Thorns”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78f17df5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/427/s2"},"text":"Pub. L. 91–427, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-09-26"},"text":"Sept. 26, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/884"},"text":"84 Stat. 884","children":[],"tail":"; 1970 Reorg. Plan No. 4, eff. "},{"tag":"date","attrib":{"date":"1970-10-03"},"text":"Oct. 3, 1970","children":[],"tail":", 35 F.R. 15627, "},{"tag":"ref","attrib":{"href":"/us/stat/84/2090"},"text":"84 Stat. 2090","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78f17df6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id78f17df7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id78f17df8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of functions to Secretary of Commerce from Secretary of the Interior by Reorg. Plan No. 4 of 1970, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1211"},"text":"section 1211 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
