{"tag":"section","attrib":{"id":"id7a35e5f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8304"},"text":null,"children":[{"tag":"num","attrib":{"value":"8304"},"text":"§ 8304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a35e5f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2024-12-11"},"text":"December 11, 2024","children":[],"tail":", and annually thereafter, the Secretary, acting through the Director of the Service, shall submit to the Committees on Appropriations and Natural Resources of the House of Representatives and the Committees on Appropriations and Environment and Public Works of the Senate, and make available to the public on the website of the Service, a report on the Coastal Program carried out under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a35e5fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report submitted under subsection (a) shall assess on regional and nationwide bases—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a35e5fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8304/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coastal Program work on coastal ecosystems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e5fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8304/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" progress made by the Coastal Program toward identifying the leading threats to priority coastal landscapes and conservation actions to address those threats; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e5fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8304/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prospects for, and success of, protecting, restoring, and enhancing coastal ecosystems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a35e5fe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report submitted under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a35e5ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8304/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quantitative information on coastal landscapes protected, restored, or enhanced;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e600-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8304/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds appropriated to the Coastal Program that have been expended or leveraged;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e601-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8304/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of adaptive management practices implemented; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a35e602-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8304/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of emerging challenges or data gaps that hinder the ability of the Coastal Program to achieve the purpose of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a35e603-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/138/s5"},"text":"Pub. L. 118–138, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-11"},"text":"Dec. 11, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1653"},"text":"138 Stat. 1653","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
