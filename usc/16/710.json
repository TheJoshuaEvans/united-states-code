{"tag":"section","attrib":{"id":"id78817eb6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s710"},"text":null,"children":[{"tag":"num","attrib":{"value":"710"},"text":"§ 710.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partial invalidity; short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any clause, sentence, paragraph, or part of this subchapter, which shall be known by the short title of the “Migratory Bird Treaty Act”, shall, for any reason, be adjudged by any court of competent jurisdiction to be invalid, such judgment shall not affect, impair, or invalidate the remainder thereof, but shall be confined in its operation to the clause, sentence, paragraph, or part thereof directly involved in the controversy in which such judgment shall have been rendered.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78817eb7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1918-07-03/ch128"},"text":"July 3, 1918, ch. 128","children":[],"tail":", §§ 1, 10, "},{"tag":"ref","attrib":{"href":"/us/stat/40/755"},"text":"40 Stat. 755","children":[],"tail":", 757.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78817eb8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78817eb9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78817eba-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The provisions of this section relating to short title are from section 1 of act ","children":[{"tag":"date","attrib":{"date":"1918-07-03"},"text":"July 3, 1918","children":[],"tail":", and the provisions relating to severability are from section 10 of that act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78817ebb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id78817ebc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dE/tI/s143/a"},"text":"Pub. L. 108–447, div. E, title I, § 143(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3071"},"text":"118 Stat. 3071","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/447/dE/tI/s143/a"},"text":"“This section [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s703"},"text":"section 703 of this title","children":[],"tail":" and enacting provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s703"},"text":"section 703 of this title","children":[],"tail":"] may be cited as the ‘Migratory Bird Treaty Reform Act of 2004’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id78817ebd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/312/tI/s101"},"text":"Pub. L. 105–312, title I, § 101","c