{"tag":"section","attrib":{"id":"id77930067-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"430g–8"},"text":"§ 430g–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77930068-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–8/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is hereby established the Gettysburg National Military Park Advisory Commission (hereafter in sections 430g–8 to 430g–10 of this title referred to as the “Advisory Commission”). The Advisory Commission shall be composed of eleven members, as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77930069-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–8/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member representing each of the local governments from the four townships surrounding the park and the Borough of Gettysburg, appointed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7793006a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–8/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member representing the Adams County, Pennsylvania government, appointed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7793006b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–8/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member representing the State Historic Preservation Office of the State of Pennsylvania, appointed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7793006c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–8/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two members who are residents of Adams County and who are knowledgeable about the park and its resources, appointed by the Secretary, one of whom shall own land or interests in land within the park boundary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7793006d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–8/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member with expertise in local historic preservation, appointed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7793006e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–8/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Park Service or his designee, ex officio.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Members shall be appointed for staggered terms of three years, as designated by the Secretary at the time of the initial appointments. Any member of the Advisory Commission appointed for a definite term may serve after the expiration of his term until his successor is appointed. The Advisory Commission shall designate one of its members as Chairperson. Six members of the Advisory Commission shall constitute a quorum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7793006f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–8/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management and development issues","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, or his designee, shall from time to time, but at least semiannually, meet and consult with the Advisory Commission to coordinate the management of the park and the historic district with local jurisdictions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77930070-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–8/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Commission shall meet on a regular basis. Notice of meetings and agenda shall be published in local newspapers which have a distribution which generally covers the area affected by the park. Advisory Commission meetings shall be held at locations and in such a manner as to ensure adequate public involvement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77930071-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–8/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Advisory Commission shall serve without compensation as such, but the Secretary may pay expenses reasonably incurred in carrying out their responsibilities under sections 430g–4 to 430g–10 of this title on vouchers signed by the Chairperson.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77930072-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430g–8/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"section 1013 of title 5","children":[],"tail":" are hereby waived with respect to this Advisory Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77930073-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/377/s5"},"text":"Pub. L. 101–377, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-17"},"text":"Aug. 17, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/466"},"text":"104 Stat. 466","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/90"},"text":"Pub. L. 117–286, § 4(a)(90)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4315"},"text":"136 Stat. 4315","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77930074-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77930075-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77930076-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"section 1013 of title 5","children":[],"tail":"” for “section 14 of the Federal Advisory Committee Act (5 U.S.C. App.)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
