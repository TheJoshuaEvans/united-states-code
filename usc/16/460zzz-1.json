{"tag":"section","attrib":{"id":"id780c9c5b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"460zzz–1"},"text":"§ 460zzz–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dominguez-Escalante National Conservation Area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id780c9c5c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780c9c5d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the Dominguez-Escalante National Conservation Area in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9c5e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area included","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Conservation Area shall consist of approximately 209,610 acres of public land, as generally depicted on the Map.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9c5f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Conservation Area are to conserve and protect for the benefit and enjoyment of present and future generations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780c9c60-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the unique and important resources and values of the land, including the geological, cultural, archaeological, paleontological, natural, scientific, recreational, wilderness, wildlife, riparian, historical, educational, and scenic resources of the public land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9c61-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the water resources of area streams, based on seasonally available flows, that are necessary to support aquatic, riparian, and terrestrial species and communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9c62-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780c9c63-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall manage the Conservation Area—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780c9c64-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–1/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a component of the National Landscape Conservation System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9c65-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–1/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner that conserves, protects, and enhances the resources and values of the Conservation Area described in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9c66-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–1/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in accordance with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id780c9c67-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–1/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"43 U.S.C. 1701","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id780c9c68-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–1/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id780c9c69-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–1/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other applicable laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9c6a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780c9c6b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–1/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall allow only such uses of the Conservation Area as the Secretary determines would further the purposes for which the Conservation Area is established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9c6c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–1/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of motorized vehicles","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id780c9c6d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–1/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in clauses (ii) and (iii), use of motorized vehicles in the Conservation Area shall be allowed—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id780c9c6e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–1/c/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before the effective date of the management plan, only on roads and trails designated for use of motor vehicles in the management plan that applies on ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", to the public land in the Conservation Area; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id780c9c6f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–1/c/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the effective date of the management plan, only on roads and trails designated in the management plan for the use of motor vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id780c9c70-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–1/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative and emergency response use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Clause (i) shall not limit the use of motor vehicles in the Conservation Area for administrative purposes or to respond to an emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id780c9c71-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–1/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subparagraph shall not apply to the Wilderness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id780c9c72-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tII/s2402"},"text":"Pub. L. 111–11, title II, § 2402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1102"},"text":"123 Stat. 1102","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id780c9c73-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id780c9c74-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id780c9c75-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Land Policy and Management Act of 1976, referred to in subsec. (c)(1)(C)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579"},"text":"Pub. L. 94–579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2743"},"text":"90 Stat. 2743","children":[],"tail":", which is classified principally to chapter 35 (§ 1701 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
