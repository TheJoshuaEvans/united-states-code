{"tag":"section","attrib":{"id":"id79dd8c30-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3851a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3851a"},"text":"§ 3851a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forest Service participation in ACES Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79dd8c31-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3851a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Chief of the Forest Service, may use funds derived from conservation-related programs executed on National Forest System land to utilize the Agriculture Conservation Experienced Services Program established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3851"},"text":"section 3851 of this title","children":[],"tail":" to provide technical services for conservation-related programs and authorities carried out by the Secretary on National Forest System land."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79dd8c32-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3851a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of effectiveness","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority provided to the Secretary to carry out this section terminates effective ","children":[{"tag":"date","attrib":{"date":"2023-10-01"},"text":"October 1, 2023","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn002773"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002773"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Extension of Forest Service Participation in Aces Program note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79dd8c33-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVIII/s8302"},"text":"Pub. L. 113–79, title VIII, § 8302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/923"},"text":"128 Stat. 923","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVIII/s8622"},"text":"Pub. L. 115–334, title VIII, § 8622","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4853"},"text":"132 Stat. 4853","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79dd8c34-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79dd8c35-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79dd8c36-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Agricultural Act of 2014, and not as part of title XII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":" which comprises this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79dd8c37-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"