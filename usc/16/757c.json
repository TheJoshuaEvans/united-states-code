{"tag":"section","attrib":{"id":"id78921fa4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s757c"},"text":null,"children":[{"tag":"num","attrib":{"value":"757c"},"text":"§ 757c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval for activities on land administered by other Federal departments or agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Activities authorized by sections 757a to 757f of this title to be performed on lands administered by other Federal departments or agencies shall be carried out only with the prior approval of such departments or agencies.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78921fa5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/304/s3"},"text":"Pub. L. 89–304, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-30"},"text":"Oct. 30, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1126"},"text":"79 Stat. 1126","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
