{"tag":"section","attrib":{"id":"id7a0fc030-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551"},"text":null,"children":[{"tag":"num","attrib":{"value":"6551"},"text":"§ 6551.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a0fc031-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0fc032-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" high levels of tree mortality resulting from insect infestation (including the interaction between insects and diseases) may result in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0fc033-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increased fire risk;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc034-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" loss of old trees and old growth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc035-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" loss of threatened and endangered species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc036-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" loss of species diversity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc037-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" degraded watershed conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc038-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increased potential for damage from other agents of disturbance, including exotic, invasive species; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc039-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decreased timber values;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fc03a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0fc03b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forest-damaging insects destroy hundreds of thousands of acres of trees each year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc03c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the West, more than 21,000,000 acres are at high risk of forest-damaging insect infestation, and in the South, more than 57,000,000 acres are at risk across all land ownerships; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc03d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" severe drought conditions in many areas of the South and West will increase the risk of forest-damaging insect infestations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fc03e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the hemlock woolly adelgid is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0fc03f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" destroying streamside forests throughout the mid-Atlantic and Appalachian regions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc040-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" threatening water quality and sensitive aquatic species; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc041-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" posing a potential threat to valuable commercial timber land in northern New England;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fc042-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0fc043-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the emerald ash borer is a nonnative, invasive pest that has quickly become a major threat to hardwood forests because an emerald ash borer infestation is almost always fatal to affected trees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc044-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the emerald ash borer pest threatens to destroy more than 692,000,000 ash trees in forests in Michigan and Ohio alone, and between 5 and 10 percent of urban street trees in the Upper Midwest;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fc045-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0fc046-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" epidemic populations of Southern pine beetles are ravaging forests in Alabama, Arkansas, Florida, Georgia, Kentucky, Mississippi, North Carolina, South Carolina, Tennessee, and Virginia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc047-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in 2001, Florida and Kentucky experienced 146 percent and 111 percent increases, respectively, in Southern pine beetle populations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fc048-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those epidemic outbreaks of Southern pine beetles have forced private landowners to harvest dead and dying trees, in rural areas and increasingly urbanized settings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fc049-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" according to the Forest Service, recent outbreaks of the red oak borer in Arkansas and Missouri have been unprecedented, with more than 1,000,000 acres infested at population levels never seen before;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fc04a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" much of the damage from the red oak borer has taken place in national forests, and the Federal response has been inadequate to protect forest ecosystems and other ecological and economic resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fc04b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0fc04c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" previous silvicultural assessments, while useful and informative, have been limited in scale and scope of application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc04d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there have not been sufficient resources available to adequately test a full array of individual and combined applied silvicultural assessments;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fc04e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only through the full funding, development, and assessment of potential applied silvicultural assessments over specific time frames across an array of environmental and climatic conditions can the most innovative and cost effective management applications be determined that will help reduce the susceptibility of forest ecosystems to attack by forest pests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fc04f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0fc050-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" often, there are significant interactions between insects and diseases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc051-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" many diseases (such as white pine blister rust, beech bark disease, and many other diseases) can weaken trees and forest stands and predispose trees and forest stands to insect attack; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc052-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/11/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certain diseases are spread using insects as vectors (including Dutch elm disease and pine pitch canker); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fc053-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funding and implementation of an initiative to combat forest pest infestations and associated diseases should not come at the expense of supporting other programs and initiatives of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0fc054-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this subchapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0fc055-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require the Secretary to develop an accelerated basic and applied assessment program to combat infestations by forest-damaging insects and associated diseases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fc056-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enlist the assistance of colleges and universities (including forestry schools, land grant colleges and universities, and 1890 Institutions), State agencies, and private landowners to carry out the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fc057-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6551/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out applied silvicultural assessments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0fc058-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/148/tIV/s401"},"text":"Pub. L. 108–148, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-03"},"text":"Dec. 3, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1907"},"text":"117 Stat. 1907","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
