{"tag":"section","attrib":{"id":"id76f0cc91-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s30"},"text":null,"children":[{"tag":"num","attrib":{"value":"30"},"text":"§ 30.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jail building; office of magistrate judge","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall cause to be erected in Yellowstone National Park a suitable building to be used as a jail, and also having in said building an office for the use of the United States magistrate judge.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id76f0cc92-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1894-05-07/ch72/s9"},"text":"May 7, 1894, ch. 72, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/75"},"text":"28 Stat. 75","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/578/tIV/s402/b/2"},"text":"Pub. L. 90–578, title IV, § 402(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-17"},"text":"Oct. 17, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1118"},"text":"82 Stat. 1118","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/650/tIII/s321"},"text":"Pub. L. 101–650, title III, § 321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5117"},"text":"104 Stat. 5117","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id76f0cc93-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id76f0cc94-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial No