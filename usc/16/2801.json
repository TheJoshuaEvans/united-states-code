{"tag":"section","attrib":{"id":"id79a209e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2801"},"text":null,"children":[{"tag":"num","attrib":{"value":"2801"},"text":"§ 2801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings, purpose, and policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79a209e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2801/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a209ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2801/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The harvest of certain species of fish and shellfish exceeds levels of optimum sustainable yield, thereby making it more difficult to meet the increasing demand for aquatic food.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a209eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2801/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To satisfy the domestic market for aquatic food, the United States imports more than 50 per centum of its fish and shellfish, but this dependence on imports adversely affects the national balance of payments and contributes to the uncertainty of supplies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a209ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2801/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Although aquaculture currently contributes approximately 13 percent of world seafood production, less than 6 percent of current United States seafood production results from aquaculture. Domestic aquacultural production, therefore, has the potential for significant growth.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a209ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2801/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Aquacultural production of aquatic plants can provide sources of food, industrial materials, pharmaceuticals, and energy, and can assist in the control and abatement of pollution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a209ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2801/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rehabilitation and enhancement of fish and shellfish resources are desirable applications of aquacultural technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a209ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2801/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The principal responsibility for the development of aquaculture in the United States must rest with the private sector.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a209f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2801/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Despite its potential, the development of aquaculture in the United States has been inhibited by many scientific, economic, legal, and production factors, such as inadequate credit, diffused legal jurisdiction, the lack of management information, the lack of supportive Government policies, and the lack of reliable supplies of seed stock.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a209f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2801/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Many areas of the United States are suitable for aquaculture, but are subject to land-use or water-use management policies that do not adequately consider the potential for aquaculture and may inhibit the development of aquaculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a209f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2801/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this chapter to promote aquaculture in the United States by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a209f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2801/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" declaring a national aquaculture policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a209f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2801/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing and implementing a national aquaculture development plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a209f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2801/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing the Department of Agriculture as the lead Federal agency with respect to the coordination and dissemination of national aquaculture information by designating the Secretary of Agriculture as the permanent chairman of the coordinating group and by establishing a National Aquaculture Information Center within the Department of Agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a209f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2801/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging aquaculture activities and programs in both the public and private sectors of the economy;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"that will result in increased aquacultural production, the coordination of domestic aquaculture efforts, the conservation and enhancement of aquatic resources, the creation of new industries and job opportunities, and other national benefits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a209f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2801/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Congress declares that aquaculture has the potential for reducing the United States trade deficit in fisheries products, for augmenting existing commercial and recreational fisheries and for producing other renewable resources, thereby assisting the United States in meeting its future food needs and contributing to the solution of world resource problems. It is, therefore, in the national interest, and it is the national policy, to encourage the development of aquaculture in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a209f8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/362/s2"},"text":"Pub. L. 96–362, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1198"},"text":"94 Stat. 1198","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVII/s1732"},"text":"Pub. L. 99–198, title XVII, § 1732","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1641"},"text":"99 Stat. 1641","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a209f9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79a209fa-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79a209fb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1985—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1732/1"},"text":"Pub. L. 99–198, § 1732(1)","children":[],"tail":", substituted “13 percent” for “10 per centum” and “6 percent” for “3 per centum”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1732/2"},"text":"Pub. L. 99–198, § 1732(2)","children":[],"tail":", inserted “scientific,” before “economic,” and “the lack of supportive Government policies,” after “management information,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1732/3"},"text":"Pub. L. 99–198, § 1732(3)","children":[],"tail":", added par. (3) and redesignated former par. (3) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1732/4"},"text":"Pub. L. 99–198, § 1732(4)","children":[],"tail":", inserted “or reducing the United States trade deficit in fisheries products,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79a209fc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id79a209fd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVII/s1731"},"text":"Pub. L. 99–198, title XVII, § 1731","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1641"},"text":"99 Stat. 1641","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/198/tXVII/s1731"},"text":"“This subtitle [subtitle C [D] (§§ 1731–1737) of title XVII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":", amending this section and sections 2802 to 2805 and 2809 of this title] may be cited as the ‘National Aquaculture Improvement Act of 1985’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id79a209fe-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/362/s1"},"text":"Pub. L. 96–362, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1198"},"text":"94 Stat. 1198","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/362/s1"},"text":"“That this Act [enacting this chapter] may be cited as the ‘National Aquaculture Act of 1980’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
