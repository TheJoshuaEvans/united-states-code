{"tag":"section","attrib":{"id":"id792ab747-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1416"},"text":null,"children":[{"tag":"num","attrib":{"value":"1416"},"text":"§ 1416.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id792ab748-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1416/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792ab749-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1416/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Consistent with the regulations issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1413"},"text":"section 1413 of this title","children":[],"tail":", the Secretary shall issue a permit to a vessel of the United States authorizing participation in the International Dolphin Conservation Program and may require a permit for the person actually in charge of and controlling the fishing operation of the vessel. The Secretary shall prescribe such procedures as are necessary to carry out this subsection, including requiring the submission of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792ab74a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1416/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and official number or other identification of each fishing vessel for which a permit is sought, together with the name and address of the owner thereof; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792ab74b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1416/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tonnage, hold capacity, speed, processing equipment, and type and quantity of gear, including an inventory of special equipment required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1413"},"text":"section 1413 of this title","children":[],"tail":", with respect to each vessel."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792ab74c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1416/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary is authorized to charge a fee for granting an authorization and issuing a permit under this section. The level of fees charged under this paragraph may not exceed the administrative cost incurred in granting an authorization and issuing a permit. Fees collected under this paragraph shall be available to the Under Secretary of Commerce for Oceans and Atmosphere for expenses incurred in granting authorizations and issuing permits under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792ab74d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1416/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After the effective date of the International Dolphin Conservation Program Act, no vessel of the United States shall operate in the yellowfin tuna fishery in the eastern tropical Pacific Ocean without a valid permit issued under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792ab74e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1416/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permit sanctions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792ab74f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1416/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In any case in which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792ab750-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1416/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel for which a permit has been issued under this section has been used in the commission of an act prohibited under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1417"},"text":"section 1417 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792ab751-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1416/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner or operator of any such vessel or any other person who has applied for or been issued a permit under this section has acted in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1417"},"text":"section 1417 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792ab752-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1416/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any civil penalty or criminal fine imposed on a vessel, owner or operator of a vessel, or other person who has applied for or been issued a permit under this section has not been paid or is overdue,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary may—","children":[],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792ab753-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1416/b/1/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revoke any permit with respect to such vessel, with or without prejudice to the issuance of subsequent permits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792ab754-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1416/b/1/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspend such permit for a period of time considered by the Secretary to be appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792ab755-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1416/b/1/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deny such permit; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792ab756-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1416/b/1/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impose additional conditions or restrictions on any permit issued to, or applied for by, any such vessel or person under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792ab757-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1416/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In imposing a sanction under this subsection, the Secretary shall take into account—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792ab758-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1416/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature, circumstances, extent, and gravity of the prohibited acts for which the sanction is imposed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792ab759-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1416/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the violator, the degree of culpability, any history of prior offenses, and other such matters as justice requires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792ab75a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1416/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transfer of ownership of a vessel, by sale or otherwise, shall not extinguish any permit sanction that is in effect or is pending at the time of transfer of ownership. Before executing the transfer of ownership of a vessel, by sale or otherwise, the owner shall disclose in writing to the prospective transferee the existence of any permit sanction that will be in effect or pending with respect to the vessel at the time of transfer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792ab75b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1416/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of any permit that is suspended for the failure to pay a civil penalty or criminal fine, the Secretary shall reinstate the permit upon payment of the penalty or fine and interest thereon at the prevailing rate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792ab75c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1416/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No sanctions shall be imposed under this section unless there has been a prior opportunity for a hearing on the facts underlying the violation for which the sanction is imposed, either in conjunction with a civil penalty proceeding under this subchapter or otherwise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id792ab75d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522/tIII/s306"},"text":"Pub. L. 92–522, title III, § 306","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/42/s6/c"},"text":"Pub. L. 105–42, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-15"},"text":"Aug. 15, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1135"},"text":"111 Stat. 1135","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id792ab75e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id792ab75f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id792ab760-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of the International Dolphin Conservation Program Act [","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/42"},"text":"Pub. L. 105–42","children":[],"tail":"], referred to in subsec. (a)(3), see "},{"tag":"ref","attrib":{"href":"/us/pl/105/42/s8"},"text":"section 8 of Pub. L. 105–42","children":[],"tail":", set out as an Effective Date of 1997 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1362"},"text":"section 1362 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id792ab761-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1416, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522/tIII/s306"},"text":"Pub. L. 92–522, title III, § 306","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/523/s2/a"},"text":"Pub. L. 102–523, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-26"},"text":"Oct. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3430"},"text":"106 Stat. 3430","children":[],"tail":", related to permits for taking dolphins, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/42/s6/c"},"text":"Pub. L. 105–42, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-15"},"text":"Aug. 15, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1130"},"text":"111 Stat. 1130","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522/s306"},"text":"section 306 of Pub. L. 92–522","children":[],"tail":" was renumbered section 406 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1421e"},"text":"section 1421e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id792ab762-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id792ab763-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/42/s8"},"text":"section 8 of Pub. L. 105–42","children":[],"tail":", set out as an Effective Date of 1997 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1362"},"text":"section 1362 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
