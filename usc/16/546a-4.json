{"tag":"section","attrib":{"id":"id78411a3f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546a–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"546a–4"},"text":"§ 546a–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78411a40-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546a–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of lands within the scenic area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall acquire, by purchase from willing sellers, gift, or exchange, lands, waters, structures, or interests therein, including scenic or other easements, within the boundaries of the scenic area to further the purposes of sections 546 to 546a–5 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78411a41-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546a–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of other lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire, by purchase from willing sellers, gift, or exchange, not more than 10 acres of land, including any improvements thereon, on the mainland to provide access to and administrative facilities for the scenic area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78411a42-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/431/s7"},"text":"Pub. L. 106–431, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-06"},"text":"Nov. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1907"},"text":"114 Stat. 1907","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
