{"tag":"section","attrib":{"id":"id79f7cc02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4915"},"text":null,"children":[{"tag":"num","attrib":{"value":"4915"},"text":"§ 4915.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary $5,000,000 for each of the fiscal years 1993, 1994, and 1995 to carry out this chapter, to remain available until expended.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79f7cc03-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/440/tI/s116"},"text":"Pub. L. 102–440, title I, § 116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2233"},"text":"106 Stat. 2233","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
