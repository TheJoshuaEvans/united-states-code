{"tag":"section","attrib":{"id":"id7784a85e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"410ffff–3"},"text":"§ 410ffff–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of real and personal property and services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7784a85f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Real and personal property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to acquire by donation, exchange, or purchase with donated or appropriated funds, the lands and improvements within the boundaries of the historical park, except that any such lands and improvements owned by the State of Connecticut may be acquired only by donation. The Secretary may also acquire by the same methods personal property associated with, and appropriate for, the interpretation of the historical park: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the Secretary may acquire works of art associated with the Weir family, J. Alden Weir, and other artists who lived at or visited the site only by donation or purchase with donated funds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7784a860-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other property, funds, and services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to accept and use donated funds, property, and services to carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7784a861-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/485/s5"},"text":"Pub. L. 101–485, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-31"},"text":"Oct. 31, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1172"},"text":"104 Stat. 1172","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/305/s2/b/3"},"text":"Pub. L. 116–305, § 2(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4917"},"text":"134 Stat. 4917","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7784a862-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7784a863-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7784a864-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/305"},"text":"Pub. L. 116–305","children":[],"tail":" substituted “historical park” for “historic site” in two places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
