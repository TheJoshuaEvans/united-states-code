{"tag":"section","attrib":{"id":"id7877e1ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s695j–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"695j–1"},"text":"§ 695j–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conformity of contracts with Federal law through negotiation of amendments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is hereby authorized to negotiate amendments to existing contracts to conform said contracts to the provisions of sections 695d to 695j–1 of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7877e200-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-27/ch1012/s8"},"text":"Aug. 27, 1954, ch. 1012, § 8","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/616/s10/b"},"text":"Pub. L. 95–616, § 10(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-08"},"text":"Nov. 8, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3115"},"text":"92 Stat. 3115","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
