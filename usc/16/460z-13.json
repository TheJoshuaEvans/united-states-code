{"tag":"section","attrib":{"id":"id77d364b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460z–13"},"text":null,"children":[{"tag":"num","attrib":{"value":"460z–13"},"text":"§ 460z–13.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated for the acquisition of lands, waters, and interests therein such sums as are necessary, not to exceed $5,750,000. For development of the recreation area, not more than $12,700,000 is authorized to be appropriated.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77d364b3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/260/s15"},"text":"Pub. L. 92–260, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-03-23"},"text":"Mar. 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/102"},"text":"86 Stat. 102","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/578/tIII/s316"},"text":"Pub. L. 94–578, title III, § 316","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2737"},"text":"90 Stat. 2737","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77d364b4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77d364b5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77d364b6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/578"},"text":"Pub. L. 94–578","children":[],"tail":" substituted “There are hereby authorized to be appropriated for the acquisition of lands, waters, and interests therein such sums as are necessary, not to exceed $5,750,000” for “Money appropriated from the Land and Water Conservation Fund shall be available for the acquisition of lands, waters, and interests therein within the recreation area, but not more than $2,500,000 is authorized to be appropriated for such purposes”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
