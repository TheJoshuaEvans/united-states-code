{"tag":"section","attrib":{"id":"id787326d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s673g"},"text":null,"children":[{"tag":"num","attrib":{"value":"673g"},"text":"§ 673g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan for elk restoration and conservation; coordination of Secretary of the Interior with Federal, State and other officers; integration with State plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior, in coordination with all Federal, State, and other officers having jurisdiction over lands on which Tule elk herds are located or lands which would provide suitable Tule elk habitat, shall develop a plan for Tule elk restoration and conservation, including habitat management, which shall be integrated with the comparable plans of State and local authorities in California.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id787326d7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/389/s3"},"text":"Pub. L. 94–389, § 3","children":[],"tail":", formerly § 4, "},{"tag":"date","attrib":{"date":"1976-08-14"},"text":"Aug. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1190"},"text":"90 Stat. 1190","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/375/tI/s108/a"},"text":"Pub. L. 97–375, title I, § 108(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-21"},"text":"Dec. 21, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1820"},"text":"96 Stat. 1820","children":[],"tail":"; renumbered § 3, "},{"tag":"ref","attrib":{"href":"/us/pl/105/362/tIX/s901/b/2"},"text":"Pub. L. 105–362, title IX, § 901(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-10"},"text":"Nov. 10, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3289"},"text":"112 Stat. 3289","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id787326d8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id787326d9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id787326da-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/389/s3"},"text":"section 3 of Pub. L. 94–389","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s673f"},"text":"section 673f of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/362"},"text":"Pub. L. 105–362","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id787326db-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/375"},"text":"Pub. L. 97–375","children":[],"tail":" struck out requirement that the Secretary’s annual report to Congress describe the development and implementation of the plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
