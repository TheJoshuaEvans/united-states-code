{"tag":"section","attrib":{"id":"id79dd8c04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3847"},"text":null,"children":[{"tag":"num","attrib":{"value":"3847"},"text":"§ 3847.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data on conservation practices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79dd8c05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3847/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data on conservation practices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall identify available data sets within the Department of Agriculture regarding the use of conservation practices and the effect of such practices on farm and ranch profitability (including such effects relating to crop yields, soil health, and other risk-related factors).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79dd8c06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3847/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report that includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79dd8c07-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3847/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the data sets identified under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8c08-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3847/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the steps the Secretary would have to take to provide access to such data sets by university researchers, including taking into account any technical, privacy, or administrative considerations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8c09-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3847/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of safeguards the Secretary employs when providing access to data to university researchers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8c0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3847/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of appropriate procedures to maximize the potential for research benefits while preventing any violations of privacy or confidentiality; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dd8c0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3847/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for any necessary authorizations or clarifications of Federal law to allow access to such data sets to maximize the potential for research benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79dd8c0c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1247"},"text":"Pub. L. 99–198, title XII, § 1247","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12618"},"text":"Pub. L. 115–334, title XII, § 12618","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5017"},"text":"132 Stat. 5017","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79dd8c0d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79dd8c0e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id79dd8c0f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3847, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1247"},"text":"Pub. L. 99–198, title XII, § 1247","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIV/s1445"},"text":"Pub. L. 101–624, title XIV, § 1445","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3603"},"text":"104 Stat. 3603","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tII/s204/8"},"text":"Pub. L. 102–237, title II, § 204(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1855"},"text":"105 Stat. 1855","children":[],"tail":", which related to assistance for control of spread of weeds and pests, was omitted in the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
