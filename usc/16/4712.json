{"tag":"section","attrib":{"id":"id79f30f86-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712"},"text":null,"children":[{"tag":"num","attrib":{"value":"4712"},"text":"§ 4712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National ballast water management information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79f30f87-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies on introduction of aquatic nuisance species by vessels","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f30f88-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ballast exchange study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Task Force, in cooperation with the Secretary, shall conduct a study—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f30f89-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assess the environmental effects of ballast water exchange on the diversity and abundance of native species in receiving estuarine, marine, and fresh waters of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f30f8a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify areas within the waters of the United States and the exclusive economic zone, if any, where the exchange of ballast water does not pose a threat of infestation or spread of aquatic nuisance species in the Great Lakes and other waters of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30f8b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biological study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Task Force, in cooperation with the Secretary, shall conduct a study to determine whether aquatic nuisance species threaten the ecological characteristics and economic uses of Lake Champlain and other waters of the United States other than the Great Lakes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30f8c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shipping study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct a study to determine the need for controls on vessels entering waters of the United States, other than the Great Lakes, to minimize the risk of unintentional introduction and dispersal of aquatic nuisance species in those waters. The study shall include an examination of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f30f8d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree to which shipping may be a major pathway of transmission of aquatic nuisance species in those waters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f30f8e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" possible alternatives for controlling introduction of those species through shipping; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f30f8f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the feasibility of implementing regional versus national control measures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f30f90-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ecological and ballast water discharge surveys","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f30f91-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ecological surveys","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f30f92-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Task Force, in cooperation with the Secretary, shall conduct ecological surveys of the Chesapeake Bay, San Francisco Bay, and Honolulu Harbor and, as necessary, of other estuaries of national significance and other waters that the Task Force determines—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f30f93-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be highly susceptible to invasion by aquatic nuisance species resulting from ballast water operations and other operations of vessels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f30f94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require further study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f30f95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for surveys","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the surveys under this paragraph, the Task Force shall, with respect to each such survey—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f30f96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine the attributes and patterns of invasions of aquatic nuisance species; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f30f97-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an estimate of the effectiveness of ballast water management and other vessel management guidelines issued and regulations promulgated under this subchapter in abating invasions of aquatic nuisance species in the waters that are the subject of the survey.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30f98-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ballast water discharge surveys","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f30f99-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with the Task Force, shall conduct surveys of ballast water discharge rates and practices in the waters referred to in paragraph (1)(A) on the basis of the criteria under clauses (i) and (ii) of such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f30f9a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for surveys","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the surveys under this paragraph, the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f30f9b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine the rate of, and trends in, ballast water discharge in the waters that are the subject of the survey; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f30f9c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the effectiveness of voluntary guidelines issued, and regulations promulgated, under this subchapter in altering ballast water discharge practices to reduce the probability of accidental introductions of aquatic nuisance species.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30f9d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Columbia River","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with the Task Force and academic institutions in each of the States affected, shall conduct an ecological and ballast water discharge survey of the Columbia River system consistent with the requirements of paragraphs (1) and (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f30f9e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f30f9f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ballast exchange","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"1990-11-29"},"text":"November 29, 1990","children":[],"tail":", and prior to the effective date of the regulations issued under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4711/b"},"text":"section 4711(b) of this title","children":[],"tail":" (as in effect on the day before "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"December 4, 2018","children":[],"tail":"), the Task Force shall submit a report to the Congress that presents the results of the study required under subsection (a)(1) and makes recommendations with respect to such regulations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30fa0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biological and shipping studies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"1990-11-29"},"text":"November 29, 1990","children":[],"tail":", the Secretary and the Task Force shall each submit to the Congress a report on the results of their respective studies under paragraphs (2) and (3) of subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f30fa1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negotiations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, working through the International Maritime Organization, is encouraged to enter into negotiations with the governments of foreign countries concerning the planning and implementation of measures aimed at the prevention and control of unintentional introductions of aquatic nuisance species in coastal waters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f30fa2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional research grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Out of amounts appropriated to carry out this subsection for a fiscal year, the Under Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f30fa3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available not to exceed $750,000 to fund research on aquatic nuisance species prevention and control in the Chesapeake Bay through grants, to be competitively awarded and subject to peer review, to universities and research institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30fa4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available not to exceed $500,000 to fund research on aquatic nuisance species prevention and control in the Gulf of Mexico through grants, to be competitively awarded and subject to peer review, to universities and research institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30fa5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available not to exceed $500,000 to fund research on aquatic nuisance species prevention and control for the Pacific Coast through grants, to be competitively awarded and subject to peer review, to universities and research institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30fa6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available not to exceed $500,000 to fund research on aquatic nuisance species prevention and control for the Atlantic Coast through grants, to be competitively awarded and subject to peer review, to universities and research institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30fa7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available not to exceed $750,000 to fund research on aquatic nuisance species prevention and control in the San Francisco Bay-Delta Estuary through grants, to be competitively awarded and subject to peer review, to universities and research institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f30fa8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National ballast information clearinghouse","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f30fa9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall develop and maintain, in consultation and cooperation with the Task Force and the Smithsonian Institution (acting through the Smithsonian Environmental Research Center), a clearinghouse of national data concerning—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f30faa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ballasting practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f30fab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with the guidelines issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4711/c"},"text":"section 4711(c) of this title","children":[],"tail":" (as in effect on the day before "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"December 4, 2018","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f30fac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information obtained by the Task Force under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30fad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ballast water reporting requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f30fae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The owner or operator of a vessel subject to this chapter shall submit to the National Ballast Information Clearinghouse, by not later than 6 hours after the arrival of the vessel at a United States port or place of destination, the ballast water management report form approved by the Office of Management and Budget numbered OMB 1625–0069 (or a successor form), unless the vessel is operating exclusively on a voyage between ports or places within contiguous portions of a single Captain of the Port Zone.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f30faf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple discharges","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The owner or operator of a vessel subject to this chapter may submit a single report under subparagraph (A) for multiple ballast water discharges within a single port or place of destination during the same voyage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f30fb0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance report to States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State may require the owner or operator of a vessel subject to this chapter to submit directly to the State, or to an appropriate regional forum, a ballast water management report form—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f30fb1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 24 hours prior to arrival at a United States port or place of destination in the State, if the voyage of the vessel is anticipated to exceed 24 hours; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f30fb2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before departing the port or place of departure, if the voyage of the vessel to the United States port or place of destination is not anticipated to exceed 24 hours.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30fb3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vessel reporting data","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f30fb4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination to States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On receipt of a ballast water management report under paragraph (2), the National Ballast Information Clearinghouse shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f30fb5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a form submitted electronically, immediately disseminate the report to interested States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f30fb6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a form submitted by means other than electronically, disseminate the report to interested States as soon as practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f30fb7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability to public","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the date of receipt of a ballast water management report under paragraph (2), the National Ballast Information Clearinghouse shall make the data in the report fully and readily available to the public in a searchable and fully retrievable electronic format.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30fb8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f30fb9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", and annually thereafter, the Secretary shall prepare and submit a report in accordance with this paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f30fba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under this paragraph shall synthesize and analyze the data described in paragraph (1) for the preceding 2-year period to evaluate nationwide status and trends relating to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f30fbb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ballast water delivery and management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f30fbc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" invasions of aquatic nuisance species resulting from ballast water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f30fbd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prepare each report under this paragraph in consultation and cooperation with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f30fbe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Task Force; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f30fbf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Smithsonian Institution (acting through the Smithsonian Environmental Research Center).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f30fc0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f30fc1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit each report under this paragraph to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79f30fc2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/4/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Task Force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79f30fc3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/4/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce, Science, and Transportation of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79f30fc4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/4/D/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Transportation and Infrastructure of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f30fc5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make each report available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f30fc6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4712/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Working group","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2018-12-04"},"text":"December 4, 2018","children":[],"tail":", the Secretary shall establish a working group, including members from the National Ballast Information Clearinghouse and States with ballast water management programs, to establish a process for compiling and readily sharing Federal and State commercial vessel reporting and enforcement data regarding compliance with this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f30fc7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/646/tI/s1102"},"text":"Pub. L. 101–646, title I, § 1102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4764"},"text":"104 Stat. 4764","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/c"},"text":"Pub. L. 104–332, § 2(c)","children":[],"tail":", (g), (h)(1), "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4081"},"text":"110 Stat. 4081","children":[],"tail":", 4091; "},{"tag":"ref","attrib":{"href":"/us/pl/105/362/tXV/s1502/d"},"text":"Pub. L. 105–362, title XV, § 1502(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-10"},"text":"Nov. 10, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3295"},"text":"112 Stat. 3295","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tIX/s903/a/2/B"},"text":"Pub. L. 115–282, title IX, § 903(a)(2)(B)","children":[],"tail":", (h)(1), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4354"},"text":"132 Stat. 4354","children":[],"tail":", 4362.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79f30fc8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79f30fc9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79f30fca-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4711"},"text":"Section 4711 of this title","children":[],"tail":" (as in effect on the day before "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"December 4, 2018","children":[],"tail":"), referred to in subsecs. (c)(1) and (f)(1)(B), means "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4711"},"text":"section 4711 of this title","children":[],"tail":" as in effect prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tIX/s903/a/2/A/i"},"text":"Pub. L. 115–282, title IX, § 903(a)(2)(A)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4354"},"text":"132 Stat. 4354","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (f)(2), was in the original “this title”, meaning title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/646"},"text":"Pub. L. 101–646","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4761"},"text":"104 Stat. 4761","children":[],"tail":", known as the Nonindigenous Aquatic Nuisance Prevention and Control Act of 1990, which is classified principally to this chapter. For complete classification of title I to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4701"},"text":"section 4701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (f)(5), was in the original “this Act”, which, to reflect the probable intent of Congress, was translated as reading “this title” meaning title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/646"},"text":"Pub. L. 101–646","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4761"},"text":"104 Stat. 4761","children":[],"tail":", known as the Nonindigenous Aquatic Nuisance Prevention and Control Act of 1990, which is classified principally to this chapter. For complete classification of title I to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4701"},"text":"section 4701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79f30fcb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s903/a/2/B/i"},"text":"Pub. L. 115–282, § 903(a)(2)(B)(i)","children":[],"tail":", inserted “(as in effect on the day before "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"December 4, 2018","children":[],"tail":")” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4711/b"},"text":"section 4711(b) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s903/a/2/B/ii"},"text":"Pub. L. 115–282, § 903(a)(2)(B)(ii)","children":[],"tail":", inserted “(as in effect on the day before "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"December 4, 2018","children":[],"tail":")” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4711/c"},"text":"section 4711(c) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s903/h/1"},"text":"Pub. L. 115–282, § 903(h)(1)","children":[],"tail":", added pars. (2) to (5) and struck out former par. (2). Prior to amendment, text of par. (2) read as follows: “In consultation and cooperation with the Task Force and the Smithsonian Institution (acting through the Smithsonian Environmental Research Center), the Secretary shall prepare and submit to the Task Force and the Congress, on a biennial basis, a report that synthesizes and analyzes the data referred to in paragraph (1) relating to—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) ballast water delivery and management; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) invasions of aquatic nuisance species resulting from ballast water.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/362"},"text":"Pub. L. 105–362","children":[],"tail":" substituted “biennial basis” for “biannual basis” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/h/1"},"text":"Pub. L. 104–332, § 2(h)(1)","children":[],"tail":", made technical amendment to "},{"tag":"ref","attrib":{"href":"/us/pl/101/646/s1102"},"text":"Pub. L. 101–646, § 1102","children":[],"tail":", which enacted this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/c/1"},"text":"Pub. L. 104–332, § 2(c)(1)","children":[],"tail":", substituted “management information” for “control program” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/c/2/A"},"text":"Pub. L. 104–332, § 2(c)(2)(A)","children":[],"tail":", inserted “, in cooperation with the Secretary,” before “shall conduct” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/c/2"},"text":"Pub. L. 104–332, § 2(c)(2)","children":[],"tail":", inserted “, in cooperation with the Secretary,” before “shall conduct” and “Lake Champlain and other” after “economic uses of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/c/3"},"text":"Pub. L. 104–332, § 2(c)(3)","children":[],"tail":", added subsec. (b) and struck out heading and text of former subsec. (b). Text read as follows: “The Secretary and the Task Force shall cooperate in conducting their respective studies under this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/g"},"text":"Pub. L. 104–332, § 2(g)","children":[],"tail":", substituted “Congress” for “appropriate Committees” in pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/c/4"},"text":"Pub. L. 104–332, § 2(c)(4)","children":[],"tail":", added subsecs. (e) and (f)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
