{"tag":"section","attrib":{"id":"id79d68716-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23"},"text":null,"children":[{"tag":"num","attrib":{"value":"3839aa–23"},"text":"§ 3839aa–23.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stewardship contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79d68717-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of contract offers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to participate in the conservation stewardship program, a producer shall submit to the Secretary a contract offer for the agricultural operation that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d68718-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates to the satisfaction of the Secretary that the producer, at the time of the contract offer, meets or exceeds the stewardship threshold for at least 2 priority resource concerns; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d68719-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" would, at a minimum, meet or exceed the stewardship threshold for at least 1 additional priority resource concern by the end of the stewardship contract by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d6871a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" installing and adopting additional conservation activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d6871b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving, maintaining, and managing existing conservation activities across the entire agricultural operation in a manner that increases or extends the conservation benefits in place at the time the contract offer is accepted by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d6871c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation of contract offers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d6871d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ranking of applications","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d6871e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In evaluating contract offers submitted under subsection (a) and contract renewals under subsection (e), the Secretary shall rank applications based on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d6871f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the natural resource conservation and environmental benefits that result from the conservation treatment on all applicable priority resource concerns at the time of submission of the application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d68720-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree to which the proposed conservation activities increase natural resource conservation and environmental benefits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d68721-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other consistent criteria, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d68722-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional criterion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If 2 or more applications receive the same ranking under subparagraph (A), the Secretary shall rank those contracts based on the extent to which the actual and anticipated conservation benefits from each contract are provided at the lowest cost relative to other similarly beneficial contract offers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d68723-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not assign a higher priority to any application because the applicant is willing to accept a lower payment than the applicant would otherwise be eligible to receive.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d68724-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may develop and use such additional criteria that the Secretary determines are necessary to ensure that national, State, and local priority resource concerns are effectively addressed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d68725-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entering into contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After a determination that a producer is eligible for a contract or contract renewal under this section, and a determination that the contract or contract renewal offer ranks sufficiently high under the evaluation criteria under subsection (b), the Secretary shall enter into a conservation stewardship contract or contract renewal with the producer to enroll the eligible land to be covered by the contract or contract renewal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d68726-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract provisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d68727-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A conservation stewardship contract shall be for a term of 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d68728-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required provisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The conservation stewardship contract of a producer shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d68729-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state the amount of the payment the Secretary agrees to make to the producer for each year of the conservation stewardship contract under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3839aa–24/c"},"text":"section 3839aa–24(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d6872a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" require the producer—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d6872b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to implement a conservation stewardship plan that describes the program purposes to be achieved through 1 or more conservation activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d6872c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain and supply information as required by the Secretary to determine compliance with the conservation stewardship plan and any other requirements of the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d6872d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not to conduct any activities on the agricultural operation that would tend to defeat the purposes of the program;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d6872e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" permit all economic uses of the eligible land that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d6872f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain the agricultural nature of the land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d68730-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with the conservation purposes of the conservation stewardship contract;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d68731-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a provision to ensure that a producer shall not be considered in violation of the contract for failure to comply with the contract due to circumstances beyond the control of the producer, including a disaster or related condition, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d68732-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include provisions requiring that upon the violation of a term or condition of the contract at any time the producer has control of the land—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d68733-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the Secretary determines that the violation warrants termination of the contract—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79d68734-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/2/E/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the producer shall forfeit all rights to receive payments under the contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79d68735-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/2/E/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the producer shall refund all or a portion of the payments received by the producer under the contract, including any interest on the payments, as determined by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d68736-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary determines that the violation does not warrant termination of the contract, the producer shall refund or accept adjustments to the payments provided to the producer, as the Secretary determines to be appropriate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d68737-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include provisions in accordance with paragraphs (3) and (4); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d68738-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include any additional provisions the Secretary determines are necessary to carry out the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d68739-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Change of interest in land subject to a contract","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d6873a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the time of application, a producer shall have control of the eligible land to be enrolled in the program. Except as provided in subparagraph (B), a change in the interest of a producer in eligible land covered by a contract under the program shall result in the termination of the contract with regard to that land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d6873b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of duties and rights","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subparagraph (A) shall not apply if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d6873c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within a reasonable period of time (as determined by the Secretary) after the date of the change in the interest in eligible land covered by a contract under the program, the transferee of the land provides written notice to the Secretary that all duties and rights under the contract have been transferred to, and assumed by, the transferee for the portion of the land transferred;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d6873d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transferee meets the eligibility requirements of the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d6873e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary approves the transfer of all duties and rights under the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d6873f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification and termination of contracts","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d68740-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary modification or termination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may modify or terminate a contract with a producer if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d68741-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the producer agrees to the modification or termination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d68742-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that the modification or termination is in the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d68743-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Involuntary termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may terminate a contract if the Secretary determines that the producer violated the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d68744-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a contract is terminated, the Secretary may, consistent with the purposes of the program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d68745-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow the producer to retain payments already received under the contract; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d68746-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require repayment, in whole or in part, of payments received and assess liquidated damages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d68747-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract renewal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide the producer an opportunity to renew an existing contract in the first half of the fifth year of the contract period if the producer—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d68748-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates compliance with the terms of the existing contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d68749-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agrees to adopt and continue to integrate new or improved conservation activities across the entire agricultural operation, demonstrating continued improvement during the additional 5-year period, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d6874a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" agrees, by the end of the contract period—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d6874b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to meet the stewardship threshold of at least 2 additional priority resource concerns on the agricultural operation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d6874c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–23/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to adopt or improve conservation activities, as determined by the Secretary, to achieve higher levels of performance with respect to not less than 2 existing priority resource concerns that are specified by the Secretary in the initial contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79d6874d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1240K"},"text":"Pub. L. 99–198, title XII, § 1240K","children":[],"tail":", formerly § 1238F, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tII/s2301/a/2"},"text":"Pub. L. 110–234, title II, § 2301(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1042"},"text":"122 Stat. 1042","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title II, § 2301(a)(2), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1770; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII/s2101/a"},"text":"Pub. L. 113–79, title II, § 2101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/723"},"text":"128 Stat. 723","children":[],"tail":"; renumbered § 1240K and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII"},"text":"Pub. L. 115–334, title II","children":[],"tail":", §§ 2301(b), 2308(c), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4551"},"text":"132 Stat. 4551","children":[],"tail":", 4565.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79d6874e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79d6874f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79d68750-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3838f"},"text":"section 3838f of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79d68751-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2308/c/1"},"text":"Pub. L. 115–334, § 2308(c)(1)","children":[],"tail":", added par. (1) and struck out former par. (1) which provided criteria for ranking of applications."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2308/c/2"},"text":"Pub. L. 115–334, § 2308(c)(2)","children":[],"tail":", substituted “a contract or contract renewal under this section” for “the program under subsection (a)” and inserted “or contract renewal” after “determination that the contract”, after “conservation stewardship contract”, and after “covered by the contract”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2308/c/3"},"text":"Pub. L. 115–334, § 2308(c)(3)","children":[],"tail":", substituted “section 3839aa–24(c)” for “section 3838g(d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2308/c/4/A"},"text":"Pub. L. 115–334, § 2308(c)(4)(A)","children":[],"tail":", substituted “The Secretary may provide the producer an opportunity to renew an existing contract in the first half of the fifth year of the contract period” for “At the end of the initial 5-year contract period, the Secretary may allow the producer to renew the contract for 1 additional 5-year period” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2308/c/4/B"},"text":"Pub. L. 115–334, § 2308(c)(4)(B)","children":[],"tail":", substituted “existing contract” for “initial contract”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2308/c/4/C"},"text":"Pub. L. 115–334, § 2308(c)(4)(C)","children":[],"tail":", inserted “new or improved” before “conservation activities” and “demonstrating continued improvement during the additional 5-year period,” before “as determined by the Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2308/c/4/D"},"text":"Pub. L. 115–334, § 2308(c)(4)(D)","children":[],"tail":", substituted “to adopt or improve conservation activities, as determined by the Secretary, to achieve higher levels of performance with respect to not less than 2” for “to exceed the stewardship threshold of 2”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" amended section generally. Prior to amendment, section related to stewardship contracts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
