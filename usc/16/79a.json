{"tag":"section","attrib":{"id":"id76fa68c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s79a"},"text":null,"children":[{"tag":"num","attrib":{"value":"79a"},"text":"§ 79a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; statement of purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In order to preserve significant examples of the primeval coastal redwood (Sequoia sempervirens) forests and the streams and seashores with which they are associated for purposes of public inspiration, enjoyment, and scientific study, there is hereby established a Redwood National Park in Del Norte and Humboldt Counties, California.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id76fa68c2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/545/s1"},"text":"Pub. L. 90–545, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-02"},"text":"Oct. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/931"},"text":"82 Stat. 931","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id76fa68c3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id76fa68c4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id76fa68c5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/131/tIII/s301"},"text":"Pub. L. 109–131, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-20"},"text":"Dec. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2569"},"text":"119 Stat. 2569","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/131/tIII/s301"},"text":"“This title [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s79b"},"text":"section 79b of this title","children":[],"tail":"] may be cited as the ‘Redwood National Park Boundary Adjustment Act of 2005’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id76fa68c6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Thomas H. Kuchel Visitor Center","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tI/s146"},"text":"Pub. L. 105–277, div. A, § 101(e) [title I, § 146]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–267, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/277/dA/s101/e/tI/s146"},"text":"“The Redwood Information Center located at 119231 Highway 101 in Orick, California is hereby named the ‘Thomas H. Kuchel Visitor Center’ and shall be referred to in any law, document or record of the United States as the ‘Thomas H. Kuchel Visitor Center’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
