{"tag":"section","attrib":{"id":"id798c860b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2001"},"text":null,"children":[{"tag":"num","attrib":{"value":"2001"},"text":"§ 2001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds that:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id798c860c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2001/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is a growing demand on the soil, water, and related resources of the Nation to meet present and future needs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798c860d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2001/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Congress, in its concern for sustained use of the resource base of the United States, has ensured that the Department of Agriculture possesses information, technical expertise, and a delivery system for providing assistance to land users with respect to conservation and use of soils; plants; woodlands; watershed protection and flood prevention; the conservation, development, utilization, and disposal of water; animal husbandry; fish and wildlife management; recreation; community development; and related resource uses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798c860e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2001/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appraisal and inventory of resources, assessment and inventory of conservation needs, evaluation of the effects of conservation practices, and analyses of alternative approaches to existing conservation programs are basic to effective soil, water, and related natural resource conservation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798c860f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2001/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Since individual and governmental decisions concerning soil and water resources often transcend administrative boundaries and affect other programs and decisions, a coordinated appraisal and program framework are essential.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id798c8610-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/192/s2"},"text":"Pub. L. 95–192, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-18"},"text":"Nov. 18, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1407"},"text":"91 Stat. 1407","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s246/f/2/A"},"text":"Pub. L. 103–354, title II, § 246(f)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3225"},"text":"108 Stat. 3225","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tII/s2804/a"},"text":"Pub. L. 110–234, title II, § 2804(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1086"},"text":"122 Stat. 1086","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title II, § 2804(a), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1814.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id798c8611-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id798c8612-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id798c8613-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id798c8614-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s2804/a/1"},"text":"Pub. L. 110–246, § 2804(a)(1)","children":[],"tail":", substituted “base of the” for “base, of the”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s2804/a/2"},"text":"Pub. L. 110–246, § 2804(a)(2)","children":[],"tail":", added par. (3), redesignated former par. (3) as (4), and struck out “Resource appraisal is basic to effective soil and water conservation.” before “Since individual”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" struck out “created the Soil Conservation Service” after “resource base,” and substituted “, has ensured that the Department of Agriculture” for “Department of Agriculture which” after “United States”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id798c8615-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id798c8616-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id798c8617-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/192/s1"},"text":"Pub. L. 95–192, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-18"},"text":"Nov. 18, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1407"},"text":"91 Stat. 1407","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/192/s1"},"text":"“That this Act [enacting this chapter] may be cited as the ‘Soil and Water Resources Conservation Act of 1977’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
