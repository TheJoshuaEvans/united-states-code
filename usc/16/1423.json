{"tag":"section","attrib":{"id":"id792f98e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423"},"text":null,"children":[{"tag":"num","attrib":{"value":"1423"},"text":"§ 1423.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792f98e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Agreement” means the Agreement Between the Government of the United States of America and the Government of the Russian Federation on the Conservation and Management of the Alaska-Chukotka Polar Bear Population, signed at Washington, D.C., on ","children":[{"tag":"date","attrib":{"date":"2000-10-16"},"text":"October 16, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792f98e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alaska Nanuuq Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Alaska Nanuuq Commission” means the Alaska Native entity, in existence on ","children":[{"tag":"date","attrib":{"date":"2007-01-12"},"text":"January 12, 2007","children":[],"tail":", that represents all villages in the State of Alaska that engage in the annual subsistence taking of polar bears from the Alaska-Chukotka population and any successor entity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792f98e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Import","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “import” means to land on, bring into, or introduce into, or attempt to land on, bring into, or introduce into, any place subject to the jurisdiction of the United States, without regard to whether the landing, bringing, or introduction constitutes an importation within the meaning of the customs laws of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792f98e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Polar bear part or product","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “part or product of a polar bear” means any polar bear part or product, including the gall bile and gall bladder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792f98e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792f98e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “taking” has the meaning given the term in the Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792f98e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commission” means the commission established under article 8 of the Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id792f98e8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522/tV/s501"},"text":"Pub. L. 92–522, title V, § 501","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/479/tIX/s902/a"},"text":"Pub. L. 109–479, title IX, § 902(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3660"},"text":"120 Stat. 3660","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
