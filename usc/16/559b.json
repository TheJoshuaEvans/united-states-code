{"tag":"section","attrib":{"id":"id7845d584-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s559b"},"text":null,"children":[{"tag":"num","attrib":{"value":"559b"},"text":"§ 559b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevention of manufacture, etc., of marijuana and other controlled substances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7845d585-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s559b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of sections 559b to 559f of this title is to authorize the Secretary of Agriculture (hereinafter in sections 559b to 559f of this title referred to as the “Secretary”) to take actions necessary, in connection with the administration and use of the National Forest System, to prevent the manufacture, distribution, or dispensing of marijuana and other controlled substances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7845d586-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s559b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law enforcement authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in sections 559b to 559f of this title shall diminish in any way the law enforcement authority of the Forest Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7845d587-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s559b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in sections 559b to 559f of this title, the terms “manufacture”, “dispense”, and “distribute” shall have the same meaning given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"section 802 of title 21","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7845d588-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/tXV/s15002"},"text":"Pub. L. 99–570, title XV, § 15002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-191"},"text":"100 Stat. 3207–191","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7845d589-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7845d58a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7845d58b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 559b to 559f of this title, referred to in text, was in the original “this title”, meaning title XV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570"},"text":"Pub. L. 99–570","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-191"},"text":"100 Stat. 3207–191","children":[],"tail":", known as the National Forest System Drug Control Act of 1986, which enacted sections 559b to 559f of this title, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s841"},"text":"section 841 of Title 21","children":[],"tail":", Food and Drugs, and enacted provisions set out as a note below. For complete classification of title XV to the Code, see Short Title note set out below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7845d58c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7845d58d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/tXV/s15001"},"text":"Pub. L. 99–570, title XV, § 15001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-191"},"text":"100 Stat. 3207–191","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/570/tXV/s15001"},"text":"“This title [enacting this section and sections 559c to 559f of this title and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s841"},"text":"section 841 of Title 21","children":[],"tail":", Food and Drugs] may be cited as the ‘National Forest System Drug Control Act of 1986’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7845d58e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"National Forest System, National Park System, and Bureau of Land Management Public Lands Safety; Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI/s6254/a"},"text":"Pub. L. 100–690, title VI, § 6254(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4363"},"text":"102 Stat. 4363","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/690/tVI/s6254/a"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" National Forest System lands continue to be a haven for the unlawful production of marijuana and other controlled substances, which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" endangers the public in its use of National Forest System lands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interferes with the ability of the Forest Service to effectively manage the natural resources and activities within the National Forest System; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" causes damage and destruction of the natural resources and facilities managed by the Forest Service;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the unlawful production of marijuana and other controlled substances often—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is generally harmful to the environment and public health and safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pollutes the air, soil, and water; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is harmful to wildlife;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Forest Service needs additional authority to adequately deal with the problem of controlled substance production that affects the administration of the National Forest System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Forest Service needs to be able to exercise its investigative authorities outside the boundaries of the National Forest System for drug-related crimes arising from within the National Forest System in order to be effective in deterring such crime;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority and powers of the Forest Service are not intended to be in conflict or interfere with the statutory authority, powers, or responsibilities of any State or political subdivision thereof; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Forest Service, in the exercise of its law enforcement powers, should cooperate to every extent possible with any other Federal, State, or local law enforcement authority having jurisdiction in areas where national forests are located, particularly where coordinated investigative and enforcement actions can be effective to control crime which affects multiple agencies.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
