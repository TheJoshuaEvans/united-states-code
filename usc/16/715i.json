{"tag":"section","attrib":{"id":"id78817f08-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s715i"},"text":null,"children":[{"tag":"num","attrib":{"value":"715i"},"text":"§ 715i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78817f09-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s715i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treaty obligations; rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Areas of lands, waters, or interests therein acquired or reserved pursuant to this subchapter shall, unless otherwise provided by law, be administered by the Secretary of the Interior under rules and regulations prescribed by him to conserve and protect migratory birds in accordance with treaty obligations with Mexico, Canada, Japan, and the Union of Soviet Socialist Republics, and other species of wildlife found thereon, including species that are listed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1533"},"text":"section 1533 of this title","children":[],"tail":" as endangered species or threatened species, and to restore or develop adequate wildlife habitat."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78817f0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s715i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management and public and private agency agreements authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In administering such areas, the Secretary is authorized to manage timber, range, and agricultural crops; to manage other species of animals, including but not limited to fenced range animals, with the objectives of perpetuating, distributing, and utilizing the resources; and to enter into agreements with public and private agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78817f0b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1929-02-18/ch257/s10"},"text":"Feb. 18, 1929, ch. 257, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1224"},"text":"45 Stat. 1224","children":[],"tail":"; 1939 Reorg. Plan No. II, § 4(f), eff. "},{"tag":"date","attrib":{"date":"1939-07-01"},"text":"July 1, 1939","children":[],"tail":", 4 F.R. 2731, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1433"},"text":"53 Stat. 1433","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/669/s7/b"},"text":"Pub. L. 89–669, § 7(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/929"},"text":"80 Stat. 929","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/205/s13/b"},"text":"Pub. L. 93–205, § 13(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-28"},"text":"Dec. 28, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/902"},"text":"87 Stat. 902","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/616/s5/b"},"text":"Pub. L. 95–616, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-08"},"text":"Nov. 8, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3114"},"text":"92 Stat. 3114","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78817f0c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78817f0d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78817f0e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/616"},"text":"Pub. L. 95–616","children":[],"tail":" provided for treaty obligations with Japan and the Union of Soviet Socialist Republics."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/205"},"text":"Pub. L. 93–205","children":[],"tail":" substituted “listed pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1533"},"text":"section 1533 of this title","children":[],"tail":" as endangered species or threatened species,” for “threatened with extinction,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/669"},"text":"Pub. L. 89–669","children":[],"tail":" added subsecs. (a) and (b). Former paragraph prohibited acts on acquired areas and is now covered by section 668dd(c) and (d)(1) of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78817f0f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id78817f10-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1973 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"