{"tag":"section","attrib":{"id":"id788639fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718i"},"text":null,"children":[{"tag":"num","attrib":{"value":"718i"},"text":"§ 718i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of contest fees","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, funds received by the United States Fish and Wildlife Service in the form of fees for entering any Migratory Bird Hunting and Conservation Stamp contest shall be credited—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id788639fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" first, to the appropriation account from which expenditures for the administration of the contest are made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id788639fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" second, to the extent any funds remain, to the Migratory Bird Conservation Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id788639fd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-03-16/ch71/s9"},"text":"Mar. 16, 1934, ch. 71, § 9","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/266/s10/h"},"text":"Pub. L. 109–266, § 10(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-03"},"text":"Aug. 3, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/678"},"text":"120 Stat. 678","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id788639fe-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id788639ff-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id78863a00-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 9 of act ","children":[{"tag":"date","attrib":{"date":"1934-03-16"},"text":"Mar. 16, 1934","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s718"},"text":"section 718 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/109/266/s10/h"},"text":"Pub. L. 109–266, § 10(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-03"},"text":"Aug. 3, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/677"},"text":"120 Stat. 677","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 718i, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1941-06-28/ch259/s1"},"text":"act June 28, 1941, ch. 259, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/356"},"text":"55 Stat. 356","children":[],"tail":", related to disposal of surplus stamps and restricted use of stamps to the fiscal year for which issued prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/act/1956-07-30/ch782/s3/d"},"text":"act July 30, 1956, ch. 782, § 3(d)","children":[],"tail":", formerly § 3(c), "},{"tag":"ref","attrib":{"href":"/us/stat/70/722"},"text":"70 Stat. 722","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/109/266/s10/i/1"},"text":"Pub. L. 109–266, § 10(i)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-03