{"tag":"section","attrib":{"id":"id7832c251-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"539m–3"},"text":"§ 539m–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pueblo rights and interests in the Area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7832c252-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Pueblo shall have the following rights and interests in the Area:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7832c253-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Free and unrestricted access to the Area for traditional or cultural uses, to the extent that those uses are not inconsistent with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7832c254-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–3/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Wilderness Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"16 U.S.C. 1131","children":[],"tail":" et seq.) (including regulations promulgated under that Act) as in effect on "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"February 20, 2003","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7832c255-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–3/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicable Federal wildlife protection laws as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m–4/a/2"},"text":"section 539m–4(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c256-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Perpetual preservation of the national forest and wilderness character of the Area under sections 539m to 539m–12 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c257-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–3/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Rights in the management of the Area as specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m–5"},"text":"section 539m–5 of this title","children":[],"tail":", including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7832c258-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–3/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right to consent or withhold consent to a new use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7832c259-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–3/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right to consultation regarding a modified use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7832c25a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–3/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right to consultation regarding the management and preservation of the Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7832c25b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–3/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right to dispute resolution procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c25c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–3/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Exclusive authority, in accordance with the customs and laws of the Pueblo, to administer access to the Area for traditional or cultural uses by members of the Pueblo and of other federally-recognized Indian tribes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c25d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–3/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other rights and interests as are recognized in subsection (c) and sections 539m–2, 539m–5, 539m–6, and 539m–7 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7832c25e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (a)(4), access to and use of the Area for all other purposes shall continue to be administered by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7832c25f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensable interest","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7832c260-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, by an Act of Congress enacted after ","children":[{"tag":"date","attrib":{"date":"2003-02-20"},"text":"February 20, 2003","children":[],"tail":", Congress diminishes the national forest or wilderness designation of the Area by authorizing a use prohibited by "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m–2/e"},"text":"section 539m–2(e) of this title","children":[],"tail":" in all or any portion of the Area, or denies the Pueblo access for any traditional or cultural use in all or any portion of the Area—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7832c261-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–3/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States shall compensate the Pueblo as if the Pueblo held a fee title interest in the affected portion of the Area and as though the United States had acquired such an interest by legislative exercise of the power of eminent domain; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7832c262-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–3/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the restrictions of sections 539m–2(e) and 539m–4(a) of this title shall be disregarded in determining just compensation owed to the Pueblo.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c263-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any compensation made to the Pueblo under paragraph (c) ","children":[{"tag":"ref","attrib":{"idref":"fn002411"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002411"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be paragraph “(1)”."}],"tail":" shall not affect the extinguishment of claims under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m–8"},"text":"section 539m–8 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7832c264-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dF/tIV/s405"},"text":"Pub. L. 108–7, div. F, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/283"},"text":"117 Stat. 283","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7832c265-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7832c266-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7832c267-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Wilderness Act, referred to in subsec. (a)(1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/577"},"text":"Pub. L. 88–577","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-09-03"},"text":"Sept. 3, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/890"},"text":"78 Stat. 890","children":[],"tail":", which is classified generally to chapter 23 (§ 1131 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"section 1131 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 539m to 539m–12 of this title, referred to in subsec. (a)(2), was in the original “this title”, meaning title IV of div. F of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/279"},"text":"117 Stat. 279","children":[],"tail":", which is classified generally to sections 539m to 539m–12 of this title. For complete classification of title IV to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m"},"text":"section 539m of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
