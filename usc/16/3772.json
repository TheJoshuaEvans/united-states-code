{"tag":"section","attrib":{"id":"id79c5be0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772"},"text":null,"children":[{"tag":"num","attrib":{"value":"3772"},"text":"§ 3772.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79c5be0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal trust species","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal trust species” means migratory birds, threatened species, endangered species, interjurisdictional fish, marine mammals, and other species of concern.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c5be0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Habitat enhancement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79c5be0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “habitat enhancement” means the manipulation of the physical, chemical, or biological characteristics of a habitat to change a specific function or seral stage of the habitat.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c5be0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “habitat enhancement” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79c5be0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an activity conducted to increase or decrease a specific function for the purpose of benefitting species, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79c5be10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the hydroperiod and water depth of a stream or wetland beyond what would naturally occur;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79c5be11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving waterfowl habitat conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79c5be12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/2/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing water level management capabilities for native plant communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79c5be13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/2/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating mud flat conditions important for shorebirds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79c5be14-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/2/B/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cross fencing or establishing a rotational grazing system on native range to improve grassland nesting bird habitat conditions; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79c5be15-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an activity conducted to shift a native plant community successional stage, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79c5be16-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" burning an established native grass community to reduce or eliminate invading brush or exotic species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79c5be17-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" brush shearing to set back early successional plant communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79c5be18-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/2/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forest management that promotes a particular seral stage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c5be19-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “habitat enhancement” does not include regularly scheduled and routine maintenance and management activities, such as annual mowing or spraying of unwanted vegetation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c5be1a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Habitat establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “habitat establishment” means the manipulation of physical, chemical, or biological characteristics of a project site to create and maintain habitat that did not previously exist on the project site, including construction of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79c5be1b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shallow water impoundments on non-hydric soils; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c5be1c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" side channel spawning and rearing habitat.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c5be1d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Habitat improvement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “habitat improvement” means restoring, enhancing, or establishing physiographic, hydrological, or disturbance conditions necessary to establish or maintain native plant and animal communities, including periodic manipulations to maintain intended habitat conditions on completed project sites.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c5be1e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Habitat restoration","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79c5be1f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “habitat restoration” means the manipulation of the physical, chemical, or biological characteristics of a site with the goal of returning the majority of natural functions to the lost or degraded native habitat.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c5be20-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “habitat restoration” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79c5be21-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an activity conducted to return a project site, to the maximum extent practicable, to the ecological condition that existed prior to the loss or degradation, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79c5be22-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/5/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" removing tile drains or plugging drainage ditches in former or degraded wetland;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79c5be23-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/5/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" returning meanders and sustainable profiles to straightened streams;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79c5be24-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/5/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" burning grass communities heavily invaded by exotic species to reestablish native grass and plant communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79c5be25-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/5/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" planting plant communities that are native to the project site;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79c5be26-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if restoration of a project site to its original ecological condition is not practicable, an activity that repairs 1 or more of the original habitat functions and that involve the use of native vegetation, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79c5be27-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/5/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the installation of a water control structure in a swale on land isolated from overbank flooding by a major levee to simulate natural hydrological processes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79c5be28-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/5/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the placement of streambank or instream habitat diversity structures in streams that cannot be restored to original conditions or profile; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79c5be29-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" removal of a disturbing or degrading element to enable the native habitat to reestablish or become fully functional.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c5be2a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private land","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79c5be2b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “private land” means any land that is not owned by the Federal Government or a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c5be2c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “private land” includes tribal land and Hawaiian homeland.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c5be2d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “project” means a project carried out under the Partners for Fish and Wildlife Program established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3773"},"text":"section 3773 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c5be2e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3772/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79c5be2f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/294/s3"},"text":"Pub. L. 109–294, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-03"},"text":"Oct. 3, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1352"},"text":"120 Stat. 1352","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
