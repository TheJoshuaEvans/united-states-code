{"tag":"section","attrib":{"id":"id78863a7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719a"},"text":null,"children":[{"tag":"num","attrib":{"value":"719a"},"text":"§ 719a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Junior Duck Stamp","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78863a7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the Program, the Secretary may annually conduct a competition to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78863a80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solicit the submission by students at elementary and secondary schools of designs relating to conservation of migratory birds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78863a81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select winning designs from among those submissions for use for licensing and marketing under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78863a82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licensing and marketing of design of Junior Duck Stamps","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the Program, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78863a83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" license and market winning designs selected in competitions under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78863a84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" license and market stamps bearing those designs, which shall be known as Junior Duck Stamps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78863a85-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of proceeds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts received under subsection (b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78863a86-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002498"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002498"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Subsec. (c), as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/166"},"text":"Pub. L. 109–166","children":[],"tail":", does not contain a par. (2)."}],"tail":" shall be available to the Secretary until expended, without further appropriations, solely for—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78863a87-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" awards, prizes, and scholarships to individuals who submit designs in competitions under subsection (a), that are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78863a88-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719a/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selected in such a competition as winning designs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78863a89-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719a/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise determined in such a competition to be superior;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78863a8a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" awards and prizes to schools, students, teachers, and other participants to further education activities related to the conservation education goals of the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78863a8b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award ceremonies for winners of national and State Junior Duck Stamp competitions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78863a8c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719a/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" travel expenses for winners of national and State Junior Duck Stamp competitions to award ceremonies, if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78863a8d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719a/c/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the event is intended to honor students for winning a national competition; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78863a8e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719a/c/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the event is intended to honor students for winning a State competition;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78863a8f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719a/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expenses for licensing and marketing under subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78863a90-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719a/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expenses for migratory bird reference materials or supplies awarded to schools that participate in the Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78863a91-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s719a/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expenses for marketing and educational materials developed to promote the Program; ","children":[{"tag":"ref","attrib":{"idref":"fn002499"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002499"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78863a92-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/340/s3"},"text":"Pub. L. 103–340, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-06"},"text":"Oct. 6, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3119"},"text":"108 Stat. 3119","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/166/s2"},"text":"Pub. L. 109–166, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-10"},"text":"Jan. 10, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3576"},"text":"119 Stat. 3576","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78863a93-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78863a94-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78863a95-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/166"},"text":"Pub. L. 109–166","children":[],"tail":" amended heading and text of subsec. (c) generally. Prior to amendment, text read as follows: “Amounts received under subsection (b) of this section—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) shall be available to the Secretary until expended, without further appropriations, solely for—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) awards and scholarships to individuals who submit designs in competitions under subsection (a) of this section, that are—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) selected in such a competition as winning designs; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) otherwise determined in such a competition to be superior;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) awards to schools and other participants to further education activities related to the conservation education goals of the Program; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) expenses for licensing and marketing under subsection (b) of this section; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) may not be used for administrative expenses of the Program.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
