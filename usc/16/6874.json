{"tag":"section","attrib":{"id":"id7a206156-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6874"},"text":null,"children":[{"tag":"num","attrib":{"value":"6874"},"text":"§ 6874.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation and coordination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a206157-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6874/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community partners and third-party providers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of carrying out this chapter, the Secretaries may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a206158-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6874/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" coordinate and partner with non-Federal agencies and private sector and nonprofit partners, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a206159-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6874/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State natural resource agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a20615a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6874/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tribal natural resource agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a20615b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6874/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technology companies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a20615c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6874/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geospatial data companies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a20615d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6874/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experts in data science, analytics, and operations research; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a20615e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6874/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into an agreement with a third party to carry out any provision of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a20615f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6874/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Geological Survey","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries may work with the Director of the United States Geological Survey to collect, aggregate, digitize, standardize, and publish data on behalf of the Secretaries to meet the requirements of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a206160-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6874/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to data developed and distributed under this chapter, the Secretaries shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a206161-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6874/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop the data in accordance with applicable Federal, State, and Tribal laws (including regulations); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a206162-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6874/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a notice that any geospatial data are subject to applicable Federal, State, and Tribal laws (including regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a206163-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6874/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing efforts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent practicable, the Secretary concerned shall use or incorporate existing applicable data, maps, and resources in carrying out this chapter, including data, maps, and resources developed and published under—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a206164-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6874/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Modernizing Access to Our Public Land Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6851"},"text":"16 U.S.C. 6851","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a206165-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6874/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s776"},"text":"section 776 of title 43","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a206166-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6874/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a206167-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/62/s5"},"text":"Pub. L. 119–62, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-26"},"text":"Dec. 26, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1981"},"text":"139 Stat. 1981","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a206168-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a206169-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a20616a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Modernizing Access to Our Public Land Act, referred to in subsec. (d)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/114"},"text":"Pub. L. 117–114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-04-29"},"text":"Apr. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1175"},"text":"136 Stat. 1175","children":[],"tail":", which is classified generally to chapter 87A (§ 6851 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6851"},"text":"section 6851 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
