{"tag":"section","attrib":{"id":"id79155a4e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1336"},"text":null,"children":[{"tag":"num","attrib":{"value":"1336"},"text":"§ 1336.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements; regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to enter into cooperative agreements with other landowners and with the State and local governmental agencies and may issue such regulations as he deems necessary for the furtherance of the purposes of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79155a4f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/195/s6"},"text":"Pub. L. 92–195, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-15"},"text":"Dec. 15, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/650"},"text":"85 Stat. 650","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79155a50-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79155a51-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79155a52-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Contracts and Agreements for Wild Horse and Burro Holding Facilities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74/dE/tI/s114"},"text":"Pub. L. 112–74, div. E, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1009"},"text":"125 Stat. 1009","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/74/dE/tI/s114"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of this Act [div. E of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74"},"text":"Pub. L. 112–74","children":[],"tail":", see Tables for classification], the Secretary of the Interior may enter into multiyear cooperative agreements with nonprofit organizations and other appropriate entities, and may enter into multiyear contracts in accordance with the provisions of section 304B of the Federal Property and Administrative Services Act of 1949 ([former] "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s254c"},"text":"41 U.S.C. 254c","children":[],"tail":") [see "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s3903"},"text":"41 U.S.C. 3903","children":[],"tail":"] (except that the 5-year term restriction in subsection (d) [see "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s3903/a"},"text":"41 U.S.C. 3903(a)","children":[],"tail":"] shall not apply), for the long-term care and maintenance of excess wild free roaming horses and burros by such organizations or entities on private land. Such cooperative agreements and contracts may not exceed 10 years, subject to renewal at the discretion of the Secretary."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During fiscal year 2012 and subsequent fiscal years, in carrying out work involving cooperation with any State or political subdivision thereof, the Bureau of Land Management may record obligations against accounts receivable from any such entities.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/74/dC/tI/s108"},"text":"Pub. L. 119–74, div. C, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-01-23"},"text":"Jan. 23, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/121"},"text":"140 Stat. 121","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/42/dE/tI/s108"},"text":"Pub. L. 118–42, div. E, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-09"},"text":"Mar. 9, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/246"},"text":"138 Stat. 246","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dG/tI/s108"},"text":"Pub. L. 117–328, div. G, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4786"},"text":"136 Stat. 4786","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dG/tI/s108"},"text":"Pub. L. 117–103, div. G, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/375"},"text":"136 Stat. 375","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dG/tI/s108"},"text":"Pub. L. 116–260, div. G, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1504"},"text":"134 Stat. 1504","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dD/tI/s108"},"text":"Pub. L. 116–94, div. D, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2712"},"text":"133 Stat. 2712","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/6/dE/tI/s109"},"text":"Pub. L. 116–6, div. E, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-02-15"},"text":"Feb. 15, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/231"},"text":"133 Stat. 231","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dG/tI/s109"},"text":"Pub. L. 115–141, div. G, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/659"},"text":"132 Stat. 659","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31/dG/tI/s109"},"text":"Pub. L. 115–31, div. G, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/460"},"text":"131 Stat. 460","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dG/tI/s109"},"text":"Pub. L. 114–113, div. G, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18,