{"tag":"section","attrib":{"id":"id77898a4b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423h–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"423h–1"},"text":"§ 423h–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redesignation of park","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Petersburg National Military Park, established under authority of sections 423, 423a, and 423b to 423h of this title, and enlarged pursuant to sections 423a–1 and 423a–2 of this title, is redesignated the Petersburg National Battlefield.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77898a4c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/603/s1"},"text":"Pub. L. 87–603, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-08-24"},"text":"Aug. 24, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/403"},"text":"76 Stat. 403","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
