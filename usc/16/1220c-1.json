{"tag":"section","attrib":{"id":"id78f17e1c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1220c–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1220c–1"},"text":"§ 1220c–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance to State to prepare transferred ship","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78f17e1d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1220c–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, subject to the availability of appropriations, may provide, to any State to which an obsolete ship is transferred under this chapter, financial assistance to prepare the ship for use as an artificial reef, including for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78f17e1e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1220c–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental remediation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78f17e1f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1220c–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" towing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78f17e20-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1220c–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sinking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78f17e21-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1220c–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall determine the amount of assistance under this section with respect to an obsolete ship based on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78f17e22-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1220c–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount available for providing assistance under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78f17e23-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1220c–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the benefit achieved by providing assistance for that ship; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78f17e24-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1220c–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost effectiveness of disposing of the ship by transfer under this chapter and provision of assistance under this section, compared to other disposal options for that ship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78f17e25-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1220c–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78f17e26-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1220c–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall require a State seeking assistance under this section to provide cost data and other information determined by the Secretary to be necessary to justify and document the assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78f17e27-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1220c–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may require a State receiving such assistance to comply with terms and conditions necessary to protect the environment and the interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78f17e28-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1220c–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not provide assistance under this section to a foreign country to which an obsolete ship is transferred under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78f17e29-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/402/s7"},"text":"Pub. L. 92–402, § 7","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dC/tXXXV/s3504/a/1/B"},"text":"Pub. L. 107–314, div. C, title XXXV, § 3504(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2754"},"text":"116 Stat. 2754","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dC/tXXXV/s3513/b"},"text":"Pub. L. 111–84, div. C, title XXXV, § 3513(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2724"},"text":"123 Stat. 2724","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78f17e2a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78f17e2b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id78f17e2c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/402/s7"},"text":"section 7 of Pub. L. 92–402","children":[],"tail":" was renumbered section 8 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1220d"},"text":"section 1220d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78f17e2d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
