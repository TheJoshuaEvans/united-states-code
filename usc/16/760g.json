{"tag":"section","attrib":{"id":"id78922047-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s760g"},"text":null,"children":[{"tag":"num","attrib":{"value":"760g"},"text":"§ 760g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations for migratory game fish study","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated such sums as may be necessary to carry out the provisions of sections 760e to 760g of this title: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That no more than $2,700,000 be appropriated for this purpose in any one fiscal year."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78922048-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/359/s3"},"text":"Pub. L. 86–359, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-22"},"text":"Sept. 22, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/643"},"text":"73 Stat. 643","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
