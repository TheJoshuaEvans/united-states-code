{"tag":"section","attrib":{"id":"id7a3d1226-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8549"},"text":null,"children":[{"tag":"num","attrib":{"value":"8549"},"text":"§ 8549.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost recovery reform","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a3d1227-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8549/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost recovery for special recreation permits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to a fee collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6802"},"text":"section 6802 of this title","children":[],"tail":" or any other authorized fee collected by the Secretary concerned, the Secretary concerned may assess and collect a reasonable fee from an applicant for, or holder of, a special recreation permit to recover administrative costs incurred by the Secretary concerned for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3d1228-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8549/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" processing a proposal or application for the special recreation permit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3d1229-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8549/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issuing the special recreation permit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3d122a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8549/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring the special recreation permit to ensure compliance with the terms and conditions of the special recreation permit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3d122b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8549/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" De minimis exemption from cost recovery","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the administrative costs described in subsection (a) are assessed on an hourly basis, the Secretary concerned shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3d122c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8549/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish an hourly de minimis threshold that exempts a specified number of hours from the assessment and collection of administrative costs described in subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3d122d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8549/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charge an applicant only for any hours that exceed the de minimis threshold.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3d122e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8549/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary concerned collectively processes multiple applications for special recreation permits for the same or similar services in the same unit of Federal recreational lands and waters, the Secretary concerned shall, to the extent practicable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3d122f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8549/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess from the applicants the fee described in subsection (a) on a prorated basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3d1230-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8549/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply the exemption described in subsection (b) to each applicant on an individual basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3d1231-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8549/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary concerned shall not assess or collect administrative costs under this section for a programmatic environmental review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3d1232-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8549/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, the agency processing an application for a special recreation permit shall use existing studies and analysis to reduce the quantity of work and costs necessary to process the application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3d1233-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tIII/s320"},"text":"Pub. L. 118–234, title III, § 320","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2908"},"text":"138 Stat. 2908","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
