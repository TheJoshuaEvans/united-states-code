{"tag":"section","attrib":{"id":"id7727bab8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s284e"},"text":null,"children":[{"tag":"num","attrib":{"value":"284e"},"text":"§ 284e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vested property of United States; status of Foundation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All right, title, and interest in the Center shall be vested in the United States. Nothing in this subchapter shall be construed to provide that the Foundation shall be considered to be a Federal agency or instrumentality for purposes of applying any law or regulation of the United States or of any State.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7727bab9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/671/s6"},"text":"Pub. L. 89–671, § 6","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/310"},"text":"Pub. L. 97–310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-14"},"text":"Oct. 14, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1457"},"text":"96 Stat. 1457","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
