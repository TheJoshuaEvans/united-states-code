{"tag":"section","attrib":{"id":"id7987cb87-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1869"},"text":null,"children":[{"tag":"num","attrib":{"value":"1869"},"text":"§ 1869.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restoration study","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7987cb88-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1869/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may conduct a study to update scientific information and protocols needed to improve restoration techniques for a variety of coast habitat types and synthesize the results in a format easily understandable by restoration practitioners and local communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7987cb89-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1869/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $500,000 for fiscal year 2007 to conduct this study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7987cb8a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265/tIII/s320"},"text":"Pub. L. 94–265, title III, § 320","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/479/tII/s206"},"text":"Pub. L. 109–479, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3615"},"text":"120 Stat. 3615","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
