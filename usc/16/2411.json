{"tag":"section","attrib":{"id":"id799adddb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2411"},"text":null,"children":[{"tag":"num","attrib":{"value":"2411"},"text":"§ 2411.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal agency cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each Federal department or agency whose activities affect Antarctica shall utilize, to the maximum extent practicable, its authorities in furtherance of the purposes of this chapter, and shall cooperate with the Director in carrying out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id799adddc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/541/s12"},"text":"Pub. L. 95–541, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-28"},"text":"Oct. 28, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2056"},"text":"92 Stat. 2056","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
