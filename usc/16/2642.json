{"tag":"section","attrib":{"id":"id79a2095f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2642"},"text":null,"children":[{"tag":"num","attrib":{"value":"2642"},"text":"§ 2642.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79a20960-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2642/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may periodically notify the State regulatory authorities, and electric utilities identified pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2612/c"},"text":"section 2612(c) of this title","children":[],"tail":", of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a20961-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2642/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" load management techniques and the results of studies and experiments concerning load management techniques;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a20962-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2642/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developments and innovations in electric utility ratemaking throughout the United States, including the results of studies and experiments in rate structure and rate reform;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a20963-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2642/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods for determining cost of service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a20964-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2642/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other data or information which the Secretary determines would assist such authorities and utilities in carrying out the provisions of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a20965-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2642/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technologies, techniques, and rate-making methods related to advanced metering and communications and the use of these technologies, techniques and methods in demand response programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a20966-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2642/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide such technical assistance as he determines appropriate to assist the State regulatory authorities in carrying out their responsibilities under subchapter II and as is requested by any State regulatory authority relating to the standards established by subchapter II.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a20967-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2642/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out the purposes of subsection (b) not to exceed $1,000,000 for each of the fiscal years 1979 and 1980.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a20968-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2642/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demand response","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall be responsible for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a20969-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2642/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educating consumers on the availability, advantages, and benefits of advanced metering and communications technologies, including the funding of demonstration or pilot projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a2096a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2642/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" working with States, utilities, other energy providers and advanced metering and communications experts to identify and address barriers to the adoption of demand response programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a2096b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2642/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", providing Congress with a report that identifies and quantifies the national benefits of demand response and makes a recommendation on achieving specific levels of such benefits by "},{"tag":"date","attrib":{"date":"2007-01-01"},"text":"January 1, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a2096c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617/tI/s132"},"text":"Pub. L. 95–617, title I, § 132","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3131"},"text":"92 Stat. 3131","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXII/s1252/c"},"text":"Pub. L. 109–58, title XII, § 1252(c)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/965"},"text":"119 Stat. 965","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a2096d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79a2096e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79a2096f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(4), was in the original “this title”, meaning title I (§ 101 et seq.) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617"},"text":"Pub. L. 95–617","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3120"},"text":"92 Stat. 3120","children":[],"tail":", which enacted subchapters I to IV of this chapter and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6808"},"text":"section 6808 of Title 42","children":[],"tail":", The Public Health and Welfare, and amended sections 6802 to 6807 of Title 42. For complete classification of title I to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79a20970-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1252/c"},"text":"Pub. L. 109–58, § 1252(c)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1252/d"},"text":"Pub. L. 109–58, § 1252(d)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79a20971-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79a20972-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Demand Response Assistance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXII/s1252/e"},"text":"Pub. L. 109–58, title XII, § 1252(e)","children":[],"tail":", (f), "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/965"},"text":"119 Stat. 965","children":[],"tail":", 966, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/58/tXII/s1252/e"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Demand Response and Regional Coordination.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It is the policy of the United States to encourage States to coordinate, on a regional basis, State energy policies to provide reliable and affordable demand response services to the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Technical assistance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary [of Energy] shall provide technical assistance to States and regional organizations formed by two or more States to assist them in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying the areas with the greatest demand response potential;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying and resolving problems in transmission and distribution networks, including through the use of demand response;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing plans and programs to use demand response to respond to peak demand or emergency needs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying specific measures consumers can take to participate in these demand response programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of enactment of the Energy Policy Act of 2005 [","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":"], the [Federal Energy Regulatory] Commission shall prepare and publish an annual report, by appropriate region, that assesses demand response resources, including those available from all consumer classes, and which identifies and reviews—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" saturation and penetration rate of advanced meters and communications technologies, devices and systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing demand response programs and time-based rate programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the annual resource contribution of demand resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential for demand response as a quantifiable, reliable resource for regional planning purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" steps taken to ensure that, in regional transmission planning and operations, demand resources are provided equitable treatment as a quantifiable, reliable resource relative to the resource obligations of any load-serving entity, transmission provider, or transmitting party; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"“(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulatory barriers to improve customer participation in demand response, peak reduction and critical period pricing programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Encouragement of Demand Response Devices","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It is the policy of the United States that time-based pricing and other forms of demand response, whereby electricity customers are provided with electricity price signals and the ability to benefit by responding to them, shall be encouraged, the deployment of such technology and devices that enable electricity customers to participate in such pricing and demand response systems shall be facilitated, and unnecessary barriers to demand response participation in energy, capacity and ancillary service markets shall be eliminated. It is further the policy of the United States that the benefits of such demand response that accrue to those not deploying such technology and devices, but who are part of the same regional electricity entity, shall be recognized.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
