{"tag":"section","attrib":{"id":"id778bd458-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s426g"},"text":null,"children":[{"tag":"num","attrib":{"value":"426g"},"text":"§ 426g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Occupation of lands by former owners","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to enter into agreements, upon such nominal terms as he may prescribe, with such present owners of the land as may desire to remain upon it, to occupy and cultivate their present holdings, upon condition that they will preserve the present buildings and roads, and the present outlines of field and forest, and that they will only cut trees or underbrush under such regulations as the Secretary may prescribe, and that they will assist in caring for and protecting all tablets, monuments, or such other artificial works as may from time to time be erected by proper authority.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id778bd459-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-03/ch374/s8"},"text":"Mar. 3, 1927, ch. 374, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1400"},"text":"44 Stat. 1400","children":[],"tail":"; Ex. Ord. No. 6166, § 2, "},{"tag":"date","attrib":{"date":"1933-06-10"},"text":"June 10, 1933","children":[],"tail":"; Ex. Ord. No. 6228, § 1, "},{"tag":"date","attrib":{"date":"1933-07-28"},"text":"July 28, 1933","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id778bd45a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id778bd45b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id778bd45c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of administrative functions of park, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s426"},"text":"section 426 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
