{"tag":"section","attrib":{"id":"id77fbfad1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–21"},"text":null,"children":[{"tag":"num","attrib":{"value":"460lll–21"},"text":"§ 460lll–21.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land and resource management plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77fbfad2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–21/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after the effective date of the transfer of jurisdiction under section 460","children":[{"tag":"i","attrib":{},"text":"lll","children":[],"tail":"–41 of this title, the Secretary shall prepare a land and resource management plan for the Recreation Area in conformity with the National Forest Management Act of 1976 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s472a"},"text":"16 U.S.C. 472a","children":[],"tail":" et seq.) and other applicable law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfad3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–21/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Until adoption of the land and resource management plan, the Secretary may use, as appropriate, the existing Tennessee Valley Authority Natural Resource Management Plan to provide interim management direction. Use of all or a portion of the management plan by the Secretary shall not be considered to be a major Federal action significantly affecting the quality of the human environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77fbfad4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tV/s521"},"text":"Pub. L. 105–277, div. A, § 101(e) [title V, § 521]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–314.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77fbfad5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77fbfad6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77fbfad7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Forest Management Act of 1976, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/588"},"text":"Pub. L. 94–588","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-22"},"text":"Oct. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2949"},"text":"90 Stat. 2949","children":[],"tail":", which enacted sections 472a, 521b, 1600, and 1611 to 1614 of this title, amended sections 500, 515, 516, 518, 576b, and 1601 to 1610 of this title, repealed sections 476, 513, and 514 of this title, and enacted provisions set out as notes under sections 476, 513, 528, 594–2, and 1600 of this title. For complete classification of this Act to the Code, see Short Title of 1976 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1600"},"text":"section 1600 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
