{"tag":"section","attrib":{"id":"id7832c268-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"539m–4"},"text":"§ 539m–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on Pueblo rights and interests in the Area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7832c269-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The rights and interests of the Pueblo recognized in sections 539m to 539m–12 of this title do not include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7832c26a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–4/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any right to sell, grant, lease, convey, encumber, or exchange land or any interest in land in the Area (and any such conveyance shall not have validity in law or equity);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c26b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–4/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any exemption from applicable Federal wildlife protection laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c26c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–4/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any right to engage in a use prohibited by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m–2/e"},"text":"section 539m–2(e) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c26d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–4/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any right to exclude persons or governmental entities from the Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7832c26e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person who exercises traditional or cultural use rights as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m–3/a/4"},"text":"section 539m–3(a)(4) of this title","children":[],"tail":" may be prosecuted for a Federal wildlife offense requiring proof of a violation of a State law (including regulations)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7832c26f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dF/tIV/s406"},"text":"Pub. L. 108–7, div. F, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/284"},"text":"117 Stat. 284","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7832c270-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7832c271-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7832c272-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 539m to 539m–12 of this title, referred to in subsec. (a), was in the original “this title”, meaning title IV of div. F of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/279"},"text":"117 Stat. 279","children":[],"tail":", which is classified generally to sections 539m to 539m–12 of this title. For complete classification of title IV to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m"},"text":"section 539m of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
