{"tag":"section","attrib":{"id":"id78d4f56c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s935"},"text":null,"children":[{"tag":"num","attrib":{"value":"935"},"text":"§ 935.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of real property; construction and operation of lamprey control works; entry into agreements for construction and operation of works","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In order to carry out the obligations of the United States under the Convention, the United States Section is authorized—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78d4f56d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s935/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire any real property, or any interest therein, by purchase, exchange, gift, dedication, condemnation, or otherwise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78d4f56e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s935/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to construct, operate, and maintain any project or works designed to facilitate compliance with the provisions of the Convention relating to the sea lamprey control program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78d4f56f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s935/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enter into contract or agreement with any State or other public agency or private agency or individual for the construction, operation, or maintenance of any such project or works.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78d4f570-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-06-04/ch358/s6"},"text":"June 4, 1956, ch. 358, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/243"},"text":"70 Stat. 243","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78d4f571-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78d4f572-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78d4f573-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"United States Fish and Wildlife Service; Work on Sea Lamprey Program; Reimbursements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/512/tI"},"text":"Pub. L. 101–512, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1918"},"text":"104 Stat. 1918","children":[],"tail":", provided in part that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/512/tI"},"text":"“beginning ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"October 1, 1990","children":[],"tail":", and thereafter, the United States Fish and Wildlife Service can perform work for the Great Lakes Fishery Commission, authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s931–939c"},"text":"16 U.S.C. 931–939c","children":[],"tail":", Great Lakes Fisheries [Fishery] Act of 1956, on the sea lamprey program on a reimbursable basis: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That such reimbursements are to be treated as Intragovernmental funds as defined in the publication titled ‘A Glossary of Terms Used in the Federal Budget Process’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
