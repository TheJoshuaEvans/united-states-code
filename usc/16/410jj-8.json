{"tag":"section","attrib":{"id":"id7759c7a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jj–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"410jj–8"},"text":"§ 410jj–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reevaluation of management, etc., policies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"At such time when there is no longer a resident patient community at Kalaupapa, the Secretary shall reevaluate the policies governing the management, administration, and public use of the park in order to identify any changes deemed to be appropriate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7759c7a6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/565/tI/s109"},"text":"Pub. L. 96–565, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3324"},"text":"94 Stat. 3324","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
