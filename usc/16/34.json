{"tag":"section","attrib":{"id":"id76f0cca9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s34"},"text":null,"children":[{"tag":"num","attrib":{"value":"34"},"text":"§ 34.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Road extensions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Road extensions and improvements shall be made in the Yellowstone National Park under and in harmony with the general plan of roads and improvements to be approved by the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id76f0ccaa-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1918-07-01/ch113/s1"},"text":"July 1, 1918, ch. 113, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/678"},"text":"40 Stat. 678","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
