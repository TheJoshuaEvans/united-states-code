{"tag":"section","attrib":{"id":"id77fbfaff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–24"},"text":null,"children":[{"tag":"num","attrib":{"value":"460lll–24"},"text":"§ 460lll–24.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of receipts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77fbfb00-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–24/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All amounts received from charges, use fees, and natural resource utilization, including timber and agricultural receipts, shall be deposited in a special fund in the Treasury of the United States to be known as the “Land Between the Lakes Management Fund”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfb01-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–24/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the Land Between the Lakes Management Fund shall be available to the Secretary until expended, without further appropriation, for construction, improvement, or maintenance in the Recreation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77fbfb02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–24/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on use of Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), amounts in the Land Between the Lakes Management Fund shall not be used for management of the Recreation Area, including salaries and expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77fbfb03-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tV/s524"},"text":"Pub. L. 105–277, div. A, § 101(e) [title V, § 524]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–315; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dDD/tII/s201/e"},"text":"Pub. L. 117–328, div. DD, title II, § 201(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5582"},"text":"136 Stat. 5582","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77fbfb04-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77fbfb05-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77fbfb06-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" added subsecs. (b) and (c) and struck out former subsec. (b). Prior to amendment, text of subsec. (b) read as follows: “Amounts in the Fund shall be available to the Secretary until expended, without further Act of appropriation, for the management of the Recreation Area, including payment of salaries and expenses.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
