{"tag":"section","attrib":{"id":"id77681fef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–74"},"text":null,"children":[{"tag":"num","attrib":{"value":"410aaa–74"},"text":"§ 410aaa–74.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management of newly acquired lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any lands within the boundaries of a wilderness area designated under this Act which are acquired by the Federal Government, shall become part of the wilderness area within which they are located and shall be managed in accordance with all the provisions of this Act and other laws applicable to such wilderness area.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77681ff0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/tVII/s704"},"text":"Pub. L. 103–433, title VII, § 704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4497"},"text":"108 Stat. 4497","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77681ff1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77681ff2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77681ff3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/s3"},"text":"section 3 of Pub. L. 103–433","children":[],"tail":", which is set out as a Definitions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410aaa"},"text":"section 410aaa of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
