{"tag":"section","attrib":{"id":"id79e26ee3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3921"},"text":null,"children":[{"tag":"num","attrib":{"value":"3921"},"text":"§ 3921.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National wetlands priority conservation plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79e26ee4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3921/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish, and periodically review and revise, a national wetlands priority conservation plan which shall specify, on a region-by-region basis or other basis considered appropriate by the Secretary, the types of wetlands and interests in wetlands which should be given priority with respect to Federal and State acquisition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e26ee5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3921/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish the plan required by subsection (a) after consultation with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e4b7d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3921/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Environmental Protection Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e4b7d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3921/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e4b7d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3921/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e4b7d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3921/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" (the chief executive officer of) each State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e4b7da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3921/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors to be considered","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in establishing the plan required by subsection (a), shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e4b7db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3921/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated proportion remaining of the respective types of wetlands which existed at the time of European settlement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e4b7dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3921/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated current rate of loss and the threat of future losses of the respective types of wetlands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e4b7dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3921/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the contributions of the respective types of wetlands to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e4b7de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3921/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wildlife, including endangered and threatened species, migratory birds, and resident species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e4b7df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3921/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commercial and sport fisheries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e4b7e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3921/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" surface and ground water quality and quantity, and flood control;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e4b7e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3921/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outdoor recreation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e4b7e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3921/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other areas or concerns the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79e4b7e3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/645/tIII/s301"},"text":"Pub. L. 99–645, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3586"},"text":"100 Stat. 3586","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
