{"tag":"section","attrib":{"id":"id7746b4a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r"},"text":null,"children":[{"tag":"num","attrib":{"value":"410r"},"text":"§ 410r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lands acquired as part of park; rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All lands and submerged lands title to which is accepted by the Secretary of the Interior pursuant to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410q"},"text":"section 410q of this title","children":[],"tail":" shall, upon the acceptance of title thereto, become parts of the Everglades National Park and shall be subject to all laws and regulations applicable thereto."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7746b4a4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/269/s2"},"text":"Pub. L. 86–269, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-14"},"text":"Sept. 14, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/554"},"text":"73 Stat. 554","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
