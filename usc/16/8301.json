{"tag":"section","attrib":{"id":"id7a35e5c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8301"},"text":null,"children":[{"tag":"num","attrib":{"value":"8301"},"text":"§ 8301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purpose of this chapter is to legislatively authorize the Coastal Program of the Service in effect as of ","children":[{"tag":"date","attrib":{"date":"2024-12-11"},"text":"December 11, 2024","children":[],"tail":", to conduct collaborative landscape-level planning and on-the-ground coastal habitat assessment, coastal habitat protection, coastal habitat restoration, and coastal habitat enhancement projects in priority coastal landscapes to conserve and recover Federal trust species."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a35e5c2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/138/s2"},"text":"Pub. L. 118–138, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-11"},"text":"Dec. 11, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1651"},"text":"138 Stat. 1651","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a35e5c3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a35e5c4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a35e5c5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/138/s1"},"text":"Pub. L. 118–138, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-11"},"text":"Dec. 11, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1651"},"text":"138 Stat. 1651","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/138/s1"},"text":"“This Act [enacting this chapter] may be cited as the ‘Coastal Habitat Conservation Act of 2023’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
