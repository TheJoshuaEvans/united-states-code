{"tag":"section","attrib":{"id":"id7987caf3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1861b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1861b"},"text":"§ 1861b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fisheries enforcement plans and reporting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7987caf4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1861b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fisheries enforcement plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In preparing the Coast Guard’s annual fisheries enforcement plan, the Commandant of the Coast Guard shall consult with the Under Secretary of Commerce for Oceans and Atmosphere and with State and local enforcement authorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7987caf5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1861b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fishery patrols","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to undertaking fisheries patrols, the Commandant of the Coast Guard shall notify the Under Secretary of Commerce for Oceans and Atmosphere and appropriate State and local enforcement authorities of the projected dates for such patrols.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7987caf6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1861b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual summary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commandant of the Coast Guard shall prepare and make available to the Under Secretary of Commerce for Oceans and Atmosphere, State and local enforcement entities, and other relevant stakeholders, an annual summary report of fisheries enforcement activities for the preceding year, including a summary of the number of patrols, law enforcement actions taken, and resource hours expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7987caf7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293/tII/s224"},"text":"Pub. L. 108–293, title II, § 224","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1040"},"text":"118 Stat. 1040","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7987caf8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7987caf9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7987cafa-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Coast Guard and Maritime Transportation Act of 2004, and not as part of the Magnuson-Stevens Fishery Conservation and Management Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7987cafb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7987cafc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirement","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provision terminating reporting requirement under this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/207/s4/b"},"text":"section 4(b) of Pub. L. 111–207","children":[],"tail":", set out as a Combination of Fisheries Enforcement Plans and Foreign Fishing Incursion Reports note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1828"},"text":"section 1828 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
