{"tag":"section","attrib":{"id":"id77825df0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"410eeee–8"},"text":"§ 410eeee–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General management plan; submission to Congressional committees","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Within three years from ","children":[{"tag":"date","attrib":{"date":"1978-11-10"},"text":"November 10, 1978","children":[],"tail":", the Secretary shall develop and transmit to the Senate Committee on Energy and Natural Resources and the House Committee on Interior and Insular Affairs, a general management plan for the protection and development of the national river consistent with the purposes of this subchapter, indicating—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id77825df1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee–8/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measures for the preservation of the area’s resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77825df2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee–8/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indications of types and general intensities of development (including visitor circulation and transportation patterns, systems and modes) associated with public enjoyment and use of the area, including general locations, timing of implementation, and anticipated costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77825df3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee–8/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of and implementation commitments for visitor carrying capacities for all areas of the unit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77825df4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410eeee–8/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indications of potential modifications to the external boundaries of the unit, and the reasons therefor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77825df5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625/tXI/s1109"},"text":"Pub. L. 95–625, title XI, § 1109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3548"},"text":"92 Stat. 3548","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77825df6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77825df7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77825df8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460m–22"},"text":"section 460m–22 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77825df9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading"