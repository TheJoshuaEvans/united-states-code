{"tag":"section","attrib":{"id":"id7a120a02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6576"},"text":null,"children":[{"tag":"num","attrib":{"value":"6576"},"text":"§ 6576.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protections and measures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a120a03-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6576/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protections","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a landowner that enrolls land in the program and whose conservation activities result in a net conservation benefit for listed, candidate, or other species, the Secretary of Agriculture shall make available to the landowner safe harbor or similar assurances and protection under—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a120a04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6576/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1536/b/4"},"text":"section 1536(b)(4) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a120a05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6576/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1539/a/1"},"text":"section 1539(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a120a06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6576/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Measures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If protection under subsection (a) requires the taking of measures that are in addition to the measures covered by the applicable restoration plan agreed to under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6573"},"text":"section 6573 of this title","children":[],"tail":", the cost of the additional measures, as well as the cost of any permit, shall be considered part of the restoration plan for purposes of financial assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6574"},"text":"section 6574 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a120a07-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/148/tV/s506"},"text":"Pub. L. 108–148, title V, § 506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-03"},"text":"Dec. 3, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1914"},"text":"117 Stat. 1914","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
