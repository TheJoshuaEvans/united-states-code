{"tag":"section","attrib":{"id":"id772c7659-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s349"},"text":null,"children":[{"tag":"num","attrib":{"value":"349"},"text":"§ 349.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights-of-way","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever consistent with the primary purposes of Denali National Park, the Act of February fifteenth, nineteen hundred and one,","children":[{"tag":"ref","attrib":{"idref":"fn002067"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002067"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" applicable to the location of rights of way in certain national parks and national forests for irrigation and other purposes, shall be and remain applicable to the lands included within the park."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id772c765a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-02-26/ch121/s3"},"text":"Feb. 26, 1917, ch. 121, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/938"},"text":"39 Stat. 938","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/487/tII/s202/3/a"},"text":"Pub. L. 96–487, title II, § 202(3)(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-02"},"text":"Dec. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2382"},"text":"94 Stat. 2382","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id772c765b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id772c765c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id772c765d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Act of February fifteenth, nineteen hundred and one, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1901-02-15/ch372"},"text":"act Feb. 15, 1901, ch. 372","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/31/790"},"text":"31 Stat. 790","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s959"},"text":"section 959 of Title 43","children":[],"tail":", Public Lands. The Act, insofar as it related to National Park System units, was repealed and restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100902/a"},"text":"section 100902(a) of Title 54","children":[],"tail":", National Park Service and Related Programs, by "},{"tag":"ref","attrib":{"href":"/us/pl/113/287"},"text":"Pub. L. 113–287","children":[],"tail":", §§ 3, 7, "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3094"},"text":"128 Stat. 3094","children":[],"tail":", 3272."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id772c765e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id772c765f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Denali National Park” substituted in text for “Mount McKinley National Park” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/487/s202/3/a"},"text":"Pub. L. 96–487, § 202(3)(a)","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410hh–1/3/a"},"text":"section 410hh–1(3)(a) of this title","children":[],"tail":" and which added lands to the park, established additional land as the Denali National Preserve, and redesignated the whole as the Denali National Park and Preserve."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
