{"tag":"section","attrib":{"id":"id78377dfd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s"},"text":null,"children":[{"tag":"num","attrib":{"value":"539s"},"text":"§ 539s.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Frank and Jeanne Moore Wild Steelhead Special Management Area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78377dfe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78377dff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Frank Moore has committed his life to family, friends, his country, and fly fishing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78377e00-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Frank Moore is a World War II veteran who stormed the beaches of Normandy along with 150,000 troops during the D-Day Allied invasion and was awarded the Chevalier of the French Legion of Honor for his bravery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78377e01-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Frank Moore returned home after the war, started a family, and pursued his passion of fishing on the winding rivers in Oregon;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78377e02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as the proprietor of the Steamboat Inn along the North Umpqua River in Oregon for nearly 20 years, Frank Moore, along with his wife Jeanne, shared his love of fishing, the flowing river, and the great outdoors, with visitors from all over the United States and the world;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78377e03-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Frank Moore has spent most of his life fishing the vast rivers of Oregon, during which time he has contributed significantly to efforts to conserve fish habitats and protect river health, including serving on the State of Oregon Fish and Wildlife Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78377e04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Frank Moore has been recognized for his conservation work with the National Wildlife Federation Conservationist of the Year award, the Wild Steelhead Coalition Conservation Award, and his 2010 induction into the Fresh Water Fishing Hall of Fame; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78377e05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in honor of the many accomplishments of Frank Moore, both on and off the river, approximately 99,653 acres of Forest Service land in the State of Oregon should be designated as the “Frank and Jeanne Moore Wild Steelhead Special Management Area”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78377e06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78377e07-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Map” means the map entitled “Frank Moore Wild Steelhead Special Management Area Designation Act” and dated ","children":[{"tag":"date","attrib":{"date":"2016-06-23"},"text":"June 23, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78377e08-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture, acting through the Chief of the Forest Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78377e09-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special Management Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Special Management Area” means the Frank and Jeanne Moore Wild Steelhead Special Management Area designated by subsection (c)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78377e0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means the State of Oregon.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78377e0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Frank and Jeanne Moore Wild Steelhead Special Management Area, Oregon","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78377e0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The approximately 99,653 acres of Forest Service land in the State, as generally depicted on the Map, is designated as the “Frank and Jeanne Moore Wild Steelhead Special Management Area”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78377e0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map; legal description","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78377e0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretary shall prepare a map and legal description of the Special Management Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78377e0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Force of law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map and legal description prepared under subparagraph (A) shall have the same force and effect as if included in this section, except that the Secretary may correct clerical and typographical errors in the map and legal description.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78377e10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map and legal description prepared under subparagraph (A) shall be on file and available for public inspection in the appropriate offices of the Forest Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78377e11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to valid existing rights, the Special Management Area shall be administered by the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78377e12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with all laws (including regulations) applicable to the National Forest System; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78377e13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in a manner that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78377e14-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conserves and enhances the natural character, scientific use, and the botanical, recreational, ecological, fish and wildlife, scenic, drinking water, and cultural values of the Special Management Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78377e15-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintains and seeks to enhance the wild salmonid habitat of the Special Management Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78377e16-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintains or enhances the watershed as a thermal refuge for wild salmonids; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78377e17-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/c/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preserves opportunities for recreation, including primitive recreation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78377e18-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fish and wildlife","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section affects the jurisdiction or responsibilities of the State with respect to fish and wildlife in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78377e19-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjacent management","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78377e1a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creates any protective perimeter or buffer zone around the Special Management Area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78377e1b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modifies the applicable travel management plan for the Special Management Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78377e1c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wildfire management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section prohibits the Secretary, in cooperation with other Federal, State, and local agencies, as appropriate, from conducting wildland fire operations in the Special Management Area, consistent with the purposes of this section, including the use of aircraft, machinery, mechanized equipment, fire breaks, backfires, and retardant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78377e1d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vegetation management","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section prohibits the Secretary from conducting vegetation management projects within the Special Management Area in a manner consistent with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78377e1e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purposes described in paragraph (3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78377e1f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable forest plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78377e20-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of tribal rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section diminishes any treaty rights of an Indian Tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78377e21-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to valid existing rights, the Federal land within the boundaries of the Special Management Area river segments designated by paragraph (1) is withdrawn from all forms of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78377e22-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/c/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entry, appropriation, or disposal under the public land laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78377e23-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/c/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" location, entry, and patent under the mining laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78377e24-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539s/c/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disposition under all laws relating to mineral and geothermal leasing or mineral materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78377e25-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tI/s1103"},"text":"Pub. L. 116–9, title I, § 1103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/605"},"text":"133 Stat. 605","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
