{"tag":"section","attrib":{"id":"id776a6952-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81b"},"text":null,"children":[{"tag":"num","attrib":{"value":"410aaa–81b"},"text":"§ 410aaa–81b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wildlife corridors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id776a6953-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776a6954-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the impacts of habitat fragmentation on wildlife in the California Desert Conservation Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776a6955-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish policies and procedures to ensure the preservation of wildlife corridors and facilitate species migration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776a6956-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776a6957-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable, but not later than 2 years, after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretary shall complete a study regarding the impact of habitat fragmentation on wildlife in the California Desert Conservation Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776a6958-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Components","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id776a6959-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the species migrating, or likely to migrate ","children":[{"tag":"ref","attrib":{"idref":"fn002150"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002150"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" in the California Desert Conservation Area;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776a695a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" examine the impacts and potential impacts of habitat fragmentation on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id776a695b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81b/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plants, insects, and animals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id776a695c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81b/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" soil;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id776a695d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81b/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" air quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id776a695e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81b/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water quality and quantity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id776a695f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81b/b/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" species migration and survival;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776a6960-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81b/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify critical wildlife and species migration corridors recommended for preservation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776a6961-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81b/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include recommendations for ensuring the biological connectivity of public land managed by the Secretary and the Secretary of Defense throughout the California Desert Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776a6962-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights-of-way","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall consider the information and recommendations of the study under paragraph (1) to determine the individual and cumulative impacts of rights-of-way for projects in the California Desert Conservation Area, in accordance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id776a6963-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81b/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776a6964-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81b/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Endangered Species Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"16 U.S.C. 1531","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776a6965-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81b/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776a6966-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land management plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall incorporate into all land management plans applicable to the California Desert Conservation Area the findings and recommendations of the study completed under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id776a6967-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/tVII/s713"},"text":"Pub. L. 103–433, title VII, § 713","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tI/s1452"},"text":"Pub. L. 116–9, title I, § 1452","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/711"},"text":"133 Stat. 711","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id776a6968-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id776a6969-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":