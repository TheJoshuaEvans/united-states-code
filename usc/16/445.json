{"tag":"section","attrib":{"id":"id779ee6ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s445"},"text":null,"children":[{"tag":"num","attrib":{"value":"445"},"text":"§ 445.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Canyon De Chelly National Monument; establishment; boundaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"With the consent of the tribal council of the Navajo Tribe of Indians, the President of the United States is authorized to establish by presidential proclamation the Canyon De Chelly National Monument, within the Navajo Indian Reservation, Arizona, including the lands hereinafter described.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"All lands in Del Muerto, De Chelly, and Monument Canyons, in the canyons tributary thereto, and the lands within one-half mile of the rims of the said canyons, situated in unsurveyed townships 4 and 5 north, range 7 west; townships 4, 5, and 6 north, range 8 west; townships 4 and 5 north, range 9 west; and in surveyed townships 4 and 5 north, range 6 west; townships 3, 6, and 7 north, range 7 west; township 6 north, range 9 west; and township 5 north, range 10 west; embracing about eighty-three thousand eight hundred and forty acres, all of the Navajo meridian, in Arizona.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id779ee6eb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1931-02-14/ch188/s1"},"text":"Feb. 14, 1931, ch. 188, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/1161"},"text":"46 Stat. 1161","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1933-03-01/ch161"},"text":"Mar. 1, 1933, ch. 161","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/1419"},"text":"47 Stat. 1419","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id779ee6ec-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id779ee6ed-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id779ee6ee-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1933—Act ","children":[{"tag":"date","attrib":{"date":"1933-03-01"},"text":"Mar. 1, 1933","children":[],"tail":", redescribed lands referred to in second par."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id779ee6ef-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id779ee6f0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Establishment of Monument; Boundaries","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Monument and boundaries established by Presidential Proc. No. 1945, ","children":[{"tag":"date","attrib":{"date":"1931-04-01"},"text":"Apr. 1, 1931","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/2448"},"text":"47 Stat. 2448","children":[],"tail":"; Proc. No. 2036, "},{"tag":"date","attrib":{"date":"1933-03-03"},"text":"Mar. 3, 1933","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/2562"},"text":"47 Stat. 2562","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
