{"tag":"section","attrib":{"id":"id777d7b66-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv"},"text":null,"children":[{"tag":"num","attrib":{"value":"410vvv"},"text":"§ 410vvv.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oregon Caves National Monument and Preserve","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id777d7b67-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777d7b68-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “map” means the map entitled “Oregon Caves National Monument and Preserve”, numbered 150/80,023, and dated May 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7b69-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monument","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Monument” means the Oregon Caves National Monument established by Presidential Proclamation Number 876 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/36/2497"},"text":"36 Stat. 2497","children":[],"tail":"), dated "},{"tag":"date","attrib":{"date":"1909-07-12"},"text":"July 12, 1909","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7b6a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Monument and Preserve","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National Monument and Preserve” means the Oregon Caves National Monument and Preserve designated by subsection (b)(1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7b6b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Preserve","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National Preserve” means the National Preserve designated by subsection (b)(1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7b6c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7b6d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary concerned","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Secretary concerned” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777d7b6e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture (acting through the Chief of the Forest Service), with respect to National Forest System land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777d7b6f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior, with respect to land managed by the Bureau of Land Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7b70-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means the State of Oregon.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777d7b71-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designations; land transfer; boundary adjustment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777d7b72-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777d7b73-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Monument and the National Preserve shall be administered as a single unit of the National Park System and collectively known and designated as the “Oregon Caves National Monument and Preserve”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777d7b74-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Preserve","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The approximately 4,070 acres of land identified on the map as “Proposed Addition Lands” shall be designated as a National Preserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7b75-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of administrative jurisdiction","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777d7b76-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Administrative jurisdiction over the land designated as a National Preserve under paragraph (1)(B) is transferred from the Secretary of Agriculture to the Secretary, to be administered as part of the National Monument and Preserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777d7b77-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The boundaries of the Rogue River-Siskiyou National Forest are adjusted to exclude the land transferred under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7b78-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary adjustment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The boundary of the National Monument and Preserve is modified to exclude approximately 4 acres of land—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777d7b79-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" located in the City of Cave Junction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777d7b7a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identified on the map as the “Cave Junction Unit”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7b7b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map shall be on file and available for public inspection in the appropriate offices of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7b7c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reference in a law, map, regulation, document, paper, or other record of the United States to the Monument shall be considered to be a reference to the “Oregon Caves National Monument and Preserve”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777d7b7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777d7b7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall administer the National Monument and Preserve in accordance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777d7b7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777d7b80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Presidential Proclamation Number 876 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/36/2497"},"text":"36 Stat. 2497","children":[],"tail":"), dated "},{"tag":"date","attrib":{"date":"1909-07-12"},"text":"July 12, 1909","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777d7b81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any law (including regulations) generally applicable to units of the National Park System, including the National Park Service Organic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"16 U.S.C. 1","children":[],"tail":" et seq.)."},{"tag":"ref","attrib":{"idref":"fn002190"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002190"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7b82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fire management","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2014-12-19"},"text":"December 19, 2014","children":[],"tail":", in accordance with paragraph (1), the Secretary shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777d7b83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revise the fire management plan for the Monument to include the land transferred under subsection (b)(2)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777d7b84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with the revised plan, carry out hazardous fuel management activities within the boundaries of the National Monument and Preserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7b85-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing Forest Service contracts","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777d7b86-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777d7b87-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow for the completion of any Forest Service stewardship or service contract executed as of ","children":[{"tag":"date","attrib":{"date":"2014-12-19"},"text":"December 19, 2014","children":[],"tail":", with respect to the National Preserve; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777d7b88-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognize the authority of the Secretary of Agriculture for the purpose of administering a contract described in clause (i) through the completion of the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777d7b89-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All terms and conditions of a contract described in subparagraph (A)(i) shall remain in place for the duration of the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777d7b8a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Forest Service shall be responsible for any liabilities relating to a contract described in subparagraph (A)(i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7b8b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grazing","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777d7b8c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), the Secretary may allow the grazing of livestock within the National Preserve to continue as authorized under permits or leases in existence as of ","children":[{"tag":"date","attrib":{"date":"2014-12-19"},"text":"December 19, 2014","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777d7b8d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable law","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grazing under subparagraph (A) shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777d7b8e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a level not greater than the level at which the grazing exists as of ","children":[{"tag":"date","attrib":{"date":"2014-12-19"},"text":"December 19, 2014","children":[],"tail":", as measured in Animal Unit Months; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777d7b8f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with each applicable law (including National Park Service regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7b90-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fish and wildlife","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall permit hunting and fishing on land and waters within the National Preserve in accordance with applicable Federal and State laws, except that the Secretary may, in consultation with the Oregon Department of Fish and Wildlife, designate zones in which, and establish periods during which, no hunting or fishing shall be permitted for reasons of public safety, administration, or compliance by the Secretary with any applicable law (including regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777d7b91-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary grazing lease or permit donation program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777d7b92-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donation of lease or permit","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777d7b93-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance by Secretary concerned","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned shall accept a grazing lease or permit that is donated by a lessee or permittee for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777d7b94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Big Grayback Grazing Allotment located in the Rogue River-Siskiyou National Forest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777d7b95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Billy Mountain Grazing Allotment located on a parcel of land that is managed by the Secretary (acting through the Director of the Bureau of Land Management).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777d7b96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to each grazing permit or lease donated under subparagraph (A), the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id777d7b97-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminate the grazing permit or lease; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id777d7b98-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure a permanent end to grazing on the land covered by the grazing permit or lease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777d7b99-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vvv/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of donation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A lessee or permittee that donates a grazing lease or grazing permit (or a portion of a grazing lease or grazing permit) under this section shall be considered to have waived any claim to any range improvement on the associated grazing allotment or portion of the associated grazing allotment, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id777d7b9a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dB/tXXX/s3041"},"text":"Pub. L. 113–291, div. B, title XXX, § 3041","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3789"},"text":"128 Stat. 3789","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id777d7b9b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id777d7b9c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id777d7b9d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Presidential Proclamation Number 876, referred to in subsecs. (a)(2) and (c)(1)(B), is listed in a table of National Monuments Established Under Presidential Proclamation set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s320301"},"text":"section 320301 of Title 54","children":[],"tail":", National Park Service and Related Programs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The National Park Service Organic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"16 U.S.C. 1","children":[],"tail":" et seq.), referred to in subsec. (c)(1)(C), is "},{"tag":"ref","attrib":{"href":"/us/act/1916-08-25/ch408"},"text":"act Aug. 25, 1916, ch. 408","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/535"},"text":"39 Stat. 535","children":[],"tail":", which enacted sections 1, 2, 3, and 4 of this title and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100101"},"text":"section 100101 of Title 54","children":[],"tail":", National Park Service and Related Programs. Sections 1 to 4 of the Act were repealed and restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1865/a"},"text":"section 1865(a) of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and section 100101(a), chapter 1003, and sections 100751(a), 100752, 100753, and 102101 of Title 54 by "},{"tag":"ref","attrib":{"href":"/us/pl/113/287"},"text":"Pub. L. 113–287","children":[],"tail":", §§ 3, 4(a)(1), 7, "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3094"},"text":"128 Stat. 3094","children":[],"tail":", 3260, 3272. For complete classification of this Act to the Code, see Tables. For disposition of former sections of this title, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100101"},"text":"section 100101 of Title 54","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id777d7b9e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3041"},"text":"section 3041 of Pub. L. 113–291","children":[],"tail":". Subsec. (e) of "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3041"},"text":"section 3041 of Pub. L. 113–291","children":[],"tail":" amended sections 1274 and 1276 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
