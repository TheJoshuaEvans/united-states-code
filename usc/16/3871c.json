{"tag":"section","attrib":{"id":"id79e26e2f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c"},"text":null,"children":[{"tag":"num","attrib":{"value":"3871c"},"text":"§ 3871c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to producers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79e26e30-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A producer may receive financial or technical assistance to conduct eligible activities on eligible land through a program contract entered into with the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e26e31-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program contracts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e26e32-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program contract to be entered into with a producer to conduct eligible activities on eligible land, subject to such terms and conditions as the Secretary may establish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26e33-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application bundles","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e26e34-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible partner may submit to the Secretary, on behalf of producers, a bundle of applications for assistance under the program through program contracts to address a substantial portion of the conservation benefits to be achieved by the project, as defined in the partnership agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e35-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may give priority to applications described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e26e36-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e26e37-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3871d"},"text":"section 3871d of this title","children":[],"tail":", the Secretary may make payments to a producer in an amount determined by the Secretary to be necessary to achieve the purposes of the program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26e38-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to certain producers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide payments for a period of 5 years—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e26e39-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to producers participating in a project that addresses water quantity concerns and in an amount sufficient to encourage conversion from irrigated to dryland farming; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e3a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to producers participating in a project that addresses water quality concerns and in an amount sufficient to encourage adoption of conservation practices and systems that improve nutrient management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26e3b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To assist in the implementation of the program, the Secretary may waive the applicability of the limitation in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308–3a/b/2"},"text":"section 1308–3a(b)(2) of title 7","children":[],"tail":" for producers if the Secretary determines that the waiver is necessary to fulfill the objectives of the program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e26e3c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding through alternative funding arrangements or grant agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e26e3d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A partnership agreement entered into with an eligible partner may be funded through an alternative funding arrangement or grant in accordance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26e3e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of the Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e26e3f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" under a funding agreement under paragraph (1)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79e26e40-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use funding made available to carry out this subchapter to provide funding directly to the eligible partner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79e26e41-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical and administrative assistance, as mutually agreed by the parties; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e42-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into not more than 15 alternative funding arrangements or grant agreements with 1 or more eligible partners each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26e43-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of eligible partners","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under a funding agreement under paragraph (1), the eligible partner shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e26e44-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" carry out eligible activities on eligible land in agreement with producers to achieve conservation benefits on a regional or watershed scale, such as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79e26e45-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" infrastructure investments relating to agricultural or nonindustrial private forest production that would—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79e26e46-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/d/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benefit multiple producers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79e26e47-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/d/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address natural resource concerns such as drought, wildfire, or water quality impairment on the land covered by the project;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79e26e48-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects addressing natural resources concerns in coordination with producers, including the development and implementation of watershed, habitat, or other area restoration plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79e26e49-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/d/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" projects that use innovative approaches to leveraging the Federal investment in conservation with private financial mechanisms, in conjunction with agricultural production or forest resource management, such as—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79e26e4a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/d/3/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of performance-based payments to producers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79e26e4b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/d/3/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support for an environmental market; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79e26e4c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/d/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other projects for which the Secretary determines that the goals and objectives of the program would be easier to achieve through the funding agreement under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e4d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the Secretary, in addition to any information that the Secretary requires to prepare the report under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3871e/b"},"text":"section 3871e(b) of this title","children":[],"tail":", an annual report that describes the status of the project, including a description of—"}],"tail":null},{"tag":"clause","attrib":{"id":"id79e26e4e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of the funds awarded under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79e26e4f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any subcontracts awarded;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79e26e50-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/d/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the producers receiving funding through the funding agreement under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79e26e51-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/d/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79e26e52-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/d/3/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress made by the project in addressing each natural resource concern defined in the funding agreement under paragraph (1), including in a quantified form to the extent practicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79e26e53-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/d/3/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as appropriate, other outcomes of the project; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79e26e54-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871c/d/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other reporting data the Secretary determines are necessary to ensure compliance with the program rules.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79e26e55-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1271C"},"text":"Pub. L. 99–198, title XII, § 1271C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII/s2401"},"text":"Pub. L. 113–79, title II, § 2401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/747"},"text":"128 Stat. 747","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII/s2704"},"text":"Pub. L. 115–334, title II, § 2704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4596"},"text":"132 Stat. 4596","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79e26e56-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79e26e57-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79e26e58-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2704/1"},"text":"Pub. L. 115–334, § 2704(1)","children":[],"tail":", added subsecs. (a) and (b) and struck out former subsecs. (a) and (b) which authorized the Secretary to enter into contracts with producers to provide financial and technical assistance and set forth provisions relating to terms and conditions, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2704/2/A"},"text":"Pub. L. 115–334, § 2704(2)(A)","children":[],"tail":", substituted “Subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3871d"},"text":"section 3871d of this title","children":[],"tail":", the Secretary may make payments to a producer” for “In accordance with statutory requirements of the covered programs involved, the Secretary may make payments to a producer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2704/2/B"},"text":"Pub. L. 115–334, § 2704(2)(B)","children":[],"tail":", struck out “participating” before “producers”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2704/3"},"text":"Pub. L. 115–334, § 2704(3)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
