{"tag":"section","attrib":{"id":"id7a3aa0df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485"},"text":null,"children":[{"tag":"num","attrib":{"value":"8485"},"text":"§ 8485.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accessible recreation opportunities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a3aa0e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretary concerned shall select a location to develop at least 2 new accessible recreation opportunities—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3aa0e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on National Forest System lands in each region of the Forest Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa0e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on land managed by the National Park Service in each region of the National Park Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa0e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on land managed by the Bureau of Land Management in each region of the Bureau of Land Management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa0e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on land managed by the United States Fish and Wildlife Service in each region of the United States Fish and Wildlife Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3aa0e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing an accessible recreation opportunity under subsection (a), the Secretary concerned—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3aa0e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3aa0e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create a new accessible recreation opportunity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa0e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modify an existing recreation opportunity into an accessible recreation opportunity; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa0e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3aa0ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with stakeholders with respect to the feasibility and resources necessary for completing the accessible recreation opportunity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa0eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the accessible recreation opportunity complies with the Architectural Barriers Act of 1968 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4151"},"text":"42 U.S.C. 4151","children":[],"tail":" et seq.) and "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s794"},"text":"section 794 of title 29","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa0ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, ensure that outdoor constructed features supporting the accessible recreation opportunity, including trail bridges, parking spaces and restroom facilities, meet the requirements of the Architectural Barriers Act of 1968 and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s794"},"text":"section 794 of title 29","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3aa0ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accessible recreation opportunities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The accessible recreation opportunities developed under subsection (a) may include improving accessibility or access to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3aa0ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" camp shelters, camping facilities, and camping units;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa0ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hunting, fishing, shooting, or archery ranges or locations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa0f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" snow activities, including skiing and snowboarding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa0f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water activities, including kayaking, paddling, canoeing, and boat launch ramps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa0f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rock climbing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa0f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" biking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa0f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" off-highway vehicle recreation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa0f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" picnic facilities and picnic units;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa0f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outdoor constructed features; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa0f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other new or existing recreation opportunities identified in consultation with stakeholders under subsection (b)(2) and consistent with the applicable land management plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3aa0f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Completion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 7 years after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretary concerned, in coordination with stakeholders consulted with under subsection (b)(2), shall complete each accessible recreation opportunity developed under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3aa0f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maps, signage, and promotional materials","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each accessible recreation opportunity developed under subsection (a), the Secretary concerned shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3aa0fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish and distribute maps and install signage, consistent with Architectural Barriers Act accessibility guidelines and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s794d"},"text":"section 794d of title 29","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa0fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with stakeholders to leverage any non-Federal resources necessary for the development, stewardship, completion, or promotion of the accessible trail.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3aa0fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflict avoidance with other uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing each accessible recreation opportunity under subsection (a), the Secretary concerned shall ensure that the accessible recreation opportunity—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3aa0fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" minimizes conflict with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3aa0fe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the uses in effect before ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", with respect to any Federal recreational lands and waters on which the accessible recreation opportunity is located; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa0ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multiple-use areas in existence on ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa100-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complies with all applicable land use and management plans of the Federal recreational lands and waters on which the accessible recreational opportunity is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3aa101-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3aa102-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretary concerned, in coordination with stakeholders and other interested organizations, shall prepare and publish an interim report that lists the accessible recreation opportunities developed under this section during the previous 3 years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa103-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8485/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 7 years after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretary concerned, in coordination with stakeholders and other interested organizations, shall prepare and publish a final report that lists the accessible recreation opportunities developed under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3aa104-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tII/s215"},"text":"Pub. L. 118–234, title II, § 215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2884"},"text":"138 Stat. 2884","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a3aa105-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a3aa106-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a3aa107-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Architectural Barriers Act of 1968, referred to in subsec. (b)(2)(B), (C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/480"},"text":"Pub. L. 90–480","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-12"},"text":"Aug. 12, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/718"},"text":"82 Stat. 718","children":[],"tail":", which is classified generally to chapter 51 (§ 4151 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4151"},"text":"section 4151 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s794"},"text":"Section 794 of title 29","children":[],"tail":", referred to in subsec. (b)(2)(B), (C), was in the original a reference to section 504 of the Rehabilitation Act, and was translated as meaning section 504 of the Rehabilitation Act of 1973, "},{"tag":"ref","attrib":{"href":"/us/pl/93/112"},"text":"Pub. L. 93–112","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s794d"},"text":"Section 794d of title 29","children":[],"tail":", referred to in subsec. (e)(1), was in the original a reference to section 508 of the Rehabilitation Act, and was translated as meaning section 508 of the Rehabilitation Act of 1973, "},{"tag":"ref","attrib":{"href":"/us/pl/93/112"},"text":"Pub. L. 93–112","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
