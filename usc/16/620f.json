{"tag":"section","attrib":{"id":"id78601327-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f"},"text":null,"children":[{"tag":"num","attrib":{"value":"620f"},"text":"§ 620f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations and review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78601328-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78601329-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agriculture and Interior","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries of Agriculture and Interior shall, in consultation, each prescribe new coordinated and consistent regulations to implement sections 620 to 620j of this title on lands which they administer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7860132a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commerce","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce shall promulgate such rules and guidelines as may be necessary to carry out sections 620 to 620j of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7860132b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7860132c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in sections 620 to 620j of this title, regulations and guidelines required under this subsection shall be issued not later than ","children":[{"tag":"date","attrib":{"date":"1998-06-01"},"text":"June 1, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7860132d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The regulations and guidelines issued under sections 620 to 620j of this title that were in effect prior to ","children":[{"tag":"date","attrib":{"date":"1995-09-08"},"text":"September 8, 1995","children":[],"tail":" shall remain in effect until new regulations and guidelines are issued under subparagraph (A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7860132e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Painting and branding","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7860132f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned shall issue regulations that impose reasonable painting, branding, or other forms of marking or tracking requirements on unprocessed timber if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78601330-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the benefits of the requirements outweigh the cost of complying with the requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78601331-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary determines that, without the requirements, it is likely that the unprocessed timber—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id78601332-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/4/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would be exported in violation of sections 620 to 620j of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78601333-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/4/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the unprocessed timber originated from Federal lands, would be substituted for unprocessed timber originating from private lands west of the 100th Meridian in the contiguous 48 States in violation of sections 620 to 620j of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78601334-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum size","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned shall not impose painting, branding, or other forms of marking or tracking requirements on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78601335-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the face of a log that is less than 7 inches in diameter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78601336-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unprocessed timber that is less than 8 feet in length or less than ⅓ sound wood.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78601337-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waivers","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78601338-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may waive log painting and branding requirements—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id78601339-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/4/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a geographic area, if the Secretary determines that the risk of the unprocessed timber being exported from the area or used in substitution is low;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7860133a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/4/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to unprocessed timber originating from private lands located within an approved sourcing area for a person who certifies that the timber will be processed at a specific domestic processing facility to the extent that the processing does occur; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7860133b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/4/C/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as part of a log yard agreement that is consistent with the purposes of the export and substitution restrictions imposed under sections 620 to 620j of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7860133c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and termination of waivers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A waiver granted under clause (i)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7860133d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/4/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall, to the maximum extent practicable, be reviewed once a year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7860133e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/4/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall remain effective until terminated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7860133f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making a determination under this paragraph, the Secretary concerned shall consider—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78601340-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the risk of unprocessed timber of that species, grade, and size being exported or used in substitution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78601341-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location of the unprocessed timber and the effect of the location on its being exported or used in substitution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78601342-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/4/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the history of the person involved with respect to compliance with log painting and branding requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78601343-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/4/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other factor that is relevant to determining the likelihood of the unprocessed timber being exported or used in substitution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78601344-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78601345-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), the Secretary concerned shall issue regulations that impose reasonable documentation and reporting requirements if the benefits of the requirements outweigh the cost of complying with the requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78601346-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waivers","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78601347-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may waive documentation and reporting requirements for a person if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id78601348-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/5/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an audit of the records of the facility of the person reveals substantial compliance with all notice, reporting, painting, and branding requirements during the preceding year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78601349-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/5/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person transferring the unprocessed timber and the person processing the unprocessed timber enter into an advance agreement with the Secretary concerned regarding the disposition of the unprocessed timber by domestic processing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7860134a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and termination of waivers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A waiver granted under clause (i)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7860134b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/5/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall, to the maximum extent practicable, be reviewed once a year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7860134c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/a/5/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall remain effective until terminated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7860134d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s620f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries of Agriculture and Interior shall, in consultation, review the definition of unprocessed timber under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s620e/7"},"text":"section 620e(7) of this title","children":[],"tail":" for purposes of sections 620 to 620j of this title and, not later than 18 months after "},{"tag":"date","attrib":{"date":"1990-08-20"},"text":"August 20, 1990","children":[],"tail":", submit to the Congress any recommendations they have with respect to such definition. Specifically, the Secretaries shall report on the effects of maintaining 2 size standards under section 620e(B)(ii) "},{"tag":"ref","attrib":{"idref":"fn002465"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002465"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be section “620e(7)(B)(ii)”."}],"tail":" and (iii) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7860134e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/382/tIV/s495"},"text":"Pub. L. 101–382, title IV, § 495","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-20"},"text":"Aug. 20, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/725"},"text":"104 Stat. 725","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/83/tVI/s605"},"text":"Pub. L. 105–83, title VI, § 605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-14"},"text":"Nov. 14, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1622"},"text":"111 Stat. 1622","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7860134f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78601350-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78601351-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/83"},"text":"Pub. L. 105–83","children":[],"tail":" redesignated first two sentences as pars. (1) and (2), respectively, and inserted headings, and substituted pars. (3) to (5) for last sentence which read as follows: “Except as otherwise provided in sections 620 to 620j of this title, regulations and guidelines under this subsection shall be issued not later than 9 months after "},{"tag":"date","attrib":{"date":"1990-08-20"},"text":"August 20, 1990","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
