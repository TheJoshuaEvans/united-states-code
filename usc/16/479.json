{"tag":"section","attrib":{"id":"id781faf37-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s479"},"text":null,"children":[{"tag":"num","attrib":{"value":"479"},"text":"§ 479.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sites for schools and churches","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The settlers residing within the exterior boundaries of national forests, or in the vicinity thereof, may maintain schools and churches within such national forest, and for that purpose may occupy any part of the said national forest, not exceeding two acres for each schoolhouse and one acre for a church.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id781faf38-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1897-06-04/ch2/s1"},"text":"June 4, 1897, ch. 2, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/36"},"text":"30 Stat. 36","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id781faf39-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id781faf3a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id781faf3b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“National forests” substituted in text for “forest reservations”, and “national forest” substituted for “reservation” and “forest reservation” on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1907-03-04/ch2907"},"text":"act Mar. 4, 1907, ch. 2907","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/1269"},"text":"34 Stat. 1269","children":[],"tail":", which provided that forest reserves shall hereafter be known as national forests."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
