{"tag":"section","attrib":{"id":"id78bd27ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831s"},"text":null,"children":[{"tag":"num","attrib":{"value":"831s"},"text":"§ 831s.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Possession by Government in time of war; damages to contract holders","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Government of the United States reserves the right, in case of war or national emergency declared by Congress, to take possession of all or any part of the property described or referred to in this chapter for the purpose of manufacturing explosives or for other war purposes; but, if this right is exercised by the Government, it shall pay the reasonable and fair damages that may be suffered by any party whose contract for the purchase of electric power or fixed nitrogen or fertilizer ingredients is violated, after the amount of the damages has been fixed by the United States Court of Federal Claims in proceedings instituted and conducted for that purpose under rules prescribed by the court.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78bd27cb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-18/ch32/s20"},"text":"May 18, 1933, ch. 32, § 20","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/68"},"text":"48 Stat. 68","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s161/2"},"text":"Pub. L. 97–164, title I, § 161(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/49"},"text":"96 Stat. 49","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tIX/s902/b/1"},"text":"Pub. L. 102–572, title IX, § 902(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"