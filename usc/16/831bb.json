{"tag":"section","attrib":{"id":"id78bd27fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"831bb"},"text":"§ 831bb.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of right to amend or repeal","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The right to alter, amend, or repeal this chapter is expressly declared and reserved, but no such amendment or repeal shall operate to impair the obligation of any contract made by said Corporation under any power conferred by this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78bd27fc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-18/ch32/s29"},"text":"May 18, 1933, ch. 32, § 29","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/72"},"text":"48 Stat. 72","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
