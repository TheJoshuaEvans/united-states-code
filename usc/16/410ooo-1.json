{"tag":"section","attrib":{"id":"id7778c0be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ooo–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"410ooo–1"},"text":"§ 410ooo–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Pinnacles National Park","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7778c0bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ooo–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is hereby established Pinnacles National Park in the State of California for the purposes of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7778c0c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ooo–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preserving and interpreting for the benefit of future generations the chaparral, grasslands, blue oak woodlands, and majestic valley oak savanna ecosystems of the area, the area’s geomorphology, riparian watersheds, unique flora and fauna, and the ancestral and cultural history of native Americans, settlers and explorers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7778c0c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ooo–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interpreting the recovery program for the California Condor and the international significance of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7778c0c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ooo–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The boundaries of Pinnacles National Park are as generally depicted on the map entitled “Proposed: Pinnacles National Park Designation Change”, numbered 114/111,724, and dated December 2011. The map shall be on file and available for public inspection in the appropriate offices of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7778c0c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ooo–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abolishment of current Pinnacles National Monument","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7778c0c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ooo–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In light of the establishment of Pinnacles National Park, Pinnacles National Monument is hereby abolished and the lands and interests therein are incorporated within and made part of Pinnacles National Park. Any funds available for purposes of the monument shall be available for purposes of the park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7778c0c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ooo–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any references in law (other than in this subchapter), regulation, document, record, map or other paper of the United States to Pinnacles National Monument shall be considered a reference to Pinnacles National Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7778c0c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ooo–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall administer Pinnacles National Park in accordance with this subchapter and laws generally applicable to units of the National Park System, including the National Park Service Organic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"16 U.S.C. 1","children":[],"tail":", 2–4)."},{"tag":"ref","attrib":{"idref":"fn002180"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002180"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7778c0c7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/245/s3"},"text":"Pub. L. 112–245, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-10"},"text":"Jan. 10, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2386"},"text":"126 Stat. 2386","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7778c0c8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7778c0c9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7778c0ca-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsecs. (c)(2) and (d), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/245"},"text":"Pub. L. 112–245","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-10"},"text":"Jan. 10, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2385"},"text":"126 Stat. 2385","children":[],"tail":", known as the Pinnacles National Park Act, which enacted this subchapter and amended provisions listed in a table of Wilderness Areas under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1132"},"text":"section 1132 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under section 410"},{"tag":"i","attrib":{},"text":"ooo","children":[],"tail":" of this title and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The National Park Service Organic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"16 U.S.C. 1","children":[],"tail":", 2–4), referred to in subsec. (d), is "},{"tag":"ref","attrib":{"href":"/us/act/1916-08-25/ch408"},"text":"act Aug. 25, 1916, ch. 408","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/535"},"text":"39 Stat. 535","children":[],"tail":", which enacted sections 1, 2, 3, and 4 of this title and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100101"},"text":"section 100101 of Title 54","children":[],"tail":", National Park Service and Related Programs. Sections 1 to 4 of the Act were repealed and restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1865/a"},"text":"section 1865(a) of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and section 100101(a), chapter 1003, and sections 100751(a), 100752, 100753, and 102101 of Title 54 by "},{"tag":"ref","attrib":{"href":"/us/pl/113/287"},"text":"Pub. L. 113–287","children":[],"tail":", §§ 3, 4(a)(1), 7, "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3094"},"text":"128 Stat. 3094","children":[],"tail":", 3260, 3272. For complete classification of this Act to the Code, see Tables. For disposition of former sections of this title, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100101"},"text":"section 100101 of Title 54","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
