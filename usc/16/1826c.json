{"tag":"section","attrib":{"id":"id796b1b7c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1826c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1826c"},"text":"§ 1826c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In sections 1826a to 1826c of this title, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id796b1b7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1826c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fish and fish products","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “fish and fish products” means any aquatic species (including marine mammals and plants) and all products thereof exported from a nation, whether or not taken by fishing vessels of that nation or packed, processed, or otherwise prepared for export in that nation or within the jurisdiction thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id796b1b7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1826c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Large-scale driftnet fishing","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id796b1b7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1826c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the term “large-scale driftnet fishing” means a method of fishing in which a gillnet composed of a panel or panels of webbing, or a series of such gillnets, with a total length of two and one-half kilometers or more is placed in the water and allowed to drift with the currents and winds for the purpose of entangling fish in the webbing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id796b1b80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1826c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Until ","children":[{"tag":"date","attrib":{"date":"1994-01-01"},"text":"January 1, 1994","children":[],"tail":", the term “large-scale driftnet fishing” does not include the use in the northeast Atlantic Ocean of gillnets with a total length not to exceed five kilometers if the use is in accordance with regulations adopted by the European Community pursuant to the "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"October 28, 1991","children":[],"tail":", decision by the Council of Fisheries Ministers of the Community."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id796b1b81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1826c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Large-scale driftnet fishing vessel","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “large-scale driftnet fishing vessel” means any vessel which is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id796b1b82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1826c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used for, equipped to be used for, or of a type which is normally used for large-scale driftnet fishing; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id796b1b83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1826c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used for aiding or assisting one or more vessels at sea in the performance of large-scale driftnet fishing, including preparation, supply, storage, refrigeration, transportation, or processing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id796b1b84-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/582/tI/s104"},"text":"Pub. L. 102–582, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-02"},"text":"Nov. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4903"},"text":"106 Stat. 4903","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id796b1b85-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id796b1b86-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id796b1b87-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 1826a to 1826c of this title, referred to in text, was in the original “this title”, meaning title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/582"},"text":"Pub. L. 102–582","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-02"},"text":"Nov. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4901"},"text":"106 Stat. 4901","children":[],"tail":", which enacted sections 1826a to 1826c of this title and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1371"},"text":"section 1371 of this title","children":[],"tail":". For complete classification of title I to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id796d8b88-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the High Seas Driftnet Fisheries Enforcement Act, and not as part of the Magnuson-Stevens Fishery Conservation and Management Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
