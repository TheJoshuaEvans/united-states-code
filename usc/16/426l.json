{"tag":"section","attrib":{"id":"id778e4475-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s426l"},"text":null,"children":[{"tag":"num","attrib":{"value":"426l"},"text":"§ 426l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redesignation; availability of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Stones River National Military Park is redesignated as the Stones River National Battlefield, and any remaining balance of funds appropriated for the purpose of the Stones River National Military Park shall be available for the purpose of Stones River National Battlefield.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id778e4476-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/443/s2"},"text":"Pub. L. 86–443, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-04-22"},"text":"Apr. 22, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/82"},"text":"74 Stat. 82","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
