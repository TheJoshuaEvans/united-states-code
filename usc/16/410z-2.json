{"tag":"section","attrib":{"id":"id774b6fec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410z–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"410z–2"},"text":"§ 410z–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boston National Historical Park Advisory Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id774b6fed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410z–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established a Boston National Historical Park Advisory Commission (hereinafter referred to as the “Commission”) which shall be composed of members appointed by the Secretary as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id774b6fee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410z–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three members appointed from recommendations submitted by the Governor of Massachusetts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id774b6fef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410z–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three members appointed from recommendations submitted by the mayor of the city of Boston; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id774b6ff0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410z–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member to represent each owner with which the Secretary has concluded a cooperative agreement pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410z–1"},"text":"section 410z–1 of this title","children":[],"tail":", to be appointed from recommendations submitted by each such owner."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id774b6ff1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410z–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall terminate ten years from the date of establishment of the Boston National Historical Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id774b6ff2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410z–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies; chairman","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A vacancy in the Commission shall not affect its powers, but shall be filled in the same manner as the original appointment (and for the balance of the unexpired term). The Chairman of the Commission shall be designated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id774b6ff3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410z–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Majority rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall act and advise by affirmative vote of a majority of its members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id774b6ff4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410z–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation between Secretary and Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or his designee shall from time to time, but at least semiannually, consult with the Commission with respect to matters relating to the development of the Boston National Historical Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id774b6ff5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410z–2/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation; payment of expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Commission shall serve without compensation as such. The Secretary is authorized to pay the expenses reasonably incurred by the Commission in carrying out its responsibilities under this subchapter upon presentation of vouchers signed by the Chairman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id774b6ff6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/431/s4"},"text":"Pub. L. 93–431, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-01"},"text":"Oct. 1, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1185"},"text":"88 Stat. 1185","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
