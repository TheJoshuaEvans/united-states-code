{"tag":"section","attrib":{"id":"id78542ce1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s590b"},"text":null,"children":[{"tag":"num","attrib":{"value":"590b"},"text":"§ 590b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lands on which preventive measures may be taken","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The acts authorized in section 590a(1) and (2) of this title may be performed—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78542ce2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s590b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On lands owned or controlled by the United States or any of its agencies, with the cooperation of the agency having jurisdiction thereof; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78542ce3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s590b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On any other lands, upon obtaining proper consent or the necessary rights or interests in such lands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78542ce4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-04-27/ch85/s2"},"text":"Apr. 27, 1935, ch. 85, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/163"},"text":"49 Stat. 163","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
