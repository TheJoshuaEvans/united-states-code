{"tag":"section","attrib":{"id":"id77dd00f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ff–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"460ff–2"},"text":"§ 460ff–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land acquisition plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77dd00f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ff–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Congressional committees; time; contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within one year after ","children":[{"tag":"date","attrib":{"date":"1974-12-27"},"text":"December 27, 1974","children":[],"tail":", the Secretary shall submit, in writing, to the Committees on Interior and Insular Affairs and to the Committees on Appropriations of the United States Congress a detailed plan which shall indicate:"}],"tail":null},{"tag":"clause","attrib":{"id":"id77dd00fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ff–2/a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lands and areas which he deems essential to the protection and public enjoyment of this park,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77dd00fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ff–2/a/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lands which he has previously acquired by purchase, donation, exchange, or transfer for the purpose of this park, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77dd00fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ff–2/a/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the annual acquisition program (including the level of funding) which he recommends for the ensuing five fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77dd00fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ff–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional intent for land acquisition completion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the express intent of the Congress that the Secretary should substantially complete the land acquisition program contemplated by this subchapter within six years after ","children":[{"tag":"date","attrib":{"date":"1974-12-27"},"text":"December 27, 1974","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77dd00fe-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/555/s3"},"text":"Pub. L. 93–555, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-27"},"text":"Dec. 27, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1786"},"text":"88 Stat. 1786","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/291/tI/s149/c/2"},"text":"Pub. L. 106–291, title I, § 149(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-11"},"text":"Oct. 11, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/956"},"text":"114 Stat. 956","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77dd00ff-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77dd0100-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77dd0101-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(i), (ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/291"},"text":"Pub. L. 106–291","children":[],"tail":" substituted “park” for “recreation area”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77dd0102-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id77dd0103-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Interior and Insular Affairs of the Senate abolished and replaced by Committee on Energy and Natural Resources of the Senate, effective ","children":[{"tag":"date","attrib":{"date":"1977-02-11"},"text":"Feb. 11, 1977","children":[],"tail":". See Rule XXV of Standing Rules of the Senate, as amended by Senate Resolution No. 4 (popularly cited as the “Committee System Reorganization Amendments of 1977”), approved "},{"tag":"date","attrib":{"date":"1977-02-04"},"text":"Feb. 4, 1977","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Interior and Insular Affairs of the House of Representatives changed to Committee on Natural Resources of the House of Representatives on ","children":[{"tag":"date","attrib":{"date":"1993-01-05"},"text":"Jan. 5, 1993","children":[],"tail":", by House Resolutio