{"tag":"section","attrib":{"id":"id779c9cb2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s441k"},"text":null,"children":[{"tag":"num","attrib":{"value":"441k"},"text":"§ 441k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of property for park","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id779c9cb3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s441k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consent of State or Oglala Sioux Tribe of South Dakota; transfer from Federal agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the provisions of subsection (b) hereof, the Secretary of the Interior may, within the boundaries of the park, acquire lands and interests in lands by donation, purchase with donated or appropriated funds, or exchange, except that any lands or interests in lands owned by the State of South Dakota, a political subdivision thereof, or the Oglala Sioux Tribe of South Dakota may be acquired only with the consent of owner. Notwithstanding any other provision of law, lands and interests in lands located within the park under the administrative jurisdiction of any other Federal agency may be transferred to the administrative jurisdiction of the Secretary without a transfer of funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id779c9cb4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s441k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Easements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As to lands located within the boundaries of the park but outside the boundaries of the gunnery range referred to in section 441","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title, the Secretary of the Interior may acquire only rights-of-way and scenic easements."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id779c9cb5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/468/s2"},"text":"Pub. L. 90–468, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-08"},"text":"Aug. 8, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/663"},"text":"82 Stat. 663","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/625/tVI/s611"},"text":"Pub. L. 95–625, title VI, § 611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3521"},"text":"92 Stat. 3521","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id779c9cb6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id779c9cb7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id779c9cb8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Word “park” substituted in text for “monument” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625/s611"},"text":"Pub. L. 95–625, § 611","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s441e–1"},"text":"section 441e–1 of this title","children":[],"tail":" and which redesignated Badlands National Monument as Badlands National Park."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
