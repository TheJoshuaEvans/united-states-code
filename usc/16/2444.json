{"tag":"section","attrib":{"id":"id799ade84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2444"},"text":null,"children":[{"tag":"num","attrib":{"value":"2444"},"text":"§ 2444.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Severability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any provision of this chapter or the application of this chapter to any person or circumstance is held invalid, neither the remainder of this chapter nor the application of that provision to other persons or circumstances shall be affected thereby.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id799ade85-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/623/tIII/s315"},"text":"Pub. L. 98–623, title III, § 315","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3407"},"text":"98 Stat. 3407","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
