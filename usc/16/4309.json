{"tag":"section","attrib":{"id":"id79ee54b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4309"},"text":null,"children":[{"tag":"num","attrib":{"value":"4309"},"text":"§ 4309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provision","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79ee54b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4309/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter shall be construed as authorizing the appropriation of water by any Federal, State, or local agency, Indian tribe, or any other entity or individual. Nor shall any provision of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ee54ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4309/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affect the rights or jurisdiction of the United States, the States, Indian tribes, or other entities over waters of any river or stream or over any ground water resource;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ee54bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4309/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alter, amend, repeal, interpret, modify, or be in conflict with any interstate compact made by the States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ee54bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4309/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alter or establish the respective rights of States, the United States, Indian tribes, or any person with respect to any water or water-related right.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ee54bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4309/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fish and wildlife","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed as affecting the jurisdiction or responsibilities of the States with respect to fish and wildlife.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79ee54be-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/691/s10"},"text":"Pub. L. 100–691, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4551"},"text":"102 Stat. 4551","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
