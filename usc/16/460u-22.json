{"tag":"section","attrib":{"id":"id77cea942-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460u–22"},"text":null,"children":[{"tag":"num","attrib":{"value":"460u–22"},"text":"§ 460u–22.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of property owner’s hardship in property acquisition","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In exercising his authority to acquire property under this subchapter, the Secretary shall give prompt and careful consideration to any offer made by an individual owning property within the Park to sell such property, if such individual notifies the Secretary in writing that the continued ownership of such property is causing, or would result in, undue hardship.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77cea943-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/761/s22"},"text":"Pub. L. 89–761, § 22","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/612/s1/12"},"text":"Pub. L. 96–612, § 1(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-28"},"text":"Dec. 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3577"},"text":"94 Stat. 3577","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/6/dE/tI/s115/a/1/B"},"text":"Pub. L. 116–6, div. E, title I, § 115(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-02-15"},"text":"Feb. 15, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/232"},"text":"133 Stat. 232","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77cea944-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77cea945-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77cea946-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/6"},"text":"Pub. L. 116–6","children":[],"tail":" substituted “Park” for “lakeshore”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
