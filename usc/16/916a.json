{"tag":"section","attrib":{"id":"id78d284bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s916a"},"text":null,"children":[{"tag":"num","attrib":{"value":"916a"},"text":"§ 916a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Commissioner","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78d284bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s916a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Commissioner shall be appointed by the President, on the concurrent recommendations of the Secretary of State and the Secretary of Commerce, and shall serve at the pleasure of the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78d284be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s916a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deputy Commissioner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may appoint a Deputy United States Commissioner, on the concurrent recommendations of the Secretary of State and the Secretary of Commerce. The Deputy United States Commissioner shall serve at the pleasure of the President and shall be the principal technical adviser to the United States Commissioner, and shall be empowered to perform the duties of the Commissioner in case of the death, resignation, absence, or illness of the Commissioner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78d284bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s916a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Commissioner and Deputy Commissioner, although officers of the United States Government, shall receive no compensation for their services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78d284c0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-08-09/ch653/s3"},"text":"Aug. 9, 1950, ch. 653, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/421"},"text":"64 Stat. 421","children":[],"tail":"; 1970 Reorg. Plan. No. 4, eff. "},{"tag":"date","attrib":{"date":"1970-10-03"},"text":"Oct. 3, 1970","children":[],"tail":", 35 F.R. 15627, "},{"tag":"ref","attrib":{"href":"/us/stat/84/2090"},"text":"84 Stat. 2090","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78d284c1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78d284c2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78d284c3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Alternate United States Commissioners","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Secretary of State authorized to designate Alternate United States Commissioners, see sections 2672a and 2672b of Title 22, Foreign Relations and Intercourse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id78d284c4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id78d284c5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of functions to Secretary of Commerce from Secretary of the Interior by Reorg. Plan No. 4 of 1970, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s916"},"text":"section 916 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
