{"tag":"section","attrib":{"id":"id77719481-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"410fff–4"},"text":"§ 410fff–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion of the Black Canyon of the Gunnison Wilderness","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77719482-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion of Black Canyon of the Gunnison Wilderness","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Black Canyon of the Gunnison Wilderness, as established by subsection (b) of the first section of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/567"},"text":"Public Law 94–567","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/90/2692"},"text":"90 Stat. 2692","children":[],"tail":"), is expanded to include the parcel of land depicted on the Map as “Tract A” and consisting of approximately 4,419 acres."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77719483-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Black Canyon of the Gunnison Wilderness shall be administered as a component of the Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77719484-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/76/s6"},"text":"Pub. L. 106–76, § 6","children":[],"tail":", "},{"tag":"date",