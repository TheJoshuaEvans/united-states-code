{"tag":"section","attrib":{"id":"id79ab7fc5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3163"},"text":null,"children":[{"tag":"num","attrib":{"value":"3163"},"text":"§ 3163.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as specifically provided for in this subchapter, applicable law shall apply with respect to the authorization and administration of transportation or utility systems.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79ab7fc6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/487/tXI/s1103"},"text":"Pub. L. 96–487, title XI, § 1103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-02"},"text":"Dec. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2459"},"text":"94 Stat. 2459","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
