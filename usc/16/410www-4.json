{"tag":"section","attrib":{"id":"id777d7bcf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410www–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"410www–4"},"text":"§ 410www–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entrance or admission fees prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, no fees shall be charged for entrance or admission to the national historical park or the preservation district established by this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id777d7bd0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/428/s5"},"text":"Pub. L. 96–428, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-10"},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1842"},"text":"94 Stat. 1842","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/108/s2/3"},"text":"Pub. L. 115–108, § 2(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-01-08"},"text":"Jan. 8, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2267"},"text":"131 Stat. 2267","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id777d7bd1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id777d7bd2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id777d7bd3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},