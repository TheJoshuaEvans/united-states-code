{"tag":"section","attrib":{"id":"id773d3ec9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s403i"},"text":null,"children":[{"tag":"num","attrib":{"value":"403i"},"text":"§ 403i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of the Interior authorized to purchase necessary lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to acquire on behalf of the United States by purchase, at prices deemed by him to be reasonable, the lands needed to complete the Great Smoky Mountains National Park in the State of Tennessee, in accordance with the provisions of sections 403 and 403a to 403c of this title; and the Secretary of the Interior is further authorized, when in his opinion unreasonable prices are asked for any of such lands, to acquire the same by condemnation under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3113"},"text":"section 3113 of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id773d3eca-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-12/ch27/s5"},"text":"Feb. 12, 1938, ch. 27, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/29"},"text":"52 Stat. 29","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id773d3ecb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id773d3ecc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id773d3ecd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3113"},"text":"Section 3113 of title 40","children":[],"tail":"” substituted in text for “the Act of "},{"tag":"date","attrib":{"date":"1888-08-01"},"text":"August 1, 1888","children":[],"tail":"” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s5/c"},"text":"Pub. L. 107–217, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1303"},"text":"116 Stat. 1303","children":[],"tail":", the first section of which enacted Title 40, Public Buildings, Property, and Works."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
