{"tag":"section","attrib":{"id":"id76ff24c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s81i"},"text":null,"children":[{"tag":"num","attrib":{"value":"81i"},"text":"§ 81i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donation of buildings thereafter revenue producing; disposition of proceeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the event that lands and/or buildings, structures, and so forth, within the city of Williamsburg are donated to the United States and are thereafter revenue producing, the United States shall pay in the treasury of the city of Williamsburg 25 per centum of any rentals included in said revenues, and 25 per centum of the net proceeds of any commercial enterprise there conducted by the United States, such payment into the treasury of the city of Williamsburg not to exceed $20,000 in any year.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id770194ca-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-07-03/ch837/s7"},"text":"July 3, 1930, ch. 837, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/856"},"text":"46 Stat. 856","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id770194cb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id770194cc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id770194cd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s443f"},"text":"section 443f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
