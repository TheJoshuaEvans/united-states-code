{"tag":"section","attrib":{"id":"id792d278b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1421a"},"text":"§ 1421a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination; data collection and dissemination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id792d278c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination for release","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, in consultation with the Secretary of the Interior, the Marine Mammal Commission, and individuals with knowledge and experience in marine science, marine mammal science, marine mammal veterinary and husbandry practices, and marine conservation, including stranding network participants, develop objective criteria, after an opportunity for public review and comment, to provide guidance for determining at what point a rehabilitated marine mammal is releasable to the wild.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792d278d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, in consultation with the Secretary of the Interior, collect and update, periodically, existing information on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792d278e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" procedures and practices for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792d278f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rescuing and rehabilitating stranded or entangled marine mammals, including criteria used by stranding network participants, on a species-by-species basis, for determining at what point a marine mammal undergoing rescue and rehabilitation is returnable to the wild; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d2790-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collecting, preserving, labeling, and transporting marine mammal tissues for physical, chemical, and biological analyses;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d2791-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate scientific literature on marine mammal health, disease, and rehabilitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d2792-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strandings and entanglements, including unusual mortality events, which the Secretary shall compile and analyze, by stranding region, to monitor species, numbers, conditions, and causes of illnesses and deaths of stranded marine mammals and entangled marine mammals to allow comparison of the causes of illness and deaths in stranded marine mammals and entangled marine mammals with physical, chemical, and biological environmental parameters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d2793-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other life history and reference level data, including marine mammal tissue analyses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792d2794-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information required to be submitted and collected","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792d2795-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After each response to a stranding or entanglement event, the Secretary shall collect (including from any staff of the National Oceanic and Atmospheric Administration that respond directly to such an event), and shall require each stranding network participant who responds to that stranding or entanglement to submit to the Administrator of the National Oceanic and Atmospheric Administration or the Director of the United States Fish and Wildlife Service—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792d2796-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data on the stranding event, including NOAA Form 89–864 (OMB #0648–0178), NOAA Form 89–878 (OMB #0648–0178), similar successor forms, or similar information in an appropriate format required by the United States Fish and Wildlife Service for species under its management authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d2797-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" supplemental data to the data described in subparagraph (A), which may include, as available, relevant information about—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id792d2798-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" weather and tide conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792d2799-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offshore human, predator, or prey activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792d279a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" morphometrics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792d279b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/c/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" behavior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792d279c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/c/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health assessments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792d279d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/c/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" life history samples; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792d279e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/c/1/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stomach and intestinal contents; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d279f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" data and results from laboratory analysis of tissues, which may include, as appropriate and available—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id792d27a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" histopathology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792d27a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" toxicology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792d27a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" microbiology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792d27a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/c/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" virology; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792d27a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/c/1/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parasitology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d27a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timeline","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A stranding network participant shall submit—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792d27a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the data described in paragraph (1)(A) not later than 30 days after the date of a response to a stranding or entanglement event;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d27a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the compiled data described in paragraph (1)(B) not later than 30 days after the date on which the data is available to the stranding network participant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d27a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the compiled data described in paragraph (1)(C) not later than 30 days after the date on which the laboratory analysis has been reported to the stranding network participant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d27a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Online data input system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Under Secretary of Commerce for Oceans and Atmosphere, in consultation with the stranding network and the Office of Evaluation Sciences of the General Services Administration, shall establish an online system for the purposes of efficient and timely submission of data described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792d27aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of data","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792d27ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall develop a program to make information, including any data and metadata collected under paragraph (3) or (4) of subsection (b) or subsection (c), available to researchers, stranding network participants, and the public—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792d27ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve real-time coordination of response to stranding and entanglement events across geographic areas and between stranding coordinators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d27ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify and quickly disseminate information on potential public health risks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d27ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate integrated interdisciplinary research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d27af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate peer-reviewed publications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d27b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to archive regional data into 1 national database for future analyses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d27b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for education and outreach activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d27b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to data","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that any data or metadata collected under subsection (c)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792d27b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by staff of the National Oceanic and Atmospheric Administration or the United States Fish and Wildlife Service that responded directly to a stranding or entanglement event is available to the public through the Health MAP and the Observation System not later than 30 days after that data or metadata is collected by, available to, or reported to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d27b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a stranding network participant that responded directly to a stranding or entanglement event is made available to the public through the Health MAP and the Observation System 2 years after the date on which that data are submitted to the Secretary under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d27b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792d27b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Written release","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (2)(B), the Secretary may make data described in paragraph (2)(B) publicly available earlier than 2 years after the date on which that data are submitted to the Secretary under subsection (c), if the stranding network participant has completed a written release stating that such data may be made publicly available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792d27b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (2), the Secretary may withhold data for a longer period than the period of time described in paragraph (2) in the event of a law enforcement action or legal action that may be related to that data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792d27b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the marine mammal stranding community, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792d27b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make publicly available guidance about uniform data and metadata standards to ensure that data collected in accordance with this section can be archived in a form that is readily accessible and understandable to the public through the Health MAP and the Observation System; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792d27ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodically update such guidance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792d27bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In collaboration with the regional stranding networks, the Secretary shall develop, and periodically update, a data management and public outreach collaboration policy for stranding or entanglement events.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792d27bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorship agreements and acknowledgment policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Under Secretary of Commerce for Oceans and Atmosphere, shall include authorship agreements or other acknowledgment considerations for use of data by the public, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792d27bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1421a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings clause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not require submission of research data that are not described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id792d27be-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522/tIV/s402"},"text":"Pub. L. 92–522, title IV, § 402","children":[],"tail":", formerly title III, § 302, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/tIII/s3003/a"},"text":"Pub. L. 102–587, title III, § 3003(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5061"},"text":"106 Stat. 5061","children":[],"tail":"; renumbered title IV, § 402, "},{"tag":"ref","attrib":{"href":"/us/pl/103/238/s24/b"},"text":"Pub. L. 103–238, § 24(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/565"},"text":"108 Stat. 565","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tCIV/s10401"},"text":"Pub. L. 117–263, div. J, title CIV, § 10401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3981"},"text":"136 Stat. 3981","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id792d27bf-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id792d27c0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id792d27c1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10401/1/A"},"text":"Pub. L. 117–263, § 10401(1)(A)","children":[],"tail":", inserted “or entangled” after “stranded”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10401/1/B"},"text":"Pub. L. 117–263, § 10401(1)(B)","children":[],"tail":", substituted “strandings and entanglements, including unusual mortality events, which the Secretary shall compile and analyze, by stranding region, to monitor species, numbers, conditions, and causes of illnesses and deaths of stranded marine mammals and entangled marine mammals to allow comparison of the causes of illness and deaths in stranded marine mammals and entangled marine mammals with physical, chemical, and biological environmental parameters; and” for “strandings, which the Secretary shall compile and analyze, by region, to monitor species, numbers, conditions, and causes of illnesses and deaths of stranded marine mammals; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10401/1/C"},"text":"Pub. L. 117–263, § 10401(1)(C)","children":[],"tail":", substituted “analyses.” for “analyses, that would allow comparison of the causes of illness and deaths in stranded marine mammals with physical, chemical, and biological environmental parameters.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10401/2"},"text":"Pub. L. 117–263, § 10401(2)","children":[],"tail":", added subsecs. (c) to (h) and struck out former subsec. (c). Prior to amendment, text of subsec. (c) read as follows: “The Secretary shall make information collected under this section available to stranding network participants and other qualified scientists.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id792d27c2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id792d27c3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/tIII/s3003/b"},"text":"Pub. L. 102–587, title III, § 3003(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5066"},"text":"106 Stat. 5066","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/587/tIII/s3003/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Secretary of Commerce shall—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in accordance with section 302(a) and (b) [now 402(a), (b)] of the Marine Mammal Protection Act of 1972 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1421a/a"},"text":"16 U.S.C. 1421a(a)","children":[],"tail":", (b)], as amended by this Act, and not later than 24 months after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":"]—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and implement objective criteria to determine at what point a marine mammal undergoing rehabilitation is returnable to the wild; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and make available information on marine mammal health and health trends; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in accordance with section 304(b) [now 404(b)] of the Marine Mammal Protection Act of 1972 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1421c/b"},"text":"16 U.S.C. 1421c(b)","children":[],"tail":"], as amended by this Act, issue a detailed contingency plan for responding to any unusual mortality event—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in proposed form by not later than 18 months after the date of enactment of this Act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in final form by not later than 24 months after the date of enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
