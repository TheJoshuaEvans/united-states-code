{"tag":"section","attrib":{"id":"id79ebe3e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4244"},"text":null,"children":[{"tag":"num","attrib":{"value":"4244"},"text":"§ 4244.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ebe3e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4244/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “African elephant” means any animal of the species loxodonta africana;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe3e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4244/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “CITES” means the Convention on the International Trade in Endangered Species of Wild Fauna and Flora;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe3e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4244/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “CITES Ivory Control System” means the ivory quota and marking system established by CITES to curtail illegal trade in African elephant ivory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe3e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4244/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Fund” means the account established by division A, section 101(e), title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Public Law 105–277","children":[],"tail":" under the heading “"},{"tag":"inline","attrib":{},"text":"multinational species conservation fund","children":[],"tail":"” ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4246"},"text":"16 U.S.C. 4246","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe3ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4244/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “import” and “importation” have the meanings such terms have in the Endangered Species Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"16 U.S.C. 1531","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe3eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4244/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “intermediary country” means a country that exports raw or worked ivory that does not originate in that country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe3ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4244/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “ivory producing country” means any African country within which is located any part of the range of a population of African elephants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe3ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4244/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “ivory quota” means a quota submitted by an ivory producing country to the CITES Secretariat in accordance with the CITES Ivory Control System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe3ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4244/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “personal effects” means articles which are not intended for sale and are part of a shipment of the household effects of a person who is moving his or her residence to or from the United States, or are included in personal accompanying baggage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe3ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4244/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “raw ivory” means any African elephant tusk, and any piece thereof, the surface of which, polished or unpolished, is unaltered or minimally carved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe3f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4244/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of the Interior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe3f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4244/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “United States” means the fifty States, the District of Columbia, Guam, the Commonwealth of the Northern Mariana Islands, the Commonwealth of Puerto Rico, and the territories and possessions of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe3f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4244/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “worked ivory” means any African elephant tusk, and any piece thereof, which is not raw ivory.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79ebe3f3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/478/tII/s2305"},"text":"Pub. L. 100–478, title II, § 2305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-07"},"text":"Oct. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2322"},"text":"102 Stat. 2322","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/111/s6/a/4"},"text":"Pub. L. 107–111, § 6(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2096"},"text":"115 Stat. 2096","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79ebe3f4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79ebe3f5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79ebe3f6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Division A, section 101(e), title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Public Law 105–277","children":[],"tail":", referred to in par. (4), is "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/