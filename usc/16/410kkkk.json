{"tag":"section","attrib":{"id":"id77871980-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410kkkk"},"text":null,"children":[{"tag":"num","attrib":{"value":"410kkkk"},"text":"§ 410kkkk.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary Revision of Salem Maritime National Historic Site ","children":[{"tag":"ref","attrib":{"idref":"fn002217"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002217"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Redesignation of Salem Maritime National Historic Site note below."}],"tail":null}],"tail":null},{"tag":"subsection","attrib":{"id":"id77871981-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410kkkk/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary revision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Salem Maritime National Historic Site ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" (hereafter in this section referred to as the “national historic site”), designated on "},{"tag":"date","attrib":{"date":"1938-03-17"},"text":"March 17, 1938","children":[],"tail":", under "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-21/s2"},"text":"section 2 of the Act of August 21, 1935","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/49/666"},"text":"49 Stat. 666","children":[],"tail":"), and located in Salem, Massachusetts, shall consist of lands and interests in lands as generally depicted on the map entitled “Boundary Map, Salem Maritime National Historic Site, Salem, Massachusetts”, numbered 373–80,011, and dated April 1987. The map shall be on file and available for public inspection in the offices of the National Park Service, Department of the Interior."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77871982-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410kkkk/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of lands","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77871983-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410kkkk/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Interior may acquire lands or interests therein within the boundary of the national historic site ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" by donation, purchase with donated or appropriated funds, or exchange. Any lands or interests in lands owned by the Commonwealth of Massachusetts or any political subdivision thereof may be acquired only by donation. Lands and interests therein acquired pursuant to this section shall become part of the national historic site "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and shall be subject to all the laws and regulations applicable to the national historic site."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77871984-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410kkkk/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77871985-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410kkkk/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subparagraph (B), the Secretary may acquire under this subsection property or an interest therein in the city of Salem for use as a visitor center or the national historic site.","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" The Secretary shall conduct an economic analysis of the costs and benefits of acquiring such property or interest therein. Funds appropriated for the development and operation of the visitor center may be expended on property in which the Secretary has acquired less than a fee simple interest."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77871986-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410kkkk/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77871987-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410kkkk/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any acquisition under this paragraph shall provide that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id77871988-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410kkkk/b/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under any lease, the leased period shall not be less than 25 years and shall contain an option to renew for an addtional ","children":[{"tag":"ref","attrib":{"idref":"fn002218"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002218"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “additional”."}],"tail":" 25 years;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id77871989-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410kkkk/b/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner of the property shall maintain the property to a standard acceptable to the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7787198a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410kkkk/b/2/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under any lease, rental amounts paid by the Secretary may not exceed the fair market value of the leased premises, as determined by an independent party acceptable to both the lessor and the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7787198b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410kkkk/b/2/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under any lease, rental payments be reduced by the fair market value of improvements in the leased premises made by or at the expense of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7787198c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410kkkk/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not acquire an interest in more than 12,000 square feet under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7787198d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410kkkk/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall submit the economic analysis, together with any proposed acquisition, to the appropriate committees of Congress for their review at least 120 days before the effective date of such acquisition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7787198e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/349/s1"},"text":"Pub. L. 100–349, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-27"},"text":"June 27, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/659"},"text":"102 Stat. 659","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/632"},"text":"Pub. L. 101–632","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4575"},"text":"104 Stat. 4575","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7787198f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77871990-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77871991-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Act of ","children":[{"tag":"date","attrib":{"date":"1935-08-21"},"text":"August 21, 1935","children":[],"tail":", referred to in subsec. (a), is "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-21/ch593"},"text":"act Aug. 21, 1935, ch. 593","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/666"},"text":"49 Stat. 666","children":[],"tail":", known as the Historic Sites, Buildings and Antiquities Act and also as the Historic Sites Act of 1935. Section 2 of the Act was repealed and substantially restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s320102"},"text":"section 320102 of Title 54","children":[],"tail":", National Park Service and Related Programs, by "},{"tag":"ref","attrib":{"href":"/us/pl/113/287"},"text":"Pub. L. 113–287","children":[],"tail":", §§ 3, 7, "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3257"},"text":"128 Stat. 3257","children":[],"tail":", 3274. For complete classification of this Act to the Code, see Tables. For disposition of former sections of this title, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100101"},"text":"section 100101 of Title 54","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77871992-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/632"},"text":"Pub. L. 101–632","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77871993-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id77871994-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/25/s1"},"text":"Pub. L. 119–25, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-15"},"text":"July 15, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/408"},"text":"139 Stat. 408","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/25/s1"},"text":"“This Act [enacting provisions set out as a note under this section] may be cited as the ‘Salem Maritime National Historical Park Redesignation and Boundary Study Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77871995-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Redesignation of Salem Maritime National Historical Site","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/25/s2"},"text":"Pub. L. 119–25, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-15"},"text":"July 15, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/408"},"text":"139 Stat. 408","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/25/s2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Redesignation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Salem Maritime National Historic Site shall hereafter be known and designated as the ‘Salem Maritime National Historical Park’.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"References in Law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any reference to the Salem Maritime National Historic Site in any law, regulation, map, document, record, or other paper of the United States shall be deemed to be a reference to the Salem Maritime National Historical Park.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
