{"tag":"section","attrib":{"id":"id79a935e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3121"},"text":null,"children":[{"tag":"num","attrib":{"value":"3121"},"text":"§ 3121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural residents engaged in subsistence uses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79a935e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3121/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to subsistence resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that rural residents engaged in subsistence uses shall have reasonable access to subsistence resources on the public lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a935e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3121/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of snowmobiles, motorboats, or other means of surface transportation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this Act or other law, the Secretary shall permit on the public lands appropriate use for subsistence purposes of snowmobiles, motorboats, and other means of surface transportation traditionally employed for such purposes by local residents, subject to reasonable regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a935e9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/487/tVIII/s811"},"text":"Pub. L. 96–487, title VIII, § 811","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-02"},"text":"Dec. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2428"},"text":"94 Stat. 2428","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a935ea-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79a935eb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79a935ec-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (b), is Pub. L 96–487, ","children":[{"tag":"date","attrib":{"date":"1980-12-02"},"text":"Dec. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2371"},"text":"94 Stat. 2371","children":[],"tail":", known as the Alaska National Interest Lands Conservation Act. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3101"},"text":"section 3101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
