{"tag":"section","attrib":{"id":"id78b11b22-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824u"},"text":null,"children":[{"tag":"num","attrib":{"value":"824u"},"text":"§ 824u.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on filing false information","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No entity (including an entity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s824/f"},"text":"section 824(f) of this title","children":[],"tail":") shall willfully and knowingly report any information relating to the price of electricity sold at wholesale or the availability of transmission capacity, which information the person or any other entity knew to be false at the time of the reporting, to a Federal agency with intent to fraudulently affect the data being compiled by the Federal agency."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78b11b23-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-10/ch285"},"text":"June 10, 1920, ch. 285","children":[],"tail":", pt. II, § 221, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXII/s1282"},"text":"Pub. L. 109–58, title XII, § 1282","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/979"},"text":"119 Stat. 979","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
