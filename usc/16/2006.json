{"tag":"section","attrib":{"id":"id798c8661-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2006"},"text":null,"children":[{"tag":"num","attrib":{"value":"2006"},"text":"§ 2006.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id798c8662-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2006/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appraisal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the date on which Congress convenes in 2011, 2016, and 2022, the President shall transmit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate the appraisal developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2004"},"text":"section 2004 of this title","children":[],"tail":" and completed before the end of the previous year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798c8663-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2006/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program and statement of policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than the date on which Congress convenes in 2012, 2017, and 2023, the President shall transmit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id798ef664-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2006/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the initial program or updated program developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2005"},"text":"section 2005 of this title","children":[],"tail":" and completed before the end of the previous year;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798ef665-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2006/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed statement of policy regarding soil and water conservation activities of the Department of Agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798ef666-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2006/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a special evaluation of the status, conditions, and trends of soil quality on cropland in the United States that addresses the challenges and opportunities for reducing soil erosion to tolerance levels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798ef667-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2006/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improvements to appraisal and program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the date on which Congress convenes in 2012, the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report describing the plans of the Department of Agriculture for improving the resource appraisal and national conservation program required under this chapter, based on the recommendations received under sections 2004(d) and 2005(c) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id798ef668-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/192/s7"},"text":"Pub. L. 95–192, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-18"},"text":"Nov. 18, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1410"},"text":"91 Stat. 1410","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1252/c"},"text":"Pub. L. 99–198, title XII, § 1252(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1516"},"text":"99 Stat. 1516","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tII/s2804/d"},"text":"Pub. L. 110–234, title II, § 2804(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1087"},"text":"122 Stat. 1087","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title II, § 2804(d), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1815; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII/s2402/3"},"text":"Pub. L. 115–334, title II, § 2402(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4571"},"text":"132 Stat. 4571","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id798ef669-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id798ef66a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id798ef66b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id798ef66c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2402/3/A"},"text":"Pub. L. 115–334, § 2402(3)(A)","children":[],"tail":", substituted “2011, 2016, and 2022” for “2011 and 2016”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2402/3/B"},"text":"Pub. L. 115–334, § 2402(3)(B)","children":[],"tail":", substituted “2012, 2017, and 2023” for “2012 and 2017” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s2804/d"},"text":"Pub. L. 110–246, § 2804(d)","children":[],"tail":", amended section generally. Prior to amendment, section related to transmission of appraisal developed under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2004"},"text":"section 2004 of this title","children":[],"tail":" at the time Congress convened in 1980, 1987, 1996, and 2006, transmission of program developed under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2005"},"text":"section 2005 of this title","children":[],"tail":" and statement of policy at the time Congress convened in 1980, 1988, 1998, and 2008, and annual report on program effectiveness."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1252/c/1"},"text":"Pub. L. 99–198, § 1252(c)(1)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a) which read as follows: “On the first day Congress convenes in 1980 and at each five-year interval thereafter during the period this chapter is in effect the President shall transmit to the Speaker of the House of Representatives and the President of the Senate, the appraisal and the program as required by sections 2004 and 2005 of this title, together with a detailed statement of policy regarding soil and water conservation activities of the United States Department of Agriculture.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1252/c/2"},"text":"Pub. L. 99–198, § 1252(c)(2)","children":[],"tail":", (3), struck out subsec. (b) which provided for an annual report of program and policy achievement, and redesignated subsec. (c) as (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id798ef66d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id798ef66e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id798ef66f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id798ef670-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Reporting and Other Authorities","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2011-02-14"},"text":"Feb. 14, 2011","children":[],"tail":", 76 F.R. 9493, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the Secretary of Agriculture","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":", United States Code, I hereby delegate to you the functions and authority conferred upon the President by section 7 of the Soil and Water Resources Conservation Act of 1977 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2006"},"text":"16 U.S.C. 2006","children":[],"tail":"), as amended by section 2804 of the Food, Conservation, and Energy Act of 2008, to make the specified reports to the Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"You are authorized and directed to publish this memorandum in the Federal Register.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Barack Obama.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
