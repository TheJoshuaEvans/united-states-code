{"tag":"section","attrib":{"id":"id7851bbeb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j"},"text":null,"children":[{"tag":"num","attrib":{"value":"583j"},"text":"§ 583j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and purposes of Foundation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7851bbec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the National Forest Foundation (hereinafter referred to as the “Foundation”) as a charitable and nonprofit corporation domiciled in the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7851bbed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Foundation are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7851bbee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage, accept, and administer private gifts of money, and of real and personal property for the benefit of, or in connection with, the activities and services of the Forest Service of the Department of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bbef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" undertake and conduct activities that further the purposes for which units of the National Forest System are established and are administered and that are consistent with approved forest plans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bbf0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" undertake, conduct and encourage educational, technical and other assistance, and other activities that support the multiple use, research, cooperative forestry and other programs administered by the Forest Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7851bbf1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation and conflicts of interests","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7851bbf2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Foundation shall not participate or intervene in a political campaign on behalf of any candidate for public office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bbf3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No director, officer, or employee of the Foundation shall participate, directly or indirectly, in the consideration or determination of any question before the Foundation affecting—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7851bbf4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial interests of the director, officer, or employee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7851bbf5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the interests of any corporation partnership, entity, or organization in which such director, officer, or employee—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7851bbf6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an officer, director, or trustee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7851bbf7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has any direct or indirect financial interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7851bbf8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/593/tIV/s402"},"text":"Pub. L. 101–593, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2970"},"text":"104 Stat. 2970","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7851bbf9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7851bbfa-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id7851bbfb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/106/s1"},"text":"Pub. L. 103–106, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-10-12"},"text":"Oct. 12, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1031"},"text":"107 Stat. 1031","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/106/s1"},"text":"“This Act [amending sections 583j–3 and 583j–8 of this title and enacting provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s583j–3"},"text":"section 583j–3 of this title","children":[],"tail":"] may be cited as the ‘National Forest Foundation Act Amendment Act of 1993’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7851bbfc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/593/tIV/s401"},"text":"Pub. L. 101–593, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2969"},"text":"104 Stat. 2969","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/593/tIV/s401"},"text":"“This title [enacting this subchapter] may be cited as the ‘National Forest Foundation Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
