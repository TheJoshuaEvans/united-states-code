{"tag":"section","attrib":{"id":"id796ffd59-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827"},"text":null,"children":[{"tag":"num","attrib":{"value":"1827"},"text":"§ 1827.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Observer program regarding certain foreign fishing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id796ffd5a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id796ffd5b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Act of 1976” means the Magnuson-Stevens Fishery Conservation and Management Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1801"},"text":"16 U.S.C. 1801","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id796ffd5c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “billfish” means any species of marlin, spearfish, sailfish or swordfish.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id796ffd5d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id796ffd5e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Observer program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a program under which a United States observer will be stationed aboard each foreign fishing vessel while that vessel—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id796ffd5f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is in waters that are within—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id796ffd60-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fishery conservation zone established under section 101 of the Act of 1976 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1811"},"text":"16 U.S.C. 1811","children":[],"tail":"],"},{"tag":"ref","attrib":{"idref":"fn002681"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002681"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id796ffd61-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Convention area as defined in Article I of the International Convention for the Conservation of Atlantic Tunas; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id796ffd62-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is taking or attempting to take any species of fish if such taking or attempting to take may result in the incidental taking of billfish.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Secretary may acquire observers for such program through contract with qualified private persons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id796ffd63-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of observers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"United States observers, while aboard foreign fishing vessels as required under subsection (b), shall carry out such scientific and other functions as the Secretary deems necessary or appropriate to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id796ffd64-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is imposed for each year after 1980 on the owner or operator of each foreign fishing vessel that, in the judgment of the Secretary, will engage in fishing in waters described in subsection (b)(1) during that year which may result in the incidental taking of billfish a fee in an amount sufficient to cover all of the costs of providing an observer aboard that vessel under the program established under subsection (a). The fees imposed under this subsection for any year shall be paid to the Secretary before that year begins. All fees collected by the Secretary under this subsection shall be deposited in the Fund established by subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id796ffd65-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States the Foreign Fishing Observer Fund. The Fund shall be available to the Secretary as a revolving fund for the purpose of carrying out this section. The Fund shall consist of the fees deposited into it as required under subsection (d). All payments made by the Secretary to carry out this section shall be paid from the Fund, only to the extent and in the amounts provided for in advance in appropriation Acts. Sums in the Fund which are not currently needed for the purposes of this section shall be kept on deposit or invested in obligations of, or guaranteed by, the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id796ffd66-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited acts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id796ffd67-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" It is unlawful for any person who is the owner or operator of a foreign fishing vessel to which this section applies—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id796ffd68-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to violate any regulation issued under subsection (g);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id796ffd69-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to refuse to pay the fee imposed under subsection (d) after being requested to do so by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id796ffd6a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to refuse to permit an individual who is authorized to act as an observer under this section with respect to that vessel to board the vessel for purposes of carrying out observer functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id796ffd6b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 308 of the Act of 1976 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1858"},"text":"16 U.S.C. 1858","children":[],"tail":"] (relating to civil penalties) applies to any act that is unlawful under paragraph (1), and for purposes of such application the commission of any such act shall be treated as an act the commission of which is unlawful under section 307 of the Act of 1976 ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1857"},"text":"16 U.S.C. 1857","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id796ffd6c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1827/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue such regulations as are necessary or appropriate to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id796ffd6d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/339/s2"},"text":"Pub. L. 96–339, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-04"},"text":"Sept. 4, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1069"},"text":"94 Stat. 1069","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/561/tII/s238/b"},"text":"Pub. L. 96–561, title II, § 238(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3300"},"text":"94 Stat. 3300","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/a/tII/s211/b"},"text":"Pub. L. 104–208, div. A, title I, § 101(a) [title II, § 211(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009"},"text":"110 Stat. 3009","children":[],"tail":", 3009–41.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id796ffd6e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id796ffd6f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id796ffd70-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Magnuson-Stevens Fishery Conservation and Management Act, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265"},"text":"Pub. L. 94–265","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-13"},"text":"Apr. 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/331"},"text":"90 Stat. 331","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1801"},"text":"section 1801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 101 of the Act of 1976 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1811"},"text":"16 U.S.C. 1811","children":[],"tail":"], referred to in subsec. (b)(1)(A), which established the fishery conservation zone, was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/99/659/tI/s101/b"},"text":"Pub. L. 99–659, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3706"},"text":"100 Stat. 3706","children":[],"tail":", and now relates to United States sovereign rights to fish and fishery management authority within the exclusive economic zone."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id796ffd71-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Magnuson-Stevens Fishery Conservation and Management Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id796ffd72-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" substituted “Magnuson-Stevens Fishery” for “Magnuson Fishery”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/561"},"text":"Pub. L. 96–561","children":[],"tail":" substituted “Magnuson Fishery Conservation and Management Act” for “Fishery Conservation and Management Act of 1976”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id796ffd73-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id796ffd74-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/a/tII/s211/b"},"text":"Pub. L. 104–208, div. A, title I, § 101(a) [title II, § 211(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009"},"text":"110 Stat. 3009","children":[],"tail":", 3009–41, provided that the amendment made by that section is effective 15 days after "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id796ffd75-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/561/tII/s238/b"},"text":"Pub. L. 96–561, title II, § 238(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3300"},"text":"94 Stat. 3300","children":[],"tail":", provided that the amendment made by that section is effective 15 days after "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
