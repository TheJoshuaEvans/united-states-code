{"tag":"section","attrib":{"id":"id7800b660-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–72"},"text":null,"children":[{"tag":"num","attrib":{"value":"460nnn–72"},"text":"§ 460nnn–72.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donner und Blitzen River Redband Trout Reserve","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7800b661-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–72/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7800b662-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–72/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Those portions of the Donner und Blitzen River in the Wilderness Area are an exceptional environmental resource that provides habitat for unique populations of native fish, migratory waterfowl, and other wildlife resources, including a unique population of redband trout.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b663-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–72/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Redband trout represent a unique natural history reflecting the Pleistocene connection between the lake basins of eastern Oregon and the Snake and Columbia Rivers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b664-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–72/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of Reserve","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall designate the Donner und Blitzen Redband Trout Reserve consisting of the Donner und Blitzen River in the Wilderness Area above its confluence with Fish Creek and the Federal riparian lands immediately adjacent to the river.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b665-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–72/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserve purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Redband Trout Reserve are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7800b666-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–72/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conserve, protect, and enhance the Donner und Blitzen River population of redband trout and the unique ecosystem of plants, fish, and wildlife of a river system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b667-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–72/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide opportunities for scientific research, environmental education, and fish and wildlife oriented recreation and access to the extent compatible with paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b668-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–72/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of private lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Redband Trout Reserve does not include any private lands adjacent to the Donner und Blitzen River or its tributaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b669-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–72/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7800b66a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–72/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall administer all lands, waters, and interests therein in the Redband Trout Reserve consistent with the Wilderness Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"16 U.S.C. 1131","children":[],"tail":" et seq.) and the Wild and Scenic Rivers Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1271"},"text":"16 U.S.C. 1271","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b66b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–72/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In administering the Redband Trout Reserve, the Secretary shall consult with the advisory council and cooperate with the Oregon Department of Fish and Wildlife.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b66c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–72/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to recreation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent consistent with applicable law, the Secretary shall manage recreational activities in the Redband Trout Reserve in a manner that conserves the unique population of redband trout native to the Donner und Blitzen River.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b66d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–72/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of dam","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall remove the dam located below the mouth of Fish Creek and above Page Springs if removal of the dam is scientifically justified and funds are available for such purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b66e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–72/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach and education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may work with, provide technical assistance to, provide community outreach and education programs for or with, or enter into cooperative agreements with private landowners, State and local governments or agencies, and conservation organizations to further the purposes of the Redband Trout Reserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7800b66f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/399/tIII/s302"},"text":"Pub. L. 106–399, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1668"},"text":"114 Stat. 1668","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7800b670-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7800b671-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7800b672-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Wilderness Act, referred to in subsec. (e)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/577"},"text":"Pub. L. 88–577","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-09-03"},"text":"Sept. 3, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/890"},"text":"78 Stat. 890","children":[],"tail":", which is classified generally to chapter 23 (§ 1131 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"section 1131 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Wild and Scenic Rivers Act, referred to in subsec. (e)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/542"},"text":"Pub. L. 90–542","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-02"},"text":"Oct. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/906"},"text":"82 Stat. 906","children":[],"tail":", which is classified generally to chapter 28 (§ 1271 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1271"},"text":"section 1271 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
