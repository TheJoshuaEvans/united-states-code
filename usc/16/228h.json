{"tag":"section","attrib":{"id":"id7716f1b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s228h"},"text":null,"children":[{"tag":"num","attrib":{"value":"228h"},"text":"§ 228h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction with existing Colorado River system reclamation provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in sections 228a to 228j of this title shall be construed to alter, amend, repeal, modify, or be in conflict with the provisions of sections 1551 to 1556 of title 43.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7716f1b7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/620/s9/a"},"text":"Pub. L. 93–620, § 9(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2091"},"text":"88 Stat. 2091","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
