{"tag":"section","attrib":{"id":"id7a0fc059-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6552"},"text":null,"children":[{"tag":"num","attrib":{"value":"6552"},"text":"§ 6552.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0fc05a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6552/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applied silvicultural assessment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0fc05b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6552/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “applied silvicultural assessment” means any vegetative or other treatment carried out for information gathering and research purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc05c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6552/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “applied silvicultural assessment” includes timber harvesting, thinning, prescribed burning, pruning, and any combination of those activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fc05d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6552/2"},"text":null,"children":[{