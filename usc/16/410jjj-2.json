{"tag":"section","attrib":{"id":"id77740690-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjj–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"410jjj–2"},"text":"§ 410jjj–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77740691-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjj–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall administer property acquired for the park in accordance with the Act of ","children":[{"tag":"date","attrib":{"date":"1916-08-25"},"text":"August 25, 1916","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/39/535"},"text":"39 Stat. 535","children":[],"tail":"),"},{"tag":"ref","attrib":{"idref":"fn002175"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002175"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" as amended and supplemented, and the provisions of this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77740692-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjj–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sport fishing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall permit sport fishing on lands and waters under his jurisdiction within the park in accordance with applicable Federal and State laws, except that he may designate zones where and establish periods when no fishing shall be permitted for reasons of public safety, administration, fish or wildlife management, or public use and enjoyment. Except in emergencies, any regulations promulgated under this subsection shall be placed in effect only after consultation with the appropriate fish and game agency of the State of South Carolina.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77740693-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jjj–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Visitor center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At such time as the principal visitor center at such park is established, such center shall be designated as the “Harry R. E. Hampton Visitor Center”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77740694-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/545/s3"},"text":"Pub. L. 94–545, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-18"},"text":"Oct. 18, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2517"},"text":"90 Stat. 2517","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/506/s1"},"text":"Pub. L. 98–506, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2338"},"text":"98 Stat. 2338","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/108/tI/s135"},"text":"Pub. L. 108–108, title I, § 135","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-10"},"text":"Nov. 10, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1270"},"text":"117 Stat. 1270","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","a