{"tag":"section","attrib":{"id":"id781157e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii"},"text":null,"children":[{"tag":"num","attrib":{"value":"460iiii"},"text":"§ 460iiii.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pistone-Black Mountain National Conservation Area","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id781157e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id781157e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Conservation Area” means the Pistone-Black Mountain National Conservation Area established by paragraph (2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id781157e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id781157e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Tribe” means the Walker River Paiute Tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id781157e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id781157e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To protect, conserve, and enhance the unique and nationally important historic, cultural, archaeological, natural, and educational resources of the Pistone Site on Black Mountain, subject to valid existing rights, there is established in Mineral County, Nevada, the Pistone-Black Mountain National Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id781157ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area included","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id781157eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Conservation Area shall consist of the approximately 3,415 acres of public land in Mineral County, Nevada, administered by the Bureau of Land Management, as depicted on the map entitled “Black Mountain/Pistone Archaeological District” and dated ","children":[{"tag":"date","attrib":{"date":"2020-05-12"},"text":"May 12, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id781157ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map described in clause (i) shall be on file and available for public inspection in the appropriate offices of the Bureau of Land Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id781157ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id781157ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall manage the Conservation Area—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id781157ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner that conserves, protects, and enhances the resources and values of the Conservation Area, including the resources and values described in paragraph (2)(A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id781157f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in accordance with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id781157f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id781157f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"43 U.S.C. 1701","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id781157f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/3/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other applicable law; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id781157f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a component of the National Landscape Conservation System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id781157f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall allow only those uses of the Conservation Area that the Secretary determines would further the purposes of the Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id781157f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal cultural resources","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In administering the Conservation Area, the Secretary shall provide for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id781157f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to and use of cultural resources by the Tribe at the Conservation Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id781157f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection from disturbance of the cultural resources and burial sites of the Tribe located in the Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id781157f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, in a manner consistent with this section, enter into cooperative agreements with the State of Nevada, affected Indian tribes, and institutions and organizations to carry out the purposes of this section, subject to the requirement that the Tribe shall be a party to any cooperative agreement entered into under this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id781157fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id781157fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the Secretary shall develop a management plan for the Conservation Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id781157fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the management plan required under subparagraph (A), the Secretary shall consult with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id781157fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate State, Tribal, and local governmental entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id781157fe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id781157ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The management plan developed under subparagraph (A) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78115800-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the appropriate uses and management of the Conservation Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78115801-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate, as appropriate, decisions contained in any other management or activity plan for the land in or adjacent to the Conservation Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78115802-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into consideration any information developed in studies of the land and resources in or adjacent to the Conservation Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78115803-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/4/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for a cooperative agreement with the Tribe to address the historical, archaeological, and cultural values of the Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78115804-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78115805-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to valid existing rights, all public land in the Conservation Area is withdrawn from—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78115806-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all forms of entry, appropriation, and disposal under the public land laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78115807-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" location, entry, and patent under the mining laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78115808-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/5/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disposition under all laws relating to mineral and geothermal leasing or mineral materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78115809-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary acquires mineral or other interests in a parcel of land within the Conservation Area after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the parcel is withdrawn from operation of the laws referred to in subparagraph (A) on the date of acquisition of the parcel."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7811580a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hunting, fishing, and trapping","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7811580b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), nothing in this section affects the jurisdiction of the State of Nevada with respect to fish and wildlife, including hunting, fishing, and trapping in the Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7811580c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7811580d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may designate by regulation areas in which, and establish periods during which, no hunting, fishing, or trapping will be permitted in the Conservation Area, for reasons of public safety, administration, or compliance with applicable laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7811580e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except in an emergency, the Secretary shall consult with the appropriate State agency and notify the public before taking any action under clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7811580f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grazing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of land included in the Conservation Area on which the Secretary permitted, as of ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", livestock grazing, the livestock grazing shall be allowed to continue, subject to applicable laws (including regulations)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78115810-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No buffer zones","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78115811-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section creates a protective perimeter or buffer zone around the Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78115812-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities outside Conservation Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The fact that an activity or use on land outside the Conservation Area can be seen or heard within the Conservation Area shall not preclude the activity or use outside the boundary of the Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78115813-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military overflights","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section restricts or precludes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78115814-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" low-level overflights of military aircraft over the Conservation Area, including military overflights that can be seen or heard within the Conservation Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78115815-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flight testing and evaluation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78115816-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the designation or creation of new units of special use airspace, or the establishment of military flight training routes, over the Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78115817-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460iiii/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on water rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section constitutes an express or implied reservation of any water rights with respect to the Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78115818-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dB/tXXIX/s2903/b"},"text":"Pub. L. 117–263, div. B, title XXIX, § 2903(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3037"},"text":"136 Stat. 3037","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78115819-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7811581a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7811581b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Land Policy and Management Act of 1976, referred to in par. (3)(A)(ii)(II), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579"},"text":"Pub. L. 94–579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2743"},"text":"90 Stat. 2743","children":[],"tail":", which is classified principally to chapter 35 (§ 1701 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
