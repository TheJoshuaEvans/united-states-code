{"tag":"section","attrib":{"id":"id77e1bc1a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460jj–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"460jj–3"},"text":"§ 460jj–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permits for facilities and services","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall cooperate with other Federal agencies, with State and local public agencies, and with private individuals and organizations in the issuance of permits for facilities and services in the Arapaho National Recreation Area and the development and operation of those facilities and services.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77e1bc1b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/450/s7"},"text":"Pub. L. 95–450, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-11"},"text":"Oct. 11, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1097"},"text":"92 Stat. 1097","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
