{"tag":"section","attrib":{"id":"id78438ab4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551c–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"551c–1"},"text":"§ 551c–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on prescribed burns","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78438ab5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551c–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), the Secretary shall not authorize a prescribed burn on Forest Service land if, for the county or contiguous county in which the land is located, the national fire danger rating system indicates an extreme fire danger level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78438ab6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551c–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may authorize a prescribed burn under a condition described in subsection (a) if the Secretary coordinates with the applicable State government and local fire officials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78438ab7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551c–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the end of each fiscal year, the Secretary shall submit to Congress a report describing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78438ab8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551c–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and locations of prescribed burns during that fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78438ab9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s551c–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each prescribed burn during that fiscal year that was authorized by the Secretary pursuant to subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78438aba-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/275/s3"},"text":"Pub. L. 114–275, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-14"},"text":"Dec. 14, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1405"},"text":"130 Stat. 1405","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78438abb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78438abc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id78438abd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/275/s2"},"text":"Pub. L. 114–275, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-14"},"text":"Dec. 14, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1405"},"text":"130 Stat. 1405","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/275/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this Act [enacting this section and provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s551"},"text":"section 551 of this title","children":[],"tail":"]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National fire danger rating system","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘national fire danger rating system’ means the national system used to provide a measure of fire danger according to a range of low to moderate to high to very high to extreme.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prescribed burn","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘prescribed burn’ means a planned fire intentionally ignited.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Secretary’ means the Secretary of Agriculture, acting through the Chief of the Forest Service.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
