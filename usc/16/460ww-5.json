{"tag":"section","attrib":{"id":"id77eda34e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ww–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"460ww–5"},"text":"§ 460ww–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77eda34f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ww–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established the Gauley River National Recreation Area Advisory Committee (hereinafter in this Act referred to as the “Advisory Committee”). The Advisory Committee shall be composed of fifteen members appointed by the Secretary to serve for terms of two years. Any member of the Advisory Committee may serve after the expiration of his term until a successor is appointed. Any member of the Advisory Committee may be appointed to serve more than one term. The Secretary or his designee shall serve as Chairman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77eda350-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ww–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management and development issues","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, or his designee, shall meet on a regular basis and consult with the Advisory Committee on matters relating to development of a management plan for the recreation area and on implementation of such plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77eda351-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ww–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Advisory Committee shall serve without compensation as such, but the Secretary may pay expenses reasonably incurred in carrying out their responsibilities under this Act on vouchers signed by the Chairman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77eda352-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ww–5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall appoint members to the Advisory Committee as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77eda353-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ww–5/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member to represent other departments or agencies of the United States administering lands affected by the recreation area, to be appointed from among persons nominated by the head of such department or agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77eda354-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ww–5/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two members to represent the State Department of Natural Resources, to be appointed from among persons nominated by the Governor of the State of West Virginia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77eda355-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ww–5/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member to represent the State Department of Commerce to be appointed from among persons nominated by the Governor of West Virginia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77eda356-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ww–5/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three members to represent the commercial whitewater rafting industry in West Virginia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77eda357-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ww–5/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member to represent noncommercial whitewater boating organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77eda358-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ww–5/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member to represent conservation organizations in West Virginia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77eda359-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ww–5/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member to represent individuals engaged in game fishing in West Virginia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77eda35a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ww–5/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member to represent the Nicholas County Chamber of Commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77eda35b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ww–5/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member to represent the Fayette County Chamber of Commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77eda35c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ww–5/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member to represent recreational users of Summersville Lake; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77eda35d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ww–5/d/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two members to represent local citizens or citizens groups which are concerned with the Gauley River or own lands included within the boundaries of the recreation area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77eda35e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ww–5/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination; charter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall terminate on the date ten years after ","children":[{"tag":"date","attrib":{"date":"1988-10-26"},"text":"October 26, 1988","children":[],"tail":", notwithstanding chapter 10 of title 5. The provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013/b"},"text":"section 1013(b) of title 5","children":[],"tail":" (relating to the charter of the Committee),"},{"tag":"ref","attrib":{"idref":"fn002352"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002352"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" are hereby waived with respect to this Advisory Committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77eda35f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/534/tII/s206"},"text":"Pub. L. 100–534, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-26"},"text":"Oct. 26, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2705"},"text":"102 Stat. 2705","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/92"},"text":"Pub. L. 117–286, § 4(a)(92)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4316"},"text":"136 Stat. 4316","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77eda360-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77eda361-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77eda362-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsecs. (a) and (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/534"},"text":"Pub. L. 100–534","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-26"},"text":"Oct. 26, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2699"},"text":"102 Stat. 2699","children":[],"tail":", known as the West Virginia National Interest River Conservation Act of 1987, which enacted this subchapter and sections 410eeee–12 to 410eeee–15 of this title, amended sections 410eeee–1 and 1274 of this title, and enacted provisions set out as notes under sections 410eeee–1 and 1274 of this title. For complete classification of this Act to the Code, see Short Title of 1988 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410eeee–1"},"text":"section 410eeee–1 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77eda363-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5. The provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013/b"},"text":"section 1013(b) of title 5","children":[],"tail":" (relating to the charter of the Committee),” for “the Federal Advisory Committee Act (Act of "},{"tag":"date","attrib":{"date":"1972-10-06"},"text":"October 6, 1972","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/86/776"},"text":"86 Stat. 776","children":[],"tail":"). The provisions of section 14(b) of such Act (relating to the charter of the Committee)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
