{"tag":"section","attrib":{"id":"id7a0addd7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6413"},"text":null,"children":[{"tag":"num","attrib":{"value":"6413"},"text":"§ 6413.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports on administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a0addd8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6413/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", and every 2 years thereafter, the Administrator shall submit to the committees specified in subsection (b) a report on the administration of this chapter during the 2-year period preceding submission of the report, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0addd9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6413/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of all activities undertaken to implement the National Coral Reef Resilience Strategy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0addda-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6413/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of all funds obligated under the authorities of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0adddb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6413/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary, disaggregated by State, of Federal and non-Federal contributions toward the costs of each project or activity funded, in full or in part, under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0adddc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6413/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committees specified","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The committees specified in this subsection are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0adddd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6413/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce, Science, and Transportation, Committee on Environment and Public Works, Committee on Energy and Natural Resources, and the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0addde-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6413/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Natural Resources and the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0adddf-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/562/tII/s214"},"text":"Pub. L. 106–562, title II, § 214","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tC/s10001/a"},"text":"Pub. L. 117–263, div. J, title C, § 10001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3947"},"text":"136 Stat. 3947","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
