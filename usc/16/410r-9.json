{"tag":"section","attrib":{"id":"id7749261f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"410r–9"},"text":"§ 410r–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary revision","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77492620-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of Tarpon Basin property","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77492621-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77492622-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hurricane Hole","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Hurricane Hole” means the natural salt-water body of water within the Duesenbury Tracts of the eastern parcel of the Tarpon Basin boundary adjustment and accessed by Duesenbury Creek.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77492623-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “map” means the map entitled “Proposed Tarpon Basin Boundary Revision”, numbered 160/80,012, and dated May 2008.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77492624-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77492625-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tarpon Basin property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Tarpon Basin property” means land that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77492626-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/a/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is comprised of approximately 600 acres of land and water surrounding Hurricane Hole, as generally depicted on the map; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77492627-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/a/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located in South Key Largo.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77492628-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary revision","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77492629-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The boundary of the Everglades National Park is adjusted to include the Tarpon Basin property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7749262a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire from willing sellers by donation, purchase with donated or appropriated funds, or exchange, land, water, or interests in land and water, within the area depicted on the map, to be added to Everglades National Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7749262b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map shall be on file and available for public inspection in the appropriate offices of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7749262c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Land added to Everglades National Park by this section shall be administered as part of Everglades National Park in accordance with applicable laws (including regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7749262d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hurricane Hole","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may allow use of Hurricane Hole by sailing vessels during emergencies, subject to such terms and conditions as the Secretary determines to be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7749262e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7749262f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land exchanges","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77492630-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77492631-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Company","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Company” means Florida Power & Light Company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77492632-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Land","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal Land” means the parcels of land that are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77492633-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned by the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77492634-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administered by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77492635-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" located within the National Park; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77492636-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" generally depicted on the map as—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id77492637-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/1/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tract A, which is adjacent to the Tamiami Trail, U.S. Rt. 41; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id77492638-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/1/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tract B, which is located on the eastern boundary of the National Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77492639-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “map” means the map prepared by the National Park Service, entitled “Proposed Land Exchanges, Everglades National Park”, numbered 160/60411A, and dated September 2008.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7749263a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Park","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National Park” means the Everglades National Park located in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7749263b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal land","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “non-Federal land” means the land in the State that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7749263c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is owned by the State, the specific area and location of which shall be determined by the State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7749263d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7749263e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/1/E/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is owned by the Company;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7749263f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/1/E/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comprises approximately 320 acres; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id77492640-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/1/E/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located within the East Everglades Acquisition Area, as generally depicted on the map as “Tract D”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77492641-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77492642-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means the State of Florida and political subdivisions of the State, including the South Florida Water Management District.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77492643-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land exchange with State","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77492644-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the provisions of this paragraph, if the State offers to convey to the Secretary all right, title, and interest of the State in and to specific parcels of non-Federal land, and the offer is acceptable to the Secretary, the Secretary may, subject to valid existing rights, accept the offer and convey to the State all right, title, and interest of the United States in and to the Federal land generally depicted on the map as “Tract A”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77492645-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The land exchange under subparagraph (A) shall be subject to such terms and conditions as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77492646-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Valuation","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77492647-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The values of the land involved in the land exchange under subparagraph (A) shall be equal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77492648-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equalization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the values of the land are not equal, the values may be equalized by donation, payment using donated or appropriated funds, or the conveyance of additional parcels of land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77492649-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appraisals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before the exchange of land under subparagraph (A), appraisals for the Federal and non-Federal land shall be conducted in accordance with the Uniform Appraisal Standards for Federal Land Acquisitions and the Uniform Standards of Professional Appraisal Practice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7749264a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical corrections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the agreement of the State, the Secretary may make minor corrections to correct technical and clerical errors in the legal descriptions of the Federal and non-Federal land and minor adjustments to the boundaries of the Federal and non-Federal land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7749264b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of land acquired by Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Land acquired by the Secretary under subparagraph (A) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7749264c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" become part of the National Park; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7749264d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be administered in accordance with the laws applicable to the National Park System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7749264e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land exchange with company","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7749264f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the provisions of this paragraph, if the Company offers to convey to the Secretary all right, title, and interest of the Company in and to the non-Federal land generally depicted on the map as “Tract D”, and the offer is acceptable to the Secretary, the Secretary may, subject to valid existing rights, accept the offer and convey to the Company all right, title, and interest of the United States in and to the Federal land generally depicted on the map as “Tract B”, along with a perpetual easement on a corridor of land contiguous to Tract B for the purpose of vegetation management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77492650-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The land exchange under subparagraph (A) shall be subject to such terms and conditions as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77492651-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Valuation","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77492652-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The values of the land involved in the land exchange under subparagraph (A) shall be equal unless the non-Federal land is of higher value than the Federal land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77492653-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equalization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the values of the land are not equal, the values may be equalized by donation, payment using donated or appropriated funds, or the conveyance of additional parcels of land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77492654-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appraisal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before the exchange of land under subparagraph (A), appraisals for the Federal and non-Federal land shall be conducted in accordance with the Uniform Appraisal Standards for Federal Land Acquisitions and the Uniform Standards of Professional Appraisal Practice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77492655-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical corrections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the agreement of the Company, the Secretary may make minor corrections to correct technical and clerical errors in the legal descriptions of the Federal and non-Federal land and minor adjustments to the boundaries of the Federal and non-Federal land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77492656-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of land acquired by Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Land acquired by the Secretary under subparagraph (A) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77492657-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/3/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" become part of the National Park; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77492658-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/3/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be administered in accordance with the laws applicable to the National Park System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77492659-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map shall be on file and available for public inspection in the appropriate offices of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7749265a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–9/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary revision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On completion of the land exchanges authorized by this subsection, the Secretary shall adjust the boundary of the National Park accordingly, including removing the land conveyed out of Federal ownership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7749265b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVII/s7107"},"text":"Pub. L. 111–11, title VII, § 7107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1193"},"text":"123 Stat. 1193","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
