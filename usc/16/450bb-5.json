{"tag":"section","attrib":{"id":"id77a15807-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450bb–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"450bb–5"},"text":"§ 450bb–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums, not to exceed $300,000, as may be necessary for the purchase of lands, interests therein, and improvements thereon pursuant to sections 450bb–3 to 450bb–5 of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77a15808-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/655/s3"},"text":"Pub. L. 86–655, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-14"},"text":"July 14, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/521"},"text":"74 Stat. 521","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
