{"tag":"section","attrib":{"id":"id79b51d0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3315"},"text":null,"children":[{"tag":"num","attrib":{"value":"3315"},"text":"§ 3315.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary for the purposes of carrying out the provisions of this subchapter in fiscal years commencing after ","children":[{"tag":"date","attrib":{"date":"1981-09-30"},"text":"September 30, 1981","children":[],"tail":", an aggregate amount of $3,000,000. Funds appropriated pursuant to this section remain available to the Secretary until expended."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79b51d0f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/561/tI/s114"},"text":"Pub. L. 96–561, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3280"},"text":"94 Stat. 3280","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
