{"tag":"section","attrib":{"id":"id7a1df0ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6851"},"text":null,"children":[{"tag":"num","attrib":{"value":"6851"},"text":"§ 6851.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1df0cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6851/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal land” means any land managed by a Federal land management agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1df0d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6851/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal land management agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal land management agency” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1df0d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6851/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of Reclamation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df0d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6851/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Park Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df0d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6851/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of Land Management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df0d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6851/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Fish and Wildlife Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df0d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6851/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Forest Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df0d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6851/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Corps of Engineers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1df0d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6851/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Road or trail","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “road or trail” means a road or trail designated by 1 or more of the Secretaries for public use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1df0d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6851/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretaries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Secretaries” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1df0d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6851/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture, acting through the Chief of the Forest Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df0da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6851/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1df0db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6851/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Army, acting through the Assistant Secretary of the Army for Civil Works.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1df0dc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/114/s2"},"text":"Pub. L. 117–114, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-04-29"},"text":"Apr. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1175"},"text":"136 Stat. 1175","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a1df0dd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a1df0de-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a1df0df-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/114/s1"},"text":"Pub. L. 117–114, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-04-29"},"text":"Apr. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1175"},"text":"136 Stat. 1175","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/114/s1"},"text":"“This Act [enacting this chapter] may be cited as the ‘Modernizing Access to Our Public Land Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
