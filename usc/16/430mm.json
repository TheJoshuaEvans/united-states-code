{"tag":"section","attrib":{"id":"id7797ba6f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430mm"},"text":null,"children":[{"tag":"num","attrib":{"value":"430mm"},"text":"§ 430mm.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For development of the Wilson’s Creek National Battlefield, there are authorized to be appropriated not more than $5,640,000. There are authorized to be appropriated such sums as may be necessary to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s430kk/b"},"text":"section 430kk(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7797ba70-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/434/s3"},"text":"Pub. L. 86–434, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-04-22"},"text":"Apr. 22, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/76"},"text":"74 Stat. 76","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/554/s1/b"},"text":"Pub. L. 91–554, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-16"},"text":"Dec. 16, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1441"},"text":"84 Stat. 1441","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/625/tI/s101/29"},"text":"Pub. L. 95–625, title I, § 101(29)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3472"},"text":"92 Stat. 3472","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/394/s2/b"},"text":"Pub. L. 108–394, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail"