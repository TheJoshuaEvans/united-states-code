{"tag":"section","attrib":{"id":"id795cea5d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1721"},"text":null,"children":[{"tag":"num","attrib":{"value":"1721"},"text":"§ 1721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings and purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id795cea5e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1721/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id795cea5f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1721/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Conserving or developing natural and cultural resources and enhancing and maintaining environmentally important lands and waters through the use of the Nation’s young men and women in a Public Lands Corps can benefit those men and women by providing them with education and work opportunities, furthering their understanding and appreciation of the natural and cultural resources, and providing a means to pay for higher education or to repay indebtedness they have incurred to obtain higher education while at the same time benefiting the Nation’s economy and its environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795cea60-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1721/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Many facilities and natural resources located on eligible service lands are in disrepair or degraded and in need of labor intensive rehabilitation, restoration, and enhancement work which cannot be carried out by Federal agencies at existing personnel levels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795cea61-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1721/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Youth conservation corps have established a good record of restoring and maintaining these kinds of facilities and resources in a cost effective and efficient manner, especially when they have worked in partnership arrangements with government land management agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795cea62-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1721/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this subchapter to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id795cea63-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1721/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform, in a cost-effective manner, appropriate conservation projects on eligible service lands where such projects will not be performed by existing employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795cea64-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1721/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist governments and Indian tribes in performing research and public education tasks associated with natural and cultural resources on eligible service lands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795cea65-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1721/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expose young men and women to public service while furthering their understanding and appreciation of the Nation’s natural and cultural resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795cea66-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1721/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand educational opportunities by rewarding individuals who participate in national service with an increased ability to pursue higher education or job training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795cea67-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1721/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stimulate interest among the Nation’s young men and women in conservation careers by exposing them to conservation professionals in land managing agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id795cea68-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/378/tII/s202"},"text":"Pub. L. 91–378, title II, § 202","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s105/6"},"text":"Pub. L. 103–82, title I, § 105(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/848"},"text":"107 Stat. 848","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id795cea69-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id795cea6a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id795cea6b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s123"},"text":"section 123 of Pub. L. 103–82","children":[],"tail":", set out as an Effective Date of 1993 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1701"},"text":"section 1701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id795cea6c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/378"},"text":"Pub. L. 91–378","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s105/6"},"text":"Pub. L. 103–82, title I, § 105(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/848"},"text":"107 Stat. 848","children":[],"tail":", as the “Public Lands Corps Act of 1993”, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1701"},"text":"section 1701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
