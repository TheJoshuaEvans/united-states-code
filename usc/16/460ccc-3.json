{"tag":"section","attrib":{"id":"id77f25e49-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ccc–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"460ccc–3"},"text":"§ 460ccc–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77f25e4a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ccc–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77f25e4b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ccc–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No later than ","children":[{"tag":"date","attrib":{"date":"1997-01-01"},"text":"January 1, 1997","children":[],"tail":", the Secretary shall develop and transmit to the Committee on Energy and Natural Resources of the United States Senate and the Committee on Natural Resources of the United States House of Representatives, a general management plan for the conservation area, which shall describe the appropriate uses and development of the conservation area consistent with the purposes of this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77f25e4c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ccc–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The management plan described in paragraph (1) shall be developed with full public participation and shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77f25e4d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ccc–3/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an implementation plan for a continuing program of interpretation and public education about the resources and values of the conservation area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77f25e4e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ccc–3/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proposal for administrative and public facilities to be developed, expanded, or improved for the conservation area including the Red Rock Canyon visitors center, to accommodate visitors to the conservation area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77f25e4f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ccc–3/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a cultural resources management plan for the conservation area prepared in consultation with the Nevada State Historic Preservation Officer, with emphasis on the preservation of the resources in the conservation area and the interpretive, educational, and long-term scientific uses of these resources, giving priority to the enforcement of the Archaeological Resources Protection Act of 1979 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s470aa"},"text":"16 U.S.C. 470aa","children":[],"tail":" et seq.) and the National Historic Preservation Act "},{"tag":"ref","attrib":{"idref":"fn002362"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002362"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" within the conservation area;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77f25e50-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ccc–3/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a wildlife resource management plan for the conservation area prepared in consultation with appropriate departments of the State of Nevada and using previous studies of the area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77f25e51-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ccc–3/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a recreation management plan, including nonmotorized dispersed recreation opportunities for the conservation area in consultation with appropriate departments of the State of Nevada.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f25e52-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ccc–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wilderness study areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460ccc–5"},"text":"section 460ccc–5 of this title","children":[],"tail":", nothing in this subchapter is intended to alter the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1782"},"text":"section 1782 of title 43","children":[],"tail":", or section 5(a) of the National Forest and Public Lands of Nevada Enhancement Act of 1988 ("},{"tag":"ref","attrib":{"href":"/us/stat/102/2751"},"text":"102 Stat. 2751","children":[],"tail":"), as those requirements apply to the lands within, or adjacent to the conservation area as of "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"November 16, 1990","children":[],"tai