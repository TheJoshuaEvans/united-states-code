{"tag":"section","attrib":{"id":"id789bbd91-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s778"},"text":null,"children":[{"tag":"num","attrib":{"value":"778"},"text":"§ 778.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of experiment stations; purpose of research","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture shall establish 1 or more centers for the purpose of carrying on a program of research and experimentation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id789bbd92-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s778/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine species of fishes most suitable for culture on a commercial basis in shallow reservoirs and flooded rice lands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789bbd93-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s778/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine methods for production of fingerling fishes for stocking in commercial reservoirs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789bbd94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s778/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop methods for the control of parasites and diseases of brood fishes and of fingerlings prior to stocking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789bbd95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s778/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop economical methods for raising the more desirable species of fishes to a marketable size;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789bbd96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s778/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine, in cooperation with the Secretary of the Interior, the effects of fish-rice rotations, including crops other than rice commonly grown on rice farms, upon both the fish and other crops; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789bbd97-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s778/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop suitable methods for harvesting the fish crop and preparing it for marketing, including a study of sport fishing as a means of such harvest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id789bbd98-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/342/s1"},"text":"Pub. L. 85–342, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-03-15"},"text":"Mar. 15, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/35"},"text":"72 Stat. 35","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVIII/s889/a/1"},"text":"Pub. L. 104–127, title VIII, § 889(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1180"},"text":"110 Stat. 1180","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id789bbd99-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id789bbd9a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id789bbd9b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":", in introductory provisions, substituted “Secretary of Agriculture shall” for “Secretary of the Interior is authorized and directed to” and “1 or more centers” for “an experiment station or stations” and, in par. (5), substituted “Secretary of the Interior” for “Department of Agriculture”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
