{"tag":"section","attrib":{"id":"id78d74052-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s943a"},"text":null,"children":[{"tag":"num","attrib":{"value":"943a"},"text":"§ 943a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data base","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78d74053-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s943a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall maintain a central data base which provides an effective means for tracking and assessing relevant reference data on Great Lakes fish and wildlife, including data on tissues collected for and maintained in the Great Lakes Fish and Wildlife Tissue Bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78d74054-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s943a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish criteria, after an opportunity for public review and comment, for access to the data base which provides for appropriate use of the information by the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78d74055-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/440/tII/s203"},"text":"Pub. L. 102–440, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2233"},"text":"106 Stat. 2233","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
