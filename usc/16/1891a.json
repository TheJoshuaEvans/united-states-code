{"tag":"section","attrib":{"id":"id798c85b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1891a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1891a"},"text":"§ 1891a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community-based restoration program for fishery and coastal habitats","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id798c85b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1891a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce shall establish a community-based fishery and coastal habitat restoration program to implement and support the restoration of fishery and coastal habitats.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798c85b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1891a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id798c85b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1891a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide funding and technical expertise to fishery and coastal communities to assist them in restoring fishery and coastal habitat;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798c85b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1891a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advance the science and monitoring of coastal habitat restoration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798c85b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1891a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer restoration technologies to the private sector, the public, and other governmental agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798c85b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1891a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop public-private partnerships to accomplish sound coastal restoration projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798c85b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1891a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote significant community support and volunteer participation in fishery and coastal habitat restoration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798c85b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1891a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote stewardship of fishery and coastal habitats; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798c85ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1891a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leverage resources through national, regional, and local public-private partnerships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id798c85bb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/479/tI/s117"},"text":"Pub. L. 109–479, title I, § 117","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3606"},"text":"120 Stat. 3606","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id798c85bc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id798c85bd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id798c85be-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Magnuson-Stevens Fishery Conservation and Management Reauthorization Act of 2006, and not as part of the Magnuson-Stevens Fishery Conservation and Management Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
