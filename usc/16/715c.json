{"tag":"section","attrib":{"id":"id78817ed9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s715c"},"text":null,"children":[{"tag":"num","attrib":{"value":"715c"},"text":"§ 715c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Areas recommended for approval; character","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Interior may not recommend any area for purchase or rental under the terms of this subchapter unless the Secretary of the Interior—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78817eda-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s715c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has determined that such area is necessary for the conservation of migratory birds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78817edb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s715c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has consulted with the county or other unit of local government in which such area is located and with the Governor of the State concerned or the appropriate State agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78817edc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1929-02-18/ch257/s4"},"text":"Feb. 18, 1929, ch. 257, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1223"},"text":"45 Stat. 1223","children":[],"tail":"; 1939 Reorg. Plan No. II, § 4(f), eff. "},{"tag":"date","attrib":{"date":"1939-07-01"},"text":"July 1, 1939","children":[],"tail":", 4 F.R. 2731, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1433"},"text":"53 Stat. 1433","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/669/s7/a"},"text":"Pub. L. 89–669, § 7(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/929"},"text":"80 Stat. 929","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/552/s2"},"text":"Pub. L. 95–552, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-30"},"text":"Oct. 30, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2071"},"text":"92 Stat. 2071","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78817edd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78817ede-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78817edf-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/552"},"text":"Pub. L. 95–552","children":[],"tail":" substituted “may not recommend any area” for “shall recommend no area”, incorporated existing provision in item (1) and added item (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/669"},"text":"Pub. L. 89–669","children":[],"tail":" struck out “game” from “migratory game birds”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id78817ee0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id78817ee1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of functions of Secretary of Agriculture to Secretary of the Interior by Reorg. Plan No. II of 1939, see Transfer of Functions note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s715a"},"text":"section 715a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
