{"tag":"section","attrib":{"id":"id7a310413-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8032"},"text":null,"children":[{"tag":"num","attrib":{"value":"8032"},"text":"§ 8032.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategic plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a310414-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8032/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategic plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", the Working Group, after consultation with the relevant stakeholders, shall submit to the Committee on Commerce, Science, and Transportation of the Senate, the Committee on Foreign Relations of the Senate, the Committee on Appropriations of the Senate, the Committee on Transportation and Infrastructure of the House of Representatives, the Committee on Natural Resources of the House of Representatives, the Committee on Foreign Affairs of the House of Representatives, and the Committee on Appropriations of the House of Representatives a 5-year integrated strategic plan on combating IUU fishing and enhancing maritime security, including specific strategies with monitoring benchmarks for addressing IUU fishing in priority regions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a310415-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8032/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of priority regions and priority flag states","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a310416-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8032/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The strategic plan submitted under subsection (a) shall identify priority regions and priority flag states to be the focus of assistance coordinated by the Working Group under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s8031"},"text":"section 8031 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a310417-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8032/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority region selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting priority regions under paragraph (1), the Working Group shall select regions that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a310418-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8032/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are at high risk for IUU fishing activity or the entry of illegally caught seafood into their markets; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a310419-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8032/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lack the capacity to fully address the issues described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a31041a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8032/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority flag states selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting priority flag states under paragraph (1), the Working Group shall select countries—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a31041b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8032/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the flagged vessels of which actively engage in, knowingly profit from, or are complicit in IUU fishing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a31041c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8032/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that lack the capacity to police their fleet.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a31041d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dC/tXXXV/s3552"},"text":"Pub. L. 116–92, div. C, title XXXV, § 3552","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2006"},"text":"133 Stat. 2006","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
