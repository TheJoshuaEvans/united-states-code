{"tag":"section","attrib":{"id":"id79e26e73-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871e"},"text":null,"children":[{"tag":"num","attrib":{"value":"3871e"},"text":"§ 3871e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79e26e74-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the criteria used in evaluating applications as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3871b/e/2"},"text":"section 3871b(e)(2) of this title","children":[],"tail":", the Secretary shall make publicly available information on projects selected through the competitive process described in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3871b/e/1"},"text":"section 3871b(e)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e26e75-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2019-12-31"},"text":"December 31, 2019","children":[],"tail":", and every two years thereafter, the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report on the status of projects funded under the program, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e26e76-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a summary of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e26e77-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871e/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress made towards achieving the conservation benefits defined for the projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e78-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871e/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other related outcomes of the projects;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26e79-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and types of eligible partners and producers participating in the partnership agreements selected;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26e7a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of producers receiving assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26e7b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871e/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" total funding committed to projects, including from Federal and non-Federal resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26e7c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871e/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of how the funds under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3871c/d"},"text":"section 3871c(d) of this title","children":[],"tail":" are being administered, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e26e7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871e/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any oversight mechanisms that the Secretary has implemented;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871e/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the process through which the Secretary is resolving appeals by program participants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871e/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the means by which the Secretary is tracking adherence to any applicable provisions for payment eligibility; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26e80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871e/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a project within a critical conservation area under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3871f"},"text":"section 3871f of this title","children":[],"tail":", the status of each priority resource concern for each designated critical conservation area, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e26e81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871e/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the priority resource concerns for which each critical conservation area is designated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871e/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conservation goals and outcomes sufficient to demonstrate that progress is being made to address the priority resource concerns;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871e/b/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the partnership agreements selected to address each conservation goal and outcome; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26e84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871e/b/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which each conservation goal and outcome is being addressed by the partnership agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e26e85-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with certain requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not provide assistance under the program to a producer unless the producer agrees, during the program year for which the assistance is provided—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e26e86-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to comply with applicable conservation requirements under subchapter II; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26e87-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to comply with applicable wetland protection requirements under subchapter III.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e26e88-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Historically underserved producers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, in carrying out the program, the Secretary and eligible partners shall conduct outreach to beginning farmers and ranchers, veteran farmers and ranchers, socially disadvantaged farmers and ranchers, and limited resource farmers and ranchers to encourage participation by those producers in a project subject to a partnership agreement or funding agreement under 3871c(d) ","children":[{"tag":"ref","attrib":{"idref":"fn002777"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002777"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “section”."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e26e89-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue regulations to carry out the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79e26e8a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1271E"},"text":"Pub. L. 99–198, title XII, § 1271E","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII/s2401"},"text":"Pub. L. 113–79, title II, § 2401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/749"},"text":"128 Stat. 749","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII/s2706"},"text":"Pub. L. 115–334, title II, § 2706","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4599"},"text":"132 Stat. 4599","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79e26e8b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79e26e8c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79e26e8d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2706/1"},"text":"Pub. L. 115–334, § 2706(1)","children":[],"tail":", which directed amendment of subsec. (a) by substituting “3871b(e)” for “3871b(d)” wherever appearing, was executed by substituting “3871(e)(2)” for “3871b(d)(2)” and “3871(e)(1)” for “3871b(d)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2706/2/A"},"text":"Pub. L. 115–334, § 2706(2)(A)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2019-12-31"},"text":"December 31, 2019","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2014-12-31"},"text":"December 31, 2014","children":[],"tail":"” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1) to (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2706/2/B"},"text":"Pub. L. 115–334, § 2706(2)(B)","children":[],"tail":", (C), added par. (1) and redesignated former pars. (1) and (2) as (2) and (3), respectively. Former par. (3) redesignated (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2706/2/B"},"text":"Pub. L. 115–334, § 2706(2)(B)","children":[],"tail":", (D), redesignated par. (3) as (4) and struck out “and” at end. Former par. (4) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2706/2/B"},"text":"Pub. L. 115–334, § 2706(2)(B)","children":[],"tail":", (E), redesignated par. (4) as (5) and substituted “3871c(d)” for “3871c(b)(2)” in introductory provisions and “; and” for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2706/2/F"},"text":"Pub. L. 115–334, § 2706(2)(F)","children":[],"tail":", added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2706/3"},"text":"Pub. L. 115–334, § 2706(3)","children":[],"tail":", added subsecs. (c) to (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
