{"tag":"section","attrib":{"id":"id79f09f24-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4608"},"text":null,"children":[{"tag":"num","attrib":{"value":"4608"},"text":"§ 4608.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79f09f25-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4608/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of the Interior","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary such sums as may be necessary to carry out the purposes of this chapter, not to exceed the amount expended for such purposes for fiscal year 1990.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f09f26-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4608/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to other Federal departments and agencies such sums as may be necessary to carry out the provisions of any other Take Pride in America programs established by such departments or agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f09f27-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/628/tXI/s1109"},"text":"Pub. L. 101–628, title XI, § 1109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4503"},"text":"104 Stat. 4503","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
