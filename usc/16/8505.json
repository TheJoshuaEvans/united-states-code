{"tag":"section","attrib":{"id":"id7a3d113d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8505"},"text":null,"children":[{"tag":"num","attrib":{"value":"8505"},"text":"§ 8505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Career and volunteer opportunities for veterans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a3d113e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veteran hiring","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries are strongly encouraged to hire veterans in all positions related to the management of Federal recreational lands and waters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3d113f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3d1140-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8505/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Assistant Secretary of Labor for Veterans’ Employment and Training and the Secretary of Veterans Affairs, shall establish a pilot program under which veterans are employed by the Federal Government in positions that relate to the conservation and resource management activities of the Department of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3d1141-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8505/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Positions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3d1142-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8505/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify vacant positions in the Department of the Interior that are appropriate to fill using the pilot program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3d1143-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8505/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, fill such positions using the pilot program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3d1144-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8505/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of civil service laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A veteran employed under the pilot program shall be treated as an employee as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3d1145-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8505/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Briefings and report","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3d1146-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8505/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial briefing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretary and the Assistant Secretary of Labor for Veterans’ Employment and Training shall jointly provide to the appropriate congressional committees a briefing on the pilot program under this subsection, which shall include—"}],"tail":null},{"tag":"clause","attrib":{"id":"id7a3d1147-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8505/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the pilot program will be carried out in a manner to reduce the unemployment of veterans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3d1148-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8505/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations for legislative actions to improve the pilot program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3d1149-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8505/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation briefing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the date on which the pilot program under subsection (a) ","children":[{"tag":"ref","attrib":{"idref":"fn002880"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002880"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should refer to “this subsection”."}],"tail":" commences, the Secretary and the Assistant Secretary of Labor for Veterans’ Employment and Training shall jointly provide to the appropriate congressional committees a briefing on the implementation of the pilot program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3d114a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8505/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after the date on which the pilot program under subsection (a) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" terminates under paragraph (5), the Secretary and the Assistant Secretary of Labor for Veterans’ Employment and Training shall jointly submit to the appropriate congressional committees a report on the pilot program that includes the following:"}],"tail":null},{"tag":"clause","attrib":{"id":"id7a3d114b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8505/b/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of veterans who applied to participate in the pilot program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3d114c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8505/b/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of such veterans employed under the pilot program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3d114d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8505/b/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of veterans identified in clause (ii) who transitioned to full-time positions with the Federal Government after participating in the pilot program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3d114e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8505/b/4/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other information the Secretary and the Assistant Secretary of Labor for Veterans’ Employment and Training determine appropriate with respect to measuring the effectiveness of the pilot program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3d114f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8505/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority to carry out the pilot program under this subsection shall terminate on the date that is 2 years after the date on which the pilot program commences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3d1150-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8505/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3d1151-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8505/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Veterans’ Affairs and the Committee on Natural Resources of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3d1152-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8505/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Veterans’ Affairs and the Committee on Energy and Natural Resources of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3d1153-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8505/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outdoor recreation program attendance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Secretary of a military department is encouraged to allow members of the Armed Forces on active duty status to participate in programs related to environmental stewardship or guided outdoor recreation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3d1154-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tII/s226"},"text":"Pub. L. 118–234, title II, § 226","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2889"},"text":"138 Stat. 2889","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
