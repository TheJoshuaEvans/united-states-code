{"tag":"section","attrib":{"id":"id7a1df0e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6853"},"text":null,"children":[{"tag":"num","attrib":{"value":"6853"},"text":"§ 6853.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Digitization and publication of easements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1df0e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6853/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 4 years after ","children":[{"tag":"date","attrib":{"date":"2022-04-29"},"text":"April 29, 2022","children":[],"tail":", each of the Secretaries, to the maximum extent practicable, shall digitize and publish on the applicable agency website geographic information system mapping data that specifies, with respect to the relevant Secretary, all Federal interests in private land, including easements (other than flowage easements), reservations, and rights-of-way—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1df0e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6853/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to which the Federal Government does not have a fee title interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1df0ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6853/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that may be used to provide public recreational access to the Federal land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1df0eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6853/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries shall develop a process to allow members of the public to submit questions or comments regarding the information described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1df0ec-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/114/s4"},"text":"Pub. L. 117–114, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-04-29"},"text":"Apr. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1176"},"text":"136 Stat. 1176","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
