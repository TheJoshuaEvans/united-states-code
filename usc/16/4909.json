{"tag":"section","attrib":{"id":"id79f7cbbb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4909"},"text":null,"children":[{"tag":"num","attrib":{"value":"4909"},"text":"§ 4909.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79f7cbbc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4909/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person may at any time submit to the Secretary a petition in writing requesting that the Secretary exercise authority of the Secretary under this chapter to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f7cbbd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4909/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish, modify, or terminate any prohibition, suspension, or quota under this chapter on importation of any species of exotic bird;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cbbe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4909/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" add a species of exotic bird to, or remove such a species from, a list under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4905"},"text":"section 4905 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cbbf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4909/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4906"},"text":"section 4906 of this title","children":[],"tail":" whether an exotic bird breeding facility is a qualifying facility."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f7cbc0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4909/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration and ruling","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each petition submitted to the Secretary in accordance with subsection (a), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f7cbc1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4909/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within 90 days after receiving the petition, issue and publish in the Federal Register a preliminary ruling regarding whether the petition presents sufficient information indicating that the action requested in the petition might be warranted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cbc2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4909/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each petition determined to present such sufficient information—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f7cbc3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4909/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an opportunity for the submission of public comment on the petition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f7cbc4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4909/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue and publish in the Federal Register a final ruling on the petition, by not later than 90 days after the end of the period for public comment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f7cbc5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/440/tI/s110"},"text":"Pub. L. 102–440, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2229"},"text":"106 Stat. 2229","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
