{"tag":"section","attrib":{"id":"id787598a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s690h"},"text":null,"children":[{"tag":"num","attrib":{"value":"690h"},"text":"§ 690h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Person” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As used in sections 690 to 690i of this title the term “person” includes an individual, partnership, association, or corporation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id787598a1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1928-04-23/ch413/s10"},"text":"Apr. 23, 1928, ch. 413, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/450"},"text":"45 Stat. 450","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id787598a2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id787598a3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id787598a4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 690i, included within the reference to sections 690 to 690i, was omitted from the Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
