{"tag":"section","attrib":{"id":"id78dc2217-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973e"},"text":null,"children":[{"tag":"num","attrib":{"value":"973e"},"text":"§ 973e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal offenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78dc2218-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited acts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person is guilty of a criminal offense if he or she commits any act prohibited by paragraph (6), (8), (9), or (10) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s973c/a"},"text":"section 973c(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78dc2219-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sentence and fine","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any offense described in subsection (a) of this section is punishable by a fine of not more than $50,000, or imprisonment for not more than 6 months, or both; except that if in the commission of any such offense the person uses a dangerous weapon, engages in conduct that causes bodily injury to any Authorized Officer, Authorized Party Officer, or observer under the Treaty in the conduct of their duties, or places any such Authorized Officer, Authorized Party Officer, or observer in fear of imminent bodily injury, the offense is punishable by a fine of not more than $100,000 or imprisonment for not more than 10 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78dc221a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The district courts of the United States shall have jurisdiction over any offense described in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78dc221b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/330/s7"},"text":"Pub. L. 100–330, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-07"},"text":"June 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/594"},"text":"102 Stat. 594","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXIV/s8415"},"text":"Pub. L. 119–60, div. H, title LXXXIV, § 8415","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1915"},"text":"139 Stat. 1915","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78dc221c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78dc221d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78dc221e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “paragraph (6), (8), (9), or (10) of section 973c(a)” for “section 973c(a)(8), (10), (11), or (12)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
