{"tag":"section","attrib":{"id":"id77d364e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460aa–11"},"text":null,"children":[{"tag":"num","attrib":{"value":"460aa–11"},"text":"§ 460aa–11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Patents; restriction on issuance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Patents shall not hereafter be issued for locations and claims heretofore made in the recreation area under the mining laws of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77d364e7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/400/s12"},"text":"Pub. L. 92–400, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-08-22"},"text":"Aug. 22, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/615"},"text":"86 Stat. 615","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
