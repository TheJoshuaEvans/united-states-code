{"tag":"section","attrib":{"id":"id7a29ff27-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7611"},"text":null,"children":[{"tag":"num","attrib":{"value":"7611"},"text":"§ 7611.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a29ff28-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7611/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support a collaborative, interagency approach to address wildlife trafficking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29ff29-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7611/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect and conserve the remaining populations of wild elephants, rhinoceroses, and other species threatened by poaching and the illegal wildlife trade;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29ff2a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7611/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to disrupt regional and global transnational organized criminal networks and to prevent the illegal wildlife trade from being used as a source of financing for criminal groups that undermine United States and global security interests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29ff2b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7611/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent wildlife poaching and trafficking from being a means to make a living in focus countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29ff2c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7611/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the efforts of, and collaborate with, individuals, communities, local organizations, and foreign governments to combat poaching and wildlife trafficking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29ff2d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7611/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist focus countries in implementation of national wildlife anti-trafficking and poaching laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29ff2e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7611/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that United States assistance to prevent and suppress illicit wildlife trafficking is carefully planned and coordinated, and that it is systematically and rationally prioritized on the basis of detailed analysis of the nature and severity of threats to wildlife and the willingness and ability of foreign partners to cooperate effectively toward these ends.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a29ff2f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/231/tI/s101"},"text":"Pub. L. 114–231, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-10-07"},"text":"Oct. 7, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/951"},"text":"130 Stat. 951","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a29ff30-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a29ff31-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a29ff32-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/231"},"text":"Pub. L. 114–231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-10-07"},"text":"Oct. 7, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/949"},"text":"130 Stat. 949","children":[],"tail":", known as the Eliminate, Neutralize, and Disrupt Wildlife Trafficking Act of 2016, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s7601"},"text":"section 7601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
