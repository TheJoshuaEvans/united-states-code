rences in Text note below."}],"tail":" (as in effect on "},{"tag":"date","attrib":{"date":"2006-09-29"},"text":"September 29, 2006","children":[],"tail":") for the eligible counties in the covered State that have elected under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s7112/b"},"text":"section 7112(b) of this title","children":[],"tail":" to receive a share of the State payment for fiscal year 2008; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a251c22-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7113/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sum of the amounts paid for fiscal year 2006 under section 103(a)(2) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" (as in effect on "},{"tag":"date","attrib":{"date":"2006-09-29"},"text":"September 29, 2006","children":[],"tail":") for the eligible counties in the State of Oregon that have elected under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s7112/b"},"text":"section 7112(b) of this title","children":[],"tail":" to receive the county payment for fiscal year 2008;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a251c23-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7113/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for fiscal year 2009, 81 percent of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a251c24-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7113/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sum of the amounts paid for fiscal year 2006 under section 102(a)(2) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" (as in effect on "},{"tag":"date","attrib":{"date":"2006-09-29"},"text":"September 29, 2006","children":[],"tail":") for the eligible counties in the covered State that have elected under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s7112/b"},"text":"section 7112(b) of this title","children":[],"tail":" to receive a share of the State payment for fiscal year 2009; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a251c25-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7113/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sum of the amounts paid for fiscal year 2006 under section 103(a)(2) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" (as in effect on "},{"tag":"date","attrib":{"date":"2006-09-29"},"text":"September 29, 2006","children":[],"tail":") for the eligible counties in the State of Oregon that have elected under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s7112/b"},"text":"section 7112(b) of this title","children":[],"tail":" to receive the county payment for fiscal year 2009; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a251c26-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7113/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for fiscal year 2010, 73 percent of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a251c27-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7113/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sum of the amounts paid for fiscal year 2006 under section 102(a)(2) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" (as in effect on "},{"tag":"date","attrib":{"date":"2006-09-29"},"text":"September 29, 2006","children":[],"tail":") for the eligible counties in the covered State that have elected under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s7112/b"},"text":"section 7112(b) of this title","children":[],"tail":" to receive a share of the State payment for fiscal year 2010; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a251c28-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7113/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sum of the amounts paid for fiscal year 2006 under section 103(a)(2) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" (as in effect on "},{"tag":"date","attrib":{"date":"2006-09-29"},"text":"September 29, 2006","children":[],"tail":") for the eligible counties in the State of Oregon that have elected under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s7112/b"},"text":"section 7112(b) of this title","children":[],"tail":" to receive the county payment for fiscal year 2010."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a251c29-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7113/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered State” means each of the States of California, Louisiana, Oregon, Pennsylvania, South Carolina, South Dakota, Texas, and Washington.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a251c2a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each of fiscal years 2008 through 2010, in lieu of the payment amounts that otherwise would have been made under paragraphs (1)(B) and (2)(B) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7112/a"},"text":"section 7112(a) of this title","children":[],"tail":", the Secretary of the Treasury shall pay the adjusted amount to each covered State and the eligible counties within the covered State, as applicable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a251c2b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7113/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of adjusted amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (d), it is the intent of Congress that the method of distributing the payments under subsection (b) among the counties in the covered States for each of fiscal years 2008 through 2010 be in the same proportion that the payments were distributed to the eligible counties in fiscal year 2006.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a251c2c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7113/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of payments in California","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following payments shall be distributed among the eligible counties in the State of California in the same proportion that payments under section 102(a)(2) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" (as in effect on "},{"tag":"date","attrib":{"date":"2006-09-29"},"text":"September 29, 2006","children":[],"tail":") were distributed to the eligible counties for fiscal year 2006:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a251c2d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7113/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payments to the State of California under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a251c2e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7113/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The shares of the eligible counties of the State payment for California under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7112"},"text":"section 7112 of this title","children":[],"tail":" for each of fiscal years 2011 through 2015 and for each of fiscal years 2017 through 2026."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a251c2f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7113/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter, any payment made under subsection (b) shall be considered to be a payment made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7112/a"},"text":"section 7112(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a251c30-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/393/tI/s103"},"text":"Pub. L. 106–393, title I, § 103","children":[],"tail":", as added "},{"tag":"ref","attrib":{"hre