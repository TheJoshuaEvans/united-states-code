{"tag":"section","attrib":{"id":"id7708c177-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s157b"},"text":null,"children":[{"tag":"num","attrib":{"value":"157b"},"text":"§ 157b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional lands within park boundaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provisions of law, the Secretary of the Interior is authorized to procure, in such manner as he may consider to be in the public interest, the remaining non-Federal land and interests in land within the boundaries of Big Bend National Park.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7708c178-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1953-08-08/ch385"},"text":"Aug. 8, 1953, ch. 385","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/497"},"text":"67 Stat. 497","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
