{"tag":"section","attrib":{"id":"id7a0ade44-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6453"},"text":null,"children":[{"tag":"num","attrib":{"value":"6453"},"text":"§ 6453.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a0ade45-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6453/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The voting members of the Task Force shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0ade46-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6453/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Under Secretary of Commerce for Oceans and Atmosphere and the Secretary of Interior, who shall be co-chairpersons of the Task Force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0ade47-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6453/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such representatives from other Federal agencies as the President, in consultation with the Under Secretary, determines appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0ade48-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6453/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Governor, or a representative of the Governor, of each covered State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0ade49-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6453/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonvoting members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Task Force shall have the following nonvoting members:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0ade4a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6453/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the South Atlantic Fishery Management Council who is designated by the Governor of Florida under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1852/b/1"},"text":"section 1852(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0ade4b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6453/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Gulf of Mexico Fishery Management Council who is designated by the Governor of Florida under such section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0ade4c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6453/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member of the Western Pacific Fishery Management Council who is designated under such section and selected as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0ade4d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6453/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the period beginning on ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", and ending on December 31 of the calendar year during which such date occurs, the member shall be selected jointly by the Governors of Hawaii, American Samoa, Guam, and the Commonwealth of the Northern Mariana Islands."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0ade4e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6453/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each calendar year thereafter, the Governors of Hawaii, American Samoa, Guam, and the Commonwealth of the Northern Mariana Islands shall, on a rotating basis, take turns selecting the member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0ade4f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6453/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member of the Caribbean Fishery Management Council who is designated under such section and selected as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0ade50-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6453/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the period beginning on ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", and ending on December 31 of the calendar year during which such date occurs, the member shall be selected jointly by the Governors of Puerto Rico and the United States Virgin Islands."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0ade51-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6453/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each calendar year thereafter, the Governors of Puerto Rico and the United States Virgin Islands shall, on an alternating basis, take turns selecting the member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0ade52-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6453/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member appointed by the President of the Federated States of Micronesia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0ade53-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6453/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member appointed by the President of the Republic of the Marshall Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0ade54-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6453/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member appointed by the President of the Republic of Palau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0d4e55-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tC/s10013"},"text":"Pub. L. 117–263, div. J, title C, § 10013","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3952"},"text":"136 Stat. 3952","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
