{"tag":"section","attrib":{"id":"id79f7cbc6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4910"},"text":null,"children":[{"tag":"num","attrib":{"value":"4910"},"text":"§ 4910.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited acts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79f7cbc7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4910/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f7cbc8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4910/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), it is unlawful for any person to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f7cbc9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4910/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" import any exotic bird in violation of any prohibition, suspension, or quota on importation under section 4904 or 4907 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f7cbca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4910/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" import an exotic bird of a species that pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4905/a/2/B"},"text":"section 4905(a)(2)(B) of this title","children":[],"tail":" is included in a list under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4905"},"text":"section 4905 of this title","children":[],"tail":", if the bird was not captive bred at a qualifying facility; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f7cbcb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4910/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" violate any regulation promulgated by the Secretary pursuant to authority provided by this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cbcc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4910/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1)(A) and (B) does not apply to importations made incident to the transit of exotic birds through the United States to foreign countries if the applicable requirements of the Convention have been satisfied with respect to the trade in those exotic birds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f7cbcd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4910/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Burden of proof for exemptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person claiming the benefit of any exemption or permit under this chapter shall have the burden of proving that the exemption or permit is applicable or has been granted, and was valid and in force at the time of the alleged violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f7cbce-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/440/tI/s111"},"text":"Pub. L. 102–440, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2230"},"text":"106 Stat. 2230","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
