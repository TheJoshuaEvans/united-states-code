{"tag":"section","attrib":{"id":"id77719552-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"410hhh–2"},"text":"§ 410hhh–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Great Sand Dunes National Park, Colorado","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77719553-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When the Secretary determines that sufficient land having a sufficient diversity of resources has been acquired to warrant designation of the land as a national park, the Secretary shall establish the Great Sand Dunes National Park in the State of Colorado, as generally depicted on the map, as a unit of the National Park System. Such establishment shall be effective upon publication of a notice of the Secretary’s determination in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77719554-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map shall be on file and available for public inspection in the appropriate offices of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77719555-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Until the date on which the national park is established, the Secretary shall annually notify the Committee on Energy and Natural Resources of the Senate and the Committee on Resources of the House of Representatives of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77719556-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimate of the Secretary of the lands necessary to achieve a sufficient diversity of resources to warrant designation of the national park; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77719557-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress of the Secretary in acquiring the necessary lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77719558-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abolishment of National Monument","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77719559-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–2/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On the date of establishment of the national park pursuant to subsection (a), the Great Sand Dunes National Monument shall be abolished, and any funds made available for the purposes of the national monument shall be available for the purposes of the national park.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7771955a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–2/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any reference in any law (other than this subchapter), regulation, document, record, map, or other paper of the United States to “Great Sand Dunes National Monument” shall be considered a reference to “Great Sand Dunes National Park”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7771955b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of jurisdiction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Administrative jurisdiction is transferred to the National Park Service over any land under the jurisdiction of the Department of the Interior that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7771955c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–2/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is depicted on the map as being within the boundaries of the national park or the preserve; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7771955d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh–2/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not under the administrative jurisdiction of the National Park Service on ","children":[{"tag":"date","attrib":{"date":"2000-11-22"},"text":"November 22, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7771955e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/530/s4"},"text":"Pub. L. 106–530, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2529"},"text":"114 Stat. 2529","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7771955f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77719560-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id77719561-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Resources of House of Representatives changed to Committee on Natural Resources of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77719562-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Designation of Park","children":[],"tail":null},{"tag":"p","attrib":{},"text":"On ","children":[{"tag":"date","attrib":{"date":"2004-09-13"},"text":"Sept. 13, 2004","children":[],"tail":", the Secretary of the Interior made the determination under subsec. (a) of this section and designated the existing Great Sand Dunes National Monument as the Great Sand Dunes National Park. See 69 F.R. 57355."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
