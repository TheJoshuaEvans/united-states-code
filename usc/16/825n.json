{"tag":"section","attrib":{"id":"id78b38ba3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s825n"},"text":null,"children":[{"tag":"num","attrib":{"value":"825n"},"text":"§ 825n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeiture for violations; recovery; applicability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78b38ba4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s825n/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeiture","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any licensee or public utility which willfully fails, within the time prescribed by the Commission, to comply with any order of the Commission, to file any report required under this chapter or any rule or regulation of the Commission thereunder, to submit any information or document required by the Commission in the course of an investigation conducted under this chapter, or to appear by an officer or agent at any hearing or investigation in response to a subpena issued under this chapter, shall forfeit to the United States an amount not exceeding $1,000 to be fixed by the Commission after notice and opportunity for hearing. The imposition or payment of any such forfeiture shall not bar or affect any penalty prescribed in this chapter but such forfeiture shall be in addition to any such penalty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b38ba5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s825n/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The forfeitures provided for in this chapter shall be payable into the Treasury of the United States and shall be recoverable in a civil suit in the name of the United States, brought in the district where the person is an inhabitant or has his principal place of business, or if a licensee or public utility, in any district in which such licensee or public utility transacts business. It shall be the duty of the various United States attorneys, under the direction of the Attorney General of the United States, to prosecute for the recovery of forfeitures under this chapter. The costs and expenses of such prosecution shall be paid from the appropriations for the expenses of the courts of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b38ba6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s825n/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply in the case of any provision of section 824j, 824k, 824","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":", or 824m of this title or any rule or order issued under any such provision."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78b38ba7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-10/ch285"},"text":"June 10, 1920, ch. 285","children":[],"tail":", pt. III, § 315, as added "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-26/ch687"},"text":"Aug. 26, 1935, ch. 687","children":[],"tail":", title II, § 213, "},{"tag":"ref","attrib":{"href":"/us/stat/49/861"},"text":"49 Stat. 861","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646/s1"},"text":"June 25, 1948, ch. 646, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"