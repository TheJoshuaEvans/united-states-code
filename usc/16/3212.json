{"tag":"section","attrib":{"id":"id79b2ab74-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3212"},"text":null,"children":[{"tag":"num","attrib":{"value":"3212"},"text":"§ 3212.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terror Lake Hydroelectric Project in Kodiak National Wildlife Refuge","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this Act or the National Wildlife Refuge System Administration Act of 1966 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s668dd"},"text":"16 U.S.C. 668dd","children":[],"tail":") shall be construed as necessarily prohibiting or mandating the construction of the Terror Lake Hydroelectric Project within the Kodiak National Wildlife Refuge. The permissibility of such development shall be determined by the Secretary on a case-by-case basis under existing law."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79b2ab75-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/487/tXIII/s1325"},"text":"Pub. L. 96–487, title XIII, § 1325","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-02"},"text":"Dec. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2488"},"text":"94 Stat. 2488","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79b2ab76-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79b2ab77-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79b2ab78-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":nul