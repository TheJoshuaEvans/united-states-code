{"tag":"section","attrib":{"id":"id770d7c2a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s162a"},"text":null,"children":[{"tag":"num","attrib":{"value":"162a"},"text":"§ 162a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summer homes and cottages","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"After ","children":[{"tag":"date","attrib":{"date":"1931-01-26"},"text":"January 26, 1931","children":[],"tail":", no permit, license, lease, or other authorization for the use of land within the Glacier National Park, Montana, for the erection and maintenance of summer homes or cottages shall be granted or made: "},{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That the Secretary of the Interior may, in his discretion, renew any permit, license, lease, or other authorization for such purpose granted or made prior to "},{"tag":"date","attrib":{"date":"1931-01-26"},"text":"January 26, 1931","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id770d7c2b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1931-01-26/ch47/s3"},"text":"Jan. 26, 1931, ch. 47, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/1043"},"text":"46 Stat. 1043","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
