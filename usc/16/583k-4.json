{"tag":"section","attrib":{"id":"id7851bca1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"583k–4"},"text":"§ 583k–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7851bca2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into a cooperative agreement with any State, tribal, local governmental, and private entity to carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7851bca3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Cooperative agreements authorized under this section may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7851bca4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–4/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve trail maintenance in a priority area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bca5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–4/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement the strategy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bca6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–4/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advance trail maintenance in a manner deemed appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7851bca7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/245/s6"},"text":"Pub. L. 114–245, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-11-28"},"text":"Nov. 28, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/994"},"text":"130 Stat. 994","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
