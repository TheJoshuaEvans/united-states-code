{"tag":"section","attrib":{"id":"id787cc427-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u"},"text":null,"children":[{"tag":"num","attrib":{"value":"698u"},"text":"§ 698u.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tallgrass Prairie National Preserve: findings and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id787cc428-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id787cc429-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the 400,000 square miles of tallgrass prairie that once covered the North American Continent, less than 1 percent remains, primarily in the Flint Hills of Kansas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787cc42a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in 1991, the National Park Service conducted a special resource study of the Spring Hill Ranch, located in the Flint Hills of Kansas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787cc42b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the study concludes that the Spring Hill Ranch—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id787cc42c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a nationally significant example of the once vast tallgrass ecosystem, and includes buildings listed on the National Register of Historic Places pursuant to section 101 of the National Historic Preservation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s470a"},"text":"16 U.S.C. 470a","children":[],"tail":") "},{"tag":"ref","attrib":{"idref":"fn002488"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002488"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" that represent outstanding examples of Second Empire and other 19th Century architectural styles; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id787cc42d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is suitable and feasible as a potential addition to the National Park System; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787cc42e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the National Park Trust, which owns the Spring Hill Ranch, has agreed to permit the National Park Service—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id787cc42f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire a portion of the ranch, as specified in sections 698u to 698u–7 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id787cc430-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to manage the ranch in order to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id787cc431-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conserve the scenery, natural and historic objects, and wildlife of the ranch; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id787cc432-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the enjoyment of the ranch in such a manner and by such means as will leave the scenery, natural and historic objects, and wildlife unimpaired for the enjoyment of future generations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id787cc433-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of sections 698u to 698u–7 of this title are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id787cc434-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to preserve, protect, and interpret for the public an example of a tallgrass prairie ecosystem on the Spring Hill Ranch, located in the Flint Hills of Kansas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787cc435-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698u/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to preserve and interpret for the public the historic and cultural values represented on the Spring Hill Ranch.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id787cc436-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/333/dI/tX/s1002"},"text":"Pub. L. 104–333, div. I, title X, § 1002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-11-12"},"text":"Nov. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4204"},"text":"110 Stat. 4204","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/176/tI/s122/1"},"text":"Pub. L. 106–176, title I, § 122(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-03-10"},"text":"Mar. 10, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/29"},"text":"114 Stat. 29","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id787cc437-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id787cc438-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id787cc439-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 101 of the National Historic Preservation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s470a"},"text":"16 U.S.C. 470a","children":[],"tail":"), referred to in subsec. (a)(3)(A), is "},{"tag":"ref","attrib":{"href":"/us/pl/89/665/s101"},"text":"section 101 of Pub. L. 89–665","children":[],"tail":", which was repealed and restated as chapters 3021 to 3027 and sections 302902(a), 302903(a), 302904 to 302909, 303902, 303903, and 306101(b) and (c) of Title 54, National Park Service and Related Programs, by "},{"tag":"ref","attrib":{"href":"/us/pl/113/287"},"text":"Pub. L. 113–287","children":[],"tail":", §§ 3, 7, "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3094"},"text":"128 Stat. 3094","children":[],"tail":", 3272."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id787cc43a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/176"},"text":"Pub. L. 106–176","children":[],"tail":" substituted “to acquire” for “to purchase”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id787cc43b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id787cc43c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/333/dI/tX/s1001"},"text":"Pub. L. 104–333, div. I, title X, § 1001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-11-12"},"text":"Nov. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4204"},"text":"110 Stat. 4204","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/333/dI/tX/s1001"},"text":"“This subtitle [subtitle A (§§ 1001–1009) of title X of div. I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/333"},"text":"Pub. L. 104–333","children":[],"tail":", enacting this section and sections 698u–1 to 698u–7 of this title] may be cited as the ‘Tallgrass Prairie National Preserve Act of 1996’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
