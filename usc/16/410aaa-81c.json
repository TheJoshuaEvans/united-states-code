{"tag":"section","attrib":{"id":"id776a696d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c"},"text":null,"children":[{"tag":"num","attrib":{"value":"410aaa–81c"},"text":"§ 410aaa–81c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited uses of acquired, donated, and conservation land","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id776a696e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776a696f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquired land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “acquired land” means any land acquired within the Conservation Area using amounts from the land and water conservation fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s200302"},"text":"section 200302 of title 54","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776a6970-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Conservation Area” means the California Desert Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776a6971-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation land","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “conservation land” means any land within the Conservation Area that is designated to satisfy the conditions of a Federal habitat conservation plan, general conservation plan, or State natural communities conservation plan, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id776a6972-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national conservation land established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7202/b/2/D"},"text":"section 7202(b)(2)(D) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776a6973-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" areas of critical environmental concern established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1712/c/3"},"text":"section 1712(c)(3) of title 43","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776a6974-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donated land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “donated land” means any private land donated to the United States for conservation purposes in the Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776a6975-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “donor” means an individual or entity that donates private land within the Conservation Area to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776a6976-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary, acting through the Director of the Bureau of Land Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776a6977-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means the State of California.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776a6978-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (c), the Secretary shall not authorize the use of acquired land, conservation land, or donated land within the Conservation Area for any activities contrary to the conservation purposes for which the land was acquired, designated, or donated, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776a6979-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disposal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776a697a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rights-of-way;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776a697b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776a697c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" livestock grazing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776a697d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" infrastructure development, except as provided in subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776a697e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mineral entry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776a697f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" off-highway vehicle use, except on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id776a6980-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designated routes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776a6981-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" off-highway vehicle areas designated by law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776a6982-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/b/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administratively designated open areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776a6983-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id776a6984-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization by Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), the Secretary may authorize limited exceptions to prohibited uses of acquired land or donated land in the Conservation Area if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id776a6985-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a right-of-way application for a renewable energy development project or associated energy transport facility on acquired land or donated land was submitted to the Bureau of Land Management on or before ","children":[{"tag":"date","attrib":{"date":"2009-12-01"},"text":"December 1, 2009","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776a6986-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the completion and consideration of an analysis under the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.), the Secretary has determined that proposed use is in the public interest."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776a6987-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id776a6988-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary grants an exception to the prohibition under paragraph (1), the Secretary shall require the permittee to donate private land of comparable value located within the Conservation Area to the United States to mitigate the use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776a6989-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The private land to be donated under subparagraph (A) shall be approved by the Secretary after—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id776a698a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consultation, to the maximum extent practicable, with the donor of the private land proposed for nonconservation uses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id776a698b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an opportunity for public comment regarding the donation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776a698c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section affects permitted or prohibited uses of donated land or acquired land in the Conservation Area established in any easements, deed restrictions, memoranda of understanding, or other agreements in existence on ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776a698d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deed restrictions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Effective beginning on ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", within the Conservation Area, the Secretary may—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id776a698e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept deed restrictions requested by landowners for land donated to, or otherwise acquired by, the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id776a698f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consistent with existing rights, create deed restrictions, easements, or other third-party rights relating to any public land determined by the Secretary to be necessary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id776a6990-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fulfill the mitigation requirements resulting from the development of renewable resources; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id776a6991-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to satisfy the conditions of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id776a6992-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a habitat conservation plan or general conservation plan established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1539"},"text":"section 1539 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id776a6993-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–81c/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a natural communities conservation plan approved by the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id776a6994-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/tVII/s714"},"text":"Pub. L. 103–433, title VII, § 714","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tI/s1453"},"text":"Pub. L. 116–9, title I, § 1453","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/712"},"text":"133 Stat. 712","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id776a6995-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id776a6996-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id776a6997-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (c)(1)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id776a6998-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id776a6999-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/s103"},"text":"Section 103 of Pub. L. 103–433","children":[],"tail":" provided in part that in this subchapter “Secretary” means the Secretary of the Interior."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
