{"tag":"section","attrib":{"id":"id7a0add47-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6408"},"text":null,"children":[{"tag":"num","attrib":{"value":"6408"},"text":"§ 6408.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a0add48-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6408/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, from funds appropriated pursuant to the authorization of appropriations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6414"},"text":"section 6414 of this title","children":[],"tail":", the Administrator may provide emergency assistance to any covered State or coral reef stewardship partnership to respond to immediate harm to coral reefs or coral reef ecosystems arising from any of the exigent circumstances described in subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0add49-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6408/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coral reef exigent circumstances","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall develop a list of, and criteria for, circumstances that pose an exigent threat to coral reefs, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0add4a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6408/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new and ongoing outbreaks of disease;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0add4b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6408/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new and ongoing outbreaks of invasive or nuisance species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0add4c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6408/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new and ongoing coral bleaching events;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0add4d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6408/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" natural disasters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0add4e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6408/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" industrial or mechanical incidents, such as vessel groundings, hazardous spills, or coastal construction accidents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0add4f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6408/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other circumstances as the Administrator determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0add50-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6408/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on exigent circumstances","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On February 1 of each year, the Administrator shall submit to the appropriate congressional committees, the Committee on Appropriations of the Senate, and the Committee on Appropriations of the House of Representatives a report that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0add51-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6408/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes locations with exigent circumstances described in subsection (b) that were considered but declined for emergency assistance, and the rationale for the decision; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0add52-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6408/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to each instance in which emergency assistance under this section was provided—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0add53-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6408/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location and a description of the exigent circumstances that prompted the emergency assistance, the entity that received the assistance, and the current and expected outcomes from the assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0add54-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6408/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of activities of the National Oceanic and Atmospheric Administration that were curtailed as a result of providing the emergency assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0add55-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6408/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of whether further action is needed to restore the affected coral reef, recommendations for such restoration, and a cost estimate to implement such recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0add56-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/562/tII/s209"},"text":"Pub. L. 106–562, title II, § 209","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tC/s10001/a"},"text":"Pub. L. 117–263, div. J, title C, § 10001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3940"},"text":"136 Stat. 3940","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a0add57-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a0add58-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a0add59-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6408, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/562/tII/s209"},"text":"Pub. L. 106–562, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-23"},"text":"Dec. 23, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2805"},"text":"114 Stat. 2805","children":[],"tail":", authorized appropriations, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tC/s10001/a"},"text":"Pub. L. 117–263, div. J, title C, § 10001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3931"},"text":"136 Stat. 3931","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
