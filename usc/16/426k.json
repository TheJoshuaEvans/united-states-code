{"tag":"section","attrib":{"id":"id778e4470-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s426k"},"text":null,"children":[{"tag":"num","attrib":{"value":"426k"},"text":"§ 426k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of additional lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In furtherance of the purposes of sections 426 to 426j of this title, authorizing establishment of the Stones River National Battlefield, the Secretary of the Interior is authorized to acquire by such means as he may deem to be in the public interest, for inclusion in the Stones River National Battlefield, such additional lands and interests in lands, not to exceed seven acres, as in the discretion of the Secretary are necessary for the preservation and interpretation of the battlefield of Stones River, Tennessee.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id778e4471-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/443"},"text":"Pub. L. 86–443","children":[],"tail":", §§ 1, 2, "},{"tag":"date","attrib":{"date":"1960-04-22"},"text":"Apr. 22, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/82"},"text":"74 Stat. 82","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id778e4472-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id778e4473-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id778e4474-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Stones River National Battlefield” substituted in text for “Stones River National Park” in view of redesignation of Stones River National Military Park as Stones River National Battlefield by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/443"},"text":"Pub. L. 86–443","children":[],"tail":". See section 426"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
