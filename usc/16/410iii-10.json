{"tag":"section","attrib":{"id":"id7774065b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"410iii–10"},"text":"§ 410iii–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7774065c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–10/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to further the purposes of this subchapter, the Secretary is authorized to enter into cooperative agreements with interested public and private entities and individuals (including the National Trust for Historic Preservation, Belle Grove, Inc., the Cedar Creek Battlefield Foundation, the Shenandoah Valley Battlefields Foundation, and the Counties of Frederick, Shenandoah, and Warren), through technical and financial assistance, including encouraging the conservation of historic and natural resources of the Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7774065d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–10/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical and financial assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide to any person, organization, or governmental entity technical and financial assistance for the purposes of this subchapter, including the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7774065e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–10/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Preserving historic structures within the Park.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7774065f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–10/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Maintaining the natural or cultural landscape of the Park.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77740660-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–10/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Local preservation planning, interpretation, and management of public visitation for the Park.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77740661-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–10/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Furthering the goals of the Shenandoah Valley Battlefields Foundation related to the Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77740662-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/373/s12"},"text":"Pub. L. 107–373, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3109"},"text":"116 Stat. 3109","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
