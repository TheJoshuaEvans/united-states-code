{"tag":"section","attrib":{"id":"id78d9b0de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s962"},"text":null,"children":[{"tag":"num","attrib":{"value":"962"},"text":"§ 962.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of bycatch in eastern tropical Pacific Ocean","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of State, in consultation with the Secretary of Commerce and acting through the United States Commissioners, shall seek, in cooperation with other nations whose vessels fish for tuna in the eastern tropical Pacific Ocean, to establish standards and measures for a bycatch reduction program for vessels fishing for yellowfin tuna in the eastern tropical Pacific Ocean. The bycatch reduction program shall include measures—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78d9b0df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s962/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require, to the maximum extent practicable, that sea turtles and other threatened species and endangered species are released alive;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d9b0e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s962/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce, to the maximum extent practicable, the harvest of nontarget species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d9b0e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s962/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce, to the maximum extent practicable, the mortality of nontarget species; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d9b0e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s962/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce, to the maximum extent practicable, the mortality of juveniles of the target species.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78d9b0e3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-07/ch907/s15"},"text":"Sept. 7, 1950, ch. 907, § 15","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/42/s7/c"},"text":"Pub. L. 105–42, § 7(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-15"},"text":"Aug. 15, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1138"},"text":"111 Stat. 1138","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/81/tII/s209"},"text":"Pub. L. 114–81, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-05"},"text":"Nov. 5, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/664"},"text":"129 Stat. 664","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78d9b0e4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78d9b0e5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78d9b0e6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/42/s7/c"},"text":"Section 7(c) of Pub. L. 105–42","children":[],"tail":", which directed the addition of this section at the end of the Tuna Conventions Act, was executed by adding this section at the end of the Tuna Conventions Act of 1950, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78d9b0e7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/81"},"text":"Pub. L. 114–81","children":[],"tail":" substituted “vessels” for “vessel” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78d9b0e8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id78d9b0e9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon certification by Secretary of Commerce that sufficient funding is available to complete first year of study required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1414a/a"},"text":"section 1414a(a) of this title","children":[],"tail":" and that study has commenced, and certification by Secretary of State to Congress that binding resolution of Inter-American Tropical Tuna Commission or other legally binding instrument establishing International Dolphin Conservation Program has been adopted and is in force, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/42/s8"},"text":"section 8 of Pub. L. 105–42","children":[],"tail":", set out as an Effective Date of 1997 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1362"},"text":"section 1362 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
