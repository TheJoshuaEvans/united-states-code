{"tag":"section","attrib":{"id":"id792ab6ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1405"},"text":null,"children":[{"tag":"num","attrib":{"value":"1405"},"text":"§ 1405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commission shall have access to all studies and data compiled by Federal agencies regarding marine mammals. With the consent of the appropriate Secretary or Agency head, the Commission may also utilize the facilities or services of any Federal agency and shall take every feasible step to avoid duplication of research and to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id792ab6ac-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522/tII/s205"},"text":"Pub. L. 92–522, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-21"},"text":"Oct. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1045"},"text":"86 Stat. 1045","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id792ab6ad-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id792ab6ae-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id792ab6af-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the expiration of the sixty-day period following ","children":[{"tag":"date","attrib":{"date":"1972-10-21"},"text":"Oct. 21, 1972","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/92/522/s4"},"text":"section 4 of Pub. L. 92–522","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1361"},"text":"section 1361 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
