{"tag":"section","attrib":{"id":"id7875982b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s682"},"text":null,"children":[{"tag":"num","attrib":{"value":"682"},"text":"§ 682.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Game refuge in Ozark National Forest","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President of the United States is authorized to designate such national forest lands within the Ozark National Forest, within the State of Arkansas, as should, in his discretion, be set aside for the protection of game animals, birds, or fish; and, except under such rules and regulations as the Secretary of Agriculture may from time to time prescribe, it shall be unlawful for any person to hunt, catch, trap, willfully disturb, or kill any kind of game animal, game or nongame bird, or fish, or take the eggs of any such bird on any lands so set aside, or in or on the waters thereof.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7875982c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1925-02-28/ch376"},"text":"Feb. 28, 1925, ch. 376","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/1091"},"text":"43 Stat. 1091","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1945-08-11/ch365"},"text":"Aug. 11, 1945, ch. 365","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/531"},"text":"59 Stat. 531","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645/s12"},"text":"June 25, 1948, ch. 645, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/861"},"text":"62 Stat. 861","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7875982d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7875982e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7875982f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1948—Act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", struck out penal provisions (see "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s41"},"text":"section 41 of Title 18","children":[],"tail":", Crimes and Criminal Procedure), and inserted provision relating to the unlawfulness in hunting, catching, etc., game animals, etc., under rules and regulations of the Secretary of Agriculture."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1945—Act ","children":[{"tag":"date","attrib":{"date":"1945-08-11"},"text":"Aug. 11, 1945","children":[],"tail":", struck out last sentence which read “No lands within the present limits of the fourth congressional district shall be included in such designations.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78759830-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id78759831-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1948 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 20 of act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", provided that the amendment made by that act is effective "},{"tag":"date","attrib":{"date":"1948-09-01"},"text":"Sept. 1, 1948","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id78759832-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78759833-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Presidential Designation","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Lands comprising the Ozark National Game Refuge were designated by Proclamations of ","children":[{"tag":"date","attrib":{"date":"1928-06-13"},"text":"June 13, 1928","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/45/2953"},"text":"45 Stat. 2953","children":[],"tail":"), and "},{"tag":"date","attrib":{"date":"1935-10-25"},"text":"Oct. 25, 1935","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/49/3478"},"text":"49 Stat. 3478","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
