{"tag":"section","attrib":{"id":"id7807e263-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ttt–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"460ttt–2"},"text":"§ 460ttt–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of national recreation area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7807e264-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ttt–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to valid rights existing on ","children":[{"tag":"date","attrib":{"date":"2006-12-01"},"text":"December 1, 2006","children":[],"tail":", the Secretary shall administer the Moosalamoo National Recreation Area in accordance with—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7807e265-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ttt–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" laws (including rules and regulations) applicable to units of the National Forest System; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e266-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ttt–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the management direction (including objectives, standards, and guidelines) established for the Moosalamoo Recreation and Education Management Area under the Management Plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7807e267-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ttt–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fish and wildlife","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter affects the jurisdiction of the State with respect to wildlife and fish on the public land located in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7807e268-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ttt–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Escarpment and ecological areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter prevents the Secretary from managing the Green Mountain Escarpment Management Area and the Ecological Special Areas, as described in the Management Plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7807e269-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/382/tII/s223"},"text":"Pub. L. 109–382, title II, § 223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-01"},"text":"Dec. 1, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2677"},"text":"120 Stat. 2677","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
