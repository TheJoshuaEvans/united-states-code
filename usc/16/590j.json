{"tag":"section","attrib":{"id":"id78569da8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s590j"},"text":null,"children":[{"tag":"num","attrib":{"value":"590j"},"text":"§ 590j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78569da9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s590j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural commodity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “agricultural commodity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78569daa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s590j/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agricultural commodity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78569dab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s590j/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any regional or market classification, type, or grade of an agricultural commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78569dac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s590j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78569dad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s590j/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “technical assistance” means technical expertise, information, and tools necessary for the conservation of natural resources on land active in agricultural, forestry, or related uses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78569dae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s590j/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “technical assistance” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78569daf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s590j/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical services provided directly to farmers, ranchers, and other eligible entities, such as conservation planning, technical consultation, and assistance with design and implementation of conservation practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78569db0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s590j/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical infrastructure, including activities, processes, tools, and agency functions needed to support delivery of technical services, such as technical standards, resource inventories, training, data, technology, monitoring, and effects analyses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78569db1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(",