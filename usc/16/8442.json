{"tag":"section","attrib":{"id":"id7a383002-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442"},"text":null,"children":[{"tag":"num","attrib":{"value":"8442"},"text":"§ 8442.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improved recreation visitation data","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a383003-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistent visitation data","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a383004-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual visitation data","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretaries shall establish a single visitation data reporting system to report accurate annual visitation data, in a consistent manner, for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a383005-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each unit of Federal recreational lands and waters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a383006-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land held in trust for an Indian Tribe, on request of the Indian Tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a383007-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Categories of use","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within the visitation data reporting system established under paragraph (1), the Secretaries shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a383008-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish multiple categories of different recreation activities that are reported consistently across agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a383009-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an estimate of the number of visitors for each applicable category established under subparagraph (A) for each unit of Federal recreational lands and waters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a38300a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Real-Time Data Pilot Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a38300b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 5 years after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", using existing funds available to the Secretaries, the Secretaries shall carry out a pilot program, to be known as the “Real-Time Data Pilot Program” (referred to in this section as the “Pilot Program”), to make available to the public, for each unit of Federal recreational lands and waters selected for participation in the Pilot Program under paragraph (2)—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a38300c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" real-time or predictive data on visitation (including data and resources publicly available from existing nongovernmental platforms) at—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a38300d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the unit of Federal recreational lands and waters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a38300e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, areas within the unit of Federal recreational lands and waters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a38300f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, recreation sites managed by any other Federal agency, a State agency, or a local agency that are located near the unit of Federal recreational lands and waters; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a383010-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through multiple media platforms, information about lesser-known recreation sites located near the unit of Federal recreational lands and waters (including recreation sites managed by any other Federal agency, a State agency, or a local agency), in an effort to encourage visitation among recreational sites.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a383011-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Locations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a383012-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial number of units","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On establishment of the Pilot Program, the Secretaries shall select for participation in the Pilot Program—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a383013-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 units of Federal recreational lands and waters managed by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a383014-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 units of Federal recreational lands and waters managed by the Secretary of Agriculture (acting through the Chief of the Forest Service);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a383015-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 unit of Federal recreational lands and waters managed by the Secretary of Commerce (acting through the Administrator of the National Oceanic and Atmospheric Administration); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a383016-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 unit of Federal recreational lands and waters managed by the Assistant Secretary of Army for Civil Works.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a383017-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 6 years after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretaries shall submit a report to Congress regarding the implementation of the pilot program, including policy recommendations to expand the pilot program to additional units managed by the Secretaries."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a383018-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feedback; support of gateway communities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretaries shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a383019-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solicit feedback regarding participation in the Pilot Program from communities adjacent to units of Federal recreational lands and waters and the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a38301a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in carrying out subparagraphs (A) and (B), select a unit of Federal recreation lands and waters to participate in the Pilot Program only if the community adjacent to the unit of Federal recreational lands and waters is supportive of the participation of the unit of Federal recreational lands and waters in the Pilot Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a38301b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries may disseminate the information described in paragraph (1) directly or through an entity or organization referred to in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a38301c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of current assessments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the Pilot Program, the Secretaries may, to the extent practicable, rely on assessments completed or data gathered prior to ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a38301d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community partners and third-party providers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of carrying out this section, the Secretary concerned may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a38301e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" coordinate and partner with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a38301f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communities adjacent to units of Federal recreational lands and waters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a383020-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local outdoor recreation and tourism offices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a383021-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a383022-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian Tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a383023-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trade associations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a383024-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local outdoor recreation marketing organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a383025-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permitted facilitated recreation providers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a383026-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/c/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant stakeholders; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a383027-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" coordinate or enter into agreements, as appropriate, with private sector and nonprofit partners, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a383028-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technology companies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a383029-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geospatial data companies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a38302a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experts in data science, analytics, and operations research; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a38302b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data companies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a38302c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries may use existing programs or products of the Secretaries to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a38302d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy clauses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section provides authority to the Secretaries—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a38302e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to monitor or record the movements of a visitor to a unit of Federal recreational lands and waters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a38302f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to restrict, interfere with, or monitor a private communication of a visitor to a unit of Federal recreational lands and waters; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a383030-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to collect—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a383031-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information from owners of land adjacent to a unit of Federal recreational lands and waters; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a383032-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on non-Federal land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a383033-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", and annually thereafter, the Secretaries shall publish on a website of the Secretaries a report that describes the annual visitation of each unit of Federal recreational lands and waters, including, to the maximum extent practicable, visitation categorized by recreational activity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a383034-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a383035-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal recreational lands and waters","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal recreational lands and waters”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a383036-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6801"},"text":"section 6801 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a383037-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes Federal lands and waters managed by the National Oceanic and Atmospheric Administration and the U.S. Army Corps of Engineers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a383038-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretaries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Secretaries” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a383039-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary, with respect to lands under the jurisdiction of the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a38303a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture, acting through the Chief of the Forest Service, with respect to lands under the jurisdiction of the Forest Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a38303b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Commerce, acting through the Administrator of the National Oceanic and Atmospheric Administration, with respect to Federal waters under the jurisdiction of the National Oceanic and Atmospheric Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a38303c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8442/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary of Army for Civil Works, with respect to lakes and reservoirs under the jurisdiction of the U.S. Army Corps of Engineers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a38303d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tI/s132"},"text":"Pub. L. 118–234, title I, § 132","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2859"},"text":"138 Stat. 2859","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
