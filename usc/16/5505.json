{"tag":"section","attrib":{"id":"id79fef6ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5505"},"text":null,"children":[{"tag":"num","attrib":{"value":"5505"},"text":"§ 5505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful activities","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is unlawful for any person subject to the jurisdiction of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79fef6ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5505/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use a high seas fishing vessel on the high seas in contravention of international conservation and management measures described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s5504/e"},"text":"section 5504(e) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef6ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5505/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use a high seas fishing vessel on the high seas, unless the vessel has on board a valid permit issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s5503"},"text":"section 5503 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef6ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5505/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use a high seas fishing vessel in violation of the conditions or restrictions of a permit issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s5503"},"text":"section 5503 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef6f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5505/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to falsify any information required to be reported, communicated, or recorded pursuant to this chapter or any regulation issued under this chapter, or to fail to submit in a timely fashion any required information, or to fail to report to the Secretary immediately any change in circumstances that has the effect of rendering any such information false, incomplete, or misleading;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef6f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5505/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to refuse to permit an authorized officer to board a high seas fishing vessel subject to such person’s control for purposes of conducting any search or inspection in connection with the enforcement of this chapter or any regulation issued under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef6f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5505/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to forcibly assault, resist, oppose, impede, intimidate, or interfere with an authorized officer in the conduct of any search or inspection described in paragraph (5);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef6f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5505/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to resist a lawful arrest or detention for any act prohibited by this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef6f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5505/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to interfere with, delay, or prevent, by any means, the apprehension, arrest, or detection of another person, knowing that such person has committed any act prohibited by this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef6f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5505/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ship, transport, offer for sale, sell, purchase, import, export, or have custody, control, or possession of, any living marine resource taken or retained in violation of this chapter or any regulation or permit issued under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fef6f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5505/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to violate any provision of this chapter or any regulation or permit issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79fef6f7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/tI/s106"},"text":"Pub. L. 104–43, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/371"},"text":"109 Stat. 371","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79fef6f8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79fef6f9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79fef6fa-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 120 days after ","children":[{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/43/s111"},"text":"section 111 of Pub. L. 104–43","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s5501"},"text":"section 5501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
