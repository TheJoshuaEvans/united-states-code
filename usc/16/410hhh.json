{"tag":"section","attrib":{"id":"id77719529-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh"},"text":null,"children":[{"tag":"num","attrib":{"value":"410hhh"},"text":"§ 410hhh.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7771952a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Great Sand Dunes National Monument in the State of Colorado was established by Presidential proclamation in 1932 to preserve Federal land containing spectacular and unique sand dunes and additional features of scenic, scientific, and educational interest for the benefit and enjoyment of future generations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7771952b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Great Sand Dunes, together with the associated sand sheet and adjacent wetland and upland, contain a variety of rare ecological, geological, paleontological, archaeological, scenic, historical, and wildlife components, which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7771952c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include the unique pulse flow characteristics of Sand Creek and Medano Creek that are integral to the existence of the dunes system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7771952d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interact to sustain the unique Great Sand Dunes system beyond the boundaries of the existing National Monument;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7771952e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are enhanced by the serenity and rural western setting of the area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7771952f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comprise a setting of irreplaceable national significance;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77719530-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Great Sand Dunes and adjacent land within the Great Sand Dunes National Monument—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77719531-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide extensive opportunities for educational activities, ecological research, and recreational activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77719532-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are publicly used for hiking, camping, and fishing, and for wilderness value (including solitude);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77719533-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" other public and private land adjacent to the Great Sand Dunes National Monument—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77719534-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offers additional unique geological, hydrological, paleontological, scenic, scientific, educational, wildlife, and recreational resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77719535-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contributes to the protection of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77719536-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sand sheet associated with the dune mass;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77719537-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the surface and ground water systems that are necessary to the preservation of the dunes and the adjacent wetland; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77719538-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the wildlife, viewshed, and scenic qualities of the Great Sand Dunes National Monument;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77719539-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" some of the private land described in paragraph (4) contains important portions of the sand dune mass, the associated sand sheet, and unique alpine environments, which would be threatened by future development pressures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7771953a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the designation of a Great Sand Dunes National Park, which would encompass the existing Great Sand Dunes National Monument and additional land, would provide—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7771953b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" greater long-term protection of the geological, hydrological, paleontological, scenic, scientific, educational, wildlife, and recreational resources of the area (including the sand sheet associated with the dune mass and the ground water system on which the sand dune and wetland systems depend); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7771953c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expanded visitor use opportunities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7771953d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" land in and adjacent to the Great Sand Dunes National Monument is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7771953e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognized for the culturally diverse nature of the historical settlement of the area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7771953f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognized for offering natural, ecological, wildlife, cultural, scenic, paleontological, wilderness, and recreational resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77719540-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognized as being a fragile and irreplaceable ecological system that could be destroyed if not carefully protected; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77719541-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410hhh/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preservation of this diversity of resources would ensure the perpetuation of the entire ecosystem for the enjoyment of future generations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77719542-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/530/s2"},"text":"Pub. L. 106–530, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2527"},"text":"114 Stat. 2527","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77719543-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77719544-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id77719545-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/530/s1"},"text":"Pub. L. 106–530, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2527"},"text":"114 Stat. 2527","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/530/s1"},"text":"“This Act [enacting this subchapter and provisions listed in a table of National Wildlife Refuges set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s668dd"},"text":"section 668dd of this title","children":[],"tail":"] may be cited as the ‘Great Sand Dunes National Park and Preserve Act of 2000’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
