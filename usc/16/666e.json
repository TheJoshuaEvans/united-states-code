{"tag":"section","attrib":{"id":"id78628597-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s666e"},"text":null,"children":[{"tag":"num","attrib":{"value":"666e"},"text":"§ 666e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of acquired lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any lands acquired by the Secretary of the Interior under the terms of this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s666d"},"text":"section 666d of this title","children":[],"tail":", if located within or adjacent to an existing wildlife refuge or reservation, immediately shall become a part of such refuge or reservation and shall be administered under the laws and regulations applicable thereto, and, if not so located, may be administered as a migratory-waterfowl management area, refuge, reservation, or breeding ground in accordance with the provisions of the Act of "},{"tag":"date","attrib":{"date":"1946-08-14"},"text":"August 14, 1946","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/60/1080"},"text":"60 Stat. 1080","children":[],"tail":"), and Acts supplementary thereto."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78628598-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-06/ch619/s2"},"text":"Oct. 6, 1949, ch. 619, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/708"},"text":"63 Stat. 708","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78628599-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7862859a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tai