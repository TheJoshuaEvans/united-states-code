{"tag":"section","attrib":{"id":"id787f0d45-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s702"},"text":null,"children":[{"tag":"num","attrib":{"value":"702"},"text":"§ 702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importation of eggs of game birds for propagation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall have the power to authorize the importation of eggs of game birds for purposes of propagation, and he shall prescribe all necessary rules and regulations governing the importation of eggs of said birds for such purposes.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id787f0d46-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1902-06-03/ch983"},"text":"June 3, 1902, ch. 983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/285"},"text":"32 Stat. 285","children":[],"tail":"; 1939 Reorg. Plan No. II, § 4(f), eff. "},{"tag":"date","attrib":{"date":"1939-07-01"},"text":"July 1, 1939","children":[],"tail":", 4 F.R. 2731, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1433"},"text":"53 Stat. 1433","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id787f0d47-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id787f0d48-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id787f0d49-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Transfer of functions of Secretary of Agriculture to Secretary o