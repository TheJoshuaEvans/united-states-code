{"tag":"section","attrib":{"id":"id79fa3b7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5009"},"text":null,"children":[{"tag":"num","attrib":{"value":"5009"},"text":"§ 5009.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful activities","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is unlawful for any person or fishing vessel subject to the jurisdiction of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79fa3b7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5009/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fish for any anadromous fish in the Convention area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fa3b7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5009/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to retain on board any anadromous fish taken incidentally in a fishery directed at nonanadromous fish in the Convention area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fa3b80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5009/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fail to return immediately to the sea any anadromous fish taken incidentally in a fishery directed at nonanadromous fish in the Convention area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fa3b81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5009/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ship, transport, offer for sale, sell, purchase, import, export, or have custody, control, or possession of, any anadromous fish taken or retained in violation of the Convention, this chapter, or any regulation issued under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fa3b82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5009/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to refuse to permit any enforcement officer to board a fishing vessel subject to such person’s control for purposes of conducting any search, investigation, or inspection in connection with the enforcement of the Convention, this chapter, or any regulation issued under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fa3b83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5009/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to forcibly assault, resist, oppose, impede, intimidate, or interfere with any enforcement officer in the conduct of any search, investigation, or inspection described in paragraph (5);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fa3b84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5009/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to resist a lawful arrest or detection for any act prohibited by this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fa3b85-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5009/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to interfere with, delay, or prevent, by any means, the apprehension, arrest, or detection of another person, knowing that such person has committed any act prohibited by this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fa3b86-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5009/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to violate any provision of the Convention, this chapter, or any regulation issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79fa3b87-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/567/tVIII/s810"},"text":"Pub. L. 102–567, title VIII, § 810","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4313"},"text":"106 Stat. 4313","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/tVIII/s8010"},"text":"Pub. L. 102–587, title VIII, § 8010","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5103"},"text":"106 Stat. 5103","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/562/tIII/s304/a"},"text":"Pub. L. 106–562, title III, § 304(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-23"},"text":"Dec. 23, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2806"},"text":"114 Stat. 2806","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/81/tI/s103/a"},"text":"Pub. L. 114–81, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-05"},"text":"Nov. 5, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/657"},"text":"129 Stat. 657","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79fa3b88-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79fa3b89-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79fa3b8a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Title VIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/567"},"text":"Pub. L. 102–567","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/102/587"},"text":"Pub. L. 102–587","children":[],"tail":" enacted substantially identical sections. Title VIII of "},{"tag":"ref","attrib":{"href":"/us/pl/102/587"},"text":"Pub. L. 102–587","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/106/562"},"text":"Pub. L. 106–562","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79fa3b8b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Pars. (5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/81"},"text":"Pub. L. 114–81","children":[],"tail":" inserted “, investigation,” after “search”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
