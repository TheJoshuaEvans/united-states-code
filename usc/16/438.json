{"tag":"section","attrib":{"id":"id779a2c46-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s438"},"text":null,"children":[{"tag":"num","attrib":{"value":"438"},"text":"§ 438.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repairs and improvements; how made","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any and all repairs, improvements, changes, and alterations in the grounds, buildings, and other appurtenances to the reservation shall be made only according to detailed plans which shall be approved by the Secretary of the Interior, and all such repairs, improvements, or alterations shall be made at the expense of the United States, and all such improvements, together with the reservation itself, shall become and remain permanently the property of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id779a2c47-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-05-26/ch100"},"text":"May 26, 1914, ch. 100","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/382"},"text":"38 Stat. 382","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1925-03-03/ch425"},"text":"Mar. 3, 1925, ch. 425","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/1109"},"text":"43 Stat. 1109","children":[],"tail":"; Ex. Ord. No. 6166, § 2, "},{"tag":"date","attrib":{"date":"1933-06-10"},"text":"June 10, 1933","children":[],"tail":"; Ex. Ord. No. 6228, § 1, "},{"tag":"date","attrib":{"date":"1933-07-28"},"text":"July 28, 1933","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id779a2c48-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id779a2c49-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children