{"tag":"section","attrib":{"id":"id77a61337-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450rr–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"450rr–1"},"text":"§ 450rr–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of sections 450rr to 450rr–6 of this title, the term—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77a61338-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450rr–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Administrator” means the Administrator of the National Oceanic and Atmospheric Administration (NOAA);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77a61339-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450rr–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “person” means any individual (whether or not a citizen or national of the United States), any corporation, partnership, association, or other entity (whether or not organized or existing under the laws of any State), and any Federal, State, local, or foreign government or any entity of any such government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77a6133a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450rr–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “R.M.S. Titanic” means the shipwrecked vessel R.M.S. Titanic, her cargo or other contents, including those items which are scattered on the ocean floor in her vicinity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77a6133b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450rr–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77a6133c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/513/s3"},"text":"Pub. L. 99–513, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2082"},"text":"100 Stat. 2082","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
