{"tag":"section","attrib":{"id":"id7a251cf5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7126"},"text":null,"children":[{"tag":"num","attrib":{"value":"7126"},"text":"§ 7126.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of project funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a251cf6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7126/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement regarding schedule and cost of project","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a251cf7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7126/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement between parties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may carry out a project submitted by a resource advisory committee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7123/a"},"text":"section 7123(a) of this title","children":[],"tail":" using project funds or other funds described in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s7123/a/2"},"text":"section 7123(a)(2) of this title","children":[],"tail":", if, as soon as practicable after the issuance of a decision document for the project and the exhaustion of all administrative appeals and judicial review of the project decision, the Secretary concerned and the resource advisory committee enter into an agreement addressing, at a minimum, the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a251cf8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7126/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The schedule for completing the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a251cf9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7126/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total cost of the project, including the level of agency overhead to be assessed against the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a251cfa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7126/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For a multiyear project, the estimated cost of the project for each of the fiscal years in which it will be carried out.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a251cfb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7126/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The remedies for failure of the Secretary concerned to comply with the terms of the agreement consistent with current Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a251cfc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7126/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited use of Federal funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary concerned may decide, at the sole discretion of the Secretary concerned, to cover the costs of a portion of an approved project using Federal funds appropriated or otherwise available to the Secretary for the same purposes as the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a251cfd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7126/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of project funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a251cfe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7126/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial transfer required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As soon as practicable after the agreement is reached under subsection (a) with regard to a project to be funded in whole or in part using project funds, or other funds described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7123/a/2"},"text":"section 7123(a)(2) of this title","children":[],"tail":", the Secretary concerned shall transfer to the applicable unit of National Forest System land or Bureau of Land Management District an amount of project funds equal to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a251cff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7126/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a project to be completed in a single fiscal year, the total amount specified in the agreement to be paid using project funds, or other funds described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7123/a/2"},"text":"section 7123(a)(2) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a251d00-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7126/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a multiyear project, the amount specified in the agreement to be paid using project funds, or other funds described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7123/a/2"},"text":"section 7123(a)(2) of this title","children":[],"tail":" for the first fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a251d01-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7126/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condition on project commencement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The unit of National Forest System land or Bureau of Land Management District concerned shall not commence a project until the project funds, or other funds described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7123/a/2"},"text":"section 7123(a)(2) of this title","children":[],"tail":" required to be transferred under paragraph (1) for the project, have been made available by the Secretary concerned."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a251d02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7126/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent transfers for multiyear projects","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a251d03-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7126/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the second and subsequent fiscal years of a multiyear project to be funded in whole or in part using project funds, the unit of National Forest System land or Bureau of Land Management District concerned shall use the amount of project funds required to continue the project in that fiscal year according to the agreement entered into under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a251d04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7126/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of work","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary concerned shall suspend work on the project if the project funds required by the agreement in the second and subsequent fiscal years are not available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a251d05-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/393/tII/s206"},"text":"Pub. L. 106–393, title II, § 206","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/343/dC/tVI/s601/a"},"text":"Pub. L. 110–343, div. C, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3907"},"text":"122 Stat. 3907","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/58/s4/b"},"text":"Pub. L. 119–58, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/716"},"text":"139 Stat. 716","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a251d06-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a251d07-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a251d08-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/393/s206"},"text":"section 206 of Pub. L. 106–393","children":[],"tail":" was set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s500"},"text":"section 500 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/110/343/dC/tVI/s601/a"},"text":"Pub. L. 110–343, div. C, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3893"},"text":"122 Stat. 3893","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a251d09-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/58"},"text":"Pub. L. 119–58","children":[],"tail":" struck out comma after “District concerned”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
