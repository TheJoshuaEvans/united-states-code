{"tag":"section","attrib":{"id":"id7a0d4e56-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6454"},"text":null,"children":[{"tag":"num","attrib":{"value":"6454"},"text":"§ 6454.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of Federal agency members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a0d4e57-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6454/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member of the Task Force described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6453/a"},"text":"section 6453(a) of this title","children":[],"tail":" shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0d4e58-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6454/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the actions of the agency that member represents that may affect coral reef ecosystems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0d4e59-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6454/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the programs and authorities of that agency to protect and enhance the conditions of such ecosystems, including through the promotion of basic and applied scientific research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0d4e5a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6454/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate with the Task Force to appropriately reflect budgetary needs for coral reef conservation and restoration activities in all agency budget planning and justification documents and processes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0d4e5b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6454/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage in any other coordinated efforts approved by the Task Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0d4e5c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6454/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Co-chairpersons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to their responsibilities under subsection (a), the co-chairpersons of the Task Force shall perform the administrative functions of the Task Force and facilitate the coordination of the members of the Task Force described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6453/a"},"text":"section 6453(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0d4e5d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6454/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Briefing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 30 days before each meeting of the Task Force, the program offices of the National Oceanic and Atmospheric Administration responsible for implementing this title shall provide a briefing to the relevant congressional committees on efforts and spending associated with such implementation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0d4e5e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tC/s10014"},"text":"Pub. L. 117–263, div. J, title C, § 10014","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3953"},"text":"136 Stat. 3953","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a0d4e5f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a0d4e60-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a0d4e61-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in subsec. (c), means title C of division J of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":", which enacted this chapter and sections 6401 to 6415 of this title, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s7504"},"text":"section 7504 of this title","children":[],"tail":", repealed sections 6401 to 6409 of this title, and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6401"},"text":"section 6401 of this title","children":[],"tail":". For complete classification of title C to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
