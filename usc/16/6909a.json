{"tag":"section","attrib":{"id":"id7a206207-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6909a"},"text":null,"children":[{"tag":"num","attrib":{"value":"6909a"},"text":"§ 6909a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States conservation, management, and enforcement objectives","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Secretary of State, in the course of negotiations, shall seek—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a206208-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6909a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to minimize any disadvantage to United States fishermen in relation to other members of the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a206209-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6909a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maximize the opportunities for fishing vessels of the United States to harvest fish stocks on the high seas in the Convention area, recognizing that such harvests may be restricted if the Commission, based on the best available scientific information provided by the Scientific Committee, determines it is necessary to achieve the conservation objective set forth in Article 2 of the Convention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a20620a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6909a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent any requirement for the transfer to other nations or foreign entities of the fishing capacity, fishing capacity rights, or fishing vessels of the United States or its territories, unless any such requirement is voluntary and market-based; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a20620b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6909a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that conservation and management measures take into consideration traditional fishing patterns of fishing vessels of the United States and the operating requirements of the fisheries covered by the Western and Central Pacific Convention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a20620c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/479/tV/s511"},"text":"Pub. L. 109–479, title V, § 511","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/327/tIII/s301/a/2"},"text":"Pub. L. 114–327, title III, § 301(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1994"},"text":"130 Stat. 1994","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a20620d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a20620e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a20620f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/479/s511"},"text":"section 511 of Pub. L. 109–479","children":[],"tail":" was renumbered section 512 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6910"},"text":"section 6910 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
