{"tag":"section","attrib":{"id":"id787598c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s692a"},"text":null,"children":[{"tag":"num","attrib":{"value":"692a"},"text":"§ 692a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hunting, pursuing, capturing, etc., in Ocala National Forest unlawful","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When such game sanctuaries or refuges have been established as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s692"},"text":"section 692 of this title","children":[],"tail":", the hunting, pursuing, poisoning, killing, or capturing by trapping, netting, or any other means, or attempting to hunt, pursue, kill, or capture any game animals or birds upon the lands of the United States within the limits of such game sanctuaries or refuges shall be unlawful except under such rules and regulations as the Secretary of Agriculture may from time to time prescribe."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id787598c4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-28/ch709/s2"},"text":"June 28, 1930, ch. 709, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/828"},"text":"46 Stat. 828","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645/s15"},"text":"June 25, 1948, ch. 645, § 15","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/861"},"text":"62 Stat. 861","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id787598c5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id787598c6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id787598c7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1948—Act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", struck out penal provisions (see "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s41"},"text":"section 41 of Title 18","children":[],"tail":", Crimes and Criminal Procedure), and inserted reference to rules and regulations of the Secretary of Agriculture."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id787598c8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id787598c9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1948 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 20 of act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", provided that the amendment made by that act is effective "},{"tag":"date","attrib":{"date":"1948-09-01"},"text":"Sept. 1, 1948","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
