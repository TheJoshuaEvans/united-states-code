{"tag":"section","attrib":{"id":"id78a53340-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s822"},"text":null,"children":[{"tag":"num","attrib":{"value":"822"},"text":"§ 822.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of right to alter or repeal chapter","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The right to alter, amend, or repeal this chapter is expressly reserved; but no such alteration, amendment, or repeal shall affect any license theretofore issued under the provisions of this chapter or the rights of any licensee thereunder.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78a53341-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-10/ch285"},"text":"June 10, 1920, ch. 285","children":[],"tail":", pt. I, § 28, "},{"tag":"ref","attrib":{"href":"/us/stat/41/1077"},"text":"41 Stat. 1077","children":[],"tail":"; renumbered pt. I, "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-26/ch687"},"text":"Aug. 26, 1935, ch. 687","children":[],"tail":", title II, § 212, "},{"tag":"ref","attrib":{"href":"/us/stat/49/847"},"text":"49 Stat. 847","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
