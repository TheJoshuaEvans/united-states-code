{"tag":"section","attrib":{"id":"id7a16c467-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c"},"text":null,"children":[{"tag":"num","attrib":{"value":"6592c"},"text":"§ 6592c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a16c468-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a16c469-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized emergency action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “authorized emergency action” means an action carried out pursuant to an emergency situation determination issued under this section to mitigate the harm to life, property, or important natural or cultural resources on National Forest System land or adjacent land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c46a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency situation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “emergency situation” means a situation on National Forest System land for which immediate implementation of 1 or more authorized emergency actions is necessary to achieve 1 or more of the following results:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c46b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Relief from hazards threatening human health and safety.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c46c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mitigation of threats to natural resources on National Forest System land or adjacent land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c46d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency situation determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “emergency situation determination” means a determination made by the Secretary under subsection (b)(1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c46e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land and resource management plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “land and resource management plan” means a plan developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1604"},"text":"section 1604 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c46f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Forest System land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National Forest System land” means land of the National Forest System (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1609/a"},"text":"section 1609(a) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c470-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a16c471-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized emergency actions to respond to emergency situations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a16c472-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c473-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make a determination that an emergency situation exists with respect to National Forest System land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c474-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An emergency situation determination shall not be subject to objection under the predecisional administrative review processes under part 218 of title 36, Code of Federal Regulations (or successor regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c475-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis of determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An emergency situation determination shall be based on an examination of the relevant information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c476-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized emergency actions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After making an emergency situation determination with respect to National Forest System land, the Secretary may carry out authorized emergency actions on that National Forest System land in order to achieve reliefs from hazards threatening human health and safety or mitigation of threats to natural resources on National Forest System land or adjacent land, including through—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c477-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the salvage of dead or dying trees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c478-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the harvest of trees damaged by wind or ice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c479-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the commercial and noncommercial sanitation harvest of trees to control insects or disease, including trees already infested with insects or disease;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c47a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reforestation or replanting of fire-impacted areas through planting, control of competing vegetation, or other activities that enhance natural regeneration and restore forest species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c47b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the removal of hazardous trees in close proximity to roads and trails;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c47c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the removal of hazardous fuels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c47d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the restoration of water sources or infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c47e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reconstruction of existing utility lines; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c47f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the replacement of underground cables.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c480-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to land and resource management plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any authorized emergency action carried out under paragraph (2) on National Forest System land shall be conducted consistent with the applicable land and resource management plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a16c481-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental analysis","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a16c482-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental assessment or environmental impact statement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary determines that an authorized emergency action requires an environmental assessment or an environmental impact statement pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4332/2"},"text":"section 4332(2) of title 42","children":[],"tail":", the Secretary shall study, develop, and describe—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c483-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed agency action, taking into account the probable environmental consequences of the authorized emergency action and mitigating foreseeable adverse environmental effects, to the extent practicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c484-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the alternative of no action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c485-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide notice of each authorized emergency action that the Secretary determines requires an environmental assessment or environmental impact statement under paragraph (1), in accordance with applicable regulations and administrative guidelines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c486-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide an opportunity for public comment during the preparation of any environmental assessment or environmental impact statement under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a16c487-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings clause","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subsection prohibits the Secretary from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a16c488-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making an emergency situation determination, including a determination that an emergency exists pursuant to section 218.21(a) of title 36, Code of Federal Regulations (or successor regulations); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a16c489-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taking an emergency action under section 220.4(b) of title 36, Code of Federal Regulations (or successor regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a16c48a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative review of authorized emergency actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An authorized emergency action carried out under this section shall not be subject to objection under the predecisional administrative review processes established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6515"},"text":"section 6515 of this title","children":[],"tail":" and section 428 of the Department of the Interior, Environment, and Related Agencies Appropriations Act, 2012 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6515"},"text":"16 U.S.C. 6515","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/112/74"},"text":"Public Law 112–74","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a16c48b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review of emergency actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A court shall not enjoin an authorized emergency action under this section if the court determines that the plaintiff is unable to demonstrate that the claim of the plaintiff is likely to succeed on the merits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a16c48c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6592c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification and guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide notification and guidance to each local field office of the Forest Service to ensure awareness of, compliance with, and appropriate use of the authorized emergency action authority under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a16c48d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tVIII/s40807"},"text":"Pub. L. 117–58, div. D, title VIII, § 40807","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1112"},"text":"135 Stat. 1112","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a16c48e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a16c48f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a16c490-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Infrastructure Investment and Jobs Act, and not as part of the Healthy Forests Restoration Act of 2003 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a16c491-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a16c492-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
