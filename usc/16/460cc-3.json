{"tag":"section","attrib":{"id":"id77d81f77-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cc–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"460cc–3"},"text":"§ 460cc–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gateway National Recreation Area Advisory Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77d81f78-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cc–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; termination date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established a Gateway National Recreation Area Advisory Commission (hereinafter referred to as the “Commission”). Said Commission shall terminate twenty years after the date of the establishment of the recreation area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77d81f79-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cc–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership; appointment; terms of office; representation of interests","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall be composed of fifteen members each appointed for a term of two years by the Secretary as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77d81f7a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cc–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two members to be appointed from recommendations made by the Governor of the State of New York;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77d81f7b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cc–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two members to be appointed from recommendations made by the Governor of the State of New Jersey;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77d81f7c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cc–3/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two members to be appointed from recommendations made by the mayor of New York City;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77d81f7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cc–3/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two members to be appointed from recommendations made by the mayor of Newark, New Jersey; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77d81f7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cc–3/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seven members to be appointed by the Secretary to represent the general public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77d81f7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cc–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairman; vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall designate one member to be Chairman. Any vacancy in the Commission shall be filled in the same manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77d81f80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cc–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and expenses; vouchers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Commission shall serve without compensation as such. The Secretary is authorized to pay the expenses reasonably incurred by the Commission in carrying out its responsibility under this subchapter upon vouchers signed by the Chairman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77d81f81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cc–3/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission established by this section shall act and advise by affirmative vote of a majority of the members thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77d81f82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cc–3/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations of Secretary with members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or his designee shall, from time to time, consult with the members of the Commission with respect to matters relating to the development of the recreation area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77d81f83-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/592/s4"},"text":"Pub. L. 92–592, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1310"},"text":"86 Stat. 1310","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/344/s11/2"},"text":"Pub. L. 96–344, § 11(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1136"},"text":"94 Stat. 1136","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/232/s2"},"text":"Pub. L. 97–232, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-09"},"text":"Aug. 9, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/259"},"text":"96 Stat. 259","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77d81f84-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77d81f85-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77d81f86-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/232"},"text":"Pub. L. 97–232","children":[],"tail":" substituted “twenty” for “ten”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/344"},"text":"Pub. L. 96–344","children":[],"tail":" substituted in provision preceding par. (1) “fifteen” for “eleven” and in par. (5) “seven” for “three”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
