{"tag":"section","attrib":{"id":"id77c051a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460h"},"text":null,"children":[{"tag":"num","attrib":{"value":"460h"},"text":"§ 460h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs of surveys or relocation of boundaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The costs of any surveys or the relocation of boundary markers necessary as an incident of a conveyance or other property transfer under this subchapter shall be borne by the grantee.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77c051a3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-06/ch987/s4"},"text":"Aug. 6, 1956, ch. 987, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/1066"},"text":"70 Stat. 1066","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
