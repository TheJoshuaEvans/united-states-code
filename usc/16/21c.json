{"tag":"section","attrib":{"id":"id76f0cc6b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s21c"},"text":null,"children":[{"tag":"num","attrib":{"value":"21c"},"text":"§ 21c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section 485 as extending to revised boundaries; lands acquired by exchange","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s485"},"text":"section 485 of this title","children":[],"tail":" shall continue to be applicable to the areas included within the Yellowstone National Park by "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s21a"},"text":"section 21a of this title","children":[],"tail":", and any lands within such areas acquired by exchange thereunder shall thereupon become a part of the Yellowstone National Park."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id76f0cc6c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1929-03-01/ch437/s3"},"text":"Mar. 1, 1929, ch. 437, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1436"},"text":"45 Stat. 1436","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
