{"tag":"section","attrib":{"id":"id77529b84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ff"},"text":null,"children":[{"tag":"num","attrib":{"value":"410ff"},"text":"§ 410ff.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In order to protect the nationally significant natural, scenic, wildlife, marine, ecological, archaeological, cultural, and scientific values of the Channel Islands in the State of California, including, but not limited to, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77529b85-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ff/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the brown pelican nesting area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77529b86-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ff/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the undisturbed tide pools providing species diversity unique to the eastern Pacific coast;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77529b87-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ff/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the pinnipeds which breed and pup almost exclusively on the Channel islands, including the only breeding colony for northern fur seals south of Alaska;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77529b88-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ff/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Eolian landforms and caliche;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77529b89-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ff/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the presumed burial place of Juan Rod­riquez Cabrillo; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77529b8a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ff/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the archaeological evidence of substantial populations of Native Americans;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"there is hereby established the Channel Islands National Park, the boundaries of which shall include San Miguel and Prince Islands, Santa Rosa, Santa Cruz, Anacapa, and Santa Barbara Islands, including the rocks, islets, submerged lands, and waters within one nautical mile of each island, as depicted on the map entitled, “Proposed Channel Islands National Park” numbered 159–20,008 and dated April 1979, which shall be on file and available for public inspection in the offices of the Superintendent of the park and the Director of the National Park Service, Department of the Interior. The Channel Islands National Monument is hereby abolished as such, and the lands, waters, and interests therein withdrawn or reserved for the monument are hereby incorporated within and made a part of the new Channel Islands National Park.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77529b8b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/199/tII/s201"},"text":"Pub. L. 96–199, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-05"},"text":"Mar. 5, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/74"},"text":"94 Stat. 74","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77529b8c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77529b8d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77529b8e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Robert J. Lagomarsino Visitor Center","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/333/dI/tVIII/s809"},"text":"Pub. L. 104–333, div. I, title VIII, § 809","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-11-12"},"text":"Nov. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4189"},"text":"110 Stat. 4189","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/106/176/tI/s119"},"text":"Pub. L. 106–176, title I, § 119","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-03-10"},"text":"Mar. 10, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/28"},"text":"114 Stat. 28","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/176/tI/s119"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The visitor center at the Channel Islands National Park, California, is designated as the ‘Robert J. Lagomarsino Visitor Center’.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Legal References","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any reference in any law, regulation, document, record, map, or other document of the United States to the visitor center referred to in subsection (a) is deemed to be a reference to the ‘Robert J. Lagomarsino Visitor Center’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/d/tI/s125"},"text":"Pub. L. 104–208, div. A, title I, § 101(d) [title I, § 125]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-181"},"text":"110 Stat. 3009–181","children":[],"tail":", 3009–204."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
