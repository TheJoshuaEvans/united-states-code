{"tag":"section","attrib":{"id":"id78e34e5b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1053"},"text":null,"children":[{"tag":"num","attrib":{"value":"1053"},"text":"§ 1053.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation of responsibility for operation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall assign the responsibility for the operation of the National Fisheries Center and Aquarium and related activities to that branch of the United States Fish and Wildlife Service having as its major activity the rearing and holding of living fishes, including the operation of aquariums.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78e5974c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/758/s3"},"text":"Pub. L. 87–758, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-09"},"text":"Oct. 9, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/753"},"text":"76 Stat. 753","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/271/s1/3"},"text":"Pub. L. 93–271, § 1(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-04-22"},"text":"Apr. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/92"},"text":"88 Stat. 92","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78e5974d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78e5974e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id78e5974f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“United States Fish and Wildlife Service” substituted in text for “Bureau of Sport Fisheries and Wildlife” on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/271/s1/3"},"text":"Pub. L. 93–271, § 1(3)","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s742b/c"},"text":"section 742b(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
