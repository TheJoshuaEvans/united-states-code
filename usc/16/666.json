{"tag":"section","attrib":{"id":"id78628510-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s666"},"text":null,"children":[{"tag":"num","attrib":{"value":"666"},"text":"§ 666.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated from time to time, out of any money in the Treasury not otherwise appropriated, such amounts as may be necessary to carry out the provisions of this Act and regulations made pursuant thereto, including the construction of such facilities, buildings, and other improvements necessary for economical administration of areas made available to the Secretary of the Interior under this Act, and the employment in the city of Washington and elsewhere of such persons and means as the Secretary of the Interior may deem necessary for such purposes.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78628511-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-03-10/ch55/s6"},"text":"Mar. 10, 1934, ch. 55, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/402"},"text":"48 Stat. 402","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch965"},"text":"Aug. 14, 1946, ch. 965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/1081"},"text":"60 Stat. 1081","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78628512-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78628513-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78628514-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-03-10/ch55"},"text":"act Mar. 10, 1934, ch. 55","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/401"},"text":"48 Stat. 401","children":[],"tail":", known as the Fish and Wildlife Coordination Act, which is classified generally to sections 661 to 666c–1 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s661/a"},"text":"section 661(a) of this title","children":[],"tail":", Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s661"},"text":"section 661 of this title","children":[],"tail":", and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78628515-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1946—Act ","children":[{"tag":"date","attrib":{"date":"1946-08-14"},"text":"Aug. 14, 1946","children":[],"tail":", amended section generally to provide for the necessary appropriations to carry out the purposes of sections 661 to 666c of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
