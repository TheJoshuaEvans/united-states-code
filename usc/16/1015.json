{"tag":"section","attrib":{"id":"id78e34da2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015"},"text":null,"children":[{"tag":"num","attrib":{"value":"1015"},"text":"§ 1015.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78e34da3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affected stakeholder","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “affected stakeholder” means an entity that significantly affects, or is significantly affected by, the quality or quantity of water in a watershed, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78e34da4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disadvantaged community","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “disadvantaged community” means a community (including a city, town, county, or reasonably isolated and divisible segment of a larger municipality) with an annual median household income that is less than 100 percent of the statewide annual median household income for the State in which the community is located, according to the most recent decennial census.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78e34da5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant recipient","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “grant recipient” means a watershed group that the Secretary has selected to receive a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1015a/c/2"},"text":"section 1015a(c)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78e34da6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means the Cooperative Watershed Management Program established by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1015a/a"},"text":"section 1015a(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78e34da7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78e34da8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Watershed group","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “watershed group” means a self-sustaining, cooperative watershed-wide group that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78e34da9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is comprised of representatives of the affected stakeholders of the relevant watershed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e34daa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" incorporates the perspectives of a diverse array of stakeholders, including, to the maximum extent practicable—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78e34dab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" representatives of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id78e34dac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/6/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hydroelectric production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78e34dad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/6/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" livestock grazing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78e34dae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/6/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" timber production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78e34daf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/6/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78e34db0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/6/B/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recreation or tourism;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78e34db1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/6/B/i/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" irrigated agricultural production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78e34db2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/6/B/i/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78e34db3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/6/B/i/VIII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VIII"},"text":"(VIII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potable water purveyors and industrial water users;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78e34db4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/6/B/i/IX"},"text":null,"children":[{"tag":"num","attrib":{"value":"IX"},"text":"(IX)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private property owners within the watershed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78e34db5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/6/B/i/X"},"text":null,"children":[{"tag":"num","attrib":{"value":"X"},"text":"(X)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disadvantaged communities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78e34db6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Federal agency that has authority with respect to the watershed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78e34db7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/6/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State agency that has authority with respect to the watershed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78e34db8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/6/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any local agency that has authority with respect to the watershed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78e34db9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/6/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any Indian tribe that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id78e34dba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/6/B/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owns land within the watershed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78e34dbb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/6/B/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has land in the watershed that is held in trust;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e34dbc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a grassroots, nonregulatory entity that addresses water availability and quality issues within the relevant watershed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e34dbd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is capable of promoting the sustainable use of the water resources of the relevant watershed and improving the functioning condition of rivers and streams through—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78e34dbe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/6/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water conservation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78e34dbf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/6/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improved water quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78e34dc0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/6/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ecological resiliency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78e34dc1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/6/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reduction of water conflicts; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e34dc2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes decisions on a consensus basis, as defined in the bylaws of the watershed group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78e34dc3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Watershed management project","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “watershed management project” means any project (including a demonstration project) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78e34dc4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhances water conservation, including alternative water uses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e34dc5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improves water quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e34dc6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improves ecological resiliency of a river or stream, including benefits to fisheries, wildlife, or habitat;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e34dc7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduces the potential for water conflicts; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e34dc8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1015/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advances any other goals associated with water quality or quantity that the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78e34dc9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVI/s6001"},"text":"Pub. L. 111–11, title VI, § 6001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1165"},"text":"123 Stat. 1165","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tXI/s1107/a"},"text":"Pub. L. 116–260, div. FF, title XI, § 1107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3243"},"text":"134 Stat. 3243","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78e34dca-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78e34dcb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78e34dcc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Pars. (2) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s1107/a/1"},"text":"Pub. L. 116–260, § 1107(a)(1)","children":[],"tail":", (2), added par. (2) and redesignated former pars. (2) to (5) as (3) to (6), respectively. Former par. (6) redesignated (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6)(B)(i)(X). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s1107/a/3"},"text":"Pub. L. 116–260, § 1107(a)(3)","children":[],"tail":", added subcl. (X)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s1107/a/1"},"text":"Pub. L. 116–260, § 1107(a)(1)","children":[],"tail":", redesignated par. (6) as (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s1107/a/4"},"text":"Pub. L. 116–260, § 1107(a)(4)","children":[],"tail":", inserted “, including benefits to fisheries, wildlife, or habitat” after “river or stream”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
