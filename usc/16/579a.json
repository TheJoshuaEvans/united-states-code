{"tag":"section","attrib":{"id":"id784a8fa6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s579a"},"text":null,"children":[{"tag":"num","attrib":{"value":"579a"},"text":"§ 579a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation of aerial facilities and services","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Forest Service by contract or otherwise may provide for procurement and operation of aerial facilities and services for the protection and management of the national forests and other lands administered by it, including the furnishing, at the airbase, of facilities, equipment, materials and the preparation, mixing and loading into aircraft, with authority to renew any contract for such purpose annually, not more than twice, without additional advertising.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id784a8fa7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-09-21/ch412"},"text":"Sept. 21, 1944, ch. 412","children":[],"tail":", title II, § 205, "},{"tag":"ref","attrib":{"href":"/us/stat/58/736"},"text":"58 Stat. 736","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1950-04-24/ch97/s4"},"text":"Apr. 24, 1950, ch. 97, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/83"},"text":"64 Stat. 83","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/435"},"text":"Pub. L. 91–435","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-06"},"text":"Oct. 6, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/888"},"text":"84 Stat. 888","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id784a8fa8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id784a8fa9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id784a8faa-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as a part of the Department of Agriculture Organic Act of 1944.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id784a8fab-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/435"},"text":"Pub. L. 91–435","children":[],"tail":" authorized the Forest Service to extend aerial facilities and services for the protection and management of other lands administered by the Service and to procure, at the airbase, facilities, equipment, materials and the preparation, mixing and loading into aircraft."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1950—Act ","children":[{"tag":"date","attrib":{"date":"1950-04-24"},"text":"Apr. 24, 1950","children":[],"tail":", amended section to provide for aerial facilities and services for the protection and management of our national forests."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
