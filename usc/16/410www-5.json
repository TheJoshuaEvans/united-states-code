{"tag":"section","attrib":{"id":"id777d7bd5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410www–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"410www–5"},"text":"§ 410www–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; limitation on authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Effective ","children":[{"tag":"date","attrib":{"date":"1980-10-01"},"text":"October 1, 1980","children":[],"tail":", there are authorized to be appropriated such sums as may be necessary to carry out the provisions of this subchapter. Notwithstanding any other provision of this subchapter, authority to enter into contracts, to incur obligations, or to make payments under this subchapter shall be effective only to the extent, and in such amounts, as are provided in advance in appropriation Acts."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id777d7bd6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/428/s6"},"text":"Pub. L. 96–428, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-10"},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1842"},"text":"94 Stat. 1842","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/575/tXL/s4024/b"},"text":"Pub. L. 102–575, title XL, § 4024(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-30"},"text":"Oct. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4768"},"text":"106 Stat. 4768","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id777d7bd7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id777d7bd8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text