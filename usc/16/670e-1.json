{"tag":"section","attrib":{"id":"id7870b61f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s670e–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"670e–1"},"text":"§ 670e–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal enforcement of other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All Federal laws relating to the management of natural resources on Federal land may be enforced by the Secretary of Defense with respect to violations of the laws that occur on military installations within the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7870b620-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/797/tI/s106"},"text":"Pub. L. 86–797, title I, § 106","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dB/tXXIX/s2909/2"},"text":"Pub. L. 105–85, div. B, title XXIX, § 2909(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2021"},"text":"111 Stat. 2021","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7870b621-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7870b622-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7870b623-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/797/s106"},"text":"section 106 of Pub. L. 86–797","children":[],"tail":" was renumbered section 108, and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s670f"},"text":"section 670f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
