{"tag":"section","attrib":{"id":"id79e72934-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4006"},"text":null,"children":[{"tag":"num","attrib":{"value":"4006"},"text":"§ 4006.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Secretary with regard to National Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79e72935-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4006/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e72936-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4006/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within sixty days after its submission by the National Council, review the annual marketing and promotion plan and budget and, if the Secretary determines that such plan and budget are in accordance with the purposes and policies of this chapter, approve such plan and budget;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e72937-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4006/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer the Fund and, in accordance with subsection (b) of this section, withdraw from the Fund such sums as are necessary to carry out the National Council’s approved marketing and promotion plan and budget;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e72938-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4006/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promulgate regulations necessary to carry out the purposes and policies of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e72939-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4006/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide such administrative assistance as the National Council may require for purposes of its initial organization and operation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e7293a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4006/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make all initial appointments to the National Council within ninety days after ","children":[{"tag":"date","attrib":{"date":"1986-11-14"},"text":"November 14, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e7293b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4006/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make withdrawals of sums from the Fund under this section at the request of the National Council, unless the Secretary determines that the purposes for which such sums are requested are not reasonably likely to further the purposes and policies of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79e7293c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/659/tII/s207"},"text":"Pub. L. 99–659, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3719"},"text":"100 Stat. 3719","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/627/tVII/s704/c"},"text":"Pub. L. 101–627, title VII, § 704(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4464"},"text":"104 Stat. 4464","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79e7293d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79e7293e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79e7293f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/627"},"text":"Pub. L. 101–627","children":[],"tail":" inserted “initial” before “appointments”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
