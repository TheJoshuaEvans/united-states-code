{"tag":"section","attrib":{"id":"id7727bac1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s284h"},"text":null,"children":[{"tag":"num","attrib":{"value":"284h"},"text":"§ 284h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General management plan; preparation and revision; submittal to Congressional committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A general management plan for the park shall be prepared and periodically revised in a timely manner in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s100502"},"text":"section 100502 of title 54","children":[],"tail":". Such plan shall be submitted to the Committee on Natural Resources of the United States House of Representatives and the Committee on Energy and Natural Resources of the United States Senate no later than "},{"tag":"date","attrib":{"date":"1984-01-01"},"text":"January 1, 1984","children":[],"tail":", and such revisions shall be submitted to such committees of the Congress in a timely manner."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7727bac2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/671/s9"},"text":"Pub. L. 89–671, § 9","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/310"},"text":"Pub. L. 97–310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-14"},"text":"Oct. 14, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1457"},"text":"96 Stat. 1457","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/437/s6/d/8"},"text":"Pub. L. 103–437, § 6(d)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4583"},"text":"108 Stat. 4583","children":[],"tail":".)"}],"tail":"\n"},{"tag":"not