{"tag":"section","attrib":{"id":"id79e26ec7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3902"},"text":null,"children":[{"tag":"num","attrib":{"value":"3902"},"text":"§ 3902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e26ec8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3902/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Committees” means the Committee on Merchant Marine and Fisheries and the Committee on Natural Resources of the House of Representatives and the Committee on Environment and Public Works and the Committee on Energy and Natural Resources of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26ec9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3902/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “designated unit” means a unit of the National Wildlife Refuge System designated by the Secretary under section 3911(a)(2) ","children":[{"tag":"ref","attrib":{"idref":"fn002778"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002778"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26eca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3902/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “hydric soil” means soil that, in its undrained condition, is saturated, flooded, or ponded long enough during a growing season to develop an anaerobic condition that supports the growth and regeneration of hydrophytic vegetation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26ecb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3902/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “hydrophytic vegetation” means a plant growing in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e26ecc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3902/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26ecd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3902/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a substrate that is at least periodically deficient in oxygen during a growing season as a result of excessive water content.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26ece-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3902/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “wetland” means land that has a predominance of hydric soils and that is inundated or saturated by surface or groundwater at a frequency and duration sufficient to support, and that under normal circumstances does support, a prevalence of hydrophytic vegetation typically adapted for life in saturated soil conditions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79e26ecf-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/645/s3"},"text":"Pub. L. 99–645, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3583"},"text":"100 Stat. 3583","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/437/s6/d/41"},"text":"Pub. L. 103–437, § 6(d)(41)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4585"},"text":"108 Stat. 4585","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79e26ed0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79e26ed1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79e26ed2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3911"},"text":"Section 3911 of this title","children":[],"tail":", referred to in par. (2), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/dJ/tVIII/s813/c"},"text":"Pub. L. 108–447, div. J, title VIII, § 813(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3390"},"text":"118 Stat. 3390","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79e26ed3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/437"},"text":"Pub. L. 103–437","children":[],"tail":" substituted “Natural Resources” for “Interior and Insular Affairs” after “Committee on”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79e26ed4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79e26ed5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of House Committee on Merchant Marine and Fisheries","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Merchant Marine and Fisheries of House of Representatives abolished and its jurisdiction transferred by House Resolution No. 6, One Hundred Fourth Congress, ","children":[{"tag":"date","attrib":{"date":"1995-01-04"},"text":"Jan. 4, 1995","children":[],"tail":". Committee on Merchant Marine and Fisheries of House of Representatives treated as referring to Committee on Resources of House of Representatives in case of provisions relating to fisheries, wildlife, international fishing agreements, marine affairs (including coastal zone management) except for measures relating to oil and other pollution of navigable waters, or oceanography by "},{"tag":"ref","attrib":{"href":"/us/pl/104/14/s1/b/3"},"text":"section 1(b)(3) of Pub. L. 104–14","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s21"},"text":"section 21 of Title 2","children":[],"tail":", The Congress. Committee on Resources of House of Representatives changed to Committee on Natural Resources of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, "},{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
