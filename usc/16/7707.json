{"tag":"section","attrib":{"id":"id7a2c491e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7707"},"text":null,"children":[{"tag":"num","attrib":{"value":"7707"},"text":"§ 7707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation in carrying out Convention","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a2c491f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7707/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal and State agencies; private institutions and organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may cooperate with any Federal agency, any public or private institution or organization within the United States or abroad, and, through the Secretary of State, a duly authorized official of the government of any party to the North Pacific Fisheries Convention, in carrying out responsibilities under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2c4920-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7707/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientific and other programs; facilities and personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Federal agency may, upon the request of the Secretary, cooperate in the conduct of scientific and other programs and furnish facilities and personnel for the purpose of assisting the Commission in carrying out its duties under the North Pacific Fisheries Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2c4921-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7707/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctioned fishing operations and biological experiments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter, or in the laws of any State, prevents the Secretary or the Commission from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2c4922-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7707/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting or authorizing the conduct of fishing operations and biological experiments at any time for purposes of scientific investigation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2c4923-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7707/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discharging any other duties prescribed by the North Pacific Fisheries Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2c4924-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7707/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State jurisdiction not affected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to diminish or to increase the jurisdiction of any State in the territorial sea of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a2c4925-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/327/tI/s107"},"text":"Pub. L. 114–327, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1983"},"text":"130 Stat. 1983","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
