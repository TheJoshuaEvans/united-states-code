{"tag":"section","attrib":{"id":"id77908f9a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430f–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"430f–4"},"text":"§ 430f–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Upon the delivery and acceptance of the conveyance herein authorized, any jurisdiction heretofore ceded to the United States by the State of Tennessee over the lands conveyed shall thereby cease and determine and shall thereafter vest and be in the State of Tennessee.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77908f9b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/406/s4"},"text":"Pub. L. 85–406, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-05-16"},"text":"May 16, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/115"},"text":"72 Stat. 115","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77908f9c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77908f9d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77908f9e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Herein, referred to in text, means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/406"},"text":"Pub. L. 85–406","children":[],"tail":", which is classified to sections 430f–1 to 430f–4 of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
