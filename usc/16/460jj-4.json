{"tag":"section","attrib":{"id":"id77e1bc1c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460jj–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"460jj–4"},"text":"§ 460jj–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of State water laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The jurisdiction of the State of Colorado and the United States over waters of any stream included in the Arapaho National Recreation Area shall be determined by established principles of law. Nothing in this subchapter shall constitute an express or implied claim or denial on the part of the Federal Government as to exemption from State water laws.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77e1bc1d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/450/s8"},"text":"Pub. L. 95–450, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-11"},"text":"Oct. 11, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1097"},"text":"92 Stat. 1097","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
