{"tag":"section","attrib":{"id":"id7912e8e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1287"},"text":null,"children":[{"tag":"num","attrib":{"value":"1287"},"text":"§ 1287.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated, including such sums as have heretofore been appropriated, the following amounts for land acquisition for each of the rivers (described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1274/a"},"text":"section 1274(a) of this title","children":[],"tail":"):"}],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"Clearwater, Middle Fork, Idaho, $2,909,800;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"Eleven Point, Missouri, $10,407,000;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"Feather Middle Fork, California, $3,935,700;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"Rio Grande, New Mexico, $253,000;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"Rogue, Oregon, $15,147,000;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"St. Croix, Minnesota and Wisconsin, $21,769,000;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"Salmon Middle Fork, Idaho, $1,837,000;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"Wolf, Wisconsin, $142,150.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7912e8e1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/542/s17"},"text":"Pub. L. 90–542, § 17","children":[],"tail":", formerly § 16, "},{"tag":"date","attrib":{"date":"1968-10-02"},"text":"Oct. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"hre