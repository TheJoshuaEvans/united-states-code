{"tag":"section","attrib":{"id":"id76ff2475-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s80d–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"80d–1"},"text":"§ 80d–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of appropriations for road construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"After ","children":[{"tag":"date","attrib":{"date":"1946-06-22"},"text":"June 22, 1946","children":[],"tail":", no part of appropriations made for the National Park Service shall be available for road construction in Kings Canyon National Park, California, except on the floor of the canyon of the South Fork of the Kings River and the Grant Grove section of that park."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id76ff2476-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-07-01/ch529/s1"},"text":"July 1, 1946, ch. 529, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/377"},"text":"60 Stat. 377","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id76ff2477-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id76ff2478-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id76ff2479-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-03-04/ch40"},"text":"act Mar. 4, 1940, ch. 40","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/41"},"text":"54 Stat. 41","children":[],"tail":", which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id76ff247a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id76ff247b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of other officers, employees, and agencies of Department of the Interior, with certain exceptions, to Secretary of the Interior, with power to delegate, see Reorg. Plan No. 3 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1262"},"text":"64 Stat. 1262","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
