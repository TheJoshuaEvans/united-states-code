{"tag":"section","attrib":{"id":"id77898a7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423l–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"423l–4"},"text":"§ 423l–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land acquisition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77898a7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423l–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77898a7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423l–4/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire lands, waters, and interests in lands within the boundaries of the battlefield park from willing landowners by donation, purchase with donated or appropriated funds, or exchange. In acquiring lands and interests in lands under sections 423","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–1 to 423"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–6 of this title, the Secretary shall acquire the minimum interest necessary to achieve the purposes for which the battlefield is established."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77898a80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423l–4/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for private lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Privately owned lands or interests in lands may be acquired under sections 423","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–1 to 423"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–6 of this title only with the consent of the owner."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77898a81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423l–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Easements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77898a82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423l–4/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outside boundaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire an easement on property outside the boundaries of the battlefield park and around the City of Richmond, with the consent of the owner, if the Secretary determines that the easement is necessary to protect core Civil War resources as identified by the Civil War Sites Advisory Committee. Upon acquisition of the easement, the Secretary shall revise the boundaries of the battlefield park to include the property subject to the easement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77898a83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423l–4/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inside boundaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent practicable, and if preferred by a willing landowner, the Secretary shall use permanent conservation easements to acquire interests in land in lieu of acquiring land in fee simple and thereby removing land from non-Federal ownership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77898a84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423l–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Visitor center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire the Tredegar Iron Works buildings and associated land in the City of Richmond for use as a visitor center for the battlefield park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77898a85-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/511/tV/s504"},"text":"Pub. L. 106–511, title V, § 504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2374"},"text":"114 Stat. 2374","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77898a86-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77898a87-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77898a88-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 423","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–1 to 423"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–6 of this title, referred to in subsec. (a), was in the original “this title”, meaning title V of "},{"tag":"ref","attrib":{"href":"/us/pl/106/511"},"text":"Pub. L. 106–511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2373"},"text":"114 Stat. 2373","children":[],"tail":", which enacted sections 423"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–1 to 423"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–6 of this title and repealed sections 423j to 423"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title. For complete classification of title V to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
