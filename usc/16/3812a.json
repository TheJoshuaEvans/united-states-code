{"tag":"section","attrib":{"id":"id79c82ee9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3812a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3812a"},"text":"§ 3812a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development and implementation of conservation plans and conservation systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79c82eea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3812a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In connection with the standards and guidelines contained in Natural Resources Conservation Service field office technical guides applicable to the development and use of conservation measures and management practices as part of a conservation system, the Secretary shall ensure that the standards and guidelines permit a person to use a conservation system that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79c82eeb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3812a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is technically and economically feasible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c82eec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3812a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is based on local resource conditions and available conservation technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c82eed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3812a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is cost-effective; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c82eee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3812a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not cause undue economic hardship on the person applying the conservation system under the person’s conservation plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c82eef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3812a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Measurement of erosion reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of determining whether there is a substantial reduction in soil erosion on a field containing highly erodible cropland, the measurement of erosion reduction achieved by the application of a conservation system under a person’s conservation plan shall be based on the estimated annual level of erosion at the time of the measurement compared to the estimated annual level of erosion that existed before the implementation of the conservation measures and management practices provided for in the conservation system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c82ef0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3812a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Residue measurement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79c82ef1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3812a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of the Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of measuring the level of residue on a field, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79c82ef2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3812a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into account any residue incorporated into the top 2 inches of soil, as well as the growing crop, in the measurement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c82ef3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3812a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical guidelines for acceptable residue measurement methods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c82ef4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3812a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a certification system for third parties to perform residue measurements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c82ef5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3812a/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the acceptance and use of information and data voluntarily provided by the producer regarding the field.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c82ef6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3812a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of producer measurements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Annual residue measurements supplied by a producer (including measurements performed by a certified third party) shall be used by the Secretary if the Secretary determines that the measurements indicate that the residue level for the field meets the level required under the conservation plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c82ef7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3812a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of compliance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79c82ef8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3812a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of determining the eligibility of a person for program benefits specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3811"},"text":"section 3811 of this title","children":[],"tail":" at the time application is made for the benefits, the Secretary shall permit the person to certify that the person is complying with the person’s conservation plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c82ef9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3812a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status reviews","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a person makes a certification under paragraph (1), the Secretary shall not be required to carry out a review of the status of compliance of the person with the conservation plan under which the conservation system is being applied.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c82efa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3812a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revisions and modifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall permit a person who makes a certification under paragraph (1) with respect to a conservation plan to revise the conservation plan in any manner, if the same level of conservation treatment provided for by the conservation system under the person’s conservation plan is maintained. The Secretary may not revise the person’s conservation plan without the concurrence of the person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c82efb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3812a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crop insurance premium assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of determining the eligibility of a person for the payment described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3811/a/1/E"},"text":"section 3811(a)(1)(E) of this title","children":[],"tail":", the Secretary shall apply the procedures described in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3821/c/3/E"},"text":"section 3821(c)(3)(E) of this title","children":[],"tail":" and coordinate the certification process so as to avoid duplication or unnecessary paperwork."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c82efc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3812a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, using available resources and consistent with the Secretary’s other conservation responsibilities and objectives, provide technical assistance to a person throughout the development, revision, and application of the conservation plan and any conservation system of the person. At the request of the person, the Secretary may provide technical assistance regarding conservation measures and management practices for other lands of the person that do not contain highly erodible cropland.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c82efd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3812a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encouragement of on-farm research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To encourage on-farm conservation research, the Secretary may allow a person to include in the person’s conservation plan or a conservation system under the plan, on a field trial basis, practices that are not currently approved but that the Secretary considers have a reasonable likelihood of success.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79c82efe-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1213"},"text":"Pub. L. 99–198, title XII, § 1213","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tIII/s315/a/2"},"text":"Pub. L. 104–127, title III, § 315(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/984"},"text":"110 Stat. 984","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII/s2611/a/3"},"text":"Pub. L. 113–79, title II, § 2611(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/763"},"text":"128 Stat. 763","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79c82eff-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79c82f00-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id79c82f01-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1213"},"text":"section 1213 of Pub. L. 99–198","children":[],"tail":" was renumbered section 1214 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3813"},"text":"section 3813 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79c82f02-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" added par. (4)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
