{"tag":"section","attrib":{"id":"id7759c7bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll"},"text":null,"children":[{"tag":"num","attrib":{"value":"410ll"},"text":"§ 410ll.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7759c7bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7759c7bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Women’s Rights Convention held at the Wesleyan Methodist Chapel in Seneca Falls, New York, in 1848 was an event of major importance in the history of the United States because it marked the formal beginning of the struggle of women for their equal rights.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7759c7be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Declaration of Sentiments approved by the 1848 Women’s Rights Convention is a document of enduring relevance, which expresses the goal that equality and justice should be extended to all people without regard to sex.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7759c7bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are nine sites located in Seneca Falls and Waterloo, New York, associated with the nineteenth century women’s rights movement which should be recognized, preserved, and interpreted for the benefit of the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7759c7c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the purpose of this section to preserve and interpret for the education, inspiration, and benefit of present and future generations the nationally significant historical and cultural sites and structures associated with the struggle for equal rights for women and to cooperate with State and local entities to preserve the character and historic setting of such sites and structures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7759c7c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out the purposes of this section there is hereby established the Women’s Rights National Historical Park (hereinafter in this section referred to as the “park”). The park shall consist of the following designated sites in Seneca Falls and Waterloo, New York:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7759c7c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Stanton House, 32 Washington Street, Seneca Falls;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7759c7c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dwelling, 30 Washington Street, Seneca Falls;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7759c7c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dwelling, 34 Washington Street, Seneca Falls;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7759c7c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lot, 26–28 Washington Street, Seneca Falls;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7759c7c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" former Wesleyan Chapel, 126 Fall Street, Seneca Falls;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7759c7c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" theater, 128 Fall Street, Seneca Falls;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7759c7c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" McClintock House, 16 East Williams Street, Waterloo;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7759c7c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hunt House, 401 East Main Street, Waterloo;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7759c7ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not to exceed 1 acre, plus improvements, as determined by the Secretary, in Seneca Falls for development of a maintenance facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7759c7cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dwelling, 1 Seneca Street, Seneca Falls;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7759c7cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dwelling, 10 Seneca Street, Seneca Falls;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7759c7cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/c/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parcels adjacent to Wesleyan Chapel Block, including Clinton Street, Fall Street, and Mynderse Street, Seneca Falls; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7759c7ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/c/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dwelling, 12 East Williams Street, Waterloo.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7759c7cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of lands and interests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to acquire by donation, purchase with donated or appropriated funds, transfer from any other Federal agency, or exchange lands and interests therein within sites designated as part of the park. Lands and interests therein owned by a State or political subdivision thereof may be acquired only by donation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7759c7d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to enter into cooperative agreements with the owners of properties designated as part of the park, pursuant to which the Secretary may mark, interpret, improve, restore, and provide technical assistance with respect to the preservation and interpretation of such properties. Such agreements shall contain, but need not be limited to, provisions that the Secretary shall have the right of access at reasonable times to public portions of the property for interpretative and other purposes, and that no changes or alterations shall be made in the property except by mutual agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7759c7d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and local participation; financial assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall encourage State and local governmental agencies to develop and implement plans for the preservation and rehabilitation of sites designated as part of the park and their immediate environs, in order to preserve the historic character of the setting in which such sites are located. The Secretary may provide technical and financial assistance to such agencies in the development and implementation of such plans, but financial assistance may not exceed 50 per centum of the cost thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7759c7d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall administer the park in accordance with the provisions of this section and the provisions of law generally applicable to the administration of units of the National Park System, including the Act of ","children":[{"tag":"date","attrib":{"date":"1916-08-25"},"text":"August 25, 1916","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/39/535"},"text":"39 Stat. 535","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"16 U.S.C. 1","children":[],"tail":", 2–4) "},{"tag":"ref","attrib":{"idref":"fn002115"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002115"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and the Act of "},{"tag":"date","attrib":{"date":"1935-08-21"},"text":"August 21, 1935","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/49/666"},"text":"49 Stat. 666","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s461–7"},"text":"16 U.S.C. 461–7","children":[],"tail":")."},{"tag":"ref","attrib":{"idref":"fn002115"},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7759c7d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Women’s Rights National Historical Park Advisory Commission; membership; Chair; compensation and expenses; function; consultation; termination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7759c7d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There is hereby established the Women’s Rights National Historical Park Advisory Commission (hereinafter referred to as the “Commission”). The Commission shall consist of eleven members, each appointed by the Secretary for a term of five years as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7759c7d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member appointed from recommendations submitted by the Elizabeth Cady Stanton Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7759c7d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member appointed from recommendations submitted by the Women’s Hall of Fame;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7759c7d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/h/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two members appointed from recommendations submitted by the Governor of New York;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7759c7d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/h/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member appointed from recommendations submitted by the village of Seneca Falls;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7759c7d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/h/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member appointed from recommendations submitted by the town of Seneca Falls; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7759c7da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/h/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Five members appointed by the Secretary, at least one of whom shall represent an institution of higher learning and at least two of whom shall represent national women’s rights organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7759c7db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall designate one member to be the Chair of the Commission. Any vacancy on the Commission shall be filled in the same manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7759c7dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Commission shall serve without compensation as such, but the Secretary may pay the expenses reasonably incurred by the Commission and its members in carrying out their responsibilities under this section upon presentation of vouchers signed by the Chair of the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7759c7dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The function of the Commission shall be to advise the Secretary with respect to matters relating to the administration of the park and the carrying out of the provisions of this section. The Secretary shall consult with the Commission from time to time with respect to his responsibilities and authorities under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7759c7de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall terminate ten years from the effective date of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7759c7df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7759c7e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated such sums as may be necessary to carry out the provisions of this section, but not to exceed $700,000 for acquisition, and $500,000 for development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7759c7e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ll/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to those sums appropriated prior to ","children":[{"tag":"date","attrib":{"date":"1996-11-12"},"text":"November 12, 1996","children":[],"tail":", for land acquisition and development, there is hereby authorized to be appropriated an additional $2,000,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7759c7e2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/607/tXVI/s1601"},"text":"Pub. L. 96–607, title XVI, § 1601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-28"},"text":"Dec. 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3546"},"text":"94 Stat. 3546","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/402"},"text":"Pub. L. 98–402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-28"},"text":"Aug. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1478"},"text":"98 Stat. 1478","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/475/s1"},"text":"Pub. L. 100–475, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-06"},"text":"Oct. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2303"},"text":"102 Stat. 2303","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/333/dI/tV/s505"},"text":"Pub. L. 104–333, div. I, title V, § 505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-11-12"},"text":"Nov. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4155"},"text":"110 Stat. 4155","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/258/s1"},"text":"Pub. L. 106–258, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-08-08"},"text":"Aug. 8, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/655"},"text":"114 Stat. 655","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7759c7e3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7759c7e4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7759c7e5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Act of ","children":[{"tag":"date","attrib":{"date":"1916-08-25"},"text":"August 25, 1916","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/39/535"},"text":"39 Stat. 535","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"16 U.S.C. 1","children":[],"tail":", 2–4), referred to in subsec. (g), is "},{"tag":"ref","attrib":{"href":"/us/act/1916-08-25/ch408"},"text":"act Aug. 25, 1916, ch. 408","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/535"},"text":"39 Stat. 535","children":[],"tail":", known as the National Park Service Organic Act, which enacted sections 1, 2, 3, and 4 of this title and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100101"},"text":"section 100101 of Title 54","children":[],"tail":", National Park Service and Related Programs. Sections 1 to 4 of the Act were repealed and restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1865/a"},"text":"section 1865(a) of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and section 100101(a), chapter 1003, and sections 100751(a), 100752, 100753, and 102101 of Title 54 by "},{"tag":"ref","attrib":{"href":"/us/pl/113/287"},"text":"Pub. L. 113–287","children":[],"tail":", §§ 3, 4(a)(1), 7, "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3094"},"text":"128 Stat. 3094","children":[],"tail":", 3260, 3272. For complete classification of this Act to the Code, see Tables. For disposition of former sections of this title, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100101"},"text":"section 100101 of Title 54","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Act of ","children":[{"tag":"date","attrib":{"date":"1935-08-21"},"text":"August 21, 1935","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/49/666"},"text":"49 Stat. 666","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s461–7"},"text":"16 U.S.C. 461–7","children":[],"tail":"), referred to in subsec. (g), is "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-21/ch593"},"text":"act Aug. 21, 1935, ch. 593","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/666"},"text":"49 Stat. 666","children":[],"tail":", known as the Historic Sites Act of 1935 and also as the Historic Sites, Buildings, and Antiquities Act, which enacted sections 461 to 467 of this title. The Act was repealed and restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1866/a"},"text":"section 1866(a) of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and sections 102303 and 102304 and chapter 3201 of Title 54, National Park Service and Related Programs, by "},{"tag":"ref","attrib":{"href":"/us/pl/113/287"},"text":"Pub. L. 113–287","children":[],"tail":", §§ 3, 4(a)(1), 7, "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3094"},"text":"128 Stat. 3094","children":[],"tail":", 3260, 3272. For complete classification of this Act to the Code, see Tables. For disposition of former sections of this title, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100101"},"text":"section 100101 of Title 54","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The effective date of this section, referred to in subsec. (h)(5), probably means the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/607"},"text":"Pub. L. 96–607","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1980-12-28"},"text":"Dec. 28, 1980","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7759c7e6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (c)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/258/s1/b"},"text":"Pub. L. 106–258, § 1(b)","children":[],"tail":", substituted “Main” for “Williams”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/258/s1/a"},"text":"Pub. L. 106–258, § 1(a)","children":[],"tail":", in first sentence struck out before period at end “, except that the Secretary may not acquire the fee simple title to the land comprising the sites designated in paragraphs (7) and (9) of subsection (c) of this section” and struck out last sentence which read as follows: “Within two years of the acquisition of the property listed in subsection (c)(8) of this section the Secretary shall have removed all structures from the property that are not relevant to the historic integrity of the McClintock House.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/333/s505/a"},"text":"Pub. L. 104–333, § 505(a)","children":[],"tail":", inserted heading and amended text generally. Prior to amendment, text read as follows: “To carry out the purpose of this section there is hereby established the Women’s Rights National Historical Park (hereinafter in this section referred to as the ‘park’). The park shall consist initially of the following designated sites in Seneca Falls and Waterloo, New York:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Stanton House, 32 Washington Street, Seneca Falls;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) dwelling, 30 Washington Street, Seneca Falls;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) dwelling, 34 Washington Street, Seneca Falls;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) lot, 26–28 Washington Street, Seneca Falls;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) former Wesleyan Chapel, 126 Fall Street, Seneca Falls;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(6) theater, 128 Fall Street, Seneca Falls;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(7) Bloomer House, 53 East Bayard Street;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(8) McClintock House and related structures, 14 and 16 East Williams Street, Waterloo; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(9) Hunt House, 401 East Main Street, Waterloo.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/333/s505/b"},"text":"Pub. L. 104–333, § 505(b)","children":[],"tail":", designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/475"},"text":"Pub. L. 100–475","children":[],"tail":" substituted “$700,000” for “$490,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/402/s1/a"},"text":"Pub. L. 98–402, § 1(a)","children":[],"tail":", substituted “McClintock House and related structures, 14 and 16 East Williams Street” for “McClintock House, 16 East Williams Street”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/402/s1/b"},"text":"Pub. L. 98–402, § 1(b)","children":[],"tail":", substituted “paragraphs (7) and (9)” for “paragraphs (7) through (9)”, and inserted “Within two years of the acquisition of the property listed in subsection (c)(8) of this section the Secretary shall have removed all structures from the property that are not relevant to the historic integrity of the McClintock House.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7759c7e7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory N