{"tag":"section","attrib":{"id":"id78353368-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539o"},"text":null,"children":[{"tag":"num","attrib":{"value":"539o"},"text":"§ 539o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ancient Bristlecone Pine Forest","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78353369-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539o/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To conserve and protect the Ancient Bristlecone Pines by maintaining near-natural conditions and to ensure the survival of the Pines for the purposes of public enjoyment and scientific study, the approximately 31,700 acres of public land in the State, as generally depicted on the map entitled “Ancient Bristlecone Pine Forest—Proposed” and dated ","children":[{"tag":"date","attrib":{"date":"2008-07-16"},"text":"July 16, 2008","children":[],"tail":", is designated as the “Ancient Bristlecone Pine Forest”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7835336a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539o/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map and legal description","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7835336b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539o/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As soon as practicable, but not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", the Secretary shall file a map and legal description of the Forest with—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7835336c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539o/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Natural Resources of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7835336d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539o/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Natural Resources of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7835336e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539o/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Force of law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map and legal description filed under paragraph (1) shall have the same force and effect as if included in this subtitle, except that the Secretary may correct any errors in the map and legal description.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7835336f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539o/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map and legal description filed under paragraph (1) shall be on file and available for public inspection in the appropriate offices of the Forest Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78353370-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539o/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78353371-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539o/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall administer the Forest—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78353372-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539o/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in a manner that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78353373-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539o/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect ","children":[{"tag":"ref","attrib":{"idref":"fn002417"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002417"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “protects”."}],"tail":" the resources and values of the area in accordance with the purposes for which the Forest is established, as described in subsection (a); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78353374-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539o/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" promotes the objectives of the applicable management plan (as in effect on ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":"), including objectives relating to—"}],"tail":null},{"tag":"subclause","attrib":{"id":"id78353375-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539o/c/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection of bristlecone pines for public enjoyment and scientific study;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78353376-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539o/c/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recognition of the botanical, scenic, and historical values of the area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78353377-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539o/c/1/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maintenance of near-natural conditions by ensuring that all activities are subordinate to the needs of protecting and preserving bristlecone pines and wood remnants; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78353378-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539o/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with the National Forest Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1600"},"text":"16 U.S.C. 1600","children":[],"tail":" et seq.), this section, and any other applicable laws."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78353379-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539o/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7835337a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539o/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall allow only such uses of the Forest as the Secretary determines would further the purposes for which the Forest is established, as described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7835337b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539o/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientific research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Scientific research shall be allowed in the Forest in accordance with the Inyo National Forest Land and Resource Management Plan (as in effect on ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7835337c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539o/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to valid existing rights, all Federal land within the Forest is withdrawn from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7835337d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539o/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all forms of entry, appropriation or disposal under the public land laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7835337e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539o/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" location, entry, and patent under the mining laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7835337f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539o/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disposition under all laws relating to mineral and geothermal leasing or mineral materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78353380-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tI/s1808"},"text":"Pub. L. 111–11, title I, § 1808","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1060"},"text":"123 Stat. 1060","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78353381-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78353382-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":