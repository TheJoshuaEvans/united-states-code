{"tag":"section","attrib":{"id":"id7993b26d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2106c"},"text":"§ 2106c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced community fire protection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7993b26e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative management related to wildfire threats","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may cooperate with State foresters and equivalent State officials in the management of lands in the United States for the following purposes:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7993b26f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Aid in wildfire prevention and control.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7993b270-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Protect communities from wildfire threats.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7993b271-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enhance the growth and maintenance of trees and forests that promote overall forest health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7993b272-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ensure the continued production of all forest resources, including timber, outdoor recreation opportunities, wildlife habitat, and clean water, through conservation of forest cover on watersheds, shelterbelts, and windbreaks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7993b273-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community and Private Land Fire Assistance Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7993b274-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a Community and Private Land Fire Assistance program (in this subsection referred to as the “Program”)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7993b275-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to focus the Federal role in promoting optimal firefighting efficiency at the Federal, State, and local levels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7993b276-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to augment Federal projects that establish landscape level protection from wildfires;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7993b277-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106c/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expand outreach and education programs to homeowners and communities about fire prevention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7993b278-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106c/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish space around homes and property of private landowners that is defensible against wildfires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7993b279-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration and implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Program shall be administered by the Forest Service and implemented through State foresters or equivalent State officials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7993b27a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Components","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In coordination with existing authorities under this chapter, the Secretary, in consultation with the State forester or equivalent State official, may undertake on non-Federal lands—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7993b27b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106c/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fuel hazard mitigation and prevention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7993b27c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106c/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" invasive species management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7993b27d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106c/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multiresource wildfire planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7993b27e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106c/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community protection planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7993b27f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106c/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community and landowner education enterprises, including the program known as FIREWISE;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7993b280-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106c/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" market development and expansion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7993b281-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106c/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improved wood utilization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7993b282-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106c/b/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special restoration projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7993b283-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consent required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Program activities undertaken by the Secretary on non-Federal lands shall be undertaken only with the consent of the owner of the lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7993b284-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106c/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall use persons in the local community wherever possible to carry out projects under the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7993b285-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary shall consult with the Administrator of the United States Fire Administration, the Director of the National Institute of Standards and Technology, and the heads of other Federal agencies, as necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7993b286-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are hereby authorized to be appropriated to the Secretary to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7993b287-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $35,000,000 for each of fiscal years 2002 through 2007; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7993b288-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2106c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for fiscal years thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7993b289-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/313/s10A"},"text":"Pub. L. 95–313, § 10A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVIII/s8003/b"},"text":"Pub. L. 107–171, title VIII, § 8003(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/473"},"text":"116 Stat. 473","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7993b28a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7993b28b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7993b28c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings for Enhanced Community Fire Protection","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVIII/s8003/a"},"text":"Pub. L. 107–171, title VIII, § 8003(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/473"},"text":"116 Stat. 473","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/171/tVIII/s8003/a"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress finds the following:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The severity and intensity of wildland fires has increased dramatically over the past few decades as a result of past fire and land management policies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The record 2000 fire season is a prime example of what can be expected if action is not taken.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Wildland fires threaten not only the forested resources of the United States, but also the thousands of communities intermingled with the wildlands in the wildland-urban interface.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Fire Plan, if implemented to achieve appropriate priorities, is the proper, coordinated, and most effective means to address the issue of wildfires.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" While adequate authorities exist to tackle the wildfire issues at the landscape level on Federal lands, there is limited authority to take action on most private lands, and the largest threat to life and property exists on private lands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is a significant Federal interest in enhancing community protection from wildfire.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
