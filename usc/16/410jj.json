{"tag":"section","attrib":{"id":"id7757566d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410jj"},"text":null,"children":[{"tag":"num","attrib":{"value":"410jj"},"text":"§ 410jj.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In order to provide for the preservation of the unique nationally and internationally significant cultural, historic, educational, and scenic resources of the Kalaupapa settlement on the island of Molokai in the State of Hawaii, there is hereby established the Kalaupapa National Historical Park (hereinafter referred to as the “park”).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7757566e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/565/tI/s101"},"text":"Pub. L. 96–565, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3321"},"text":"94 Stat. 3321","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
