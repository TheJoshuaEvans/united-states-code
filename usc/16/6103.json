{"tag":"section","attrib":{"id":"id7a03b204-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6103"},"text":null,"children":[{"tag":"num","attrib":{"value":"6103"},"text":"§ 6103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a03b205-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6103/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Caribbean","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Caribbean” includes Puerto Rico and the United States Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a03b206-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6103/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “conservation” means the use of methods and procedures necessary to bring a species of neotropical migratory bird to the point at which there are sufficient populations in the wild to ensure the long-term viability of the species, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a03b207-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6103/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protection and management of neotropical migratory bird populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a03b208-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6103/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintenance, management, protection, and restoration of neotropical migratory bird habitat;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a03b209-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6103/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research and monitoring;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a03b20a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6103/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" law enforcement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a03b20b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6103/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community outreach and education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a03b20c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6103/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Fund” means the Neotropical Migratory Bird Conservation Fund established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6108/a"},"text":"section 6108(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a03b20d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6103/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a03b20e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/247/s4"},"text":"Pub. L. 106–247, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-07-20"},"text":"July 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/593"},"text":"114 Stat. 593","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/363/tIII/s302/c"},"text":"Pub. L. 109–363, title III, § 302(c)","children":[],"tail":", (h)(3)(A), "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2075"},"text":"120 Stat. 2075","children":[],"tail":", 2076; "},{"tag":"ref","attrib":{"href":"/us/pl/118/51/s2/d/1"},"text":"Pub. L. 118–51, § 2(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-24"},"text":"Apr. 24, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1005"},"text":"138 Stat. 1005","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a03b20f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a03b210-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a03b211-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[