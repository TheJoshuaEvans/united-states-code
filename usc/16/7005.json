{"tag":"section","attrib":{"id":"id7a22d23d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7005"},"text":null,"children":[{"tag":"num","attrib":{"value":"7005"},"text":"§ 7005.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States representation on advisory panel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a22d23e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7005/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a22d23f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7005/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Secretary of State, shall appoint at least 6 but not more than 12 individuals to serve as members of the advisory panel, selected from among individuals who are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a22d240-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7005/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowledgeable or experienced in the harvesting, processing, marketing, management, conservation, or research of the offshore whiting resource; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a22d241-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7005/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not employees of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a22d242-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7005/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual appointed under paragraph (1) shall be appointed for a term of not to exceed 4 years, but shall be eligible for reappointment. An individual appointed to fill a vacancy occurring prior to the expiration of the term of office of that individual’s predecessor shall be appointed for the remainder of that term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a22d243-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/479/tVI/s606"},"text":"Pub. L. 109–479, title VI, § 606","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3646"},"text":"120 Stat. 3646","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
