{"tag":"section","attrib":{"id":"id78c69e05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s838e"},"text":null,"children":[{"tag":"num","attrib":{"value":"838e"},"text":"§ 838e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Subject to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s838c"},"text":"section 838c of this title","children":[],"tail":" the Administrator may purchase or lease or otherwise acquire and hold such real and personal property in the name of the United States as he deems necessary or appropriate to carry out his duties pursuant to law."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78c90f06-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/454/s7"},"text":"Pub. L. 93–454, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-18"},"text":"Oct. 18, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1377"},"text":"88 Stat. 1377","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78c90f07-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78c90f08-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id78c90f09-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of Secretary of the Interior with respect to Bonneville Power Administration transferred to Secretary of Energy by section 7152(a)(1)(D), (2) of Title 42, The Public Health and Welfare, with Bonneville Power Administration to be preserved as a distinct organizational entity within Department of Energy and headed by an Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
