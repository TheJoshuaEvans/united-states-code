,"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3834/f/4"},"text":"Section 3834(f)(4) of this title","children":[],"tail":", referred to in subsec. (c)(3), was redesignated as "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3834/g/2"},"text":"section 3834(g)(2) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII"},"text":"Pub. L. 113–79, title II","children":[],"tail":", §§ 2005(b)(2), (e)(3), "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/718"},"text":"128 Stat. 718","children":[],"tail":", 719."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79d8d131-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79d8d132-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" substituted “2023,” for “2023, and” and inserted “, and $70,000,000 for the period of fiscal years 2025 through 2031” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/22"},"text":"Pub. L. 118–22","children":[],"tail":" struck out “and” after “through 2018,” and inserted “, and $10,000,000 for fiscal year 2024” after “through 2023”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2406/1"},"text":"Pub. L. 115–334, § 2406(1)","children":[],"tail":", substituted “funding” for “grants”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2406/2"},"text":"Pub. L. 115–334, § 2406(2)","children":[],"tail":", substituted “funding” for “a grant” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2406/1"},"text":"Pub. L. 115–334, § 2406(1)","children":[],"tail":", substituted “funding” for “grants” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2406/3"},"text":"Pub. L. 115–334, § 2406(3)","children":[],"tail":", inserted “or on land covered by a wetland reserve easement under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3865C"},"text":"section 3865C of this title","children":[],"tail":"” before “by providing”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2202/b/1"},"text":"Pub. L. 115–334, § 2202(b)(1)","children":[],"tail":", substituted “a conservation reserve enhancement program under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3831a"},"text":"section 3831a of this title","children":[],"tail":"” for “a special conservation reserve enhancement program described in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3834/f/4"},"text":"section 3834(f)(4) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2406/2"},"text":"Pub. L. 115–334, § 2406(2)","children":[],"tail":", substituted “funding” for “a grant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2406/4/A"},"text":"Pub. L. 115–334, § 2406(4)(A)","children":[],"tail":", substituted “2009 through 2012,” for “2009 through 2012 and” and inserted “, and $50,000,000 for the period of fiscal years 2019 through 2023” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2406/4/B"},"text":"Pub. L. 115–334, § 2406(4)(B)","children":[],"tail":", (C), added par. (2) and redesignated former par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":", in heading, substituted “Mandatory funding” for “Fiscal years 2009 through 2012” and in text, inserted “and $40,000,000 for the period of fiscal years 2014 through 2018” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/240"},"text":"Pub. L. 112–240","children":[],"tail":" added subsec. (f) and struck out former subsec. (f). Prior to amendment, text read as follows: “Of the funds of the Commodity Credit Corporation, the Secretary shall use, to the maximum extent practicable, $50,000,000 for the period of fiscal years 2009 through 2012.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79d8d133-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79d8d134-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2023 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/22"},"text":"Pub. L. 118–22","children":[],"tail":" to be applied and administered as if enacted on "},{"tag":"date","attrib":{"date":"2023-09-30"},"text":"Sept. 30, 2023","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/s102/g"},"text":"section 102(g) of Pub. L. 118–22","children":[],"tail":", set out in an Extension of Agricultural Programs note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79d8d135-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/240"},"text":"Pub. L. 112–240","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-09-30"},"text":"Sept. 30, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/240/s701/j"},"text":"section 701(j) of Pub. L. 112–240","children":[],"tail":", set out in a 1-Year Extension of Agricultural Programs note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79d8d136-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
