{"tag":"section","attrib":{"id":"id79d68828-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"3839bb–5"},"text":"§ 3839bb–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary public access and habitat incentive program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79d68829-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a voluntary public access program under which States and tribal governments may apply for funding to encourage owners and operators of privately-held farm, ranch, and forest land to voluntarily make that land available for access by the public for wildlife-dependent recreation, including hunting or fishing under programs administered by the States and tribal governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d6882a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In submitting applications for funding under the program, a State or tribal government shall describe—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d6882b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the benefits that the State or tribal government intends to achieve by encouraging public access to private farm and ranch land for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d6882c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–5/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hunting and fishing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d6882d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–5/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, other recreational purposes; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d6882e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methods that will be used to achieve those benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d6882f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In approving applications and awarding funding under the program, the Secretary shall give priority to States and tribal governments that propose—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d68830-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–5/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maximize participation by offering a program the terms of which are likely to meet with widespread acceptance among landowners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d68831-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–5/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that land enrolled under the State or tribal government program has appropriate wildlife habitat;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d68832-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–5/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to strengthen wildlife habitat improvement efforts on land enrolled in a conservation reserve enhancement program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3831a"},"text":"section 3831a of this title","children":[],"tail":" or on land covered by a wetland reserve easement under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3865c"},"text":"section 3865c of this title","children":[],"tail":" by providing incentives to increase public hunting and other recreational access on that land;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d68833-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–5/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use additional Federal, State, tribal government, or private resources in carrying out the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d68834-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–5/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make available to the public the location of land enrolled.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d68835-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other laws","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d68836-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–5/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No preemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section preempts a State or tribal government law, including any State or tribal government liability law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d8d127-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–5/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of inconsistent opening dates for migratory bird hunting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall reduce by 25 percent the amount of funding otherwise determined for a State under the program if the opening dates for migratory bird hunting in the State are not consistent for residents and non-residents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d8d128-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–5/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate such regulations as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d8d129-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–5/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d8d12a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–5/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds of the Commodity Credit Corporation, the Secretary shall use to carry out this section, to the maximum extent practicable, $50,000,000 for the period of fiscal years 2009 through 2012, $40,000,000 for the period of fiscal years 2014 through 2018, $50,000,000 for the period of fiscal years 2019 through 2023, $10,000,000 for fiscal year 2024, and $70,000,000 for the period of fiscal years 2025 through 2031.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d8d12b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–5/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced public access to wetland reserve easements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, of the funds made available under paragraph (1), the Secretary shall use $3,000,000 for the period of fiscal years 2019 through 2023 to encourage public access to land covered by wetland reserve easements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3865c"},"text":"section 3865c of this title","children":[],"tail":" through agreements with States and tribal governments under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d8d12c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–5/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $10,000,000 for fiscal year 2013.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79d8d12d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1240R"},"text":"Pub. L. 99–198, title XII, § 1240R","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tII/s2606"},"text":"Pub. L. 110–234, title II, § 2606","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1070"},"text":"122 Stat. 1070","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title II, § 2606, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1798; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/240/tVII/s701/c/2"},"text":"Pub. L. 112–240, title VII, § 701(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2363"}