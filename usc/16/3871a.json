{"tag":"section","attrib":{"id":"id79dffdc9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3871a"},"text":"§ 3871a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79dffdca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered program” means the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79dffdcb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The agricultural conservation easement program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffdcc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The environmental quality incentives program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffdcd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The conservation stewardship program, not including the grassland conservation initiative under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3839aa–25"},"text":"section 3839aa–25 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffdce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The healthy forests reserve program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6571"},"text":"section 6571 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffdcf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The conservation reserve program established under subpart B of part I of subchapter IV.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffdd0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The programs established by the Secretary to carry out the Watershed Protection and Flood Prevention Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1001"},"text":"16 U.S.C. 1001","children":[],"tail":" et seq.), except for any program established by the Secretary to carry out section 14 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1012"},"text":"16 U.S.C. 1012","children":[],"tail":") of that Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dffdd1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible activity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible activity” means a practice, activity, agreement, easement, or related conservation measure that is available under the statutory authority for a covered program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dffdd2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible land” means any agricultural or nonindustrial private forest land or associated land on which the Secretary determines an eligible activity would help achieve conservation benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dffdd3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible partner","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible partner” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79dffdd4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An agricultural or silvicultural producer association or other group of producers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffdd5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State or unit of local government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffdd6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffdd7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A farmer cooperative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffdd8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A water district, irrigation district, acequia, rural water district or association, or other organization with specific water delivery authority to producers on agricultural land.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffdd9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871a/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A municipal water or wastewater treatment entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffdda-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871a/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffddb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871a/4/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An organization or entity with an established history of working cooperatively with producers on agricultural land, as determined by the Secretary, to address—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79dffddc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871a/4/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local conservation priorities related to agricultural production, wildlife habitat development, or nonindustrial private forest land management; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dffddd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871a/4/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" critical watershed-scale soil erosion, water quality, sediment reduction, or other natural resource issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffdde-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871a/4/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An organization described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3865a/3/B"},"text":"section 3865a(3)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffddf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871a/4/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A conservation district.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dffde0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “partnership agreement” means the programmatic agreement entered into between the Secretary and an eligible partner, subject to the terms and conditions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3871b"},"text":"section 3871b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dffde1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means the regional conservation partnership program established by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e26de2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program contract","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e26de3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program contract” means the contract between the Secretary and a producer entered into under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e26de4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3871a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program contract” does not include a contract under a covered program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79e26de5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1271A"},"text":"Pub. L. 99–198, title XII, § 1271A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII/s2401"},"text":"Pub. L. 113–79, title II, § 2401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/745"},"text":"128 Stat. 745","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII/s2702"},"text":"Pub. L. 115–334, title II, § 2702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4593"},"text":"132 Stat. 4593","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79e26de6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79e26de7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79e26de8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Watershed Protection and Flood Prevention Act, referred to in par. (1)(F), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-04/ch656"},"text":"act Aug. 4, 1954, ch. 656","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/666"},"text":"68 Stat. 666","children":[],"tail":", which is classified principally to chapter 18 (§ 1001 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1001"},"text":"section 1001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79e26de9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Par. (1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2702/1/A"},"text":"Pub. L. 115–334, § 2702(1)(A)","children":[],"tail":", inserted “, not including the grassland conservation initiative under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3839aa–25"},"text":"section 3839aa–25 of this title","children":[],"tail":"” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(E), (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2702/1/B"},"text":"Pub. L. 115–334, § 2702(1)(B)","children":[],"tail":", added subpars. (E) and (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2702/2"},"text":"Pub. L. 115–334, § 2702(2)","children":[],"tail":", added pars. (2) and (3) and struck out former pars. (2) and (3), which defined “eligible activity” as a conservation activity for specified purposes and types of projects and “eligible land” as specified types of land or associated lands on which agricultural commodities, livestock, or forest-related products are produced."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2702/3/A"},"text":"Pub. L. 115–334, § 2702(3)(A)","children":[],"tail":", inserted “acequia,” after “irrigation district,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4)(I), (J). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2702/3/B"},"text":"Pub. L. 115–334, § 2702(3)(B)","children":[],"tail":", added subpars. (I) and (J)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2702/4"},"text":"Pub. L. 115–334, § 2702(4)","children":[],"tail":", added par. (5) and struck out former par. (5). Prior to amendment, text read as follows: “The term ‘partnership agreement’ means an agreement entered into under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3871b"},"text":"section 3871b of this title","children":[],"tail":" between the Secretary and an eligible partner.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2702/5"},"text":"Pub. L. 115–334, § 2702(5)","children":[],"tail":", added par. (7)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
