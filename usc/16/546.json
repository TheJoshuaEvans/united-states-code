{"tag":"section","attrib":{"id":"id78411a1a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546"},"text":null,"children":[{"tag":"num","attrib":{"value":"546"},"text":"§ 546.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Saint Helena Island National Scenic Area, Michigan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78411a1b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of sections 546 to 546a–5 of this title are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78411a1c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to preserve and protect for present and future generations the outstanding resources and values of Saint Helena Island in Lake Michigan, Michigan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78411a1d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for the conservation, protection, and enhancement of primitive recreation opportunities, fish and wildlife habitat, vegetation, and historical and cultural resources of the island.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78411a1e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes described in subsection (a), there shall be established the Saint Helena Island National Scenic Area (in sections 546 to 546a–5 of this title referred to as the “scenic area”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78411a1f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s546/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective upon conveyance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (b) shall be effective upon conveyance of satisfactory title to the United States of the whole of Saint Helena Island, except that portion conveyed to the Great Lakes Lighthouse Keepers Association pursuant to section 1001 of the Coast Guard Authorization Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324"},"text":"Public Law 104–324","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/110/3948"},"text":"110 Stat. 3948","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78411a20-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/431/s2"},"text":"Pub. L. 106–431, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-06"},"text":"Nov. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1905"},"text":"114 Stat. 1905","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78411a21-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78411a22-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78411a23-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1001 of the Coast Guard Authorization Act of 1996, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/s1001"},"text":"section 1001 of Pub. L. 104–324","children":[],"tail":", title X, "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3948"},"text":"110 Stat. 3948","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78411a24-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id78411a25-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/431/s1"},"text":"Pub. L. 106–431, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-06"},"text":"Nov. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1905"},"text":"114 Stat. 1905","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/431/s1"},"text":"“This Act [enacting sections 546 to 546a–5 of this title] may be cited as the ‘Saint Helena Island National Scenic Area Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
