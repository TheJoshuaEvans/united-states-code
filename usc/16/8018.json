{"tag":"section","attrib":{"id":"id7a3103d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8018"},"text":null,"children":[{"tag":"num","attrib":{"value":"8018"},"text":"§ 8018.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capacity building in foreign fisheries","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the heads of other Federal agencies, as appropriate, shall develop and carry out with partner governments and civil society—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3103d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8018/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multi-year international environmental cooperation agreements and projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3103d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8018/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multi-year capacity-building projects for implementing measures to address illegal, unreported, or unregulated fishing, fraud, forced labor, bycatch, and other conservation measures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3103da-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXIII/s11339/a"},"text":"Pub. L. 117–263, div. K, title CXIII, § 11339(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4105"},"text":"136 Stat. 4105","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a3103db-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a3103dc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a3103dd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Don Young Coast Guard Authorization Act of 2022 and also as part of the James M. Inhofe National Defense Authorization Act for Fiscal Year 2023, and not as part of the Maritime Security and Fisheries Enforcement Act or the Maritime SAFE Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a3103de-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id7a3103df-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/s11329"},"text":"section 11329 of div. K of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1885a"},"text":"section 1885a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
