{"tag":"section","attrib":{"id":"id784a8fdb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s580a"},"text":null,"children":[{"tag":"num","attrib":{"value":"580a"},"text":"§ 580a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale and distribution of supplies, equipment, and materials to other Government activities and to cooperating State and private agencies; reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Forest Service may sell and distribute supplies, equipment, and materials to other Government activities and to State and private agencies who cooperate with the Forest Service in fire control under terms of written cooperative agreements, the cost of such supplies, equipment, and materials, including the cost of supervision, transportation, warehousing, and handling, to be reimbursed to appropriations current at the time additional supplies, equipment, and materials are procured for warehouse stocks.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id784d00dc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-09-21/ch412"},"text":"Sept. 21, 1944, ch. 412","children":[],"tail":", title II, § 203, "},{"tag":"ref","attrib":{"href":"/us/stat/58/736"},"text":"58 Stat. 736","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id784d00dd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id784d00de-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id784d00df-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as a part of the Department of Agriculture Organic Act of 1944.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id784d00e0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in the following Department of Agriculture Appropriation Acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1944-06-28/ch296"},"text":"June 28, 1944, ch. 296","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/443"},"text":"58 Stat. 443","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1943-07-12/ch215"},"text":"July 12, 1943, ch. 215","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/57/411"},"text":"57 Stat. 411","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1942-07-22/ch516"},"text":"July 22, 1942, ch. 516","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/679"},"text":"56 Stat. 679","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1941-07-01/ch267"},"text":"July 1, 1941, ch. 267","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/421"},"text":"55 Stat. 421","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1940-06-25/ch421"},"text":"June 25, 1940, ch. 421","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/546"},"text":"54 Stat. 546","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref",