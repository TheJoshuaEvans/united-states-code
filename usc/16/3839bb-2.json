{"tag":"section","attrib":{"id":"id79d6880f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"3839bb–2"},"text":"§ 3839bb–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grassroots source water protection program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79d68810-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a national grassroots water protection program to more effectively use onsite technical assistance capabilities of each State rural water association that, as of ","children":[{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", operates a wellhead or groundwater protection program in the State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d68811-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d68812-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $20,000,000 for each of fiscal years 2008 through 2031.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d68813-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to funds made available under paragraph (1), of the funds of the Commodity Credit Corporation, the Secretary shall use $5,000,000, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d68814-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to any other funds made available under this subsection, of the funds of the Commodity Credit Corporation, the Secretary shall use—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d68815-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–2/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 beginning in fiscal year 2019, to remain available until expended;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d68816-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–2/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000 beginning in fiscal year 2024, to remain available until expended; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d68817-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839bb–2/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000 beginning in fiscal year 2026, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79d68818-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1240O"},"text":"Pub. L. 99–198, title XII, § 1240O","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tII/s2502/a"},"text":"Pub. L. 107–171, title II, § 2502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/267"},"text":"116 Stat. 267","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tII/s2603"},"text":"Pub. L. 110–234, title II, § 2603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1068"},"text":"122 Stat. 1068","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title II, § 2603, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1796; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII/s2502"},"text":"Pub. L. 113–79, title II, § 2502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/751"},"text":"128 Stat. 751","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII/s2405"},"text":"Pub. L. 115–334, title II, § 2405","children":[],"tail":", "},{"tag":"date","attrib":{