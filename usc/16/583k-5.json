{"tag":"section","attrib":{"id":"id7851bca8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"583k–5"},"text":"§ 583k–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stewardship credits for outfitters and guides","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7851bca9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 1 year after ","children":[{"tag":"date","attrib":{"date":"2016-11-28"},"text":"November 28, 2016","children":[],"tail":", in accordance with this section, the Secretary shall establish a pilot program on not less than 20 administrative units to offset all or part of the land use fee for an outfitting and guiding permit by the cost of the work performed by the permit holder to construct, improve, or maintain National Forest System trails, trailheads, or developed sites that support public use under terms established by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7851bcaa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing the pilot program authorized by subsection (a), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7851bcab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select administrative units where the pilot program will improve trail maintenance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bcac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583k–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish appropriate terms and conditions, including meeting National Quality Standards for Trails and the Trail Management Objectives identified for the trail.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7851bcad-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/245/s7"},"text":"Pub. L. 114–245, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-11-28"},"text":"Nov. 28, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/994"},"text":"130 Stat. 994","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
