{"tag":"section","attrib":{"id":"id77719488-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"410fff–5"},"text":"§ 410fff–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of the Gunnison Gorge National Conservation Area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77719489-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7771948a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–5/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established the Gunnison Gorge National Conservation Area, consisting of approximately 57,725 acres as generally depicted on the Map.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7771948b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–5/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The boundary of the Conservation Area is revised to include the addition of approximately 7,100 acres, as generally depicted on the map entitled “Black Canyon of the Gunnison National Park and Gunnison Gorge NCA Boundary Modifications”, and dated ","children":[{"tag":"date","attrib":{"date":"2003-04-02"},"text":"April 2, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7771948c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management of Conservation Area","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Director of the Bureau of Land Management, shall manage the Conservation Area to protect the resources of the Conservation Area in accordance with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7771948d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7771948e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"43 U.S.C. 1701","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7771948f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–5/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other applicable provisions of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77719490-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to valid existing rights, all Federal lands within the Conservation Area are hereby withdrawn from all forms of entry, appropriation or disposal under the public land laws; from location, entry, and patent under the mining laws; and from disposition under all laws relating to mineral and geothermal leasing, and all amendments thereto.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77719491-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hunting, trapping, and fishing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77719492-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–5/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall permit hunting, trapping, and fishing within the Conservation Area in accordance with applicable laws (including regulations) of the United States and the State of Colorado.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77719493-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–5/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, after consultation with the Colorado Division of Wildlife, may issue regulations designating zones where and establishing periods when no hunting or trapping shall be permitted for reasons concerning—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77719494-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–5/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77719495-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–5/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77719496-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–5/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public use and enjoyment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77719497-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–5/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of motorized vehicles","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the use of motorized vehicles on established roadways, the use of motorized vehicles in the Conservation Area shall be allowed to the extent the use is compatible with off-highway vehicle designations as described in the management plan in effect on ","children":[{"tag":"date","attrib":{"date":"1999-10-21"},"text":"October 21, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77719498-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–5/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation Area management plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77719499-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–5/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 4 years after ","children":[{"tag":"date","attrib":{"date":"1999-10-21"},"text":"October 21, 1999","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7771949a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–5/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a comprehensive plan for the long-range protection and management of the Conservation Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7771949b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–5/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" transmit the plan to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7771949c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–5/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Natural Resources of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7771949d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–5/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Resources of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7771949e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–5/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7771949f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–5/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall describe the appropriate uses and management of the Conservation Area in accordance with this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777194a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–5/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may incorporate appropriate decisions contained in any management or activity plan for the area completed prior to ","children":[{"tag":"date","attrib":{"date":"1999-10-21"},"text":"October 21, 1999","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777194a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–5/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may incorporate appropriate wildlife habitat management plans or other plans prepared for the land within or adjacent to the Conservation Area prior to ","children":[{"tag":"date","attrib":{"date":"1999-10-21"},"text":"October 21, 1999","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777194a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–5/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be prepared in close consultation with appropriate Federal, State, county, and local agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777194a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–5/f/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may use information developed prior to ","children":[{"tag":"date","attrib":{"date":"1999-10-21"},"text":"October 21, 1999","children":[],"tail":", in studies of the land within or adjacent to the Conservation Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777194a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–5/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary revisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make revisions to the boundary of the Conservation Area following acquisition of land necessary to accomplish the purposes for which the Conservation Area was designated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id777194a5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/76/s7"},"text":"Pub. L. 106–76, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-21"},"text":"Oct. 21, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1129"},"text":"113 Stat. 1129","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/128/s3"},"text":"Pub. L. 108–128, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-17"},"text":"Nov. 17, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1356"},"text":"117 Stat. 1356","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id777194a6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id777194a7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id777194a8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Land Policy and Management Act of 1976, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579"},"text":"Pub. L. 94–579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2743"},"text":"90 Stat. 2743","children":[],"tail":", which is classified principally to chapter 35 (§ 1701 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id777194a9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/128"},"text":"Pub. L. 108–128","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id777194aa-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id777194ab-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Resources of House of Representatives changed to Committee on Natural Resources of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
