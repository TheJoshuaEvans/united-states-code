{"tag":"section","attrib":{"id":"id799622ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109"},"text":null,"children":[{"tag":"num","attrib":{"value":"2109"},"text":"§ 2109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id799622ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative and coordinating requirements for implementation of programs, etc.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In implementing this chapter, the Secretary shall, to the maximum extent practicable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id799622ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work through, cooperate with, and assist State foresters or equivalent State officials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799622af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage cooperation and coordination between State foresters or equivalent State officials and other State agencies that manage renewable natural resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799622b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use and encourage cooperators under this chapter to use, private agencies, consult­ants, organizations, firms, and individuals to furnish necessary materials and services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799622b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote effectiveness and economy by coordinating the direct actions and assistance authorized under this chapter with related programs the Secretary administers, and with cooperative programs of other agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799622b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Money appropriated under this chapter shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799622b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation requirements for implementation of programs, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Requirements for the development of State forest resources programs and State participation in management assistance, planning assistance, and technology implementation, the apportionment of funds among States participating under this chapter, the administrative expenses in connection with activities and programs under this chapter, and the amounts to be expended by the Secretary to assist non-State cooperators under this chapter, shall be determined by the Secretary in consultation with a committee of not less than five State foresters or equivalent State officials selected by a majority of the State foresters or equivalent State officials from States participating in programs under this chapter. However, the Secretary need not consult with such committee regarding funds to be expended under emergency conditions that the Secretary may determine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799622b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id799622b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “United States” and “State” shall include each of the several States, the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands of the United States, the Commonwealth of the Northern Mariana Islands, the Federated States of Micronesia, the Republic of the Marshall Islands, the Republic of Palau, and the territories and possessions of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799622b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “forest resources” shall include esthetics, fish and wildlife, forage, outdoor recreation opportunities, timber, and water; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799622b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “urban forestry” means the planning, establishment, protection, and management of trees and associated plants, individually, in small groups, or under forest conditions within cities, their suburbs, and towns.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799622b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may prescribe rules and regulations, as the Secretary deems appropriate, to implement the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799622b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Granting, etc., authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to make grants, agreements, contracts, and other arrangements the Secretary deems necessary to implement this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799622ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of statutory provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This chapter shall be construed as supplementing all other laws relating to the Department of Agriculture and shall not be construed as limiting or repealing any existing law or authority of the Secretary, except as specifically cited in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2111"},"text":"section 2111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799622bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2109/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the authority provided elsewhere in this chapter, the Secretary may provide assistance to other countries with respect to the activities described in paragraphs (1) through (10) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2102/b"},"text":"section 2102(b) of this title","children":[],"tail":", paragraphs (1) through (5) of section 2104(b) "},{"tag":"ref","attrib":{"idref":"fn002714"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002714"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, and paragraphs (1) through (3) of "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2105/b"},"text":"section 2105(b) of this title","children":[],"tail":". For the purposes of providing assistance to other countries under this subsection, the term “non-Federal forest land” shall mean any forest land and related renewable natural resources in such countries. In providing the assistance authorized under this subsection, the Secretary shall coordinate with other Federal officials, departments, agencies, or international organizations, as the President may direct. The references to “State foresters or equivalent State officials” in this chapter shall not apply to the assistance provided by the Secretary to other countries under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id799622bc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/313/s13"},"text":"Pub. L. 95–313, § 13","children":[],"tail":", formerly § 10, "},{"tag":"date","attrib":{"date":"1978-07-01"},"text":"July 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/373"},"text":"92 Stat. 373","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/513/tVI/s611/b/3"},"text":"Pub. L. 101–513, title VI, § 611(b)(3)","children":[],"tail":", formerly § 607(b)(3), "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2072"},"text":"104 Stat. 2072","children":[],"tail":", renumbered § 611(b)(3), "},{"tag":"ref","attrib":{"href":"/us/pl/102/574/s2/a/1"},"text":"Pub. L. 102–574, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4593"},"text":"106 Stat. 4593","children":[],"tail":"; renumbered § 13 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXII"},"text":"Pub. L. 101–624, title XII","children":[],"tail":", §§ 1215(1), 1224(3), "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3525"},"text":"104 Stat. 3525","children":[],"tail":", 3542; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVIII/s8004"},"text":"Pub. L. 110–234, title VIII, § 8004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1284"},"text":"122 Stat. 1284","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VIII, § 8004, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2045.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id799622bd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id799622be-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id799622bf-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2104/b"},"text":"Section 2104(b) of this title","children":[],"tail":", referred to in subsec. (h), was in the original a reference to section 7(b), meaning "},{"tag":"ref","attrib":{"href":"/us/pl/95/313/s7/b"},"text":"section 7(b) of Pub. L. 95–313","children":[],"tail":", which has been translated as reading "},{"tag":"ref","attrib":{"href":"/us/pl/95/313/s8/b"},"text":"section 8(b) of Pub. L. 95–313","children":[],"tail":" as the probable intent of Congress. "},{"tag":"ref","attrib":{"href":"/us/pl/95/313/s7/b"},"text":"Section 7(b) of Pub. L. 95–313","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2103c"},"text":"section 2103c of this title","children":[],"tail":", does not contain pars. (1) to (5)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id799622c0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id799622c1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/313/s13"},"text":"section 13 of Pub. L. 95–313","children":[],"tail":" was renumbered section 16 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2111"},"text":"section 2111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id799622c2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s8004"},"text":"Pub. L. 110–246, § 8004","children":[],"tail":", substituted “the Federated States of Micronesia, the Republic of the Marshall Islands, the Republic of Palau,” for “the Trust Territory of the Pacific Islands,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1224/3"},"text":"Pub. L. 101–624, § 1224(3)","children":[],"tail":", made technical amendment to reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2111"},"text":"section 2111 of this title","children":[],"tail":" to reflect renumbering of corresponding section of original act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/513"},"text":"Pub. L. 101–513","children":[],"tail":", which directed amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/95/313/s12"},"text":"section 12 of Pub. L. 95–313","children":[],"tail":" by adding a new subsec. (h), was executed to this section to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id799622c3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id799622c4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
