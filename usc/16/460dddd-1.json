{"tag":"section","attrib":{"id":"id780f0db8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"460dddd–1"},"text":"§ 460dddd–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management of Recreation Area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id780f0db9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall administer the Recreation Area—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780f0dba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner that conserves, protects, and enhances the purposes for which the Recreation Area is established; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780f0dbb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in accordance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780f0dbc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780f0dbd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"43 U.S.C. 1701","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780f0dbe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other applicable laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780f0dbf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall allow only uses of the Recreation Area that are consistent with the purposes for which the Recreation Area is established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780f0dc0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management Plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780f0dc1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 5 years after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretary shall develop a comprehensive management plan for the long-term protection and management of the Recreation Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780f0dc2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Management Plan shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780f0dc3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the appropriate uses and management of the Recreation Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780f0dc4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be developed with extensive public input;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780f0dc5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into consideration any information developed in studies of the land within the Recreation Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780f0dc6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be developed fully consistent with the settlement agreement entered into on ","children":[{"tag":"date","attrib":{"date":"2017-01-13"},"text":"January 13, 2017","children":[],"tail":", in the case in the United States District Court for the District of Utah styled “Southern Utah Wilderness Alliance, et al. v. U.S. Department of the Interior, et al.” and numbered 2:12–cv–257 DAK."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780f0dc7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motorized vehicles; new roads","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780f0dc8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motorized vehicles","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as needed for emergency response or administrative purposes, the use of motorized vehicles in the Recreation Area shall be permitted only on roads and motorized routes designated in the Management Plan for the use of motorized vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780f0dc9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New roads","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No new permanent or temporary roads or other motorized vehicle routes shall be constructed within the Recreation Area after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780f0dca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing roads","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780f0dcb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Necessary maintenance or repairs to existing roads designated in the Management Plan for the use of motorized vehicles, including necessary repairs to keep existing roads free of debris or other safety hazards, shall be permitted after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", consistent with the requirements of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780f0dcc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection prevents the Secretary from rerouting an existing road or trail to protect Recreation Area resources from degradation or to protect public safety, as determined to be appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780f0dcd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grazing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780f0dce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The grazing of livestock in the Recreation Area, if established before ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", shall be allowed to continue, subject to such reasonable regulations, policies, and practices as the Secretary considers to be necessary in accordance with—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780f0dcf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicable law (including regulations); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780f0dd0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purposes of the Recreation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780f0dd1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inventory","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 5 years after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretary, in collaboration with any affected grazing permittee, shall carry out an inventory of facilities and improvements associated with grazing activities in the Recreation Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780f0dd2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cold War sites","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall manage the Recreation Area in a manner that educates the public about Cold War and historic uranium mine sites in the Recreation Area, subject to such terms and conditions as the Secretary considers necessary to protect public health and safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780f0dd3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incorporation of acquired land and interests","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any land or interest in land located within the boundary of the Recreation Area that is acquired by the United States after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id780f0dd4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" become part of the Recreation Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780f0dd5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be managed in accordance with applicable laws, including as provided in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780f0dd6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to valid existing rights, all Federal land within the Recreation Area, including any land or interest in land that is acquired by the United States within the Recreation Area after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", is withdrawn from—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id780f0dd7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entry, appropriation, or disposal under the public land laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780f0dd8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" location, entry, and patent under the mining laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780f0dd9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operation of the mineral leasing, mineral materials, and geothermal leasing laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780f0dda-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study of nonmotorized recreation opportunities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretary, in consultation with interested parties, shall conduct a study of nonmotorized recreation trail opportunities, including bicycle trails, within the Recreation Area, consistent with the purposes of the Recreation Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780f0ddb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dddd–1/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into a cooperative agreement with the State in accordance with section 307(b) of the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1737/b"},"text":"43 U.S.C. 1737(b)","children":[],"tail":") and other applicable laws to provide for the protection, management, and maintenance of the Recreation Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id780f0ddc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tI/s1222"},"text":"Pub. L. 116–9, title I, § 1222","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/668"},"text":"133 Stat. 668","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id780f0ddd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id780f0dde-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id780f0ddf-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Land Policy and Management Act of 1976, referred to in subsec. (a)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579"},"text":"Pub. L. 94–579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2743"},"text":"90 Stat. 2743","children":[],"tail":", which is classified principally to chapter 35 (§ 1701 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
