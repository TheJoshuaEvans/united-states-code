{"tag":"section","attrib":{"id":"id79986ca1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2202b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2202b"},"text":"§ 2202b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The maximum payment made under the emergency conservation program to an agricultural producer under sections 2201 and 2202 of this title shall not exceed $500,000.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79986ca2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/334/tIV/s402B"},"text":"Pub. L. 95–334, title IV, § 402B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII/s2403/c"},"text":"Pub. L. 115–334, title II, § 2403(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4572"},"text":"132 Stat. 4572","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
