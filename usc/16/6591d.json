{"tag":"section","attrib":{"id":"id7a147abf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d"},"text":null,"children":[{"tag":"num","attrib":{"value":"6591d"},"text":"§ 6591d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wildfire resilience projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a147ac0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Hazardous fuels reduction projects, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6511/2"},"text":"section 6511(2) of this title","children":[],"tail":" may be—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a147ac1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carried out in accordance with subsections (b), (c), and (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6512"},"text":"section 6512 of this title","children":[],"tail":" and sections 6514 and 6515 of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a147ac2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considered an action categorically excluded from the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Public Law 91–190","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a147ac3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exempt from the special administrative review process under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6515"},"text":"section 6515 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a147ac4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaborative restoration project","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a147ac5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project referred to in subsection (a) is a project to carry out forest restoration treatments that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a147ac6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximizes the retention of old-growth and large trees, as appropriate for the forest type, to the extent that the trees promote stands that are resilient to insects and disease, and reduce the risk or extent of, or increase the resilience to, wildfires;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a147ac7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considers the best available scientific information to maintain or restore the ecological integrity, including maintaining or restoring structure, function, composition, and connectivity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a147ac8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is developed and implemented through a collaborative process that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a147ac9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes multiple interested persons representing diverse interests; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a147aca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a147acb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/b/1/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is transparent and nonexclusive; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a147acc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/b/1/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the requirements for a resource advisory committee under subsections (c) through (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7125"},"text":"section 7125 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a147acd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A project under this subsection may carry out part of a proposal that complies with the eligibility requirements of the Collaborative Forest Landscape Restoration Program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7303/b"},"text":"section 7303(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a147ace-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a147acf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project size","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A project under this section may not exceed 3000 acres.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a147ad0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project under this section shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a147ad1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prioritized within the wildland-urban interface;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a147ad2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If located outside the wildland-urban interface, limited to areas within Condition Classes 2 or 3 in Fire Regime Groups I, II, or III that contain very high wildfire hazard potential; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a147ad3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Limited to areas designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6591a/b"},"text":"section 6591a(b) of this title","children":[],"tail":" as of "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"March 23, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a147ad4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Roads","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a147ad5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permanent roads","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a147ad6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A project under this section shall not include the establishment of permanent roads.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a147ad7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing roads","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may carry out necessary maintenance and repairs on existing permanent roads for the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a147ad8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary roads","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall decommission any temporary road constructed under a project under this section not later than 3 years after the date on which the project is completed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a147ad9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extraordinary circumstances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall apply the extraordinary circumstances procedures under section 220.6 of title 36, code of Federal regulations ","children":[{"tag":"ref","attrib":{"idref":"fn002831"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002831"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Code of Federal Regulations”."}],"tail":" (or successor regulations), when using the categorical exclusion under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a147ada-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section does not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a147adb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a component of the National Wilderness Preservation System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a147adc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Federal land on which, by Act of Congress or Presidential proclamation, the removal of vegetation is restricted or prohibited;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a147add-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a congressionally designated wilderness study area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a147ade-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an area in which activities under subsection (a) would be inconsistent with the applicable land and resource management plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a147adf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forest management plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All projects and activities carried out under this section shall be consistent with the land and resource management plan established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1604"},"text":"section 1604 of this title","children":[],"tail":" for the unit of the National Forest System containing the projects and activities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a147ae0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public notice and scoping","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct public notice and scoping for any project or action proposed in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a147ae1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a147ae2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prepare an annual report on the use of categorical exclusions under this section that includes a description of all acres (or other appropriate unit) treated through projects carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a147ae3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2018-03-23"},"text":"March 23, 2018","children":[],"tail":", and each year thereafter, the Secretary shall submit the reports required under paragraph (1) to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a147ae4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture, Nutrition, and Forestry of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a147ae5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Environment and Public Works of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a147ae6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a147ae7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Natural Resources of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a147ae8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6591d/g/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Government Accountability Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a147ae9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/148/tVI/s605"},"text":"Pub. L. 108–148, title VI, § 605","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dO/tII/s202"},"text":"Pub. L. 115–141, div. O, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1062"},"text":"132 Stat. 1062","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a147aea-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a147aeb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a147aec-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6511/2"},"text":"Section 6511(2) of this title","children":[],"tail":", referred to in subsec. (a), was in the original “the Healthy Forests Restoration Act of 2003 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6511/2"},"text":"16 U.S.C. 6511(2)","children":[],"tail":")” and was translated as referring to section 101(2) of that Act, which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6511/2"},"text":"section 6511(2) of this title","children":[],"tail":" and defines “authorized hazardous fuel reduction project”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Public Law 91–190","children":[],"tail":", referred to in subsec. (a)(2), is "},{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", known as the National Environmental Policy Act of 1969, which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"2018-03-23"},"text":"March 23, 2018","children":[],"tail":", referred to in subsec. (c)(2)(C), was in the original “the date of enactment of this Act” and was translated as meaning the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":", which enacted this section, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
