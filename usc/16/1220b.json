{"tag":"section","attrib":{"id":"id78f17e12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1220b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1220b"},"text":"§ 1220b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obsolete ships available; number; equitable administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A State may apply for more than one obsolete ship under this chapter. The Secretary shall, however, taking into account the number of obsolete ships which may be or become available for transfer under this chapter, administer this chapter in an equitable manner with respect to the various States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78f17e13-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/402/s5"},"text":"Pub. L. 92–402, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-08-22"},"text":"Aug. 22, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/618"},"text":"86 Stat. 618","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/623/tII/s207/1"},"text":"Pub. L. 98–623, title II, § 207(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3397"},"text":"98 Stat. 3397","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78f17e14-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78f17e15-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78f17e16-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/623"},"text":"Pub. L. 98–623","children":[],"tail":" substituted “obsolete ships” for “Liberty ships” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
