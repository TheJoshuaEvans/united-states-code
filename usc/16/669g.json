{"tag":"section","attrib":{"id":"id786bfaf2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669g"},"text":null,"children":[{"tag":"num","attrib":{"value":"669g"},"text":"§ 669g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of projects; expenditures for management of wildlife areas and resources","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id786bfaf3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Maintenance of wildlife-restoration projects established under the provisions of this chapter shall be the duty of the States in accordance with their respective laws. Beginning ","children":[{"tag":"date","attrib":{"date":"1945-07-01"},"text":"July 1, 1945","children":[],"tail":", the term “wildlife-restoration project”, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s669a"},"text":"section 669a of this title","children":[],"tail":", shall include maintenance of completed projects. Notwithstanding any other provisions of this chapter, funds apportioned to a State under this chapter may be expended by the State for management (exclusive of law enforcement) of wildlife areas and resources. Funds from the Wildlife Conservation and Restoration Account may be used for a wildlife conservation education program, except that no such funds may be used for education efforts, projects, or programs that promote or encourage opposition to the regulated taking of wildlife."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id786e6bf4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expenditures for Management of Wildlife Areas and Resources.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id786e6bf5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), each State may use the funds apportioned to it under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s669c/c"},"text":"section 669c(c) of this title","children":[],"tail":" to pay up to 75 per centum of the costs of a hunter safety program and the operation and maintenance of public target ranges."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id786e6bf6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding the limitation described in paragraph (1), a State may pay up to 90 percent of the cost of acquiring land for, expanding, or constructing a public target range.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id786e6bf7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669g/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Non-federal share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The non-Federal share of such costs may be derived from license fees paid by hunters, but not from other Federal grant programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id786e6bf8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s669g/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall issue not later than the 120th day after the effective date of this subsection such regulations as he deems advisable relative to the criteria for the establishment of hunter safety programs and public target ranges under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id786e6bf9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-02/ch899/s8"},"text":"Sept. 2, 1937, ch. 899, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/919"},"text":"50 Stat. 919","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-07-24/ch605/s2"},"text":"July 24, 1946, ch. 605, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/656"},"text":"60 Stat. 656","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1955-08-12/ch861/s2"},"text":"Aug. 12, 1955, ch. 861, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/698"},"text":"69 Stat. 698","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/503/tI/s102"},"text":"Pub. L. 91–503, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-23"},"text":"Oct. 23, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1100"},"text":"84 Stat. 1100","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/558/tI/s102/a"},"text":"Pub. L. 92–558, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-25"},"text":"Oct. 25, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1173"},"text":"86 Stat. 1173","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/408/tI/s111/c"},"text":"Pub. L. 106–408, title I, § 111(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1766"},"text":"114 Stat. 1766","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/553/s1/a/2/tIX/s902/g"},"text":"Pub. L. 106–553, § 1(a)(2) [title IX, § 902(g)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2762"},"text":"114 Stat. 2762","children":[],"tail":", 2762A–124; "},{"tag":"ref","attrib":{"href":"/us/pl/116/17/s4/b"},"text":"Pub. L. 116–17, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-05-10"},"text":"May 10, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/867"},"text":"133 Stat. 867","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dP/tV/s501/e"},"text":"Pub. L. 116–94, div. P, title V, § 501(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3193"},"text":"133 Stat. 3193","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id786e6bfa-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id786e6bfb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id786e6bfc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The effective date of this subsection, referred to in subsec. (b)(4), probably means ","children":[{"tag":"date","attrib":{"date":"1970-10-23"},"text":"Oct. 23, 1970","children":[],"tail":", the date of approval of "},{"tag":"ref","attrib":{"href":"/us/pl/91/503"},"text":"Pub. L. 91–503","children":[],"tail":", which added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id786e6bfd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s501/e/1"},"text":"Pub. L. 116–94, § 501(e)(1)","children":[],"tail":", struck out “and public relations” after “(exclusive of law enforcement”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/17"},"text":"Pub. L. 116–17","children":[],"tail":" inserted subsec. heading, designated first, second, and third sentences of existing provisions as pars. (1), (3), and (4), respectively, and inserted par. headings, in par. (1), substituted “Except as provided in paragraph (2), each State” for “Each State” and “operation” for “construction, operation,”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s501/e/2"},"text":"Pub. L. 116–94, § 501(e)(2)","children":[],"tail":", struck out “, as a part of such program” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/553"},"text":"Pub. L. 106–553","children":[],"tail":" inserted at end “Funds from the Wildlife Conservation and Restoration Account may be used for a wildlife conservation education program, except that no such funds may be used for education efforts, projects, or programs that promote or encourage opposition to the regulated taking of wildlife.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/408"},"text":"Pub. L. 106–408","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t16/s669c/c"},"text":"section 669c(c) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t16/s669c/b"},"text":"section 669c(b) of this title","children":[],"tail":"” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/558"},"text":"Pub. L. 92–558","children":[],"tail":" substituted “public target ranges” for “public outdoor target ranges” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/503"},"text":"Pub. L. 91–503","children":[],"tail":" designated existing provisions as subsec. (a), struck out the 25 percent limitation on the use of Federal funds for wildlife restoration projects and the 30 percent limitation on the use of Federal funds for the management of wild life areas and resources, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1955—Act ","children":[{"tag":"date","attrib":{"date":"1955-08-12"},"text":"Aug. 12, 1955","children":[],"tail":", permitted expenditure of funds for management of wildlife areas and resource."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1946—Act ","children":[{"tag":"date","attrib":{"date":"1946-07-24"},"text":"July 24, 1946","children":[],"tail":", inserted proviso defining “wildlife-restoration project”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id786e6bfe-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id786e6bff-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1972 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/558/tI/s102/b"},"text":"Pub. L. 92–558, title I, § 102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-25"},"text":"Oct. 25, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1173"},"text":"86 Stat. 1173","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/92/558/tI/s102/b"},"text":"“The amendments made by subsection (a) of this section [amending this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1972-10-25"},"text":"Oct. 25, 1972","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
