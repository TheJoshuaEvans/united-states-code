{"tag":"section","attrib":{"id":"id7765ae33-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"410aaa–6"},"text":"§ 410aaa–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Death Valley National Park Advisory Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7765ae34-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish an Advisory Commission of no more than fifteen members, to advise the Secretary concerning the development and implementation of a new or revised comprehensive management plan for Death Valley National Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7765ae35-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7765ae36-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–6/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The advisory commission shall include an elected official for each County within which any part of the park is located, a representative of the owners of private properties located within or immediately adjacent to the park, and other members representing persons actively engaged in grazing and range management, mineral exploration and development, and persons with expertise in relevant fields, including geology, biology, ecology, law enforcement, and the protection and management of National Park resources and values.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7765ae37-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–6/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Vacancies in the advisory commission shall be filled by the Secretary so as to maintain the full diversity of views required to be represented on the advisory commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7765ae38-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–6/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 shall apply to the procedures and activities of the advisory commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7765ae39-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–6/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The advisory commission shall cease to exist ten years after the date of its establishment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7765ae3a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/tIII/s307"},"text":"Pub. L. 103–433, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4487"},"text":"108 Stat. 4487","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/84"},"text":"Pub. L. 117–286, § 4(a)(84)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4315"},"text":"136 Stat. 4315","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7765ae3b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7765ae3c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7765ae3d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Chapter 10 of title 5” for “The Federal Advisory Committee Act”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
