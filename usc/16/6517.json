{"tag":"section","attrib":{"id":"id7a0fbfbc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6517"},"text":null,"children":[{"tag":"num","attrib":{"value":"6517"},"text":"§ 6517.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of subchapter","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a0fbfbd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6517/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter affects, or otherwise biases, the use by the Secretary of other statutory or administrative authority (including categorical exclusions adopted to implement the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.)) to conduct a hazardous fuel reduction project on Federal land (including Federal land identified in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6512/d"},"text":"section 6512(d) of this title","children":[],"tail":") that is not conducted using the process authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6514"},"text":"section 6514 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0fbfbe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6517/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Forest System","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For projects and activities of the National Forest System other than authorized hazardous fuel reduction projects, nothing in this subchapter affects, or otherwise biases, the notice, comment, and appeal procedures for projects and activities of the National Forest System contained in part 215 of title 36, Code of Federal Regulations, or the consideration or disposition of any legal action brought with respect to the procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0fbfbf-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/148/tI/s107"},"text":"Pub. L. 108–148, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-03"},"text":"Dec. 3, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1900"},"text":"117 Stat. 1900","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a0fbfc0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a0fbfc1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a0fbfc2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
