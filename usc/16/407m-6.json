{"tag":"section","attrib":{"id":"id773f88a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s407m–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"407m–6"},"text":"§ 407m–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums, but not more than $200,000, as may be necessary for acquisition of the land described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s407m–3"},"text":"section 407m–3 of this title","children":[],"tail":": "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the Secretary of the Interior shall not obligate or expend any moneys herein authorized to be appropriated for acquisition of the land unless and until commitments are obtained for donations in an amount which in the judgment of the Secretary is sufficient to provide a replica of the Graff House in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s407m–4"},"text":"section 407m–4 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id773f88a9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/477/s4"},"text":"Pub. L. 88–477, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-21"},"text":"Aug. 21, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/587"},"text":"78 Stat. 587","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id773f88aa-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id773f88ab-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id773f88ac-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as a part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-28/ch687"},"text":"act June 28, 1948, ch. 687","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/1061"},"text":"62 Stat. 1061","children":[],"tail":", as amended, which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
