{"tag":"section","attrib":{"id":"id77df4a94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hh–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"460hh–6"},"text":"§ 460hh–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated such sums as may be necessary to carry out the purposes of this subchapter, but not to exceed $1,600,000 for the acquisition of lands and interests in lands, and $4,567,000 for development.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77df4a95-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/235/s7"},"text":"Pub. L. 94–235, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-03-17"},"text":"Mar. 17, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/237"},"text":"90 Stat. 237","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
