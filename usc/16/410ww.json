{"tag":"section","attrib":{"id":"id7760f3d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww"},"text":null,"children":[{"tag":"num","attrib":{"value":"410ww"},"text":"§ 410ww.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7760f3d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established, as a unit of the National Park System in the State of Ohio, the Dayton Aviation Heritage National Historical Park (hereinafter in this subchapter referred to as the “park”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7760f3d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Areas included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The park shall consist of the following sites, as generally depicted on a map entitled “Dayton Aviation Heritage National Historical Park”, numbered 362–80,010 and dated ","children":[{"tag":"date","attrib":{"date":"2000-09-01"},"text":"September 1, 2000","children":[],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7760f3d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A core parcel in Dayton, Ohio, which shall consist of the Wright Cycle Company building, Hoover Block, and lands between.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f3d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Setzer building property (also known as the Aviation Trail building property), Dayton, Ohio.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f3d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The residential properties at 26 South Williams Street and at 30 South Williams Street, Dayton, Ohio.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f3d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Huffman Prairie Flying Field, located at Wright-Patterson Air Force Base, Ohio.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f3d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Wright 1905 Flyer III and Wright Hall, including constructed additions and attached structures, known collectively as the John W. Berry, Sr. Wright Brothers National Museum, Dayton, Ohio.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f3da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Paul Laurence Dunbar State Memorial, Dayton, Ohio.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7760f3db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional sites","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the sites described in subsection (b), the park shall consist of the following sites, as generally depicted on a map titled “Dayton Aviation Heritage National Historical Park”, numbered 362/80,013 and dated May 2008:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7760f3dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hawthorn Hill, Oakwood, Ohio.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f3dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Wright Company factory and associated land and buildings, Dayton, Ohio.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7760f3de-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/419/tI/s101"},"text":"Pub. L. 102–419, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-16"},"text":"Oct. 16, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2141"},"text":"106 Stat. 2141","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/356/s2/a"},"text":"Pub. L. 106–356, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-24"},"text":"Oct. 24, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1391"},"text":"114 Stat. 1391","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVII/s7117/a"},"text":"Pub. L. 111–11, title VII, § 7117(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1204"},"text":"123 Stat. 1204","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dB/tXXVIII/s2832"},"text":"Pub. L. 114–328, div. B, title XXVIII, § 2832","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2740"},"text":"130 Stat. 2740","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7760f3df-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7760f3e0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7760f3e1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" substituted “National Museum” for “Aviation Center”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11"},"text":"Pub. L. 111–11","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/356"},"text":"Pub. L. 106–356","children":[],"tail":" amended heading and text of subsec. (b) generally. Prior to amendment, text read as follows: “The park shall consist of the following sites, as generally depicted on a map entitled ‘Proposed Dayton Aviation Heritage National Historical Park’, numbered NHP–DAH 80,000, and dated February 1992:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) A core parcel in Dayton, Ohio, which shall consist of the Wright Cycle Company Building, Hoover Block, and lands between.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Huffman Prairie Flying Field, Wright-Patterson Air Force Base, Ohio.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) The Wright 1905 Flyer and Wright Hall, Dayton, Ohio.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) The Paul Laurence Dunbar home, Dayton, Ohio.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7760f3e2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id7760f3e3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/356/s1"},"text":"Pub. L. 106–356, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-24"},"text":"Oct. 24, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1391"},"text":"114 Stat. 1391","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/356/s1"},"text":"“This Act [amending this section and sections 410ww–6 and 410ww–8 of this title] may be cited as the ‘Dayton Aviation Heritage Preservation Amendments Act of 2000’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7760f3e4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/419/s1"},"text":"Pub. L. 102–419, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-16"},"text":"Oct. 16, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2141"},"text":"106 Stat. 2141","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/419/s1"},"text":"“This Act [enacting this subchapter] may be cited as the ‘Dayton Aviation Heritage Preservation Act of 1992’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7760f3e5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purposes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/419/s2"},"text":"Pub. L. 102–419, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-16"},"text":"Oct. 16, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2141"},"text":"106 Stat. 2141","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/419/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The purposes of this Act [this subchapter] are—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish a unit of the National Park System in Dayton, Ohio, consisting of certain lands and structures associated with Wilbur and Orville Wright and the early development of aviation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to create partnerships among Federal, State, and local governments and the private sector to preserve, enhance, and interpret for present and future generations the historic and cultural structures, districts, and artifacts in Dayton and the Miami Valley in the State of Ohio, which are associated with the Wright brothers, the invention and development of aviation, or the life and works of Paul Laurence Dunbar, and which, as a whole, represent a nationally significant resource.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
