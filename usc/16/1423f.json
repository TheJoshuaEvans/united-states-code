{"tag":"section","attrib":{"id":"id792f9926-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1423f"},"text":"§ 1423f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of actions taken by the Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id792f9927-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall take all necessary actions to implement the decisions and determinations of the Commission under paragraph 7 of article 8 of the Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792f9928-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1423f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taking limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the date on which the Secretary receives notice of the determination of the Commission of an annual taking limit, or of the adoption by the Commission of other restriction on the taking of polar bears for subsistence purposes, the Secretary shall publish a notice in the Federal Register announcing the determination or restriction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id792f9929-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522/tV/s507"},"text":"Pub. L. 92–522, title V, § 507","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/479/tIX/s902/a"},"text":"Pub. L. 109–479, title IX, § 902(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3664"},"text":"120 Stat. 3664","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
