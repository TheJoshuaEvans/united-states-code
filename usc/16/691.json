{"tag":"section","attrib":{"id":"id787598a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s691"},"text":null,"children":[{"tag":"num","attrib":{"value":"691"},"text":"§ 691.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cheyenne Bottoms Migratory Bird Refuge; location; acquisition of land","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to acquire by purchase, gift, or lease not to exceed twenty thousand acres of land in what is known as the Cheyenne Bottoms, in Barton County, Kansas, or, in lieu of purchase, to compensate any owner for any damage sustained by reason of submergence of his lands.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id787598aa-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-12/ch469/s1"},"text":"June 12, 1930, ch. 469, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/579"},"text":"46 Stat. 579","children":[],"tail":"; 1939 Reorg. Plan No. II, § 4(f), eff. "},{"tag":"date","attrib":{"date":"1939-07-01"},"text":"July 1, 1939","children":[],"tail":", 4 F.R. 2731, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1433"},"text":"53 Stat. 1433","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id787598ab-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id787598ac-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id787598ad-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reorg. Plan No. II of 1939, set out in the Appendix to Title 5, Government Organization and Employees, transferred functions of Secretary of Agriculture relating to conservation of wildlife, game, and migratory birds to Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
