{"tag":"section","attrib":{"id":"id787cc3e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s698p"},"text":null,"children":[{"tag":"num","attrib":{"value":"698p"},"text":"§ 698p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated administration and interpretation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any properties of historic interest acquired under section 698","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title shall become part of the Preserve established under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s698n"},"text":"section 698n of this title","children":[],"tail":". The Secretary shall administer such properties in accordance with a plan that integrates the administration and interpretation of the ecological values of the Preserve and the historical values of the sites so acquired and the historical features of Fort Caroline. Such administration and interpretation shall be conducted through the facilities and staff of Fort Caroline National Memorial consistent with "},{"tag":"ref","attrib":{"href":"/us/act/1950-09-21/s2"},"text":"section 2 of the Act of September 21, 1950","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/64/897"},"text":"64 Stat. 897","children":[],"tail":")."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id787cc3e6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/249/tII/s203"},"text":"Pub. L. 100–249, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-02-16"},"text":"Feb. 16, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/15"},"text":"102 Stat. 15","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id787cc3e7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id787cc3e8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id787cc3e9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-21/s2"},"text":"Section 2 of the Act of September 21, 1950","children":[],"tail":", referred to in text, is section 2 of "},{"tag":"ref","attrib":{"href":"/us/act/1950-09-21/ch973"},"text":"act Sept. 21, 1950, ch. 973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/897"},"text":"64 Stat. 897","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
