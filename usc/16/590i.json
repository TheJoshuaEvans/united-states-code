{"tag":"section","attrib":{"id":"id78569d99-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s590i"},"text":null,"children":[{"tag":"num","attrib":{"value":"590i"},"text":"§ 590i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surveys and investigations; publication of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to conduct surveys, investigations, and research relating to the conditions and factors affecting, and methods of accomplishing most effectively, the policy and purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s590g/a"},"text":"section 590g(a) of this title","children":[],"tail":". Notwithstanding any provision of existing law, the Secretary is authorized to make public such information as he deems necessary to carry out the provisions of this chapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78569d9a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-04-27/ch85/s9"},"text":"Apr. 27, 1935, ch. 85, § 9","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1936-02-29/ch104/s1"},"text":"Feb. 29, 1936, ch. 104, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1150"},"text":"49 Stat. 1150","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1937-06-28/ch395/s2"},"text":"June 28, 1937, ch. 395, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/329"},"text":"50 Stat. 329","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/375/tI/s103/c"},"text":"Pub. L. 97–375, title I, § 103(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-21"},"text":"Dec. 21, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1819"},"text":"96 Stat. 1819","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attr