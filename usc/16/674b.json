{"tag":"section","attrib":{"id":"id787597ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s674b"},"text":null,"children":[{"tag":"num","attrib":{"value":"674b"},"text":"§ 674b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" White Horse Hill National Game Preserve; acquisition of additional lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to acquire, by purchase or otherwise, after ","children":[{"tag":"date","attrib":{"date":"1932-07-01"},"text":"July 1, 1932","children":[],"tail":", an area of land not to exceed three thousand acres, at an average cost of not more than $10 per acre, with the improvements thereon, situated on the east and south of said preserve as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s674a"},"text":"section 674a of this title","children":[],"tail":", within sections 10, 11, 12, 13, 14, 15, 22, 23, and 24, township 152 north, range 65 west, fifth principal meridian, said lands, upon acquisition by the United States, to become a part of the White Horse Hill National Game Preserve."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id787597f0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1931-03-03/ch439/s2"},"text":"Mar. 3, 1931, ch. 439, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/1509"},"text":"46 Stat. 1509","children":[],"tail":"; 1939 Reorg. Plan No. II, § 4(f), eff. "},{"tag":"date","attrib":{"date":"1939-07-01"},"text":"July 1, 1939","children":[],"tail":", 4 F.R. 2731, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1433"},"text":"53 Stat. 1433","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dP/tIV/s402/b"},"text":"Pub. L. 116–94, div. P, title IV, § 402(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3191"},"text":"133 Stat. 3191","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id787597f1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id787597f2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id787597f3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" substituted “White Horse Hill National Game Preserve” for “Sullys Hill National Game Preserve” in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id787597f4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id787597f5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reorg. Plan No. II of 1939, set out in the Appendix to Title 5, Government Organization and Employees, transferred functions of Secretary of Agriculture relating to conservation of wildlife, game, and migratory birds to Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
