{"tag":"section","attrib":{"id":"id77c50c57-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460m–14"},"text":null,"children":[{"tag":"num","attrib":{"value":"460m–14"},"text":"§ 460m–14.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the acquisition of lands and interests in lands, there are authorized to be appropriated not more than $39,948,000. For development of the national river, there are authorized to be appropriated not to exceed $9,371,000.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77c50c58-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/237/s7"},"text":"Pub. L. 92–237, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-03-01"},"text":"Mar. 1, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/46"},"text":"86 Stat. 46","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/578/tI/s101/3"},"text":"Pub. L. 94–578, title I, § 101(3)","children":[],"tail":", title III, § 310, "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2732"},"text":"90 Stat. 2732","children":[],"tail":", 2736; "},{"tag":"ref","attrib":{"href":"/us/pl/95/625/tII/s201/2"},"text":"Pub. L. 95–625, title II, § 201(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3473"},"text":"92 Stat. 3473","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77c50c59-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77c50c5a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77c50c5b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625"},"text":"Pub. L. 95–625","children":[],"tail":" increased land acquisition appropriations authorization to $39,948,000 from $30,071,500."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/578"},"text":"Pub. L. 94–578","children":[],"tail":" substituted “$30,071,500” for “$16,115,000” in provision covering the acquisition of lands and interests in lands and substituted “For development of the national river, there are authorized to be appropriated not to exceed $9,371,000” for “For development of the national river, there are authorized to be appropriated not more than $283,000 in fiscal year 1974; $2,923,000 in fiscal year 1975; $3,643,000 in fiscal year 1976; $1,262,000 in fiscal year 1977; and $1,260,000 in fiscal year 1978. The sums appropriated each year shall remain available until expended”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
