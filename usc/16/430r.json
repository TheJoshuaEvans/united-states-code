{"tag":"section","attrib":{"id":"id779570f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430r"},"text":null,"children":[{"tag":"num","attrib":{"value":"430r"},"text":"§ 430r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall have the power to make all needful rules and regulations for the care of the park, and for the establishment and marking of lines of battle and other historical features of the park.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id779570fa-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-21/ch694/s9"},"text":"June 21, 1934, ch. 694, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1200"},"text":"48 Stat. 1200","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
