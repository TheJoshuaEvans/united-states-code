{"tag":"section","attrib":{"id":"id7a03b1eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6101"},"text":null,"children":[{"tag":"num","attrib":{"value":"6101"},"text":"§ 6101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a03b1ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the nearly 800 bird species known to occur in the United States, approximately 500 migrate among countries, and the large majority of those species, the neotropical migrants, winter in Latin America and the Caribbean but breed in Canada and the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a03b1ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" neotropical migratory bird species provide invaluable environmental, economic, recreational, and aesthetic benefits to the United States, as well as to the Western Hemisphere;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a03b1ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6101/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a03b1ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6101/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" many neotropical migratory bird populations, once considered common, are in decline, and some have declined to the point that their long-term survival in the wild is in jeopardy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a03b1f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6101/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the primary reason for the decline in the populations of those species is habitat loss and degradation (including pollution and contamination) across the species’ range; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a03b1f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6101/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a03b1f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6101/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because neotropical migratory birds range across numerous international borders each year, their conservation requires the commitment and effort of all countries along their migration routes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a03b1f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6101/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" although numerous initiatives exist to conserve migratory birds and their habitat, those initiatives can be significantly strengthened and enhanced by increased coordination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a03b1f4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/247/s2"},"text":"Pub. L. 106–247, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-07-20"},"text":"July 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/593"},"text":"114 Stat. 593","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/363/tIII/s302/a"},"text":"Pub. L. 109–363, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2075"},"text":"120 Stat. 2075","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a03b1f5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a03b1f6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a03b1f7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/363"},"text":"Pub. L. 109–363","children":[],"tail":" inserted “but breed in Canada and the United States” after “the Caribbean”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a03b1f8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id7a03b1f9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2024 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/51/s1"},"text":"Pub. L. 118–51, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-24"},"text":"Apr. 24, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1005"},"text":"138 Stat. 1005","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/51/s1"},"text":"“This Act [amending sections 6103, 6104, 6106, and 6109 of this title] may be cited as the ‘Migratory Birds of the Americas Conservation Enhancements Act of 2023’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id7a03b1fa-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/363/tIII/s301"},"text":"Pub. L. 109–363, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2075"},"text":"120 Stat. 2075","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/363/tIII/s301"},"text":"“This title [amending this section and sections 6102 to 6104 and 6106 to 6109 of this title and enacting provisions set out as notes under sections 6106 and 6108 of this title] may be cited as the ‘Neotropical Migratory Bird Conservation Improvement Act of 2006’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a03b1fb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/247/s1"},"text":"Pub. L. 106–247, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-07-20"},"text":"July 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/593"},"text":"114 Stat. 593","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/247/s1"},"text":"“This Act [enacting this chapter] may be cited as the ‘Neotropical Migratory Bird Conservation Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
