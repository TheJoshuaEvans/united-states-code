{"tag":"section","attrib":{"id":"id7760f3b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vv–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"410vv–3"},"text":"§ 410vv–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marsh-Billings-Rockefeller National Historical Park Scenic Zone","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7760f3b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vv–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the Marsh-Billings-Rockefeller National Historical Park Scenic Zone (hereinafter in this subchapter referred to as the “scenic zone”), which shall include those lands as generally depicted on the map entitled “Marsh-Billings-Rockefeller National Historical Park Scenic Zone Map” and dated ","children":[{"tag":"date","attrib":{"date":"1991-11-19"},"text":"November 19, 1991","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7760f3b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vv–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the scenic zone shall be to protect portions of the natural setting beyond the park boundaries that are visible from the Marsh-Billings-Rockefeller Mansion, by such means and in such a manner as will permit current and future compatible uses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7760f3b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vv–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of scenic easements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within the boundaries of the scenic zone, the Secretary is authorized only to acquire scenic easements by donation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7760f3b6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/350/s5"},"text":"Pub. L. 102–350, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-08-26"},"text":"Aug. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/935"},"text":"106 Stat. 935","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tI/s143"},"text":"Pub. L. 105–277, div. A, § 101(e) [title I, § 143]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–267.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7760f3b7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7760f3b8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7760f3b9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" substituted “Marsh-Billings-Rockefeller” for “Marsh-Billings” in section catchline and wherever appearing in subsecs. (a) and (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
