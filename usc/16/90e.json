{"tag":"section","attrib":{"id":"id7703df2c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s90e"},"text":null,"children":[{"tag":"num","attrib":{"value":"90e"},"text":"§ 90e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pasayten Wilderness, Okanogan and Mount Baker National Forests; designation; abolition of North Cascades Primitive Area classification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7703df2d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s90e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to further the purposes of the Wilderness Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"16 U.S.C. 1131","children":[],"tail":" et seq.], there is hereby designated, subject to valid existing rights, the Pasayten Wilderness within and as a part of the Okanogan National Forest and the Mount Baker National Forest, comprising an area of about five hundred thousand acres lying east of Ross Lake, as generally depicted in the area designated as “Pasayten Wilderness” on the map referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s90"},"text":"section 90 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7703df2e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s90e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The previous classification of the North Cascades Primitive Area is hereby abolished.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7703df2f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/544/tVI/s601"},"text":"Pub. L. 90–544, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-02"},"text":"Oct. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/930"},"text":"82 Stat. 930","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7703df30-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7703df31-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7703df32-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Wilderness Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/577"},"text":"Pub. L. 88–577","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-09-03"},"text":"Sept. 3, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/890"},"text":"78 Stat. 890","children":[],"tail":", which is classified generally to chapter 23 (§ 1131 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"section 1131 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
