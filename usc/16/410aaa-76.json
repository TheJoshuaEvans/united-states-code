{"tag":"section","attrib":{"id":"id776a690b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–76"},"text":null,"children":[{"tag":"num","attrib":{"value":"410aaa–76"},"text":"§ 410aaa–76.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal reserved water rights","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id776a690c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–76/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of sufficient water","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in section 204 of this Act, with respect to each wilderness area designated by this Act, Congress hereby reserves a quantity of water sufficient to fulfill the purposes of this Act. The priority date of such reserved water rights shall be ","children":[{"tag":"date","attrib":{"date":"1994-10-31"},"text":"October 31, 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776a690d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–76/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of rights reserved","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and all other officers of the United States shall take all steps necessary to protect the rights reserved by this section, including the filing by the Secretary of a claim for the quantification of such rights in any present or future appropriate stream adjudication in the courts of the State of California in which the United States is or may be joined in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s666"},"text":"section 666 of title 43","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776a690e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–76/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relinquishment or reduction of rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this Act shall be construed as a relinquishment or reduction of any water rights reserved or appropriated by the United States in the State of California on or before ","children":[{"tag":"date","attrib":{"date":"1994-10-31"},"text":"October 31, 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776a690f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–76/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific reservation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal water rights reserved by this Act are specific to the wilderness area located in the State of California designated under this Act. Nothing in this Act related to the reserved Federal water rights shall be construed as establishing a precedent with regard to any future designations, nor shall it constitute an interpretation of any other Act or any designation made thereto.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id776a6910-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/tVII/s706"},"text":"Pub. L. 103–433, title VII, § 706","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4498"},"text":"108 Stat. 4498","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id776a6911-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id776a6912-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id776a6913-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 204 of this Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/s204"},"text":"section 204 of Pub. L. 103–433","children":[],"tail":", title II, "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4485"},"text":"108 Stat. 4485","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsecs. (a), (c), and (d), is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/s3"},"text":"section 3 of Pub. L. 103–433","children":[],"tail":", which is set out as a Definitions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410aaa"},"text":"section 410aaa of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
