{"tag":"section","attrib":{"id":"id7760f406-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"410ww–5"},"text":"§ 410ww–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation of Federal agencies","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any Federal entity conducting or supporting activities directly affecting the park shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7760f407-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–5/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with, cooperate with, and to the maximum extent practicable, coordinate its activities with the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f408-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–5/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct or support such activities in a manner which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7760f409-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–5/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable is consistent with the standards and criteria established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410ww–22/b/9"},"text":"section 410ww–22(b)(9) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7760f40a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ww–5/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","at