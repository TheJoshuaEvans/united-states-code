{"tag":"section","attrib":{"id":"id78b5fc4c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a"},"text":null,"children":[{"tag":"num","attrib":{"value":"831a"},"text":"§ 831a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership, operation, and duties of the Board of Directors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78b5fc4d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78b5fc4e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Directors of the Corporation (referred to in this chapter as the “Board”) shall be composed of 9 members appointed by the President by and with the advice and consent of the Senate, at least 7 of whom shall be a legal resident of the service area of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b5fc4f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairman","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Board shall select 1 of the members to act as chairman of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b5fc50-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to be appointed as a member of the Board, an individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78b5fc51-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be a citizen of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b5fc52-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have management expertise relative to a large for-profit or nonprofit corporate, government, or academic structure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b5fc53-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be an employee of the Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b5fc54-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall make full disclosure to Congress of any investment or other financial interest that the individual holds in the energy industry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b5fc55-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall affirm support for the objectives and missions of the Corporation, including being a national leader in technological innovation, low-cost power, and environmental stewardship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b5fc56-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In appointing members of the Board, the President shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78b5fc57-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consider recommendations from such public officials as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78b5fc58-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Governors of States in the service area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78b5fc59-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individual citizens;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78b5fc5a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" business, industrial, labor, electric power distribution, environmental, civic, and service organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78b5fc5b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional delegations of the States in the service area; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b5fc5c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek qualified members from among persons who reflect the diversity, including the geographical diversity, and needs of the service area of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b5fc5d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78b5fc5e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Board shall serve a term of 5 years. A member of the Board whose term has expired may continue to serve after the member’s term has expired until the date on which a successor takes office, except that the member shall not serve beyond the end of the session of Congress in which the term of the member expires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b5fc5f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member appointed to fill a vacancy on the Board occurring before the expiration of the term for which the predecessor of the member was appointed shall be appointed for the remainder of that term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b5fc60-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78b5fc61-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Five of the members of the Board shall constitute a quorum for the transaction of business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b5fc62-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A vacancy on the Board shall not impair the power of the Board to act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b5fc63-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78b5fc64-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member of the Board shall be entitled to receive—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78b5fc65-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a stipend of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78b5fc66-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/f/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $45,000 per year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78b5fc67-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/f/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id78b5fc68-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/f/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the chairman of any committee of the Board created by the Board, $46,000 per year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78b5fc69-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/f/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the chairman of the Board, $50,000 per year; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78b5fc6a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" travel expenses, including per diem in lieu of subsistence, in the same manner as persons employed intermittently in Government service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b5fc6b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments in stipends","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the stipends under paragraph (1)(A) shall be adjusted by the same percentage, at the same time and manner, and subject to the same limitations as are applicable to adjustments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5318"},"text":"section 5318 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b5fc6c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78b5fc6d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78b5fc6e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish the broad goals, objectives, and policies of the Corporation that are appropriate to carry out this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78b5fc6f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop long-range plans to guide the Corporation in achieving the goals, objectives, and policies of the Corporation and provide assistance to the chief executive officer to achieve those goals, objectives, and policies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78b5fc70-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that those goals, objectives, and policies are achieved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78b5fc71-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/g/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approve an annual budget for the Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78b5fc72-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/g/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt and submit to Congress a conflict-of-interest policy applicable to members of the Board and employees of the Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78b5fc73-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/g/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a compensation plan for employees of the Corporation in accordance with subsection (i);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78b5fc74-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/g/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approve all compensation (including salary or any other pay, bonuses, benefits, incentives, and any other form of remuneration) of all managers and technical personnel that report directly to the chief executive officer (including any adjustment to compensation);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78b5fc75-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/g/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that all activities of the Corporation are carried out in compliance with applicable law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78b5fc76-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/g/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" create an audit committee, composed solely of Board members independent of the management of the Corporation, which shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78b5fc77-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/g/1/I/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the inspector general of the Corporation, recommend to the Board an external auditor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78b5fc78-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/g/1/I/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive and review reports from the external auditor of the Corporation and inspector general of the Corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78b5fc79-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/g/1/I/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make such recommendations to the Board as the audit committee considers necessary;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78b5fc7a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/g/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create such other committees of Board members as the Board considers to be appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78b5fc7b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/g/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct such public hearings as it deems appropriate on issues that could have a substantial effect on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78b5fc7c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/g/1/K/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the electric ratepayers in the service area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78b5fc7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/g/1/K/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economic, environmental, social, or physical well-being of the people of the service area;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78b5fc7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/g/1/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish the electricity rates charged by the Corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78b5fc7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/g/1/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage the services of an external auditor for the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b5fc80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall meet at least 4 times each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b5fc81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief executive officer","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78b5fc82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall appoint a person to serve as chief executive officer of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b5fc83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78b5fc84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To serve as chief executive officer of the Corporation, a person—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78b5fc85-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/h/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have senior executive-level management experience in large, complex organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78b5fc86-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/h/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be a current member of the Board or have served as a member of the Board within 2 years before being appointed chief executive officer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78b5fc87-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/h/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall comply with the conflict-of-interest policy adopted by the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78b5fc88-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expertise","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In appointing a chief executive officer, the Board shall give particular consideration to appointing an individual with expertise in the electric industry and with strong financial skills.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b5fc89-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tenure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chief executive officer shall serve at the pleasure of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b5fc8a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78b5fc8b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall approve a compensation plan that specifies all compensation (including salary or any other pay, bonuses, benefits, incentives, and any other form of remuneration) for the chief executive officer and employees of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b5fc8c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual survey","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The compensation plan shall be based on an annual survey of the prevailing compensation for similar positions in private industry, including engineering and electric utility companies, publicly owned electric utilities, and Federal, State, and local governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b5fc8d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The compensation plan shall provide that education, experience, level of responsibility, geographic differences, and retention and recruitment needs will be taken into account in determining compensation of employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b5fc8e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Positions at or below level IV","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chief executive officer shall determine the salary and benefits of employees whose annual salary is not greater than the annual rate payable for positions at level IV of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b5fc8f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s831a/i/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Positions above level IV","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the recommendation of the chief executive officer, the Board shall approve the salaries of employees whose annual salaries would be in excess of the annual rate payable for positions at level IV of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78b5fc90-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-18/ch32/s2"},"text":"May 18, 1933, ch. 32, § 2","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/dC/tVI/s601"},"text":"Pub. L. 108–447, div. C, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2963"},"text":"118 Stat. 2963","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dC/tIV/s401"},"text":"Pub. L. 110–161, div. C, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1971"},"text":"121 Stat. 1971","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78b5fc91-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78b5fc92-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id78b5fc93-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-18/ch32/s2"},"text":"act May 18, 1933, ch. 32, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/59"},"text":"48 Stat. 59","children":[],"tail":", related to the Directors of the Authority, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/dC/tVI/s601"},"text":"Pub. L. 108–447, div. C, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2963"},"text":"118 Stat. 2963","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78b5fc94-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161"},"text":"Pub. L. 110–161","children":[],"tail":" substituted “stipends under paragraph (1)(A)” for “stipend under paragraph (1)(A)(i)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78b5fc95-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78b5fc96-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Appointments; Effective Date; Transition","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dC/tVI/s604"},"text":"Pub. L. 108–447, div. C, title VI, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2967"},"text":"118 Stat. 2967","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/447/dC/tVI/s604"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointments.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As soon as practicable after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":"], the President shall submit to the Senate nominations of six persons to serve as members of the Board of Directors of the Tennessee Valley Authority in addition to the members serving on the date of enactment of this Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initial terms","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding section 2(d) of the Tennessee Valley Authority Act of 1933 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s831a/d"},"text":"16 U.S.C. 831a(d)","children":[],"tail":"] (as amended by this title), in making the appointments under paragraph (1), the President shall appoint—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two members for a term to expire on ","children":[{"tag":"date","attrib":{"date":"2007-05-18"},"text":"May 18, 2007","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two members for a term to expire on ","children":[{"tag":"date","attrib":{"date":"2009-05-18"},"text":"May 18, 2009","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two members for a term to expire on ","children":[{"tag":"date","attrib":{"date":"2011-05-18"},"text":"May 18, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amendments made by this title [enacting this section, amending sections 831, 831b, 831c, 831c–3, 831d, 831e, 831g, 831h, 831k, 831","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":", 831n, 831"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":", 831q, and 831w of this title and sections 5314 and 5315 of Title 5, Government Organization and Employees, and repealing prior "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s831a"},"text":"section 831a of this title","children":[],"tail":"] take effect on the later of—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which at least three persons nominated under subsection (a) take office; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"2005-05-18"},"text":"May 18, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection of Chairman","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board of Directors of the Tennessee Valley Authority shall select one of the members to act as chairman of the Board not later than 30 days after the effective date specified in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conflict-of-Interest Policy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board of Directors of the Tennessee Valley Authority shall adopt and submit to Congress a conflict-of-interest policy, as required by section 2(g)(1)(E) of the Tennessee Valley Authority Act of 1933 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s831a/g/1/E"},"text":"16 U.S.C. 831a(g)(1)(E)","children":[],"tail":"] (as amended by this title), as soon as practicable after the effective date specified in subsection (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person who is serving as a member of the board of directors of the Tennessee Valley Authority on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":"]—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall continue to serve until the end of the current term of the member; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the effective date specified in subsection (b), shall serve under the terms of the Tennessee Valley Authority Act of 1933 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s831"},"text":"16 U.S.C. 831","children":[],"tail":" et seq.] (as amended by this title).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id78b5fc97-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78b5fc98-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Emergency Preparedness Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For assignment of certain emergency preparedness functions to Board of Directors of Tennessee Valley Authority, see Parts 1, 2, and 24 of Ex. Ord. No. 12656, ","children":[{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", 53 F.R. 47491, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5195"},"text":"section 5195 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
