{"tag":"section","attrib":{"id":"id7760f38b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uu–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"410uu–4"},"text":"§ 410uu–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary for the acquisition of lands and interests in land within the park, the conduct of archeological studies on lands within and adjacent to the park, and the development of facilities for interpretation of the park.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7760f38c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/294/s5"},"text":"Pub. L. 102–294, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-27"},"text":"May 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/186"},"text":"106 Stat. 186","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
