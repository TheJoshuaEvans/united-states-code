{"tag":"section","attrib":{"id":"id7845d55d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s558e"},"text":null,"children":[{"tag":"num","attrib":{"value":"558e"},"text":"§ 558e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration as Federal employee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7845d55e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s558e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in this section, a volunteer shall not be deemed a Federal employee and shall not be subject to the provisions of law relating to Federal employment, including those relating to hours of work, rates of compensation, leave, unemployment compensation, and Federal employee benefits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7845d55f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s558e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of the tort claim provisions of title 28, a volunteer under this Act shall be considered a Federal employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7845d560-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s558e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of subchapter I of chapter 81 of title 5, relating to compensation to Federal employees for work injuries, volunteers under this Act shall be deemed civil employees of the United States within the meaning of the term “employee” as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8101"},"text":"section 8101 of title 5","children":[],"tail":", and the provisions of that subchapter shall apply."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7845d561-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s558e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of claims relating to damage to, or loss of, personal property of a volunteer incident to volunteer service, a volunteer under this Act shall be considered a Federal employee, and the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3721"},"text":"section 3721 of title 31","children":[],"tail":" shall apply."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7845d562-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s558e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purposes of subsections (b), (c), and (d), the term “volunteer” includes a person providing volunteer services to either of the Secretaries who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7845d563-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s558e/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is recruited, trained, and supported by a cooperator under a mutual benefit agreement or cooperative agreement with either of the Secretaries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7845d564-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s558e/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" performs such volunteer services under the supervision of the cooperator as directed by either of the Secretaries in the mutual benefit agreement or cooperative agreement in the mutual benefit agreement, including direction that specifies—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7845d565-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s558e/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the volunteer services, including the geographic boundaries of the work to be performed by the volunteers, and the supervision to be provided by the cooperator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7845d566-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s558e/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable project safety standards and protocols to be adhered to by the volunteers and enforced by the cooperator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7845d567-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s558e/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the on-site visits to be made by either of the Secretaries, if feasible and only if necessary to verify that volunteers are performing the volunteer services and the cooperator is providing the supervision agreed upon;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7845d568-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s558e/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the equipment the volunteers are authorized to use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7845d569-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s558e/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the training the volunteers are required to complete;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7845d56a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s558e/e/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actions the volunteers are authorized to take; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7845d56b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s558e/e/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other terms and conditions that are determined to be necessary by the applicable Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7845d56c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/300/s6"},"text":"Pub. L. 92–300, § 6","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/234/tIII/s341"},"text":"Pub. L. 118–234, title III, § 341","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2913"},"text":"138 Stat. 2913","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7845d56d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7845d56e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7845d56f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsecs. (b) to (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/300"},"text":"Pub. L. 92–300","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-05-18"},"text":"May 18, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/147"},"text":"86 Stat. 147","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/118/234/tIII/s341"},"text":"Pub. L. 118–234, title III, § 341","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2913"},"text":"138 Stat. 2913","children":[],"tail":", known as the Volunteers in the National Forests and Public Lands Act, which enacted sections 558a to 558g of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s558a"},"text":"section 558a of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
