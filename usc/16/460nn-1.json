{"tag":"section","attrib":{"id":"id77e405d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nn–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"460nn–1"},"text":"§ 460nn–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In furtherance of the findings and purposes of this subchapter, certain lands in the Green Mountain National Forest, Vermont, which comprise approximately thirty-six thousand four hundred acres, as generally depicted on a map entitled “White Rocks National Recreation Area—Proposed”, dated September 1983, are hereby designated as the Robert T. Stafford White Rocks National Recreation Area.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77e405d1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/322/tII/s202"},"text":"Pub. L. 98–322, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-06-19"},"text":"June 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/257"},"text":"98 Stat. 257","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/1/s1/b"},"text":"Pub. L. 110–1, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-17"},"text":"Jan. 17, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/3"},"text":"121 Stat. 3","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77e405d2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77e405d3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id77e405d4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Robert T. Stafford White Rocks National Recreation Area” substituted in text for “White Rocks National Recreation Area” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/1/s1/b"},"text":"section 1(b) of Pub. L. 110–1","children":[],"tail":", set out below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/1/s1"},"text":"Pub. L. 110–1, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-17"},"text":"Jan. 17, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/3"},"text":"121 Stat. 3","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/1/s1"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Redesignation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The White Rocks National Recreation Area in the State of Vermont, as established by section 202 of the Vermont Wilderness Act of 1984 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460nn–1"},"text":"16 U.S.C. 460nn–1","children":[],"tail":"), is redesignated as the ‘Robert T. Stafford White Rocks National Recreation Area’."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"References","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any reference in a law, map, regulation, document, paper, or other record of the United States to the recreation area referred to in subsection (a) shall be deemed to be a reference to the Robert T. Stafford White Rocks National Recreation Area.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
