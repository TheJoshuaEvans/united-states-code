{"tag":"section","attrib":{"id":"id7a3aa098-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8482"},"text":null,"children":[{"tag":"num","attrib":{"value":"8482"},"text":"§ 8482.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trail inventory","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a3aa099-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8482/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 7 years after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretary concerned shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3aa09a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8482/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct a comprehensive assessment of high-priority trails, in accordance with subsection (b), on Federal recreational lands and waters under the jurisdiction of the respective Secretary concerned, including measuring each trail’s—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3aa09b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8482/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" average and minimum tread width;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa09c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8482/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" average and maximum running slope;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa09d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8482/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" average and maximum cross slope;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa09e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8482/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tread type; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa09f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8482/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" length; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa0a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8482/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make information about such high-priority trails available (including through the use of prominently displayed links) on public websites of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3aa0a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8482/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each of the Federal land management agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa0a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8482/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each relevant unit and subunit of the Federal land management agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3aa0a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8482/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned shall select high-priority trails to be assessed under subsection (a)(1)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3aa0a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8482/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with stakeholders, including veterans organizations and organizations with expertise or experience providing outdoor recreation opportunities to individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa0a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8482/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a geographically equitable manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa0a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8482/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in no fewer than 15 units or subunits managed by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3aa0a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8482/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of current assessments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the assessment required under subsection (a)(1), the Secretary concerned may, to the extent practicable, rely on assessments completed or data gathered prior to ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3aa0a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8482/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3aa0a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8482/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 7 years after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretary concerned shall identify opportunities to replace signage and other publicly available information, including web page information, related to such high-priority trails and consistent with the Architectural Barriers Act of 1968 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4151"},"text":"42 U.S.C. 4151","children":[],"tail":" et seq.) and "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s794"},"text":"section 794 of title 29","children":[],"tail":" at high-priority trails covered by the assessment required under subsection (a)(1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa0aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8482/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tread obstacles","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the assessment required under subsection (a)(1), the Secretary may, to the extent practicable, include photographs or descriptions of tread obstacles and barriers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3aa0ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8482/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistive technology specification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In publishing information about each trail under this subsection, the Secretary concerned shall make public information about trails that do not meet the Architectural Barriers Act accessibility guidelines but could otherwise provide outdoor recreation opportunities to individuals with disabilities through the use of certain assistive technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3aa0ac-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tII/s212"},"text":"Pub. L. 118–234, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2881"},"text":"138 Stat. 2881","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a3aa0ad-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a3aa0ae-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a3aa0af-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Architectural Barriers Act of 1968, referred to in subsec. (d)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/480"},"text":"Pub. L. 90–480","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-12"},"text":"Aug. 12, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/718"},"text":"82 Stat. 718","children":[],"tail":", which is classified generally to chapter 51 (§ 4151 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4151"},"text":"section 4151 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s794"},"text":"Section 794 of title 29","children":[],"tail":", referred to in subsec. (d)(1), was in the original a reference to section 504 of the Rehabilitation Act, and was translated as meaning section 504 of the Rehabilitation Act of 1973, "},{"tag":"ref","attrib":{"href":"/us/pl/93/112"},"text":"Pub. L. 93–112","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
