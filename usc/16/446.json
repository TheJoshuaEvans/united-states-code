{"tag":"section","attrib":{"id":"id779ee707-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s446"},"text":null,"children":[{"tag":"num","attrib":{"value":"446"},"text":"§ 446.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sites for tablets at Antietam; care and supervision","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All lands acquired by the United States, whether by purchase, gift, or otherwise, for the purposes of sites for tablets for the marking of the lines of battle of the Army of the Potomac and of the Army of Northern Virginia at Antietam, and of the position of each of the forty-three different commands of the Regular Army engaged in the battle of Antietam, shall be under the care and supervision of the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id779ee708-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1890-08-30/ch837/s1"},"text":"Aug. 30, 1890, ch. 837, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/401"},"text":"26 Stat. 401","children":[],"tail":"; Ex. Ord. No. 6166, § 2, "},{"tag":"date","attrib":{"date":"1933-06-10"},"text":"June 10, 1933","children":[],"tail":"; Ex. Ord. No. 6228, § 1, "},{"tag":"date","attrib":{"date":"1933-07-28"},"text":"July 28, 1933","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id779ee709-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id779ee70a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id779ee70b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"ta