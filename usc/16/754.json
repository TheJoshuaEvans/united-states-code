{"tag":"section","attrib":{"id":"id788fd66a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s754"},"text":null,"children":[{"tag":"num","attrib":{"value":"754"},"text":"§ 754.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commutation of rations for officers and crews of vessels of Service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1942-07-02"},"text":"July 2, 1942","children":[],"tail":", commutation of rations (not to exceed $1 per man per day) may be paid to officers and crews of vessels of the United States Fish and Wildlife Service under regulations prescribed by the Secretary of the Interior, and money accruing from commutation of rations on board vessels may be paid on proper vouchers to the persons having charge of the mess of such vessels; and "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5911"},"text":"section 5911 of title 5","children":[],"tail":", shall not be construed to require deductions from the salaries of officers and crews of vessels of the United States Fish and Wildlife Service for quarters and rations furnished on vessels of said Service."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id788fd66b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1942-07-02/ch473/s1"},"text":"July 2, 1942, ch. 473, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/558"},"text":"56 Stat. 558","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-08/ch1036/s3"},"text":"Aug. 8, 1956, ch. 1036, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/1120"},"text":"70 Stat. 1120","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id788fd66c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"edito