{"tag":"section","attrib":{"id":"id79d4167c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"3839aa–8"},"text":"§ 3839aa–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation innovation grants and payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79d4167d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grants for innovative conservation approaches","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d4167e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Out of the funds made available to carry out this subpart, the Secretary may pay the cost of competitive grants that are intended to stimulate innovative approaches to leveraging the Federal investment in environmental enhancement and protection, in conjunction with agricultural production or forest resource management, through the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d4167f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide grants under this subsection to governmental and non-governmental organizations and persons, on a competitive basis, to carry out projects that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d41680-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve producers who are eligible for payments or technical assistance under the program or community colleges (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3319e/a"},"text":"section 3319e(a) of title 7","children":[],"tail":") carrying out demonstration projects on land of the community college;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d41681-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leverage Federal funds made available to carry out the program under this subpart with matching funds provided by State and local governments and private organizations to promote environmental enhancement and protection in conjunction with agricultural production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d41682-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure efficient and effective transfer of innovative technologies and approaches demonstrated through projects that receive funding under this section, such as market systems for pollution reduction and practices for the storage of carbon in soil;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d41683-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide environmental and resource conservation benefits through increased participation by producers of specialty crops;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d41684-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partner with farmers to develop innovative practices for urban, indoor, or other emerging agricultural operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d41685-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" utilize edge-of-field and other monitoring practices on farms—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d41686-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/a/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to quantify the impacts of practices implemented under the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d41687-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/a/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist producers in making the best conservation investments for the operations of the producers;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d41688-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate on-farm conservation research and demonstration activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d41689-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate pilot testing of new technologies or innovative conservation practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d4168a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Air quality concerns from agricultural operations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d4168b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide payments under this subsection to producers to implement practices to address air quality concerns from agricultural operations and to meet Federal, State, and local regulatory requirements. The funds shall be made available on the basis of air quality concerns in a State and shall be used to provide payments to producers that are cost effective and reflect innovative technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d4168c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds made available to carry out this subpart, the Secretary shall carry out this subsection using $37,500,000 for each of fiscal years 2019 through 2031.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d4168d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" On-farm conservation innovation trials","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d4168e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d4168f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means, as determined by the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d41690-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a third-party private entity the primary business of which is related to agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d41691-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nongovernmental organization with experience working with agricultural producers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d41692-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a governmental organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d41693-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New or innovative conservation approach","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “new or innovative conservation approach” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d41694-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" new or innovative—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79d41695-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" precision agriculture technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79d41696-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhanced nutrient management plans, nutrient recovery systems, and fertilization systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79d41697-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/1/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" soil health management systems, including systems to increase soil carbon levels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79d41698-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/1/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water management systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79d41699-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/1/B/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resource-conserving crop rotations (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3839aa–24/d/1"},"text":"section 3839aa–24(d)(1) of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79d4169a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/1/B/i/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cover crops; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79d4169b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/1/B/i/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" irrigation systems; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d4169c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other conservation approach approved by the Secretary as new or innovative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d4169d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Testing new or innovative conservation approaches","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Using $25,000,000 of the funds made available to carry out this subpart for each of fiscal years 2019 through 2031, the Secretary shall carry out on-farm conservation innovation trials, on eligible land of producers, to test new or innovative conservation approaches—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d4169e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly with producers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d4169f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through eligible entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d416a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentive payments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d416a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out paragraph (2), the Secretary shall enter into agreements with producers (either directly or through eligible entities) on whose land an on-farm conservation innovation trial is being carried out to provide payments (including payments to compensate for foregone income, as appropriate to address the increased economic risk potentially associated with new or innovative conservation approaches) to the producers to assist with adopting and evaluating new or innovative conservation approaches to achieve conservation benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d416a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjusted gross income requirements","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d416a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Adjusted gross income requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308–3a/b/1"},"text":"section 1308–3a(b)(1) of title 7","children":[],"tail":" shall—"}],"tail":null},{"tag":"subclause","attrib":{"id":"id79d416a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply to producers receiving payments under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79d416a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be enforced by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d416a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity participating in an on-farm conservation innovation trial under this subsection shall report annually to the Secretary on the amount of payments made to individual farm operations under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d416a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"None of the funds made available to carry out this subsection may be used to pay for the administrative expenses of an eligible entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d416a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Length of agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agreement entered into under subparagraph (A) shall be for a period determined by the Secretary that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d416a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 3 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d416aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if appropriate, more than 3 years, including if such a period is appropriate to support—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79d416ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/3/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adaptive management over multiple crop years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79d416ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/3/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequate data collection and analysis by a producer or eligible entity to report the natural resource and agricultural production benefits of the new or innovative conservation approaches to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d416ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flexible adoption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The scale of adoption of a new or innovative conservation approach under an on-farm conservation innovation trial under an agreement under paragraph (2) may include multiple scales on an operation, including whole farm, field-level, or sub-field scales.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d416ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide technical assistance—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d416af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to each producer or eligible entity participating in an on-farm conservation innovation trial under paragraph (2) with respect to the design, installation, and management of the new or innovative conservation approaches; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d416b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to each eligible entity participating in an on-farm conservation innovation trial under paragraph (2) with respect to data analyses of the on-farm conservation innovation trial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d416b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic scope","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall identify a diversity of geographic regions of the United States in which to establish on-farm conservation innovation trials under paragraph (2), taking into account factors such as soil type, cropping history, and water availability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d416b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Soil health demonstration trial","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Using funds made available to carry out this subsection, the Secretary shall carry out a soil health demonstration trial under which the Secretary coordinates with eligible entities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d416b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to provide incentives to producers to implement conservation practices that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d416b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve soil health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d416b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase carbon levels in the soil; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d416b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/7/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the goals described in clauses (i) and (ii);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d416b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish protocols for measuring carbon levels in the soil and testing carbon levels on land where conservation practices described in subparagraph (A) were applied to evaluate gains in soil health as a result of the practices implemented by the producers in the soil health demonstration trial; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d416b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d416b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/7/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than ","children":[{"tag":"date","attrib":{"date":"2020-09-30"},"text":"September 30, 2020","children":[],"tail":", to initiate a study regarding changes in soil health and, if feasible, economic outcomes, generated as a result of the conservation practices described in subparagraph (A) that were applied by producers through the soil health demonstration trial; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d416ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/c/7/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate annual reports on the progress and results of the study under clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d416bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting and database","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d416bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2019-09-30"},"text":"September 30, 2019","children":[],"tail":", and every 2 years thereafter, the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report on the status of activities funded under this section, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d416bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funding awarded;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d416be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" results of the activities, including, if feasible, economic outcomes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d416bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporation of findings from the activities, such as new technology and innovative approaches, into the conservation efforts implemented by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d416c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on completion of the study required under subsection (c)(7)(C), the findings of the study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d416c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation practice database","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d416c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall use the data reported under paragraph (1) to establish and maintain a publicly available conservation practice database that provides—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d416c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a compilation and analysis of effective conservation practices for soil health, nutrient management, and source water protection in varying soil compositions, cropping systems, slopes, and landscapes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d416c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of recommended new and effective conservation practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d416c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–8/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Information provided under subparagraph (A) shall be transformed into a statistical or aggregate form so as to not include any identifiable or personal information of individual producers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79d416c6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1240H"},"text":"Pub. L. 99–198, title XII, § 1240H","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tII/s2301"},"text":"Pub. L. 107–171, title II, § 2301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/257"},"text":"116 Stat. 257","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tII/s2509"},"text":"Pub. L. 110–234, title II, § 2509","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1064"},"text":"122 Stat. 1064","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title II, § 2509, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1792; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII/s2207"},"text":"Pub. L. 113–79, title II, § 2207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/731"},"text":"128 Stat. 731","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII"},"text":"Pub. L. 115–334, title II","children":[],"tail":", §§ 2301(d)(1)(J), 2307, "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4554"},"text":"132 Stat. 4554","children":[],"tail":", 4561; "},{"tag":"ref","attrib":{"href":"/us/pl/117/169/tII/s21001/c/2"},"text":"Pub. L. 117–169, title II, § 21001(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2017"},"text":"136 Stat. 2017","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79d416c7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79d416c8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79d416c9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id79d416ca-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3839aa–8, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1240H"},"text":"Pub. L. 99–198, title XII, § 1240H","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tIII/s334"},"text":"Pub. L. 104–127, title III, § 334","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1002"},"text":"110 Stat. 1002","children":[],"tail":", related to temporary administration of environmental quality incentives program, prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79d416cb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsecs. (b)(2), (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169"},"text":"Pub. L. 117–169","children":[],"tail":" substituted “2031” for “2023”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2301/d/1/J"},"text":"Pub. L. 115–334, § 2301(d)(1)(J)","children":[],"tail":", substituted “this subpart” for “this part”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2307/a/1"},"text":"Pub. L. 115–334, § 2307(a)(1)","children":[],"tail":", substituted “program or community colleges (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3319e/a"},"text":"section 3319e(a) of title 7","children":[],"tail":") carrying out demonstration projects on land of the community college;” for “program;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2301/d/1/J"},"text":"Pub. L. 115–334, § 2301(d)(1)(J)","children":[],"tail":", substituted “this subpart” for “this part”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(E) to (H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2307/a/2"},"text":"Pub. L. 115–334, § 2307(a)(2)","children":[],"tail":", (3), added subpars. (E) and (F) and redesignated former subpars. (E) and (F) as (G) and (H), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2307/b"},"text":"Pub. L. 115–334, § 2307(b)","children":[],"tail":", substituted “$37,500,000 for