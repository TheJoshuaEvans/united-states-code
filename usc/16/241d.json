{"tag":"section","attrib":{"id":"id771e1d6c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s241d"},"text":null,"children":[{"tag":"num","attrib":{"value":"241d"},"text":"§ 241d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The following area is excluded from the park: That portion of section 8 lying southwest of a line between the common corner of sections 8, 9, 16, and 17 and the northwest corner of the southwest quarter section 8; that portion of section 16 lying southwest of a line between the southeast corner southwest quarter and the northwest corner southwest quarter section 16; and section 17, township 147 north, range 100 west, fifth principal meridian, North Dakota.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id771e1d6d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-03-24/ch94/s2"},"text":"Mar. 24, 1956, ch. 94, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/56"},"text":"70 Stat. 56","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id771e1d6e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id771e1d6f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id771e1d70-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-04-25/ch41"},"text":"act Apr. 25, 1947, ch. 41",