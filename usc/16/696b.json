{"tag":"section","attrib":{"id":"id7877e21b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s696b"},"text":null,"children":[{"tag":"num","attrib":{"value":"696b"},"text":"§ 696b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is hereby authorized to be appropriated from time to time out of any money in the Treasury not otherwise appropriated, such amounts as may be necessary to effectuate the purposes of sections 696 to 696b of this title. The Secretary shall not utilize more than $2,035,000 from appropriated funds for the acquisition of land and interests in land for the purposes of sections 696 to 696b of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7877e21c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/164/s3"},"text":"Pub. L. 85–164, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-08-22"},"text":"Aug. 22, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/413"},"text":"71 Stat. 413","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/669/s10/b"},"text":"Pub. L. 89–669, § 10(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/930"},"text":"80 Stat. 930","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7877e21d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7877e21e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7877e21f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/669"},"text":"Pub. L. 89–669","children":[],"tail":" increased from $35,000 to $2,035,000 the limitation on funds for acquisition of land, provided for such acquisition “for the purposes of sections 696 to 696b of this title”, and struck out sentence which provided that exchange by the Secretary of lands and interests therein shall not be considered an expenditure from appropriated funds for acquisition of land."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
