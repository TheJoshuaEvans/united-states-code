{"tag":"section","attrib":{"id":"id7800b630-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–52"},"text":null,"children":[{"tag":"num","attrib":{"value":"460nnn–52"},"text":"§ 460nnn–52.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory role in management activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7800b631-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–52/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management recommendations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The advisory committee ","children":[{"tag":"ref","attrib":{"idref":"fn002382"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002382"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “advisory council”."}],"tail":" shall utilize sound science, existing plans for the management of Federal lands included in the Cooperative Management and Protection Area, and other tools to formulate recommendations for the Secretary regarding—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7800b632-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–52/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new and unique approaches to the management of lands within the boundaries of the Cooperative Management and Protection Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b633-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–52/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperative programs and incentives for seamless landscape management that meets human needs and maintains and improves the ecological and economic integrity of the Cooperative Management and Protection Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b634-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–52/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation of management plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consult with the advisory committee ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" as part of the preparation and implementation of the management plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b635-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–52/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No recommendations may be presented to the Secretary by the advisory council without the agreement of at least nine members of the advisory council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7800b636-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/399/tI/s132"},"text":"Pub. L. 106–399, title I, § 132","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1665"},"text":"114 Stat. 1665","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
