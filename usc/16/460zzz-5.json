{"tag":"section","attrib":{"id":"id780c9ccb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"460zzz–5"},"text":"§ 460zzz–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id780c9ccc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", the Secretary shall develop a comprehensive management plan for the long-term protection and management of the Conservation Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9ccd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The management plan shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780c9cce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the appropriate uses and management of the Conservation Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9ccf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be developed with extensive public input;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9cd0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–5/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into consideration any information developed in studies of the land within the Conservation Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9cd1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460zzz–5/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a comprehensive travel management plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id780c9cd2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tII/s2406"},"text":"Pub. L. 111–11, title II, § 2406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1107"},"text":"123 Stat. 1107","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
