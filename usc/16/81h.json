{"tag":"section","attrib":{"id":"id76ff24c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s81h"},"text":null,"children":[{"tag":"num","attrib":{"value":"81h"},"text":"§ 81h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil and criminal jurisdiction; legislative authority of State over park","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be held to deprive the State of Virginia, or any political subdivision thereof, of its civil and criminal jurisdiction in and over the areas included in said national park, nor shall this subchapter in any way impair or affect the rights of citizenship of any resident therein; and save and except as the consent of the State of Virginia may be hereafter given, the legislative authority of said State in and over all areas included within said national park shall not be diminished or affected by the creation of said national park, nor by the terms and provisions of this subchapter: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That any rules and regulations authorized in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s81g"},"text":"section 81g of this title","children":[],"tail":", and in the Act therein referred to,"},{"tag":"ref","attrib":{"idref":"fn002019"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002019"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall not apply to any property of a public nature in the city of Williamsburg, other than property of the United States."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id76ff24c2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-07-03/ch837/s6"},"text":"July 3, 1930, ch. 837, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/856"},"text":"46 Stat. 856","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-05/ch525/s2"},"text":"June 5, 1936, ch. 525, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1483"},"text":"49 Stat. 1483","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id76ff24c3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id76ff24c4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id76ff24c5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Act referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s81g"},"text":"section 81g of this title","children":[],"tail":", referred to in text, is "},{"tag":"ref","attrib":{"href":"/us/act/1916-08-25/ch408"},"text":"act Aug. 25, 1916, ch. 408","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/535"},"text":"39 Stat. 535","children":[],"tail":", known as the National Park Service Organic Act. See References in Text note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s81g"},"text":"section 81g of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id76ff24c6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s443e"},"text":"section 443e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id76ff24c7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id76ff24c8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1936-06-05"},"text":"June 5, 1936","children":[],"tail":", changed “Colonial National Monument” to “Colonial National Historical Park”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
