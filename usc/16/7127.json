{"tag":"section","attrib":{"id":"id7a251d0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7127"},"text":null,"children":[{"tag":"num","attrib":{"value":"7127"},"text":"§ 7127.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of project funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a251d0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7127/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of proposed projects to obligate funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"By September 30 of each fiscal year (or a later date specified by the Secretary concerned for the fiscal year), a resource advisory committee shall submit to the Secretary concerned pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7123/a/1"},"text":"section 7123(a)(1) of this title","children":[],"tail":" a sufficient number of project proposals that, if approved, would result in the obligation of at least the full amount of the project funds reserved by the participating county in the preceding fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a251d0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7127/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use or transfer of unobligated funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7128"},"text":"section 7128 of this title","children":[],"tail":", if a resource advisory committee fails to comply with subsection (a) for a fiscal year, any project funds reserved by the participating county in the preceding fiscal year and remaining unobligated shall be available for use as part of the project submissions in the next fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a251d0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7127/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of rejection of projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7128"},"text":"section 7128 of this title","children":[],"tail":", any project funds reserved by a participating county in the preceding fiscal year that are unobligated at the end of a fiscal year because the Secretary concerned has rejected one or more proposed projects shall be available for use as part of the project submissions in the next fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a251d0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7127/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of court orders","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a278d0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7127/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an approved project under this chapter is enjoined or prohibited by a Federal court, the Secretary concerned shall return the unobligated project funds related to the project to the participating county or counties that reserved the funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a278d10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7127/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditure of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The returned funds shall be available for the county to expend in the same manner as the funds reserved by the county under subparagraph (B)(i), (B)(ii), or (C)(i) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7112/d/1"},"text":"section 7112(d)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a278d11-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/393/tII/s207"},"text":"Pub. L. 106–393, title II, § 207","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/343/dC/tVI/s601/a"},"text":"Pub. L. 110–343, div. C, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3908"},"text":"122 Stat. 3908","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dF/tI/s100101/a/2"},"text":"Pub. L. 112–141, div. F, title I, § 100101(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/905"},"text":"126 Stat. 905","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/40/s10/a/2/D"},"text":"Pub. L. 113–40, § 10(a)(2)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-10-02"},"text":"Oct. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/545"},"text":"127 Stat. 545","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/10/tV/s524/c/3"},"text":"Pub. L. 114–10, title V, § 524(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-04-16"},"text":"Apr. 16, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/180"},"text":"129 Stat. 180","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dO/tIV/s401/b/3"},"text":"Pub. L. 115–141, div. O, title IV, § 401(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1079"},"text":"132 Stat. 1079","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a278d12-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a278d13-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a278d14-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (d)(1), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/393"},"text":"Pub. L. 106–393","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1607"},"text":"114 Stat. 1607","children":[],"tail":", known as the Secure Rural Schools and Community Self-Determination Act of 2000, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s7101"},"text":"section 7101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a278d15-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/393/s207"},"text":"section 207 of Pub. L. 106–393","children":[],"tail":" was set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s500"},"text":"section 500 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/110/343/dC/tVI/s601/a"},"text":"Pub. L. 110–343, div. C, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3893"},"text":"122 Stat. 3893","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a278d16-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “subparagraph (B)(i), (B)(ii),” for “subparagraph (B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/10"},"text":"Pub. L. 114–10","children":[],"tail":" substituted “September 30 of each fiscal year (or a later date specified by the Secretary concerned for the fiscal year)” for “"},{"tag":"date","attrib":{"date":"2008-09-30"},"text":"September 30, 2008","children":[],"tail":" (or as soon thereafter as the Secretary concerned determines is practicable), and each September 30 thereafter for each succeeding fiscal year through fiscal year 2013”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/40"},"text":"Pub. L. 113–40","children":[],"tail":" substituted “2013” for “2012”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" substituted “2012” for “2011”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
