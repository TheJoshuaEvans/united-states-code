{"tag":"section","attrib":{"id":"id77c50c33-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460m–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"460m–7"},"text":"§ 460m–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated such sums (but not more than $10,804,000 for the acquisition of lands or interests in lands) as are necessary to carry out the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77c50c34-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/492/s8"},"text":"Pub. L. 88–492, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-27"},"text":"Aug. 27, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/610"},"text":"78 Stat. 610","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/272/tI/s101/7"},"text":"Pub. L. 92–272, title I, § 101(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-04-11"},"text":"Apr. 11, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/120"},"text":"86 Stat. 120","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77c50c35-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77c50c36-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77c50c37-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/272"},"text":"Pub. L. 92–272","children":[],"tail":" increased maximum amount authorized to be appropriated for acquisition of lands or interests in lands from not more than $7,000,000 to not more than $10,804,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
