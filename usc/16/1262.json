{"tag":"section","attrib":{"id":"id78fd6546-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1262"},"text":null,"children":[{"tag":"num","attrib":{"value":"1262"},"text":"§ 1262.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Recreational Trails Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78fd6547-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1262/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the National Recreational Trails Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78fd6548-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1262/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There shall be 12 members of the advisory committee, consisting of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78fd6549-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1262/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 8 members appointed by the Secretary from nominations submitted by recreational trail user organizations, one each representing the following recreational trail uses:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78fd654a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1262/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hiking,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78fd654b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1262/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cross-country skiing,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78fd654c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1262/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" off-highway motorcycling,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78fd654d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1262/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" snowmobiling,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78fd654e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1262/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" horseback riding,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78fd654f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1262/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all-terrain vehicle riding,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78fd6550-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1262/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bicycling, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78fd6551-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1262/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" four-wheel driving;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78fd6552-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1262/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member appointed by the Secretary representing individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78fd6553-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1262/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an appropriate official of government with a background in science or natural resources management, including any official of State or local government, designated by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78fd6554-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1262/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member appointed by the Secretary from nominations submitted by water trail user organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78fd6555-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1262/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member appointed by the Secretary from nominations submitted by hunting and fishing enthusiast organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78fd6556-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1262/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairman","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chair of the advisory committee shall be the government official referenced in subsection (b)(3), who shall serve as a non-voting member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78fd6557-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1262/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support for committee action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any action, recommendation, or policy of the advisory committee must be supported by at least five of the members appointed under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78fd6558-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1262/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the advisory committee appointed by the Secretary shall be appointed for terms of three years, except that the members filling five of the eleven positions shall be initially appointed for terms of two years, with subsequent appointments to those positions extending for terms of three years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78fd6559-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1262/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The advisory committee shall meet at least twice annually to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78fd655a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1262/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review utilization of allocated moneys by States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78fd655b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1262/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and review criteria for trail-side and trail-head facilities that qualify for funding under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78fd655c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1262/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the Secretary for changes in Federal policy to advance the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78fd655d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1262/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The advisory committee shall present to the Secretary an annual report on its activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78fd655e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1262/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement for expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nongovernmental members of the advisory committee shall serve without pay, but, to the extent funds are available pursuant to section 1261(d)(1)(B) ","children":[{"tag":"ref","attrib":{"idref":"fn002588"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002588"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, shall be entitled to reimbursement for travel, subsistence, and other necessary expenses incurred in the performance of their duties."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78fd655f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1262/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 4 years after ","children":[{"tag":"date","attrib":{"date":"1991-12-18"},"text":"December 18, 1991","children":[],"tail":", the Secretary shall prepare and submit to the Committee on Environment and Public Works of the Senate, and the Committee on Transportation and Infrastructure of the House of Representatives, a study which summarizes the annual reports of the National Recreational Trails Advisory Committee, describes the allocation and utilization of moneys under this chapter, and contains recommendations for changes in Federal policy to advance the purposes of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78fd6560-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1262/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The advisory committee established by this section shall terminate on ","children":[{"tag":"date","attrib":{"date":"2000-09-30"},"text":"September 30, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78fd6561-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/240/tI/s1303"},"text":"Pub. L. 102–240, title I, § 1303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-18"},"text":"Dec. 18, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2068"},"text":"105 Stat. 2068","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/59/tIII"},"text":"Pub. L. 104–59, title III","children":[],"tail":", §§ 325(h), 337(e), "},{"tag":"date","attrib":{"date":"1995-11-28"},"text":"Nov. 28, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/592"},"text":"109 Stat. 592","children":[],"tail":", 603; "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tI/s1112/d"},"text":"Pub. L. 105–178, title I, § 1112(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/151"},"text":"112 Stat. 151","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78fd6562-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78fd6563-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78fd6564-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1261"},"text":"Section 1261 of this title","children":[],"tail":", referred to in subsec. (h), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tI/s1112/c"},"text":"Pub. L. 105–178, title I, § 1112(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/151"},"text":"112 Stat. 151","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78fd6565-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178"},"text":"Pub. L. 105–178","children":[],"tail":" added subsec. (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/59/s337/e/1/A"},"text":"Pub. L. 104–59, § 337(e)(1)(A)","children":[],"tail":", substituted “12” for “11” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/59/s337/e/1/B"},"text":"Pub. L. 104–59, § 337(e)(1)(B)","children":[],"tail":", (C), added par. (2) and redesignated former pars. (2) to (4) as (3) to (5), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/59/s337/e/2"},"text":"Pub. L. 104–59, § 337(e)(2)","children":[],"tail":", substituted “(b)(3)” for “(b)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/59/s325/h"},"text":"Pub. L. 104–59, § 325(h)","children":[],"tail":", substituted “Transportation and Infrastructure” for “Public Works and Transportation”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
