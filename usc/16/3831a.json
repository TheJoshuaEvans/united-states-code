{"tag":"section","attrib":{"id":"id79ccea37-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3831a"},"text":"§ 3831a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation reserve enhancement program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79ccea38-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ccea39-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CREP","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “CREP” means a conservation reserve enhancement program carried out under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ccea3a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible land” means land that is eligible to be included in the program established under this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ccea3b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible partner","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible partner” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79ccea3c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ccea3d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a political subdivision of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ccea3e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ccea3f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nongovernmental organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ccea40-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “management” means an activity conducted by an owner or operator under a contract entered into under this subpart after the establishment of a conservation practice on eligible land, to regularly maintain or enhance the vegetative cover established by the conservation practice—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79ccea41-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" throughout the term of the contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ccea42-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with the conservation plan that covers the eligible land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ccea43-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ccea44-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may enter into an agreement with an eligible partner to carry out a conservation reserve enhancement program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79ccea45-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist in enrolling eligible land in the program established under this subpart; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ccea46-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the Secretary determines will advance the purposes of this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ccea47-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agreement entered into under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79ccea48-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describe—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79ccea49-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more specific State or nationally significant conservation concerns to be addressed by the agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79ccea4a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quantifiable environmental goals for addressing the concerns under clause (i);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79ccea4b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a suitable acreage goal for enrollment of eligible land under the agreement, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79ccea4c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location of eligible land to be enrolled in the project area identified under the agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79ccea4d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/b/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payments to be offered by the Secretary and eligible partner to an owner or operator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79ccea4e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/b/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an appropriate list of conservation reserve program conservation practices that are appropriate to meeting the concerns described under clause (i), as determined by the Secretary in consultation with eligible partners;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ccea4f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" subject to subparagraph (C), require the eligible partner to provide matching funds—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79ccea50-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an amount determined during a negotiation between the Secretary and 1 or more eligible partners, if the majority of the matching funds to carry out the agreement are provided by 1 or more eligible partners that are not nongovernmental organizations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79ccea51-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an amount not less than 30 percent of the cost required to carry out the conservation measures and practices described in the agreement, if a majority of the matching funds to carry out the agreement are provided by 1 or more nongovernmental organizations; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ccea52-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include procedures to allow for a temporary waiver of the matching requirements under subparagraph (B), or continued enrollment with a temporary suspension of incentives or eligible partner contributions for new agreements, during a period when an eligible partner loses the authority or ability to provide matching contributions, if the Secretary determines that the temporary waiver or continued enrollment with a temporary suspension will advance the purposes of this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ccea53-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on existing agreements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79ccea54-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), an agreement under this subsection shall not affect, modify, or interfere with existing agreements under this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ccea55-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification of existing agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To implement this section, the signatories to an agreement under this subsection may mutually agree to a modification of an agreement entered into before ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", under the Conservation Reserve Enhancement Program established by the Secretary under this subpart."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ccea56-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ccea57-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds provided by an eligible partner may be in cash, in-kind contributions, or technical assistance, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ccea58-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marginal pastureland cost-share payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that cost-share payments to an owner or operator to install stream fencing, crossings, and alternative water development on marginal pastureland under a CREP reflect the fair market value of the cost of installation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ccea59-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-share and practice incentive payments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79ccea5a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On request of an owner or operator, the Secretary shall provide cost-share payments when a major component of a conservation practice is completed under a CREP, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ccea5b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of implementing conservation practices on land enrolled under a CREP, the Secretary may waive the contribution limitation described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3834/b/2/A"},"text":"section 3834(b)(2)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ccea5c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Riparian buffer management payments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79ccea5d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an agreement under subsection (b)(1) that includes riparian buffers as an eligible practice, the Secretary shall make cost-share payments to encourage the regular management of the riparian buffer throughout the term of the agreement, consistent with the conservation plan that covers the eligible land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ccea5e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of payments received by an owner or operator under subparagraph (A) shall not be greater than 100 percent of the normal and customary projected management cost, as determined by the Secretary, in consultation with the applicable State technical committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3861/a"},"text":"section 3861(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ccea5f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forested riparian buffer practice","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ccea60-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food-producing woody plants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an agreement under subsection (b)(1) that includes forested riparian buffers as an eligible practice, the Secretary shall allow an owner or operator—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79ccea61-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to plant food-producing woody plants in the forested riparian buffers, on the conditions that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79ccea62-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plants shall contribute to the conservation of soil, water quality, and wildlife habitat; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79ccea63-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the planting shall be consistent with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79ccea64-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/d/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations of the applicable State technical committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3861/a"},"text":"section 3861(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79ccea65-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/d/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical guide standards of the applicable field office of the Natural Resources Conservation Service; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ccea66-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to harvest from plants described in subparagraph (A), on the conditions that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79ccea67-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the harvesting shall not damage the conserving cover or otherwise have a negative impact on the conservation concerns targeted by the CREP;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79ccea68-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only native plant species appropriate to the region shall be used within 35 feet of the watercourse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79ccea69-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/d/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the producer shall be subject to a reduction in the rental rate commensurate to the value of the crop harvested.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ccea6a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of enrolling forested riparian buffers in a CREP, the Administrator of the Farm Service Agency shall coordinate with the applicable State forestry agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ccea6b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drought and water conservation agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an agreement under subsection (b)(1) to address regional drought concerns, in accordance with the conservation purposes of the CREP, the Secretary, in consultation with the applicable State technical committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3861/a"},"text":"section 3861(a) of this title","children":[],"tail":", may—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ccea6c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding subsection (a)(2), enroll other agricultural land on which the resource concerns identified in the agreement can be addressed if the enrollment of the land is critical to the accomplishment of the purposes of the agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ccea6d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit dryland agricultural uses with the adoption of best management practices on enrolled land if the agreement involves the significant long-term reduction of consumptive water use and dryland production is compatible with the agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ccea6e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" calculate annual rental payments consistent with existing administrative practice for similar drought and water conservation agreements under this subchapter and ensure regional consistency in those rates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ccea6f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the end of each fiscal year, the Secretary shall submit to Congress a report that describes, with respect to each agreement entered into under subsection (b)(1)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ccea70-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of the agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ccea71-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purposes and objectives of the agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ccea72-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal and eligible partner commitments made under the agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ccea73-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3831a/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress made in fulfilling those commitments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79ccea74-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1231A"},"text":"Pub. L. 99–198, title XII, § 1231A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII/s2202/a"},"text":"Pub. L. 115–334, title II, § 2202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4534"},"text":"132 Stat. 4534","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79ccea75-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79ccea76-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id79ccea77-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3831a, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1231A"},"text":"Pub. L. 99–198, title XII, § 1231A","children":[],"tail":", as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tII/s2106/b"},"text":"Pub. L. 110–234, title II, § 2106(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1032"},"text":"122 Stat. 1032","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title II, § 2106(b), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1760, related to emergency forestry conservation reserve program, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII/s2702/a"},"text":"Pub. L. 113–79, title II, § 2702(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/766"},"text":"128 Stat. 766","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79ccea78-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79ccea79-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal of Former Section 3831a; Transitional Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII/s2702"},"text":"Pub. L. 113–79, title II, § 2702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/766"},"text":"128 Stat. 766","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/79/tII/s2702"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repeal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), section 1231A of the Food Security Act of 1985 ([former] ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3831a"},"text":"16 U.S.C. 3831a","children":[],"tail":") is repealed."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transitional Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect on existing contracts and agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendment made by this section shall not affect the validity or terms of any contract or agreement entered into by the Secretary of Agriculture under section 1231A of the Food Security Act of 1985 ([former] ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3831a"},"text":"16 U.S.C. 3831a","children":[],"tail":") before the date of enactment of the Agricultural Act of 2014 ["},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":"], or any payments required to be made in connection with the contract or agreement."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary [of Agriculture] may use funds made available to carry out the conservation reserve program under subchapter B of chapter 1 of subtitle D of title XII of the Food Security Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3831"},"text":"16 U.S.C. 3831","children":[],"tail":" et seq.) to continue to carry out contracts or agreements referred to in paragraph (1) using the provisions of law and regulation applicable to such contracts or agreements as in existence on the day before the date of enactment of the Agricultural Act of 2014.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
