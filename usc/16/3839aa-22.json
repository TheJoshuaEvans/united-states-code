{"tag":"section","attrib":{"id":"id79d41703-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–22"},"text":null,"children":[{"tag":"num","attrib":{"value":"3839aa–22"},"text":"§ 3839aa–22.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation stewardship program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79d41704-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–22/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During each of fiscal years 2019 through 2031, the Secretary shall carry out a conservation stewardship program to encourage producers to address priority resource concerns and improve and conserve the quality and condition of natural resources in a comprehensive manner—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d41705-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–22/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by undertaking additional conservation activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d41706-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–22/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by improving, maintaining, and managing existing conservation activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d41707-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–22/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d41708-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–22/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land enrolled in other conservation programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), the following land (even if covered by the definition of eligible land) is not eligible for enrollment in the program:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d41709-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–22/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Land enrolled in the conservation reserve program, unless—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d4170a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–22/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conservation reserve contract will expire at the end of the fiscal year in which the land is to be enrolled in the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d4170b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–22/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conservation reserve program payments for land enrolled in the program cease before the first program payment is made to the applicant under this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d4170c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–22/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Land enrolled in a wetland reserve easement through the agricultural conservation easement program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d4170d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–22/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conversion to cropland","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Eligible land used for crop production after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", that had not been planted, considered to be planted, or devoted to crop production for at least 4 of the 6 years preceding that date shall not be the basis for any payment under the program, unless the land does not meet such requirement because—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d6870e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–22/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the land had previously been enrolled in the conservation reserve program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d6870f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–22/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the land has been maintained using long-term crop rotation practices, as determined by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d68710-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3839aa–22/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the land is incidental land needed for efficient operation of the farm or ranch, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79d68711-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1240J"},"text":"Pub. L. 99–198, title XII, § 1240J","children":[],"tail":", formerly § 1238E, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tII/s2301/a/2"},"text":"Pub. L. 110–234, title II, § 2301(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1041"},"text":"122 Stat. 1041","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title II, § 2301(a)(2), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1769; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/55/dA/tVII/s716/b"},"text":"Pub. L. 112–55, div. A, title VII, § 716(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-11-18"},"text":"Nov. 18, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/582"},"text":"125 Stat. 582","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII/s2101/a"},"text":"Pub. L. 113–79, title II, § 2101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/722"},"text":"128 Stat. 722","children":[],"tail":"; renumbered § 1240J and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII"},"text":"Pub. L. 115–334, title II","children":[],"tail":", §§ 2301(b), (d)(1)(C), 2308(b), "},{"tag":"dat