,"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79d68715-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169"},"text":"Pub. L. 117–169","children":[],"tail":" substituted “2031” for “2023” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2308/b/1"},"text":"Pub. L. 115–334, § 2308(b)(1)","children":[],"tail":", substituted “2019 through 2023” for “2014 through 2018” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2301/d/1/C"},"text":"Pub. L. 115–334, § 2301(d)(1)(C)","children":[],"tail":", struck out subpar. (C) which read as follows: “Land enrolled in the conservation security program.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2308/b/2"},"text":"Pub. L. 115–334, § 2308(b)(2)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"February 7, 2014","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" amended section generally. Prior to amendment, section related to conservation stewardship program."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/55"},"text":"Pub. L. 112–55","children":[],"tail":" substituted “2014” for “2012”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
