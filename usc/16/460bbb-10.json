{"tag":"section","attrib":{"id":"id77f25e12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bbb–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"460bbb–10"},"text":"§ 460bbb–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provision","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77f25e13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bbb–10/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities on lands outside of recreation area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall limit, restrict, or require specific management practices on lands outside the recreation area boundary. The fact that activities or uses outside the recreation area can be seen, heard, or otherwise perceived within the recreation area shall not, of itself, limit, restrict, or preclude such activities or uses up to the boundary of the recreation area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f25e14-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bbb–10/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior rights","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77f25e15-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bbb–10/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this subchapter shall limit, restrict, or preclude the implementation of valid timber sale contracts or other contracts or agreements executed by the Secretary before ","children":[{"tag":"date","attrib":{"date":"1990-11-16"},"text":"November 16, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77f25e16-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bbb–10/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as specifically provided herein nothing in this subchapter shall be construed as diminishing or relinquishing any right, title, or interest of the United States in any lands, waters, or interests therein within the boundaries of the recreation area designated by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f25e17-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bbb–10/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Road easements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed as affecting the responsibilities of the State of California or any of its political subdivisions with respect to road easements, including maintenance and improvement of State Highway 199 and County Route 427.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f25e18-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bbb–10/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights of access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Existing rights provided by Federal law for access by private landowners across National Forest System lands shall not be affected by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f25e19-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bbb–10/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entitlement moneys","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Annually for the first two full fiscal years after ","children":[{"tag":"date","attrib":{"date":"1990-11-16"},"text":"November 16, 1990","children":[],"tail":", the Secretary shall pay for use by units of local government within the recreation area an amount equal to the difference between the amounts payable for such purposes pursuant to the Act of "},{"tag":"date","attrib":{"date":"1908-05-23"},"text":"May 23, 1908","children":[],"tail":" (chapter 193; "},{"tag":"ref","attrib":{"href":"/us/stat/35/251"},"text":"35 Stat. 251","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s500"},"text":"16 U.S.C. 500","children":[],"tail":") and the average amount paid for such purpose under such Act during the five fiscal years preceding "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"November 16, 1990","children":[],"tail":". The amount payable under this subsection shall be reduced by 10 percent annually thereafter for each succeeding fiscal year until the amount payable shall be reduced 100 percent by the end of the twelfth fiscal year after "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"November 16, 1990","children":[],"tail":". This subsection shall expire 11 years after the first payment pursuant to this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77f25e1a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/612/s13"},"text":"Pub. L. 101–612, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3222"},"text":"104 Stat. 3222","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77f25e1b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77f25e1c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77f25e1d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsecs. (a) to (d), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/612"},"text":"Pub. L. 101–612","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3209"},"text":"104 Stat. 3209","children":[],"tail":", which is classified principally to this subchapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460bbb"},"text":"section 460bbb of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1908-05-23"},"text":"May 23, 1908","children":[],"tail":" (chapter 193; "},{"tag":"ref","attrib":{"href":"/us/stat/35/251"},"text":"35 Stat. 251","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s500"},"text":"16 U.S.C. 500","children":[],"tail":"), referred to in subsec. (e), probably means "},{"tag":"ref","attrib":{"href":"/us/act/1908-05-23/ch192"},"text":"act May 23, 1908, ch. 192","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/260"},"text":"35 Stat. 260","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s500"},"text":"section 500 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
