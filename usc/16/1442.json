{"tag":"section","attrib":{"id":"id79345458-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1442"},"text":null,"children":[{"tag":"num","attrib":{"value":"1442"},"text":"§ 1442.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements, donations, and acquisitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79345459-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1442/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements and grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into cooperative agreements, contracts, or other agreements with, or make grants to, States, local governments, regional agencies, interstate agencies, or other persons to carry out the purposes and policies of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7934545a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1442/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization to solicit donations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into such agreements with any nonprofit organization authorizing the organization to solicit private donations to carry out the purposes and policies of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7934545b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1442/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may accept donations of funds, property, and services for use in designating and administering national marine sanctuaries under this chapter. Donations accepted under this section shall be considered as a gift or bequest to or for the use of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7934545c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1442/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire by purchase, lease, or exchange, any land, facilities, or other property necessary and appropriate to carry out the purposes and policies of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7934545d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1442/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of resources of other government agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, whenever appropriate, enter into an agreement with a State or other Federal agency to use the personnel, services, or facilities of such agency on a reimbursable or nonreimbursable basis, to assist in carrying out the purposes and policies of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7934545e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1442/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to obtain grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law that prohibits a Federal agency from receiving assistance, the Secretary may apply for, accept, and use grants from other Federal agencies, States, local governments, regional agencies, interstate agencies, foundations, or other persons, to carry out the purposes and policies of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7934545f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532/tIII/s311"},"text":"Pub. L. 92–532, title III, § 311","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/627/tII/s203/3"},"text":"Pub. L. 100–627, title II, § 203(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3215"},"text":"102 Stat. 3215","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/tII/s2109"},"text":"Pub. L. 102–587, title II, § 2109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5045"},"text":"106 Stat. 5045","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/283/s9/d"},"text":"Pub. L. 104–283, § 9(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3367"},"text":"110 Stat. 3367","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/513/s12"},"text":"Pub. L. 106–513, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2389"},"text":"114 Stat. 2389","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79345460-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79345461-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79345462-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/513/s12/a"},"text":"Pub. L. 106–513, § 12(a)","children":[],"tail":", amended heading and text of subsec. (a) generally. Prior to amendment, text read as follows: “The Secretary may enter into cooperative agreements, financial agreements, grants, contracts, or other agreements with States, local governments, regional agencies, interstate agencies, or other persons to carry out the purposes and policies of this chapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/513/s12/b"},"text":"Pub. L. 106–513, § 12(b)","children":[],"tail":", added subsecs. (e) and (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/283"},"text":"Pub. L. 104–283","children":[],"tail":" made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/102/587"},"text":"Pub. L. 102–587","children":[],"tail":". See 1992 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587"},"text":"Pub. L. 102–587","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/283"},"text":"Pub. L. 104–283","children":[],"tail":", amended section generally. Prior to amendment, section read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"Cooperative Agreements","children":[],"tail":".—The Secretary may enter into cooperative agreements with any nonprofit organization—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) to aid and promote interpretive, historical, scientific, and educational activities; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) for the solicitation of private donations for the support of such activities.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Donations","children":[],"tail":".—The Secretary may accept donations of funds, property, and services for use in designating and administering national marine sanctuaries under this chapter.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79345463-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79345464-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Enhancing Support for National Marine Sanctuaries","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/tII/s2204"},"text":"Section 2204 of title II of Pub. L. 102–587","children":[],"tail":", which was formerly set out as a note under this section, was renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/92/532/s316"},"text":"section 316 of Pub. L. 92–532","children":[],"tail":", The National Marine Sanctuaries Act, by "},{"tag":"ref","attrib":{"href":"/us/pl/104/283/s6/a"},"text":"Pub. L. 104–283, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3364"},"text":"110 Stat. 3364","children":[],"tail":", and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1445b"},"text":"section 1445b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
