{"tag":"section","attrib":{"id":"id793453d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1435"},"text":null,"children":[{"tag":"num","attrib":{"value":"1435"},"text":"§ 1435.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of regulations; international negotiations and cooperation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id793453d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1435/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This chapter and the regulations issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1434"},"text":"section 1434 of this title","children":[],"tail":" shall be applied in accordance with generally recognized principles of international law, and in accordance with treaties, conventions, and other agreements to which the United States is a party. No regulation shall apply to or be enforced against a person who is not a citizen, national, or resident alien of the United States, unless in accordance with—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id793453d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1435/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" generally recognized principles of international law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793453d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1435/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agreement between the United States and the foreign state of which the person is a citizen; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793453d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1435/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agreement between the United States and the flag state of a foreign vessel, if the person is a crewmember of the vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id793453d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1435/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negotiations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State, in consultation with the Secretary, shall take appropriate action to enter into negotiations with other governments to make necessary arrangements for the protection of any national marine sanctuary and to promote the purposes for which the sanctuary is established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id793453d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1435/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of State and other appropriate Federal agencies, shall cooperate with other governments and international organizations in furtherance of the purposes and policies of this chapter and consistent with applicable regional and mutilateral ","children":[{"tag":"ref","attrib":{"idref":"fn002643"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002643"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “multilateral”."}],"tail":" arrangements for the protection and management of special marine areas."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id793453d8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532/tIII/s305"},"text":"Pub. L. 92–532, title III, § 305","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/498/tI/s102"},"text":"Pub. L. 98–498, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2302"},"text":"98 Stat. 2302","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/tII/s2105"},"text":"Pub. L. 102–587, title II, § 2105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5043"},"text":"106 Stat. 5043","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id793453d9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id793453da-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id793453db-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/s2105/b"},"text":"Pub. L. 102–587, § 2105(b)","children":[],"tail":", substituted “; international negotiations and cooperation” for “and international negotiations” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/s2105/a/1"},"text":"Pub. L. 102–587, § 2105(a)(1)","children":[],"tail":", substituted “This chapter and the regulations” for “The regulations” and inserted “or be enforced against” after “apply to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/s2105/a/2"},"text":"Pub. L. 102–587, § 2105(a)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id793453dc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id793453dd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"International Cooperation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For direction that the Secretary of State seek effective international action and cooperation through the development of appropriate international rules and regulations in support of the policy of this chapter and chapter 27 of Title 33, Navigation and Navigable Waters, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1419"},"text":"section 1419 of Title 33","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
