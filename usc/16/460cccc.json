{"tag":"section","attrib":{"id":"id780c9d65-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc"},"text":null,"children":[{"tag":"num","attrib":{"value":"460cccc"},"text":"§ 460cccc.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" John Wesley Powell National Conservation Area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id780c9d66-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780c9d67-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Map” means the Bureau of Land Management map entitled “Proposed John Wesley Powell National Conservation Area” and dated ","children":[{"tag":"date","attrib":{"date":"2018-12-10"},"text":"December 10, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9d68-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Conservation Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National Conservation Area” means the John Wesley Powell National Conservation Area established by subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9d69-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780c9d6a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to valid existing rights, there is established the John Wesley Powell National Conservation Area in the State of Utah.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9d6b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area included","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Conservation Area shall consist of approximately 29,868 acres of public land administered by the Bureau of Land Management as generally depicted on the Map.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9d6c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purposes of the National Conservation Area are to conserve, protect, and enhance for the benefit of present and future generations the nationally significant historic, cultural, natural, scientific, scenic, recreational, archaeological, educational, and wildlife resources of the National Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9d6d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map and legal description","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780c9d6e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretary shall prepare and file a map and legal description of the National Conservation Area with the Committee on Energy and Natural Resources of the Senate and the Committee on Natural Resources of the House of Representatives."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9d6f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map and legal description prepared under paragraph (1) shall have the same force and effect as if included in this section, except that the Secretary may correct minor errors in the map or legal description.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9d70-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A copy of the map and legal description shall be on file and available for public inspection in the appropriate offices of the Bureau of Land Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9d71-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall manage the National Conservation Area—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780c9d72-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner that conserves, protects, and enhances the resources of the National Conservation Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9d73-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in accordance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780c9d74-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"43 U.S.C. 1701","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9d75-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9d76-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other applicable law; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9d77-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a component of the National Landscape Conservation System.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9d78-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Management plan","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780c9d79-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretary shall develop a management plan for the National Conservation Area."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9d7a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prepare the management plan—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id780c9d7b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/e/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation and coordination with the State of Utah, Uintah County, and affected Indian Tribes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id780c9d7c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/e/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after providing for public input.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9d7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall only allow such uses of the National Conservation Area as the Secretary determines would further the purposes for which the National Conservation is established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9d7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780c9d7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire land or interests in land within the boundaries of the National Conservation Area by purchase from a willing seller, donation, or exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9d80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incorporation in National Conservation Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any land or interest in land located inside the boundary of the National Conservation Area that is acquired by the United States after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", shall be added to and administered as part of the National Conservation Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9d81-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On request of the Utah School and Institutional Trust Lands Administration and, if practicable, not later than 5 years after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", the Secretary shall seek to acquire all State-owned land within the boundaries of the National Conservation Area by exchange or purchase, subject to the appropriation of necessary funds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9d82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motorized vehicles","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780c9d83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), except in cases in which motorized vehicles are needed for administrative purposes or to respond to an emergency, the use of motorized vehicles in the National Conservation Area shall be permitted only on roads designated in the management plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9d84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of motorized vehicles prior to completion of management plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to completion of the management plan, the use of motorized vehicles within the National Conservation Area shall be permitted in accordance with the applicable Bureau of Land Management resource management plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9d85-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grazing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The grazing of livestock in the National Conservation Area, where established before ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", shall be allowed to continue, subject to such reasonable regulations, policies, and practices as the Secretary considers to be necessary in accordance with—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id780c9d86-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicable law (including regulations);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9d87-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purposes of the National Conservation Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9d88-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the guidelines set forth in Appendix A of the report of the Committee on Interior and Insular Affairs of the House of Representatives accompanying H.R. 2570 of the 101st Congress (House Report 101–405).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9d89-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fish and wildlife","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section affects the jurisdiction of the State of Utah with respect to the management of fish and wildlife on Federal land in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9d8a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wildlife water projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the State of Utah, may authorize wildlife water projects (including guzzlers) within the National Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9d8b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Greater sage-grouse conservation projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section affects the authority of the Secretary to undertake Greater sage-grouse (Centrocercus urophasianus) conservation projects to maintain and improve Greater sage-grouse habitat, including the management of vegetation through mechanical means, to further the purposes of the National Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9d8c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water rights","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780c9d8d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/m/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constitutes an express or implied reservation by the United States of any water rights with respect to the National Conservation Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9d8e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/m/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affects any water rights in the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9d8f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/m/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affects the use or allocation, in existence on ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", of any water, water right, or interest in water;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9d90-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/m/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affects any vested absolute or decreed conditional water right in existence on ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":", including any water right held by the United States;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9d91-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/m/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affects any interstate water compact in existence on ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9d92-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/m/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be considered to be a relinquishment or reduction of any water rights reserved or appropriated by the United States in the State on or before ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9d93-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/n"},"text":null,"children":[{"tag":"num","attrib":{"value":"n"},"text":"(n)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No buffer zones","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780c9d94-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/n/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section creates a protective perimeter or buffer zone around the National Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780c9d95-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/n/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities outside National Conservation Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The fact that an authorized activity or use on land outside the National Conservation Area can be seen or heard within the National Conservation Area shall not preclude the activity or use outside the boundary of the Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9d96-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/o"},"text":null,"children":[{"tag":"num","attrib":{"value":"o"},"text":"(o)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780c9d97-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/o/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to valid existing rights, all Federal land in the National Conservation Area (including any land acquired after ","children":[{"tag":"date","attrib":{"date":"2019-03-12"},"text":"March 12, 2019","children":[],"tail":") is withdrawn from—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id780c9d98-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/o/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all forms of entry, appropriation, and disposal under the public land laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9d99-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/o/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" location, entry, and patent under the mining laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id780c9d9a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/o/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operation of the mineral leasing, mineral materials, and geothermal leasing laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9d9b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/p"},"text":null,"children":[{"tag":"num","attrib":{"value":"p"},"text":"(p)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vegetation management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section prevents the Secretary from conducting vegetation management projects, including fuels reduction activities, within the National Conservation Area that are consistent with this section and that further the purposes of the National Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9d9c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/q"},"text":null,"children":[{"tag":"num","attrib":{"value":"q"},"text":"(q)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wildland fire operations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section prohibits the Secretary, in consultation with other Federal, State, local, and Tribal agencies, as appropriate, from conducting wildland fire prevention and restoration operations in the National Conservation Area, consistent with the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9d9d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/r"},"text":null,"children":[{"tag":"num","attrib":{"value":"r"},"text":"(r)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recreation fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except for improved campgrounds, the Secretary is prohibited from collecting recreation entrance or use fees within the National Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780c9d9e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/s"},"text":null,"children":[{"tag":"num","attrib":{"value":"s"},"text":"(s)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outfitting and guide activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Outfitting and guide services within the National Conservation Area, including commercial outfitting and guide services, are authorized in accordance with this section and other applicable law (including regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780f0d9f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/t"},"text":null,"children":[{"tag":"num","attrib":{"value":"t"},"text":"(t)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal land","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780f0da0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/t/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section affects non-Federal land or interests in non-Federal land within the National Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780f0da1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/t/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasonable access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide reasonable access to non-Federal land or interests in non-Federal land within the National Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780f0da2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460cccc/u"},"text":null,"children":[{"tag":"num","attrib":{"value":"u"},"text":"(u)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and interpretive management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may establish programs and projects for the conduct of scientific, historical, cultural, archeological, and natural studies through the use of public and private partnerships that further the purposes of the National Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id780f0da3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/tI/s1118"},"text":"Pub. L. 116–9, title I, § 1118","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/627"},"text":"133 Stat. 627","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id780f0da4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id780f0da5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id780f0da6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Land Policy and Management Act of 1976, referred to in subsec. (e)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579"},"text":"Pub. L. 94–579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2743"},"text":"90 Stat. 2743","children":[],"tail":", which is classified principally to chapter 35 (§ 1701 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id780f0da7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 460cccc, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dG/tI/s121/a/2"},"text":"Pub. L. 115–141, div. G, title I, § 121(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/661"},"text":"132 Stat. 661","children":[],"tail":", which related to Ste. Genevieve National Historical Park, was transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410xxx"},"text":"section 410xxx of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id780f0da8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id780f0da9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":null},{"tag":"p","attrib":{},"text":"“Secretary” as meaning the Secretary of the Interior, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9/s2"},"text":"section 2 of Pub. L. 116–9","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
