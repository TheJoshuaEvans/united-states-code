{"tag":"section","attrib":{"id":"id7746b4a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410r–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"410r–2"},"text":"§ 410r–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lands acquired as part of park; rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All lands and submerged lands title to which is accepted by the Secretary of the Interior pursuant to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410r–1"},"text":"section 410r–1 of this title","children":[],"tail":" shall, upon the acceptance of title thereto, become parts of the Everglades National Park and shall be subject to all laws and regulations applicable thereto."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7746b4a8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/681/s2"},"text":"Pub. L. 86–681, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-02"},"text":"Sept. 2, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/577"},"text":"74 Stat. 577","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
