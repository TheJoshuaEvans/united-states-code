{"tag":"section","attrib":{"id":"id79dffcb7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3865b"},"text":"§ 3865b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural land easements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79dffcb8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall facilitate and provide funding for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79dffcb9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase by eligible entities of agricultural land easements in eligible land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dffcba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical assistance to implement the program, including technical assistance for the development of a conservation plan under subsection (b)(4)(C)(iv); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dffcbb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" buy-protect-sell transactions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79dffcbc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-share assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79dffcbd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall protect the agricultural use, including grazing, and related conservation values of eligible land through cost-share assistance to eligible entities for purchasing agricultural land easements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dffcbe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of assistance available","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79dffcbf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agreement described in paragraph (4) shall provide for a Federal share determined by the Secretary of an amount not to exceed 50 percent of the fair market value of the agricultural land easement, as determined by the Secretary using—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79dffcc0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Uniform Standards of Professional Appraisal Practice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dffcc1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an areawide market analysis or survey; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dffcc2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another industry-approved method.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffcc3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-federal share","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79dffcc4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under the agreement, the eligible entity shall provide a share that is at least equivalent to that provided by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dffcc5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grasslands exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of grassland of special environmental significance, as determined by the Secretary, the Secretary may provide an amount not to exceed 75 percent of the fair market value of the agricultural land easement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dffcc6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissible forms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The non-Federal share provided by an eligible entity under this subparagraph may comprise—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79dffcc7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/2/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cash resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dffcc8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/2/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a charitable donation or qualified conservation contribution (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s170/h"},"text":"section 170(h) of title 26","children":[],"tail":") from the private landowner from which the agricultural land easement will be purchased;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dffcc9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/2/B/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" costs associated with securing a deed to the agricultural land easement, including the cost of appraisal, survey, inspection, and title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dffcca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/2/B/iii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other costs, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dffccb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation and ranking of applications","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79dffccc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish evaluation and ranking criteria to maximize the benefit of Federal investment under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffccd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing the criteria, the Secretary shall emphasize support for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79dffcce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protecting agricultural uses and related conservation values of the land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dffccf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximizing the protection of areas devoted to agricultural use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffcd0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accounting for geographic differences","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may adjust the criteria established under subparagraph (A) to account for geographic differences, if the adjustments—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79dffcd1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the purposes of the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dffcd2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue to maximize the benefit of the Federal investment under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffcd3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In evaluating applications under the program, the Secretary may give priority to an application for the purchase of an agricultural land easement that, as determined by the Secretary, maintains agricultural viability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffcd4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bidding down","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that 2 or more applications for cost-share assistance are comparable in achieving the purpose of the program, the Secretary shall not assign a higher priority to any of those applications solely on the basis of lesser cost to the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dffcd5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements with eligible entities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79dffcd6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall enter into agreements with eligible entities to stipulate the terms and conditions under which the eligible entity is permitted to use cost-share assistance provided under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffcd7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Length of agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agreement shall be for a term that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79dffcd8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an eligible entity certified under the process described in paragraph (5), a minimum of five years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dffcd9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for all other eligible entities, at least three, but not more than five years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffcda-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum terms and conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity shall be authorized to use its own terms and conditions for agricultural land easements so long as the Secretary determines such terms and conditions—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79dffcdb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with the purposes of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dffcdc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit effective enforcement of the conservation purposes of such easements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dffcdd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include a right of enforcement for the Secretary that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79dffcde-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/C/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be used only if the terms and conditions of the easement are not enforced by the eligible entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dffcdf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/C/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not extend to a right of inspection unless—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id79dffce0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/C/iii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"subitem","attrib":{"id":"id79dffce1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/C/iii/II/aa/AA"},"text":null,"children":[{"tag":"num","attrib":{"value":"AA"},"text":"(AA)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the holder of the easement fails to provide monitoring reports in a timely manner; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subitem","attrib":{"id":"id79dffce2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/C/iii/II/aa/BB"},"text":null,"children":[{"tag":"num","attrib":{"value":"BB"},"text":"(BB)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary has a reasonable and articulable belief that the terms and conditions of the easement have been violated; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id79dffce3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/C/iii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior to the inspection, the Secretary notifies the eligible entity and the landowner of the inspection and provides a reasonable opportunity for the eligible entity and the landowner to participate in the inspection;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dffce4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a conservation plan only for any portion of the land subject to the agricultural land easement that is highly erodible cropland; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dffce5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a limit on the impervious surfaces to be allowed that is consistent with the agricultural activities to be conducted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffce6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional permitted terms and conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity may include terms and conditions for an agricultural land easement that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79dffce7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are intended to keep the land subject to the agricultural land easement under the ownership of a farmer or rancher, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dffce8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" allow subsurface mineral development on the land subject to the agricultural land easement and in accordance with applicable State law if, as determined by the Secretary—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79dffce9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the subsurface mineral development—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id79dffcea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/D/ii/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a limited and localized impact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id79dffceb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/D/ii/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not harm the agricultural use and conservation values of the land subject to the easement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id79dffcec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/D/ii/I/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not materially alter or affect the existing topography;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id79dffced-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/D/ii/I/dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"dd"},"text":"(dd)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall comply with a subsurface mineral development plan that—","children":[],"tail":null},{"tag":"subitem","attrib":{"id":"id79dffcee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/D/ii/I/dd/AA"},"text":null,"children":[{"tag":"num","attrib":{"value":"AA"},"text":"(AA)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a plan for the remediation of impacts to the agricultural use and conservation values of the land subject to the easement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subitem","attrib":{"id":"id79dffcef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/D/ii/I/dd/BB"},"text":null,"children":[{"tag":"num","attrib":{"value":"BB"},"text":"(BB)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is approved by the Secretary prior to the initiation of mineral development activity;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id79dffcf0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/D/ii/I/ee"},"text":null,"children":[{"tag":"num","attrib":{"value":"ee"},"text":"(ee)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not accomplished by any surface mining method;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id79dffcf1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/D/ii/I/ff"},"text":null,"children":[{"tag":"num","attrib":{"value":"ff"},"text":"(ff)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is within the impervious surface limits of the easement under subparagraph (C)(v); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id79dffcf2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/D/ii/I/gg"},"text":null,"children":[{"tag":"num","attrib":{"value":"gg"},"text":"(gg)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses practices and technologies that minimize the duration and intensity of impacts to the agricultural use and conservation values of the land subject to the easement; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dffcf3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each area impacted by the subsurface mineral development shall be reclaimed and restored by the holder of the mineral rights at cessation of operation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dffcf4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include other relevant activities relating to the agricultural land easement, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffcf5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substitution of qualified projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An agreement shall allow, upon mutual agreement of the parties, substitution of qualified projects that are identified at the time of the proposed substitution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffcf6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of violation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a violation occurs of a term or condition of an agreement under this subsection—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79dffcf7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may terminate the agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dffcf8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/4/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may require the eligible entity to refund all or part of any payments received by the entity under the program, with interest on the payments as determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dffcf9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of eligible entities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79dffcfa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification process","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a process under which the Secretary may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79dffcfb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly certify eligible entities that meet established criteria;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dffcfc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into long-term agreements with certified eligible entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dffcfd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/5/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept proposals for cost-share assistance for the purchase of agricultural land easements throughout the duration of such agreements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dffcfe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/5/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow a certified eligible entity to use its own terms and conditions, notwithstanding paragraph (4)(C), as long as the terms and conditions are consistent with the purposes of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffcff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to be certified, an eligible entity shall demonstrate to the Secretary that the eligible entity—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79dffd00-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" will maintain, at a minimum, for the duration of the agreement—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79dffd01-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/5/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for administering easements that is consistent with the purpose of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dffd02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/5/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capacity and resources to monitor and enforce agricultural land easements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dffd03-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/5/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" policies and procedures to ensure—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id79dffd04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/5/B/i/III/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the long-term integrity of agricultural land easements on eligible land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id79dffd05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/5/B/i/III/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" timely completion of acquisitions of such easements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id79dffd06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/5/B/i/III/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" timely and complete evaluation and reporting to the Secretary on the use of funds provided under the program;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dffd07-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79dffd08-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/5/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" been accredited by the Land Trust Accreditation Commission, or by an equivalent accrediting body, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dffd09-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/5/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquired not fewer than 10 agricultural land easements under the program or any predecessor program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dffd0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/5/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" successfully met the responsibilities of the eligible entity under the applicable agreements with the Secretary, as determined by the Secretary, relating to agricultural land easements that the eligible entity has acquired under the program or any predecessor program; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dffd0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is a State department of agriculture or other State agency with statutory authority for farm and ranchland protection that has—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79dffd0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/5/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquired not fewer than 10 agricultural land easements under the program or any predecessor program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dffd0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/5/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" successfully met the responsibilities of the eligible entity under the applicable agreements with the Secretary, as determined by the Secretary, relating to agricultural land easements that the eligible entity has acquired under the program or any predecessor program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dffd0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and revision","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79dffd0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct a review of eligible entities certified under subparagraph (A) every three years to ensure that such entities are meeting the criteria established under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dffd10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary finds that a certified eligible entity no longer meets the criteria established under subparagraph (B), the Secretary may—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79dffd11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/5/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow the certified eligible entity a specified period of time, at a minimum 180 days, in which to take such actions as may be necessary to meet the criteria; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79dffd12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/b/5/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revoke the certification of the eligible entity, if, after the specified period of time, the certified eligible entity does not meet such criteria.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79dffd13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of enrollment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall enroll eligible land under this section through the use of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79dffd14-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permanent easements; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dffd15-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" easements for the maximum duration allowed under applicable State laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79dffd16-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3865b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide technical assistance, if requested, to assist in compliance with the terms and conditions of easements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79dffd17-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1265B"},"text":"Pub. L. 99–198, title XII, § 1265B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tII/s2301/a"},"text":"Pub. L. 113–79, title II, § 2301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/734"},"text":"128 Stat. 734","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tII/s2603"},"text":"Pub. L. 115–334, title II, § 2603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4586"},"text":"132 Stat. 4586","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79dffd18-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79dffd19-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79dffd1a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2603/a/2"},"text":"Pub. L. 115–334, § 2603(a)(2)","children":[],"tail":", substituted “technical assistance to implement the program, including technical assistance for the development of a conservation plan under subsection (b)(4)(C)(iv); and” for “technical assistance to provide for the conservation of natural resources pursuant to an agricultural land easement plan.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2603/a/1"},"text":"Pub. L. 115–334, § 2603(a)(1)","children":[],"tail":", (3), added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B)(ii), (iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2603/b/1/A"},"text":"Pub. L. 115–334, § 2603(b)(1)(A)","children":[],"tail":", added cls. (ii) and (iii) and struck out former cl. (ii). Prior to amendment, text of cl. (ii) read as follows: “An eligible entity may include as part of its share under clause (i) a charitable donation or qualified conservation contribution (as defined by "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s170/h"},"text":"section 170(h) of title 26","children":[],"tail":") from the private landowner if the eligible entity contributes its own cash resources in an amount that is at least 50 percent of the amount contributed by the Secretary.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2603/b/1/B"},"text":"Pub. L. 115–334, § 2603(b)(1)(B)","children":[],"tail":", struck out subpar. (C) which related to exception to Federal and non-Federal share requirements in the case of grassland of special environmental significance and for projects of special significance."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(C) to (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2603/b/2"},"text":"Pub. L. 115–334, § 2603(b)(2)","children":[],"tail":", added subpars. (C) and (D) and redesignated former subpar. (C) as (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(C)(iii), (iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2603/b/3/A"},"text":"Pub. L. 115–334, § 2603(b)(3)(A)","children":[],"tail":", added cls. (iii) and (iv) and struck out former cls. (iii) and (iv) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iii) include a right of enforcement for the Secretary, that may be used only if the terms of the easement are not enforced by the holder of the easement;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iv) subject the land in which an interest is purchased to an agricultural land easement plan that—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(I) describes the activities which promote the long-term viability of the land to meet the purposes for which the easement was acquired;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(II) requires the management of grasslands according to a grasslands management plan; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(III) includes a conservation plan, where appropriate, and requires, at the option of the Secretary, the conversion of highly erodible cropland to less intensive uses; and”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(D) to (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2603/b/3/B"},"text":"Pub. L. 115–334, § 2603(b)(3)(B)","children":[],"tail":", (C), added subpar. (D) and redesignated former subpars. (D) and (E) as (E) and (F), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5)(A)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2603/b/4/A"},"text":"Pub. L. 115–334, § 2603(b)(4)(A)","children":[],"tail":", added cl. (iv)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2603/b/4/B"},"text":"Pub. L. 115–334, § 2603(b)(4)(B)","children":[],"tail":", substituted “eligible entity—” for “entity”, inserted cl. (i) designation before “will maintain”, redesignated former cls. (i) to (iii) as subcls. (I) to (III), respectively, of cl. (i) and subcls. (I) to (III) of former cl. (iii) as items (aa) to (cc), respectively, of subcl. (III), realigned margins, and added cl. (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2603/b/5"},"text":"Pub. L. 115–334, § 2603(b)(5)","children":[],"tail":", added subsec. (d) and struck out former subsec. (d). Prior to amendment, text read as follows: “The Secretary may provide technical assistance, if requested, to assist in—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) compliance with the terms and conditions of easements; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) implementation of an agricultural land easement plan.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
