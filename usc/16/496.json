{"tag":"section","attrib":{"id":"id782469ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s496"},"text":null,"children":[{"tag":"num","attrib":{"value":"496"},"text":"§ 496.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All funds arising from the privileges granted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s495"},"text":"section 495 of this title","children":[],"tail":" shall be covered into the Treasury of the United States as provided by law."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id782469ed-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1899-02-28/ch221/s2"},"text":"Feb. 28, 1899, ch. 221, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/908"},"text":"30 Stat. 908","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1907-03-04/ch2907"},"text":"Mar. 4, 1907, ch. 2907","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/1270"},"text":"34 Stat. 1270","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id782469ee-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id782469ef-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id782469f0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"As enacted by act ","children":[{"tag":"date","attrib":{"date":"1899-02-28"},"text":"Feb. 28, 1899","children":[],"tail":", section provided that the funds be “covered into the Treasury of the United States as a special fund, to be expended in the care of public forest reservations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was affected by act ","children":[{"tag":"date","attrib":{"date":"1907-03-04"},"text":"Mar. 4, 1907","children":[],"tail":", which provides that all revenue from the national forests shall be covered into the Treasury as a miscellaneous receipt."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
