{"tag":"section","attrib":{"id":"id77254a39-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s281f"},"text":null,"children":[{"tag":"num","attrib":{"value":"281f"},"text":"§ 281f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated the sums of not more than $2,130,000 for the acquisition of lands and interests in land and not more than $9,300,000 for construction, restoration work, and other improvements at the Nez Perce National Historical Park under this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77254a3a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/19/s7"},"text":"Pub. L. 89–19, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-05-15"},"text":"May 15, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/111"},"text":"79 Stat. 111","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/578/tII/s201/10"},"text":"Pub. L. 94–578, title II, § 201(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2733"},"text":"90 Stat. 2733","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/576/s2/7"},"text":"Pub. L. 102–576, § 2(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-30"},"text":"Oct. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4771"},"text":"106 Stat. 4771","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77254a3b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77254a3c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77254a3d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/576"},"text":"Pub. L. 102–576","children":[],"tail":" substituted “$2,130,000” for “$630,000” and “$9,300,000” for “$4,100,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/578"},"text":"Pub. L. 94–578","children":[],"tail":" substituted “$4,100,000” for “$1,337,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
