{"tag":"section","attrib":{"id":"id78a07865-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s798"},"text":null,"children":[{"tag":"num","attrib":{"value":"798"},"text":"§ 798.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose and scope of preliminary permits; transfer and cancellation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78a07866-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s798/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each preliminary permit issued under this subchapter shall be for the sole purpose of maintaining priority of application for a license under the terms of this chapter for such period or periods, not exceeding a total of 4 years, as in the discretion of the Commission may be necessary for making examinations and surveys, for preparing maps, plans, specifications, and estimates, and for making financial arrangements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78a07867-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s798/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78a07868-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s798/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extend the period of a preliminary permit once for not more than 4 additional years beyond the 4 years permitted by subsection (a) if the Commission finds that the permittee has carried out activities under such permit in good faith and with reasonable diligence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a07869-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s798/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the end of an extension period granted under paragraph (1), issue an additional permit to the permittee if the Commission determines that there are extraordinary circumstances that warrant the issuance of the additional permit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78a0786a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s798/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permit conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each such permit shall set forth the conditions under which priority shall be maintained.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78a0786b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s798/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-transferability and cancellation of permits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such permits shall not be transferable, and may be canceled by order of the Commission upon failure of permittees to comply with the conditions thereof or for other good cause shown after notice and opportunity for hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78a0786c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-10/ch285"},"text":"June 10, 1920, ch. 285","children":[],"tail":", pt. I, § 5, "},{"tag":"ref","attrib":{"href":"/us/stat/41/1067"},"text":"41 Stat. 1067","children":[],"tail":"; renumbered pt. I and amended, "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-26/ch687"},"text":"Aug. 26, 1935, ch. 687","children":[],"tail":", title II, §§ 203, 212, "},{"tag":"ref","attrib":{"href":"/us/stat/49/841"},"text":"49 Stat. 841","children":[],"tail":", 847; "},{"tag":"ref","attrib":{"href":"/us/pl/113/23/s5"},"text":"Pub. L. 113–23, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-08-09"},"text":"Aug. 9, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/495"},"text":"127 Stat. 495","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/270/tIII/s3001/a"},"text":"Pub. L. 115–270, title III, § 3001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3862"},"text":"132 Stat. 3862","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78a0786d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78a0786e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78a0786f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s3001/a/1"},"text":"Pub. L. 115–270, § 3001(a)(1)","children":[],"tail":", substituted “4 years” for “three years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s3001/a/2"},"text":"Pub. L. 115–270, § 3001(a)(2)","children":[],"tail":", inserted dash after “The Commission may”, designated remaining provisions as par. (1), substituted “4 additional years beyond the 4 years” for “2 additional years beyond the 3 years”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/23"},"text":"Pub. L. 113–23","children":[],"tail":" designated existing first, second, and third sentences as subsecs. (a), (c), and (d), respectively, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1935—Act ","children":[{"tag":"date","attrib":{"date":"1935-08-26"},"text":"Aug. 26, 1935","children":[],"tail":", § 203, amended section generally, striking out “and a license issued” at end of second sentence and inserting “or for other good cause shown after notice and opportunity for hearing” in last sentence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
