{"tag":"section","attrib":{"id":"id777194ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"410fff–6"},"text":"§ 410fff–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of wilderness within the Conservation Area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id777194ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gunnison Gorge Wilderness","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id777194ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–6/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within the Conservation Area, there is designated as wilderness, and as a component of the National Wilderness Preservation System, the Gunnison Gorge Wilderness, consisting of approximately 17,700 acres, as generally depicted on the Map.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id777194af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–6/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id777194b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–6/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wilderness study area exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The approximately 300-acre portion of the wilderness study area depicted on the Map for release from ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1782"},"text":"section 1782 of title 43","children":[],"tail":" shall not be subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1782/c"},"text":"section 1782(c) of title 43","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id777194b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–6/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incorporation into national Conservation Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The portion of the wilderness study area described in subparagraph (A) shall be incorporated into the Conservation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777194b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to valid rights in existence on ","children":[{"tag":"date","attrib":{"date":"1999-10-21"},"text":"October 21, 1999","children":[],"tail":", the wilderness areas designated under this subchapter shall be administered by the Secretary in accordance with the Wilderness Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"16 U.S.C. 1131","children":[],"tail":" et seq.) except that any reference in such provisions to the effective date of the Wilderness Act shall be deemed to be a reference to the effective date of this subchapter and any reference to the Secretary of Agriculture shall be deemed to be a reference to the Secretary of the Interior."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777194b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–6/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State responsibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As provided in section 4(d)(7) of the Wilderness Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1133/d/7"},"text":"16 U.S.C. 1133(d)(7)","children":[],"tail":"), nothing in this subchapter or in the Wilderness Act shall affect the jurisdiction or responsibilities of the State of Colorado with respect to wildlife and fish on the public land located in that State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id777194b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410fff–6/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maps and legal descriptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"1999-10-21"},"text":"October 21, 1999","children":[],"tail":", the Secretary of the Interior shall file a map and a legal description of the Gunnison Gorge Wilderness with the Committee on Energy and Natural Resources of the United States Senate and the Committee on Resources of the United States House of Representatives. This map and description shall have the same force and effect as if included in this subchapter. The Secretary of the Interior may correct clerical and typographical errors in the map and legal description. The map and legal description shall be on file and available in the office of the Director of the Bureau of Land Management (BLM)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id777194b5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/76/s8"},"text":"Pub. L. 106–76, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-21"},"text":"Oct. 21, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1130"},"text":"113 Stat. 1130","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id777194b6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id777194b7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id777194b8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Wilderness Act, referred to in subsecs. (b) and (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/577"},"text":"Pub. L. 88–577","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-09-03"},"text":"Sept. 3, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/890"},"text":"78 Stat. 890","children":[],"tail":", which is classified generally to chapter 23 (§ 1131 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"section 1131 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The effective date of the Wilderness Act, referred to in subsec. (b), means ","children":[{"tag":"date","attrib":{"date":"1964-09-03"},"text":"Sept. 3, 1964","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/88/577"},"text":"Pub. L. 88–577","children":[],"tail":", which enacted chapter 23 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The effective date of this subchapter, referred to in subsec. (b), means ","children":[{"tag":"date","attrib":{"date":"1999-10-21"},"text":"Oct. 21, 1999","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/106/76"},"text":"Pub. L. 106–76","children":[],"tail":", which enacted this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id777194b9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id777194ba-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Resources of House of Representatives changed to Committee on Natural Resources of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
