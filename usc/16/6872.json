{"tag":"section","attrib":{"id":"id7a1df12e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6872"},"text":null,"children":[{"tag":"num","attrib":{"value":"6872"},"text":"§ 6872.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency data standardization","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not later than 30 months after ","children":[{"tag":"date","attrib":{"date":"2025-12-26"},"text":"December 26, 2025","children":[],"tail":", the Secretaries, in coordination with the Federal Geographic Data Committee established by "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s2802/a"},"text":"section 2802(a) of title 43","children":[],"tail":", shall jointly develop and adopt interagency standards to ensure compatibility and interoperability among applicable Federal databases with respect to the collection and dissemination of geospatial data relating to public outdoor recreational access of Federal waterways and Federal fishing restrictions."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a1df12f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/62/s3"},"text":"Pub. L. 119–62, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-26"},"text":"Dec. 26, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1979"},"text":"139 Stat. 1979","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
