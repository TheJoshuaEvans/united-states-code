{"tag":"section","attrib":{"id":"id777fec7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410zzz–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"410zzz–5"},"text":"§ 410zzz–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated such sums, but not more than $10,632,000 for development, as may be necessary to carry out the purposes of this subchapter. For the acquisition of lands or interest therein, there is authorized to be appropriated not to exceed $2,000,000.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id777fec7e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/543/s6"},"text":"Pub. L. 88–543, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-31"},"text":"Aug. 31, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/749"},"text":"78 Stat. 749","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/578/tI/s101/10"},"text":"Pub. L. 94–578, title I, § 101(10)","children":[],"tail":", title II, § 201(7), "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2732"},"text":"90 Stat. 2732","children":[],"tail":", 2733; "},{"tag":"ref","attrib":{"href":"/us/pl/106/491/s1/2"},"text":"Pub. L. 106–491, § 1(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2209"},"text":"114 Stat. 2209","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id777fec7f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id777fec80-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id777fec81-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/491"},"text":"Pub. L. 106–491","children":[],"tail":" substituted “$10,632,000” for “$2,677,000” and “$2,000,000” for “$80,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/578/s201/7"},"text":"Pub. L. 94–578, § 201(7)","children":[],"tail":", substituted “$2,677,000” for “$210,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/578/s101/10"},"text":"Pub. L. 94–578, § 101(10)","children":[],"tail":", inserted at end “For the acquisition of lands or interest therein, there is authorized to be appropriated not to exceed $80,000.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
