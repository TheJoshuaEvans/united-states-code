{"tag":"section","attrib":{"id":"id7845d5df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s565a–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"565a–2"},"text":"§ 565a–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal employee status of cooperators","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In any agreement authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s565a–1"},"text":"section 565a–1 of this title","children":[],"tail":", cooperators and their employees may perform cooperative work under supervision of the Forest Service in emergencies or otherwise as mutually agreed to, but shall not be deemed to be Federal employees other than for the purposes of chapter 171 of title 28 and chapter 81 of title 5."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7845d5e0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/148/s2"},"text":"Pub. L. 94–148, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-12"},"text":"Dec. 12, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/804"},"text":"89 Stat. 804","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
