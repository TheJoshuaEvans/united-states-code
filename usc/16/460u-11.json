{"tag":"section","attrib":{"id":"id77cc37ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460u–11"},"text":null,"children":[{"tag":"num","attrib":{"value":"460u–11"},"text":"§ 460u–11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legal cooling, process, or surface drainage into Little Calumet River; Federal, State or local air and water pollution standards not affected","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77cc37ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460u–11/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this subchapter shall be construed as prohibiting any otherwise legal cooling, process, or surface drainage into the part of the Little Calumet River located within the Park: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That this subsection shall not affect nor in any way limit the Secretary’s authority and responsibility to protect park resources."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77cc37ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460u–11/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authorization of lands to be added to the Park by the Ninety-fourth Congress and the administration of such lands as part of the Park shall in and of itself in no way operate to render more restrictive the application of Federal, State, or local air and water pollution standards to the uses of property outside the boundaries of the Park, nor shall it be construed to augment the control of water and air pollution sources in the State of Indiana beyond that required pursuant to applicable Federal, State, or local law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77cc37f0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/761/s11"},"text":"Pub. L. 89–761, § 11","children":[],"tail":", formerly § 12, as added and renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/94/549/s1/8"},"text":"Pub. L. 94–549, § 1(8)","children":[],"tail":", (9), "},{"tag":"date","attrib":{"date":"1976-10-18"},"text":"Oct. 18, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2531"},"text":"90 Stat. 2531","children":[],"tail":", 2533; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/6/dE/tI/s115/a/1/B"},"text":"Pub. L. 116–6, div. E, title I, § 115(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-02-15"},"text":"Feb. 15, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/232"},"text":"133 Stat. 232","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77cc37f1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77cc37f2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77cc37f3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/6"},"text":"Pub. L. 116–6","children":[],"tail":" substituted “Park” for “lakeshore” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
