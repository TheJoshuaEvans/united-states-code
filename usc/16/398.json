{"tag":"section","attrib":{"id":"id773612f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s398"},"text":null,"children":[{"tag":"num","attrib":{"value":"398"},"text":"§ 398.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A portion of the Virgin Islands of the United States, containing outstanding scenic and other features of national significance, shall be established, as prescribed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s398a"},"text":"section 398a of this title","children":[],"tail":", as the “Virgin Islands National Park”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The national park shall be administered and preserved by the Secretary of the Interior in its natural condition for the public benefit and inspiration, in accordance with the laws governing the administration of the national parks.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id773612f4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-02/ch885/s1"},"text":"Aug. 2, 1956, ch. 885, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/940"},"text":"70 Stat. 940","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id773612f5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id773612f6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id773612f7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Installation of Plaque Commemorating Slave Rebellion on St. John","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dDD/tVI/s621"},"text":"Pub. L. 117–328, div. DD, title VI, § 621","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5608"},"text":"136 Stat. 5608","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dDD/tVI/s621"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":"], the Secretary [of the Interior] shall install, in an appropriate location in the area of the Ram Head trail at the peak of Ram Head in the Virgin Islands National Park on St. John, United States Virgin Islands, a suitable plaque to commemorate the slave rebellion that began on St. John on "},{"tag":"date","attrib":{"date":"1733-11-23"},"text":"November 23, 1733","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of Plaque","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plaque installed under subsection (a) shall include information regarding—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" important facts about the slave rebellion that began on St. John in 1733;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the collective suicide that occurred during the slave rebellion in the vicinity of Ram Head on St. John in 1734; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the significance of the slave rebellion to the history of St. John, the United States Virgin Islands, and the United States.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
