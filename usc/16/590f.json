{"tag":"section","attrib":{"id":"id78542d11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s590f"},"text":null,"children":[{"tag":"num","attrib":{"value":"590f"},"text":"§ 590f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations and conservation technical assistance funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78542d12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s590f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated for the purposes of this chapter such sums as Congress may from time to time determine to be necessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Appropriations for carrying out this chapter allocated for the production or procurement of nursery stock by any Federal agency, or funds appropriated to any Federal agency for allocation to cooperating States for the production or procurement of nursery stock, shall remain available for expenditure for not more than three fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78542d13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s590f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation Technical Assistance Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78542d14-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s590f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a fund to be known as the “Conservation Technical Assistance Fund” (referred to in this subsection as the “Fund”), to be administered by the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78542d15-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s590f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An amount equal to the amounts collected as fees under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s590c/4"},"text":"section 590c(4) of this title","children":[],"tail":" and late payments, interest, and such other amounts as are authorized to be collected pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3717"},"text":"section 3717 of title 31","children":[],"tail":" shall be deposited in the Fund."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78542d16-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s590f/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts in the Fund shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78542d17-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s590f/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only be available to the extent and in the amount provided in advance in appropriations Acts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78542d18-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s590f/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be used for the costs of carrying out this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78542d19-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s590f/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78542d1a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-04-27/ch85/s6"},"text":"Apr. 27, 1935, ch. 85, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/164"},"text":"49 Stat. 164","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1944-09-21/ch412"},"text":"Sept. 21, 1944, ch. 412","children":[],"tail":", title III, § 302(a), "},{"tag":"ref","attrib":{"href":"/us/stat/58/738"},"text":"58 Stat. 738","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/67/dA/tVII/s705/b"},"text":"Pub. L. 113–67, div. A, title VII, § 705(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/1193"},"text":"127 Stat. 1193","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78542d1b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78542d1c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78542d1d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/67"},"text":"Pub. L. 113–67","children":[],"tail":" inserted section catchline, designated existing provisions as subsec. (a), inserted heading, substituted “There is authorized” for “There are hereby authorized”, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1944—Act ","children":[{"tag":"date","attrib":{"date":"1944-09-21"},"text":"Sept. 21, 1944","children":[],"tail":", inserted second par."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
