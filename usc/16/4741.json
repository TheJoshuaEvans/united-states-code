Research Laboratory of the National Oceanic and Atmospheric Administration, of which $500,000 shall be made available for grants, to be competitively awarded and subject to peer review, for research relating to Lake Champlain;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f7cb21-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4741/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" $5,000,000 for competitive grants for university research on aquatic nuisance species under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4722/f/3"},"text":"section 4722(f)(3) of this title","children":[],"tail":" as follows:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f7cb22-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4741/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,800,000, which shall be made available from funds otherwise authorized to be appropriated if such funds are so authorized, to fund grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1124"},"text":"section 1124 of title 33","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f7cb23-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4741/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,200,000 to fund grants to colleges for the benefit of agriculture and the mechanic arts referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s322"},"text":"section 322 of title 7","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f7cb24-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4741/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"v