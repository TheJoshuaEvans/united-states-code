{"tag":"section","attrib":{"id":"id78863a45-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718r"},"text":null,"children":[{"tag":"num","attrib":{"value":"718r"},"text":"§ 718r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State obligations and authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78863a46-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718r/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delivery of electronic stamp","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require that each individual to whom a State sells an electronic stamp under this subchapter shall receive the electronic stamp—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78863a47-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718r/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the date of purchase of the electronic stamp; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78863a48-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718r/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner agreed upon by the State and Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78863a49-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718r/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection and transfer of electronic stamp revenue and customer information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78863a4a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718r/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to transmit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require each State authorized to issue electronic stamps to collect and submit to the Secretary in accordance with this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78863a4b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718r/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first name, last name, and complete mailing address of each individual that purchases an electronic stamp from the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78863a4c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718r/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the face value amount of each electronic stamp sold by the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78863a4d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718r/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the Federal portion of any fee required by the agreement for each stamp sold.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78863a4e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718r/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time of transmittal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require the submission under paragraph (1) to be made with respect to sales of electronic stamps by a State according to the written agreement between the Secretary and the State agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78863a4f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718r/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional fees not affected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to the State portion of any fee collected by a State under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78863a50-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718r/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic stamp issuance fee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State authorized to issue electronic stamps may charge a reasonable fee to cover costs incurred by the State and the Department of the Interior in issuing electronic stamps under this subchapter, including costs of delivery of actual stamps under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78863a51-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718r/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duplicate electronic stamps","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State authorized to issue electronic stamps may issue a duplicate electronic stamp to replace an electronic stamp issued by the State that is lost or damaged.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78863a52-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718r/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delivery of actual stamps","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue an actual stamp after March 10 of each year to each individual that purchased an electronic stamp for the preceding waterfowl season.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78863a53-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718r/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on authority to require purchase of State license","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may not require that an individual purchase a State hunting license as a condition of issuing an electronic stamp under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78863a54-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/239/s5"},"text":"Pub. L. 113–239, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2848"},"text":"128 Stat. 2848","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/25/s2/a"},"text":"Pub. L. 118–25, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-19"},"text":"Dec. 19, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/129"},"text":"137 Stat. 129","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78863a55-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78863a56-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78863a57-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/25/s2/a/1/A"},"text":"Pub. L. 118–25, § 2(a)(1)(A)","children":[],"tail":", (B), substituted “electronic stamp” for “actual stamp” in heading and “the electronic stamp” for “an actual stamp” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/25/s2/a/1/C"},"text":"Pub. L. 118–25, § 2(a)(1)(C)","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “by not later than the date on which the electronic stamp expires under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s718s/c"},"text":"section 718s(c) of this title","children":[],"tail":"; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/25/s2/a/2"},"text":"Pub. L. 118–25, § 2(a)(2)","children":[],"tail":", substituted “actual stamps under subsection (e)” for “actual stamps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/25/s2/a/3"},"text":"Pub. L. 118–25, § 2(a)(3)","children":[],"tail":", added subsec. (e) and redesignated former subsec. (e) as (f)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
