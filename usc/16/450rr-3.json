{"tag":"section","attrib":{"id":"id77a6133f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450rr–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"450rr–3"},"text":"§ 450rr–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International guidelines","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77a61340-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450rr–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator is directed to enter into consultations with the United Kingdom, France, Canada, and other interested nations to develop international guidelines for research on, exploration of, and if appropriate, salvage of the R.M.S. Titanic, which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77a61341-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450rr–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with its national and international scientific, cultural, and historical significance and the purposes of sections 450rr to 450rr–6 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77a61342-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450rr–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the safety of individuals involved in such operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77a61343-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450rr–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out subsection (a), the Administrator shall consult with the Secretary and shall promote full participation by other interested Federal agencies, academic and research institutions, and members of the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77a61344-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/513/s5"},"text":"Pub. L. 99–513, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2083"},"text":"100 Stat. 2083","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
