{"tag":"section","attrib":{"id":"id77385d33-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s402c"},"text":null,"children":[{"tag":"num","attrib":{"value":"402c"},"text":"§ 402c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Further additions to park","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Unsurveyed sections 28 and 33, township 36 south, range 3 west, and section 20, township 37 south, range 3 west, Salt Lake meridian, public lands of the United States, are added to and made a part of the Bryce Canyon National Park subject to the provisions of sections 346, 401, and 402 of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77385d34-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1928-02-25/ch102/s3"},"text":"Feb. 25, 1928, ch. 102, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/147"},"text":"45 Stat. 147","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
