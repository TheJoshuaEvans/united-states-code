{"tag":"section","attrib":{"id":"id78817ebe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s711"},"text":null,"children":[{"tag":"num","attrib":{"value":"711"},"text":"§ 711.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Breeding and sale for food supply","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to prevent the breeding of migratory game birds on farms and preserves and the sale of birds so bred under proper regulation for the purpose of increasing the food supply.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78817ebf-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1918-07-03/ch128/s12"},"text":"July 3, 1918, ch. 128, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/757"},"text":"40 Stat. 757","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
