{"tag":"section","attrib":{"id":"id7797baa6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430uu–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"430uu–4"},"text":"§ 430uu–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums not exceeding $42,500 as are necessary for the acquisition of lands and interests in land pursuant to sections 430uu to 430uu–4 of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7797baa7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/24/s5"},"text":"Pub. L. 88–24, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-05-17"},"text":"May 17, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/19"},"text":"77 Stat. 19","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/272/tI/s101/2"},"text":"Pub. L. 92–272, title I, § 101(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-04-11"},"text":"Apr. 11, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/120"},"text":"86 Stat. 120","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7797baa8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7797baa9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7797baaa-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/272"},"text":"Pub. L. 92–272","children":[],"tail":" substituted “$42,500” for “$20,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
