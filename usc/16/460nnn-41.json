{"tag":"section","attrib":{"id":"id7800b604-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–41"},"text":null,"children":[{"tag":"num","attrib":{"value":"460nnn–41"},"text":"§ 460nnn–41.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative management agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7800b605-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–41/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative efforts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To further the purposes and objectives for which the Cooperative Management and Protection Area is designated, the Secretary may work with non-Federal landowners and other parties who voluntarily agree to participate in the cooperative management of Federal and non-Federal lands in the Cooperative Management and Protection Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b606-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–41/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into a cooperative management agreement with any party to provide for the cooperative conservation and management of the Federal and non-Federal lands subject to the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b607-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–41/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other participants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With the consent of the landowners involved, the Secretary may permit permittees, special-use permit holders, other Federal and State agencies, and interested members of the public to participate in a cooperative management agreement as appropriate to achieve the resource or land use management objectives of the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b608-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–41/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal cultural site protection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into agreements with the Burns Paiute Tribe to protect cultural sites in the Cooperative Management and Protection Area of importance to the tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7800b609-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/399/tI/s121"},"text":"Pub. L. 106–399, title I, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1663"},"text":"114 Stat. 1663","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
