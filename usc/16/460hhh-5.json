{"tag":"section","attrib":{"id":"id77f71936-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"460hhh–5"},"text":"§ 460hhh–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of lands","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77f71937-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to acquire lands and interests therein within the boundaries of the Recreation Area by donation, purchase with donated or appropriated funds, exchange, or transfer from another Federal agency, except that such lands or interests owned by the State of Nevada or a political subdivision thereof may be acquired only by donation or exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f71938-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incorporation of acquired lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any lands, waters, or interests in lands or interests therein located within the Recreation Area that are acquired by the United States or administratively transferred to the Secretary after ","children":[{"tag":"date","attrib":{"date":"1993-08-04"},"text":"August 4, 1993","children":[],"tail":", shall be incorporated into the Recreation Area and managed in accordance with the laws, rules, and regulations applicable to the National Forest System and the provisions of this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77f71939-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460hhh–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land and Water Conservation Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s100506"},"text":"section 100506 of title 54","children":[],"tail":", where such boundaries are established for units of the National Forest System, such established boundaries shall be treated as if they were the boundaries of the National Forests as of "},{"tag":"date","attrib":{"date":"1965-01-01"},"text":"January 1, 1965","children":[],"tail":". Money appropriated from the Land and Water Conservation Fund shall be available for the acquisition of lands and interests therein in furtherance of the purposes of this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77f7193a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/63/s7"},"text":"Pub. L. 103–63, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-04"},"text":"Aug. 4, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/300"},"text":"107 Stat. 300","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/287/s5/d/3"},"text":"Pub. L. 113–287, § 5(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3264"},"text":"128 Stat. 3264","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77f7193b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77f7193c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77f7193d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287"},"text":"Pub. L. 113–287","children":[],"tail":", which directed substitution of “"},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100506"},"text":"section 100506 of title 54","children":[],"tail":"” for “section 460"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–9 of this title” in section 7 of the Springs Mountain National Recreation Area Act, was executed to this section, which is section 7 of the Spring Mountains National Recreation Area Act, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
