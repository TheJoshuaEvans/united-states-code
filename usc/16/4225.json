{"tag":"section","attrib":{"id":"id79ebe3d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4225"},"text":null,"children":[{"tag":"num","attrib":{"value":"4225"},"text":"§ 4225.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rewards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79ebe3d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4225/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the recommendation of the Secretary, the Secretary of the Treasury may pay a reward to any person who furnishes information which leads to a civil penalty or a criminal conviction under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ebe3d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4225/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of a reward under this section shall be equal to not more than one-half of any criminal or civil penalty or fine with respect to which the reward is paid, or $25,000, whichever is less.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ebe3d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4225/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An officer or employee of the United States or of any State or local government who furnishes information or renders service in the performance of his or her official duties shall not be eligible for a reward under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79ebe3d9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/478/tII/s2205"},"text":"Pub. L. 100–478, title II, § 2205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-07"},"text":"Oct. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2320"},"text":"102 Stat. 2320","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
