{"tag":"section","attrib":{"id":"id785b5936-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s619"},"text":null,"children":[{"tag":"num","attrib":{"value":"619"},"text":"§ 619.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency stumpage rate redeterminations in Alaska","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id785b5937-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s619/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application; applicable period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Emergency stumpage rate redetermination shall be made upon the written application of the purchaser of National Forest timber in Alaska, bid after ","children":[{"tag":"date","attrib":{"date":"1974-01-01"},"text":"January 1, 1974","children":[],"tail":", and rates established as a result thereof shall be effective for timber scaled during a period between "},{"tag":"date","attrib":{"date":"1981-01-01"},"text":"January 1, 1981","children":[],"tail":", and five years from "},{"tag":"date","attrib":{"date":"1984-10-16"},"text":"October 16, 1984","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id785b5938-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s619/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive effect of modification of contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making the emergency rate redeterminations the Secretary may modify existing contract terms, including the amount of the bid premium, in order to provide rates which will permit the holders of contracts bid after ","children":[{"tag":"date","attrib":{"date":"1974-01-01"},"text":"January 1, 1974","children":[],"tail":", to be competitive with other purchasers of National Forest timber."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id785b5939-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s619/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excepted contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section shall not apply to contracts held by the holders of 50-year timber sale contracts in Alaska.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id785b593a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/478/s4"},"text":"Pub. L. 98–478, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-16"},"text":"Oct. 16, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2217"},"text":"98 Stat. 2217","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
