{"tag":"section","attrib":{"id":"id79f09e6a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4413"},"text":null,"children":[{"tag":"num","attrib":{"value":"4413"},"text":"§ 4413.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall undertake with the appropriate officials of nations in the Western Hemisphere to establish agreements, modeled after the Plan or the Agreement, for the protection of migratory birds identified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2912/a/5"},"text":"section 2912(a)(5) of this title","children":[],"tail":". When any such agreements are reached, the Secretary shall make recommendations to the appropriate Committees on legislation necessary to implement the agreements."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79f09e6b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/233/s16/a"},"text":"Pub. L. 101–233, § 16(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-13"},"text":"Dec. 13, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1977"},"text":"103 Stat. 1977","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/308/s8/a/14"},"text":"Pub. L. 107–308, § 8(a)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2448"},"text":"116 Stat. 2448","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79f09e6c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79f09e6d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},