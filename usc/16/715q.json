{"tag":"section","attrib":{"id":"id7883c841-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s715q"},"text":null,"children":[{"tag":"num","attrib":{"value":"715q"},"text":"§ 715q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses of commission; authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A sum sufficient to pay the necessary expenses of the commission and its members, not to exceed an annual expenditure of $7,500, is authorized to be appropriated out of any money in the Treasury not otherwise appropriated. Said appropriation shall be paid out on the audit and order of the chairman of said commission, which audit and order shall be conclusive and binding upon the Government Accountability Office as to the correctness of the accounts of said commission.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7883c842-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1929-02-18/ch257/s18"},"text":"Feb. 18, 1929, ch. 257, § 18","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1225"},"text":"45 Stat. 1225","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/812"},"text":"Pub. L. 87–812","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-15"},"text":"Oct. 15, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/922"},"text":"76 Stat. 922","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7883c843-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7883c844-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7883c845-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/812"},"text":"Pub. L. 87–812","children":[],"tail":" increased annual expenditures from not more than $5,000 to not more than $7,500 and corrected a misspelling of “commission”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
