{"tag":"section","attrib":{"id":"id78863a36-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718q"},"text":null,"children":[{"tag":"num","attrib":{"value":"718q"},"text":"§ 718q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78863a37-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718q/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of application required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not authorize a State to issue electronic stamps under this subchapter unless the Secretary has received and approved an application submitted by the State in accordance with this section. The Secretary may determine the number of new States per year to participate in the electronic stamp program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78863a38-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718q/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not approve a State application unless the application contains—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78863a39-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718q/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the format of the electronic stamp that the State will issue under this subchapter, including identifying features of the licensee that will be specified on the stamp;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78863a3a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718q/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any fee the State will charge for issuance of an electronic stamp;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78863a3b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718q/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the process the State will use to account for and transfer to the Secretary the amounts collected by the State that are required to be transferred to the Secretary under the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78863a3c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718q/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner by which the State will transmit electronic stamp customer data to the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78863a3d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718q/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner by which actual stamps will be delivered;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78863a3e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718q/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the policies and procedures under which the State will issue duplicate electronic stamps; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78863a3f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718q/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other policies, procedures, and information as may be reasonably required by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78863a40-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718q/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of deadlines, eligibility requirements, and selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days before the date on which the Secretary begins accepting applications under this section, the Secretary shall publish—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78863a41-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718q/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deadlines for submission of applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78863a42-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718q/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligibility requirements for submitting applications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78863a43-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718q/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" criteria for approving applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78863a44-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/239/s4"},"text":"Pub. L. 113–239, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2848"},"text":"128 Stat. 2848","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
