{"tag":"section","attrib":{"id":"id788fd60b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s742l–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"742l–1"},"text":"§ 742l–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to use available law enforcement funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In fiscal year 2023 and hereafter of the amount available for law enforcement, up to $750,000, to remain available until expended, may at the discretion of the Secretary be used for payment for information, rewards, or evidence concerning violations of laws administered by the Service, and miscellaneous and emergency expenses of enforcement activity, authorized or approved by the Secretary and to be accounted for solely on the Secretary’s certificate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id788fd60c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74/dE/tI"},"text":"Pub. L. 112–74, div. E, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/988"},"text":"125 Stat. 988","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dG/tI"},"text":"Pub. L. 117–328, div. G, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4765"},"text":"136 Stat. 4765","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id788fd60d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id788fd60e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id788fd60f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" substituted “2023” for “2012” and “$750,000” for “$400,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
