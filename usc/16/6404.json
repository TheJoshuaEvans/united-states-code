{"tag":"section","attrib":{"id":"id7a0893ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404"},"text":null,"children":[{"tag":"num","attrib":{"value":"6404"},"text":"§ 6404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coral reef action plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a0893eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plans prepared by Federal reef managers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0893ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", and 2 years after the date of publication of each National Coral Reef Resilience Strategy, each Federal reef manager shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0893ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare a coral reef action plan to guide management and restoration activities to be undertaken within the responsibilities and jurisdiction of the manager; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0893ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a reef under the jurisdiction of a Federal reef manager for which there is an action plan in effect as of ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", update that plan to comply with the requirements of this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0893ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A plan prepared under paragraph (1) by a Federal reef manager shall include a discussion of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0893f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Short- and medium-term coral reef conservation and restoration objectives within the jurisdiction of the manager.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0893f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A current adaptive management framework to inform research, monitoring, and assessment needs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0893f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tools, strategies, and partnerships necessary to identify, monitor, and address pollution, water quality, and other negative impacts to coral reef ecosystems within the jurisdiction of the manager.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0893f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The status of efforts to improve coral reef ecosystem management cooperation and integration between Federal reef managers and covered reef managers, including the identification of existing research and monitoring activities that can be leveraged for coral reef status and trends assessments within the jurisdiction of the manager.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0893f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Estimated budgetary and resource considerations necessary to carry out the plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0893f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Contingencies for response to and recovery from emergencies and disasters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0893f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an updated plan, annual records of significant management and restoration actions taken under the previous plan, cash and noncash resources used to undertake the actions, and the source of such resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0893f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Documentation by the Federal reef manager that the plan is consistent with the National Coral Reef Resilience Strategy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0893f8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A data management plan to ensure data, assessments, and accompanying information are appropriately preserved, curated, publicly accessible, and broadly reusable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0893f9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Task Force","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Federal reef manager shall submit a plan prepared under paragraph (1) to the Task Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0893fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of Administrative Procedure Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each plan prepared under paragraph (1) shall be subject to the requirements of subchapter II of chapter 5, and chapter 7, of title 5 (commonly known as the “Administrative Procedure Act”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0893fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plans prepared by covered reef managers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0893fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A covered reef manager may elect to prepare, submit to the Task Force, and maintain a coral reef action plan to guide management and restoration activities to be undertaken within the responsibilities and jurisdiction of the manager.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0893fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A plan prepared under this subsection shall remain in effect for 5 years, or until an updated plan is submitted to the Task Force, whichever occurs first.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0893fe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A plan prepared under paragraph (1) by a covered reef manager—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0893ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall contain a discussion of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a089400-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" short- and medium-term coral reef conservation and restoration objectives within the jurisdiction of the manager;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a089401-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimated budgetary and resource considerations necessary to carry out the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a089402-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an updated plan, annual records of significant management and restoration actions taken under the previous plan, cash and noncash resources used to undertake the actions, and the source of such resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a089403-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/b/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contingencies for response to and recovery from emergencies and disasters; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a089404-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" may contain a discussion of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a089405-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of efforts to improve coral reef ecosystem management cooperation and integration between Federal reef managers and covered reef managers, including the identification of existing research and monitoring activities that can be leveraged for coral reef status and trends assessments within the jurisdiction of the manager;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a089406-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a current adaptive management framework to inform research, monitoring, and assessment needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a089407-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tools, strategies, and partnerships necessary to identify, monitor, and address pollution and water quality impacts to coral reef ecosystems within the jurisdiction of the manager; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a089408-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/b/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a data management plan to ensure data, assessments, and accompanying information are appropriately preserved, curated, publicly accessible, and broadly reusable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a089409-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator and the Task Force shall make reasonable efforts to provide technical assistance upon request by a Federal reef manager or covered reef manager developing a coral reef action plan under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a08940a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6404/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall publish each coral reef action plan prepared and submitted to the Task Force under this section on the public website of the Coral Reef Conservation Program of the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a08940b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/562/tII/s205"},"text":"Pub. L. 106–562, title II, § 205","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tC/s10001/a"},"text":"Pub. L. 117–263, div. J, title C, § 10001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3935"},"text":"136 Stat. 3935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a08940c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a08940d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a08940e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Administrative Procedure Act, referred to in subsec. (a)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-11/ch324"},"text":"act June 11, 1946, ch. 324","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/237"},"text":"60 Stat. 237","children":[],"tail":", which was classified to sections 1001 to 1011 of former Title 5, Executive Departments and Government Officers and Employees, and which was repealed and reenacted as subchapter II (§ 551 et seq.) of chapter 5, and chapter 7 (§ 701 et seq.), of Title 5, Government Organization and Employees, by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/378"},"text":"80 Stat. 378","children":[],"tail":". See Short Title note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s551"},"text":"section 551 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a08940f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6404, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/562/tII/s205"},"text":"Pub. L. 106–562, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-23"},"text":"Dec. 23, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2803"},"text":"114 Stat. 2803","children":[],"tail":", related to creation of a coral reef conservation fund, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tC/s10001/a"},"text":"Pub. L. 117–263, div. J, title C, § 10001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3931"},"text":"136 Stat. 3931","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
