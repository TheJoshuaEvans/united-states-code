{"tag":"section","attrib":{"id":"id775c3826-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410mm–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"410mm–3"},"text":"§ 410mm–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id775c3827-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410mm–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than $800,000 are authorized to be appropriated for development of the park.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id775c3828-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410mm–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than $200,000 are authorized to be appropriated for acquisition of lands and interests in land within the park.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id775c3829-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/565/s5"},"text":"Pub. L. 99–565, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3183"},"text":"100 Stat. 3183","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
