{"tag":"section","attrib":{"id":"id7a3f5b74-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8572"},"text":null,"children":[{"tag":"num","attrib":{"value":"8572"},"text":"§ 8572.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permit relief for picnic areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a3f5b75-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8572/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary concerned does not require the public to obtain a permit or reservation to access a picnic area on Federal recreational lands and waters administered by the Forest Service or the Bureau of Land Management, the Secretary concerned shall not require a covered person to obtain a permit solely to access the picnic area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3f5b76-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8572/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered person defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “covered person” means a person (including an educational group) that provides outfitting and guiding services to fewer than 40 customers per year at a picnic area described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3f5b77-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tIII/s352"},"text":"Pub. L. 118–234, title III, § 352","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2916"},"text":"138 Stat. 2916","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
