{"tag":"section","attrib":{"id":"id7877e1cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s694a"},"text":null,"children":[{"tag":"num","attrib":{"value":"694a"},"text":"§ 694a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hunting, pursuing, capturing, etc., in sanctuaries in national forests unlawful","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When such fish and game sanctuaries or refuges have been established as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s694"},"text":"section 694 of this title","children":[],"tail":", hunting, pursuing, poisoning, angling for, killing, or capturing by trapping, netting, or any other means, or attempting to hunt, pursue, angle for, kill, or capture any wild animals or fish for any purpose whatever upon the lands of the United States within the limits of said fish and game sanctuaries or refuges shall be unlawful except as hereinafter provided."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7877e1cd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-03-10/ch54/s2"},"text":"Mar. 10, 1934, ch. 54, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/400"},"text":"48 Stat. 400","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645/s16"},"text":"June 25, 1948, ch. 645, § 16","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/861"},"text":"62 Stat. 861","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7877e1ce-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7877e1cf-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7877e1d0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1948—Act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", struck out penal provisions. See "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s41"},"text":"section 41 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7877e1d1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7877e1d2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1948 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 10 of act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", provided that the amendment made by that act is effective "},{"tag":"date","attrib":{"date":"1948-09-01"},"text":"Sept. 1, 1948","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
