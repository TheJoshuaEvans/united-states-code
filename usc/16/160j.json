{"tag":"section","attrib":{"id":"id770d7bfe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s160j"},"text":null,"children":[{"tag":"num","attrib":{"value":"160j"},"text":"§ 160j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Roads accessible to public facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to make provision for such roads within the park as are, or will be, necessary to assure access from present and future State roads to public facilities within the park.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id770d7bff-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/661/s305"},"text":"Pub. L. 91–661, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-08"},"text":"Jan. 8, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1973"},"text":"84 Stat. 1973","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
