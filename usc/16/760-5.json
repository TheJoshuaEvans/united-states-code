{"tag":"section","attrib":{"id":"id78922019-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s760–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"760–5"},"text":"§ 760–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of fish hatchery at Paint Bank, Virginia","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized and directed to construct, equip, maintain, and operate a new fish hatchery in the vicinity of Paint Bank, Virginia.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7892201a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-03/ch943/s1"},"text":"Aug. 3, 1956, ch. 943, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/1020"},"text":"70 Stat. 1020","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
