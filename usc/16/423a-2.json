{"tag":"section","attrib":{"id":"id778989ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423a–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"423a–2"},"text":"§ 423a–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment of boundary","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is further authorized to adjust the boundary of the Petersburg National Battlefield through purchase, exchange, or transfer: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That in doing so the total area of the battlefield will not be increased and that such changes will become effective upon publication of the description thereof in the Federal Register by the Secretary of the Interior."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77898a00-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-09-07/ch543/s2"},"text":"Sept. 7, 1949, ch. 543, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/692"},"text":"63 Stat. 692","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/603/s1"},"text":"Pub. L. 87–603, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-08-24"},"text":"Aug. 24, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/403"},"text":"76 Stat. 403","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77898a01-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77898a02-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id77898a03-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Petersburg National Battlefield” and “battlefield” substituted in text for “Petersburg National Military Park” and “park”, respectively, in view of redesignation of Petersburg National Military Park as Petersburg National Battlefield by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/603"},"text":"Pub. L. 87–603","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s423h–1"},"text":"section 423h–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
