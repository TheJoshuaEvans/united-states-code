{"tag":"section","attrib":{"id":"id78e34d36-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1010"},"text":null,"children":[{"tag":"num","attrib":{"value":"1010"},"text":"§ 1010.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall collect and maintain data on a national and State by State basis concerning—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78e34d37-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1010/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expenditures for the individual flood control and conservation measures for which assistance is provided under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78e34d38-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1010/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expected flood control or environmental (including soil erosion) benefits that will result from the implementation of such measures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78e34d39-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-04/ch656/s13"},"text":"Aug. 4, 1954, ch. 656, § 13","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIV/s1463"},"text":"Pub. L. 101–624, title XIV, § 1463","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3615"},"text":"104 Stat. 3615","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
