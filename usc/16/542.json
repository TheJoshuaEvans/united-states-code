{"tag":"section","attrib":{"id":"id78377e54-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s542"},"text":null,"children":[{"tag":"num","attrib":{"value":"542"},"text":"§ 542.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Langmuir Research Site; establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"That in order to encourage scientific research into atmospheric processes and astronomical phenomena, and to preserve conditions necessary for that research, there is hereby established the Langmuir Research Site (hereinafter referred to as the “research site”) in the Cibola National Forest in the State of New Mexico.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7839ee55-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/550/tII/s201"},"text":"Pub. L. 96–550, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-19"},"text":"Dec. 19, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3225"},"text":"94 Stat. 3225","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
