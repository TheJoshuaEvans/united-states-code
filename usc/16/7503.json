{"tag":"section","attrib":{"id":"id7a29febe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7503"},"text":null,"children":[{"tag":"num","attrib":{"value":"7503"},"text":"§ 7503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Oceans and Coastal Security Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a29febf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator and the Foundation are authorized to establish the National Oceans and Coastal Security Fund as a tax exempt fund to further the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a29fec0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a29fec1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be deposited into the Fund amounts appropriated or otherwise made available to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29fec2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions on donations from foreign governments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No amounts donated by a foreign government, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7342"},"text":"section 7342 of title 5","children":[],"tail":", may be deposited into the Fund."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a29fec3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any amounts received by the Foundation pursuant to this chapter shall be subject to the provisions of the National Fish and Wildlife Foundation Establishment Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3701"},"text":"16 U.S.C. 3701","children":[],"tail":" et seq.), except the provisions of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a29fec4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7503/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 4(e)(1)(B) of that Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3703/e/1/B"},"text":"16 U.S.C. 3703(e)(1)(B)","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29fec5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7503/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 10(a) of that Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3709/a"},"text":"16 U.S.C. 3709(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a29fec6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7503/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amounts deposited into the Fund for each fiscal year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a29fec7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7503/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds may be used by the Foundation to award grants to coastal States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7505/b"},"text":"section 7505(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29fec8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7503/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds may be used by the Foundation to award grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7505/c"},"text":"section 7505(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29fec9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7503/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no more than 2 percent may be used by the Administrator and the Foundation for administrative expenses to carry out this chapter, which amount shall be divided between the Administrator and the Foundation pursuant to an agreement reached and documented by both the Administrator and the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a29feca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7503/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After notice and an opportunity for a hearing, the Administrator is authorized to recover any Federal payments under this section if the Foundation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a29fecb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7503/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes a withdrawal or expenditure from the Fund that is not consistent with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7504"},"text":"section 7504 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a29fecc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7503/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to comply with a procedure, measure, method, or standard established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s7505/a/1"},"text":"section 7505(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a29fecd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dO/tIX/s904"},"text":"Pub. L. 114–113, div. O, title IX, § 904","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3031"},"text":"129 Stat. 3031","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a29fece-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a29fecf-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a29fed0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Fish and Wildlife Foundation Establishment Act, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/244"},"text":"Pub. L. 98–244","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-03-26"},"text":"Mar. 26, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/107"},"text":"98 Stat. 107","children":[],"tail":", which is classified generally to chapter 57 (§ 3701 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3701"},"text":"section 3701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
