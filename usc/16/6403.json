{"tag":"section","attrib":{"id":"id7a0893b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403"},"text":null,"children":[{"tag":"num","attrib":{"value":"6403"},"text":"§ 6403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National coral reef resilience strategy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a0893ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0893bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", develop a national coral reef resilience strategy; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0893bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" review and revise the strategy—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0893bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less frequently than once every 15 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0893be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less frequently than once every 5 years, in the case of guidance on best practices under subsection (b)(4); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0893bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0893c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The strategy required by subsection (a) shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0893c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A discussion addressing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0893c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuing and emerging threats to the resilience of United States coral reef ecosystems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0893c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remaining gaps in coral reef ecosystem research, monitoring, and assessment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0893c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of management cooperation and integration among Federal reef managers and covered reef managers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0893c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of efforts to manage and disseminate critical information, and enhance interjurisdictional data sharing, related to research, reports, data sets, and maps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0893c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" areas of special focus, which may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a0893c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/b/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving natural coral recruitment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0893c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/b/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preventing avoidable losses of corals and their habitat;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0893c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/b/1/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing the resilience of coral populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0893ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/b/1/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting a resilience-based management approach;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0893cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/b/1/E/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing, coordinating, and implementing watershed management plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0893cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/b/1/E/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" building and sustaining watershed management capacity at the local level;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0893cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/b/1/E/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing data essential for coral reef fisheries management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0893ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/b/1/E/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" building capacity for coral reef fisheries management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0893cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/b/1/E/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing understanding of coral reef ecosystem services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0893d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/b/1/E/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educating the public on the importance of coral reefs, threats and solutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0893d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/b/1/E/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating intervention efficacy;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0893d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of conservation efforts, including the use of marine protected areas to serve as replenishment zones developed consistent with local practices and traditions and in cooperation with, and with respect for the scientific, technical, and management expertise and responsibilities of, covered reef managers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0893d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" science-based adaptive management and restoration efforts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0893d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" management of coral reef emergencies and disasters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0893d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A statement of national goals and objectives designed to guide—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0893d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" future Federal coral reef management and restoration activities authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6402"},"text":"section 6402 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0893d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conservation and restoration priorities for grants awarded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6410"},"text":"section 6410 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0893d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/b/2/C"},"text":null,"children":[{"tag":"num","attrib"