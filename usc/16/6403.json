"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing all elements of the strategy required by subsection (a), the Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0893dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the Secretary of the Interior, the Task Force, covered States, and covered Native entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0893dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the Secretary of Defense, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0893de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage stakeholders, including covered States, coral reef stewardship partnerships, reef research institutes and research centers described in section 6412 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title, and recipients of grants under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6410"},"text":"section 6410 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0893df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solicit public review and comment regarding scoping and the draft strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0893e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Congress; publication","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0893e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit the strategy required by subsection (a) and any revisions to the strategy to the appropriate congressional committees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0893e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" publish the strategy and any such revisions on public websites of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0893e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Coral Reef Conservation Program of the National Oceanic and Atmospheric Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0893e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6403/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Task Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"source