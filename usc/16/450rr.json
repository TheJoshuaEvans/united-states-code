{"tag":"section","attrib":{"id":"id77a61328-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450rr"},"text":null,"children":[{"tag":"num","attrib":{"value":"450rr"},"text":"§ 450rr.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" R.M.S. Titanic; international maritime memorial; findings and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77a61329-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450rr/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77a6132a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450rr/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the R.M.S. Titanic, the ocean liner which sank on her maiden voyage after striking an iceberg on ","children":[{"tag":"date","attrib":{"date":"1912-04-14"},"text":"April 14, 1912","children":[],"tail":", should be designated as an international maritime memorial to the men, women, and children who perished aboard her;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77a6132b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450rr/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recent discovery of the R.M.S. Titanic, lying more than twelve thousand feet beneath the ocean surface, demonstrates the practical applications of ocean science and engineering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77a6132c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450rr/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the R.M.S. Titanic, well preserved in the cold, oxygen-poor waters of the deep North Atlantic Ocean, is of major national and international cultural and historical significance, and merits appropriate international protection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77a6132d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450rr/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the R.M.S. Titanic represents a special opportunity for deep ocean scientific research and exploration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77a6132e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450rr/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress declares that the purposes of sections 450rr to 450rr–6 of this title are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77a6132f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450rr/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage international efforts to designate the R.M.S. Titanic as an international maritime memorial to those who lost their lives aboard her in 1912;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77a61330-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450rr/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to direct the United States to enter into negotiations with other interested nations to establish an international agreement which will provide for the designation of the R.M.S. Titanic as an international maritime memorial, and protect the scientific, cultural, and historical significance of the R.M.S. Titanic;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77a61331-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450rr/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage, in those negotiations or in other fora, the development and implementation of international guidelines for conducting research on, exploration of, and if appropriate, salvage of the R.M.S. Titanic; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77a61332-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450rr/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to express the sense of the United States Congress that, pending such international agreement or guidelines, no person should physically alter, disturb, or salvage the R.M.S. Titanic in any research or exploratory activities which are conducted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77a61333-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/513/s2"},"text":"Pub. L. 99–513, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2082"},"text":"100 Stat. 2082","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77a61334-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77a61335-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id77a61336-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/513/s1"},"text":"Pub. L. 99–513, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2082"},"text":"100 Stat. 2082","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/513/s1"},"text":"“This Act [enacting this section and sections 450rr–1 to 450rr–6 of this title] may be cited as the ‘R.M.S. Titanic Maritime Memorial Act of 1986’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
