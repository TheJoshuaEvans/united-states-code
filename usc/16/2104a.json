{"tag":"section","attrib":{"id":"id79914190-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2104a"},"text":"§ 2104a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pest and Disease Revolving Loan Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79914191-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79914192-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized equipment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79914193-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “authorized equipment” means any equipment necessary for the management of forest land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79914194-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “authorized equipment” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79914195-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cherry pickers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79914196-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" equipment necessary for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79914197-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/a/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction of staging and marshalling areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79914198-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/a/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the planting of trees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79914199-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/a/1/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the surveying of forest land;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7993b19a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vehicles capable of transporting harvested trees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7993b19b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wood chippers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7993b19c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/a/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other appropriate equipment, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7993b19d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Fund” means the Pest and Disease Revolving Loan Fund established by subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7993b19e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture, acting through the Deputy Chief of the State and Private Forestry organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7993b19f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a revolving fund, to be known as the “Pest and Disease Revolving Loan Fund”, consisting of such amounts as are appropriated to the Fund under subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7993b1a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures from Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7993b1a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), on request by the Secretary, the Secretary of the Treasury shall transfer from the Fund to the Secretary such amounts as the Secretary determines are necessary to provide loans under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7993b1a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An amount not exceeding 10 percent of the amounts in the Fund shall be available for each fiscal year to pay the administrative expenses necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7993b1a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers of amounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7993b1a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amounts required to be transferred to the Fund under this section shall be transferred at least monthly from the general fund of the Treasury to the Fund on the basis of estimates made by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7993b1a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Proper adjustment shall be made in amounts subsequently transferred to the extent prior estimates were in excess of or less than the amounts required to be transferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7993b1a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7993b1a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loans","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7993b1a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall use amounts in the Fund to provide loans to eligible units of local government to finance purchases of authorized equipment to monitor, remove, dispose of, and replace infested trees that are located—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7993b1a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on land under the jurisdiction of the eligible units of local government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7993b1aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the borders of quarantine areas infested by plant pests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7993b1ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The maximum amount of a loan that may be provided by the Secretary to an eligible unit of local government under this subsection shall be the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7993b1ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount that the eligible unit of local government has appropriated to finance purchases of authorized equipment in accordance with subparagraph (A); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7993b1ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7993b1ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The interest rate on any loan made by the Secretary under this paragraph shall be a rate equal to 2 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7993b1af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after the date on which an eligible unit of local government receives a loan provided by the Secretary under subparagraph (A), the eligible unit of local government shall submit to the Secretary a report that describes each purchase made by the eligible unit of local government using assistance provided through the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7993b1b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan repayment schedule","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7993b1b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a loan from the Secretary under paragraph (1), in accordance with each requirement described in subparagraph (B), an eligible unit of local government shall enter into an agreement with the Secretary to establish a loan repayment schedule relating to the repayment of the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7993b1b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements relating to loan repayment schedule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A loan repayment schedule established under subparagraph (A) shall require the eligible unit of local government—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7993b1b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to repay to the Secretary of the Treasury, not later than 1 year after the date on which the eligible unit of local government receives a loan under paragraph (1), and semiannually thereafter, an amount equal to the quotient obtained by dividing—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7993b1b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/e/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the principal amount of the loan (including interest); by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7993b1b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/e/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total quantity of payments that the eligible unit of local government is required to make during the repayment period of the loan; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7993b1b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 20 years after the date on which the eligible unit of local government receives a loan under paragraph (1), to complete repayment to the Secretary of the Treasury of the loan made under this section (including interest).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7993b1b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2104a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Fund such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7993b1b8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tX/s10205"},"text":"Pub. L. 110–234, title X, § 10205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1344"},"text":"122 Stat. 1344","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title X, § 10205, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2106.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7993b1b9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7993b1ba-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7993b1bb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Food, Conservation, and Energy Act of 2008, and not as part of the Cooperative Forestry Assistance Act of 1978 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7993b1bc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7993b1bd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
