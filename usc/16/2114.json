{"tag":"section","attrib":{"id":"id79962391-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2114"},"text":null,"children":[{"tag":"num","attrib":{"value":"2114"},"text":"§ 2114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79962392-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall administer this chapter in accordance with regulations that the Secretary shall develop.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79962393-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations promulgated under this chapter shall include guidelines for the administration of this chapter at the Federal and State levels and shall identify the measures and activities that are eligible for cost sharing under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79962394-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2114/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing mechanisms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Existing mechanisms shall be used to the extent possible to make payments and deliver services to the landowner under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79962395-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2114/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land grant universities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with State foresters or equivalent State officials, may provide assistance directly to other State and local natural resource management agencies and land grant universities in implementing this chapter in cases in which the State foresters or equivalent State officials are not able to make fund transfers to other State and local agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79962396-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/313/s20"},"text":"Pub. L. 95–313, § 20","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXII/s1223"},"text":"Pub. L. 101–624, title XII, § 1223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3542"},"text":"104 Stat. 3542","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
