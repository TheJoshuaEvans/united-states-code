{"tag":"section","attrib":{"id":"id789bbd59-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m"},"text":null,"children":[{"tag":"num","attrib":{"value":"777m"},"text":"§ 777m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multistate conservation grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id789bbd5a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id789bbd5b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount for grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than $3,000,000 shall be distributed to the Secretary of the Interior for making multistate conservation project grants in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789bbd5c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of availability; apportionment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id789bbd5d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts made available under paragraph (1) shall remain available for making grants only for the first fiscal year for which the amount is made available and the following fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789bbd5e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Apportionment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the end of the period of availability under subparagraph (A), the Secretary of the Interior shall apportion any amounts that remain available among the States in the manner specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s777c/c"},"text":"section 777c(c) of this title","children":[],"tail":" for use by the States in the same manner as funds apportioned under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s777c/c"},"text":"section 777c(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id789bbd5f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id789bbd60-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States or entities to be benefited","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project shall not be eligible for a grant under this section unless the project will benefit—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id789bbd61-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 26 States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789bbd62-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a majority of the States in a region of the United States Fish and Wildlife Service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789bbd63-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a regional association of State fish and game departments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789bbd64-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of submitted priority list of projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior may make grants under this section only for projects identified on a priority list of sport fish restoration projects described in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789bbd65-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority list of projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A priority list referred to in paragraph (2) is a priority list of sport fish restoration projects that the International Association of Fish and Wildlife Agencies—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id789bbd66-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prepares through a committee comprised of the heads of State fish and game departments (or their designees), in consultation with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id789bbd67-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nongovernmental organizations that represent conservation organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id789bbd68-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sportsmen organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id789bbd69-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" industries that fund the sport fish restoration programs under this chapter;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789bbd6a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approves by vote of a majority of the heads of State fish and game departments (or their designees); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789bbd6b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than October 1 of each fiscal year, submits to the Assistant Director for Wildlife and Sport Fish Restoration Programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789bbd6c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Director for Wildlife and Sport Fish Restoration Programs shall publish in the Federal Register each priority list submitted under paragraph (3)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id789bbd6d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible grantees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id789bbd6e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Interior may make a grant under this section only to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id789bbd6f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State or group of States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789bbd70-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Fish and Wildlife Service, or a State or group of States, for the purpose of carrying out the National Survey of Fishing, Hunting, and Wildlife-Associated Recreation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789bbd71-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to paragraph (2), a nongovernmental organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789bbd72-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nongovernmental organizations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id789bbd73-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any nongovernmental organization that applies for a grant under this section shall submit with the application to the International Association of Fish and Wildlife Agencies a certification that the organization—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id789bbd74-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not use the grant funds to fund, in whole or in part, any activity of the organization that promotes or encourages opposition to the regulated taking of fish; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id789bbd75-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will use the grant funds in compliance with subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789bbd76-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties for certain activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any nongovernmental organization that is found to use grant funds in violation of subparagraph (A) shall return all funds received under this section and be subject to any other applicable penalties under law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id789bbd77-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant under this section shall not be used, in whole or in part, for an activity, project, or program that promotes or encourages opposition to the regulated taking of fish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id789bbd78-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding for other activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not more than $1,200,000 of each annual appropriation made in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s777b"},"text":"section 777b of this title","children":[],"tail":" shall be distributed to the Secretary of the Interior for use as follows:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id789bbd79-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" $200,000 shall be made available for each of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id789bbd7a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Atlantic States Marine Fisheries Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789bbd7b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Gulf States Marine Fisheries Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789bbd7c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Pacific States Marine Fisheries Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789bbd7d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Great Lakes Fisheries Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789bbd7e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $400,000 shall be made available for the Sport Fishing and Boating Partnership Council established by the United States Fish and Wildlife Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789bbd7f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A portion, as determined by the Sport Fishing and Boating Partnership Council, of funds disbursed for the purposes described in paragraph (2) but remaining unobligated as of ","children":[{"tag":"date","attrib":{"date":"2021-10-01"},"text":"October 1, 2021","children":[],"tail":", shall be used to study the impact of derelict vessels and identify recyclable solutions for recreational vessels."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id789bbd80-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s777m/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability of chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 shall not apply to any activity carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id789bbd81-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-08-09/ch658/s14"},"text":"Aug. 9, 1950, ch. 658, § 14","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/408/tI/s122/a"},"text":"Pub. L. 106–408, title I, § 122(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1772"},"text":"114 Stat. 1772","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tX/s10118"},"text":"Pub. L. 109–59, title X, § 10118","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1929"},"text":"119 Stat. 1929","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/tIX/s901/r/2"},"text":"Pub. L. 109–241, title IX, § 901(r)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/566"},"text":"120 Stat. 566","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tIX/s903/a/3"},"text":"Pub. L. 111–281, title IX, § 903(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3010"},"text":"124 Stat. 3010","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tX/s10001/f"},"text":"Pub. L. 114–94, div. A, title X, § 10001(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1621"},"text":"129 Stat. 1621","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/5