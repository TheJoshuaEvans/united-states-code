{"tag":"section","attrib":{"id":"id771bd3dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230a"},"text":null,"children":[{"tag":"num","attrib":{"value":"230a"},"text":"§ 230a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id771bd3de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id771bd3df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Barataria Preserve Unit","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id771bd3e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire any land, water, and interests in land and water within the Barataria Preserve Unit by donation, purchase with donated or appropriated funds, transfer from any other Federal agency, or exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id771bd3e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id771bd3e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230a/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any non-Federal land depicted on the map described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s230"},"text":"section 230 of this title","children":[],"tail":" as “Lands Proposed for Addition” may be acquired by the Secretary only with the consent of the owner of the land."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id771bd3e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230a/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the date on which the Secretary acquires a parcel of land described in clause (i), the boundary of the Barataria Preserve Unit shall be adjusted to reflect the acquisition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id771bd3e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230a/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Easements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To ensure adequate hurricane protection of the communities located in the area, any land identified on the map described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s230"},"text":"section 230 of this title","children":[],"tail":" that is acquired or transferred shall be subject to any easements that have been agreed to by the Secretary and the Secretary of the Army."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id771bd3e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of administration jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Effective on ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", administrative jurisdiction over any Federal land within the areas depicted on the map described in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s230"},"text":"section 230 of this title","children":[],"tail":" as “Lands Proposed for Addition” is transferred, without consideration, to the administrative jurisdiction of the National Park Service, to be administered as part of the Barataria Preserve Unit."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id771bd3e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" French Quarter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire by any of the methods referred to in paragraph (1)(A) such lands and interests therein, including leasehold interests, as he may designate in the French Quarter of New Orleans for development and operation as an interpretive and administrative facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id771bd3e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of State land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Land, water, and interests in land and water owned by the State of Louisiana or any political subdivision thereof may be acquired only by donation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id771bd3e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of oil and gas rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In acquiring property pursuant to this part, the Secretary may not acquire right to oil and gas without the consent of the owner, but the exercise of such rights shall be subject to such regulations as the Secretary may promulgate in furtherance of the purposes of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id771bd3e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resource protection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to the land, water, and interests in land and water of the Barataria Preserve Unit, the Secretary shall preserve and protect—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id771bd3ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fresh water drainage patterns;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id771bd3eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vegetative cover;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id771bd3ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the integrity of ecological and biological systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id771bd3ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water and air quality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id771bd3ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjacent land","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With the consent of the owner and the parish governing authority, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id771bd3ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire land, water, and interests in land and water, by any of the methods referred to in subsection (a)(1)(A) (including use of appropriations from the Land and Water Conservation Fund); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id771bd3f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revise the boundaries of the Barataria Preserve Unit to include adjacent land and water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id771bd3f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s230a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acadian villages and towns","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to acquire lands or interests in lands by donation, purchase with donated or appropriated funds or exchange, not to exceed approximately 20 acres, in Acadian villages and towns. Any lands so acquired shall be developed, maintained and operated as part of the Jean Lafitte National Historical Park and Preserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id771bd3f2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625/tIX/s902"},"text":"Pub. L. 95–625, title IX, § 902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3535"},"text":"92 Stat. 3535","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/87/tIV/s401/q/1"},"text":"Pub. L. 96–87, title IV, § 401(q)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-12"},"text":"Oct. 12, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/666"},"text":"93 Stat. 666","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/250/s1/b"},"text":"Pub. L. 100–250, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-02-16"},"text":"Feb. 16, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/16"},"text":"102 Stat. 16","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVII/s7105/b"},"text":"Pub. L. 111–11, title VII, § 7105(b)","children":[],"tail":", (f)(2)(B), "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1191"},"text":"123 Stat. 1191","children":[],"tail":", 1193.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id771bd3f3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id771bd3f4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id771bd3f5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s7105/b/1"},"text":"Pub. L. 111–11, § 7105(b)(1)","children":[],"tail":", inserted heading, inserted par. (1) designation and heading and substituted text of par. (1) for “Within the Barataria Marsh Unit the Secretary is authorized to acquire not to exceed eight thousand six hundred acres of lands, waters, and interests therein (hereinafter referred to as the ‘core area’), as depicted on the map referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s230"},"text":"section 230 of this title","children":[],"tail":", by donation, purchase with donated or appropriated funds, or exchange.”, inserted par. (2) designation and heading and substituted “The Secretary may acquire by any of the methods referred to in paragraph (1)(A)” for “The Secretary may also acquire by any of the foregoing methods”, inserted par. (3) designation and heading and substituted “Land, water, and interests in land and water” for “Lands, waters, and interests therein”, and inserted par. (4) designation and heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s7105/b/2"},"text":"Pub. L. 111–11, § 7105(b)(2)","children":[],"tail":", added subsecs. (b) and (c) and struck out former subsecs. (b) and (c) which related to guidelines or criteria applicable to the use and development of properties within a park protection zone, and preservation and protection of certain values, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s7105/b/3"},"text":"Pub. L. 111–11, § 7105(b)(3)","children":[],"tail":", (f)(2)(B), redesignated subsec. (g) as (d) and substituted “Jean Lafitte National Historical Park and Preserve” for “Jean Lafitte National Historical Park”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s7105/b/2"},"text":"Pub. L. 111–11, § 7105(b)(2)","children":[],"tail":", struck out subsec. (d). Prior to amendment, text read as follows: “Where the State or local units of government deem it appropriate, they may cede to the Secretary, and the Secretary is authorized to accept, the power and authority to confect and enforce a program or set of rules pursuant to the guidelines established under subsection (b) of this section for the purpose of protecting the values described in subsection (c) of this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s7105/b/2"},"text":"Pub. L. 111–11, § 7105(b)(2)","children":[],"tail":", struck out subsecs. (e) and (f) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(e) The Secretary, upon the failure of the State or local units of government to enact rules pursuant to subsection (b) of this section or enforce such rules so as to protect the values enumerated in subsection (c) of this section, may acquire such lands, servitudes, or interests in lands within the park protection zone as he deems necessary to protect the values enumerated in subsection (c) of this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(f) The Secretary may revise the boundaries of the park protection zone, notwithstanding any other provision of law, to include or exclude properties, but only with the consent of Jefferson Parish.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s7105/b/3"},"text":"Pub. L. 111–11, § 7105(b)(3)","children":[],"tail":", redesignated subsec. (g) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/250"},"text":"Pub. L. 100–250","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/87"},"text":"Pub. L. 96–87","children":[],"tail":" substituted “eight thousand six hundred acres” for “eight thousand acres”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id771bd3f6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id771bd3f7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Interior, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625/s2"},"text":"section 2 of Pub. L. 95–625","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s45f"},"text":"section 45f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
