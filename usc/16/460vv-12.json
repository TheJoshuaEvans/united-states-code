{"tag":"section","attrib":{"id":"id77eb31f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vv–12"},"text":null,"children":[{"tag":"num","attrib":{"value":"460vv–12"},"text":"§ 460vv–12.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Pursuant to chapter 10 of title 5, no later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1988-10-18"},"text":"October 18, 1988","children":[],"tail":", the Secretary is directed to establish an advisory committee for Ouachita National Forest lands in Le Flore County, Oklahoma. The Committee’s purpose shall be advisory in nature and the Committee shall provide information and recommendations to the Secretary regarding the operation of the Ouachita National Forest in Le Flore County. The Committee shall be composed of representatives from the local area in which the Ouachita National Forest is located equally divided among conservation, timber, fish and wildlife, tourism and recreation, and economic development interests."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77eb31f8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/499/s14"},"text":"Pub. L. 100–499, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-18"},"text":"Oct. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2497"},"text":"102 Stat. 2497","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/91"},"text":"Pub. L. 117–286, § 4(a)(91)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4315"},"text":"136 Stat. 4315","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77eb31f9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77eb31fa-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77eb31fb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5,” for “the Federal Advisory Committee Act ("},{"tag":"ref","attrib":{"href":"/us/pl/92/463"},"text":"Public Law 92–463","children":[],"tail":"),”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77eb31fc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77eb31fd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Committees","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory committees established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of their establishment, unless, in the case of a committee established by the President or an officer of the Federal Government, such committee is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a committee established by the Congress, its duration is otherwise provided for by law. See "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"section 1013 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
