{"tag":"section","attrib":{"id":"id786285b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s667c"},"text":null,"children":[{"tag":"num","attrib":{"value":"667c"},"text":"§ 667c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of designating order","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever any real property is transferred pursuant to sections 667b to 667d of this title, the Administrator of General Services shall make and have published in the Federal Register an appropriate order, which may be revised from time to time in like manner, designating for which of the purposes specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s667b"},"text":"section 667b of this title","children":[],"tail":" the property so transferred shall be used."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id786285b9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-05-19/ch310/s2"},"text":"May 19, 1948, ch. 310, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/241"},"text":"62 Stat. 241","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title I, § 105, "},{"tag":"ref","attrib":{"href":"/us/stat/63/381"},"text":"63 Stat. 381","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id786285ba-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id786285bb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id786285bc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions, records, property, etc., of War Assets Administration transferred to General Services Administration, functions of War Assets Administrator transferred to Administrator of General Services, and War Assets Administration and office of War Assets Administrator abolished by section 105 of act ","children":[{"tag":"date","attrib":{"date":"1949-06-30"},"text":"June 30, 1949","children":[],"tail":". Transfer of functions effective "},{"tag":"date","attrib":{"date":"1949-07-01"},"text":"July 1, 1949","children":[],"tail":", see section 605, formerly § 505, of "},{"tag":"ref","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"act June 30, 1949, ch. 288","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/403"},"text":"63 Stat. 403","children":[],"tail":"; renumbered by "},{"tag":"ref","attrib":{"href":"/us/act/1950-09-05/ch849/s6/a"},"text":"act Sept. 5, 1950, ch. 849, § 6(a)","children":[],"tail":", (b), "},{"tag":"ref","attrib":{"href":"/us/stat/64/583"},"text":"64 Stat. 583","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
