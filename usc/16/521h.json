{"tag":"section","attrib":{"id":"id78294c42-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521h"},"text":null,"children":[{"tag":"num","attrib":{"value":"521h"},"text":"§ 521h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations; contents","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall issue regulations to carry out the provisions of sections 521c to 521i of this title, including specification of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78294c43-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" criteria which shall be used in making the determination as to what constitutes the public interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78294c44-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the definition of and the procedure for determining “approximately equal value”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78294c45-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" factors relating to location or size which shall be considered in connection with determining the lands to be sold, exchanged, or interchanged under clause (1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s521e"},"text":"section 521e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78294c46-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/465/s6"},"text":"Pub.