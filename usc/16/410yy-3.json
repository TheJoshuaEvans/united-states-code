{"tag":"section","attrib":{"id":"id776364ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"410yy–3"},"text":"§ 410yy–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id776364ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsections (b) and (c), the Secretary is authorized to acquire lands, or interests therein, within the boundaries of the park by donation, purchase with donated or appropriated funds, exchange, or transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776364ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Property owned by the State of Michigan or any political subdivision of the State may be acquired only by donation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id776364af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No lands or interests therein within the boundaries of the park may be acquired without the consent of the owner, unless the Secretary determines that the land is being developed, or is proposed to be developed in a manner which is detrimental to the natural, scenic, historic, and other values for which the park is established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id776364b0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/543/s4"},"text":"Pub. L. 102–543, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3570"},"text":"106 Stat. 3570","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVII/s7101/a"},"text":"Pub. L. 111–11, title VII, § 7101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1190"},"text":"123 Stat. 1190","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id776364b1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id776364b2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id776364b3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11"},"text":"Pub. L. 111–11","children":[],"tail":" struck out subsec. (d). Text read as follows: “The Secretary shall not acquire any lands pursuant to this subchapter if the Secretary determines that such lands, or any portion thereof, have become contaminated with hazardous substances (as defined in the Comprehensive Environmental Response, Compensation and Liability Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9601"},"text":"42 U.S.C. 9601","children":[],"tail":")).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
