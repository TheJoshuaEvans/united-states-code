{"tag":"section","attrib":{"id":"id77a61352-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450rr–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"450rr–6"},"text":"§ 450rr–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclaimer of extraterritorial sovereignty","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"By enactment of sections 450rr to 450rr–6 of this title, the United States does not assert sovereignty, or sovereign or exclusive rights or jurisdiction over, or the ownership of, any marine areas or the R.M.S. Titanic.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77a61353-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/513/s8"},"text":"Pub. L. 99–513, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2084"},"text":"100 Stat. 2084","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
