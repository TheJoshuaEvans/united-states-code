{"tag":"section","attrib":{"id":"id789491d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s773e"},"text":null,"children":[{"tag":"num","attrib":{"value":"773e"},"text":"§ 773e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited acts","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is unlawful—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id789491d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s773e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for any person subject to the jurisdiction of the United States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id789491d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s773e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to violate any provision of the Convention, this subchapter or any regulation adopted under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789491d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s773e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to refuse to permit any enforcement officer to board a fishing vessel subject to such person’s control for purposes of conducting any search, investigation, or inspection in connection with the enforcement of the Convention, this subchapter or any regulation adopted under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789491d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s773e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to forcibly assault, resist, oppose, impede, intimidate or interfere with any enforcement officer in the conduct of any search, investigation, or inspection described in paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789491d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s773e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to resist a lawful arrest or detention for any act prohibited by this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789491d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s773e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ship, transport, offer for sale, sell, purchase, import, export or have custody, control or possession of, any fish taken or retained in violation of the Convention, this subchapter, or any regulation adopted under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789491d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s773e/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to interfere with, delay or prevent, by any means, the apprehension, arrest or detention of another person, knowing that such person has committed any act prohibited by this section; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789491d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s773e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any foreign fishing vessel, and for the owner or operator of any foreign fishing vessel, to engage in fishing for halibut in the fishery conservation zone, unless such fishing is authorized by, and conducted in accordance with the Convention, this subchapter and regulations adopted under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id789491d9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/176/s7"},"text":"Pub. L. 97–176, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-05-17"},"text":"May 17, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/80"},"text":"96 Stat. 80","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/251/tIII/s302/b"},"text":"Pub. L. 102–251, title III, § 302(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-03-09"},"text":"Mar. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/65"},"text":"106 Stat. 65","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/81/tI/s110"},"text":"Pub. L. 114–81, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-05"},"text":"Nov. 5, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/659"},"text":"129 Stat. 659","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id789491da-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id789491db-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendment of Paragraph (2)","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/251/tIII"},"text":"Pub. L. 102–251, title III","children":[],"tail":", §§ 302(b), 308, "},{"tag":"date","attrib":{"date":"1992-03-09"},"text":"Mar. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/65"},"text":"106 Stat. 65","children":[],"tail":", 66, provided that, effective on the date on which the Agreement between the United States and the Union of Soviet Socialist Republics on the Maritime Boundary, signed "},{"tag":"date","attrib":{"date":"1990-06-01"},"text":"June 1, 1990","children":[],"tail":", enters into force for the United States, with authority to prescribe implementing regulations effective "},{"tag":"date","attrib":{"date":"1992-03-09"},"text":"Mar. 9, 1992","children":[],"tail":", but with no such regulation to be effective until the date on which the Agreement enters into force for the United States, paragraph (2), formerly subsection (b) of this section, is amended by substituting “exclusive economic zone or special areas” for “fishery conservation zone”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id789491dc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id789491dd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/81"},"text":"Pub. L. 114–81","children":[],"tail":" redesignated subsecs. (a) and (b) as pars. (1) and (2), respectively, and former pars. (1) to (6) of subsec. (a) as subpars. (A) to (F), respectively, of par. (1), inserted “, investigation,” before “or inspection” in par. (1)(B) and (C), struck out “or” after the semicolon in par. (1)(E), and substituted “section; or” for “section.” in par. (1)(F)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id789491de-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id789491df-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/251"},"text":"Pub. L. 102–251","children":[],"tail":" effective on date on which Agreement between United States and Union of Soviet Socialist Republics on the Maritime Boundary, signed "},{"tag":"date","attrib":{"date":"1990-06-01"},"text":"June 1, 1990","children":[],"tail":", enters into force for United States, with authority to prescribe implementing regulations effective "},{"tag":"date","attrib":{"date":"1992-03-09"},"text":"Mar. 9, 1992","children":[],"tail":", but with no such regulation to be effective until date on which Agreement enters into force for United States, see "},{"tag":"ref","attrib":{"href":"/us/pl/102/251/s308"},"text":"section 308 of Pub. L. 102–251","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s773"},"text":"section 773 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
