{"tag":"section","attrib":{"id":"id785b58a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s602"},"text":null,"children":[{"tag":"num","attrib":{"value":"602"},"text":"§ 602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seizure of timber cut","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any timber cut on the public lands shall be exported from the Territories of the United States, it shall be liable to seizure by United States authority wherever found.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id785b58a9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1878-04-30/ch76/s2"},"text":"Apr. 30, 1878, ch. 76, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/20/46"},"text":"20 Stat. 46","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
