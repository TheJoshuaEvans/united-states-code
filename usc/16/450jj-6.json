{"tag":"section","attrib":{"id":"id77a3c8ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"450jj–6"},"text":"§ 450jj–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jefferson National Expansion Memorial Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77a3c8ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established the Jefferson National Expansion Memorial ","children":[{"tag":"ref","attrib":{"idref":"fn002267"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002267"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Change of Name note below."}],"tail":" Commission (hereinafter in sections 450jj–6 to 450jj–9 of this title referred to as the “Commission”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77a3c8af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall be composed of twenty members as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77a3c8b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The county executive of Saint Louis County, Missouri, ex officio, or a delegate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77a3c8b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chairman of the Saint Clair County Board of Supervisors, Illinois, ex officio, or a delegate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77a3c8b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77a3c8b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The executive director of the Bi-State Development Agency, Saint Louis, Missouri, ex officio, or a delegate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77a3c8b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Bi-State Development Agency, Saint Louis, Missouri, who is not a resident of the same State as the executive director of such agency, appointed by a majority of the members of such agency, or a delegate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77a3c8b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The mayor of the city of East Saint Louis, Illinois, ex officio, or a delegate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77a3c8b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The mayor of Saint Louis, Missouri, ex officio, or a delegate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77a3c8b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Governor of the State of Illinois, ex officio, or a delegate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77a3c8b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Governor of the State of Missouri, ex officio, or a delegate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77a3c8b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Interior, ex officio, or a delegate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77a3c8ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Housing and Urban Development, ex officio, or a delegate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77a3c8bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation, ex officio, or a delegate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77a3c8bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury, ex officio, or a delegate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77a3c8bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Commerce, ex officio, or a delegate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77a3c8be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Smithsonian Institution, ex officio, or a delegate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77a3c8bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/b/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three individuals appointed by the Secretary of the Interior from a list of individuals nominated by the mayor of East Saint Louis, Illinois, and the Governor of the State of Illinois.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77a3c8c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/b/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three individuals appointed by the Secretary of the Interior from a list of individuals nominated by the mayor of Saint Louis, Missouri, and the Governor of the State of Missouri.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Individuals nominated for appointment under paragraphs (14) and (15) shall be individuals who have knowledge and experience in one or more of the fields of parks and recreation, environmental protection, historic preservation, cultural affairs, tourism, economic development, city planning and management, finance, or public administration. A vacancy in the Commission shall be filled in the manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77a3c8c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of office of members","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77a3c8c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraphs (2) and (3), members of the Commission shall be appointed for terms of three years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77a3c8c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Of the members of the Commission first appointed under paragraphs (14) and (15) of subsection (c)— ","children":[{"tag":"ref","attrib":{"idref":"fn002268"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002268"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “subsection (b)—”."}],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77a3c8c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two shall be appointed for terms of one year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77a3c8c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two shall be appointed for terms of two years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77a3c8c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two shall be appointed for terms of three years;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"as designated by the Secretary of the Interior at the time of appointment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77a3c8c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any member of the Commission appointed to fill a vacancy occurring before the expiration of the term for which his predecessor was appointed shall be appointed only for the remainder of such term. A member of the Commission may serve after the expiration of his term until his successor has taken office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77a3c8c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation of members; travel expenses and per diem","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Commission shall receive no pay on account of their service on the Commission, but while away from their homes or regular places of business in the performance of services for the Commission, members of the Commission shall be allowed travel expenses, including per diem in lieu of subsistence, in the same manner as persons employed intermittently in the Government service are allowed expenses under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77a3c8c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chairperson of the Commission shall be elected by the members of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77a3c8ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance from Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon request of the Commission, the head of any Federal agency represented by members on the Commission may detail any of the personnel or ","children":[{"tag":"ref","attrib":{"idref":"fn002269"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002269"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be “of”."}],"tail":" such agency, or provide administrative services to the Commission to assist the Commission in carrying out the Commission’s duties under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s450jj–7"},"text":"section 450jj–7 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77a3c8cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gifts, bequests, or donations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may, for the purposes of carrying out the Commission’s duties under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s450jj–7"},"text":"section 450jj–7 of this title","children":[],"tail":", seek, accept, and dispose of gifts, bequests, or donations of money, personal property, or services, received from any source."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77a3c8cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination; extension","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77a3c8cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), the Commission shall terminate on the day occurring ten years after ","children":[{"tag":"date","attrib":{"date":"1984-08-24"},"text":"August 24, 1984","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77a3c8ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450jj–6/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Interior may extend the life of the Commission for a period of not more than five years beginning on the day referred to in paragraph (1) if the Commission determines that such extension is necessary in order for the Commission to carry out sections 450jj to 450jj–9 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77a3c8cf-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-05-17/ch204/s7"},"text":"May 17, 1954, ch. 204, § 7","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/398/tII/s201/a"},"text":"Pub. L. 98–398, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-24"},"text":"Aug. 24, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1469"},"text":"98 Stat. 1469","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77a3c8d0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77a3c8d1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id77a3c8d2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Jefferson National Expansion Memorial redesignated Gateway Arch National Park by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/128/s2"},"text":"Pub. L. 115–128, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-22"},"text":"Feb. 22, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/328"},"text":"132 Stat. 328","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s450jj–10"},"text":"section 450jj–10 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
