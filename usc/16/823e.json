{"tag":"section","attrib":{"id":"id78a533c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e"},"text":null,"children":[{"tag":"num","attrib":{"value":"823e"},"text":"§ 823e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promoting hydropower development at existing nonpowered dams","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78a533c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited licensing process for non-Federal hydropower projects at existing nonpowered dams","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78a533c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As provided in this section, the Commission may issue and amend licenses, as appropriate, for any facility the Commission determines is a qualifying facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a533c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2018-10-23"},"text":"October 23, 2018","children":[],"tail":", the Commission shall issue a rule establishing an expedited process for issuing and amending licenses for qualifying facilities under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a533c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency task force","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78a533c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In establishing the expedited process under this section, the Commission shall convene an interagency task force, with appropriate Federal and State agencies and Indian tribes represented, to coordinate the regulatory processes associated with the authorizations required to construct and operate a qualifying facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a533c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The task force shall develop procedures that are consistent with subsection (e)(1)(E) to seek to ensure that, for projects licensed pursuant to this section, the Commission and appropriate Federal and State agencies and Indian tribes shall exercise their authorities in a manner that, to the extent practicable, will not result in any material change to the storage, release, or flow operations of the associated nonpowered dam existing at the time an applicant files its license application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a533c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Length of process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall seek to ensure that the expedited process under this section will result in a final decision on an application for a license by not later than 2 years after receipt of a completed application for the license.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78a533c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dam safety","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78a533ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before issuing any license for a qualifying facility, the Commission shall assess the safety of existing non-Federal dams and other non-Federal structures related to the qualifying facility (including possible consequences associated with failure of such structures).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a533cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In issuing any license for a qualifying facility at a non-Federal dam, the Commission shall ensure that the Commission’s dam safety requirements apply to such qualifying facility, and the associated qualifying nonpowered dam, over the term of such license.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78a533cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency communications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Interagency cooperation in the preparation of environmental documents under the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.) with respect to an application for a license for a qualifying facility under this section, and interagency communications relating to licensing process coordination pursuant to this section, shall not—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id78a533cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be considered to be ex parte communications under Commission rules; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a533ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preclude an agency from participating in a licensing proceeding under this subchapter, providing that any agency participating as a party in a licensing proceeding under this subchapter shall, to the extent practicable, demonstrate a separation of staff cooperating with the Commission under the National Environmental Policy Act ","children":[{"tag":"ref","attrib":{"idref":"fn002526"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002526"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “of 1969”."}],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.) and staff participating in the applicable proceeding under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78a533cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of nonpowered dams for hydropower development","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78a533d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 12 months after ","children":[{"tag":"date","attrib":{"date":"2018-10-23"},"text":"October 23, 2018","children":[],"tail":", the Commission, with the Secretary of the Army, the Secretary of the Interior, and the Secretary of Agriculture, shall jointly develop a list of existing nonpowered Federal dams that the Commission and the Secretaries agree have the greatest potential for non-Federal hydropower development."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a533d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the list under paragraph (1), the Commission and the Secretaries may consider the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78a533d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The compatibility of hydropower generation with existing purposes of the dam.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a533d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The proximity of the dam to existing transmission resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a533d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The existence of studies to characterize environmental, cultural, and historic resources relating to the dam.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a533d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The effects of hydropower development on release or flow operations of the dam.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a533d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78a533d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide the list developed under paragraph (1) to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78a533d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Commerce, the Committee on Transportation and Infrastructure, and the Committee on Natural Resources, of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78a533d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Environment and Public Works, and the Committee on Energy and Natural Resources, of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a533da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make such list available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78a533db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78a533dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualifying criteria” means, with respect to a facility—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78a533dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as of ","children":[{"tag":"date","attrib":{"date":"2018-10-23"},"text":"October 23, 2018","children":[],"tail":", the facility is not licensed under, or exempted from the license requirements contained in, this subchapter;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a533de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the facility will be associated with a qualifying nonpowered dam;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a533df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the facility will be constructed, operated, and maintained for the generation of electric power;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a533e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the facility will use for such generation any withdrawals, diversions, releases, or flows from the associated qualifying nonpowered dam, including its associated impoundment or other infrastructure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a533e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operation of the facility will not result in any material change to the storage, release, or flow operations of the associated qualifying nonpowered dam.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a533e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualifying facility” means a facility that is determined under this section to meet the qualifying criteria.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a533e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying nonpowered dam","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualifying nonpowered dam” means any dam, dike, embankment, or other barrier—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78a533e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction of which was completed on or before ","children":[{"tag":"date","attrib":{"date":"2018-10-23"},"text":"October 23, 2018","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a533e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is or was operated for the control, release, or distribution of water for agricultural, municipal, navigational, industrial, commercial, environmental, recreational, aesthetic, drinking water, or flood control purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a7a3e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that, as of ","children":[{"tag":"date","attrib":{"date":"2018-10-23"},"text":"October 23, 2018","children":[],"tail":", is not generating electricity with hydropower generating works that are licensed under, or exempted from the license requirements contained in, this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78a7a3e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings clause","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section affects—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78a7a3e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any authority of the Commission to license a facility at a nonpowered dam under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a7a3e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s823e/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any authority of the Commission to issue an exemption to a small hydroelectric power project under the Public Utility Regulatory Policies Act of 1978.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78a7a3ea-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-10/ch285"},"text":"June 10, 1920, ch. 285","children":[],"tail":", pt. I, § 34, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/270/tIII/s3003"},"text":"Pub. L. 115–270, title III, § 3003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3863"},"text":"132 Stat. 3863","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78a7a3eb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78a7a3ec-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78a7a3ed-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Public Utility Regulatory Policies Act of 1978, referred to in subsec. (f)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617"},"text":"Pub. L. 95–617","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3117"},"text":"92 Stat. 3117","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2601"},"text":"section 2601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
