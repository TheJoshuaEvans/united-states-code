{"tag":"section","attrib":{"id":"id77898a04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423a–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"423a–3"},"text":"§ 423a–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petersburg National Battlefield boundary modification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77898a05-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423a–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The boundary of the Petersburg National Battlefield is modified to include the land and interests in land as generally depicted on the map titled “Petersburg National Battlefield Proposed Boundary Expansion”, numbered 325/80,080, and dated June 2007/March 2016. The map shall be on file and available for public inspection in the appropriate offices of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77898a06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423a–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of properties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77898a07-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423a–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior (referred to in this section as the “Secretary”) is authorized to acquire the land and interests in land described in subsection (a) from willing sellers only, by donation, purchase with donated or appropriated funds, exchange, or transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77898a08-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423a–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77898a09-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423a–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall administer any land or interests in land acquired under subsection (b) as part of the Petersburg National Battlefield in accordance with applicable laws and regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77898a0a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423a–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative jurisdiction transfer","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77898a0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423a–3/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is transferred—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77898a0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423a–3/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the Secretary to the Secretary of the Army administrative jurisdiction over the approximately 1.170-acre parcel of land depicted as “Area to be transferred to Fort Lee Military Reservation” on the map described in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77898a0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423a–3/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the Secretary of the Army to the Secretary administrative jurisdiction over the approximately 1.171-acre parcel of land depicted as “Area to be transferred to Petersburg National Battlefield” on the map described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77898a0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423a–3/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The parcels of land described in paragraph (1) are depicted on the map titled “Petersburg National Battlefield Proposed Transfer of Administrative Jurisdiction”, numbered 325/80,801A, dated May 2011/March 2016. The map shall be on file and available for public inspection in the appropriate offices of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77898a0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423a–3/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions of transfer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The transfer of administrative jurisdiction under paragraph (1) is subject to the following conditions:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77898a10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423a–3/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No reimbursement or consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The transfer shall be without reimbursement or consideration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77898a11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423a–3/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77898a12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423a–3/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land transferred to the Secretary of the Army","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The land transferred to the Secretary of the Army under paragraph (1)(A) shall be excluded from the boundary of the Petersburg National Battlefield.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77898a13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423a–3/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land transferred to the Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The land transferred to the Secretary under paragraph (1)(B)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id77898a14-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423a–3/d/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be included within the boundary of the Petersburg National Battlefield; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id77898a15-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s423a–3/d/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be administered as part of Petersburg National Battlefield in accordance with applicable laws and regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77898a16-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dB/tXXVIII/s2834"},"text":"Pub. L. 114–328, div. B, title XXVIII, § 2834","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2740"},"text":"130 Stat. 2740","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77898a17-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77898a18-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77898a19-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p