{"tag":"section","attrib":{"id":"id7a382fed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8441"},"text":null,"children":[{"tag":"num","attrib":{"value":"8441"},"text":"§ 8441.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gateway communities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a382fee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8441/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of impacts and needs in gateway communities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretaries—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a382fef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8441/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall collaborate with State and local governments, Indian Tribes, housing authorities, applicable trade associations, nonprofit organizations, private entities, and other relevant stakeholders to identify needs and economic impacts in gateway communities, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a382ff0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8441/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" housing shortages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a382ff1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8441/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demands on existing municipal infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a382ff2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8441/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accommodation and management of sustainable visitation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a382ff3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8441/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the expansion and diversification of visitor experiences by bolstering the visitation at—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a382ff4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8441/a/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing developed locations that are underutilized on nearby Federal recreational lands and waters that are suitable for developing, expanding, or enhancing recreation use, as identified by the Secretaries; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a382ff5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8441/a/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing developed and suitable lesser-known recreation sites, as identified under section 5(b)(1)(B),","children":[{"tag":"ref","attrib":{"idref":"fn002873"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002873"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" on nearby land managed by a State agency or a local agency; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a382ff6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8441/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may address a need identified under paragraph (1) by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a382ff7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8441/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing financial or technical assistance to a gateway community under an existing program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a382ff8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8441/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entering into an agreement, right-of-way, or easement, in accordance with applicable laws; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a382ff9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8441/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issuing an entity referred to in paragraph (1) a special use permit (other than a special recreation permit (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6801"},"text":"section 6801 of this title","children":[],"tail":"), in accordance with applicable laws."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a382ffa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8441/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical and financial assistance to businesses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a382ffb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8441/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture (acting through the Administrator of the Rural Business-Cooperative Service), in coordination with the Secretary and the Secretary of Commerce, shall provide to businesses in gateway communities the assistance described in paragraph (2) to establish, operate, or expand infrastructure to accommodate and manage sustainable visitation, including hotels, campgrounds, and restaurants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a382ffc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8441/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture may provide assistance under paragraph (1) through the use of existing, or the establishment of new, entrepreneur and vocational training programs, technical assistance programs, low-interest business loan programs, and loan guarantee programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a382ffd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8441/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretaries may, in accordance with applicable laws, enter into a public-private partnership, cooperative agreement, memorandum of understanding, or similar agreement with a gateway community or a business in a gateway community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a382ffe-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tI/s131"},"text":"Pub. L. 118–234, title I, § 131","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2858"},"text":"138 Stat. 2858","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a382fff-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a383000-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a383001-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 5(b)(1)(B), referred to in subsec. (a)(1)(D)(ii), probably means ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s8442/b/1/B"},"text":"section 8442(b)(1)(B) of this title","children":[],"tail":". Section 5(b)(1)(B) probably referred to section 5(b)(1)(B) of H.R. 3200 introduced in the House in the 118th Congress on "},{"tag":"date","attrib":{"date":"2023-05-10"},"text":"May 10, 2023","children":[],"tail":". A later version of H.R. 3200 was enacted as subtitle C of title I of "},{"tag":"ref","attrib":{"href":"/us/pl/118/234"},"text":"Pub. L. 118–234","children":[],"tail":", and, as enacted, does not contain a section 5. However, "},{"tag":"ref","attrib":{"href":"/us/pl/118/234/s132/b/1/B"},"text":"section 132(b)(1)(B) of Pub. L. 118–234","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s8442/b/1/B"},"text":"section 8442(b)(1)(B) of this title","children":[],"tail":", contains provisions identical to those in section 5(b)(1)(B) of H.R. 3200."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
