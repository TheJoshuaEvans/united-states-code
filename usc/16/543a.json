{"tag":"section","attrib":{"id":"id7839ee77-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s543a"},"text":null,"children":[{"tag":"num","attrib":{"value":"543a"},"text":"§ 543a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of National Forest boundary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7839ee78-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s543a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The exterior boundary of the Inyo National Forest is hereby extended to include the area within the boundary of the Scenic Area. Any lands and interests therein acquired pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s543b"},"text":"section 543b of this title","children":[],"tail":" shall become part of the National Forest System."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7839ee79-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s543a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s200306/a/2"},"text":"section 200306(a)(2) of title 54","children":[],"tail":", the boundary of the Inyo National Forest, as modified by this section, shall be treated as if it were the boundary of that forest on "},{"tag":"date","attrib":{"date":"1964-01-01"},"text":"January 1, 1964","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7839ee7a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/425/tIII/s302"},"text":"Pub. L. 98–425, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1633"},"text":"98 Stat. 1633","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7839ee7b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7839ee7c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7839ee7d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s200306/a/2"},"text":"section 200306(a)(2) of title 54","children":[],"tail":"” substituted for “section 7(a)(1) of the Land and Water Conservation Fund Act of 1965 ("},{"tag":"ref","attrib":{"href":"/us/stat/78/897"},"text":"78 Stat. 897","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4601–4"},"text":"16 U.S.C. 4601–4","children":[],"tail":" through 4601–11) [sic]” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/113/287/s6/e"},"text":"Pub. L. 113–287, § 6(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3272"},"text":"128 Stat. 3272","children":[],"tail":", which Act enacted Title 54, National Park Service and Related Programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
