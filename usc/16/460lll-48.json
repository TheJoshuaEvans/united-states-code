{"tag":"section","attrib":{"id":"id77fe44c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460lll–48"},"text":null,"children":[{"tag":"num","attrib":{"value":"460lll–48"},"text":"§ 460lll–48.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tennessee Valley Authority transfer costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any costs incurred by Tennessee Valley Authority associated with the transfer under this part shall be derived from funding described in section 460","children":[{"tag":"i","attrib":{},"text":"lll","children":[],"tail":"–49 of this title."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77fe44c2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tV/s548"},"text":"Pub. L. 105–277, div. A, § 101(e) [title V, § 548]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–325.)"}],"tail":"\n"}],"tail":null}
