{"tag":"section","attrib":{"id":"id793dca06-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1457"},"text":null,"children":[{"tag":"num","attrib":{"value":"1457"},"text":"§ 1457.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All public hearings required under this chapter must be announced at least thirty days prior to the hearing date. At the time of the announcement, all agency materials pertinent to the hearings, including documents, studies, and other data, must be made available to the public for review and study. As similar materials are subsequently developed, they shall be made available to the public as they become available to the agency.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id793dca07-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/454/tIII/s311"},"text":"Pub. L. 89–454, title III, § 311","children":[],"tail":", formerly § 308, as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/583"},"text":"Pub. L. 92–583","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1287"},"text":"86 Stat. 1287","children":[],"tail":"; renumbered § 311, "},{"tag":"ref","attrib":{"href":"/us/pl/94/370/s7"},"text":"Pub. L. 94–370, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-26"},"text":"July 26, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1019"},"text":"90 Stat. 1019","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
