{"tag":"section","attrib":{"id":"id7a3a9fd9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463"},"text":null,"children":[{"tag":"num","attrib":{"value":"8463"},"text":"§ 8463.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay-for-performance projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a3a9fda-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3a9fdb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent evaluator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “independent evaluator” means an individual or entity, including an institution of higher education, that is selected by the pay-for-performance beneficiary and pay-for-performance investor, as applicable, or by the pay-for-performance project developer, in consultation with the Secretary of Agriculture, to make the determinations and prepare the reports required under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3a9fdc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Forest System land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National Forest System land” means land in the National Forest System (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1609/a"},"text":"section 1609(a) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3a9fdd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay-for-performance agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “pay-for-performance agreement” means a mutual benefit agreement (excluding a procurement contract, grant agreement, or cooperative agreement described in chapter 63 of title 31) for a pay-for-performance project—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3a9fde-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with a term of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a3a9fdf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 1 year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3a9fe0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 20 years; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3a9fe1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that is executed, in accordance with applicable law, by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a3a9fe2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3a9fe3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a pay-for-performance beneficiary or pay-for-performance project developer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3a9fe4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay-for-performance beneficiary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “pay-for-performance beneficiary” means a State or local government, an Indian Tribe, or a nonprofit or for-profit organization that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3a9fe5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repays capital loaned upfront by a pay-for-performance investor, based on a project outcome specified in a pay-for-performance agreement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3a9fe6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides capital directly for costs associated with a pay-for-performance project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3a9fe7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay-for-performance investor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “pay-for-performance investor” means a State or local government, an Indian Tribe, or a nonprofit or for-profit organization that provides upfront loaned capital for a pay-for-performance project with the expectation of a financial return dependent on a project outcome.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3a9fe8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay-for-performance project","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “pay-for-performance project” means a project that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3a9fe9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would provide or enhance a recreational opportunity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3a9fea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is conducted on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a3a9feb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/a/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National Forest System land; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3a9fec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/a/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other land, if the activities would benefit National Forest System land (including a recreational use of National Forest System land); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3a9fed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" would use an innovative funding or financing model that leverages—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a3a9fee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/a/6/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" loaned capital from a pay-for-performance investor to cover upfront costs associated with a pay-for-performance project, with the loaned capital repaid by a pay-for-performance beneficiary at a rate of return dependent on a project outcome, as measured by an independent evaluator; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3a9fef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/a/6/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capital directly from a pay-for-performance beneficiary to support costs associated with a pay-for-performance project in an amount based on an anticipated project outcome.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3a9ff0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay-for-performance project developer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “pay-for-performance project developer” means a nonprofit or for-profit organization that serves as an intermediary to assist in developing or implementing a pay-for-performance agreement or a pay-for-performance project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3a9ff1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project outcome","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “project outcome” means a measurable, beneficial result (whether economic, environmental, or social) that is attributable to a pay-for-performance project and described in a pay-for-performance agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3a9ff2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of pilot program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall establish a pilot program in accordance with this section to carry out 1 or more pay-for-performance projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3a9ff3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay-for-performance projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3a9ff4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Using funds made available through a pay-for-performance agreement or appropriations, all or any portion of a pay-for-performance project may be implemented by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3a9ff5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3a9ff6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a pay-for-performance project developer or a third party, subject to the conditions that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a3a9ff7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture shall approve the implementation by the pay-for-performance project developer or third party; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3a9ff8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation is in accordance with applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3a9ff9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to land management plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A pay-for-performance project carried out under this section shall be consistent with any applicable land management plan developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1604"},"text":"section 1604 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3a9ffa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ownership","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3a9ffb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New improvements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States shall have title to any improvements installed on National Forest System land as part of a pay-for-performance project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3a9ffc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing improvements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Investing in, conducting, or completing a pay-for-performance project on National Forest System land shall not affect the title of the United States to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a3a9ffd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any federally owned improvements involved in the pay-for-performance project; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3a9ffe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the underlying land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3a9fff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings clause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The carrying out of any action for a pay-for-performance project does not provide any right to any party to a pay-for-performance agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa000-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Potential conflicts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before approving a pay-for-performance project under this section, the Secretary of Agriculture shall consider and seek to avoid potential conflicts (including economic competition) with any existing written authorized use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3aa001-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3aa002-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the Act of ","children":[{"tag":"date","attrib":{"date":"1914-06-30"},"text":"June 30, 1914","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/38/430"},"text":"38 Stat. 430","children":[],"tail":", chapter 131; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s498"},"text":"16 U.S.C. 498","children":[],"tail":"), or subtitle C of title XX of the Social Security Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397n"},"text":"42 U.S.C. 1397n","children":[],"tail":" et seq.), in carrying out the pilot program under this section, the Secretary of Agriculture may enter into a pay-for-performance agreement under which a pay-for-performance beneficiary, pay-for-performance investor, or pay-for-performance project developer agrees to pay for or finance all or part of a pay-for-performance project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa003-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Size limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture may not enter into a pay-for-performance agreement under the pilot program under this section for a pay-for-performance project valued at more than $15,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa004-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financing","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3aa005-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A pay-for-performance agreement shall specify the amounts that a pay-for-performance beneficiary or a pay-for-performance project developer agrees to pay to a pay-for-performance investor or a pay-for-performance project developer, as appropriate, in the event of an independent evaluator determining pursuant to subsection (e) the degree to which a project outcome has been achieved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa006-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An amount described in subparagraph (A) shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a3aa007-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" based on—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a3aa008-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the respective contributions of the parties under the pay-for-performance agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a3aa009-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economic, environmental, or social benefits derived from the project outcomes; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3aa00a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a3aa00b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a percentage of the estimated value of a project outcome;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a3aa00c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a percentage of the estimated cost savings to the pay-for-performance beneficiary or the Secretary of Agriculture derived from a project outcome;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a3aa00d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d/3/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a percentage of the enhanced revenue to the pay-for-performance beneficiary or the Secretary of Agriculture derived from a project outcome; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a3aa00e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d/3/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a percentage of the cost of the pay-for-performance project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa00f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forest service financial assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations, the Secretary of Agriculture may contribute funding for a pay-for-performance project only if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a3aa010-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary of Agriculture demonstrates that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a3aa011-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d/3/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the pay-for-performance project would provide a cost savings to the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a3aa012-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d/3/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funding would accelerate the pace of implementation of an activity previously planned to be completed by the Secretary of Agriculture; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a3aa013-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d/3/C/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funding would accelerate the scale of implementation of an activity previously planned to be completed by the Secretary of Agriculture; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3aa014-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contribution of the Secretary of Agriculture has a value that is not more than 50 percent of the total cost of the pay-for-performance project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa015-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special account","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any funds received by the Secretary of Agriculture under subsection (c)(1)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a3aa016-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be retained in a separate fund in the Treasury to be used solely for pay-for-performance projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3aa017-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall remain available until expended and without further appropriation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa018-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance and decommissioning of pay-for-performance project improvements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A pay-for-performance agreement shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3aa019-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a plan for maintaining any capital improvement constructed as part of a pay-for-performance project after the date on which the pay-for-performance project is completed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa01a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" specify the party that will be responsible for decommissioning the improvements associated with the pay-for-performance project—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a3aa01b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the end of the useful life of the improvements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3aa01c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the improvements no longer serve the purpose for which the improvements were developed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3aa01d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the pay-for-performance project fails.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa01e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of pay-for-performance project agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture may unilaterally terminate a pay-for-performance agreement, in whole or in part, for any program year beginning after the program year during which the Secretary of Agriculture provides to each party to the pay-for-performance agreement a notice of the termination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3aa01f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent evaluations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3aa020-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Progress reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An independent evaluator shall submit to the Secretary of Agriculture and each party to the applicable pay-for-performance agreement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3aa021-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by not later than 2 years after the date on which the pay-for-performance agreement is executed, and at least once every 2 years thereafter, a written report that summarizes the progress that has been made in achieving each project outcome; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa022-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" before the first scheduled date for a payment described in subsection (d)(3)(A), and each subsequent date for payment, a written report that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a3aa023-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" summarizes the results of the evaluation conducted by the independent evaluator to determine whether a payment should be made pursuant to the pay-for-performance agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3aa024-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyzes the reasons why a project outcome was achieved or was not achieved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa025-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date on which a pay-for-performance project is completed, the independent evaluator shall submit to the Secretary of Agriculture and each party to the pay-for-performance agreement a written report that includes, with respect to the period covered by the report—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3aa026-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the effects of the pay-for-performance project with respect to each project outcome;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa027-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a determination of whether the pay-for-performance project has met each project outcome; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa028-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the payments made for the pay-for-performance project pursuant to subsection (d)(3)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3aa029-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional Forest Service-provided assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3aa02a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture may provide technical assistance to facilitate pay-for-performance project development, such as planning, permitting, site preparation, and design work.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa02b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations, the Secretary of Agriculture may hire a contractor—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3aa02c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct a feasibility analysis of a proposed pay-for-performance project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa02d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist in the development, implementation, or evaluation of a proposed pay-for-performance project or a pay-for-performance agreement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3aa02e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist with an environmental analysis of a proposed pay-for-performance project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3aa02f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings clause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall approve a record of decision, decision notice, or decision memo for any activities to be carried out on National Forest System land as part of a pay-for-performance project before the Secretary of Agriculture may enter into a pay-for-performance agreement involving the applicable pay-for-performance project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3aa030-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of pilot program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3aa031-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority to enter into a pay-for-performance agreement under this section terminates on the date that is 7 years after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa032-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8463/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings clause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in paragraph (1) affects any pay-for-performance project agreement entered into by the Secretary of Agriculture under this section before the date described in that paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3aa033-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tI/s155"},"text":"Pub. L. 118–234, title I, § 155","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2871"},"text":"138 Stat. 2871","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a3aa034-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a3aa035-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a3aa036-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (d)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Subtitle C of title XX of the Act is classified generally to division C (§ 1397n et seq.) of subchapter XX of chapter 7 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
