v. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3515"},"text":"112 Stat. 3515","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sums “heretofore” authorized by this section, referred to in text, means sums authorized by this section prior to the enactment on ","children":[{"tag":"date","attrib":{"date":"1980-03-05"},"text":"Mar. 5, 1980","children":[],"tail":", of "},{"tag":"ref","attrib":{"href":"/us/pl/96/199"},"text":"Pub. L. 96–199","children":[],"tail":", which added the authorization for a $5,000,000 appropriation for the acquisition of lands or interest in lands."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77ad3e8b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/544/s4/b"},"text":"Section 4(b) of Pub. L. 94–544","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/94/567/s7/b"},"text":"section 7(b) of Pub. L. 94–567","children":[],"tail":" identically renumbered this section as "},{"tag":"ref","attrib":{"href":"/us/pl/87/657/s8"},"text":"section 8 of Pub. L. 87–657","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77ad3e8c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/199"},"text":"Pub. L. 96–199","children":[],"tail":" inserted provisions authorizing an appropriation of $5,000,000 for the acquisition of lands or interests therein."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/223/s1"},"text":"Pub. L. 91–223, § 1","children":[],"tail":", substituted “$57,500,000” for “$19,135,000”, restricted conveyances of any interest in any lands acquired after "},{"tag":"date","attrib":{"date":"1970-04-03"},"text":"April 3, 1970","children":[],"tail":", only for public accommodations, facilities, and services under provisions for concessions in areas administered by National Park Service."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/666"},"text":"Pub. L. 89–666","children":[],"tail":" substituted “$19,135,000” for “$14,000,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
