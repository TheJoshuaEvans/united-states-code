{"tag":"section","attrib":{"id":"id77ad3e86-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459c–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"459c–7"},"text":"§ 459c–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; restriction on use of land","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out the provisions of sections 459c to 459c–7 of this title, except that no more than $57,500,000 shall be appropriated for the acquisition of land and waters and improvements thereon, and interests therein, and incidental costs relating thereto, in accordance with the provisions of such sections: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That no freehold, leasehold, or lesser interest in any lands hereafter acquired within the boundaries of the Point Reyes National Seashore shall be conveyed for residential or commercial purposes except for public accommodations, facilities, and services provided pursuant to the Act of "},{"tag":"date","attrib":{"date":"1965-10-09"},"text":"October 9, 1965","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/89/249"},"text":"Public Law 89–249","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/79/969"},"text":"79 Stat. 969","children":[],"tail":")."},{"tag":"ref","attrib":{"idref":"fn002279"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002279"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" In addition to the sums heretofore authorized by this section, there is further authorized to be appropriated $5,000,000 for the acquisition of lands or interests therein."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77ad3e87-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/657/s9"},"text":"Pub. L. 87–657, § 9","children":[],"tail":", formerly § 8, "},{"tag":"date","attrib":{"date":"1962-09-13"},"text":"Sept. 13, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/541"},"text":"76 Stat. 541","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/666/s1/b"},"text":"Pub. L. 89–666, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/919"},"text":"80 Stat. 919","children":[],"tail":"; renumbered § 7 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/223"},"text":"Pub. L. 91–223","children":[],"tail":", §§ 1, 2(c), "},{"tag":"date","attrib":{"date":"1970-04-03"},"text":"Apr. 3, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/90"},"text":"84 Stat. 90","children":[],"tail":"; renumbered § 8, "},{"tag":"ref","attrib":{"href":"/us/pl/94/544/s4/b"},"text":"Pub. L. 94–544, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-18"},"text":"Oct. 18, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2515"},"text":"90 Stat. 2515","children":[],"tail":"; renumbered § 8, "},{"tag":"ref","attrib":{"href":"/us/pl/94/567/s7/b"},"text":"Pub. L. 94–567, § 7(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-20"},"text":"Oct. 20, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2695"},"text":"90 Stat. 2695","children":[],"tail":"; renumbered § 9, "},{"tag":"ref","attrib":{"href":"/us/pl/95/625/tIII/s318/e"},"text":"Pub. L. 95–625, title III, § 318(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3487"},"text":"92 Stat. 3487","children":[],"tail":"; amended "},{"tag":"ref","