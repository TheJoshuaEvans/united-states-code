{"tag":"section","attrib":{"id":"id77740614-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"410iii–4"},"text":"§ 410iii–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77740615-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Real property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire land or interests in land within the boundaries of the Park, from willing sellers only, by donation, purchase with donated or appropriated funds, or exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77740616-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boundary revision","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After acquiring land for the Park, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77740617-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–4/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revise the boundary of the Park to include newly acquired land within the boundary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77740618-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–4/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer newly acquired land subject to applicable laws (including regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77740619-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire personal property associated with, and appropriate for, interpretation of the Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7774061a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–4/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation easements and covenants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to acquire conservation easements and enter into covenants regarding lands in or adjacent to the Park from willing sellers only. Such conservation easements and covenants shall have the effect of protecting the scenic, natural, and historic resources on adjacent lands and preserving the natural or historic setting of the Park when viewed from within or outside the Park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7774061b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–4/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Park Service is authorized to acquire from willing sellers, land outside the Park boundary but in close proximity to the Park, for the development of visitor, administrative, museum, curatorial, and maintenance facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7774061c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/373/s6"},"text":"Pub. L. 107–373, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3106"},"text":"116 Stat. 3106","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
