","id":"id78b84594-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Legal Representation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Customs Courts Act of 1980 as not affecting authority of Tennessee Valley Authority under this chapter to represent itself by attorneys of its choosing, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/417/tVII/s705"},"text":"Pub. L. 96–417, title VII, § 705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-10"},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1748"},"text":"94 Stat. 1748","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s251"},"text":"section 251 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
