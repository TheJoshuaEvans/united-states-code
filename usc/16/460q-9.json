{"tag":"section","attrib":{"id":"id77c77d07-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460q–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"460q–9"},"text":"§ 460q–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated for the acquisition of lands and interests in land pursuant to the provisions of this subchapter not more than $21,600,000. There are also authorized to be appropriated not more than $24,649,000 for the development of recreation facilities pursuant to the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77c77d08-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/336/s10"},"text":"Pub. L. 89–336, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1300"},"text":"79 Stat. 1300","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/625/tI/s101/27"},"text":"Pub. L. 95–625, title I, § 101(27)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3472"},"text":"92 Stat. 3472","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77c77d09-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77c77d0a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77c77d0b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625"},"text":"Pub. L. 95–625","children":[],"tail":" increased development appropriations authorization to $24,649,000 from $22,700,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
