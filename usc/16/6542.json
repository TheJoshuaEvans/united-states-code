{"tag":"section","attrib":{"id":"id7a0fbfd3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542"},"text":null,"children":[{"tag":"num","attrib":{"value":"6542"},"text":"§ 6542.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water Source Protection Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a0fbfd4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0fbfd5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" End water user","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “end water user” means a non-Federal entity, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0fbfd6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fbfd7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a political subdivision of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fbfd8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fbfd9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a utility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fbfda-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a municipal water system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fbfdb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an irrigation district;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fbfdc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fbfdd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fbfde-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forest management activity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “forest management activity” means a project carried out by the Secretary on National Forest System land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fbfdf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forest plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “forest plan” means a land management plan prepared by the Forest Service for a unit of the National Forest System pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1604"},"text":"section 1604 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fbfe0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal partner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “non-Federal partner” means an end water user with whom the Secretary has entered into a partnership agreement under subsection (c)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fbfe1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Program” means the Water Source Protection Program established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fbfe2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture, acting through the Chief of the Forest Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fbfe3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water source management plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “water source management plan” means the water source management plan developed under subsection (d)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0fbfe4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish and maintain a program, to be known as the “Water Source Protection Program”, to carry out watershed protection and restoration projects on National Forest System land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0fbfe5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water source investment partnerships","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0fbfe6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the Program, the Secretary may enter into water source investment partnership agreements with end water users to protect and restore the condition of National Forest watersheds that provide water to the end water users.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fbfe7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A partnership agreement described in paragraph (1) may take the form of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0fbfe8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a memorandum of understanding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fbfe9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a cost-share or collection agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fbfea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a long-term funding matching commitment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fbfeb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another appropriate instrument, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0fbfec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water source management plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0fbfed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the Program, the Secretary, in cooperation with the non-Federal partners and applicable State, local, and Tribal governments, may develop a water source management plan that describes the proposed implementation of watershed protection and restoration projects under the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fbfee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A water source management plan shall be conducted in a manner consistent with the forest plan applicable to the National Forest System land on which the watershed protection and restoration project is carried out.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fbfef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental analysis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may conduct a single environmental impact statement or similar analysis required under the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.)—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0fbff0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each watershed protection and restoration project included in the water source management plan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fbff1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as part of the development of, or after the finalization of, the water source management plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0fbff2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forest management activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0fbff3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent that forest management activities are necessary to protect, maintain, or enhance water quality, and in accordance with paragraph (2), the Secretary shall carry out forest management activities as part of watershed protection and restoration projects carried out on National Forest System land, with the primary purpose of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0fbff4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protecting a municipal water supply system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fbff5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restoring forest health from insect infestations and disease; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fbff6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any combination of the purposes described in subparagraphs (A) and (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fbff7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out forest management activities under paragraph (1) in accordance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0fbff8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fbff9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable water source management plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fbffa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable forest plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fbffb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other applicable laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0fbffc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Endangered Species Act of 1973","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the Program, the Secretary may use the Manual on Adaptive Management of the Department of the Interior, including any associated guidance, to comply with the Endangered Species Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"16 U.S.C. 1531","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0fbffd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds and services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0fbffe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the Program, the Secretary may accept and use funding, services, and other forms of investment and assistance from non-Federal partners to implement the water source management plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fbfff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require the contribution of funds or in-kind support from non-Federal partners to be in an amount that is at least equal to the amount of Federal funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fc000-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner of use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may accept and use investments described in paragraph (1) directly or indirectly through the National Forest Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fc001-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water source protection fund","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0fc002-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/g/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, the Secretary may establish a Water Source Protection Fund to match funds or in-kind support contributed by non-Federal partners under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc003-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/g/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of appropriated funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $10,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc004-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6542/g/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make multiyear commitments, if necessary, to implement 1 or more partnership agreements under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0fc005-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/148/tIII/s303"},"text":"Pub. L. 108–148, title III, § 303","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVIII/s8404/a"},"text":"Pub. L. 115–334, title VIII, § 8404(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4841"},"text":"132 Stat. 4841","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a0fc006-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a0fc007-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a0fc008-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (d)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attri