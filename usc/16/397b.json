{"tag":"section","attrib":{"id":"id773612e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s397b"},"text":null,"children":[{"tag":"num","attrib":{"value":"397b"},"text":"§ 397b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement of lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to procure, by donation or purchase, with any funds that may be available for that purpose, lands and interests in lands which may be needed for the Puʻuhonua o Ho̅naunau National Historical Park within the area described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s397"},"text":"section 397 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id773612e3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-26/ch385/s3"},"text":"July 26, 1955, ch. 385, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/379"},"text":"69 Stat. 379","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/625/tIII/s305"},"text":"Pub. L. 95–625, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3477"},"text":"92 Stat. 3477","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/510/s3/d/1"},"text":"Pub. L. 106–510, § 3(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2364"},"text":"114 Stat. 2364","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id773612e4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id773612e5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id773612e6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/510"},"text":"Pub. L. 106–510","children":[],"tail":" substituted “Puʻuhonua o Ho̅naunau National Historical Park” for “Puuhonua o Honaunau National Historical Park”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625"},"text":"Pub. L. 95–625","children":[],"tail":" redesignated as “Puuhonua o Honaunau National Historical Park” the park previously designated “City of Refuge National Historical Park”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
