{"tag":"section","attrib":{"id":"id79fa3b3f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5004"},"text":null,"children":[{"tag":"num","attrib":{"value":"5004"},"text":"§ 5004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Panel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79fa3b40-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5004/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Panel","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An Advisory Panel to the United States Section is established. The Advisory Panel shall be composed of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79fa3b41-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5004/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commissioner of the Alaska Department of Fish and Game.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fa3b42-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5004/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Washington Department of Fisheries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fa3b43-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5004/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One representative of the Pacific States Marine Fisheries Commission, designated by the Executive Director of that commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fa3b44-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5004/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Eleven members (six of whom shall be residents of the State of Alaska and five of whom shall be residents of the State of Washington), appointed by the Secretary, in consultation with the Secretary of Commerce, from among a slate of 12 persons nominated by the Governor of Alaska and a slate of 10 persons nominated by the Governor of Washington.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79fa3b45-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5004/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Persons appointed to the Advisory Panel shall be individuals who are knowledgeable or experienced concerning anadromous stocks and ecologically related species. In submitting a slate of nominees pursuant to subsection (a)(4), the Governors of Alaska and Washington shall seek to represent the broad range of parties interested in anadromous stocks and ecologically related species, and at a minimum shall include on each slate at least one representative of commercial salmon fishing interests and of environmental interests concerned with protection of living marine resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79fa3b46-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5004/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person appointed to the Advisory Panel pursuant to subsection (a)(4) shall serve for a term not to exceed 4 years, and may not serve more than two consecutive terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79fa3b47-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5004/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Panel shall be invited to all nonexecutive meetings of the United States Section and at such meetings shall be granted the opportunity to examine and to be heard on all proposed programs of study and investigation, reports, and recommendations of the United States Section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79fa3b48-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5004/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Advisory Panel shall receive no compensation for their service as such members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79fa3b49-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5004/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79fa3b4a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5004/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may pay the necessary travel expenses of the members of the Advisory Panel in carrying out their service as such members in accordance with the Federal Travel Regulations and sections 5701, 5702, 5704 through 5708, and 5731 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fa3b4b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5004/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce may reimburse the Secretary for amounts expended by the Secretary under this subparagraph.","children":[{"tag":"ref","attrib":{"idref":"fn002807"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002807"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection”."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79fa3b4c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/567/tVIII/s805"},"text":"Pub. L. 102–567, title VIII, § 805","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4311"},"text":"106 Stat. 4311","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/tVIII/s8005"},"text":"Pub. L. 102–587, title VIII, § 8005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5100"},"text":"106 Stat. 5100","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/562/tIII/s304/a"},"text":"Pub. L. 106–562, title III, § 304(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-23"},"text":"Dec. 23, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2806"},"text":"114 Stat. 2806","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/327/tI/s121/b/2"},"text":"Pub. L. 114–327, title I, § 121(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1985"},"text":"130 Stat. 1985","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79fa3b4d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79fa3b4e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79fa3b4f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Title VIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/567"},"text":"Pub. L. 102–567","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/102/587"},"text":"Pub. L. 102–587","children":[],"tail":" enacted identical sections. Title VIII of "},{"tag":"ref","attrib":{"href":"/us/pl/102/587"},"text":"Pub. L. 102–587","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/106/562"},"text":"Pub. L. 106–562","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79fa3b50-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/327"},"text":"Pub. L. 114–327","children":[],"tail":" added subsecs. (e) and (f) and struck out former subsec. (e) which related to compensation and expenses."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79fa3b51-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79fa3b52-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Panels","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory panels established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of their establishment, unless, in the case of a panel established by the President or an officer of the Federal Government, such panel is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a panel established by Congress, its duration is otherwise provided for by law, see sections 1001(2) and 1013 of Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
