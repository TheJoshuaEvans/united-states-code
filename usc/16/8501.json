{"tag":"section","attrib":{"id":"id7a3aa110-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8501"},"text":null,"children":[{"tag":"num","attrib":{"value":"8501"},"text":"§ 8501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion of outdoor recreation for military servicemembers and veterans","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretary concerned, in coordination with the Secretary of Veterans Affairs and the Secretary of Defense, shall develop educational and public awareness materials to disseminate to members of the Armed Forces and veterans, including through preseparation counseling of the Transition Assistance Program under chapter "},{"tag":"ref","attrib":{"idref":"fn002878"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002878"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" 1142 of title 10, on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3aa111-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunities for members of the Armed Forces and veterans to access Federal recreational lands and waters free of charge under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6804"},"text":"section 6804 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa112-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability and location of accessible trails, including new accessible trails developed and completed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s8484"},"text":"section 8484 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa113-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8501/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability and location of accessible recreation opportunities, including new accessible recreation opportunities developed and completed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s8485"},"text":"section 8485 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa114-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8501/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to, and assistance with, assistive technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa115-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8501/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outdoor-related volunteer and wellness programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa116-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8501/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the benefits of outdoor recreation for physical and mental health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3aa117-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8501/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)"