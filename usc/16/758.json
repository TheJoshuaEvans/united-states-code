{"tag":"section","attrib":{"id":"id78921fbb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s758"},"text":null,"children":[{"tag":"num","attrib":{"value":"758"},"text":"§ 758.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exploration, investigation, development, and maintenance of fishing resources and industry of Pacific Ocean","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is the policy of the United States to provide for the exploration, investigation, development, and maintenance of the fishing resources and development of the high seas fishing industry of the United States and its island possessions in the tropical and subtropical Pacific Ocean and intervening seas, for the benefit of the residents of the Pacific island possessions and of the people of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78921fbc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-08-04/ch451/s1"},"text":"Aug. 4, 1947, ch. 451, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/726"},"text":"61 Stat. 726","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/624/s11/a"},"text":"Pub. L. 86–624, § 11(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1960-07-12"},"text":"July 12, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/412"},"text":"74 Stat. 412","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78921fbd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78921fbe-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78921fbf-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1960—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/624"},"text":"Pub. L. 86–624","children":[],"tail":" substituted “the United States and its island possessions” for “the Territories and island possessions of the United States”, and struck out “Territory of Hawaii and” before “Pacific island possessions”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
