{"tag":"section","attrib":{"id":"id798a150d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1881b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1881b"},"text":"§ 1881b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Observers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id798a150e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1881b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines for carrying observers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within one year after ","children":[{"tag":"date","attrib":{"date":"1996-10-11"},"text":"October 11, 1996","children":[],"tail":", the Secretary shall promulgate regulations, after notice and opportunity for public comment, for fishing vessels that carry observers. The regulations shall include guidelines for determining—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id798a150f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1881b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when a vessel is not required to carry an observer on board because the facilities of such vessel for the quartering of an observer, or for carrying out observer functions, are so inadequate or unsafe that the health or safety of the observer or the safe operation of the vessel would be jeopardized; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798a1510-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1881b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions which vessel owners or operators may reasonably be required to take to render such facilities adequate and safe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798a1511-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1881b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in cooperation with the appropriate States and the National Sea Grant College Program, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id798a1512-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1881b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish programs to ensure that each observer receives adequate training in collecting and analyzing the information necessary for the conservation and management purposes of the fishery to which such observer is assigned;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798a1513-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1881b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that an observer demonstrate competence in fisheries science and statistical analysis at a level sufficient to enable such person to fulfill the responsibilities of the position;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798a1514-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1881b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that an observer has received adequate training in basic vessel safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798a1515-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1881b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that each observer has received training to identify indicators of forced labor and human trafficking (as such terms are defined in section 11329 of the Don Young Coast Guard Authorization Act of 2022) and refer this information to appropriate authorities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798a1516-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1881b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make use of university and any appropriate private nonprofit organization training facilities and resources, where possible, in carrying out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798a1517-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1881b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Observer status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An observer on a vessel and under contract to carry out responsibilities under this chapter or the Marine Mammal Protection Act of 1972 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1361"},"text":"16 U.S.C. 1361","children":[],"tail":" et seq.) shall be deemed to be a Federal employee for the purpose of compensation under the Federal Employee Compensation Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8101"},"text":"5 U.S.C. 8101","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id798a1518-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265/tIV/s403"},"text":"Pub. L. 94–265, title IV, § 403","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/297/tII/s204"},"text":"Pub. L. 104–297, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3609"},"text":"110 Stat. 3609","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXIII/s11340"},"text":"Pub. L. 117–263, div. K, title CXIII, § 11340","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4105"},"text":"136 Stat. 4105","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id798a1519-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id798a151a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id798a151b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 11329 of the Don Young Coast Guard Authorization Act of 2022, referred to in subsec. (b)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/s11329"},"text":"section 11329 of div. K of Pub. L. 117–263","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1885a"},"text":"section 1885a of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265"},"text":"Pub. L. 94–265","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-13"},"text":"Apr. 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/331"},"text":"90 Stat. 331","children":[],"tail":", known as the Magnuson-Stevens Fishery Conservation and Management Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1801"},"text":"section 1801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Marine Mammal Protection Act of 1972, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522"},"text":"Pub. L. 92–522","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-21"},"text":"Oct. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1027"},"text":"86 Stat. 1027","children":[],"tail":", which is classified generally to chapter 31 (§ 1361 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1361"},"text":"section 1361 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Employee Compensation Act, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-09-07/ch458"},"text":"act Sept. 7, 1916, ch. 458","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/742"},"text":"39 Stat. 742","children":[],"tail":", which was repealed and the provisions thereof were reenacted as subchapter I (§ 8101 et seq.) of chapter 81 of Title 5, Government Organization and Employees, by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/378"},"text":"80 Stat. 378","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id798a151c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265/s403"},"text":"section 403 of Pub. L. 94–265","children":[],"tail":" amended sections 1972 and 1973 of Title 22, Foreign Relations and Intercourse, and enacted provisions formerly set out as notes under sections 1972 and 1973 of Title 22, prior to being amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/104/297"},"text":"Pub. L. 104–297","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id798a151d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" added par. (4) and redesignated former par. (4) as (5)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
