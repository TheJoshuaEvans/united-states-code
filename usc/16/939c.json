{"tag":"section","attrib":{"id":"id78d4f585-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s939c"},"text":null,"children":[{"tag":"num","attrib":{"value":"939c"},"text":"§ 939c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is hereby authorized to be appropriated from time to time such sums as may be necessary for carrying out the purposes and provisions of the Convention and this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78d4f586-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-06-04/ch358/s13"},"text":"June 4, 1956, ch. 358, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/244"},"text":"70 Stat. 244","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
