{"tag":"section","attrib":{"id":"id779570b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430h–12"},"text":null,"children":[{"tag":"num","attrib":{"value":"430h–12"},"text":"§ 430h–12.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall administer any properties acquired under sections 430h–10 to 430h–13 of this title as part of the Vicksburg National Military Park in accordance with applicable laws and regulations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id779570b7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/238/s4"},"text":"Pub. L. 107–238, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-11"},"text":"Oct. 11, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1486"},"text":"116 Stat. 1486","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
