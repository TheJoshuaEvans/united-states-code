{"tag":"section","attrib":{"id":"id793dca24-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1460"},"text":null,"children":[{"tag":"num","attrib":{"value":"1460"},"text":"§ 1460.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Walter B. Jones excellence in coastal zone management awards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id793dca25-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1460/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, using sums in the Coastal Zone Management Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1456a"},"text":"section 1456a of this title","children":[],"tail":" and other amounts available to carry out this chapter (other than amounts appropriated to carry out sections 1454, 1455, 1455a, 1456b, 1456c, and 1461 of this title), implement a program to promote excellence in coastal zone management by identifying and acknowledging outstanding accomplishments in the field."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id793dca26-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1460/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual selection of recipients","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall elect annually—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id793dca27-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1460/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one individual, other than an employee or officer of the Federal Government, whose contribution to the field of coastal zone management has been the most significant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793dca28-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1460/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 local governments which have made the most progress in developing and implementing the coastal zone management principles embodied in this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793dca29-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1460/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" up to 10 graduate students whose academic study promises to contribute materially to development of new or improved approaches to coastal zone management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id793dca2a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1460/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitation of nominations for local government recipients","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making selections under subsection (b)(2) the Secretary shall solicit nominations from the coastal states, and shall consult with experts in local government planning and land use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id793dca2b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1460/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitation of nominations for graduate student recipients","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making selections under subsection (b)(3) the Secretary shall solicit nominations from coastal states and the National Sea Grant College Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id793dca2c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1460/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding; types of awards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Using sums in the Coastal Zone Management Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1456a"},"text":"section 1456a of this title","children":[],"tail":" and other amounts available to carry out this chapter (other than amounts appropriated to carry out sections 1454, 1455, 1455a, 1456b, 1456c, and 1461 of this title), the Secretary shall establish and execute appropriate awards, to be known as the “Walter B. Jones Awards”, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id793dca2d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1460/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cash awards in an amount not to exceed $5,000 each;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793dca2e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1460/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research grants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793dca2f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1460/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public ceremonies to acknowledge such awards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79403a30-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/454/tIII/s314"},"text":"Pub. L. 89–454, title III, § 314","children":[],"tail":", formerly § 313, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tVI/s6213"},"text":"Pub. L. 101–508, title VI, § 6213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-312"},"text":"104 Stat. 1388–312","children":[],"tail":"; renumbered § 314 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/tII/s2205/b/20"},"text":"Pub. L. 102–587, title II, § 2205(b)(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5052"},"text":"106 Stat. 5052","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79403a31-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79403a32-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id79403a33-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1460, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/454/tIII/s314"},"text":"Pub. L. 89–454, title III, § 314","children":[],"tail":", formerly § 311, as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/583"},"text":"Pub. L. 92–583","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1287"},"text":"86 Stat. 1287","children":[],"tail":"; renumbered § 314, "},{"tag":"ref","attrib":{"href":"/us/pl/94/370/s7"},"text":"Pub. L. 94–370, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-26"},"text":"July 26, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1019"},"text":"90 Stat. 1019","children":[],"tail":", related to establishment, etc., of Coastal Zone Management Advisory Committee, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tVI/s6045/2"},"text":"Pub. L. 99–272, title VI, § 6045(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/127"},"text":"100 Stat. 127","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79403a34-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsecs. (a), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/s2205/b/20/B"},"text":"Pub. L. 102–587, § 2205(b)(20)(B)","children":[],"tail":", (C), after “under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1456a"},"text":"section 1456a of this title","children":[],"tail":"” inserted “and other amounts available to carry out this chapter (other than amounts appropriated to carry out sections 1454, 1455, 1455a, 1456b, 1456c, and 1461 of this title)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
