{"tag":"section","attrib":{"id":"id79962319-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113"},"text":null,"children":[{"tag":"num","attrib":{"value":"2113"},"text":"§ 2113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal, State, and local coordination and cooperation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7996231a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forest Resource Coordinating Committee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7996231b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a committee, to be known as the “Forest Resource Coordinating Committee” (in this section referred to as the “Coordinating Committee”), to coordinate nonindustrial private forestry activities within the Department of Agriculture and with the private sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7996231c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Coordinating Committee shall be composed of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7996231d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of the Forest Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7996231e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of the Natural Resources Conservation Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7996231f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Farm Service Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79962320-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Institute of Food and Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79962321-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Non-Federal representatives appointed by the Secretary to 3 year terms, although initial appointees shall have staggered terms, including the following persons:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79962322-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/a/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At least three State foresters or equivalent State officials from geographically diverse regions of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79962323-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/a/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A representative of a State fish and wildlife agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79962324-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/a/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An owner of nonindustrial private forest land.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79962325-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/a/2/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A forest industry representative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79962326-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/a/2/E/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A conservation organization representative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79962327-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/a/2/E/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A land-grant university or college representative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79962328-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/a/2/E/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A private forestry consultant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79962329-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/a/2/E/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A representative from a State Technical Committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3861"},"text":"section 3861 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7996232a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other persons as determined by the Secretary to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7996232b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief of the Forest Service shall serve as chairperson of the Coordinating Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7996232c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Coordinating Committee shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7996232d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide direction and coordination of actions within the Department of Agriculture, and coordination with State agencies and the private sector, to effectively address the national priorities specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2101/c"},"text":"section 2101(c) of this title","children":[],"tail":", with specific focus "},{"tag":"ref","attrib":{"idref":"fn002717"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002717"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “on” probably should appear after “focus”."}],"tail":" owners of nonindustrial private forest land;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7996232e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clarify individual agency responsibilities of each agency represented on the Coordinating Committee concerning the national priorities specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2101/c"},"text":"section 2101(c) of this title","children":[],"tail":", with specific focus on nonindustrial private forest land;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7996232f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide advice on the allocation of funds, including the competitive funds set-aside by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2109a"},"text":"section 2109a of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79962330-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the Secretary in developing and reviewing the report required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2101/d"},"text":"section 2101(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79962331-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meeting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Coordinating Committee shall meet annually to discuss progress in addressing the national priorities specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2101/c"},"text":"section 2101(c) of this title","children":[],"tail":" and issues regarding nonindustrial private forest land."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79962332-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79962333-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Coordinating Committee who are full-time officers or employees of the United States shall receive no additional pay, allowances, or benefits by reason of their service on the Coordinating Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79962334-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Non-federal ","children":[{"tag":"ref","attrib":{"idref":"fn002718"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002718"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “Non-Federal”."}],"tail":" members of the Coordinating Committee shall serve without pay, but may be reimbursed for reasonable costs incurred while performing their duties on behalf of the Coordinating Committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79962335-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State Coordinating Committees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79962336-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79962337-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the State forester or equivalent State official of each State, shall establish a State Forest Stewardship Coordinating Committee (hereafter referred to in this section as the “State Coordinating Committee”) for each such State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79962338-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The State Coordinating Committee shall be chaired and administered by the State forester, or equivalent State official, or the designee thereof, and shall be composed, to the extent practicable, of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79962339-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives from the Forest Service, Soil Conservation Service, Agricultural Stabilization and Conservation Service, and National Institute of Food and Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7996233a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" representatives, to be appointed by the State forester or equivalent State official, representative of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7996233b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/b/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7996233c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/b/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consulting foresters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7996233d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/b/1/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7996233e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/b/1/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forest products industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7996233f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/b/1/B/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forest land owners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79962340-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/b/1/B/ii/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land-trust organizations, if applicable in the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79962341-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/b/1/B/ii/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conservation organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79962342-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/b/1/B/ii/VIII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VIII"},"text":"(VIII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State fish and wildlife agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79962343-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/b/1/B/ii/IX"},"text":null,"children":[{"tag":"num","attrib":{"value":"IX"},"text":"(IX)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State Technical Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79962344-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other individuals determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79962345-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the State Coordinating Committee appointed under subparagraph (B)(ii) shall serve 3-year terms, with the initial members serving staggered terms as determined by the State forester or equivalent State official, and may be reappointed for consecutive terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79962346-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Existing State forestry committees may be used to complement, formulate, or replace the State Coordinating Committees to avoid duplication of efforts if such existing committees are made up of membership that is similar to that described in subparagraph (B)(ii), and if such existing committees include landowners and the general public in their memberships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79962347-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State Coordinating Committee shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79962348-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with other Department of Agriculture and State committees that address State and private forestry issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79962349-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the Secretary concerning the assignment of priorities and the coordination of responsibilities for the implementation of this chapter by the various Federal and State forest management agencies that take into consideration the mandates of each such agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7996234a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the State forester or equivalent State official concerning the development of the State-wide assessment and strategy regarding forest resource conditions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2101a"},"text":"section 2101a of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7996234b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the Secretary concerning those forest lands that should be given priority for inclusion in the Forest Legacy Program established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2103c"},"text":"section 2103c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7996234c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State Coordinating Committees shall not terminate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7996234d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to compel action by any State official.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7996234e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/313/s19"},"text":"Pub. L. 95–313, § 19","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXII/s1222"},"text":"Pub. L. 101–624, title XII, § 1222","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3540"},"text":"104 Stat. 3540","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7511/c/37"},"text":"Pub. L. 110–234, title VII, § 7511(c)(37)","children":[],"tail":", title VIII, §§ 8005, 8006, "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1271"},"text":"122 Stat. 1271","children":[],"tail":", 1284, 1285; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7511(c)(37), title VIII, §§ 8005, 8006, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2032, 2045–2047; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVIII/s8102/b/2"},"text":"Pub. L. 115–334, title VIII, § 8102(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4839"},"text":"132 Stat. 4839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"n