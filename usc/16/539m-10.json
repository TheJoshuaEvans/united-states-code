{"tag":"section","attrib":{"id":"id7832c2fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"539m–10"},"text":"§ 539m–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7832c2fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–10/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A civil action to enforce the provisions of sections 539m to 539m–12 of this title may be brought to the extent permitted under chapter 7 of title 5. Judicial review shall be based on the administrative record and subject to the applicable standard of review set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s706"},"text":"section 706 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7832c2fe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–10/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A civil action may be brought against the Pueblo for declaratory judgment or injunctive relief under sections 539m to 539m–12 of this title, but no money damages, including costs or attorney’s fees, may be imposed on the Pueblo as a result of such judicial action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7832c2ff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–10/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venue","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Venue for any civil action provided for in this section, as well as any civil action to contest the constitutionality of sections 539m to 539m–12 of this title, shall lie only in the United States District Court for the District of New Mexico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7832c300-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dF/tIV/s412"},"text":"Pub. L. 108–7, div. F, title IV, § 412","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/291"},"text":"117 Stat. 291","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7832c301-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7832c302-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7832c303-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 539m to 539m–12 of this title, referred to in text, was in the original “this title”, meaning title IV of div. F of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/279"},"text":"117 Stat. 279","children":[],"tail":", which is classified generally to sections 539m to 539m–12 of this title. For complete classification of title IV to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m"},"text":"section 539m of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
