{"tag":"section","attrib":{"id":"id78438b12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s555"},"text":null,"children":[{"tag":"num","attrib":{"value":"555"},"text":"§ 555.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forest headquarters, ranger stations, dwellings, or other needed sites","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Where no suitable Government land is available for national forest headquarters, ranger stations, dwellings, or for other sites required for the effective conduct of the authorized activities of the Forest Service, the Secretary of Agriculture is authorized to purchase such lands out of the appropriation applicable to the purpose for which the land is to be used, and to accept donations of land for any national forest or experimental purpose: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That such lands may be acquired subject to such reservations and outstanding interests as the Secretary determines will not interfere with the purpose for which acquired: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That not to exceed $50,000 may be expended in any one fiscal year pursuant to this authority."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78438b13-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1925-03-03/ch457/s5"},"text":"Mar. 3, 1925, ch. 457, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/1133"},"text":"43 Stat. 1133","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1950-04-24/ch97/s13"},"text":"Apr. 24, 1950, ch. 97, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/86"},"text":"64 Stat. 86","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/464/s9"},"text":"Pub. L. 85–464, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-06-20"},"text":"June 20, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/218"},"text":"72 Stat. 218","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78438b14-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78438b15-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78438b16-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/464"},"text":"Pub. L. 85–464","children":[],"tail":" substituted “$50,000” for “$25,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1950—Act ","children":[{"tag":"date","attrib":{"date":"1950-04-24"},"text":"Apr. 24, 1950","children":[],"tail":", applied section to dwellings or other needed sites and inserted provisos."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
