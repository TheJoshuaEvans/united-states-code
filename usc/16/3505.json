{"tag":"section","attrib":{"id":"id79bc48cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505"},"text":null,"children":[{"tag":"num","attrib":{"value":"3505"},"text":"§ 3505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions to limitations on expenditures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79bc48cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3504"},"text":"section 3504 of this title","children":[],"tail":", the appropriate Federal officer, after consultation with the Secretary, may make Federal expenditures and may make financial assistance available within the System for the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79bc48ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any use or facility necessary for the exploration, extraction, or transportation of energy resources which can be carried out only on, in, or adjacent to a coastal water area because the use or facility requires access to the coastal water body.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bc48cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The maintenance or construction of improvements of existing Federal navigation channels (including the Intracoastal Waterway) and related structures (such as jetties), including the disposal of dredge materials related to such maintenance or construction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bc48d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The maintenance, replacement, reconstruction, or repair, but not the expansion, of publicly owned or publicly operated roads, structures, or facilities that are essential links in a larger network or system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bc48d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Military activities essential to national security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bc48d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The construction, operation, maintenance, and rehabilitation of Coast Guard facilities and access thereto.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bc48d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any of the following actions or projects, if a particular expenditure or the making available of particular assistance for the action or project is consistent with the purposes of this chapter:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79bc48d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Projects for the study, management, protection, and enhancement of fish and wildlife resources and habitats, including acquisition of fish and wildlife habitats and related lands, stabilization projects for fish and wildlife habitats, and recreational projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79bc48d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishment, operation, and maintenance of air and water navigation aids and devices, and for access thereto.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79bc48d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Projects under chapter 2003 of title 54 and the Coastal Zone Management Act of 1972 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1451"},"text":"16 U.S.C. 1451","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79bc48d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/a/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Scientific research, including aeronautical, atmospheric, space, geologic, marine, fish and wildlife, and other research, development, and applications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79bc48d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/a/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Emergency actions necessary to the saving of lives and the protection of property and the public health and safety, if such actions are performed pursuant to sections 5170a, 5170b, 5173, and 5192 of title 42 and are limited to actions that are necessary to alleviate the applicable emergency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79bc48d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/a/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Maintenance, replacement, reconstruction, or repair, but not the expansion (except with respect to United States route 1 in the Florida Keys), of publicly owned or publicly operated roads, structures, and facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79bc48da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/a/6/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nonstructural projects for shoreline stabilization that are designed to mimic, enhance, or restore a natural stabilization system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79bc48db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/a/6/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Aquaculture operations that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79bc48dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/a/6/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produce shellfish (including oysters, clams, and mussels), cultivate micro- or macro-algae, or do not require the use of aquaculture feeds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79bc48dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/a/6/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adhere to best management practices and conservation measures recommended by the Secretary through the consultation process referred to in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bc48de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Use of a sand source within a System unit by Federal coastal storm risk management projects or their predecessor projects that have used a System unit for sand to nourish adjacent beaches outside the System pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s701n"},"text":"section 701n of title 33","children":[],"tail":" at least once between "},{"tag":"date","attrib":{"date":"2008-12-31"},"text":"December 31, 2008","children":[],"tail":" and "},{"tag":"date","attrib":{"date":"2023-12-31"},"text":"December 31, 2023","children":[],"tail":" in response to an emergency situation prior to "},{"tag":"date","attrib":{"date":"2023-12-31"},"text":"December 31, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79bc48df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing Federal navigation channels","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a)(2), a Federal navigation channel or a related structure is an existing channel or structure, respectively, if it was authorized before the date on which the relevant System unit or portion of the System unit was included within the System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79bc48e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion of highways in Michigan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The limitations on the use of Federal expenditures or financial assistance within the System under subsection (a)(3) shall not apply to a highway—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79bc48e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" located in a unit of the System in Michigan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bc48e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in existence on ","children":[{"tag":"date","attrib":{"date":"1990-11-16"},"text":"November 16, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79bc48e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services and facilities outside System","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79bc48e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraphs (2) and (3) of this subsection, limitations on the use of Federal expenditures or financial assistance within the System under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3504"},"text":"section 3504 of this title","children":[],"tail":" shall not apply to expenditures or assistance provided for services or facilities and related infrastructure located outside the boundaries of unit T–11 of the System (as depicted on the maps referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3503/a"},"text":"section 3503(a) of this title","children":[],"tail":") which relate to an activity within that unit."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bc48e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of flood insurance coverage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No new flood insurance coverage may be provided under the National Flood Insurance Act of 1968 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4001"},"text":"42 U.S.C. 4001","children":[],"tail":" et seq.) for any new construction or substantial improvements relating to services or facilities and related infrastructure located outside the boundaries of unit T–11 of the System that facilitate an activity within that unit that is not consistent with the purposes of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79be91d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of HUD assistance","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79be91d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No financial assistance for acquisition, construction, or improvement purposes may be provided under any program administered by the Secretary of Housing and Urban Development for any services or facilities and related infrastructure located outside the boundaries of unit T–11 of the System that facilitate an activity within that unit that is not consistent with the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79be91d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Financial assistance” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, the term “financial assistance” includes any contract, loan, grant, cooperative agreement, or other form of assistance, including the insurance or guarantee of a loan, mortgage, or pool of mortgages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79be91d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability to Otherwise Protected Areas","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79be91da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The prohibitions on new Federal expenditures and financial assistance described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3504/a"},"text":"section 3504(a) of this title","children":[],"tail":" do not apply within Otherwise Protected Areas except with respect to limitations on new flood insurance coverage described in section 1321 of the National Flood Insurance Act of 1968 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4028"},"text":"42 U.S.C. 4028","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79be91db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), new Federal flood insurance may be provided for a structure in an Otherwise Protected Area that is used in a manner consistent with the purpose for which such Otherwise Protected Area is protected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79be91dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability to additions and insurable structures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79be91dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to an addition to the System made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3503"},"text":"section 3503 of this title","children":[],"tail":" on or after "},{"tag":"date","attrib":{"date":"2024-11-25"},"text":"November 25, 2024","children":[],"tail":", subject to paragraph (2), the prohibitions on new Federal expenditures and financial assistance described in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3504/a"},"text":"section 3504(a) of this title","children":[],"tail":" shall take effect on the date that is 1 year after the date on which such addition is made."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79be91de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insurable structures","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79be91df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The prohibitions on new Federal expenditures and financial assistance described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3504/a"},"text":"section 3504(a) of this title","children":[],"tail":" do not apply to an insurable structure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79be91e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insurable structure defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “insurable structure” means an insurable structure that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79be91e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" located within an addition described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79be91e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3505/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in existence before the expiration of the applicable 1-year period described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79be91e3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/348/s6"},"text":"Pub. L. 97–348, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-18"},"text":"Oct. 18, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1656"},"text":"96 Stat. 1656","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/tI/s109/h"},"text":"Pub. L. 100–707, title I, § 109(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4709"},"text":"102 Stat. 4709","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/591/s5/a"},"text":"Pub. L. 101–591, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2934"},"text":"104 Stat. 2934","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/287/s5/d/34"},"text":"Pub. L. 113–287, § 5(d)(34)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3267"},"text":"128 Stat. 3267","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/117/tI/s104"},"text":"Pub. L. 118–117, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-11-25"},"text":"Nov. 25, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1610"},"text":"138 Stat. 1610","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79be91e4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79be91e5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79be91e6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Coastal Zone Management Act of 1972, referred to in subsec. (a)(6)(C), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/454"},"text":"Pub. L. 89–454","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/92/583"},"text":"Pub. L. 92–583","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1280"},"text":"86 Stat. 1280","children":[],"tail":", which is classified generally to chapter 33 (§ 1451 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1451"},"text":"section 1451 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The National Flood Insurance Act of 1968, referred to in subsec. (d)(2), is title XIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448"},"text":"Pub. L. 90–448","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/572"},"text":"82 Stat. 572","children":[],"tail":", which is classified principally to chapter 50 (§ 4001 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4001"},"text":"section 4001 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79be91e7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(6)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/117/s104/1/A/i"},"text":"Pub. L. 118–117, § 104(1)(A)(i)","children":[],"tail":", amended subpar. (E) generally. Prior to amendment, subpar. (E) read as follows: “Assistance for emergency actions essential to the saving of lives and the protection of property and the public health and safety, if such actions are performed pursuant to sections 5170a, 5170b, and 5192 of title 42 and section 1362 of the National Flood Insurance Act of 1968 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4103"},"text":"42 U.S.C. 4103","children":[],"tail":") and are limited to actions that are necessary to alleviate the emergency.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/117/s104/1/A/ii"},"text":"Pub. L. 118–117, § 104(1)(A)(ii)","children":[],"tail":", added subpar. (H)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/117/s104/1/B"},"text":"Pub. L. 118–117, § 104(1)(B)","children":[],"tail":", added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/117/s104/2"},"text":"Pub. L. 118–117, § 104(2)","children":[],"tail":", added subsecs. (e) and (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(6)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287"},"text":"Pub. L. 113–287","children":[],"tail":", which directed the substitution of “chapter 2003 of title 54” for “the Land and Water Conservation Fund Act of 1965 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460"},"text":"16 U.S.C. 460","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–4 through 11)” in section 6(a)(6)(C) of the Coastal Barrier Act of 1968, was executed by making the substitution for “the Land and Water Conservation Fund Act of 1965 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4601–4"},"text":"16 U.S.C. 4601–4","children":[],"tail":" through 11)” in this section, which is section 6 of the Coastal Barrier Resources Act, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/591"},"text":"Pub. L. 101–591","children":[],"tail":" amended section generally, substituting substantially similar provisions in subsec. (a), substituting “a Federal navigation channel or a related structure is an existing channel or structure, respectively, if it was authorized before the date on which the relevant System unit or portion of the System unit was included within the System” for “a channel improvement or a related structure shall be treated as an existing improvement or an existing related structure only if all, or a portion, of the moneys for such improvement or structure was appropriated before "},{"tag":"date","attrib":{"date":"1982-10-18"},"text":"October 18, 1982","children":[],"tail":"” in subsec. (b), and adding subsecs. (c) and (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(6)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/707"},"text":"Pub. L. 100–707","children":[],"tail":" substituted reference to sections 5170a, 5170b, and 5192 of title 42 for reference to sections 5145 and 5146 of title 42."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79be91e8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id79be91e9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79be91ea-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Expansion of Highways in Michigan","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/707/tII/s204/d"},"text":"Pub. L. 100–707, title II, § 204(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4715"},"text":"102 Stat. 4715","children":[],"tail":", exempted existing highways in Michigan from limitations on the use of Federal expenditures or financial assistance within the Coastal Barrier Resources System under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3505/a/3"},"text":"16 U.S.C. 3505(a)(3)","children":[],"tail":" if the Congress added new units to the Coastal Barrier Resources System under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3503"},"text":"16 U.S.C. 3503","children":[],"tail":", and those units included portions of United States or State highways in the State of Michigan, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/101/591/s5/b"},"text":"Pub. L. 101–591, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2936"},"text":"104 Stat. 2936","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3505/c"},"text":"section 3505(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
