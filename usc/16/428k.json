{"tag":"section","attrib":{"id":"id778e4500-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s428k"},"text":null,"children":[{"tag":"num","attrib":{"value":"428k"},"text":"§ 428k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Addition of lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In furtherance of the purposes of sections 428 to 428d and 428e to 428i of this title and to facilitate an appropriate observance of the one hundredth anniversary of the Battle of Fort Donelson, the Secretary of the Interior is authorized to designate for addition to the present Fort Donelson National Battlefield such lands and interests in lands adjacent to said battlefield as in his discretion are necessary to preserve and interpret this historic battleground, including the nearby historic Surrender House and the land upon which it is situated on Spring Street in the town of Dover, Tennessee.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id778e4501-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/738"},"text":"Pub. L. 86–738","children":[],"tail":", §§ 1, 4, "},{"tag":"date","attrib":{"date":"1960-09-08"},"text":"Sept. 8, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/875"},"text":"74 Stat. 875","children":[],"tail":", 876; "},{"tag":"ref","attrib":{"href":"/us/pl/108/367/s6"},"text":"Pub. L. 108–367, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-25"},"text":"Oct. 25, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1745"},"text":"118 Stat. 1745","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id778e4502-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id778e4503-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id778e4504-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/367"},"text":"Pub. L. 108–367","children":[],"tail":" substituted “Tennessee” for “Tennessee, but the total area commemorating the battle of Fort Donelson shall not exceed 600 acres”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id778e4505-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id778e4506-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Fort Donelson National Battlefield” and “battlefield” substituted in text for “Fort Donelson National Military Park” and “park”, respectively, in view of redesignation of Fort Donelson National Military Park as Fort Donelson National Battlefield by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/738/s4"},"text":"Pub. L. 86–738, § 4","children":[],"tail":", set out as "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s428n"},"text":"section 428n of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
