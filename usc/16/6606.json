{"tag":"section","attrib":{"id":"id7a193564-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6606"},"text":null,"children":[{"tag":"num","attrib":{"value":"6606"},"text":"§ 6606.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a193565-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6606/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Fund $5,000,000 for each of fiscal years 2025 through 2029.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a193566-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6606/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amounts made available for each fiscal year pursuant to subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a193567-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6606/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $1,510,000 shall be used by the Secretary for marine turtle conservation purposes in accordance with this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a193568-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6606/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the amounts in excess of the amount described in paragraph (1), not less than 40 percent shall be used by the Secretary for freshwater turtle and tortoise conservation purposes in accordance with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a193569-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/266/s7"},"text":"Pub. L. 108–266, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-02"},"text":"July 2, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/795"},"text":"118 Stat. 795","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tVII/s7001/c/3/F"},"text":"Pub. L. 116–9, title VII, § 7001(c)(3)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/788"},"text":"133 Stat. 788","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dE/tLIII/s5307/b"},"text":"Pub. L. 118–159, div. E, title LIII, § 5307(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2446"},"text":"138 Stat. 2446","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a19356a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a19356b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a19356c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"r