{"tag":"section","attrib":{"id":"id77c9ee27-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460s–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"460s–3"},"text":"§ 460s–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pictured Rocks National Lakeshore Advisory Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77c9ee28-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460s–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established a Pictured Rocks National Lakeshore Advisory Commission. Said commission shall terminate ten years after the date the lakeshore is established pursuant to this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77c9ee29-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460s–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership; term","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The commission shall be composed of five members, each appointed for a term of two years by the Secretary, as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77c9ee2a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460s–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two members to be appointed from recommendations made by the county in which the lakeshore is situated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77c9ee2b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460s–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two members to be appointed from recommendations made by the Governor of the State of Michigan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77c9ee2c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460s–3/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member to be designated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77c9ee2d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460s–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairman; vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall designate one member to be chairman. Any vacancy in the commission shall be filled in the same manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77c9ee2e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460s–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the commission shall serve without compensation as such. The Secretary is authorized to pay the expenses reasonably incurred by the commission in carrying out its responsibilities under this subchapter on vouchers signed by the chairman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77c9ee2f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460s–3/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development consultations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or his designee shall, from time to time, consult with the commission with respect to the matters relating to the development of the Pictured Rocks National Lakeshore.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77c9ee30-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/668/s4"},"text":"Pub. L. 89–668, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/922"},"text":"80 Stat. 922","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
