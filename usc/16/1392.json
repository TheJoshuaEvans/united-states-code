{"tag":"section","attrib":{"id":"id79286d52-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1392"},"text":null,"children":[{"tag":"num","attrib":{"value":"1392"},"text":"§ 1392.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring ocean soundscapes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79286d53-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1392/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Under Secretary shall maintain and expand an ocean soundscape development program to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79286d54-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1392/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award grants to expand the deployment of Federal and non-Federal observing and data management systems capable of collecting measurements of underwater sound for purposes of monitoring and analyzing baselines and trends in the underwater soundscape to protect and manage marine life;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79286d55-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1392/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue to develop and apply standardized forms of measurements to assess sounds produced by marine animals, physical processes, and anthropogenic activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79286d56-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1392/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after coordinating with the Secretary of Defense, coordinate and make accessible to the public the datasets, modeling and analysis, and user-driven products and tools resulting from observations of underwater sound funded through grants awarded under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79286d57-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1392/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program described in subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79286d58-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1392/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include the Ocean Noise Reference Station Network of the National Oceanic and Atmospheric Administration and the National Park Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79286d59-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1392/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use and coordinate with the Integrated Ocean Observing System; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79286d5a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1392/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with the Regional Ocean Partnerships and the Director of the United States Fish and Wildlife Service, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79286d5b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1392/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under subsection (a), the Under Secretary shall consider the geographic diversity of the recipients of such grants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79286d5c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1392/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings clause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An activity may not be carried out under this section if the Secretary of Defense, in consultation with the Under Secretary, determines that the activity would negatively impact the defense readiness or the national security of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79286d5d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1392/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From funds otherwise appropriated to the Under Secretary, $1,500,000 is authorized for each of fiscal years 2023 through 2028 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79286d5e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXIII/s11305"},"text":"Pub. L. 117–263, div. K, title CXIII, § 11305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4077"},"text":"136 Stat. 4077","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79286d5f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79286d60-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79286d61-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Don Young Coast Guard Authorization Act of 2022 and also as part of the James M. Inhofe National Defense Authorization Act for Fiscal Year 2023, and not as part of the Marine Mammal Protection Act of 1972 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79286d62-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id79286d63-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/s11301"},"text":"section 11301 of div. K of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1390"},"text":"section 1390 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
