{"tag":"section","attrib":{"id":"id798ef6d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2102"},"text":null,"children":[{"tag":"num","attrib":{"value":"2102"},"text":"§ 2102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural forestry assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id798ef6da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to forest landowners and others","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide financial, technical, educational, and related assistance to State foresters or equivalent State officials, and State extension directors, to enable such officials to provide technical information, advice, and related assistance to private forest land owners and managers, vendors, forest resource operators, forest resource professionals, public agencies, and individuals to enable such persons to carry out activities that are consistent with the purposes of this chapter, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id798ef6db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protecting, maintaining, enhancing, restoring, and preserving forest lands and the multiple values and uses that depend on such lands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798ef6dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying, protecting, maintaining, enhancing, and preserving wildlife and fish species, including threatened and endangered species, and their habitats;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798ef6dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2102/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementing forest management technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798ef6de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2102/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selecting, producing, and marketing alternative forest crops, products and services from forest lands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798ef6df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2102/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protecting forest land from damage caused by fire, insects, disease, and damaging weather;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798ef6e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2102/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" managing the rural-land and urban-land interface to balance the use of forest resources in and adjacent to urban and community areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798ef6e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2102/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying and managing recreational forest land resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798ef6e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2102/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying and protecting the aesthetic character of forest lands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798ef6e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2102/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protecting forest land from conversion to alternative uses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798ef6e4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2102/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the management of resources of forest lands, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id798ef6e5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2102/a/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the harvesting, processing, and marketing of timber and other forest resources and the marketing and utilization of wood and wood products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id798ef6e6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2102/a/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conversion of wood to energy for domestic, industrial, municipal, and other uses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id798ef6e7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2102/a/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the planning, management, and treatment of forest land, including site preparation, reforestation, thinning, prescribed burning, and other silvicultural activities designed to increase the quantity and improve the quality of timber and other forest resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id798ef6e8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2102/a/10/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that forest regeneration or reforestation occurs if needed to sustain long-term resource productivity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id798ef6e9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2102/a/10/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protecting and improving forest soil fertility and the quality, quantity, and timing of water yields; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id798ef6ea-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2102/a/10/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging the investment of a portion of the proceeds from the sale of timber or other forest resources in stewardship activities that preserve, protect, maintain, and enhance their forest land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798ef6eb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State forestry assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to provide financial, technical, and related assistance to State foresters, or equivalent State officials, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id798ef6ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop genetically improved tree seeds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798ef6ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and contract for the development of field arboretums, greenhouses, and tree nurseries, in cooperation with a State, to facilitate production and distribution of tree seeds and seedlings in States where the Secretary determines that there is an inadequate capacity to carry out present and future reforestation needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798ef6ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2102/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procure, produce, and distribute tree seeds and trees for the purpose of establishing forests, windbreaks, shelterbelts, woodlots, and other plantings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798ef6ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2102/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plant tree seeds and seedlings on non-Federal forest lands that are suitable for the production of timber, recreation, and for other benefits associated with the growing of trees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798ef6f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2102/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plan, organize, and implement measures on non-Federal forest lands, including thinning, prescribed burning, and other silvicultural activities designed to increase the quantity and improve the quality of trees and other vegetation, fish and wildlife habitat, and water yielded therefrom; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798ef6f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2102/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect or improve soil fertility on non-Federal forest lands and the quality, quantity, and timing of water yields therefrom.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799140e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In implementing this section, the Secretary shall cooperate with other Federal, State, and local natural resource management agencies, universities and the private sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799140e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2102/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id799140e4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/313/s3"},"text":"Pub. L. 95–313, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-07-01"},"text":"July 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/366"},"text":"92 Stat. 366","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXII/s1213"},"text":"Pub. L. 101–624, title XII, § 1213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3523"},"text":"104 Stat. 3523","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id799140e5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id799140e6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id799140e7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" amended section generally, substituting present provisions for provisions which set forth Congressional findings relating to rural forestry assistance, related to financial, technical, and related assistance to State foresters or equivalent State officials, and authorized appropriations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
