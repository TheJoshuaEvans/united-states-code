{"tag":"section","attrib":{"id":"id77740610-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"410iii–3"},"text":"§ 410iii–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Cedar Creek and Belle Grove National Historical Park","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77740611-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the Cedar Creek and Belle Grove National Historical Park, consisting of approximately 3,000 acres, as generally depicted on the Map.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77740612-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iii–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of Map","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Map shall be on file and available for public inspection in the offices of the National Park Service, Department of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77740613-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/373/s5"},"text":"Pub. L. 107–373, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3106"},"text":"116 Stat. 3106","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
