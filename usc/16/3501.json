section 3503 of this title","children":[],"tail":"] may be cited as the ‘Coastal Barrier Resources Reauthorization Act of 2000’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id79b9d85d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/167/s1"},"text":"Pub. L. 106–167, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1803"},"text":"113 Stat. 1803","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/167/s1"},"text":"“This Act [amending this section and sections 3502, 3503, and 3509 of this title, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1441a–3"},"text":"section 1441a–3 of Title 12","children":[],"tail":", Banks and Banking, and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4028"},"text":"section 4028 of Title 42","children":[],"tail":", The Public Health and Welfare, and enacting and amending provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3503"},"text":"section 3503 of this title","children":[],"tail":"] may be cited as the ‘John H. Chafee Coastal Barrier Resources System Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id79b9d85e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/591/s1"},"text":"Pub. L. 101–591, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2931"},"text":"104 Stat. 2931","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/591/s1"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1441a–3"},"text":"section 1441a–3 of Title 12","children":[],"tail":", Banks and Banking, amending sections 3502 to 3506 and 3510 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4028"},"text":"section 4028 of Title 42","children":[],"tail":", The Public Health and Welfare, enacting provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3503"},"text":"section 3503 of this title","children":[],"tail":", and repealing provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3505"},"text":"section 3505 of this title","children":[],"tail":"] may be cited as the ‘Coastal Barrier Improvement Act of 1990’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id79b9d85f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/707/tII/s204/a"},"text":"Pub. L. 100–707, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4713"},"text":"102 Stat. 4713","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/707/tII/s204/a"},"text":"“This section [amending this section and sections 3502 and 3503 of this title and enacting provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3505"},"text":"section 3505 of this title","children":[],"tail":"] may be cited as the ‘Great Lakes Coastal Barrier Act of 1988’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id79b9d860-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/348/s1"},"text":"Pub. L. 97–348, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-18"},"text":"Oct. 18, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1653"},"text":"96 Stat. 1653","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/348/s1"},"text":"“This Act [enacting this chapter, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4028"},"text":"section 4028 of Title 42","children":[],"tail":", The Public Health and Welfare, and repealing provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4028"},"text":"section 4028 of Title 42","children":[],"tail":"] may be cited as the ‘Coastal Barrier Resources Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79b9d861-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Economic Assessment of John H. Chafee Coastal Barrier Resources System","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/514/s7"},"text":"Pub. L. 106–514, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2397"},"text":"114 Stat. 2397","children":[],"tail":", required the Secretary of the Interior to submit to Congress, no later than 1 year after "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", an economic assessment of the John H. Chafee Coastal Barrier Resources System that would consider the impact on Federal expenditures of the Coastal Barrier Resources Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3501"},"text":"16 U.S.C. 3501","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
