{"tag":"section","attrib":{"id":"id79ebe427-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4264"},"text":null,"children":[{"tag":"num","attrib":{"value":"4264"},"text":"§ 4264.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Asian elephant conservation assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79ebe428-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4264/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, subject to the availability of funds and in consultation with the Administrator, shall use amounts in the Fund to provide financial assistance for projects for the conservation of Asian elephants for which final project proposals are approved by the Secretary in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ebe429-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4264/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project proposal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any relevant wildlife management authority of a nation within the range of Asian elephants whose activities directly or indirectly affect Asian elephant populations, the CITES Secretariat, or any person with demonstrated expertise in the conservation of Asian elephants, may submit to the Secretary a project proposal under this section. Each proposal shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ebe42a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4264/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name of the individual responsible for conducting the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe42b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4264/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A succinct statement of the purposes of the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe42c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4264/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the qualifications of the individuals who will conduct the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe42d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4264/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An estimate of the funds and time required to complete the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe42e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4264/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Evidence of support of the project by appropriate governmental entities of countries in which the project will be conducted, if the Secretary determines that the support is required for the success of the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe42f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4264/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information regarding the source and amount of matching funding available to the applicant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe430-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4264/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other information the Secretary considers to be necessary for evaluating the eligibility of the project for funding under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ebe431-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4264/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project review and approval","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ebe432-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4264/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 30 days after receiving a final project proposal, the Secretary shall provide a copy of the proposal to the Administrator. The Secretary shall review each final project proposal to determine if it meets the criteria set forth in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe433-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4264/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation; approval or disapproval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 6 months after receiving a final project proposal, and subject to the availability of funds, the Secretary, after consulting with the Administrator, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79ebe434-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4264/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" request written comments on the proposal from each country within which the project is to be conducted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ebe435-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4264/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after requesting those comments, approve or disapprove the proposal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ebe436-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4264/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide written notification of that approval or disapproval to the person who submitted the proposal and the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ebe437-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4264/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may approve a final project proposal under this section if the project will enhance programs for conservation of Asian elephants by assisting efforts to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ebe438-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4264/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement conservation programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe439-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4264/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address the conflicts between humans and elephants that arise from competition for the same habitat;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe43a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4264/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance compliance with provisions of CITES and laws of the United States or a foreign country that prohibit or regulate the taking or trade of Asian elephants or regulate the use and management of Asian elephant habitat;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe43b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4264/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop sound scientific information on the condition of Asian elephant habitat, Asian elephant population numbers and trends, or the threats to such habitat, numbers, or trends; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe43c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4264/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote cooperative projects on those topics with other foreign governments, affected local communities, nongovernmental organizations, or others in the private sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ebe43d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4264/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project sustainability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practical, in determining whether to approve project proposals under this section, the Secretary shall give consideration to projects which will enhance sustainable integrated conservation development programs to ensure effective, long-term conservation of Asian elephants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ebe43e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4264/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each person who receives assistance under this section for a project shall provide periodic reports, as the Secretary considers necessary, to the Secretary and the Administrator. Each report shall include all information required by the Secretary, after consulting with the Administrator, for evaluating the progress and success of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ebe43f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4264/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining whether to approve project proposals under this section, the Secretary shall give priority to those projects for which there exists some measure of matching funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ebe440-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4264/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use for captive breeding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts provided as a grant under this chapter may not be used for captive breeding of Asian elephants other than for release in the wild.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ebe441-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4264/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiyear grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ebe442-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4264/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award to a person who is otherwise eligible for a grant under this section a multiyear grant of up to 5 years to carry out a project that the person demonstrates is an effective, long-term conservation strategy for Asian elephants and the habitat of Asian elephants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ebe443-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4264/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection precludes the Secretary from awarding a grant on an annual basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79ebe444-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/96/s5"},"text":"Pub. L. 105–96, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-19"},"text":"Nov. 19, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2151"},"text":"111 Stat. 2151","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/133/s2/a"},"text":"Pub. L. 110–133, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-06"},"text":"Dec. 6, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1362"},"text":"121 Stat. 1362","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dE/tLIII/s5304/a"},"text":"Pub. L. 118–159, div. E, title LIII, § 5304(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2445"},"text":"138 Stat. 2445","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79ebe445-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79ebe446-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79ebe447-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" added subsec. (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/133"},"text":"Pub. L. 110–133","children":[],"tail":" substituted “and the Administrator” for “, the Administrator, and each of those countries”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
