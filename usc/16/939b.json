{"tag":"section","attrib":{"id":"id78d4f583-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s939b"},"text":null,"children":[{"tag":"num","attrib":{"value":"939b"},"text":"§ 939b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State laws and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed as preventing any of the Great Lakes States from making or enforcing laws or regulations within their respective jurisdictions so far as such laws or regulations do not conflict with the Convention or this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78d4f584-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-06-04/ch358/s12"},"text":"June 4, 1956, ch. 358, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/244"},"text":"70 Stat. 244","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
