{"tag":"section","attrib":{"id":"id781d3ed5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s472"},"text":null,"children":[{"tag":"num","attrib":{"value":"472"},"text":"§ 472.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Laws affecting national forest lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Department of Agriculture shall execute or cause to be executed all laws affecting public lands reserved under the provisions of section 471 ","children":[{"tag":"ref","attrib":{"idref":"fn002403"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002403"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, or sections supplemental to and amendatory thereof, after such lands have been so reserved, excepting such laws as affect the surveying, prospecting, locating, appropriating, entering, relinquishing, reconveying, certifying, or patenting of any of such lands."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id781d3ed6-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1905-02-01/ch288/s1"},"text":"Feb. 1, 1905, ch. 288, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/33/628"},"text":"33 Stat. 628","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id781d3ed7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id781d3ed8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id781d3ed9-6992-11f1-ab3f-8b4c043f8cd5"},"tex