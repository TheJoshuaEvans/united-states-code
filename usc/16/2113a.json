,"attrib":{},"text":"The Secretary shall make each good neighbor agreement available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7996237f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timber sales","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79962380-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsections (d) and (g) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s472a"},"text":"section 472a of this title","children":[],"tail":" shall not apply to services performed under a good neighbor agreement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79962381-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of silviculture prescriptions and marking guides","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide or approve all silviculture prescriptions and marking guides to be applied on Federal land in all timber sale projects conducted under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79962382-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of revenue","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79962383-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds received from the sale of timber by a Governor, Indian Tribe, or county under a good neighbor agreement shall be retained and used by the Governor, Indian Tribe, or county, as applicable—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79962384-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/b/2/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out authorized restoration services on ","children":[{"tag":"ref","attrib":{"idref":"fn002719"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002719"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" under the good neighbor agreement; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79962385-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/b/2/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if there are funds remaining after carrying out clause (i),","children":[{"tag":"ref","attrib":{"idref":"fn002720"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002720"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “subclause (I)”."}],"tail":" to carry out—"}],"tail":null},{"tag":"item","attrib":{"id":"id79962386-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/b/2/C/i/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorized restoration services under other good neighbor agreements; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id79962387-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/b/2/C/i/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorized recreation services under the Good Neighbor Authority for Recreation Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79962388-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of effectiveness","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority provided under this subparagraph terminates effective ","children":[{"tag":"date","attrib":{"date":"2028-10-01"},"text":"October 1, 2028","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79962389-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention of NEPA responsibilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any decision required to be made under the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.) with respect to any authorized restoration services to be provided under this section on Federal land shall not be delegated to a Governor or county."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7996238a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receipts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, any payment made by a county to the Secretary under a project conducted under a good neighbor agreement shall not be considered to be monies received from National Forest System, Bureau of Land Management, National Park System, or U.S. Fish and Wildlife Service land, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7996238b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVIII/s8206"},"text":"Pub. L. 113–79, title VIII, § 8206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/921"},"text":"128 Stat. 921","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dO/tII/s212"},"text":"Pub. L. 115–141, div. O, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1073"},"text":"132 Stat. 1073","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVIII"},"text":"Pub. L. 115–334, title VIII","children":[],"tail":", §§ 8624, 8704(b), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4857"},"text":"132 Stat. 4857","children":[],"tail":", 4877; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dG/tIV/s439"},"text":"Pub. L. 117–328, div. G, title IV, § 439","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4832"},"text":"136 Stat. 4832","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/42/dE/tIV/s443"},"text":"Pub. L. 118–42, div. E, title IV, § 443","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-09"},"text":"Mar. 9, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/297"},"text":"138 Stat. 297","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/234/tIII/s351/b/3/B"},"text":"Pub. L. 118–234, title III, § 351(b)(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2916"},"text":"138 Stat. 2916","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7996238c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7996238d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7996238e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Good Neighbor Authority for Recreation Act, referred to in subsec. (b)(2)(C)(i)(II)(bb), probably means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/s351"},"text":"section 351 of Pub. L. 118–234","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s8571"},"text":"section 8571 of this title","children":[],"tail":" and defines “authorized recreation services”. "},{"tag":"ref","attrib":{"href":"/us/pl/118/234/s351"},"text":"Section 351 of Pub. L. 118–234","children":[],"tail":" contains the heading “Good neighbor authority for recreation”, but no Short Title was enacted."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (b)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7996238f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/42/s443"},"text":"Pub. L. 118–42, § 443","children":[],"tail":", which directed amendment of section 8206 of the “Agriculture Act of 2014”, was executed to this section, which is section 8206 of the Agricultural Act of 2014, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Agricultural Act of 2014, and not as part of the Cooperative Forestry Assistance Act of 1978 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79962390-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234"},"text":"Pub. L. 118–234","children":[],"tail":" amended subpar. (C) generally. Prior to amendment, subpar. (C) related to treatment of revenue received from sale of timber by a Governor of a State under a good neighbor agreement, and such authority terminated "},{"tag":"date","attrib":{"date":"2024-10-01"},"text":"Oct. 1, 2024","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(3)(A)(iii), (iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/42/s443/1"},"text":"Pub. L. 118–42, § 443(1)","children":[],"tail":", added cls. (iii) and (iv). See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/42/s443/2"},"text":"Pub. L. 118–42, § 443(2)","children":[],"tail":", (3), in introductory provisions, substituted a comma for “or” before “Bureau of Land Management” and inserted “, National Park Service, or National Wildlife Refuge” after “Bureau of Land Management”. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/42/s443/4"},"text":"Pub. L. 118–42, § 443(4)","children":[],"tail":", substituted “2024” for “2023”. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/42/s443/5"},"text":"Pub. L. 118–42, § 443(5)","children":[],"tail":", (6), substituted a comma for “land or” before “Bureau of Land Management” and inserted “, National Park System, or U.S. Fish and Wildlife Service” after “Bureau of Land Management”. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(4)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" inserted “or Bureau of Land Management managed” after “National Forest System” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8624/a/1"},"text":"Pub. L. 115–334, § 8624(a)(1)","children":[],"tail":", substituted “land, non-Federal land, and land owned by an Indian tribe” for “land and non-Federal land”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8624/b/1/A"},"text":"Pub. L. 115–334, § 8624(b)(1)(A)","children":[],"tail":", inserted “or county, as applicable,” after “Governor”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8624/b/1/C"},"text":"Pub. L. 115–334, § 8624(b)(1)(C)","children":[],"tail":", added par. (2). Former par. (2) redesignated (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8624/b/1/B"},"text":"Pub. L. 115–334, § 8624(b)(1)(B)","children":[],"tail":", redesignated par. (2) as (3). Former par. (3) redesignated (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s212/1"},"text":"Pub. L. 115–141, § 212(1)","children":[],"tail":", substituted “areas, other than the reconstruction, repair, or restoration of a National Forest System road that is—” and subcls. (I) and (II) for “areas; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8624/b/1/B"},"text":"Pub. L. 115–334, § 8624(b)(1)(B)","children":[],"tail":", redesignated par. (3) as (4). Former par. (4) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(B)(i)(II). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8704/b/1"},"text":"Pub. L. 115–334, § 8704(b)(1)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"March 23, 2018","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8624/b/1/B"},"text":"Pub. L. 115–334, § 8624(b)(1)(B)","children":[],"tail":", (D), redesignated par. (4) as (5) and inserted “or county, as applicable,” after “Governor”. Former par. (5) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8624/a/2"},"text":"Pub. L. 115–334, § 8624(a)(2)","children":[],"tail":", inserted “or Indian tribe” after “affected State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8624/b/1/B"},"text":"Pub. L. 115–334, § 8624(b)(1)(B)","children":[],"tail":", redesignated par. (5) as (6). Former par. (6) redesignated (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8624/a/4"},"text":"Pub. L. 115–334, § 8624(a)(4)","children":[],"tail":", which directed amendment of subsec. (a) by adding par. (6) after par. (5) “(as so redesignated)”, was executed by making the addition after par. (5), relating to the definition of “Governor”, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8624/a/3"},"text":"Pub. L. 115–334, § 8624(a)(3)","children":[],"tail":", redesignated par. (6) as (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s212/3"},"text":"Pub. L. 115–141, § 212(3)","children":[],"tail":", added par. (6). Former par. (6) redesignated (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8624/b/1/B"},"text":"Pub. L. 115–334, § 8624(b)(1)(B)","children":[],"tail":", redesignated par. (6) as (7). Former par. (7) redesignated (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8624/a/3"},"text":"Pub. L. 115–334, § 8624(a)(3)","children":[],"tail":", redesignated par. (6) as (7). Former par. (7) redesignated (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s212/2"},"text":"Pub. L. 115–141, § 212(2)","children":[],"tail":", redesignated par. (6) as (7). Former par. (7) redesignated (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8704/b/2"},"text":"Pub. L. 115–334, § 8704(b)(2)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"March 23, 2018","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8624/b/1/B"},"text":"Pub. L. 115–334, § 8624(b)(1)(B)","children":[],"tail":", redesignated par. (7) as (8). Former par. (8) redesignated (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8624/a/3"},"text":"Pub. L. 115–334, § 8624(a)(3)","children":[],"tail":", redesignated par. (7) as (8). Former par. (8) redesignated (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s212/2"},"text":"Pub. L. 115–141, § 212(2)","children":[],"tail":", redesignated par. (7) as (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8624/b/1/B"},"text":"Pub. L. 115–334, § 8624(b)(1)(B)","children":[],"tail":", redesignated par. (8) as (9). Former par. (9) redesignated (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8624/a/3"},"text":"Pub. L. 115–334, § 8624(a)(3)","children":[],"tail":", redesignated par. (8) as (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8624/b/1/B"},"text":"Pub. L. 115–334, § 8624(b)(1)(B)","children":[],"tail":", redesignated par. (9) as (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8624/b/2/A"},"text":"Pub. L. 115–334, § 8624(b)(2)(A)","children":[],"tail":", inserted “or county” after “Governor”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8624/b/2/B"},"text":"Pub. L. 115–334, § 8624(b)(2)(B)","children":[],"tail":", substituted “good neighbor agreement” for “cooperative agreement or contract entered into under subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8624/c"},"text":"Pub. L. 115–334, § 8624(c)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8624/b/2/C"},"text":"Pub. L. 115–334, § 8624(b)(2)(C)","children":[],"tail":", inserted “or county” after “Governor”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s8624/b/2/D"},"text":"Pub. L. 115–334, § 8624(b)(2)(D)","children":[],"tail":", added par. (4)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
