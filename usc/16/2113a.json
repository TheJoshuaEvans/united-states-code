{"tag":"section","attrib":{"id":"id79962355-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2113a"},"text":"§ 2113a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Good neighbor authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79962356-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79962357-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized restoration services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “authorized restoration services” means similar and complementary forest, rangeland, and watershed restoration services carried out—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79962358-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on Federal land, non-Federal land, and land owned by an Indian tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79962359-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by either the Secretary or a Governor or county, as applicable, pursuant to a good neighbor agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7996235a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" County","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “county” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7996235b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate executive official of an affected county; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7996235c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any case in which multiple counties are affected, the appropriate executive official of a compact of the affected counties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7996235d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal land","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7996235e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal land” means land that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7996235f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National Forest System land; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79962360-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public land (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1702"},"text":"section 1702 of title 43","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79962361-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/a/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National Park System land; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79962362-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/a/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National Wildlife Refuge Land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79962363-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal land” does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79962364-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a component of the National Wilderness Preservation System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79962365-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal land on which the removal of vegetation is prohibited or restricted by Act of Congress or Presidential proclamation (including the applicable implementation plan); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79962366-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a wilderness study area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79962367-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forest, rangeland, and watershed restoration services","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79962368-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “forest, rangeland, and watershed restoration services” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79962369-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2113a/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities to treat insect- and disease-infected trees;","children":[],"tail":"\n"}],"tail"