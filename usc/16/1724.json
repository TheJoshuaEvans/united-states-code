{"tag":"section","attrib":{"id":"id795ceabd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1724"},"text":null,"children":[{"tag":"num","attrib":{"value":"1724"},"text":"§ 1724.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation centers and program support","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id795ceabe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1724/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and use","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id795ceabf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1724/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may establish and use conservation centers owned and operated by the Secretary for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id795ceac0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1724/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use by the Public Lands Corps; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id795ceac1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1724/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct of appropriate conservation projects under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795ceac2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1724/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for conservation centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide to a conservation center established under paragraph (1) any services, facilities, equipment, and supplies that the Secretary determines to be necessary for the conservation center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795ceac3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1724/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards for conservation centers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id795ceac4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1724/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish basic standards of health, nutrition, sanitation, and safety for all conservation centers established under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id795ceac5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1724/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the standards established under subparagraph (A) are enforced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795ceac6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1724/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As the Secretary determines to be appropriate, the Secretary may enter into a contract or other appropriate arrangement with a State or local government agency or private organization to provide for the management of a conservation center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795ceac7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1724/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Logistical support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make arrangements with the Secretary of Defense to have logistical support provided by the Armed Forces to the Corps and any conservation center established under this section, where feasible. Logistical support may include the provision of temporary tent shelters where needed, transportation, and residential supervision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795ceac8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1724/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of military installations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make arrangements with the Secretary of Defense to identify military installations and other facilities of the Department of Defense and, in consultation with the adjutant generals of the State National Guards, National Guard facilities that may be used, in whole or in part, by the Corps for training or housing Corps participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795ceac9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1724/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide any services, facilities, equipment, supplies, technical assistance, oversight, monitoring, or evaluations that are appropriate to carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795ceaca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1724/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide to Corps participants who reside in their own homes transportation to and from appropriate conservation project sites.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id795ceacb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/378/tII/s205"},"text":"Pub. L. 91–378, title II, § 205","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s105/6"},"text":"Pub. L. 103–82, title I, § 105(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/851"},"text":"107 Stat. 851","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/154/s2/d"},"text":"Pub. L. 109–154, § 2(d)","children":[],"tail":", (g)(2), "},{"tag":"date","attrib":{"date":"2005-12-30"},"text":"Dec. 30, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2891"},"text":"119 Stat. 2891","children":[],"tail":", 2893; "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tIX/s9003/c"},"text":"Pub. L. 116–9, title IX, § 9003(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/833"},"text":"133 Stat. 833","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id795ceacc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id795ceacd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id795ceace-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/9"},"text":"Pub. L. 116–9","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/154/s2/d/1"},"text":"Pub. L. 109–154, § 2(d)(1)","children":[],"tail":", inserted “and program support” after “Conservation centers” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/154/s2/d/2"},"text":"Pub. L. 109–154, § 2(d)(2)","children":[],"tail":", added subsec. (a) and struck out heading and text of former subsec. (a). Text read as follows: “The Secretary of the Interior and the Secretary of Agriculture are each authorized to provide such quarters, board, medical care, transportation, and other services, facilities, supplies, and equipment as such Secretary deems necessary in connection with the Public Lands Corps and appropriate conservation projects carried out under this subchapter and to establish and use conservation centers owned and operated by such Secretary for purposes of the Corps and such projects. The Secretaries shall establish basic standards of health, nutrition, sanitation, and safety for all conservation centers established under this section and shall assure that such standards are enforced. Where necessary or appropriate, the Secretaries may enter into contracts and other appropriate arrangements with State and local government agencies and private organizations for the management of such conservation centers.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/154/s2/g/2/A"},"text":"Pub. L. 109–154, § 2(g)(2)(A)","children":[],"tail":", substituted “Secretary may” for “Secretary of the Interior and the Secretary of Agriculture may”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/154/s2/g/2/B"},"text":"Pub. L. 109–154, § 2(g)(2)(B)","children":[],"tail":", substituted “Secretary may” for “Secretary of the Interior and the Secretary of Agriculture may”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/154/s2/d/3"},"text":"Pub. L. 109–154, § 2(d)(3)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id795ceacf-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id795cead0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s123"},"text":"section 123 of Pub. L. 103–82","children":[],"tail":", set out as an Effective Date of 1993 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1701"},"text":"section 1701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
