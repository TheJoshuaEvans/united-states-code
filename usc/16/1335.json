{"tag":"section","attrib":{"id":"id79155a4c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1335"},"text":null,"children":[{"tag":"num","attrib":{"value":"1335"},"text":"§ 1335.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A person claiming ownership of a horse or burro on the public lands shall be entitled to recover it only if recovery is permissible under the branding and estray laws of the State in which the animal is found.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79155a4d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/195/s5"},"text":"Pub. L. 92–195, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-15"},"text":"Dec. 15, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/650"},"text":"85 Stat. 650","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
