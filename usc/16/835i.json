{"tag":"section","attrib":{"id":"id78c42c6c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s835i"},"text":null,"children":[{"tag":"num","attrib":{"value":"835i"},"text":"§ 835i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts with State of Washington for maintenance and operation of fish hatcheries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In connection with fish hatcheries built or to be built as a part of the fish-protection program required on the Columbia Basin Dam project, the Secretary of the Interior is authorized to contract with the State of Washington for the maintenance and operation of any of them at the expense of said State.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78c42c6d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-09/ch794"},"text":"Oct. 9, 1940, ch. 794","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/1085"},"text":"54 Stat. 1085","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1937-05-27/ch269/s1"},"text":"May 27, 1937, ch. 269, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/208"},"text":"50 Stat. 208","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1943-03-10/ch14"},"text":"Mar. 10, 1943, ch. 14","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/57/14"},"text":"57 Stat. 14","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78c42c6e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78c42c6f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id78c42c70-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1937-05-27"},"text":"May 27, 1937","children":[],"tail":", as amended by act "},{"tag":"date","attrib":{"date":"1943-03-10"},"text":"Mar. 10, 1943","children":[],"tail":", changed name of project from “Grand Coulee Dam” to “Columbia Basin”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
