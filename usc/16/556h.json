{"tag":"section","attrib":{"id":"id78438b39-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s556h"},"text":null,"children":[{"tag":"num","attrib":{"value":"556h"},"text":"§ 556h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recognition of private contributors to Forest Service programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, on and after ","children":[{"tag":"date","attrib":{"date":"1998-10-21"},"text":"October 21, 1998","children":[],"tail":", any appropriations or funds available to the Forest Service may be used to disseminate program information to private and public individuals and organizations through the use of nonmonetary items of nominal value and to provide nonmonetary awards of nominal value and to incur necessary expenses for the nonmonetary recognition of private individuals and organizations that make contributions to Forest Service programs."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78438b3a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tII"},"text":"Pub. L. 105–277, div. A, § 101(e) [title II]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–272.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78438b3b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78438b3c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"similarProvis