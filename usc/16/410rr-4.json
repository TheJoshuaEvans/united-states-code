{"tag":"section","attrib":{"id":"id775e81fa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rr–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"410rr–4"},"text":"§ 410rr–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Within 3 full fiscal years from the date funding is made available for the purposes of preparing a general management plan, the Secretary shall develop and transmit to the Committee on Energy and Natural Resources of the Senate and the Committee on Natural Resources of the House of Representatives, a general management plan for the park consistent with the purposes of this subchapter, including (but not limited to)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id775e81fb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rr–4/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a general visitor use and interpretive program that fully considers the prehistoric and historic aspects of the national historical park including the “gateway theme” and early Spanish settlement of New Mexico;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id775e81fc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rr–4/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement on the number of visitors and types of public uses within the park which can be reasonably accommodated in accordance with the protection of its resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id775e81fd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410rr–4/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a general development plan for the park, including the estimated cost thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id775e81fe-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/313/tII/s205"},"text":"Pub. L. 101–313, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-06-27"},"text":"June 27, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/279"},"text":"104 Stat. 279","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/437/s6/d/12"},"text":"Pub. L. 103–437, § 6(d)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4584"},"text":"108 Stat. 4584","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id775e81ff-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id775e8200-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id775e8201-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/437"},"text":"Pub. L. 103–437","children":[],"tail":" in introductory provisions substituted “Natural Resources” for “Interior and Insular Affairs” after “Committee on”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
