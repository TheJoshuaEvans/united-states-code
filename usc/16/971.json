{"tag":"section","attrib":{"id":"id78d9b0ec-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971"},"text":null,"children":[{"tag":"num","attrib":{"value":"971"},"text":"§ 971.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78d9b0ed-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Convention” means the International Convention for the Conservation of Atlantic Tunas, signed at Rio de Janeiro ","children":[{"tag":"date","attrib":{"date":"1966-05-14"},"text":"May 14, 1966","children":[],"tail":", including any amendments or protocols which are or become effective for the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d9b0ee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Commission” means the International Commission for the Conservation of Atlantic Tunas provided for in article III of the Convention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d9b0ef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “conservation recommendation” means any recommendation of the Commission made pursuant to Article VIII of the Convention and acted upon favorably by the Secretary of State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s971c/a"},"text":"section 971c(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d9b0f0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Council” means the Council established within the International Commission for the Conservation of Atlantic Tunas pursuant to article V of the Convention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d9b0f1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “exclusive economic zone” means an exclusive economic zone as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1802"},"text":"section 1802 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d9b0f2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “fishing” means the catching, taking, or fishing for or the attempted catching, taking, or fishing for any species of fish covered by the Convention, or any activities in support thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d9b0f3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “fishing vessel” means any vessel engaged in catching fish or processing or transporting fish loaded on the high seas, or any vessel outfitted for such activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d9b0f4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Panel” means any panel established by the Commission pursuant to article VI of the Convention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d9b0f5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “person” means every individual, partnership, corporation, and association subject to the jurisdiction of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d9b0f6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d9b0f7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s971/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” includes each of the States of the United States, the District of Columbia, the Commonwealth of Puerto Rico, and the territories and possessions of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78d9b0f8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/70/s2"},"text":"Pub. L. 94–70, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-08-05"},"text":"Aug. 5, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/385"},"text":"89 Stat. 385","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/265/tIV/s405/a"},"text":"Pub. L. 94–265, title IV, § 405(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-13"},"text":"Apr. 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/361"},"text":"90 Stat. 361","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/33/s2"},"text":"Pub. L. 95–33, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-05-26"},"text":"May 26, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/173"},"text":"91 Stat. 173","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/43/tIII/s303/1"},"text":"Pub. L. 104–43, title III, § 303(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/384"},"text":"109 Stat. 384","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/384/tII/s202/b/1/A"},"text":"Pub. L. 105–384, title II, § 202(b)(1)(A)","children":[],"tail":", (F), "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3452"},"text":"112 Stat. 3452","children":[],"tail":", 3453.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78d9b0f9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78d9b0fa-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78d9b0fb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Pars. (4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/384"},"text":"Pub. L. 105–384","children":[],"tail":" renumbered par. (4) defining “exclusive economic zone” as par. (5) and made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1802"},"text":"section 1802 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/s303/1"},"text":"Pub. L. 104–43, § 303(1)","children":[],"tail":", added par. (3). Former par. (3) redesignated (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/s303/2"},"text":"Pub. L. 104–43, § 303(2)","children":[],"tail":", added par. (4) defining “exclusive economic zone”. Former par. (4) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/s303/1"},"text":"Pub. L. 104–43, § 303(1)","children":[],"tail":", redesignated par. (3) defining “Council” as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/s303/2"},"text":"Pub. L. 104–43, § 303(2)","children":[],"tail":", struck out par. (5) which read as follows: “The term ‘fisheries zone’ means the waters included within a zone contiguous to the territorial sea of the United States, of which the inner boundary is a line coterminous with the seaward boundary of each coastal State, and the outer boundary is a line drawn in such a manner that each point on it is two hundred nautical miles from the baseline from which the territorial sea is measured; or similar zones established by other parties to the Convention to the extent that such zones are recognized by the United States.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/s303/1"},"text":"Pub. L. 104–43, § 303(1)","children":[],"tail":", redesignated par. (4) as (5). Former par. (5) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (6) to (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/s303/1"},"text":"Pub. L. 104–43, § 303(1)","children":[],"tail":", redesignated pars. (5) to (10) as (6) to (11), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/33"},"text":"Pub. L. 95–33","children":[],"tail":" struck out the comma between “zone” and “contiguous”, substituted “two hundred” for “200”, and substituted a semicolon for a comma after “is measured”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265"},"text":"Pub. L. 94–265","children":[],"tail":", which directed the substitution of “the waters included within a zone, contiguous to the territorial sea of the United States, of which the inner boundary is a line coterminous with the seaward boundary of each coastal state, and the outer boundary is a line drawn in such a manner that each point on it is 200 nautical miles from the baseline from which the territorial sea is measured,” for “the fisheries zone established pursuant to the Act of "},{"tag":"date","attrib":{"date":"1966-10-14"},"text":"October 14, 1966","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/80/908"},"text":"80 Stat. 908","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1091–109"},"text":"16 U.S.C. 1091–109","children":[],"tail":"4)”, was executed by making the substitution for “the entire zone established by the United States under the Act of "},{"tag":"date","attrib":{"date":"1966-10-14"},"text":"October 14, 1966","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/80/908"},"text":"80 Stat. 908","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1091–109"},"text":"16 U.S.C. 1091–109","children":[],"tail":"4)”, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78d9b0fc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id78d9b0fd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265/tIV/s405/b"},"text":"Pub. L. 94–265, title IV, § 405(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-13"},"text":"Apr. 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/361"},"text":"90 Stat. 361","children":[],"tail":", provided that the amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/94/265/s405/a"},"text":"section 405(a) of Pub. L. 94–265","children":[],"tail":" to this section was to take effect "},{"tag":"date","attrib":{"date":"1977-03-01"},"text":"Mar. 1, 1977","children":[],"tail":", prior to the general amendment of title IV of "},{"tag":"ref","attrib":{"href":"/us/pl/94/265"},"text":"Pub. L. 94–265","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/104/297"},"text":"Pub. L. 104–297","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id78d9b0fe-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/tIII/s301"},"text":"Pub. L. 104–43, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/382"},"text":"109 Stat. 382","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/43/tIII/s301"},"text":"“This title [enacting sections 971j and 971k of this title, amending this section and sections 971b, 971c to 971e, 971h, and 971i of this title, and enacting provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s971c"},"text":"section 971c of this title","children":[],"tail":"] may be cited as the ‘Atlantic Tunas Convention Authorization Act of 1995’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id78d9b0ff-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/70/s1"},"text":"Pub. L. 94–70, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-08-05"},"text":"Aug. 5, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/385"},"text":"89 Stat. 385","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/70/s1"},"text":"“That this Act [enacting this chapter and provisions set out below] may be cited as the ‘Atlantic Tunas Convention Act of 1975’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"separability","id":"id78d9b100-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Separability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/70/s12"},"text":"Pub. L. 94–70, § 12","children":[],"tail":", formerly § 11, "},{"tag":"date","attrib":{"date":"1975-08-05"},"text":"Aug. 5, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/394"},"text":"89 Stat. 394","children":[],"tail":"; renumbered § 13, "},{"tag":"ref","attrib":{"href":"/us/pl/105/384/tII/s202/b/1/D"},"text":"Pub. L. 105–384, title II, § 202(b)(1)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3452"},"text":"112 Stat. 3452","children":[],"tail":"; renumbered § 12, "},{"tag":"ref","attrib":{"href":"/us/pl/114/81/tI/s107/5"},"text":"Pub. L. 114–81, title I, § 107(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-05"},"text":"Nov. 5, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/658"},"text":"129 Stat. 658","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/81/tI/s107/5"},"text":"“If any provision of this Act [this chapter] or the application of such provision to any circumstance or persons shall be held invalid, the validity of the remainder of the Act and the applicability of such provision to other circumstances or persons shall not be affected thereby.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
