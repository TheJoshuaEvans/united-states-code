{"tag":"section","attrib":{"id":"id7858e874-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s590z–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"590z–9"},"text":"§ 590z–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers and duties of Secretaries of the Interior and Agriculture; rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior and the Secretary of Agriculture are authorized to perform any and all Acts ","children":[{"tag":"ref","attrib":{"idref":"fn002462"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002462"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" and to make such rules and regulations as may be necessary and proper for the purpose of carrying out their respective functions under this subchapter and for the purpose of carrying the provisions of this subchapter into full force and effect."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7858e875-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-08-11/ch717/s11"},"text":"Aug. 11, 1939, ch. 717, § 11","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1940-10-14/ch861"},"text":"Oct. 14, 1940, ch. 861","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/1125"},"text":"54 Stat. 1125","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7858e876-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id7858e877-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id7858e878-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of other officers, employees, and agencies of Department of the Interior, with certain exceptions, to Secretary of the Interior, with power to delegate, see Reorg. Plan No. 3 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1262"},"text":"64 Stat. 1262","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
