{"tag":"section","attrib":{"id":"id79f09e5c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s4410"},"text":null,"children":[{"tag":"num","attrib":{"value":"4410"},"text":"§ 4410.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revisions to Plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall, in 1998 and at five-year intervals thereafter, undertake with the appropriate officials in Canada and Mexico to revise the goals and other elements of the Plan in accordance with the information required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s4409"},"text":"section 4409 of this title","children":[],"tail":" and with the other provisions of this chapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79f09e5d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/233/s11"},"text":"Pub. L. 101–233, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-13"},"text":"Dec. 13, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1976"},"text":"103 Stat. 1976","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/375/s2/c"},"text":"Pub. L. 103–375, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-19"},"text":"Oct. 19, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3494"},"text":"108 Stat. 3494","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79f09e5e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79f09e5f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79f09e60-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/375"},"text":"Pub. L. 103–375","children":[],"tail":" substituted “1998” for “1991”, inserted “and Mexico” after “Canada”, and struck out at end “The Secretary shall invite and encourage the appropriate officials in Mexico to participate in any revisions of the Plan.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
