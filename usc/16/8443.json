{"tag":"section","attrib":{"id":"id7a38303e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8443"},"text":null,"children":[{"tag":"num","attrib":{"value":"8443"},"text":"§ 8443.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring for improved recreation decision making","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a38303f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8443/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries shall seek to capture comprehensive recreation use data to better understand and inform decision making by the Secretaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a383040-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8443/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot protocols","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", and after public notice and comment, the Secretaries shall establish pilot protocols at not fewer than 10 land management units under the jurisdiction of each of the Secretaries to model recreation use patterns (including low-use recreation activities and dispersed recreation activities) that may not be effectively measured by existing general and opportunistic survey and monitoring protocols."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a383041-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8443/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretaries defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “Secretaries” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a383042-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8443/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary, with respect to lands under the jurisdiction of the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a383043-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8443/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture, acting through the Chief of the Forest Service, with respect to lands under the jurisdiction of the Forest Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a383044-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8443/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Commerce, acting through the Administrator of the National Oceanic and Atmospheric Administration, with respect to Federal waters under the jurisdiction of the National Oceanic and Atmospheric Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a383045-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8443/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary of Army for Civil Works, with respect to lakes and reservoirs under the jurisdiction of the U.S. Army Corps of Engineers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a383046-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tI/s133"},"text":"Pub. L. 118–234, title I, § 133","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2862"},"text":"138 Stat. 2862","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
