{"tag":"section","attrib":{"id":"id78d4f59a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941a"},"text":null,"children":[{"tag":"num","attrib":{"value":"941a"},"text":"§ 941a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78d4f59b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and implement proposals for the restoration of fish and wildlife resources in the Great Lakes Basin; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78d4f59c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s941a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide assistance to the Great Lakes Fisheries Commission, States, Indian Tribes, and other interested entities to encourage cooperative conservation, restoration and management of the fish and wildlife resources and their habitat in the Great Lakes Basin.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78d4f59d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/537/tI/s1003"},"text":"Pub. L. 101–537, title I, § 1003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-08"},"text":"Nov. 8, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2371"},"text":"104 Stat. 2371","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/646/tII/s2003"},"text":"Pub. L. 101–646, title II, § 2003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4774"},"text":"104 Stat. 4774","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/332/s2/h/1"},"text":"Pub. L. 104–332, § 2(h)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4091"},"text":"110 Stat. 4091","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/265"},"text":"Pub. L. 105–265","children":[],"tail":", §§ 3(b), 4, "},{"tag":"date","attrib":{"date":"1998-10-19"},"text":"Oct. 19, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2358"},"text":"112 Stat. 2358","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78d4f59e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78d4f59f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78d4f5a0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/537"},"text":"Pub. L. 101–537","children":[],"tail":" and title II of "},{"tag":"ref","attrib":{"href":"/us/pl/101/646"},"text":"Pub. L. 101–646","children":[],"tail":" enacted identical sections. Title II of "},{"tag":"ref","attrib":{"href":"/us/pl/101/646"},"text":"Pub. L. 101–646","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/105/265/s3/b"},"text":"Pub. L. 105–265, § 3(b)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78d4f5a1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/265/s4/1"},"text":"Pub. L. 105–265, § 4(1)","children":[],"tail":", made technical amendment to reference in original act which appears in introductory provisions as reference to this chapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/265/s4/4"},"text":"Pub. L. 105–265, § 4(4)","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “to develop proposals to implement recommendations resulting from that study; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/265/s4/2"},"text":"Pub. L. 105–265, § 4(2)","children":[],"tail":", (3), redesignated par. (2) as (1) and struck out former par. (1) which read as follows: “to carry out a comprehensive study of the status, and the assessment, management, and restoration needs, of the fishery resources of the Great Lakes Basin;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/265/s4/3"},"text":"Pub. L. 105–265, § 4(3)","children":[],"tail":", (5), redesignated par. (3) as (2) and substituted “habitat in” for “habitat of”. Former par. (2) redesignated (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/332"},"text":"Pub. L. 104–332","children":[],"tail":" made technical amendment to "},{"tag":"ref","attrib":{"href":"/us/pl/101/646/s2003"},"text":"Pub. L. 101–646, § 2003","children":[],"tail":", which enacted this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
