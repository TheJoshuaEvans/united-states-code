{"tag":"section","attrib":{"id":"id788fd63a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s746a"},"text":null,"children":[{"tag":"num","attrib":{"value":"746a"},"text":"§ 746a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation and maintenance fees for the M/V Tiglax and other vessels","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1998-10-21"},"text":"October 21, 1998","children":[],"tail":", pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s9701"},"text":"section 9701 of title 31","children":[],"tail":" and notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":", the Secretary shall charge reasonable fees for the full costs of the U.S. Fish and Wildlife Service in operating and maintaining the M/V Tiglax and other vessels, to be credited to this account and to be available until expended."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id788fd63b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tI"},"text":"Pub. L. 105–277, div. A, § 101(e) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–236.)"}],"tail":"\n"}],"tail":null}
