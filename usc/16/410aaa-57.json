{"tag":"section","attrib":{"id":"id77681fcf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410aaa–57"},"text":null,"children":[{"tag":"num","attrib":{"value":"410aaa–57"},"text":"§ 410aaa–57.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquired lands to be made part of Mojave National Preserve","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any lands acquired by the Secretary under this part shall become part of the Mojave National Preserve.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77681fd0-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/tV/s517"},"text":"Pub. L. 103–433, title V, § 517","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4495"},"text":"108 Stat. 4495","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
