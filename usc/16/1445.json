{"tag":"section","attrib":{"id":"id79345497-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445"},"text":null,"children":[{"tag":"num","attrib":{"value":"1445"},"text":"§ 1445.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" U.S.S. Monitor artifacts and materials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79345498-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In recognition of the historical significance of the wreck of the United States ship Monitor to coastal North Carolina and to the area off the coast of North Carolina known as the Graveyard of the Atlantic, the Congress directs that a suitable display of artifacts and materials from the United States ship Monitor be maintained permanently at an appropriate site in coastal North Carolina.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79345499-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclaimer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall not affect the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7934549a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The responsibilities of the Secretary to provide for the protection, conservation, and display of artifacts and materials from the United States ship Monitor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7934549b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1445/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of the Secretary to designate the Mariner’s Museum, located at Newport News, Virginia, as the principal museum for coordination of activities referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7934549c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532/tIII/s314"},"text":"Pub. L. 92–532, title III, § 314","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/627/tII/s208"},"text":"Pub. L. 100–627, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3222"},"text":"102 Stat. 3222","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/513/s15"},"text":"Pub. L. 106–513, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2391"},"text":"114 Stat. 2391","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7934549d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7934549e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7934549f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/513"},"text":"Pub. L. 106–513","children":[],"tail":" redesignated subsec. (c) as (b) and struck out former subsec. (b) which required the Secretary to submit a plan for a suitable display in coastal North Carolina of artifacts and materials of the United States ship Monitor."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id793454a0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id793454a1-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Management, Recovery, and Preservation Plan for U.S.S. MONITOR","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/283/s4"},"text":"Pub. L. 104–283, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3363"},"text":"110 Stat. 3363","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/283/s4"},"text":"“The Secretary of Commerce shall, within 12 months after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":"], prepare and submit to the Committee on Resources [now Committee on Natural Resources] of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate a long-range, comprehensive plan for the management, stabilization, preservation, and recovery of artifacts and materials of the U.S.S. MONITOR. In preparing and implementing the plan, the Secretary shall to the extent feasible utilize the resources of other Federal and private entities with expertise and capabilities that are helpful.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id793454a2-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Graveyard of the Atlantic Artifacts","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/tII/s2201"},"text":"Pub. L. 102–587, title II, § 2201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5047"},"text":"106 Stat. 5047","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/587/tII/s2201"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisition of Space","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Pursuant to section 314 of the Marine Protection, Research, and Sanctuaries Act of 1972 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1445"},"text":"16 U.S.C. 1445","children":[],"tail":") and consistent with the Cooperative Agreement entered into in October, 1989, between the National Oceanic and Atmospheric Administration and the Mariner’s Museum of Newport News, Virginia, the Secretary of Commerce shall make a grant for the acquisition of space in Hatteras Village, North Carolina, for—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the display and interpretation of artifacts recovered from the area of the Atlantic Ocean adjacent to North Carolina generally known as the Graveyard of the Atlantic, including artifacts recovered from the Monitor National Marine Sanctuary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administration and operations of the Monitor National Marine Sanctuary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To carry out the responsibilities of the Secretary of Commerce under this section, there are authorized to be appropriated to the Secretary of Commerce a total of $800,000 for fiscal years 1993 and 1994, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not more than two-thirds of the cost of space acquired under this section may be paid with amounts provided pursuant to this section.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
