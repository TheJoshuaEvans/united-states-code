{"tag":"section","attrib":{"id":"id771e1db1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s251c"},"text":null,"children":[{"tag":"num","attrib":{"value":"251c"},"text":"§ 251c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of acquired lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Lands acquired pursuant to the exchange authority contained herein shall be administered as a part of Olympic National Park in accordance with the laws and regulations applicable to the park.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id771e1db2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/455/s2"},"text":"Pub. L. 85–455, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-06-11"},"text":"June 11, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/185"},"text":"72 Stat. 185","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id771e1db3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id771e1db4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id771e1db5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Herein, referred to in text, means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/455"},"text":"Pub. L. 85–455","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-06-11"},"text":"June 11, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/185"},"text":"72 Stat. 185","children":[],"tail":", which is classified to sections 251b to 251d of this title. The “exchange authority” referred to in text is contained in section 1 of the Act, which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s251b"},"text":"section 251b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
