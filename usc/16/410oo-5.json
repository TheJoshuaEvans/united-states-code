{"tag":"section","attrib":{"id":"id775c389d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410oo–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"410oo–5"},"text":"§ 410oo–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id775c389e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410oo–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established the Natchez National Historical Park Advisory Commission (hereinafter in this subchapter referred to as the “Advisory Commission”). The Advisory Commission shall be composed of six members appointed by the Secretary. Two of such members shall be appointed from among individuals nominated by the mayor of Natchez and one from among individuals nominated by the Governor of Mississippi. Two of the members shall have expertise in historic preservation and one shall have expertise in architectural history. Any member of the Advisory Commission appointed for a definite term may serve after the expiration of his term until his successor is appointed. The Advisory Commission shall designate one of its members as Chairperson.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id775c389f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410oo–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management and development issues","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, or his designee, shall from time to time, but at least semiannually, meet and consult with the Advisory Commission on matters relating to the management and development of the park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id775c38a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410oo–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Commission shall meet on a regular basis. Notice of meetings and agenda shall be published in local newspapers which have a distribution which generally covers the area affected by the park. Advisory Commission meetings shall be held at locations and in such a manner as to ensure adequate public involvement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id775c38a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410oo–5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Advisory Commission shall serve without compensation as such, but the Secretary may pay expenses reasonably incurred in carrying out their responsibilities under this subchapter on vouchers signed by the Chairman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id775c38a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410oo–5/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013/b"},"text":"section 1013(b) of title 5","children":[],"tail":" are hereby waived with respect to this Advisory Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id775c38a3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/479/s6"},"text":"Pub. L. 100–479, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-07"},"text":"Oct. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2326"},"text":"102 Stat. 2326","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/80"},"text":"Pub. L. 117–286, § 4(a)(80)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4314"},"text":"136 Stat. 4314","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id775c38a4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id775c38a5-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id775c38a6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013/b"},"text":"section 1013(b) of title 5","children":[],"tail":"” for “section 14(b) of the Federal Advisory Committee Act (Act of "},{"tag":"date","attrib":{"date":"1972-10-06"},"text":"October 6, 1972","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/86/776"},"text":"86 Stat. 776","children":[],"tail":"),”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id775c38a7-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id775c38a8-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Commissions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory commissions established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of their establishment, unless, in the case of a commission established by the President or an officer of the Federal Government, such commission is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a commission established by the Congress, its duration is otherwise provided for by law. See sections 1001(2) and 1013 of Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
