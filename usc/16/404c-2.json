{"tag":"section","attrib":{"id":"id773d3efb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s404c–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"404c–2"},"text":"§ 404c–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fugitives from justice","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All fugitives from justice taking refuge in the park shall be subject to the same laws as fugitives from justice found in the Commonwealth of Kentucky.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id773d3efc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1942-06-05/ch341/s2"},"text":"June 5, 1942, ch. 341, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/317"},"text":"56 Stat. 317","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646/s39"},"text":"June 25, 1948, ch. 646, § 39","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/992"},"text":"62 Stat. 992","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id773d3efd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id773d3efe-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id773d3eff-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1948—Act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", struck out first sentence relating to inclusion of park in a judicial district. See "},{"tag":"ref","