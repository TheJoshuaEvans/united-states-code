{"tag":"section","attrib":{"id":"id774b6f83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410x–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"410x–2"},"text":"§ 410x–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Residential property” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As used in this subchapter, the term “residential property” means a single-family dwelling, the construction of which began before ","children":[{"tag":"date","attrib":{"date":"1991-07-01"},"text":"July 1, 1991","children":[],"tail":", together with such land on which the dwelling and appurtenant buildings are located as is in the same ownership as such dwelling and as the Secretary designates as reasonably necessary for the owner’s continued use and occupancy of the dwelling."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id774b6f84-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/321/s8"},"text":"Pub. L. 86–321, § 8","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/488/s2/5/s4"},"text":"Pub. L. 102–488, § 2(5)[(4)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3137"},"text":"106 Stat. 3137","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
