{"tag":"section","attrib":{"id":"id7784a845-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"410ffff–2"},"text":"§ 410ffff–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Weir Farm National Historical Park","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7784a846-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established, as a unit of the National Park System, the Weir Farm National Historical Park in the State of Connecticut.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7784a847-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The historical park shall consist of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7784a848-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the approximately 2-acre core parcel containing the Weir house, studio, and barn;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7784a849-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the approximately 60 acres and improvements thereon owned by the State of Connecticut;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7784a84a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the approximately 2-acre parcel of land situated in the town of Wilton, Connecticut, designated as lot 18 on a map entitled “Revised Map of Section I, Thunder Lake at Wilton, Connecticut, Scale l’=100’, ","children":[{"tag":"date","attrib":{"date":"1978-10-27"},"text":"October 27, 1978","children":[],"tail":", Ryan and Faulds Land Surveyors, Wilton, Connecticut”, that is on file in the office of the town clerk of the town of Wilton, and therein numbered 3673; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7784a84b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–2/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the approximately 0.9-acre western portion of a parcel of land situated in the town of Wilton, Connecticut, designated as Tall Oaks Road on the map referred to in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7784a84c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General depiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The parcels referred to in paragraphs (1) through (4) of subsection (b) are all as generally depicted on a map entitled “Boundary Map, Weir Farm National Historic Site, Fairfield County Connecticut”, dated June 1994. Such map shall be on file and available for public inspection in the appropriate offices of the National Park Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7784a84d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of land for visitor and administrative facilities; limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7784a84e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–2/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7784a84f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–2/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To preserve and maintain the historic setting and character of the historical park, the Secretary may acquire not more than 15 additional acres for the development of visitor and administrative facilities for the historical park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7784a850-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–2/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proximity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The property acquired under this subsection shall be within Fairfield County.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7784a851-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–2/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The acquired property shall be included within the boundary of the historical park and shall be managed and maintained as part of the historical park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7784a852-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–2/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7784a853-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–2/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintaining natural character","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall keep development of the property acquired under paragraph (1) to a minimum so that the character of the acquired property will be similar to the natural and undeveloped landscape of the property described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7784a854-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–2/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of previously developed property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in subparagraph (A) shall either prevent the Secretary from acquiring property under paragraph (1) that, prior to the Secretary’s acquisition, was developed in a manner inconsistent with subparagraph (A), or require the Secretary to remediate such previously developed property to reflect the natural character described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7784a855-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–2/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Prior to and as a prerequisite to any development of visitor and administrative facilities on the property acquired under paragraph (1), the Secretary shall enter into one or more agreements with the local governmental entity that, in accordance with applicable State law, has jurisdiction over any property acquired under paragraph (1)(A) for the purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7784a856-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–2/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing the parking, visitor, and administrative facilities for the historical park; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7784a857-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410ffff–2/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" managing bus traffic to the historical park and limiting parking for large tour buses to an offsite location.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7784a858-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/485/s4"},"text":"Pub. L. 101–485, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-31"},"text":"Oct. 31, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1171"},"text":"104 Stat. 1171","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/449/tII/s203"},"text":"Pub. L. 103–449, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4756"},"text":"108 Stat. 4756","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/363/s1/a"},"text":"Pub. L. 105–363, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-10"},"text":"Nov. 10, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3296"},"text":"112 Stat. 3296","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVII/s7102"},"text":"Pub. L. 111–11, title VII, § 7102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1190"},"text":"123 Stat. 1190","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/305/s2/b/2"},"text":"Pub. L. 116–305, § 2(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4917"},"text":"134 Stat. 4917","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7784a859-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7784a85a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7784a85b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/305/s2/b/2/A"},"text":"Pub. L. 116–305, § 2(b)(2)(A)","children":[],"tail":", substituted “Historical Park” for “Historic Site” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/305/s2/b/2/B"},"text":"Pub. L. 116–305, § 2(b)(2)(B)","children":[],"tail":", substituted “Historical Park” for “Historic Site”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/305/s2/b/2/C"},"text":"Pub. L. 116–305, § 2(b)(2)(C)","children":[],"tail":", substituted “historical park” for “historic site” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s7102/1"},"text":"Pub. L. 111–11, § 7102(1)","children":[],"tail":", substituted “within Fairfield County.” for “contiguous to or in close proximity to the property described in subsection (b).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s7102/2"},"text":"Pub. L. 111–11, § 7102(2)","children":[],"tail":", amended par. (2) generally. Prior to amendment, text read as follows: “The Secretary shall keep development of the property acquired under paragraph (1) to a minimum so that the character of the acquired property will be similar to the natural and undeveloped landscape of the property described in subsection (b).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s7102/3"},"text":"Pub. L. 111–11, § 7102(3)","children":[],"tail":", in introductory provisions, substituted “the local governmental entity that, in accordance with applicable State law, has jurisdiction over any property acquired under paragraph (1)(A)” for “the appropriate zoning authority of the town of Ridgefield, Connecticut, and the town of Wilton, Connecticut,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/363"},"text":"Pub. L. 105–363","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/449/s203/a/2"},"text":"Pub. L. 103–449, § 203(a)(2)","children":[],"tail":", struck out concluding provisions which read as follows: “both as generally depicted on a map entitled ‘Land Ownership Map, Weir Farm Historic Site’, Figure 5, dated October 1989, as contained in the National Park Service Weir Farm Suitability/Feasibility Study, February, 1990. Such map shall be on file and available for public inspection in the appropriate offices of the National Park Service.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/449/s203/a/1"},"text":"Pub. L. 103–449, § 203(a)(1)","children":[],"tail":", (3), added pars. (3) and (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/449/s203/b"},"text":"Pub. L. 103–449, § 203(b)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7784a85c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7784a85d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purpose","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/449/tII/s202"},"text":"Pub. L. 103–449, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4756"},"text":"108 Stat. 4756","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/449/tII/s202"},"text":"“The purpose of this title [see Short Title of 1994 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410ffff"},"text":"section 410ffff of this title","children":[],"tail":"] is to preserve the last remainingundeveloped parcels of the historic Weir Farm that remain in private ownership by including the parcels within the boundary of the Weir Farm National Historic Site.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
