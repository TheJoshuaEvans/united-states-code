{"tag":"section","attrib":{"id":"id79a209d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2706"},"text":null,"children":[{"tag":"num","attrib":{"value":"2706"},"text":"§ 2706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New impoundments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter authorizes (1) the loan of funds for construction of any new dam or other impoundment, or (2) the simple and expeditious licensing of any such new dam or other impoundment.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79a209d1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617/tIV/s406"},"text":"Pub. L. 95–617, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3156"},"text":"92 Stat. 3156","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
