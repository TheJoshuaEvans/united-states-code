{"tag":"section","attrib":{"id":"id79b76716-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3374"},"text":null,"children":[{"tag":"num","attrib":{"value":"3374"},"text":"§ 3374.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeiture","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79b76717-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3374/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b76718-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3374/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All fish or wildlife or plants bred, possessed, imported, exported, transported, sold, received, acquired, or purchased contrary to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3372"},"text":"section 3372 of this title","children":[],"tail":" (other than "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3372/b"},"text":"section 3372(b) of this title","children":[],"tail":"), or any regulation issued pursuant thereto, shall be subject to forfeiture to the United States notwithstanding any culpability requirements for civil penalty assessment or criminal prosecution included in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3373"},"text":"section 3373 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b76719-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3374/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All vessels, vehicles, aircraft, and other equipment used to aid in the importing, exporting, transporting, selling, receiving, acquiring, or purchasing of fish or wildlife or plants in a criminal violation of this chapter for which a felony conviction is obtained shall be subject to forfeiture to the United States if (A) the owner of such vessel, vehicle, aircraft, or equipment was at the time of the alleged illegal act a consenting party or privy thereto or in the exercise of due care should have known that such vessel, vehicle, aircraft, or equipment would be used in a criminal violation of this chapter, and (B) the violation involved the sale or purchase of, the offer of sale or purchase of, or the intent to sell or purchase, fish or wildlife or plants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b7671a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3374/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of customs laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All provisions of law relating to the seizure, forfeiture, and condemnation of property for violation of the customs laws, the disposition of such property or the proceeds from the sale thereof, and the remission or mitigation of such forfeiture, shall apply to the seizures and forfeitures incurred, or alleged to have been incurred, under the provisions of this chapter, insofar as such provisions of law are applicable and not inconsistent with the provisions of this chapter, except that all powers, rights, and duties conferred or imposed by the customs laws upon any officer or employee of the Treasury Department may, for the purposes of this chapter, also be exercised or performed by the Secretary or by such persons as he may designate: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That any warrant for search or seizure shall be issued in accordance with rule 41 of the Federal Rules of Criminal Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b7671b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3374/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Storage cost","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person convicted of an offense, or assessed a civil penalty, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3373"},"text":"section 3373 of this title","children":[],"tail":" shall be liable for the costs incurred in the storage, care, and maintenance of any fish or wildlife or plant seized in connection with the violation concerned."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b7671c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3374/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil forfeitures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Civil forfeitures under this section shall be governed by the provisions of chapter 46 of title 18.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79b7671d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/79/s5"},"text":"Pub. L. 97–79, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-11-16"},"text":"Nov. 16, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1076"},"text":"95 Stat. 1076","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVIII/s8204/d"},"text":"Pub. L. 110–234, title VIII, § 8204(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1294"},"text":"122 Stat. 1294","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VIII, § 8204(d), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2056; "},{"tag":"ref","attrib":{"href":"/us/pl/117/243/s5"},"text":"Pub. L. 117–243, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-20"},"text":"Dec. 20, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2338"},"text":"136 Stat. 2338","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79b7671e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79b7671f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79b76720-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a)(2) and (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/79"},"text":"Pub. L. 97–79","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-11-16"},"text":"Nov. 16, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1073"},"text":"95 Stat. 1073","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3371"},"text":"section 3371 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Rule 41 of the Federal Rules of Criminal Procedure, referred to in subsec. (b), is set out in the Appendix to Title 18, Crimes and Criminal Procedure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79b76721-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79b76722-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/243"},"text":"Pub. L. 117–243","children":[],"tail":" inserted “bred, possessed,” before “imported, exported,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s8204/d"},"text":"Pub. L. 110–246, § 8204(d)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79b76723-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79b76724-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id79b76725-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of the Secretary of Agriculture relating to agricultural import and entry inspection activities under this chapter to the Secretary of Homeland Security, and for treatment of related references, see sections 231, 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
