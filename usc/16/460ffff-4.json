{"tag":"section","attrib":{"id":"id78115787-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ffff–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"460ffff–4"},"text":"§ 460ffff–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of administrative jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Administrative jurisdiction over the approximately 56 acres of Federal land depicted on the Map as “USFS Transfer to BLM” is transferred from the Forest Service to the Bureau of Land Management.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78115788-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/433/tXIV/s1405"},"text":"Pub. L. 103–433, title XIV, § 1405","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tI/s1441"},"text":"Pub. L. 116–9, title I, § 1441","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/710"},"text":"133 Stat. 710","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
