{"tag":"section","attrib":{"id":"id7892204f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s760aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"760aa"},"text":"§ 760aa.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78922050-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s760aa/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78922051-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s760aa/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The National Fish Hatchery System (in this chapter referred to as the “System”)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78922052-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s760aa/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consists of more than 60 hatcheries, seven fish technology centers, 9 fish health centers, and other fisheries program offices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78922053-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s760aa/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plays an integral role in the recovery of more than 50 threatened species and endangered species and the restoration of over 100 native species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78922054-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s760aa/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides healthy fish populations that support recreational fishing opportunities, many of which are related to Federal water control structures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78922055-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s760aa/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" works with over 250 partners to help mitigate the impacts of aquatic habitat loss and invasive species.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78922056-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s760aa/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The System faces many challenges, including aging facilities, some of which date back to the late 1800s, and maintenance of intensive infrastructures such as wells, pumps, valves, pipes, filters, heaters, chillers, and treatment systems that must keep clean water moving 24 hours a day, 365 days a year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78922057-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s760aa/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" By encouraging volunteer programs and donations and fostering non-Federal partnerships with hatchery facilities, Federal funding for the hatcheries can be supplemented.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78922058-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s760aa/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" By encouraging hatchery educational programs, public awareness of the resources of the System and public participation in the conservation of aquatic resources can be promoted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78922059-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s760aa/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7892205a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s760aa/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To encourage the use of volunteers to assist the United States Fish and Wildlife Service in the management of hatcheries within the System.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7892205b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s760aa/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To facilitate partnerships between the System and non-Federal entities to promote public awareness of the resources of the System and public participation in the conservation of those resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7892205c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s760aa/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To encourage donations and other contributions by individuals and organizations to the System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7892205d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/360/s2"},"text":"Pub. L. 109–360, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-16"},"text":"Oct. 16, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2058"},"text":"120 Stat. 2058","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7892205e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7892205f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id78922060-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/360/s1"},"text":"Pub. L. 109–360, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-16"},"text":"Oct. 16, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2058"},"text":"120 Stat. 2058","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/360/s1"},"text":"“This Act [enacting this chapter] may be cited as the ‘National Fish Hatchery System Volunteer Act of 2006’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
