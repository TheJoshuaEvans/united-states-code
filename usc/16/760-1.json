{"tag":"section","attrib":{"id":"id78922003-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s760–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"760–1"},"text":"§ 760–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Kentucky fish hatchery; authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is hereby authorized to be appropriated from time to time, out of any moneys in the Treasury not otherwise appropriated, such sums as may be necessary to carry out the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s760"},"text":"section 760 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78922004-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-07-18/ch465/s2"},"text":"July 18, 1950, ch. 465, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/343"},"text":"64 Stat. 343","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78922005-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78922006-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78922007-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Appropriation for Acquisition of Lands and Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"In addition to enacting this section, section 2 of act ","children":[{"tag":"date","attrib":{"date":"1950-07-18"},"text":"July 18, 1950","children":[],"tail":", authorized a maximum appropriation of $275,000 for the acquisition of lands and water rights or interests therein and the construction and equipment of the station provided for by section 760."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
