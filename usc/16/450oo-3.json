{"tag":"section","attrib":{"id":"id77a61301-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s450oo–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"450oo–3"},"text":"§ 450oo–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Visitor accommodations and services","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior, under regulations prescribed by him, shall grant recognized members of the Minnesota Chippewa Tribe the preferential privilege to provide those visitor accommodations and services, including guide services, which he deems are necessary within the monument.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77a61302-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/910/s4"},"text":"Pub. L. 85–910, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1753"},"text":"72 Stat. 1753","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
