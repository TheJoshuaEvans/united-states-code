{"tag":"section","attrib":{"id":"id77bde068-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460a–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"460a–9"},"text":"§ 460a–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Part of Blue Ridge Parkway; administration and maintenance of parkway extension","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The parkway extension herein authorized shall be a part of the Blue Ridge Parkway and shall be administered and maintained by the Secretary of the Interior in accordance with the laws and regulations applicable thereto, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460a–4"},"text":"section 460a–4 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77bde069-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/555/s4"},"text":"Pub. L. 90–555, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-09"},"text":"Oct. 9, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/968"},"text":"82 Stat. 968","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
