{"tag":"section","attrib":{"id":"id7a3d11b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8543"},"text":null,"children":[{"tag":"num","attrib":{"value":"8543"},"text":"§ 8543.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permit administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a3d11b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8543/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permit availability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3d11b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8543/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notifications of permit availability","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3d11b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8543/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), in an area of Federal recreational lands and waters in which use by recreation service providers is allocated, if the Secretary concerned determines that visitor-use days are available for allocation to recreation service providers or holders of a commercial use authorization for outfitting and guiding, the Secretary concerned shall publish that information on the website of the agency that administers the applicable area of Federal recreational lands and waters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3d11b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8543/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this paragraph—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a3d11b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8543/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" applies to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a3d11ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8543/a/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reissuance of an existing special recreation permit or commercial use authorization for outfitting and guiding; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a3d11bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8543/a/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the issuance of a new special recreation permit or new commercial use authorization for outfitting and guiding issued to the purchaser of—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id7a3d11bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8543/a/1/B/i/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a recreation service provider that is the holder of an existing special recreation permit; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a3d11bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8543/a/1/B/i/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a holder of an existing commercial use authorization for outfitting and guiding; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a3d11be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8543/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" creates a prerequisite to the issuance of a special recreation permit or commercial use authorization for outfitting and guiding or otherwise limits the authority of the Secretary concerned—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a3d11bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8543/a/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to issue a new special recreation permit or new commercial use authorization for outfitting and guiding; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a3d11c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8543/a/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to add a new or additional use to an existing special recreation permit or an existing commercial use authorization for outfitting and guiding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3d11c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8543/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary concerned shall ensure that information published on the website under this subsection is consistently updated to provide current and correct information to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3d11c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8543/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic mail notifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary concerned shall establish a system by which potential applicants for special recreation permits or commercial use authorizations for outfitting and guiding may subscribe to receive notification by electronic mail of the availability of special recreation permits under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6802/h/1"},"text":"section 6802(h)(1) of this title","children":[],"tail":" (as amended by this title) or commercial use authorizations for outfitting and guiding."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3d11c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8543/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permit application or proposal acknowledgment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after the date on which the Secretary concerned receives a completed application or a complete proposal for a special recreation permit under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6802/h/1"},"text":"section 6802(h)(1) of this title","children":[],"tail":" (as amended by this title), the Secretary concerned shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3d11c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8543/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the applicant notice acknowledging receipt of the application or proposal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3d11c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8543/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3d11c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8543/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue a final decision with respect to the application or proposal; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3d11c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8543/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the applicant notice of a projected date for a final decision on the application or proposal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3d11c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s8543/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section applies to a concession contract issued by the National Park Service for the provision of accommodations, facilities, or services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3d11c9-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234/tIII/s314"},"text":"Pub. L. 118–234, title III, § 314","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2902"},"text":"138 Stat. 2902","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a3d11ca-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a3d11cb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a3d11cc-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"As amended by this title, referred to in subsecs. (a)(3) and (b), means as amended by title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/234"},"text":"Pub. L. 118–234","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
