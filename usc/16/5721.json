{"tag":"section","attrib":{"id":"id7a01682e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5721"},"text":null,"children":[{"tag":"num","attrib":{"value":"5721"},"text":"§ 5721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Yukon River Salmon Panel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a01682f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5721/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a016830-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5721/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be a Yukon River Salmon Panel (in this subchapter referred to as the “Panel”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a016831-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5721/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Panel shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a016832-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5721/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Secretary of State regarding the negotiation of any international agreement with Canada relating to management of salmon stocks originating from the Yukon River in Canada;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a016833-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5721/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Secretary of the Interior regarding restoration and enhancement of such salmon stocks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a016834-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5721/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform other functions relating to conservation and management of such salmon stocks as authorized by this subchapter or any other title.","children":[{"tag":"ref","attrib":{"idref":"fn002818"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002818"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a016835-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5721/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation as United States representatives on bilateral body","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State may designate the members of the Panel to be the United States representatives on any successor to the panel established by the interim agreement for the conservation of salmon stocks originating from the Yukon River in Canada agreed to through an exchange of notes between the Government of the United States and the Government of Canada on ","children":[{"tag":"date","attrib":{"date":"1995-02-03"},"text":"February 3, 1995","children":[],"tail":", if authorized by any agreement establishing such successor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a016836-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5721/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a016837-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5721/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Panel shall be comprised of six members, as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a016838-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5721/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member who is an official of the United States Government with expertise in salmon conservation and management, who shall be appointed by the Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a016839-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5721/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member who is an official of the State of Alaska with expertise in salmon conservation and management, who shall be appointed by the Governor of Alaska.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a01683a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5721/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Four members who are knowledgeable and experienced with regard to the salmon fisheries on the Yukon River, who shall be appointed by the Secretary of State in accordance with paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a01683b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5721/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointees from Alaska","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a01683c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5721/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of State shall appoint the members under paragraph (1)(C) from a list of at least three individuals nominated for each position by the Governor of Alaska.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a01683d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5721/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In making the nominations, the Governor of Alaska may consider suggestions for nominations provided by organizations with expertise in Yukon River salmon fisheries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a01683e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5721/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Governor of Alaska may make appropriate nominations to allow for appointment of, and the Secretary of State shall appoint, under paragraph (1)(C)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a01683f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5721/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least one member who is qualified to represent the interests of Lower Yukon River fishing districts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a016840-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5721/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least one member who is qualified to represent the interests of Upper Yukon River fishing districts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a016841-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5721/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At least one of the members appointed under paragraph (1)(C) shall be an Alaska Native.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a016842-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5721/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternates","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a016843-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5721/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of State may designate an alternate Panel member for each Panel member the Secretary appoints under paragraphs (1)(A) and (C), who meets the same qualifications, to serve in the absence of the Panel member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a016844-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5721/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Governor of the State of Alaska may designate an alternative Panel member for the Panel member appointed under subsection (b)(1)(B), who meets the same qualifications, to serve in the absence of that Panel member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a016845-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5721/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term length","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Panel members and alternate Panel members shall serve 4-year terms. Any individual appointed to fill a vacancy occurring before the expiration of any term shall be appointed for the remainder of that term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a016846-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5721/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reappointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Panel members and alternate Panel members shall be eligible for reappointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a016847-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5721/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Decisions of the Panel shall be made by the consensus of the Panel members appointed under subparagraphs (B) and (C) of subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a016848-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s5721/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out their functions, Panel members may consult with such other interested parties as they consider appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a016849-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/450/tII/s202"},"text":"Pub. L. 106–450, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1941"},"text":"114 Stat. 1941","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a01684a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a01684b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a01684c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter or any other title, referred to in subsec. (a)(2)(C), was in the original “this or any other title”. The reference to “any other title” probably was intended to mean a reference to any other act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a01684d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a01684e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of this subchapter as the “Yukon River Salmon Act of 2000”, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/450/s201"},"text":"section 201 of Pub. L. 106–450","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s5701"},"text":"section 5701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
