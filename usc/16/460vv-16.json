{"tag":"section","attrib":{"id":"id77eb320e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vv–16"},"text":null,"children":[{"tag":"num","attrib":{"value":"460vv–16"},"text":"§ 460vv–16.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fishing and wildlife","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed as affecting the jurisdiction or responsibilities of the State with respect to wildlife and fish in the areas designated by this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77eb320f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/499/s18"},"text":"Pub. L. 100–499, § 18","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-18"},"text":"Oct. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2499"},"text":"102 Stat. 2499","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
