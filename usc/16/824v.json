{"tag":"section","attrib":{"id":"id78b11b24-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824v"},"text":null,"children":[{"tag":"num","attrib":{"value":"824v"},"text":"§ 824v.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of energy market manipulation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78b11b25-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824v/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any entity (including an entity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s824/f"},"text":"section 824(f) of this title","children":[],"tail":"), directly or indirectly, to use or employ, in connection with the purchase or sale of electric energy or the purchase or sale of transmission services subject to the jurisdiction of the Commission, any manipulative or deceptive device or contrivance (as those terms are used in "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78j/b"},"text":"section 78j(b) of title 15","children":[],"tail":"), in contravention of such rules and regulations as the Commission may prescribe as necessary or appropriate in the public interest or for the protection of electric ratepayers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b11b26-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824v/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No private right of action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to create a private right of action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78b11b27-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-10/ch285"},"text":"June 10, 1920, ch. 285","children":[],"tail":", pt. II, § 222, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXII/s1283"},"text":"Pub. L. 109–58, title XII, § 1283","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/979"},"text":"119 Stat. 979","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
