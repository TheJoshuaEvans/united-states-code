{"tag":"section","attrib":{"id":"id775c3866-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410nn–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"410nn–4"},"text":"§ 410nn–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated such sums as may be necessary to carry out the purposes of this subchapter, but not to exceed $200,000 for planning.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id775c3867-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/348/s7"},"text":"Pub. L. 100–348, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-27"},"text":"June 27, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/658"},"text":"102 Stat. 658","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id775c3868-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id775c3869-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id775c386a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/348"},"text":"Pub. L. 100–348","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-27"},"text":"June 27, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/654"},"text":"102 Stat. 654","children":[],"tail":", known as the San Francisco Maritime National Historical Park Act of 1988, which is classified principally to this subchapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410nn"},"text":"section 410nn of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
