{"tag":"section","attrib":{"id":"id7987cb82-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1868"},"text":null,"children":[{"tag":"num","attrib":{"value":"1868"},"text":"§ 1868.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Herring study","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7987cb83-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1868/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may conduct a cooperative research program to study the issues of abundance, distribution and the role of herring as forage fish for other commercially important fish stocks in the Northwest Atlantic, and the potential for local scale depletion from herring harvesting and how it relates to other fisheries in the Northwest Atlantic. In planning, designing, and implementing this program, the Secretary shall engage multiple fisheries sectors and stakeholder groups concerned with herring management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7987cb84-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1868/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall present the final results of this study to Congress within 3 months following the completion of the study, and an interim report at the end of fiscal year 2008.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7987cb85-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1868/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $2,000,000 for fiscal year 2007 through fiscal year 2009 to conduct this study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7987cb86-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265/tIII/s319"},"text":"Pub. L. 94–265, title III, § 319","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/479/tII/s205"},"text":"Pub. L. 109–479, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3615"},"text":"120 Stat. 3615","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
