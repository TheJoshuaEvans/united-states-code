{"tag":"section","attrib":{"id":"id770b0ab0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s160"},"text":null,"children":[{"tag":"num","attrib":{"value":"160"},"text":"§ 160.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purpose of this subchapter is to preserve, for the inspiration and enjoyment of present and future generations, the outstanding scenery, geological conditions, and waterway system which constituted a part of the historic route of the Voyageurs who contributed significantly to the opening of the Northwestern United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id770b0ab1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/661/s1"},"text":"Pub. L. 91–661, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-08"},"text":"Jan. 8, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1970"},"text":"84 Stat. 1970","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
