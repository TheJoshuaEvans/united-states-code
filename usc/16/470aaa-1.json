{"tag":"section","attrib":{"id":"id781882e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"470aaa–1"},"text":"§ 470aaa–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id781882e2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall manage and protect paleontological resources on Federal land using scientific principles and expertise. The Secretary shall develop appropriate plans for inventory, monitoring, and the scientific and educational use of paleontological resources, in accordance with applicable agency laws, regulations, and policies. These plans shall emphasize interagency coordination and collaborative efforts where possible with non-Federal partners, the scientific community, and the general public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id781882e3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s470aaa–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent possible, the Secretary of the Interior and the Secretary of Agriculture shall coordinate in the implementation of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id781882e4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tVI/s6302"},"text":"Pub. L. 111–11, title VI, § 6302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1173"},"text":"123 Stat. 1173","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
