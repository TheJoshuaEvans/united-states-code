{"tag":"section","attrib":{"id":"id7760f387-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uu–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"410uu–3"},"text":"§ 410uu–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7760f388-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uu–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Areas added by this subchapter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct archeological studies of the areas added to the park by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410uu–1/a"},"text":"section 410uu–1(a) of this title","children":[],"tail":" and adjacent areas to ensure that the boundaries of those areas encompass the lands that are needed to provide adequate protection of the significant archeological resources of those areas."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7760f389-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410uu–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct archeological studies of the areas described as the “Spruce Hill Works”, the “Harness Group”, and the “Cedar Bank Works”, and may conduct archeological studies of other areas significant to Hopewellian culture, to evaluate the desirability of adding them to the park, and shall report to Congress on any such areas that are recommended for addition to the park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7760f38a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/294/s4"},"text":"Pub. L. 102–294, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-27"},"text":"May 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/186"},"text":"106 Stat. 186","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
