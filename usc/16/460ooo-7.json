{"tag":"section","attrib":{"id":"id78032712-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ooo–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"460ooo–7"},"text":"§ 460ooo–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78032713-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ooo–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of certain lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2000-12-06"},"text":"December 6, 2000","children":[],"tail":", the Secretary shall submit to Congress a report describing the most effective measures to protect the lands north of the Acquisition Planning District within the Rincon Valley, Colossal Cave area, and Agua Verde Creek corridor north of Interstate 10 to provide an ecological link to Saguaro National Park and the Rincon Mountains and contribute to local government conservation priorities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78032714-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460ooo–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of this subchapter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 5 years after ","children":[{"tag":"date","attrib":{"date":"2000-12-06"},"text":"December 6, 2000","children":[],"tail":", and at least at the end of every 10-year period thereafter, the Secretary shall submit to Congress a report describing the implementation of this subchapter, the condition of the resources and values of the Conservation Area, and the progress of the Secretary in achieving the purposes for which the Conservation Area is established as set forth in section 460"},{"tag":"i","attrib":{},"text":"ooo","children":[],"tail":"–3(a) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78032715-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/538/s8"},"text":"Pub. L. 106–538, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-06"},"text":"Dec. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2568"},"text":"114 Stat. 2568","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
