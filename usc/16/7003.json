{"tag":"section","attrib":{"id":"id7a22d22d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7003"},"text":null,"children":[{"tag":"num","attrib":{"value":"7003"},"text":"§ 7003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States representation on the scientific review group","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a22d22e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7003/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of State, shall appoint no more than 2 scientific experts to serve on the scientific review group. An individual shall not be eligible to serve on the scientific review group while serving on the joint technical committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a22d22f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7003/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual appointed under subsection (a) shall be appointed for a term of not to exceed 4 years, but shall be eligible for reappointment. An individual appointed to fill a vacancy occurring prior to the expiration of a term of office of that individual’s predecessor shall be appointed to serve for the remainder of that term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a22d230-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7003/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint appointments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to individuals appointed under subsection (a), the Secretary, jointly with the Government of Canada, may appoint to the scientific review group, from a list of names provided by the advisory panel—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a22d231-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7003/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" up to 2 independent members of the scientific review group; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a22d232-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s7003/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 public advisors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a22d233-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/479/tVI/s604"},"text":"Pub. L. 109–479, title VI, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3645"},"text":"120 Stat. 3645","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
