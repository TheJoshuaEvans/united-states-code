{"tag":"section","attrib":{"id":"id79b2ab53-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3207"},"text":null,"children":[{"tag":"num","attrib":{"value":"3207"},"text":"§ 3207.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on existing rights; water resources","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Nothing in this Act shall be construed as limiting or restricting the power and authority of the United States or—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b2ab54-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3207/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as affecting in any way any law governing appropriation or use of, or Federal right to, water on lands within the State of Alaska;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b2ab55-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3207/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as expanding or diminishing Federal or State jurisdiction, responsibility, interests, or rights in water resources development or control, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b2ab56-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s3207/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as superseding, modifying, or repealing, except as specifically set forth in this Act, existing laws applicable to the various Federal agencies which are authorized to develop or participate in the development of water resources or to exercise licensing or regulatory functions in relation thereto.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79b2ab57-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/487/tXIII/s1319"},"text":"Pub. L. 96–487, title XIII, § 1319","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-02"},"text":"Dec. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2486"},"text":"94 Stat. 2486","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79b2ab58-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79b2ab59-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79b2ab5a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in provision preceding par. (1) and par. (3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/487"},"text":"Pub. L. 96–487","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-02"},"text":"Dec. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2371"},"text":"94 Stat. 2371","children":[],"tail":", known as the Alaska National Interest Lands Conservation Act. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3101"},"text":"section 3101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
