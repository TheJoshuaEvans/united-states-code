{"tag":"section","attrib":{"id":"id7760f38e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vv"},"text":null,"children":[{"tag":"num","attrib":{"value":"410vv"},"text":"§ 410vv.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this subchapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7760f38f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vv/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to interpret the history and evolution of conservation stewardship in America;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f390-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vv/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recognize and interpret the contributions and birthplace of George Perkins Marsh, pioneering environmentalist, author of Man and Nature, statesman, lawyer, and linguist;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f391-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vv/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recognize and interpret the contributions of Frederick Billings, conservationist, pioneer in reforestation and scientific farm management, lawyer, philanthropist, and railroad builder, who extended the principles of land management introduced by Marsh;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f392-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vv/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to preserve the Marsh-Billings-Rockefeller Mansion and its surrounding lands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7760f393-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410vv/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recognize the significant contributions of Julia Billings, Mary Billings French, Mary French Rockefeller, and Laurance Spelman Rockefeller in perpetuating the Marsh-Billings-Rockefeller heritage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7760f394-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/350/s2"},"text":"Pub. L. 102–350, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-08-26"},"text":"Aug. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/934"},"text":"106 Stat. 934","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tI/s143"},"text":"Pub. L. 105–277, div. A, § 101(e) [title I, § 143]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–267.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7760f395-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7760f396-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7760f397-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Pars. (4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" substituted “Marsh-Billings-Rockefeller” for “Marsh-Billings”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7760f398-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7760f399-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/350/s1"},"text":"Pub. L. 102–350, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-08-26"},"text":"Aug. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/934"},"text":"106 Stat. 934","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/e/tI/s143"},"text":"Pub. L. 105–277, div. A, § 101(e) [title I, § 143]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-231"},"text":"112 Stat. 2681–231","children":[],"tail":", 2681–267, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/277/dA/s101/e/tI/s143"},"text":"“This Act [enacting this subchapter] may be cited as the ‘Marsh-Billings-Rockefeller National Historical Park Establishment Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
