{"tag":"section","attrib":{"id":"id7807e298-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv"},"text":null,"children":[{"tag":"num","attrib":{"value":"460vvv"},"text":"§ 460vvv.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bridgeport Winter Recreation Area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7807e299-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The approximately 7,254 acres of land in the Humboldt-Toiyabe National Forest identified as the “Bridgeport Winter Recreation Area”, as generally depicted on the map entitled “Humboldt-Toiyabe National Forest Proposed Management” and dated ","children":[{"tag":"date","attrib":{"date":"2008-09-17"},"text":"September 17, 2008","children":[],"tail":", is designated as the Bridgeport Winter Recreation Area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7807e29a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Map and legal description","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7807e29b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", the Secretary shall file a map and legal description of the Recreation Area with—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7807e29c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Natural Resources of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7807e29d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Natural Resources of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e29e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Force of law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map and legal description filed under paragraph (1) shall have the same force and effect as if included in this subtitle, except that the Secretary may correct any errors in the map and legal description.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e29f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The map and legal description filed under paragraph (1) shall be on file and available for public inspection in the appropriate offices of the Forest Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7807e2a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7807e2a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Until completion of the management plan required under subsection (d), and except as provided in paragraph (2), the Recreation Area shall be managed in accordance with the Toiyabe National Forest Land and Resource Management Plan of 1986 (as in effect on ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e2a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of snowmobiles","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The winter use of snowmobiles shall be allowed in the Recreation Area—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7807e2a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during periods of adequate snow coverage during the winter season; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7807e2a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to any terms and conditions determined to be necessary by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7807e2a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To ensure the sound management and enforcement of the Recreation Area, the Secretary shall, not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", undergo a public process to develop a winter use management plan that provides for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7807e2a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequate signage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e2a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public education program on allowable usage areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e2a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measures to ensure adequate sanitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e2a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a monitoring and enforcement strategy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e2aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measures to ensure the protection of the Trail.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7807e2ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prioritize enforcement activities in the Recreation Area—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7807e2ac-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prohibit degradation of natural resources in the Recreation Area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e2ad-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent interference with nonmotorized recreation on the Trail; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e2ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce user conflicts in the Recreation Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7807e2af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pacific Crest National Scenic Trail","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish an appropriate snowmobile crossing point along the Trail in the area identified as “Pacific Crest Trail Proposed Crossing Area” on the map entitled “Humboldt-Toiyable National Forest Proposed Management” and dated ","children":[{"tag":"date","attrib":{"date":"2008-09-17"},"text":"September 17, 2008","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7807e2b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in accordance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7807e2b1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Trails System Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1241"},"text":"16 U.S.C. 1241","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7807e2b2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any applicable environmental and public safety laws; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7807e2b3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" subject to the terms and conditions the Secretary determines to be necessary to ensure that the crossing would not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7807e2b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interfere with the nature and purposes of the Trail; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7807e2b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" harm the surrounding landscape.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7807e2b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460vvv/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military activities at United States Marine Corps Mountain Warfare Training Center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The designation of the Bridgeport Winter Recreation Area by this section is not intended to restrict or preclude the activities conducted by the United States Armed Forces at the United States Marine Corps Mountain Warfare Training Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7807e2b7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tI/s1806"},"text":"Pub. L. 111–11, title I, § 1806","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1059"},"text":"123 Stat. 1059","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dB/tXXVIII/s2874"},"text":"Pub. L. 111–84, div. B, title XXVIII, § 2874","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2697"},"text":"123 Stat. 2697","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7807e2b8-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7807e2b9-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7807e2ba-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subtitle, referred to in subsec. (b)(2), is subtitle K (§§ 1801–1808) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11"},"text":"Pub. L. 111–11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1052"},"text":"123 Stat. 1052","children":[],"tail":", which enacted this subchapter and section 539"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1274"},"text":"section 1274 of this title","children":[],"tail":", enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1274"},"text":"section 1274 of this title","children":[],"tail":", and enacted and amended provisions listed in a table of Wilderness Areas set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1132"},"text":"section 1132 of this title","children":[],"tail":". For complete classification of subtitle K to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7807e2bb-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" added subsec. (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7807e2bc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id7807e2bd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tI/s1801"},"text":"Pub. L. 111–11, title I, § 1801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1052"},"text":"123 Stat. 1052","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/11/tI/s1801"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this subtitle [subtitle K (§§ 1801–1808) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11"},"text":"Pub. L. 111–11","children":[],"tail":", see References in Text note above]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Forest","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Forest’ means the Ancient Bristlecone Pine Forest designated by section 1808(a) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s539"},"text":"16 U.S.C. 539","children":[],"tail":null},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(a)]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recreation area","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Recreation Area’ means the Bridgeport Winter Recreation Area designated by section 1806(a) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460vvv/a"},"text":"16 U.S.C. 460vvv(a)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘Secretary’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to land under the jurisdiction of the Secretary of Agriculture, the Secretary of Agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to land under the jurisdiction of the Secretary of the Interior, the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘State’ means the State of California.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Trail","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Trail’ means the Pacific Crest National Scenic Trail.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
