{"tag":"section","attrib":{"id":"id7800b674-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–81"},"text":null,"children":[{"tag":"num","attrib":{"value":"460nnn–81"},"text":"§ 460nnn–81.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of mineral withdrawal area","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7800b675-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–81/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to valid existing rights, the Federal lands and interests in lands included within the withdrawal boundary as depicted on the map referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460nnn–11/a"},"text":"section 460nnn–11(a) of this title","children":[],"tail":" are hereby withdrawn from—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7800b676-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–81/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" location, entry and patent under the mining laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7800b677-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–81/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operation of the mineral leasing and geothermal leasing laws and from the minerals materials laws and all amendments thereto except as specified in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7800b678-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460nnn–81/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Road maintenance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If consistent with the purposes of this subchapter and the management plan for the Cooperative Management and Protection Area, the Secretary may permit the development of saleable mineral resources, for road maintenance use only, in those locations identified on the map referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460nnn–11/a"},"text":"section 460nnn–11(a) of this title","children":[],"tail":" as an existing “gravel pit” within the mineral withdrawal boundaries (excluding the Wilderness Area, wilderness study areas, and designated segments of the National Wild and Scenic Rivers System) where such development was authorized before "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"October 30, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7800b679-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/399/tIV/s401"},"text":"Pub. L. 106–399, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1669"},"text":"114 Stat. 1669","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7800b67a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7800b67b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7800b67c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/399"},"text":"Pub. L. 106–399","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1655"},"text":"114 Stat. 1655","children":[],"tail":", known as the Steens Mountain Cooperative Management and Protection Act of 2000, which is classified generally to this subchapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460nnn"},"text":"section 460nnn of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
