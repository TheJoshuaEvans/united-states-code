{"tag":"section","attrib":{"id":"id776364bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410yy–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"410yy–5"},"text":"§ 410yy–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General management plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not later than 3 fiscal years after ","children":[{"tag":"date","attrib":{"date":"1992-10-27"},"text":"October 27, 1992","children":[],"tail":", the Secretary shall prepare, in consultation with the Commission, and submit to Congress a general management plan for the park containing the information described in "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s100502"},"text":"section 100502 of title 54","children":[],"tail":". Such plan shall interpret the technological and social history of the area, and the industrial complexes of the Calumet and Hecla, and Quincy Mining Companies, with equal emphasis."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id776364bd-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/543/s6"},"text":"Pub. L. 102–543, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3571"},"text":"106 Stat. 3571","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id776364be-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id776364bf-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id776364c0-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"headi