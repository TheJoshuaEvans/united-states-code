{"tag":"section","attrib":{"id":"id772c7654-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s348"},"text":null,"children":[{"tag":"num","attrib":{"value":"348"},"text":"§ 348.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entries under land laws not affected","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing herein contained shall affect any valid existing claim, location, or entry under the land laws of the United States, whether for homestead, mineral, right of way, or any other purpose whatsoever, or shall affect the rights of any such claimant, locator, or entryman to the full use and enjoyment of his land.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id772c7655-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-02-26/ch121/s2"},"text":"Feb. 26, 1917, ch. 121, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/938"},"text":"39 Stat. 938","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id772c7656-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id772c7657-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id772c7658-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Herein, referred to in text, is act ","children":[{"tag":"date","attrib":{"date":"1917-02-26"},"text":"Feb. 26, 1917","children":[],"tail":", which is classified to sections 347 to 350, 351 to 353, and 354 of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
