{"tag":"section","attrib":{"id":"id7826dc0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521b"},"text":null,"children":[{"tag":"num","attrib":{"value":"521b"},"text":"§ 521b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report of Secretary of Agriculture prior to purchase or exchange of land; contents; waiting period","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of providing information that will aid the Congress in its oversight responsibilities and improve the accountability of expenditures for the acquisition of forest land, the Secretary of Agriculture may not hereafter enter into any land purchase or exchange relating to the National Forest System of $150,000 or more for the types of lands which have been heretofore approved by the National Forest Reservation Commission until after 30 days from the date upon which a detailed report of the facts concerning such proposed purchase or transfer is submitted to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate or such earlier time as may be approved by both such committees. Such report shall contain at least the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7826dc10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidelines utilized by the Secretary in determining that the land should be acquired;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7826dc11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location and size of the land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7826dc12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase price of the land and the criteria used by the Secretary in determining such price;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7826dc13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person from whom the land is being acquired; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7826dc14-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s521b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any adjustment made by the Secretary of relative value pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1716/f/2/B/ii"},"text":"section 1716(f)(2)(B)(ii) of title 43","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7826dc15-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/588/s17/b"},"text":"Pub. L. 94–588, § 17(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-22"},"text":"Oct. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2962"},"text":"90 Stat. 2962","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/409/s6"},"text":"Pub. L. 100–409, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-20"},"text":"Aug. 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1090"},"text":"102 Stat. 1090","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/437/s6/r"},"text":"Pub. L. 103–437, § 6(r)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4587"},"text":"108 Stat. 4587","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7826dc16-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7826dc17-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7826dc18-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Forest Reservation Commission, referred to in text, was abolished and the functions thereof were transferred to the Secretary of Agriculture by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/588/s17/a/1"},"text":"section 17(a)(1) of Pub. L. 94–588","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-22"},"text":"Oct. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2961"},"text":"90 Stat. 2961","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7826dc19-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/437"},"text":"Pub. L. 103–437","children":[],"tail":" in introductory provisions substituted “Agriculture, Nutrition, and Forestry of the Senate” for “Agriculture and Forestry of the Senate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/409"},"text":"Pub. L. 100–409","children":[],"tail":" substituted “$150,000” for “$25,000” in introductory provisions and added par. (5)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
