{"tag":"section","attrib":{"id":"id78b11aee-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824s–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"824s–1"},"text":"§ 824s–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentives for cybersecurity investments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78b11aef-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824s–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78b11af0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824s–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced cybersecurity technology","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “advanced cybersecurity technology” means any technology, operational capability, or service, including computer hardware, software, or a related asset, that enhances the security posture of public utilities through improvements in the ability to protect against, detect, respond to, or recover from a cybersecurity threat (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s650"},"text":"section 650 of title 6","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b11af1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824s–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced cybersecurity technology information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “advanced cybersecurity technology information” means information relating to advanced cybersecurity technology or proposed advanced cybersecurity technology that is generated by or provided to the Commission or another Federal agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b11af2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824s–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Commission, in consultation with the Secretary of Energy, the North American Electric Reliability Corporation, the Electricity Subsector Coordinating Council, and the National Association of Regulatory Utility Commissioners, shall conduct a study to identify incentive-based, including performance-based, rate treatments for the transmission and sale of electric energy subject to the jurisdiction of the Commission that could be used to encourage—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id78b11af3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824s–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investment by public utilities in advanced cybersecurity technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b11af4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824s–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participation by public utilities in cybersecurity threat information sharing programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b11af5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824s–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentive-based rate treatment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the completion of the study under subsection (b), the Commission shall establish, by rule, incentive-based, including performance-based, rate treatments for the transmission of electric energy in interstate commerce and the sale of electric energy at wholesale in interstate commerce by public utilities for the purpose of benefitting consumers by encouraging—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78b11af6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824s–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investments by public utilities in advanced cybersecurity technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b11af7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824s–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participation by public utilities in cybersecurity threat information sharing programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b11af8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824s–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors for consideration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In issuing a rule pursuant to this section, the Commission may provide additional incentives beyond those identified in subsection (c) in any case in which the Commission determines that an investment in advanced cybersecurity technology or information sharing program costs will reduce cybersecurity risks to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78b11af9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824s–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" defense critical electric infrastructure (as defined in section 824","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–1(a) of this title) and other facilities subject to the jurisdiction of the Commission that are critical to public safety, national defense, or homeland security, as determined by the Commission in consultation with—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78b11afa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824s–1/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78b11afb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824s–1/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Homeland Security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78b11afc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824s–1/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other appropriate Federal agencies; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b11afd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824s–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilities of small or medium-sized public utilities with limited cybersecurity resources, as determined by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b11afe-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824s–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ratepayer protection","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78b11aff-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824s–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any rate approved under a rule issued pursuant to this section, including any revisions to that rule, shall be subject to the requirements of sections 824d and 824e of this title that all rates, charges, terms, and conditions—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78b11b00-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824s–1/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be just and reasonable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78b11b01-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824s–1/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be unduly discriminatory or preferential.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b11b02-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824s–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of duplicate recovery","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any rule issued pursuant to this section shall preclude rate treatments that allow unjust and unreasonable double recovery for advanced cybersecurity technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b11b03-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824s–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Single-issue rate filings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall permit public utilities to apply for incentive-based rate treatment under a rule issued under this section on a single-issue basis by submitting to the Commission a tariff schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s824d"},"text":"section 824d of this title","children":[],"tail":" that permits recovery of costs and incentives over the depreciable life of the applicable assets, without regard to changes in receipts or other costs of the public utility."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b11b04-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s824s–1/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Advanced cybersecurity technology information that is provided to, generated by, or collected by the Federal Government under subsection (b), (c), or (f) shall be considered to be critical electric infrastructure information under section 824","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–1 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78b11b05-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-10/ch285"},"text":"June 10, 1920, ch. 285","children":[],"tail":", pt. II, § 219A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tI/s40123"},"text":"Pub. L. 117–58, div. D, title I, § 40123","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/951"},"text":"135 Stat. 951","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dG/tLXXI/s7143/d/2"},"text":"Pub. L. 117–263, div. G, title LXXI, § 7143(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3663"},"text":"136 Stat. 3663","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78b11b06-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78b11b07-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78b11b08-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t6/s650"},"text":"section 650 of title 6","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t6/s1501"},"text":"section 1501 of title 6","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78b11b09-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78b11b0a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
