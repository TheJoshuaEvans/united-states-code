{"tag":"section","attrib":{"id":"id78863a32-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718p"},"text":null,"children":[{"tag":"num","attrib":{"value":"718p"},"text":"§ 718p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to issue electronic duck stamps","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78863a33-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718p/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may authorize any State to issue electronic stamps in accordance with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78863a34-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s718p/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall implement this section in consultation with State management agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78863a35-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/239/s3"},"text":"Pub. L. 113–239, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2848"},"text":"128 Stat. 2848","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
