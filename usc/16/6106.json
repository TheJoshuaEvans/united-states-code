{"tag":"section","attrib":{"id":"id7a03b238-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6106"},"text":null,"children":[{"tag":"num","attrib":{"value":"6106"},"text":"§ 6106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a03b239-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this chapter, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a03b23a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6106/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" support and coordinate existing efforts to conserve neotropical migratory bird species, through—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a03b23b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6106/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating meetings among persons involved in such efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a03b23c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6106/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting the exchange of information among such persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a03b23d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6106/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and entering into agreements with other Federal agencies, foreign, State, and local governmental agencies, and nongovernmental organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a03b23e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6106/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting such other activities as the Secretary considers to be appropriate; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a03b23f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6106/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate activities and projects under this chapter with existing efforts in order to enhance conservation of neotropical migratory bird species.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a03b240-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory group","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a03b241-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6106/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To assist in carrying out this chapter, the Secretary may convene an advisory group consisting of individuals representing public and private organizations actively involved in the conservation of neotropical migratory birds. The advisory group as a whole shall have expertise in the methods and procedures set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s6103/2"},"text":"section 6103(2) of this title","children":[],"tail":" in each country and region of the Western Hemisphere."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a03b242-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6106/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public participation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a03b243-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6106/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The advisory group shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a03b244-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6106/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that each meeting of the advisory group is open to the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a03b245-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6106/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide, at each meeting, an opportunity for interested persons to present oral or written statements concerning items on the agenda.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a03b246-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6106/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide to the public timely notice of each meeting of the advisory group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a03b247-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6106/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minutes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Minutes of each meeting of the advisory group shall be kept by the Secretary and shall be made available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a03b248-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6106/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 shall not apply to the advisory group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a03b249-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2024-04-24"},"text":"April 24, 2024","children":[],"tail":", the Secretary shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Natural Resources of the House of Representatives a report describing the implementation of subsection (b) by the Secretary, which shall include, if applicable, a description of the composition of the advisory group convened under paragraph (1) of that subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a03b24a-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/247/s7"},"text":"Pub. L. 106–247, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-07-20"},"text":"July 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/595"},"text":"114 Stat. 595","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/363/tIII/s302/f/1"},"text":"Pub. L. 109–363, title III, § 302(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2076"},"text":"120 Stat. 2076","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/128"},"text":"Pub. L. 117–286, § 4(a)(128)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4319"},"text":"136 Stat. 4319","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/51/s2/b"},"text":"Pub. L. 118–51, § 2(b)","children":[],"tail":", (d)(2), "},{"tag":"date","attrib":{"date":"2024-04-24"},"text":"Apr. 24, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1005"},"text":"138 Stat. 1005","children":[],"tail":", 1006.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a03b24b-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a03b24c-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a03b24d-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/51/s2/d/2"},"text":"Pub. L. 118–51, § 2(d)(2)","children":[],"tail":", inserted period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/51/s2/b"},"text":"Pub. L. 118–51, § 2(b)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5” for “Federal Advisory Committee Act” in heading and “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 U.S.C. App.)” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/363"},"text":"Pub. L. 109–363","children":[],"tail":" inserted at end “The advisory group as a whole shall have expertise in the methods and procedures set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6103/2"},"text":"section 6103(2) of this title","children":[],"tail":" in each country and region of the Western Hemisphere”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a03b24e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a03b24f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Encouragement To Convene","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/363/tIII/s302/f/2"},"text":"Pub. L. 109–363, title III, § 302(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2076"},"text":"120 Stat. 2076","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/363/tIII/s302/f/2"},"text":"“The Secretary of the Interior is encouraged to convene an advisory group under section 7(b)(1) of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/247"},"text":"Pub. L. 106–247","children":[],"tail":", subsec. (b)(1) of this section] by not later than 6 months after the effective date of this Act ["},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":"]. This paragraph shall not be considered to authorize delay of the schedule previously established by the United States Fish and Wildlife Service for the submission, judging, and awarding of grants.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
