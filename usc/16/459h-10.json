{"tag":"section","attrib":{"id":"id77b1f9c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459h–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"459h–10"},"text":"§ 459h–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77b1f9c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459h–10/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated not more than $22,162,000 for the acquisition of lands and interests in lands and not more than $24,224,000 for development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77b1f9c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s459h–10/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for acquisition of land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the funds authorized by subsection (a), there are authorized to be appropriated such sums as are necessary to acquire land and submerged land on and adjacent to Cat Island, Mississippi.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77b6dbca-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/660/s11"},"text":"Pub. L. 91–660, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-08"},"text":"Jan. 8, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1970"},"text":"84 Stat. 1970","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/275/s1/2"},"text":"Pub. L. 92–275, § 1(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-04-20"},"text":"Apr. 20, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/123"},"text":"86 Stat. 123","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/578/tI/s101/6"},"text":"Pub. L. 94–578, title I, § 101(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2732"},"text":"90 Stat. 2732","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/625/tI/s101/13"},"text":"Pub. L. 95–625, title I, § 101(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3471"},"text":"92 Stat. 3471","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tI/s137/e"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title I, § 137(e)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–232.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77b6dbcb-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77b6dbcc-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77b6dbcd-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625"},"text":"Pub. L. 95–625","children":[],"tail":" substituted “$24,224,000 for development.” for “$17,774,000 (June 1970 prices) for development, plus or minus such amounts, if any, as may be justified by reason of ordinary fluctuations in construction costs as indicated by engineering cost indices applicable to the types of construction involved herein.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/578"},"text":"Pub. L. 94–578","children":[],"tail":" substituted “$22,162,000” for “$3,462,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/275"},"text":"Pub. L. 92–275","children":[],"tail":" increased appropriations authorization for lands and land interests from $3,120,000 to $3,462,000 and for development from $14,779,000 (1970 prices) to $17,774,000 (June 1970 prices)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
