{"tag":"section","attrib":{"id":"id7851bc0b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"583j–2"},"text":"§ 583j–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporate powers and obligations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7851bc0c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Foundation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7851bc0d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have perpetual succession;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc0e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may conduct business throughout the several States, territories, and possessions of the United States and in foreign countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc0f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have its principal offices in the Washington, D.C. metropolitan area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc10-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–2/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall at all times maintain a designated agent in the District of Columbia authorized to accept notice or service of process for the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7851bc11-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and service of process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The serving of notice to, or service of process upon, the agent required by subsection (a)(4), or mailed to the business address of such agent, shall be deemed as service upon or notice to the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7851bc12-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall have an official seal selected by the Board which shall be judicially noticed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7851bc13-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out its purposes, the Foundation shall have, in addition to powers otherwise authorized under this subchapter, the usual powers of a corporation in the District of Columbia, including the power to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7851bc14-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–2/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept, receive, solicit, hold, administer and use any gift, devise, or bequest, either absolutely or in trust, or real or personal property or any income therefrom or other interest therein;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc15-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–2/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire by donation, gift, devise, purchase or exchange any real or personal property or interest therein;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc16-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–2/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless otherwise required by the instrument of transfer, sell, donate, lease, invest, reinvest, retain or otherwise dispose of any property or income therefrom;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc17-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–2/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" borrow money and issue bonds, debentures, or other debt instruments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc18-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–2/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sue and be sued, and complain and defend itself in any court of competent jurisdiction (except that the Directors of the Board shall not be personally liable, except for gross negligence);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc19-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–2/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into contracts or other arrangements with public agencies, private organizations, and persons and to make such payments as may be necessary to carry out the purposes thereof; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc1a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–2/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do any and all acts necessary and proper to carry out the purposes of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7851bc1b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7851bc1c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–2/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Foundation may acquire, hold and dispose of lands, waters, or other interests in real property by donation, gift, devise, purchase or exchange. For the purposes of this subchapter, an interest in real property shall include, but not be limited to, mineral and water rights, rights of way, and easements appurtenant or in gross. A gift, devise, or bequest may be accepted by the Foundation even though it is encumbered, restricted, or subject to beneficial interests of private persons if any current or future interest therein is for the benefit of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc1d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–2/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No lands or waters, or interests therein, that are owned by the Foundation and are determined by the Chief of the United States Forest Service to be valuable for purposes established in this subchapter shall be subject to condemnation by any State or political subdivision, or any agent or instrumentality thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc1e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–2/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Foundation and any income or property received or owned by it, and all transactions relating to such income or property, shall be exempt from all Federal, State, and local taxation with respect thereto.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7851bc1f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s583j–2/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Contributions, gifts, and other transfers made to or for the use of the Foundation shall be treated as contributions, gifts, or transfers to an organization exempt from taxation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7851bc20-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/593/tIV/s404"},"text":"Pub. L. 101–593, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2971"},"text":"104 Stat. 2971","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/54/tII/s201/c/1"},"text":"Pub. L. 114–54, title II, § 201(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-09-30"},"text":"Sept. 30, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/516"},"text":"129 Stat. 516","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7851bc21-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7851bc22-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7851bc23-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/54/s201/c/1/A"},"text":"Pub. L. 114–54, § 201(c)(1)(A)","children":[],"tail":", inserted “notice or” after “authorized to accept”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/54/s201/c/1/B"},"text":"Pub. L. 114–54, § 201(c)(1)(B)","children":[],"tail":", substituted “by subsection (a)(4)” for “under this paragraph”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
