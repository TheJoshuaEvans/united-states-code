{"tag":"section","attrib":{"id":"id793b8002-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1455a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1455a"},"text":"§ 1455a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coastal resource improvement program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id793b8003-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1455a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id793b8004-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1455a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “eligible coastal state” means a coastal state that for any fiscal year for which a grant is applied for under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id793b8005-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1455a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a management program approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1455"},"text":"section 1455 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id793b8006-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1455a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the judgment of the Secretary, is making satisfactory progress in activities designed to result in significant improvement in achieving the coastal management objectives specified in section 1452(2)(A) through (K) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793b8007-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1455a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “urban waterfront and port” means any developed area that is densely populated and is being used for, or has been used for, urban residential recreational, commercial, shipping or industrial purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id793b8008-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1455a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resource management improvement grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make grants to any eligible coastal state to assist that state in meeting one or more of the following objectives:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id793b8009-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1455a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The preservation or restoration of specific areas of the state that (A) are designated under the management program procedures required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1455/d/9"},"text":"section 1455(d)(9) of this title","children":[],"tail":" because of their conservation recreational, ecological, or esthetic values, or (B) contain one or more coastal resources of national significance, or for the purpose of restoring and enhancing shellfish production by the purchase and distribution of clutch material on publicly owned reef tracts."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793b800a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1455a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The redevelopment of deteriorating and underutilized urban waterfronts and ports that are designated in the state’s management program pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1455/d/2/C"},"text":"section 1455(d)(2)(C) of this title","children":[],"tail":" as areas of particular concern."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793b800b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1455a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provision of access to public beaches and other public coastal areas and to coastal waters in accordance with the planning process required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1455/d/2/G"},"text":"section 1455(d)(2)(G) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793b800c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1455a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The development of a coordinated process among State agencies to regulate and issue permits for aquaculture facilities in the coastal zone.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id793b800d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1455a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses, terms and conditions of grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id793b800e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1455a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each grant made by the Secretary under this section shall be subject to such terms and conditions as may be appropriate to ensure that the grant is used for purposes consistent with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793b800f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1455a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Grants made under this section may be used for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id793b8010-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1455a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition of fee simple and other interests in land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id793b8011-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1455a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" low-cost construction projects determined by the Secretary to be consistent with the purposes of this section, including but not limited to, paths, walkways, fences, parks, and the rehabilitation of historic buildings and structures; except that not more than 50 per centum of any grant made under this section may be used for such construction projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id793b8012-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1455a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of grants made for objectives described in subsection (b)(2)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id793b8013-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1455a/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rehabilitation or acquisition of piers to provide increased public use, including compatible commercial activity,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id793b8014-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1455a/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of shoreline stabilization measures including the installation or rehabilitation of bulkheads for the purpose of public safety or increasing public access and use, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id793b8015-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1455a/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the removal or replacement of pilings where such action will provide increased recreational use of urban waterfront areas,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"but activities provided for under this paragraph shall not be treated as construction projects subject to the limitations in paragraph (B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id793b8016-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1455a/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engineering designs, specifications, and other appropriate reports; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id793b8017-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1455a/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational, interpretive, and management costs and such other related costs as the Secretary determines to be consistent with the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id793b8018-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1455a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State matching contributions; ratio; maximum amount of grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id793b8019-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1455a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may make grants to any coastal state for the purpose of carrying out the project or purpose for which such grants are awarded, if the state matches any such grant according to the following ratios of Federal to state contributions for the applicable fiscal year: 4 to 1 for fiscal year 1986; 2.3 to 1 for fiscal year 1987; 1.5 to 1 for fiscal year 1988; and 1 to 1 for each fiscal year after fiscal year 1988.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793b801a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1455a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Grants provided under this section may be used to pay a coastal state’s share of costs required under any other Federal program that is consistent with the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793b801b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1455a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total amount of grants made under this section to any eligible coastal state for any fiscal year may not exceed an amount equal to 10 per centum of the total amount appropriated to carry out this section for such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id793b801c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1455a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of grants to local governments and other agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With the approval of the Secretary, an eligible coastal state may allocate to a local government, an areawide agency designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3334"},"text":"section 3334 of title 42","children":[],"tail":", a regional agency, or an interstate agency, a portion of any grant made under this section for the purpose of carrying out this section; except that such an allocation shall not relieve that state of the responsibility for ensuring that any funds so allocated are applied in furtherance of the state’s approved management program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id793b801d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1455a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other technical and financial assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to providing grants under this section, the Secretary shall assist eligible coastal states and their local governments in identifying and obtaining other sources of available Federal technical and financial assistance regarding the objectives of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id793b801e-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/454/tII/s306A"},"text":"Pub. L. 89–454, title II, § 306A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/464/s6"},"text":"Pub. L. 96–464, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2062"},"text":"94 Stat. 2062","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tVI/s6043/b/2"},"text":"Pub. L. 99–272, title VI, § 6043(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/124"},"text":"100 Stat. 124","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tVI"},"text":"Pub. L. 101–508, title VI","children":[],"tail":", §§ 6207, 6216(a), "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-307"},"text":"104 Stat. 1388–307","children":[],"tail":", 1388–314; "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/tII/s2205/b/9"},"text":"Pub. L. 102–587, title II, § 2205(b)(9)","children":[],"tail":"–(12), "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5051"},"text":"106 Stat. 5051","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/150/s7/1"},"text":"Pub. L. 104–150, § 7(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-06-03"},"text":"June 3, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1381"},"text":"110 Stat. 1381","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id793b801f-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id793b8020-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id793b8021-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/150"},"text":"Pub. L. 104–150","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/s2205/b/10"},"text":"Pub. L. 102–587, § 2205(b)(10)","children":[],"tail":", substituted “through (K)” for “through (I)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/s2205/b/9"},"text":"Pub. L. 102–587, § 2205(b)(9)","children":[],"tail":", made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s6216/a"},"text":"Pub. L. 101–508, § 6216(a)","children":[],"tail":". See 1990 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/s2205/b/11/A"},"text":"Pub. L. 102–587, § 2205(b)(11)(A)","children":[],"tail":", substituted “that are designated in the state’s management program pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1455/d/2/C"},"text":"section 1455(d)(2)(C) of this title","children":[],"tail":" as areas of particular concern” for “that are designated under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1454/b/3"},"text":"section 1454(b)(3) of this title","children":[],"tail":" in the state’s management program as areas of particular concern”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/s2205/b/11/B"},"text":"Pub. L. 102–587, § 2205(b)(11)(B)","children":[],"tail":", substituted “access to” for “access of” and “1455(d)(2)(G)” for “1454(b)(7)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/s2205/b/12"},"text":"Pub. L. 102–587, § 2205(b)(12)","children":[],"tail":", in closing provisions, substituted “shall not be” for “shall not by”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s6216/a"},"text":"Pub. L. 101–508, § 6216(a)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/s2205/b/9"},"text":"Pub. L. 102–587, § 2205(b)(9)","children":[],"tail":", substituted “1455(d)(9)” for “1455(c)(9)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s6207"},"text":"Pub. L. 101–508, § 6207","children":[],"tail":", inserted before period at end “, or for the purpose of restoring and enhancing shellfish production by the purchase and distribution of clutch material on publicly owned reef tracts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272"},"text":"Pub. L. 99–272","children":[],"tail":" amended par. (1) generally. Prior to amendment, par. (1) read as follows: “No grant made under this section may exceed an amount equal to 80 per centum of the cost of carrying out the purpose or project for which it was awarded.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
