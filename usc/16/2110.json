{"tag":"section","attrib":{"id":"id79962301-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s2110"},"text":null,"children":[{"tag":"num","attrib":{"value":"2110"},"text":"§ 2110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This chapter shall not authorize the Federal Government to regulate the use of private land or to deprive owners of land of their rights to property or to income from the sale of property, unless such property rights are voluntarily conveyed or limited by contract or other agreement. This chapter does not diminish in any way the rights and responsibilities of the States and political subdivisions of States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79962302-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/313/s14"},"text":"Pub. L. 95–313, § 14","children":[],"tail":", formerly § 11, "},{"tag":"date","attrib":{"date":"1978-07-01"},"text":"July 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/374"},"text":"92 Stat. 374","children":[],"tail":"; renumbered § 14 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXII"},"text":"Pub. L. 101–624, title XII","children":[],"tail":", §§ 1215(1), 1221, "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3525"},"text":"104 Stat. 3525","children":[],"tail":", 3540.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79962303-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79962304-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id79962305-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/313/s14"},"text":"section 14 of Pub. L. 95–313","children":[],"tail":" was renumbered section 17 and is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2101"},"text":"section 2101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79962306-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1221"},"text":"Pub. L. 101–624, § 1221","children":[],"tail":", amended section generally. Prior to amendment, section read as follows: “This chapter does not authorize the Federal Government to regulate the use of private land or to deprive owners of land of their rights to property or to income from the sale of property, and this chapter does not diminish in any way the rights and responsibilities of the States and political subdivisions of States.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
