{"tag":"section","attrib":{"id":"id77871934-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"410iiii–5"},"text":"§ 410iiii–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of the Brown v. Board of Education affiliated areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77871935-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On the date on which the Secretary determines that an appropriate management entity has been identified for the applicable affiliated area, as generally depicted on the map described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s410iiii–2/c/1"},"text":"section 410iiii–2(c)(1) of this title","children":[],"tail":", the following shall be established as affiliated areas of the National Park System:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id77871936-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Robert Russa Moton Museum in Farmville, Virginia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77871937-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Delaware Brown v. Board of Education Civil Rights Sites, to include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77871938-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the former Howard High School in Wilmington, Delaware;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77871939-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Claymont High School in Claymont, Delaware; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7787193a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hockessin Colored School #107 in Hockessin, Delaware.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7787193b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The John Philip Sousa Middle School in the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7787193c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each affiliated area shall be managed in a manner consistent with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7787193d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7787193e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the laws generally applicable to units of the National Park System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7787193f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77871940-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the management entity for the applicable affiliated area, shall develop a management plan for each affiliated area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77871941-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A management plan under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77871942-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be prepared in consultation and coordination with interested State, county, and local governments, management entities, organizations, and interested members of the public associated with the affiliated area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77871943-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify, as appropriate, the roles and responsibilities of the National Park Service and the management entity in administering and interpreting the affiliated area in a manner that does not interfere with existing operations and continued use of existing facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77871944-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the Secretary to coordinate the preparation and implementation of the management plan and interpretation of the affiliated area with the historical park.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77871945-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public comment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77871946-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold not less than 1 public meeting in the general proximity of each affiliated area on the proposed management plan, which shall include opportunities for public comment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77871947-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77871948-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish the draft management plan on the internet; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77871949-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an opportunity for public comment on the draft management plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7787194a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after the date on which funds are made available to carry out this section, the Secretary shall submit to the Committee on Energy and Natural Resources of the Senate and the Committee on Natural Resources of the House of Representatives the management plan for each affiliated area developed under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7787194b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide technical and financial assistance to, and enter into cooperative agreements with, the management entity for each affiliated area to provide financial assistance for the marketing, marking, interpretation, and preservation of the applicable affiliated area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7787194c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land use","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section affects—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7787194d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land use rights of private property owners within or adjacent to an affiliated area, including activities or uses on private land that can be seen or heard within an affiliated area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7787194e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority of management entities to operate and administer the affiliated areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7787194f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited role of the Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77871950-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section authorizes the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77871951-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire land in an affiliated area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77871952-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assume financial responsibility for the operation, maintenance, or management of an affiliated area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77871953-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s410iiii–5/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ownership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each affiliated area shall continue to be owned, operated, and managed by the applicable public or private owner of the land in the affiliated area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77871954-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/525/tI/s106"},"text":"Pub. L. 102–525, title I, § 106","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/123/s3/h/2"},"text":"Pub. L. 117–123, § 3(h)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-05-12"},"text":"May 12, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1199"},"text":"136 Stat. 1199","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77871955-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77871956-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id77871957-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/525/s106"},"text":"section 106 of Pub. L. 102–525","children":[],"tail":" was renumbered section 107 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s410iiii–6"},"text":"section 410iiii–6 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
