{"tag":"section","attrib":{"id":"id77957115-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s430u"},"text":null,"children":[{"tag":"num","attrib":{"value":"430u"},"text":"§ 430u.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donations of land; purchase and condemnation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior is authorized to accept donations of land, interests in land, buildings, structures, and other property within the boundaries of said national battlefield park as determined and fixed hereunder, the title and evidence of title to lands purchased to be satisfactory to the Secretary of the Interior: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That under such funds available therefor he may acquire on behalf of the United States by purchase when purchasable at prices deemed by him reasonable, otherwise by condemnation under the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s3113"},"text":"section 3113 of title 40","children":[],"tail":", such tracts of land within the said national battlefield park as may be necessary for the completion thereof."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77957116-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-06-26/ch315/s2"},"text":"June 26, 1935, ch. 315, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/423"},"text":"49 Stat. 423","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77957117-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77957118-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77957119-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3113"},"text":"Section 3113 of title 40","children":[],"tail":"” substituted in text for “the Act of "},{"tag":"date","attrib":{"date":"1888-08-01"},"text":"August 1, 1888","children":[],"tail":"” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s5/c"},"text":"Pub. L. 107–217, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1303"},"text":"116 Stat. 1303","children":[],"tail":", the first section of which enacted Title 40, Public Buildings, Property, and Works."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
