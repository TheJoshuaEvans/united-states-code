{"tag":"section","attrib":{"id":"id77d81f34-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bb–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"460bb–4"},"text":"§ 460bb–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Golden Gate National Recreation Area Advisory Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77d81f35-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bb–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established the Golden Gate National Recreation Area Advisory Commission (hereinafter referred to as the “Commission”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77d81f36-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bb–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership; appointment; term of office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall be composed of eighteen members appointed by the Secretary for terms of five years each.","children":[{"tag":"ref","attrib":{"idref":"fn002320"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002320"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should be a colon."}],"tail":" "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the terms of those members who have been either appointed or reappointed subsequent to "},{"tag":"date","attrib":{"date":"1979-01-01"},"text":"January 1, 1979","children":[],"tail":", shall be extended so as to expire not before "},{"tag":"date","attrib":{"date":"1985-06-01"},"text":"June 1, 1985","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77d81f37-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bb–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vacancy in the Commission shall be filled in the same manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77d81f38-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bb–4/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and expenses; vouchers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Commission shall serve without compensation, as such, but the Secretary may pay, upon vouchers signed by the Chairman, the expenses reasonably incurred by the Commission and its members in carrying out their responsibilities under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77d81f39-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bb–4/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations of Secretary with members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, or his designee, shall from time to time, but at least annually, meet and consult with the Commission on general policies and specific matters related to planning, administration and development affecting the recreation area and other units of the national park system in Marin, San Mateo, and San Francisco Counties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77d81f3a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bb–4/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall act and advise by affirmative vote of a majority of the members thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77d81f3b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460bb–4/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall cease to exist thirty years after ","children":[{"tag":"date","attrib":{"date":"1972-10-27"},"text":"October 27, 1972","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77d81f3c-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/589/s5"},"text":"Pub. L. 92–589, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1302"},"text":"86 Stat. 1302","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/625/tIII/s317/g"},"text":"Pub. L. 95–625, title III, § 317(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3486"},"text":"92 Stat. 3486","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/344/s4/2"},"text":"Pub. L. 96–344, § 4(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1134"},"text":"94 Stat. 1134","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/607/tX/s1001/6"},"text":"Pub. L. 96–607, title X, § 1001(6)","children":[],"tail":", (7), "},{"tag":"date","attrib":{"date":"1980-12-28"},"text":"Dec. 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3545"},"text":"94 Stat. 3545","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/525/tIII/s303"},"text":"Pub. L. 102–525, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-26"},"text":"Oct. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3441"},"text":"106 Stat. 3441","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77d81f3d-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77d81f3e-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77d81f3f-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/525"},"text":"Pub. L. 102–525","children":[],"tail":" substituted “thirty” for “twenty”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/607/s1001/6"},"text":"Pub. L. 96–607, § 1001(6)","children":[],"tail":", substituted “eighteen” for “seventeen”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/344/s4/2"},"text":"Pub. L. 96–344, § 4(2)","children":[],"tail":", substituted “five” for “three” and inserted proviso that the terms of members appointed or reappointed subsequent to "},{"tag":"date","attrib":{"date":"1979-01-01"},"text":"Jan. 1, 1979","children":[],"tail":", be extended so as not to expire before "},{"tag":"date","attrib":{"date":"1985-06-01"},"text":"June 1, 1985","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/607/s1001/7"},"text":"Pub. L. 96–607, § 1001(7)","children":[],"tail":", substituted “Marin, San Mateo,” for “Marin”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/344/s4/3"},"text":"Pub. L. 96–344, § 4(3)","children":[],"tail":", substituted “twenty” for “ten”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/625"},"text":"Pub. L. 95–625","children":[],"tail":" increased Commission membership from fifteen to seventeen."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
