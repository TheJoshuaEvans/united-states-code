{"tag":"section","attrib":{"id":"id795a799e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1672"},"text":null,"children":[{"tag":"num","attrib":{"value":"1672"},"text":"§ 1672.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General program authorization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id795a799f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1672/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of programs; preconditions and cooperation with State program directors, etc.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture (hereinafter in this subchapter referred to as the “Secretary”), under conditions the Secretary may prescribe and in cooperation with the State directors of cooperative extension service programs and eligible colleges and universities, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id795a79a0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1672/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide educational programs that enable individuals to recognize, analyze, and resolve problems dealing with renewable resources, including forest- and range-based outdoor recreation opportunities, trees and forests in urban areas, and trees and shrubs in shelterbelts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795a79a1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1672/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use educational programs to disseminate the results of research on renewable resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795a79a2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1672/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct educational programs that transfer the best available technology to those involved in the management and protection of forests and rangelands and the processing and use of their associated renewable resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795a79a3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1672/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and implement educational programs that give special attention to the educational needs of small, private nonindustrial forest landowners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795a79a4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1672/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and implement educational programs in range and fish and wildlife management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795a79a5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1672/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in providing continuing education programs for professionally trained individuals in fish and wildlife, forest, range, and watershed management and related fields;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795a79a6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1672/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" help forest and range landowners in securing technical and financial assistance to bring appropriate expertise to bear on their problems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795a79a7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1672/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" help identify areas of needed research regarding renewable resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795a79a8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1672/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cooperation with State foresters or equivalent State officials, promote public understanding of the energy conservation, economic, social, environmental, and psychological values of trees and open space in urban and community area environments and expand knowledge of the ecological relationships and benefits of trees and related resources in urban and community environments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795a79a9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1672/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a comprehensive natural resource and environmental education program for landowners and managers, public officials, and the public, with particular emphasis on youth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795a79aa-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1672/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Eligible colleges and universities” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this subchapter, the term “eligible colleges and universities” means colleges and universities eligible to be supported and maintained, in whole or in part, with funds made available under the provisions of the Act of ","children":[{"tag":"date","attrib":{"date":"1862-07-02"},"text":"July 2, 1862","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/12/503-505"},"text":"12 Stat. 503–505","children":[],"tail":", as amended; "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s301–305"},"text":"7 U.S.C. 301–305","children":[],"tail":", 307, 308), and the Act of "},{"tag":"date","attrib":{"date":"1890-08-30"},"text":"August 30, 1890","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/26/417-419"},"text":"26 Stat. 417–419","children":[],"tail":", as amended; "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s321–326"},"text":"7 U.S.C. 321–326","children":[],"tail":", 328), including Tuskegee Institute, and colleges and universities eligible for assistance under the Act of "},{"tag":"date","attrib":{"date":"1962-10-10"},"text":"October 10, 1962","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/76/806-807"},"text":"76 Stat. 806–807","children":[],"tail":", as amended; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s582a"},"text":"16 U.S.C. 582a","children":[],"tail":", 582a–1—582a–7)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795a79ab-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s1672/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of appropriate educational methods required; scope of methods","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In implementing this section, all appropriate educational methods may be used, including, but not limited to, meetings, short courses, workshops, tours, demonstrations, publications, news releases, and radio and television programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id795a79ac-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/306/s3"},"text":"Pub. L. 95–306, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-06-30"},"text":"June 30, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/349"},"text":"92 Stat. 349","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXII"},"text":"Pub. L. 101–624, title XII","children":[],"tail":", §§ 1219(b)(1), 1251(b), "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3538"},"text":"104 Stat. 3538","children":[],"tail":", 3552; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tX/s1018/d"},"text":"Pub. L. 102–237, title X, § 1018(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1905"},"text":"105 Stat. 1905","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id795a79ad-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id795a79ae-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id795a79af-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"d