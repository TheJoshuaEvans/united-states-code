{"tag":"section","attrib":{"id":"id78de6b77-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s973k"},"text":null,"children":[{"tag":"num","attrib":{"value":"973k"},"text":"§ 973k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Closed Area stowage requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"At all times while a vessel is in a Closed Area, the fishing gear of the vessel shall be stowed in such a manner as not to be readily available for fishing and in accordance with any requirements established by the Secretary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78de6b78-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/330/s13"},"text":"Pub. L. 100–330, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-07"},"text":"June 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/599"},"text":"102 Stat. 599","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXIV/s8421"},"text":"Pub. L. 119–60, div. H, title LXXXIV, § 8421","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1918"},"text":"139 Stat. 1918","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78de6b79-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78de6b7a-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78de6b7b-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" inserted “and in accordance with any requirements established by the Secretary” before period at end of first sentence and struck out at end “In particular, the boom shall be lowered as far as possible so that the vessel cannot be used for fishing, but so that the skiff is accessible for use in emergency situations; the helicopter, if any, shall be tied down; and launches shall be secured.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
