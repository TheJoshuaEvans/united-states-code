{"tag":"section","attrib":{"id":"id7832c2b4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"539m–7"},"text":"§ 539m–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subdivisions and other property interests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7832c2b5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subdivisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7832c2b6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The subdivisions are excluded from the Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c2b7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7832c2b8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Pueblo shall have no civil or criminal jurisdiction for any purpose, including adjudicatory, taxing, zoning, regulatory or any other form of jurisdiction, over the subdivisions and property interests therein, and the laws of the Pueblo shall not apply to the subdivisions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7832c2b9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The jurisdiction of the State of New Mexico and local public bodies over the subdivisions and property interests therein shall continue in effect, except that on application of the Pueblo a tract comprised of approximately 35 contiguous, nonsubdivided acres in the northern section of Evergreen Hills owned in fee by the Pueblo on ","children":[{"tag":"date","attrib":{"date":"2003-02-20"},"text":"February 20, 2003","children":[],"tail":", shall be transferred to the United States and held in trust for the Pueblo by the United States and administered by the Secretary of the Interior."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c2ba-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on trust land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Trust land described in paragraph (2)(B) shall be subject to all limitations on use pertaining to the Area contained in sections 539m to 539m–12 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7832c2bb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Piedra Lisa","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7832c2bc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Piedra Lisa tract is excluded from the Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c2bd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration of trust title","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Piedra Lisa tract—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7832c2be-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be transferred to the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7832c2bf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is declared to be held in trust for the Pueblo by the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7832c2c0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be administered by the Secretary of the Interior subject to all limitations on use pertaining to the Area contained in sections 539m to 539m–12 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c2c1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of certain restriction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The restriction contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m–4/a/4"},"text":"section 539m–4(a)(4) of this title","children":[],"tail":" shall not apply outside of Forest Service System trails."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7832c2c2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crest facilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7832c2c3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The land on which the crest facilities are located is excluded from the Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c2c4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Pueblo shall have no civil or criminal jurisdiction for any purpose, including adjudicatory, taxing, zoning, regulatory or any other form of jurisdiction, over the land on which the crest facilities are located and property interests therein, and the laws of the Pueblo, shall not apply to that land. The preexisting jurisdictional status of that land shall continue in effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7832c2c5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special use permit area","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7832c2c6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The land described in the special use permit is excluded from the Area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c2c7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7832c2c8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Pueblo shall have no civil or criminal jurisdiction for any purpose, including adjudicatory, taxing, zoning, regulatory, or any other form of jurisdiction, over the land described in the special use permit, and the laws of the Pueblo shall not apply to that land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7832c2c9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preexisting status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The preexisting jurisdictional status of that land shall continue in effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c2ca-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment to plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event the special use permit, during its existing term or any future terms or extensions, requires amendment to include other land in the Area necessary to realign the existing or any future replacement tram line, associated structures, or facilities, the land subject to that amendment shall thereafter be excluded from the Area and shall have the same status under sections 539m to 539m–12 of this title as the land currently described in the special use permit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c2cb-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land dedicated to aerial tramway and related uses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any land dedicated to aerial tramway and related uses and associated facilities that are excluded from the special use permit through expiration, termination or the amendment process shall thereafter be included in the Area, but only after final agency action no longer subject to any appeals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7832c2cc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" La Luz tract","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7832c2cd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The La Luz tract now owned in fee by the Pueblo is excluded from the Area and, on application by the Pueblo, shall be transferred to the United States and held in trust for the Pueblo by the United States and administered by the Secretary of the Interior subject to all limitations on use pertaining to the Area contained in sections 539m to 539m–12 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c2ce-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability of certain restriction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The restriction contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m–4/a/4"},"text":"section 539m–4(a)(4) of this title","children":[],"tail":" shall not apply outside of Forest Service System trails."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7832c2cf-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evergreen Hills access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that Forest Service Road 333D, as depicted on the map, is maintained in an adequate condition in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3210/a"},"text":"section 3210(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7832c2d0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pueblo fee land","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Those properties not specifically addressed in subsections ","children":[{"tag":"ref","attrib":{"idref":"fn002413"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002413"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection”."}],"tail":" (a) or (e) that are owned in fee by the Pueblo within the subdivisions are excluded from the Area and shall be subject to the jurisdictional provisions of subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7832c2d1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights-of-way","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7832c2d2-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Road rights-of-way","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7832c2d3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with the Pueblo having given its consent in the Settlement Agreement, the Secretary of the Interior shall grant to the County of Bernalillo, New Mexico, in perpetuity, the following irrevocable rights-of-way for roads identified on the map in order to provide for public access to the subdivisions, the special use permit land and facilities, the other leasehold and easement rights and interests of the Sandia Peak Tram Company and its affiliates, the Sandia Heights South Subdivision, and the Area—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7832c2d4-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/h/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a right-of-way for Tramway Road;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7832c2d5-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/h/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a right-of-way for Juniper Hill Road North;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7832c2d6-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/h/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a right-of-way for Juniper Hill Road South;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7832c2d7-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/h/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a right-of-way for Sandia Heights Road; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7832c2d8-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/h/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a right-of-way for Juan Tabo Canyon Road (Forest Road No. 333).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7832c2d9-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The road rights-of-way shall be subject to the following conditions:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7832c2da-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/h/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such rights-of-way may not be expanded or otherwise modified without the Pueblo’s written consent, but road maintenance to the rights-of-way shall not be subject to Pueblo consent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7832c2db-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/h/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rights-of-way shall not authorize uses for any purpose other than roads without the Pueblo’s written consent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7832c2dc-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/h/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in the Settlement Agreement, existing rights-of-way or leasehold interests and obligations held by the Sandia Peak Tram Company and its affiliates, shall be preserved, protected, and unaffected by sections 539m to 539m–12 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c2dd-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utility rights-of-way","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with the Pueblo having given its consent in the Settlement Agreement, the Secretary of the Interior shall grant irrevocable utility rights-of-way in perpetuity across Pueblo land to appropriate utility or other service providers serving Sandia Heights Addition, Sandia Heights North Units I, II, and 3, the special use permit land, Tierra Monte, and Valley View Acres, including rights-of-way for natural gas, power, water, telecommunications, and cable television services. Such rights-of-way shall be within existing utility corridors as depicted on the map or, for certain water lines, as described in the existing grant of easement to the Sandia Peak Utility Company: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That use of water line easements outside the utility corridors depicted on the map shall not be used for utility purposes other than water lines and associated facilities. Except where above-ground facilities already exist, all new utility facilities shall be installed underground unless the Pueblo agrees otherwise. To the extent that enlargement of existing utility corridors is required for any technologically-advanced telecommunication, television, or utility services, the Pueblo shall not unreasonably withhold agreement to a reasonable enlargement of the easements described above."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7832c2de-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forest Service rights-of-way","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with the Pueblo having given its consent in the Settlement Agreement, the Secretary of the Interior shall grant to the Forest Service the following irrevocable rights-of-way in perpetuity for Forest Service trails crossing land of the Pueblo in order to provide for public access to the Area and through Pueblo land—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7832c2df-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a right-of-way for a portion of the Crest Spur Trail (Trail No. 84), crossing a portion of the La Luz tract, as identified on the map;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7832c2e0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a right-of-way for the extension of the Foothills Trail (Trail No. 365A), as identified on the map; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7832c2e1-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s539m–7/h/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a right-of-way for that portion of the Piedra Lisa North-South Trail (Trail No. 135) crossing the Piedra Lisa tract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7832c2e2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dF/tIV/s409"},"text":"Pub. L. 108–7, div. F, title IV, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/287"},"text":"117 Stat. 287","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7832c2e3-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7832c2e4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7832c2e5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 539m to 539m–12 of this title, referred to in subsecs. (a)(3), (b)(2)(C), (d)(3), (e)(1), and (h)(1)(B)(iii), was in the original “this title”, meaning title IV of div. F of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/279"},"text":"117 Stat. 279","children":[],"tail":", which is classified generally to sections 539m to 539m–12 of this title. For complete classification of title IV to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s539m"},"text":"section 539m of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
