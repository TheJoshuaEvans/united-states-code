{"tag":"section","attrib":{"id":"id7a0fc071-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6553"},"text":null,"children":[{"tag":"num","attrib":{"value":"6553"},"text":"§ 6553.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accelerated information gathering regarding forest-damaging insects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a0fc072-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6553/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information gathering","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Forest Service and United States Geological Survey, as appropriate, shall establish an accelerated program—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0fc073-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6553/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to plan, conduct, and promote comprehensive and systematic information gathering on forest-damaging insects and associated diseases, including an evaluation of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0fc074-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6553/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" infestation prevention and suppression methods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc075-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6553/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effects of infestations and associated disease interactions on forest ecosystems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc076-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6553/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restoration of forest ecosystem efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc077-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6553/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilization options regarding infested trees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc078-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6553/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" models to predict the occurrence, distribution, and impact of outbreaks of forest-damaging insects and associated diseases;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fc079-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6553/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist land managers in the development of treatments and strategies to improve forest health and reduce the susceptibility of forest ecosystems to severe infestations of forest-damaging insects and associated diseases on Federal land and State and private land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fc07a-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6553/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to disseminate the results of the information gathering, treatments, and strategies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0fc07b-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6553/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation and assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0fc07c-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6553/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish and carry out the program in cooperation with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0fc07d-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6553/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scientists from colleges and universities (including forestry schools, land grant colleges and universities, and 1890 Institutions);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc07e-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6553/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal, State, and local agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0fc07f-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6553/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private and industrial landowners; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0fc080-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s6553/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate such colleges and universities to assist in carrying out the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0fc081-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/148/tIV/s403"},"text":"Pub. L. 108–148, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-03"},"text":"Dec. 3, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1909"},"text":"117 Stat. 1909","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
