{"tag":"section","attrib":{"id":"id772300ae-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s272a"},"text":null,"children":[{"tag":"num","attrib":{"value":"272a"},"text":"§ 272a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id772300af-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s272a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to acquire by donation, purchase with donated or appropriated funds, transfer from any Federal agency, exchange or otherwise, the lands and interests in lands described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s272"},"text":"section 272 of this title","children":[],"tail":", except that lands or interests therein owned by the State of Utah, or any political subdivision thereof, may be acquired only with the approval of such State or political subdivision."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id772300b0-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s272a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lost Spring Canyon Addition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"1998-10-30"},"text":"October 30, 1998","children":[],"tail":", the Secretary shall transfer jurisdiction over the Federal land contained in the Lost Spring Canyon Addition from the Bureau of Land Management to the National Park Service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id772300b1-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/155/s2"},"text":"Pub. L. 92–155, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-11-12"},"text":"Nov. 12, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/422"},"text":"85 Stat. 422","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/329/s2/b"},"text":"Pub. L. 105–329, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3060"},"text":"112 Stat. 3060","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id772300b2-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id772300b3-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id772300b4-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/329"},"text":"Pub. L. 105–329","children":[],"tail":" inserted section catchline and subsec. (a) designation and heading and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
