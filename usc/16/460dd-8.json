{"tag":"section","attrib":{"id":"id77da8fb3-6992-11f1-ab3f-8b4c043f8cd5","identifier":"/us/usc/t16/s460dd–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"460dd–8"},"text":"§ 460dd–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to President","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Within two years from ","children":[{"tag":"date","attrib":{"date":"1972-10-27"},"text":"October 27, 1972","children":[],"tail":", the Secretary shall report to the President, in accordance with subsections 3(c) and 3(d) of the Wilderness Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1132/c"},"text":"16 U.S.C. 1132(c)","children":[],"tail":" and (d)], his recommendations as to the suitability or nonsuitability of any area within the recreation area for preservation as wilderness, and any designation of any such area as wilderness shall be in accordance with said Wilderness Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"16 U.S.C. 1131","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77da8fb4-6992-11f1-ab3f-8b4c043f8cd5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/593/s9"},"text":"Pub. L. 92–593, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1313"},"text":"86 Stat. 1313","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77da8fb5-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77da8fb6-6992-11f1-ab3f-8b4c043f8cd5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77da8fb7-6992-11f1-ab3f-8b4c043f8cd5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Wilderness Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/577"},"text":"Pub. L. 88–577","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-09-03"},"text":"Sept. 3, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/890"},"text":"78 Stat. 890","children":[],"tail":", which is classified generally to chapter 23 (§ 1131 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1131"},"text":"section 1131 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
